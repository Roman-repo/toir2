				<c>
					<f>12</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>4. Исправлены выявленные ошибки.</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>es</v8:lang>
							<v8:content>4. Son corregidas las faltas reveladas.</v8:content>
						</v8:item>
						<v8:item>
