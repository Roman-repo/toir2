	<rowsItem>
		<index>209</index>
		<row>
			<c>
				<i>1</i>
				<c>
					<f>13</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>2. Версия СЛК обновлена до 3.0.16.7731.</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>es</v8:lang>
							<v8:content>2. La versión СЛК es renovada hasta 3.0.16.7731.</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>2. The SLK version has been updated to 3.0.16.7731.</v8:content>
						</v8:item>
