Функция ПолучитьОбъектыРемонтаПодчиненныеТиповым(МассивТиповыхОР)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	торо_ТиповыеОР.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_СписокТОР
	|ИЗ
	|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
	|ГДЕ
	|	торо_ТиповыеОР.Ссылка В ИЕРАРХИИ(&МассивТОР)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	торо_ОбъектыРемонта.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СписокТОР КАК ВТ_СписокТОР
	|		ПО торо_ОбъектыРемонта.ТиповойОР = ВТ_СписокТОР.Ссылка";
	
	Запрос.УстановитьПараметр("МассивТОР", МассивТиповыхОР);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат.ВыгрузитьКолонку("Ссылка");
	
