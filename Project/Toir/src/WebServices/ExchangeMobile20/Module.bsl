			ДобавляемыйОбъект.Показатель = ?(ЗначениеЗаполнено(СтруктураПоказателей.Показатель),СтруктураПоказателей.Показатель.Код, 0);
			Список.рс_ИзмеряемыеПоказателиОР.Добавить(ДобавляемыйОбъект);	
		КонецЦикла;
		
	КонецЕсли;
	
	Если Список.рс_ИзмеряемыеПоказателиОР.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат Список;
	КонецЕсли;	
	
