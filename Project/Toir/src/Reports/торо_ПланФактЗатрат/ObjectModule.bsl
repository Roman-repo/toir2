#Область Локализация

Функция дс_ДобавитьПараметрыВТекстЗапроса(ТекстЗапроса)
	СтрокиЗамены = Новый Соответствие;

	СтрокиЗамены.Вставить("""План-график ремонта""", 		"&ПланГрафикРемонта");
	СтрокиЗамены.Вставить("""Материальные затраты""", 		"&МатериальныеЗатраты");
	СтрокиЗамены.Вставить("""Выявленные дефекты""", 		"&ВыявленныеДефекты");
	СтрокиЗамены.Вставить("""Внешние основания""", 			"&ВнешниеОснования");
	СтрокиЗамены.Вставить("""Регламентные мероприятия""", 	"&РегламентныеМероприятия");
	СтрокиЗамены.Вставить("""Затраты запчастей""", 			"&ЗатратыЗапчастей");

	Для каждого КодЗамены Из СтрокиЗамены Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, КодЗамены.Ключ, КодЗамены.Значение);
	КонецЦикла;
	
	Возврат ТекстЗапроса;
КонецФункции
 
Процедура дс_ДобавитьПараметрыВСКД()
	Переводы = Новый Соответствие;
	
	Переводы.Вставить("ПланГрафикРемонта", 			НСтр("es='Horario de reparación';ru='План-график ремонта';en='Repair plan-schedule'"));
	Переводы.Вставить("МатериальныеЗатраты", 		НСтр("es='Los costos de los materiales';ru='Материальные затраты';en='Material costs'"));
	Переводы.Вставить("ВыявленныеДефекты", 			НСтр("es='Los defectos identificados';ru='Выявленные дефекты';en='Defects Identified'"));
	Переводы.Вставить("ВнешниеОснования", 			НСтр("es='Externos de la fundación';ru='Внешние основания';en='External bases'"));
	Переводы.Вставить("РегламентныеМероприятия", 	НСтр("es='Actividades de mantenimiento rutinario';ru='Регламентные мероприятия';en='Regulatory activities'"));
	Переводы.Вставить("ЗатратыЗапчастей", 			НСтр("es='El costo de las partes de recambio';ru='Затраты запчастей';en='The cost of spare parts'"));
	
	Для каждого Перевод Из Переводы Цикл
		Если СхемаКомпоновкиДанных.Параметры.Найти(Перевод.Ключ) = Неопределено Тогда
			НовыйПараметр = СхемаКомпоновкиДанных.Параметры.Добавить();
			НовыйПараметр.Имя 			= Перевод.Ключ;
			НовыйПараметр.Значение 		= Перевод.Значение;
			НовыйПараметр.Использование = ИспользованиеПараметраКомпоновкиДанных.Всегда;
			НовыйПараметр.ОграничениеИспользования = Истина;
		КонецЕсли; 
	КонецЦикла; 
КонецПроцедуры

