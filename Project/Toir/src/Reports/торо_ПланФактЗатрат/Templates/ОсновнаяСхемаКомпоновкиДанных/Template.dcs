	<totalField>
		<dataPath>ОтклонениеКоличествоНоменклатура</dataPath>
		<expression>ВЫБОР
    КОГДА Количество(Различные Номенклатура.ЕдиницаИзмерения) &gt; 1
        ТОГДА 0
    ИНАЧЕ Сумма(ЕстьNULL(ФактическоеКоличествоНоменклатура, 0)) - Сумма(ЕстьNULL(ПлановоеКоличествоНоменклатура,0 ))
КОНЕЦ
</expression>
		<group>Номенклатура</group>
