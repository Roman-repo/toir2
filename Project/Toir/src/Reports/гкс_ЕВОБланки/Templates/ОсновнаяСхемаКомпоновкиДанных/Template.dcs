		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Мероприятие</dataPath>
			<field>Мероприятие</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Меры по недопущению</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Prevention measures</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДнейДоОкончанияСрокаИсполненияМероприятия</dataPath>
			<field>ДнейДоОкончанияСрокаИсполненияМероприятия</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дней до окончания срока исполнения мероприятия, (сутки/дни)</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Days before the event completion deadline</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВремяРеагирования</dataPath>
			<field>ВремяРеагирования</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Время реагирования ТС (мин.)</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВремяРемонта</dataPath>
			<field>ВремяРемонта</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Время ремонта (мин.)</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗонаОтветственности</dataPath>
			<field>ЗонаОтветственности</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Зона ответственности</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Влияние</dataPath>
			<field>Влияние</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Влияние</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Выполнено</dataPath>
			<field>Выполнено</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Отметки выполненных мероприятий</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ответственный</dataPath>
			<field>Ответственный</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Ответственный по мероприятиям</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипПроблемы</dataPath>
			<field>ТипПроблемы</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВремяНачалаОстановки</dataPath>
			<field>ВремяНачалаОстановки</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата останова</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Срок</dataPath>
			<field>Срок</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Срок исполнения мероприятий</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПовторныйОтказ</dataPath>
			<field>ПовторныйОтказ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Повторный отказ</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	гкс_ЕВОБланк.Ссылка КАК Ссылка,
	гкс_ЕВОБланк.Номер КАК Номер,
	гкс_ЕВОБланк.Дата КАК Дата,
	гкс_ЕВОБланк.Подразделение КАК Подразделение,
	гкс_ЕВОБланк.ДокументОснование КАК ДокументОснование,
	гкс_ЕВОБланк.КорневаяПричина КАК КорневаяПричина,
	гкс_ЕВОБланк.ТипКорневойПричины КАК ТипКорневойПричины,
	ВЫБОР
		КОГДА гкс_ЕВОБланк.ВремяЗапуска = ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА 0
		ИНАЧЕ РАЗНОСТЬДАТ(гкс_ЕВОБланк.ВремяНачалаОстановки, гкс_ЕВОБланк.ВремяЗапуска, МИНУТА)
	КОНЕЦ КАК ВремяПростояОборудования
	// Гкс+[TOIR20-512] Вялых Д.А. от 22.01.2025. Добавлено:{
	//,гкс_ЕВОБланк.ВидНеисправности КАК ЗонаОтветственности,
	,гкс_ЕВОБланк.ЗонаОтветственности КАК ЗонаОтветственности,
	ВЫБОР
		КОГДА гкс_ЕВОБланк.ВремяНачалаТС = ДАТАВРЕМЯ(1, 1, 1)
				ИЛИ гкс_ЕВОБланк.ВремяОкончанияТС = ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
		ИНАЧЕ РАЗНОСТЬДАТ(гкс_ЕВОБланк.ВремяНачалаТС, гкс_ЕВОБланк.ВремяОкончанияТС, МИНУТА)
	КОНЕЦ КАК ВремяРемонта,
	ВЫБОР
		КОГДА гкс_ЕВОБланк.ВремяНачалаТС = ДАТАВРЕМЯ(1, 1, 1)
				ИЛИ гкс_ЕВОБланк.ВремяОкончанияТС = ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
		ИНАЧЕ РАЗНОСТЬДАТ(гкс_ЕВОБланк.ВремяВызоваТС, гкс_ЕВОБланк.ВремяНачалаТС, МИНУТА)
	КОНЕЦ КАК ВремяРеагирования
	// } Гкс-[TOIR20-512] Вялых Д.А. от 22.01.2025. 
	// Гкс+[TOIR20-520] Вялых Д.А. от 29.01.2025. Добавлено:{
    , гкс_ЕВОБланк.ТипПроблемы
	// } Гкс-[TOIR20-520] Вялых Д.А. от 29.01.2025.
	// Гкс+[TOIR20-551] Вялых Д.А. от 03.03.2025. Добавлено:{
    , ВЫБОР
		КОГДА гкс_ЕВОБланк.ВремяНачалаОстановки = ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
		ИНАЧЕ ДОБАВИТЬКДАТЕ(гкс_ЕВОБланк.ВремяНачалаОстановки, ЧАС, &amp;СдвигЧП + 1)
	КОНЕЦ КАК ВремяНачалаОстановки, 
	гкс_ЕВОБланк.гкс_ПовторныйОтказ КАК ПовторныйОтказ
	// } Гкс-[TOIR20-551] Вялых Д.А. от 03.03.2025.
	
	
ПОМЕСТИТЬ ВсеБланки
ИЗ
	Документ.гкс_ЕВОБланк КАК гкс_ЕВОБланк
{ГДЕ
	(гкс_ЕВОБланк.Дата &lt;= &amp;ДатаОкончания
			И гкс_ЕВОБланк.Дата &gt;= &amp;ДатаНачала)}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	торо_ВыявленныеДефектыСписокДефектов.ОбъектРемонта КАК ФМ,
	торо_ВыявленныеДефектыСписокДефектов.ОтказавшийЭлемент КАК ОР,
	торо_ВыявленныеДефектыСписокДефектов.ВидДефекта КАК ВидПоломки,
	(ВЫРАЗИТЬ(торо_ВыявленныеДефектыСписокДефектов.гкс_СимптомДефекта.Наименование КАК СТРОКА(300))) + " " + торо_ВыявленныеДефектыСписокДефектов.ДефектОписание КАК ОписаниеПроблемы,
	ВсеБланки.ДокументОснование КАК ДокументОснование 
	// Гкс+[TOIR20-512] Вялых Д.А. от 22.01.2025. Добавлено:{
	,торо_ВыявленныеДефектыСсылка.гкс_Влияние КАК Влияние 
	// } Гкс-[TOIR20-512] Вялых Д.А. от 22.01.2025.
	
ПОМЕСТИТЬ ИзДефектов
ИЗ
	ВсеБланки КАК ВсеБланки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
		ПО ВсеБланки.ДокументОснование = торо_ВыявленныеДефектыСписокДефектов.Ссылка
			И (торо_ВыявленныеДефектыСписокДефектов.НомерСтроки = 1)
		// Гкс+[TOIR20-512] Вялых Д.А. от 22.01.2025. Добавлено:{	 
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты КАК торо_ВыявленныеДефектыСсылка 
		ПО торо_ВыявленныеДефектыСписокДефектов.Ссылка = торо_ВыявленныеДефектыСсылка.Ссылка
		// } Гкс-[TOIR20-512] Вялых Д.А. от 22.01.2025.
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	гкс_ЕВОБланкМероприятияПоПредупреждению.Мероприятие КАК Мероприятие,
	ВсеБланки.Ссылка КАК Ссылка,
	ВсеБланки.Номер КАК Номер,
	ВсеБланки.Дата КАК Дата,
	ВсеБланки.Подразделение КАК Подразделение,
	ВсеБланки.ДокументОснование КАК ДокументОснование,
	ВсеБланки.КорневаяПричина КАК КорневаяПричина,
	ВсеБланки.ТипКорневойПричины КАК ТипКорневойПричины,
	ВсеБланки.ВремяПростояОборудования КАК ВремяПростояОборудования,
	ИзДефектов.ФМ КАК ФМ,
	ИзДефектов.ОР КАК ОР,
	ИзДефектов.ВидПоломки КАК ВидПоломки,
	ИзДефектов.ОписаниеПроблемы КАК ОписаниеПроблемы,
	РАЗНОСТЬДАТ( &amp;ТекДата,гкс_ЕВОБланкМероприятияПоПредупреждению.Срок, ДЕНЬ) КАК ДнейДоОкончанияСрокаИсполненияМероприятия
	// Гкс+[TOIR20-512] Вялых Д.А. от 22.01.2025. Добавлено:{
	,ВсеБланки.ЗонаОтветственности КАК ЗонаОтветственности,
	ИзДефектов.Влияние КАК Влияние,
	гкс_ЕВОБланкМероприятияПоПредупреждению.Выполнено КАК Выполнено,
	гкс_ЕВОБланкМероприятияПоПредупреждению.Ответственный КАК Ответственный,
	ВсеБланки.ВремяРемонта КАК ВремяРемонта,
	ВсеБланки.ВремяРеагирования КАК ВремяРеагирования
	// } Гкс-[TOIR20-512] Вялых Д.А. от 22.01.2025.
	// Гкс+[TOIR20-520] Вялых Д.А. от 29.01.2025. Добавлено:{
    , ВсеБланки.ТипПроблемы КАК ТипПроблемы
	// } Гкс-[TOIR20-520] Вялых Д.А. от 29.01.2025.
	// Гкс+[TOIR20-551] Вялых Д.А. от 03.03.2025. Добавлено:{
    , ВсеБланки.ВремяНачалаОстановки КАК ВремяНачалаОстановки, 
	ВсеБланки.ПовторныйОтказ КАК ПовторныйОтказ,
	гкс_ЕВОБланкМероприятияПоПредупреждению.Срок КАК Срок
	// } Гкс-[TOIR20-551] Вялых Д.А. от 03.03.2025.
ИЗ
	ВсеБланки КАК ВсеБланки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИзДефектов КАК ИзДефектов
		ПО ВсеБланки.ДокументОснование = ИзДефектов.ДокументОснование
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.гкс_ЕВОБланк.МероприятияПоПредупреждению КАК гкс_ЕВОБланкМероприятияПоПредупреждению
		ПО ВсеБланки.Ссылка = гкс_ЕВОБланкМероприятияПоПредупреждению.Ссылка</query>
	</dataSet>
	<totalField>
		<dataPath>ДнейДоОкончанияСрокаИсполненияМероприятия</dataPath>
		<expression>Максимум(ДнейДоОкончанияСрокаИсполненияМероприятия)</expression>
		<group>Мероприятие</group>
	</totalField>
	<parameter>
		<name>ДатаНачала</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата начала</v8:content>
			</v8:item>
			<v8:item>
				<v8:lang>en</v8:lang>
				<v8:content>Start date</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<expression>&amp;ПериодОтчета.ДатаНачала</expression>
	</parameter>
	<parameter>
		<name>ДатаОкончания</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата окончания</v8:content>
			</v8:item>
			<v8:item>
				<v8:lang>en</v8:lang>
				<v8:content>End date</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<expression>&amp;ПериодОтчета.ДатаОкончания</expression>
	</parameter>
