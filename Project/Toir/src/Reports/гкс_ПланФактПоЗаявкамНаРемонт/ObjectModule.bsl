			СуммаЗатрат = 0;
			МассивКвалификаций = Новый Массив();
			ВыборкаТЗРР = ВыборкаТЗСмета.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаТЗРР.Следующий() Цикл
				МассивВОперации = Новый Массив();
				ВыборкаТЗ = ВыборкаТЗРР.Выбрать();
				Если ВыборкаТЗ.Следующий() Тогда 
					ТекКвал = ВыборкаТЗ.Квалификация;
					Если ЗначениеЗаполнено(ВыборкаТЗ.Сотрудник) Тогда 
						ТекКвал = ВыборкаТЗ.Сотрудник;
					КонецЕсли;
					ЭтоНовая = Истина;
					Для Каждого СтрокаМассива Из МассивВОперации Цикл
						Если СтрокаМассива.Квал = ТекКвал Тогда 
							Если ВыборкаТЗ.Колво = 0 Тогда 
								СтрокаМассива.Колво = СтрокаМассива.Колво + 1;
							Иначе
								СтрокаМассива.Колво = СтрокаМассива.Колво + ВыборкаТЗ.Колво;
							КонецЕсли;
							ЭтоНовая = ложь;
							Прервать;
						КонецЕсли;
					КонецЦикла;
					Если ЭтоНовая Тогда 
						Если ВыборкаТЗ.Колво = 0 Тогда 
							МассивВОперации.Добавить(Новый Структура("Квал,Колво", ТекКвал, 1));
						Иначе
							МассивВОперации.Добавить(Новый Структура("Квал,Колво", ТекКвал, ВыборкаТЗ.Колво));
						КонецЕсли;
					КонецЕсли;
					СуммаВремени = СуммаВремени + ВыборкаТЗ.ВремяРаботы;
					Если ВыборкаТЗ.Колво = 0 Тогда 
						СуммаЗатрат = СуммаЗатрат + (ВыборкаТЗ.ВремяРаботы);
					Иначе
						СуммаЗатрат = СуммаЗатрат + (ВыборкаТЗ.Колво * ВыборкаТЗ.ВремяРаботы);
					КонецЕсли;
				КонецЕсли;
				Для Каждого СтрокаТЗ Из МассивВОперации Цикл
					ЭтоНовая = Истина;
					Для Каждого СтрокаМассива Из МассивКвалификаций Цикл
						Если СтрокаМассива.Квал = СтрокаТЗ.Квал Тогда 
							СтрокаМассива.Колво = Макс(СтрокаМассива.Колво, СтрокаТЗ.Колво);
							ЭтоНовая = ложь;
							Прервать;
						КонецЕсли;
					КонецЦикла;
					Если ЭтоНовая Тогда 
						МассивКвалификаций.Добавить(Новый Структура("Квал,Колво", СтрокаТЗ.Квал, СтрокаТЗ.Колво));
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			Для Каждого СтрокаМассива Из МассивКвалификаций Цикл
				СуммаКвалификаций = СуммаКвалификаций + СтрокаМассива.Колво;
			КонецЦикла;
			НоваяСтрока.КолвоФакт = СуммаКвалификаций;
			НоваяСтрока.ВремяРаботыФакт = (СуммаВремени / 3600);
			НоваяСтрока.ТрудозатратыФакт = (СуммаЗатрат / 3600);
		КонецЕсли;
	КонецЕсли;
	#КонецОбласти
	
	ВыборкаАктИД.Сбросить();
	Если ВыборкаАктИД.НайтиСледующий(Новый Структура("ИД_Ремонта", ВыборкаРем.ИД_Ремонта)) Тогда 
		ВыборкаАкт = ВыборкаАктИД.Выбрать();
		Если ВыборкаАкт.НайтиСледующий(Новый Структура("Смета", ВыборкаРем.Смета)) Тогда 
			НоваяСтрока.СтоимостьФакт = ВыборкаАкт.СтоимостьФакт;
		КонецЕсли;
	КонецЕсли;
	
	ВыборкаТМ.Сбросить();
	Если ВыборкаТМ.НайтиСледующий(Новый Структура("ОР", ВыборкаРем.ОР)) Тогда 
		Если ЗначениеЗаполнено(ВыборкаТМ.ТМ) Тогда 
			НоваяСтрока.Место = ВыборкаТМ.Место;
			НоваяСтрока.Завод = ВыборкаТМ.Завод;
			НоваяСтрока.Участок = ВыборкаТМ.Участок;
		Иначе
			НоваяСтрока.Место = ВыборкаТМ.Место2;
			НоваяСтрока.Завод = ВыборкаТМ.Завод2;
			НоваяСтрока.Участок = ВыборкаТМ.Участок2;
		КонецЕсли;
	КонецЕсли;
		
	КонецЦикла;
	//
	Возврат Таб;
КонецФункции
