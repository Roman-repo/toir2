
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	НастройкиКД = КомпоновщикНастроек.ПолучитьНастройки();
	ДопПараметры = Новый Структура("ДатаНачала,ДатаОкончания", Дата(1, 1, 1), Дата(3999, 1, 1));
	ПараметрПериод = Новый ПараметрКомпоновкиДанных("ПериодОтчета");
	ПараметрПодр = Новый ПараметрКомпоновкиДанных("Подразделение");
	ПараметрСтатус = Новый ПараметрКомпоновкиДанных("СтатусСогласования");
	
	Для Каждого СтрокаПараметр Из НастройкиКД.ПараметрыДанных.Элементы Цикл
		Если СтрокаПараметр.Использование Тогда
			Если СтрокаПараметр.Параметр = ПараметрПериод Тогда
				ДопПараметры.ДатаНачала = СтрокаПараметр.Значение.ДатаНачала;
				ДопПараметры.ДатаОкончания = СтрокаПараметр.Значение.ДатаОкончания;
			ИначеЕсли СтрокаПараметр.Параметр = ПараметрПодр Тогда
				ДопПараметры.Вставить("Подразделение", СтрокаПараметр.Значение);
			ИначеЕсли СтрокаПараметр.Параметр = ПараметрСтатус Тогда
				ДопПараметры.Вставить("Статус", СтрокаПараметр.Значение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	////
	НастройкиОсновнойСхемы = КомпоновщикНастроек.ПолучитьНастройки();
	ВнешниеНаборыДанных = Новый Структура("ТабДанных1", ПолучитьОсновнуюТаблицу(ДопПараметры));
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКД, ДанныеРасшифровки);
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных, ДанныеРасшифровки);
	
	ПроцессорВыводаВТабличныйДокумент = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВыводаВТабличныйДокумент.УстановитьДокумент(ДокументРезультат);	
	ПроцессорВыводаВТабличныйДокумент.Вывести(ПроцессорКомпоновкиДанных);
КонецПроцедуры

Функция ПолучитьОсновнуюТаблицу(ДопПараметры)
	#Область ПостроениеТаблицы
	ОпТипПриоритет = Новый ОписаниеТипов("СправочникСсылка.торо_КатегорииРиска");
	ОпТипОР = Новый ОписаниеТипов("СправочникСсылка.торо_ОбъектыРемонта");
	ОпТипВР = Новый ОписаниеТипов("СправочникСсылка.торо_ВидыРемонтов");
	ОпТипПодр = Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия");
	ОпТипОрг = Новый ОписаниеТипов("СправочникСсылка.Организации");
	ОпТипСогл = Новый ОписаниеТипов("СправочникСсылка.торо_СтатусыСогласованияДокументовРемонтныхРабот");
	ОпТипСмета = Новый ОписаниеТипов("ДокументСсылка.торо_ЗаявкаНаРемонт");
	ОпТипУчасток = Новый ОписаниеТипов("СправочникСсылка.гкс_Участки");
	ОпТипЗавод = Новый ОписаниеТипов("СправочникСсылка.гкс_ЗаводыИПодразделения");
	ОпТипМесто = Новый ОписаниеТипов("СправочникСсылка.гкс_МестаИПлощадки");
	// гкс+ [11.22] Деснол 17.11.2022
	ОпТипСпособСогл = Новый ОписаниеТипов("СправочникСсылка.торо_СпособыСогласованияДокументов");
	// гкс- [11.22] Деснол 17.11.2022
	// гкс+ [03.23] Деснол 20.03.2023
	ОпТипСтатус = Новый ОписаниеТипов("ПеречислениеСсылка.торо_СтатусыДокументов");
	// гкс- [03.23] Деснол 20.03.2023
	
	
	ОпТипСтрока36 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(36));
	ОпТипСтрока = Новый ОписаниеТипов("Строка");
	ОпТипБулево = Новый ОписаниеТипов("Булево");
	ОпТипДата = Новый ОписаниеТипов("Дата", , , , , Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя));
	ОпТипЧисло15_2 = Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 2));
	//
	Таб = Новый ТаблицаЗначений();
	Таб.Колонки.Добавить("ПриоритетОР", ОпТипПриоритет);
	Таб.Колонки.Добавить("ИДРемонта", ОпТипСтрока36);
	Таб.Колонки.Добавить("КритичностьДефекта", ОпТипСтрока36);
	Таб.Колонки.Добавить("Срочность", ОпТипСтрока36);
	Таб.Колонки.Добавить("НомерСметы", ОпТипСтрока36);
	Таб.Колонки.Добавить("ВидРабот", ОпТипВР);
	Таб.Колонки.Добавить("НуженОстанов", ОпТипБулево);
	Таб.Колонки.Добавить("ОстановочныйРемонт", ОпТипСтрока36);
	Таб.Колонки.Добавить("Смета", ОпТипСмета);
	Таб.Колонки.Добавить("СтатусСогласованияСметы", ОпТипСогл);
	Таб.Колонки.Добавить("Организация", ОпТипОрг);
	Таб.Колонки.Добавить("Подразделение", ОпТипПодр);
	Таб.Колонки.Добавить("Место", ОпТипМесто);
	Таб.Колонки.Добавить("Завод", ОпТипЗавод);
	Таб.Колонки.Добавить("Участок", ОпТипУчасток);
	Таб.Колонки.Добавить("ТехНомер", ОпТипСтрока36);
	Таб.Колонки.Добавить("ОР", ОпТипОР);
	Таб.Колонки.Добавить("ОписаниеРемонта", ОпТипСтрока);
	Таб.Колонки.Добавить("Комментарий", ОпТипСтрока);
	Таб.Колонки.Добавить("Ответственный", ОпТипСтрока);
	Таб.Колонки.Добавить("Исполнитель", ОпТипСтрока);
	Таб.Колонки.Добавить("ДатаНачала", ОпТипДата);
	Таб.Колонки.Добавить("ДатаОкончания", ОпТипДата);
	Таб.Колонки.Добавить("КолвоПлан", ОпТипЧисло15_2);
	Таб.Колонки.Добавить("ВремяРаботыПлан", ОпТипЧисло15_2);
	Таб.Колонки.Добавить("ТрудозатратыПлан", ОпТипЧисло15_2);
	Таб.Колонки.Добавить("КолвоФакт", ОпТипЧисло15_2);
	Таб.Колонки.Добавить("ВремяРаботыФакт", ОпТипЧисло15_2);
	Таб.Колонки.Добавить("ТрудозатратыФакт", ОпТипЧисло15_2);
	Таб.Колонки.Добавить("СписокМЗ", ОпТипСтрока);
	Таб.Колонки.Добавить("СтоимостьПлан", ОпТипЧисло15_2);
	Таб.Колонки.Добавить("СтоимостьФакт", ОпТипЧисло15_2);
	// гкс+ [11.22] Деснол 17.11.2022
	Таб.Колонки.Добавить("СпособСоглСметы", ОпТипСпособСогл);
	// гкс- [11.22] Деснол 17.11.2022
	// гкс+ [03.23] Деснол 20.03.2023
	Таб.Колонки.Добавить("СтатусСметы", ОпТипСтатус);
	// гкс- [03.23] Деснол 20.03.2023
	// гкс+ [05.23] Деснол 05.05.2023
	ТЧПорядка = Новый ТаблицаЗначений();
	ТЧПорядка.Колонки.Добавить("Порядок", ОпТипЧисло15_2);
	ТЧПорядка.Колонки.Добавить("Срочность", Новый ОписаниеТипов("ПеречислениеСсылка.гкс_СрочностьВоздействия"));
	//
	НС = ТЧПорядка.Добавить();
	НС.Порядок = 1;
	НС.Срочность = Перечисления.гкс_СрочностьВоздействия.Немедленно;
	НС = ТЧПорядка.Добавить();
	НС.Порядок = 2;
	НС.Срочность = Перечисления.гкс_СрочностьВоздействия.Сегодня;
	НС = ТЧПорядка.Добавить();
	НС.Порядок = 3;
	НС.Срочность = Перечисления.гкс_СрочностьВоздействия.ВТечениеНедели;
	НС = ТЧПорядка.Добавить();
	НС.Порядок = 4;
	НС.Срочность = Перечисления.гкс_СрочностьВоздействия.ВТечениеМесяца;
	НС = ТЧПорядка.Добавить();
	НС.Порядок = 5;
	НС.Срочность = Перечисления.гкс_СрочностьВоздействия.ПриСледующейОстановке;
	НС = ТЧПорядка.Добавить();
	НС.Порядок = 6;
	НС.Срочность = Перечисления.гкс_СрочностьВоздействия.БуфернаяРабота;
	// гкс- [05.23] Деснол 05.05.2023
	#КонецОбласти
	//
	#Область ТекстЗапроса
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ДатыРемонтов.IDРемонта КАК ИД_Ремонта,
		|	ДатыРемонтов.ДатаНачала КАК ДатаНачала,
		|	ДатыРемонтов.ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ ВТ_ВсеРемонты
		|ИЗ
		|	РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК ДатыРемонтов
		|ГДЕ
		|	ДатыРемонтов.ДатаНачала >= &ДатаНачала
		|	И ДатыРемонтов.ДатаНачала < &ДатаОкончания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ОстановочныеРемонтыСрезПоследних.IDЗависимого КАК ИД_Ремонта,
		|	МАКСИМУМ(торо_ОстановочныеРемонтыСрезПоследних.Регистратор) КАК Регистратор
		|ПОМЕСТИТЬ ВТ_Остановочные
		|ИЗ
		|	РегистрСведений.торо_ОстановочныеРемонты.СрезПоследних(
		|			,
		|			IDЗависимого В
		|				(ВЫБРАТЬ
		|					ТЧ.ИД_Ремонта
		|				ИЗ
		|					ВТ_ВсеРемонты КАК ТЧ)) КАК торо_ОстановочныеРемонтыСрезПоследних
		|ГДЕ
		|	НЕ торо_ОстановочныеРемонтыСрезПоследних.Отвязан
		|
		|СГРУППИРОВАТЬ ПО
		|	торо_ОстановочныеРемонтыСрезПоследних.IDЗависимого
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ИД_Ремонта
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсеРемонты.ИД_Ремонта КАК ИД_Ремонта,
		|	ВТ_ВсеРемонты.ДатаНачала КАК ДатаНачала,
		|	ВТ_ВсеРемонты.ДатаОкончания КАК ДатаОкончания,
		|	РемонтыЗаявки.Ссылка КАК Смета,
		|	РемонтыЗаявки.ОбъектРемонта КАК ОР,
		|	РемонтыЗаявки.ВидРемонтныхРабот КАК ВР,
		|	РемонтыЗаявки.ОписаниеРемонта КАК ОписаниеРемонта,
		|	РемонтыЗаявки.ОбъектРемонта.ТехНомер КАК ТехНомер,
		|	РемонтыЗаявки.ОбъектРемонта.гкс_КатегорияРиска КАК Приоритет,
		|	РемонтыЗаявки.КритичностьДефекта КАК Критичность
		|ПОМЕСТИТЬ ВТ_Заявки
		|ИЗ
		|	ВТ_ВсеРемонты КАК ВТ_ВсеРемонты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК РемонтыЗаявки
		|		ПО ВТ_ВсеРемонты.ИД_Ремонта = РемонтыЗаявки.ID
		|			И (РемонтыЗаявки.Ссылка.Проведен)  И &Отбор1
		|;
		|ВЫБРАТЬ
		|	ТЧ.Порядок КАК Порядок,
		|	ТЧ.Срочность КАК Срочность
		|Поместить ВТ_Порядок
		|ИЗ &ТЧПорядка КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Заявки.ИД_Ремонта КАК ИД_Ремонта,
		|	ВТ_Заявки.ДатаНачала КАК ДатаНачала,
		|	ВТ_Заявки.ДатаОкончания КАК ДатаОкончания,
		|	ВТ_Заявки.Смета КАК Смета,
		|	ВТ_Заявки.Смета.Номер КАК НомерСметы,
		|	ВТ_Заявки.ОР КАК ОР,
		|	ВТ_Заявки.ВР КАК ВР,
		|	ВТ_Заявки.Смета.Организация КАК Организация,
		|	ВТ_Заявки.Смета.СпособСогласования КАК СпособСоглСметы,
		|	ВТ_Заявки.Смета.Подразделение КАК Подразделение,
		|	ВТ_Заявки.Смета.гкс_НуженОстанов КАК НуженОстанов,
		|	ВТ_Заявки.ОписаниеРемонта КАК ОписаниеРемонта,
		|	ВТ_Заявки.ТехНомер КАК ТехНомер,
		|	ВТ_Заявки.Приоритет КАК Приоритет,
		|	ВТ_Заявки.Критичность КАК Критичность,
		|	ВТ_Заявки.Смета.Комментарий КАК Комментарий,
		|	ВТ_Заявки.Смета.Ответственный КАК Ответственный,
		|	ВТ_Заявки.Смета.гкс_СрочностьВоздействия КАК Срочность,
		|	ТекущиеСтатусы.СтатусДокумента КАК СтатусДокумента,
		|	ВТ_Остановочные.Регистратор КАК Остановочный,
		|	РегСтатусы.СтатусДокумента КАК СтатусСметы,
		|	ВТ_Заявки.Смета.гкс_ПлановаяСтоимостьРемонта КАК СтоимостьПлан,
		|	ВТ_Порядок.Порядок КАК Порядок
		|ИЗ
		|	ВТ_Заявки КАК ВТ_Заявки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущиеСтатусыСогласованияДокументов КАК ТекущиеСтатусы
		|		ПО ВТ_Заявки.Смета = ТекущиеСтатусы.СогласуемыйДокумент
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Остановочные КАК ВТ_Остановочные
		|		ПО ВТ_Заявки.ИД_Ремонта = ВТ_Остановочные.ИД_Ремонта
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыДокументовЗаявокУстановленные.СрезПоследних() КАК РегСтатусы
		|		ПО ВТ_Заявки.Смета = РегСтатусы.ИзменяемыйДокумент
		|		Левое соединение ВТ_Порядок КАК ВТ_Порядок
		|		ПО ВТ_Порядок.Срочность = ВТ_Заявки.Смета.гкс_СрочностьВоздействия
		|Где &Отбор2
		|Упорядочить ПО ВТ_Порядок.Порядок
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Заявки.ИД_Ремонта КАК ИД_Ремонта,
		|	ВТ_Заявки.Смета КАК Смета,
		|	ДокТЧ.Исполнитель КАК Исполнитель,
		|	ДокТЧ.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	ВТ_Заявки КАК ВТ_Заявки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ИсполнителиПоРемонтам КАК ДокТЧ
		|		ПО ВТ_Заявки.Смета = ДокТЧ.Ссылка
		|			И ВТ_Заявки.ИД_Ремонта = ДокТЧ.РемонтыОборудования_ID
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ ПО
		|	ИД_Ремонта,
		|	Смета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Заявки.ИД_Ремонта КАК ИД_Ремонта,
		|	ВТ_Заявки.Смета КАК Смета,
		|	МатериальныеЗатраты.НомерСтроки КАК НомерСтроки,
		|	МатериальныеЗатраты.ЕдиницаИзмерения КАК Упаковка,
		|	МатериальныеЗатраты.Номенклатура КАК Номенклатура,
		|	МатериальныеЗатраты.Номенклатура.КОд КАК НоменклатураКод,
		|	МатериальныеЗатраты.КоличествоЕдиниц КАК Колво,
		|	МатериальныеЗатраты.Номенклатура.ЕдиницаИзмерения КАК ЕдИзм
		|ИЗ
		|	ВТ_Заявки КАК ВТ_Заявки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.МатериальныеЗатраты КАК МатериальныеЗатраты
		|		ПО ВТ_Заявки.ИД_Ремонта = МатериальныеЗатраты.РемонтыОборудования_ID
		|			И ВТ_Заявки.Смета = МатериальныеЗатраты.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ ПО
		|	ИД_Ремонта,
		|	Смета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Заявки.ИД_Ремонта КАК ИД_Ремонта,
		|	ВТ_Заявки.Смета КАК Смета,
		|	ТрудовыеЗатраты.НомерСтроки КАК НомерСтроки,
		|	ТрудовыеЗатраты.ВремяРаботы КАК ВремяРаботы,
		|	ТрудовыеЗатраты.Квалификация КАК Квалификация,
		|	ТрудовыеЗатраты.Количество КАК Колво,
