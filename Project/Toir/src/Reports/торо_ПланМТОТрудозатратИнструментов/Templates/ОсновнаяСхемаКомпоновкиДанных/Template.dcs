			<dataPath>СписокОбъектов</dataPath>
			<field>СписокОбъектов</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВидМероприятия</dataPath>
			<field>ВидМероприятия</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Организация</dataPath>
			<field>Организация</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВидРемонтныхРабот</dataPath>
			<field>ВидРемонтныхРабот</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектИерархии</dataPath>
			<field>ОбъектИерархии</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Объект иерархии</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>es</v8:lang>
					<v8:content>El objeto de la jerarquía</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Hierarchy object</v8:content>
				</v8:item>
			</title>
			<inHierarchyDataSet>Контроль</inHierarchyDataSet>
			<inHierarchyDataSetParameter>Родитель</inHierarchyDataSetParameter>
			<inputParameters>
				<dcscor:item>
					<dcscor:parameter>СвязиПараметровВыбора</dcscor:parameter>
					<dcscor:value xsi:type="dcscor:ChoiceParameterLinks">
						<dcscor:item>
							<dcscor:choiceParameter>СтруктураИерархии</dcscor:choiceParameter>
							<dcscor:value>ПараметрыДанных.ИерархияТип</dcscor:value>
							<dcscor:mode xmlns:d8p1="http://v8.1c.ru/8.1/data/enterprise" xsi:type="d8p1:LinkedValueChangeMode">Clear</dcscor:mode>
						</dcscor:item>
					</dcscor:value>
				</dcscor:item>
			</inputParameters>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УдалитьПодразделение</dataPath>
			<field>УдалитьПодразделение</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УдалитьПериодичностьДетализации</dataPath>
			<field>УдалитьПериодичностьДетализации</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Удалить_ID_Корректировок</dataPath>
			<field>Удалить_ID_Корректировок</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>// Данный запрос сохранен для работы настроек заполнения. 
// Но редактировать при необходимости нужно запрос в модуле объекта.

ВЫБРАТЬ РАЗРЕШЕННЫЕ
	торо_Ремонты.Регистратор КАК Смета,
	торо_Ремонты.ID КАК ID,
	торо_Ремонты.ОбъектРемонта КАК ОбъектРемонта,
	торо_Ремонты.ВидРемонта КАК ВидРемонта,
	торо_Ремонты.ДатаНачалаПлан КАК ДатаНачалаПлан,
	торо_Ремонты.ДатаОкончанияПлан КАК ДатаОкончанияПлан
ПОМЕСТИТЬ ВТ_РемонтыПоЗаявкам
ИЗ
	РегистрСведений.торо_Ремонты КАК торо_Ремонты
ГДЕ
	торо_Ремонты.Регистратор ССЫЛКА Документ.торо_ЗаявкаНаРемонт
	И торо_Ремонты.Активность = ИСТИНА
{ГДЕ
	(торо_Ремонты.ДатаНачалаПлан &lt;= &amp;ОкончаниеПериода),
	(торо_Ремонты.ДатаОкончанияПлан &gt;= &amp;НачалоПериода)}

ИНДЕКСИРОВАТЬ ПО
	ID
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	торо_ПланГрафикРемонта.ОбъектРемонтныхРабот КАК Объект,
	торо_ПланГрафикРемонта.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	торо_ПланГрафикРемонта.Регистратор КАК ДокППР,
	торо_ПланГрафикРемонта.ID КАК ID,
	торо_ПланГрафикРемонта.ДатаНачалаРемонтныхРабот КАК ДатаНачалаРемонтныхРабот,
	торо_ПланГрафикРемонта.ДатаОкончанияРемонтныхРабот КАК ДатаОкончанияРемонтныхРабот
ПОМЕСТИТЬ ВТ_РемонтыПоППР
ИЗ
	РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних(, &amp;РассчетППР = ИСТИНА {(Подразделение = &amp;Подразделение) КАК Поле2}) КАК торо_ПланГрафикРемонта
ГДЕ
	НЕ торо_ПланГрафикРемонта.Отменен
	И НЕ торо_ПланГрафикРемонта.Замещен
{ГДЕ
	(торо_ПланГрафикРемонта.Исполнитель = &amp;Исполнитель)}

ИНДЕКСИРОВАТЬ ПО
	ID
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	торо_ПлановыеМероприятияСрезПоследних.СписокОбъектов КАК СписокОбъектов,
	торо_ПлановыеМероприятияСрезПоследних.ВидМероприятия КАК ВидМероприятия,
	торо_ПлановыеМероприятияСрезПоследних.ДатаНачала КАК ДатаНачала,
	торо_ПлановыеМероприятияСрезПоследних.ДатаОкончания КАК ДатаОкончания
ПОМЕСТИТЬ ВТ_ПлановыеМероприятия
ИЗ
	РегистрСведений.торо_ПлановыеМероприятия.СрезПоследних(, &amp;РассчетРеглМероприятий = ИСТИНА {(Подразделение = &amp;Подразделение) КАК Поле2}) КАК торо_ПлановыеМероприятияСрезПоследних
ГДЕ
	НЕ торо_ПлановыеМероприятияСрезПоследних.Отменен
{ГДЕ
	(торо_ПлановыеМероприятияСрезПоследних.ДатаНачала &lt;= &amp;ОкончаниеПериода
			И торо_ПлановыеМероприятияСрезПоследних.ДатаНачала &gt;= &amp;НачалоПериода),
	(торо_ПлановыеМероприятияСрезПоследних.Исполнитель = &amp;Исполнитель)}

ИНДЕКСИРОВАТЬ ПО
	СписокОбъектов,
	ВидМероприятия
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаНачалаПлан, ВТ_РемонтыПоППР.ДатаНачалаРемонтныхРабот) КАК ДатаРемонта,
	ВТ_РемонтыПоППР.Объект КАК Объект,
	ВТ_РемонтыПоППР.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаОкончанияПлан, ВТ_РемонтыПоППР.ДатаОкончанияРемонтныхРабот) КАК ДатаОкончания,
	ВТ_РемонтыПоППР.ДокППР КАК ДокППР,
	ВТ_РемонтыПоЗаявкам.Смета КАК Смета,
	ВТ_РемонтыПоППР.ID КАК ID
ПОМЕСТИТЬ ВТ_ППРБезСмет
ИЗ
	ВТ_РемонтыПоППР КАК ВТ_РемонтыПоППР
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РемонтыПоЗаявкам КАК ВТ_РемонтыПоЗаявкам
		ПО ВТ_РемонтыПоППР.ID = ВТ_РемонтыПоЗаявкам.ID
			И (&amp;РассчетСметПоППР = ИСТИНА)
ГДЕ
	ВТ_РемонтыПоЗаявкам.Смета ЕСТЬ NULL

ИНДЕКСИРОВАТЬ ПО
	Объект,
	ВидРемонтныхРабот
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаНачалаПлан, ВТ_РемонтыПоППР.ДатаНачалаРемонтныхРабот) КАК ДатаРемонта,
	ВТ_РемонтыПоППР.Объект КАК Объект,
	ВТ_РемонтыПоППР.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаОкончанияПлан, ВТ_РемонтыПоППР.ДатаОкончанияРемонтныхРабот) КАК ДатаОкончания,
	ВТ_РемонтыПоППР.ДокППР КАК ДокППР,
	ВТ_РемонтыПоЗаявкам.Смета КАК Смета,
	ВТ_РемонтыПоППР.ID КАК ID
ПОМЕСТИТЬ ВТ_ППРСоСметами
ИЗ
	ВТ_РемонтыПоППР КАК ВТ_РемонтыПоППР
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РемонтыПоЗаявкам КАК ВТ_РемонтыПоЗаявкам
		ПО (ВТ_РемонтыПоЗаявкам.ID = ВТ_РемонтыПоППР.ID)

ИНДЕКСИРОВАТЬ ПО
	ID,
	Смета
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	торо_Ремонты.ДатаНачалаПлан КАК ДатаРемонта,
	торо_Ремонты.ОбъектРемонта КАК Объект,
	торо_Ремонты.ВидРемонта КАК ВидРемонтныхРабот,
	торо_Ремонты.ДатаОкончанияПлан КАК ДатаОкончания,
	NULL КАК ДокППР,
	торо_ЗаявкаНаРемонтДокументыОснования.Ссылка КАК Смета,
	торо_Ремонты.ID КАК ID
ПОМЕСТИТЬ СписокЗаявокНаОснованииДефектовИВнешнихОснований
ИЗ
	Документ.торо_ЗаявкаНаРемонт.ДокументыОснования КАК торо_ЗаявкаНаРемонтДокументыОснования
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_Ремонты
		ПО торо_ЗаявкаНаРемонтДокументыОснования.Ссылка = торо_Ремонты.Регистратор
			И (&amp;РассчетСметПоДефектам = ИСТИНА
					И ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонтДокументыОснования.ДокументОснование) = ТИП(Документ.торо_ВыявленныеДефекты)
				ИЛИ &amp;РассчетСметПоВнешнимОснованиям = ИСТИНА
					И ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонтДокументыОснования.ДокументОснование) = ТИП(Документ.торо_ВнешнееОснованиеДляРабот))
{ГДЕ
	(торо_Ремонты.ДатаНачалаПлан &lt;= &amp;ОкончаниеПериода
			И торо_Ремонты.ДатаОкончанияПлан &gt;= &amp;НачалоПериода),
	(торо_ЗаявкаНаРемонтДокументыОснования.Ссылка.Подразделение = &amp;Подразделение)}

СГРУППИРОВАТЬ ПО
	торо_Ремонты.ДатаНачалаПлан,
	торо_Ремонты.ОбъектРемонта,
	торо_Ремонты.ВидРемонта,
	торо_Ремонты.ДатаОкончанияПлан,
	торо_ЗаявкаНаРемонтДокументыОснования.Ссылка,
	торо_Ремонты.ID

ИНДЕКСИРОВАТЬ ПО
	ID,
	Смета
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВТ_ППРБезСмет.ДатаРемонта КАК ДатаРемонта,
	ВТ_ППРБезСмет.Объект КАК Объект,
	ВТ_ППРБезСмет.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	торо_НормативныеРемонтыОборудования.НормативныйРемонт КАК НормРемДляПольз,
	ВТ_ППРБезСмет.ДатаОкончания КАК ДатаОкончания,
	торо_НормативныеРемонтыОборудования.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
	ВТ_ППРБезСмет.ДокППР КАК ДокППР,
	ВТ_ППРБезСмет.Смета КАК Смета,
	РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ВТ_ППРБезСмет.ДатаРемонта, ДЕНЬ), КОНЕЦПЕРИОДА(ВТ_ППРБезСмет.ДатаОкончания, ДЕНЬ), ДЕНЬ) + 1 КАК КоличествоДней,
	ВТ_ППРБезСмет.ID КАК ID
ПОМЕСТИТЬ БазаОтчета_Ремонты_БезТехКарт
ИЗ
	ВТ_ППРБезСмет КАК ВТ_ППРБезСмет
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_НормативныеРемонтыОборудования КАК торо_НормативныеРемонтыОборудования
		ПО ВТ_ППРБезСмет.Объект = торо_НормативныеРемонтыОборудования.ОбъектРемонта
			И ВТ_ППРБезСмет.ВидРемонтныхРабот = торо_НормативныеРемонтыОборудования.ВидРемонта
ГДЕ
	торо_НормативныеРемонтыОборудования.Приоритет
{ГДЕ
	(ВТ_ППРБезСмет.ДатаРемонта &lt;= &amp;ОкончаниеПериода
			И ВТ_ППРБезСмет.ДатаРемонта &gt;= &amp;НачалоПериода)}

СГРУППИРОВАТЬ ПО
	ВТ_ППРБезСмет.ДатаРемонта,
	ВТ_ППРБезСмет.Объект,
	ВТ_ППРБезСмет.ВидРемонтныхРабот,
	торо_НормативныеРемонтыОборудования.НормативныйРемонт,
	ВТ_ППРБезСмет.ДатаОкончания,
	торо_НормативныеРемонтыОборудования.ГрафикРемонтныхРабот,
	ВТ_ППРБезСмет.ДокППР,
	ВТ_ППРБезСмет.Смета,
	ВТ_ППРБезСмет.ID

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	торо_ПлановыеМероприятия.ДатаНачала,
	торо_МаршрутыРегламентныхМероприятий.ОбъектРемонта,
	торо_ПлановыеМероприятия.ВидМероприятия,
	торо_РегламентныеМероприятияИСпискиОбъектов.НормативныйРемонт,
	торо_ПлановыеМероприятия.ДатаОкончания,
	торо_РегламентныеМероприятияИСпискиОбъектов.ГрафикРемонтныхРабот,
	ЗНАЧЕНИЕ(Документ.торо_ГрафикРегламентныхМероприятийТОиР.ПустаяСсылка),
	NULL,
	РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(торо_ПлановыеМероприятия.ДатаНачала, ДЕНЬ), КОНЕЦПЕРИОДА(торо_ПлановыеМероприятия.ДатаОкончания, ДЕНЬ), ДЕНЬ) + 1,
	NULL
ИЗ
	ВТ_ПлановыеМероприятия КАК торо_ПлановыеМероприятия
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_МаршрутыРегламентныхМероприятий КАК торо_МаршрутыРегламентныхМероприятий
		ПО торо_ПлановыеМероприятия.СписокОбъектов = торо_МаршрутыРегламентныхМероприятий.СписокОбъектов
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_РегламентныеМероприятияИСпискиОбъектов КАК торо_РегламентныеМероприятияИСпискиОбъектов
		ПО торо_ПлановыеМероприятия.СписокОбъектов = торо_РегламентныеМероприятияИСпискиОбъектов.СписокОбъектов
			И торо_ПлановыеМероприятия.ВидМероприятия = торо_РегламентныеМероприятияИСпискиОбъектов.ВидМероприятия

ИНДЕКСИРОВАТЬ ПО
	НормРемДляПольз,
	ГрафикРемонтныхРабот
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	МАКСИМУМ(торо_ВерсииТехКарт.Период) КАК Период,
	торо_ВерсииТехКарт.ИдентификаторТехКарты КАК ИдентификаторТехКарты,
	БазаОтчета_Ремонты_БезТехКарт.ДатаРемонта КАК ДатаРемонта,
	БазаОтчета_Ремонты_БезТехКарт.Объект КАК Объект,
	БазаОтчета_Ремонты_БезТехКарт.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	БазаОтчета_Ремонты_БезТехКарт.НормРемДляПольз КАК НормРемДляПольз,
	БазаОтчета_Ремонты_БезТехКарт.ДатаОкончания КАК ДатаОкончания,
	БазаОтчета_Ремонты_БезТехКарт.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
	БазаОтчета_Ремонты_БезТехКарт.ДокППР КАК ДокППР,
	БазаОтчета_Ремонты_БезТехКарт.Смета КАК Смета,
	БазаОтчета_Ремонты_БезТехКарт.КоличествоДней КАК КоличествоДней,
	БазаОтчета_Ремонты_БезТехКарт.ID КАК ID
ПОМЕСТИТЬ ВТ_ДляСрезаВерсийТК
ИЗ
	РегистрСведений.торо_ВерсииТехКарт КАК торо_ВерсииТехКарт
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ БазаОтчета_Ремонты_БезТехКарт КАК БазаОтчета_Ремонты_БезТехКарт
		ПО торо_ВерсииТехКарт.ИдентификаторТехКарты = БазаОтчета_Ремонты_БезТехКарт.НормРемДляПольз
			И (БазаОтчета_Ремонты_БезТехКарт.ДатаРемонта &gt; торо_ВерсииТехКарт.Период)

СГРУППИРОВАТЬ ПО
	торо_ВерсииТехКарт.ИдентификаторТехКарты,
	БазаОтчета_Ремонты_БезТехКарт.ДатаРемонта,
	БазаОтчета_Ремонты_БезТехКарт.Объект,
	БазаОтчета_Ремонты_БезТехКарт.ВидРемонтныхРабот,
	БазаОтчета_Ремонты_БезТехКарт.НормРемДляПольз,
	БазаОтчета_Ремонты_БезТехКарт.ДатаОкончания,
	БазаОтчета_Ремонты_БезТехКарт.ГрафикРемонтныхРабот,
	БазаОтчета_Ремонты_БезТехКарт.ДокППР,
	БазаОтчета_Ремонты_БезТехКарт.Смета,
	БазаОтчета_Ремонты_БезТехКарт.КоличествоДней,
	БазаОтчета_Ремонты_БезТехКарт.ID

ИНДЕКСИРОВАТЬ ПО
	ИдентификаторТехКарты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВТ_ДляСрезаВерсийТК.Период КАК Период,
	ВТ_ДляСрезаВерсийТК.ИдентификаторТехКарты КАК ИдентификаторТехКарты,
	ВТ_ДляСрезаВерсийТК.ДатаРемонта КАК ДатаРемонта,
	ВТ_ДляСрезаВерсийТК.Объект КАК Объект,
	ВТ_ДляСрезаВерсийТК.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	ВТ_ДляСрезаВерсийТК.НормРемДляПольз КАК НормРемДляПольз,
	ВТ_ДляСрезаВерсийТК.ДатаОкончания КАК ДатаОкончания,
	ВТ_ДляСрезаВерсийТК.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
	ВТ_ДляСрезаВерсийТК.ДокППР КАК ДокППР,
	ВТ_ДляСрезаВерсийТК.Смета КАК Смета,
	ВТ_ДляСрезаВерсийТК.КоличествоДней КАК КоличествоДней,
	ВТ_ДляСрезаВерсийТК.ID КАК ID,
	торо_ВерсииТехКарт.ТехКарта КАК НормативныйРемонт
ПОМЕСТИТЬ БазаОтчета_Ремонты
ИЗ
	ВТ_ДляСрезаВерсийТК КАК ВТ_ДляСрезаВерсийТК
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт КАК торо_ВерсииТехКарт
		ПО ВТ_ДляСрезаВерсийТК.Период = торо_ВерсииТехКарт.Период
			И ВТ_ДляСрезаВерсийТК.ИдентификаторТехКарты = торо_ВерсииТехКарт.ИдентификаторТехКарты

ИНДЕКСИРОВАТЬ ПО
	НормРемДляПольз,
	ГрафикРемонтныхРабот,
	НормативныйРемонт
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	БазаОтчета_Ремонты.ДатаРемонта КАК ДатаРемонта,
	БазаОтчета_Ремонты.Объект КАК Объект,
	БазаОтчета_Ремонты.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	БазаОтчета_Ремонты.ДатаОкончания КАК ДатаОкончания,
	БазаОтчета_Ремонты.ДокППР КАК ДокППР,
	БазаОтчета_Ремонты.НормативныйРемонт КАК НормативныйРемонт,
	БазаОтчета_Ремонты.НормРемДляПольз КАК НормРемДляПольз,
	БазаОтчета_Ремонты.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
	БазаОтчета_Ремонты.Смета КАК Смета,
	торо_Состав.Состав КАК ТехКарта,
	торо_Состав.Количество КАК Количество,
	БазаОтчета_Ремонты.КоличествоДней КАК КоличествоДней,
	БазаОтчета_Ремонты.ID КАК ID
ПОМЕСТИТЬ БазаОтчета
ИЗ
	БазаОтчета_Ремонты КАК БазаОтчета_Ремонты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_СоставИерархическихТехКартРемонтов КАК торо_Состав
		ПО БазаОтчета_Ремонты.НормативныйРемонт = торо_Состав.ТехКарта

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	БазаОтчета_Ремонты.ДатаРемонта,
	БазаОтчета_Ремонты.Объект,
	БазаОтчета_Ремонты.ВидРемонтныхРабот,
	БазаОтчета_Ремонты.ДатаОкончания,
	БазаОтчета_Ремонты.ДокППР,
	БазаОтчета_Ремонты.НормативныйРемонт,
	БазаОтчета_Ремонты.НормРемДляПольз,
	БазаОтчета_Ремонты.ГрафикРемонтныхРабот,
	БазаОтчета_Ремонты.Смета,
	БазаОтчета_Ремонты.НормативныйРемонт,
	1,
	БазаОтчета_Ремонты.КоличествоДней,
	БазаОтчета_Ремонты.ID
ИЗ
	БазаОтчета_Ремонты КАК БазаОтчета_Ремонты

ИНДЕКСИРОВАТЬ ПО
	ТехКарта,
	Объект,
	ВидРемонтныхРабот,
	Смета,
	ГрафикРемонтныхРабот
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НормативныеРемонты.ДатаРемонта КАК Период,
	НормативныеРемонты.ДокППР КАК Документ,
	торо_РемонтыМатериальныеЗатраты.Номенклатура КАК Номенклатура,
	торо_РемонтыМатериальныеЗатраты.Характеристика КАК Характеристика,
	торо_РемонтыМатериальныеЗатраты.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	СУММА(торо_РемонтыМатериальныеЗатраты.Количество * НормативныеРемонты.Количество) КАК Количество,
	НормативныеРемонты.Объект КАК ОбъектРемонтныхРабот,
	НормативныеРемонты.ВидРемонтныхРабот КАК ВидРемонта
ПОМЕСТИТЬ ТабНоменклатурыПоППРБезСмет
ИЗ
	Справочник.торо_ТехКарты.МатериальныеЗатраты КАК торо_РемонтыМатериальныеЗатраты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ БазаОтчета КАК НормативныеРемонты
		ПО торо_РемонтыМатериальныеЗатраты.Ссылка = НормативныеРемонты.ТехКарта
			И (НормативныеРемонты.Смета ЕСТЬ NULL)

СГРУППИРОВАТЬ ПО
	НормативныеРемонты.ДатаРемонта,
	торо_РемонтыМатериальныеЗатраты.Номенклатура,
	торо_РемонтыМатериальныеЗатраты.Характеристика,
	НормативныеРемонты.ДокППР,
	торо_РемонтыМатериальныеЗатраты.ЕдиницаИзмерения,
	НормативныеРемонты.Объект,
	НормативныеРемонты.ВидРемонтныхРабот

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	НормативныеРемонты.ДатаРемонта,
	НормативныеРемонты.ДокППР,
	торо_НормыЗапчастейНаОбъектыРемонта.Номенклатура,
	торо_НормыЗапчастейНаОбъектыРемонта.Характеристика,
	торо_НормыЗапчастейНаОбъектыРемонта.Номенклатура.ЕдиницаИзмерения,
	торо_НормыЗапчастейНаОбъектыРемонта.Количество,
	НормативныеРемонты.Объект,
	НормативныеРемонты.ВидРемонтныхРабот
ИЗ
	БазаОтчета_Ремонты КАК НормативныеРемонты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_НормыЗапчастейНаОбъектыРемонта КАК торо_НормыЗапчастейНаОбъектыРемонта
		ПО НормативныеРемонты.Объект = торо_НормыЗапчастейНаОбъектыРемонта.ОбъектРемонта
			И НормативныеРемонты.ВидРемонтныхРабот = торо_НормыЗапчастейНаОбъектыРемонта.ВидРемонта
			И (НормативныеРемонты.Смета ЕСТЬ NULL)
			И (торо_НормыЗапчастейНаОбъектыРемонта.Приоритет)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ТабНоменклатуры.Период КАК Период,
	ТабНоменклатуры.Документ КАК Документ,
	ТабНоменклатуры.Номенклатура КАК Номенклатура,
	ТабНоменклатуры.Характеристика КАК Характеристика,
	ТабНоменклатуры.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	ТабНоменклатуры.Количество КАК Количество,
	ТабНоменклатуры.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	ТабНоменклатуры.ВидРемонта КАК ВидРемонта,
	NULL КАК ДатаОкончания,
	NULL КАК ДокППР,
	NULL КАК ID
ПОМЕСТИТЬ НоменклатураКоличество
ИЗ
	ТабНоменклатурыПоППРБезСмет КАК ТабНоменклатуры

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	БазаОтчета.ДатаРемонта,
	БазаОтчета.Смета,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Номенклатура,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.ХарактеристикаНоменклатуры,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Номенклатура.ЕдиницаИзмерения,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Количество,
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	NULL,
	NULL,
	NULL
ИЗ
	БазаОтчета КАК БазаОтчета
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.торо_ПлановыеМатериальныеЗатратыРемонтныхРабот КАК торо_ПлановыеМатериальныеЗатратыРемонтныхРабот
		ПО БазаОтчета.Смета = торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Регистратор
			И БазаОтчета.ID = торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.РемонтыОборудования_ID

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	БазаОтчета.ДатаРемонта,
	БазаОтчета.Смета,
	торо_ПлановыеЗатратыЗапчастей.Номенклатура,
	торо_ПлановыеЗатратыЗапчастей.ХарактеристикаНоменклатуры,
	торо_ПлановыеЗатратыЗапчастей.Номенклатура.ЕдиницаИзмерения,
	торо_ПлановыеЗатратыЗапчастей.Количество,
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	NULL,
	NULL,
	NULL
ИЗ
	БазаОтчета КАК БазаОтчета
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.торо_ПлановыеЗатратыЗапчастей КАК торо_ПлановыеЗатратыЗапчастей
		ПО БазаОтчета.Смета = торо_ПлановыеЗатратыЗапчастей.Регистратор
			И БазаОтчета.ID = торо_ПлановыеЗатратыЗапчастей.РемонтыОборудования_ID

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаРемонта,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Номенклатура,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.ХарактеристикаНоменклатуры,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Номенклатура.ЕдиницаИзмерения,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Количество,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ВидРемонтныхРабот,
	NULL,
	NULL,
	NULL
ИЗ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований КАК СписокЗаявокНаОснованииДефектовИВнешнихОснований
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.торо_ПлановыеМатериальныеЗатратыРемонтныхРабот КАК торо_ПлановыеМатериальныеЗатратыРемонтныхРабот
		ПО СписокЗаявокНаОснованииДефектовИВнешнихОснований.ID = торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.РемонтыОборудования_ID
			И СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета = торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Регистратор

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаРемонта,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета,
	торо_ПлановыеЗатратыЗапчастей.Номенклатура,
	торо_ПлановыеЗатратыЗапчастей.ХарактеристикаНоменклатуры,
	торо_ПлановыеЗатратыЗапчастей.Номенклатура.ЕдиницаИзмерения,
	торо_ПлановыеЗатратыЗапчастей.Количество,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ВидРемонтныхРабот,
	NULL,
	NULL,
	NULL
ИЗ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований КАК СписокЗаявокНаОснованииДефектовИВнешнихОснований
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.торо_ПлановыеЗатратыЗапчастей КАК торо_ПлановыеЗатратыЗапчастей
		ПО СписокЗаявокНаОснованииДефектовИВнешнихОснований.ID = торо_ПлановыеЗатратыЗапчастей.РемонтыОборудования_ID
			И СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета = торо_ПлановыеЗатратыЗапчастей.Регистратор

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВТ_ППРСоСметами.ДатаРемонта,
	ВТ_ППРСоСметами.Смета,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Номенклатура,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.ХарактеристикаНоменклатуры,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Номенклатура.ЕдиницаИзмерения,
	торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Количество,
	ВТ_ППРСоСметами.Объект,
	ВТ_ППРСоСметами.ВидРемонтныхРабот,
	NULL,
	NULL,
	NULL
ИЗ
	ВТ_ППРСоСметами КАК ВТ_ППРСоСметами
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.торо_ПлановыеМатериальныеЗатратыРемонтныхРабот КАК торо_ПлановыеМатериальныеЗатратыРемонтныхРабот
		ПО ВТ_ППРСоСметами.ID = торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.РемонтыОборудования_ID
			И ВТ_ППРСоСметами.Смета = торо_ПлановыеМатериальныеЗатратыРемонтныхРабот.Регистратор

ИНДЕКСИРОВАТЬ ПО
	Номенклатура,
	Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НоменклатураКоличество.Период КАК Период,
	НоменклатураКоличество.Документ КАК Документ,
	НоменклатураКоличество.Номенклатура КАК Номенклатура,
	НоменклатураКоличество.Характеристика КАК Характеристика,
	НоменклатураКоличество.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	НоменклатураКоличество.Количество КАК Количество,
	НоменклатураКоличество.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	НоменклатураКоличество.ВидРемонта КАК ВидРемонта,
	НоменклатураКоличество.ДатаОкончания КАК ДатаОкончания,
	НоменклатураКоличество.ДокППР КАК ДокППР,
	НоменклатураКоличество.ID КАК ID
ПОМЕСТИТЬ ВТ_СгруппированнаяНоменклатура
ИЗ
	НоменклатураКоличество КАК НоменклатураКоличество

СГРУППИРОВАТЬ ПО
	НоменклатураКоличество.Период,
	НоменклатураКоличество.Документ,
	НоменклатураКоличество.Номенклатура,
	НоменклатураКоличество.Характеристика,
	НоменклатураКоличество.ЕдиницаИзмерения,
	НоменклатураКоличество.Количество,
	НоменклатураКоличество.ОбъектРемонтныхРабот,
	НоменклатураКоличество.ВидРемонта,
	НоменклатураКоличество.ДатаОкончания,
	НоменклатураКоличество.ДокППР,
	НоменклатураКоличество.ID
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВТ_СгруппированнаяНоменклатура.Период КАК Период,
	ВТ_СгруппированнаяНоменклатура.Номенклатура КАК Номенклатура,
	ВТ_СгруппированнаяНоменклатура.Характеристика КАК Характеристика,
	МАКСИМУМ(ЦеныНоменклатуры.Период) КАК ПериодЦена,
	ЦеныНоменклатуры.ВидЦены КАК ТипЦен,
	ЦеныНоменклатуры.Валюта КАК Валюта
ПОМЕСТИТЬ НоменклатураПериодЦен
ИЗ
	ВТ_СгруппированнаяНоменклатура КАК ВТ_СгруппированнаяНоменклатура
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Константы КАК Константы
			ПО ЦеныНоменклатуры.ВидЦены = Константы.торо_ТипЦеныДляРасчетаСебестоимостиРемонта
		ПО ВТ_СгруппированнаяНоменклатура.Номенклатура = ЦеныНоменклатуры.Номенклатура
			И ВТ_СгруппированнаяНоменклатура.Характеристика = ЦеныНоменклатуры.Характеристика
			И ВТ_СгруппированнаяНоменклатура.Период &gt;= ЦеныНоменклатуры.Период

СГРУППИРОВАТЬ ПО
	ВТ_СгруппированнаяНоменклатура.Период,
	ВТ_СгруппированнаяНоменклатура.Номенклатура,
	ВТ_СгруппированнаяНоменклатура.Характеристика,
	ЦеныНоменклатуры.ВидЦены,
	ЦеныНоменклатуры.Валюта

ИНДЕКСИРОВАТЬ ПО
	Номенклатура,
	Характеристика,
	ПериодЦена,
	ТипЦен,
	Валюта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВТ_СгруппированнаяНоменклатура.Период КАК Период,
	ВТ_СгруппированнаяНоменклатура.Документ КАК Документ,
	ВТ_СгруппированнаяНоменклатура.Номенклатура КАК Номенклатура,
	ВТ_СгруппированнаяНоменклатура.Характеристика КАК Характеристика,
	ВТ_СгруппированнаяНоменклатура.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	ВТ_СгруппированнаяНоменклатура.ВидРемонта КАК ВидРемонта,
	ВТ_СгруппированнаяНоменклатура.Количество КАК Количество,
	ВТ_СгруппированнаяНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	ЦеныНоменклатуры.ВидЦены КАК ТипЦен,
	ЦеныНоменклатуры.Валюта КАК Валюта,
	ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) КАК Цена
ПОМЕСТИТЬ НоменклатураЦеныВалюта
ИЗ
	ВТ_СгруппированнаяНоменклатура КАК ВТ_СгруппированнаяНоменклатура
		ЛЕВОЕ СОЕДИНЕНИЕ НоменклатураПериодЦен КАК НоменклатураПериодЦен
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
			ПО НоменклатураПериодЦен.Номенклатура = ЦеныНоменклатуры.Номенклатура
				И НоменклатураПериодЦен.Характеристика = ЦеныНоменклатуры.Характеристика
				И НоменклатураПериодЦен.ПериодЦена = ЦеныНоменклатуры.Период
				И НоменклатураПериодЦен.ТипЦен = ЦеныНоменклатуры.ВидЦены
				И НоменклатураПериодЦен.Валюта = ЦеныНоменклатуры.Валюта
		ПО ВТ_СгруппированнаяНоменклатура.Период = НоменклатураПериодЦен.Период
			И ВТ_СгруппированнаяНоменклатура.Номенклатура = НоменклатураПериодЦен.Номенклатура
			И ВТ_СгруппированнаяНоменклатура.Характеристика = НоменклатураПериодЦен.Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДанныеВалюта.Документ КАК Документ,
	ДанныеВалюта.Номенклатура КАК Номенклатура,
	ДанныеВалюта.Характеристика КАК Характеристика,
	ДанныеВалюта.Валюта КАК Валюта,
	МАКСИМУМ(КурсыВалют.Период) КАК ДатаРегистр,
	ДанныеВалюта.Период КАК Период
ПОМЕСТИТЬ ДатаРегистраКурсов
ИЗ
	НоменклатураЦеныВалюта КАК ДанныеВалюта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ДанныеВалюта.Валюта = КурсыВалют.Валюта
			И ДанныеВалюта.Период &gt;= КурсыВалют.Период

СГРУППИРОВАТЬ ПО
	ДанныеВалюта.Документ,
	ДанныеВалюта.Номенклатура,
	ДанныеВалюта.Характеристика,
	ДанныеВалюта.Валюта,
	ДанныеВалюта.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	ДатаРегистраКурсов.Документ КАК Документ,
	ДатаРегистраКурсов.Номенклатура КАК Номенклатура,
	ДатаРегистраКурсов.Характеристика КАК Характеристика,
	ДатаРегистраКурсов.Период КАК Период,
	ДатаРегистраКурсов.Валюта КАК Валюта,
	ЕСТЬNULL(КурсыВалют.Курс, 0) КАК Курс,
	ЕСТЬNULL(КурсыВалют.Кратность, 1) КАК Кратность
ПОМЕСТИТЬ ТабКурсыВалют
ИЗ
	ДатаРегистраКурсов КАК ДатаРегистраКурсов
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ДатаРегистраКурсов.Валюта = КурсыВалют.Валюта
			И ДатаРегистраКурсов.ДатаРегистр = КурсыВалют.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НоменклатураКоличество.Период КАК Период,
	НоменклатураКоличество.Документ КАК Документ,
	НоменклатураКоличество.Номенклатура КАК Номенклатура,
	НоменклатураКоличество.Характеристика КАК Характеристика,
	НоменклатураКоличество.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	НоменклатураКоличество.ВидРемонта КАК ВидРемонта,
	НоменклатураКоличество.Номенклатура.Артикул КАК Артикул,
	СУММА(НоменклатураКоличество.Количество) КАК Количество,
	НоменклатураКоличество.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	СУММА(НоменклатураКоличество.Количество * НоменклатураКоличество.Цена * ТабКурсыВалют.Курс / ТабКурсыВалют.Кратность) КАК Сумма
ПОМЕСТИТЬ ТабМТО
ИЗ
	НоменклатураЦеныВалюта КАК НоменклатураКоличество
		ЛЕВОЕ СОЕДИНЕНИЕ ТабКурсыВалют КАК ТабКурсыВалют
		ПО НоменклатураКоличество.Номенклатура = ТабКурсыВалют.Номенклатура
			И НоменклатураКоличество.Характеристика = ТабКурсыВалют.Характеристика
			И НоменклатураКоличество.Период = ТабКурсыВалют.Период
			И НоменклатураКоличество.Валюта = ТабКурсыВалют.Валюта
			И НоменклатураКоличество.Документ = ТабКурсыВалют.Документ

СГРУППИРОВАТЬ ПО
	НоменклатураКоличество.Номенклатура,
	НоменклатураКоличество.Характеристика,
	НоменклатураКоличество.ОбъектРемонтныхРабот,
	НоменклатураКоличество.ВидРемонта,
	НоменклатураКоличество.Документ,
	НоменклатураКоличество.ЕдиницаИзмерения,
	НоменклатураКоличество.Номенклатура.Артикул,
	НоменклатураКоличество.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	БазаОтчета.ДатаРемонта КАК ДатаРемонта,
	БазаОтчета.ДатаОкончания КАК ДатаОкончания,
	БазаОтчета.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот
ПОМЕСТИТЬ ВТ_ОграниченияКалендарныеГрафики
ИЗ
	БазаОтчета КАК БазаОтчета

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаРемонта,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаОкончания,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект.ПлановыйГрафикРаботы
ИЗ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований КАК СписокЗаявокНаОснованииДефектовИВнешнихОснований
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВТ_ОграниченияКалендарныеГрафики.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
	МИНИМУМ(ВТ_ОграниченияКалендарныеГрафики.ДатаРемонта) КАК ДатаРемонта,
	МАКСИМУМ(ВТ_ОграниченияКалендарныеГрафики.ДатаОкончания) КАК ДатаОкончания
ПОМЕСТИТЬ ВТ_ОграниченияКалендаря
ИЗ
	ВТ_ОграниченияКалендарныеГрафики КАК ВТ_ОграниченияКалендарныеГрафики

СГРУППИРОВАТЬ ПО
	ВТ_ОграниченияКалендарныеГрафики.ГрафикРемонтныхРабот

ИНДЕКСИРОВАТЬ ПО
	ГрафикРемонтныхРабот
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	КалендарныеГрафики.Календарь КАК Календарь,
	КалендарныеГрафики.Год КАК Год,
	КалендарныеГрафики.ДатаГрафика КАК ДатаГрафика,
	КалендарныеГрафики.ДеньВключенВГрафик КАК ДеньВключенВГрафик,
	КалендарныеГрафики.КоличествоДнейВГрафикеСНачалаГода КАК КоличествоДнейВГрафикеСНачалаГода
ПОМЕСТИТЬ ВТ_КалендарныеГрафики
ИЗ
	РегистрСведений.КалендарныеГрафики КАК КалендарныеГрафики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОграниченияКалендаря КАК ВТ_ОграниченияКалендаря
		ПО КалендарныеГрафики.Календарь = ВТ_ОграниченияКалендаря.ГрафикРемонтныхРабот
			И КалендарныеГрафики.ДатаГрафика &gt;= НАЧАЛОПЕРИОДА(ВТ_ОграниченияКалендаря.ДатаРемонта, ДЕНЬ)
			И КалендарныеГрафики.ДатаГрафика &lt;= НАЧАЛОПЕРИОДА(ВТ_ОграниченияКалендаря.ДатаОкончания, ДЕНЬ)

ИНДЕКСИРОВАТЬ ПО
	Календарь
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	БазаОтчета.Объект КАК Объект,
	БазаОтчета.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	торо_РемонтыИнструментыИТехника.Инструмент КАК Инструмент,
	КалендарныеГрафики.ДатаГрафика КАК Дата,
	СУММА(торо_РемонтыИнструментыИТехника.Количество * БазаОтчета.Количество) КАК КоличествоИнструменты,
	МАКСИМУМ(торо_РемонтыИнструментыИТехника.Количество * БазаОтчета.Количество) КАК МаксимальнаяПотребностьИнструменты,
	БазаОтчета.ДокППР КАК ПланГрафикИнструменты,
	БазаОтчета.НормРемДляПольз КАК НормативныйРемонтИнструменты,
	БазаОтчета.Смета КАК СметаИнструменты
ПОМЕСТИТЬ ТабИнструментов
ИЗ
	ВТ_КалендарныеГрафики КАК КалендарныеГрафики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ БазаОтчета КАК БазаОтчета
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТехКарты.ИнструментыИТехника КАК торо_РемонтыИнструментыИТехника
			ПО БазаОтчета.ТехКарта = торо_РемонтыИнструментыИТехника.Ссылка
		ПО (БазаОтчета.ГрафикРемонтныхРабот = КалендарныеГрафики.Календарь)
			И КалендарныеГрафики.ДатаГрафика &gt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаРемонта, ДЕНЬ)
			И КалендарныеГрафики.ДатаГрафика &lt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаОкончания, ДЕНЬ)
ГДЕ
	БазаОтчета.Смета ЕСТЬ NULL

СГРУППИРОВАТЬ ПО
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	торо_РемонтыИнструментыИТехника.Инструмент,
	торо_РемонтыИнструментыИТехника.Количество,
	КалендарныеГрафики.ДатаГрафика,
	БазаОтчета.ДокППР,
	БазаОтчета.НормРемДляПольз,
	БазаОтчета.Смета

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	торо_ЗаявкаНаРемонтИнструменты.Инструмент,
	КалендарныеГрафики.ДатаГрафика,
	СУММА(торо_ЗаявкаНаРемонтИнструменты.Количество),
	МАКСИМУМ(торо_ЗаявкаНаРемонтИнструменты.Количество),
	БазаОтчета.ДокППР,
	БазаОтчета.НормРемДляПольз,
	БазаОтчета.Смета
ИЗ
	ВТ_КалендарныеГрафики КАК КалендарныеГрафики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ БазаОтчета КАК БазаОтчета
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.Инструменты КАК торо_ЗаявкаНаРемонтИнструменты
			ПО БазаОтчета.Смета = торо_ЗаявкаНаРемонтИнструменты.Ссылка
				И БазаОтчета.ID = торо_ЗаявкаНаРемонтИнструменты.РемонтыОборудования_ID
		ПО (БазаОтчета.ГрафикРемонтныхРабот = КалендарныеГрафики.Календарь)
			И КалендарныеГрафики.ДатаГрафика &gt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаРемонта, ДЕНЬ)
			И КалендарныеГрафики.ДатаГрафика &lt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаОкончания, ДЕНЬ)
ГДЕ
	НЕ БазаОтчета.Смета ЕСТЬ NULL

СГРУППИРОВАТЬ ПО
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	торо_ЗаявкаНаРемонтИнструменты.Инструмент,
	торо_ЗаявкаНаРемонтИнструменты.Количество,
	КалендарныеГрафики.ДатаГрафика,
	БазаОтчета.ДокППР,
	БазаОтчета.НормРемДляПольз,
	БазаОтчета.Смета

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ВидРемонтныхРабот,
	торо_ЗаявкаНаРемонтИнструменты.Инструмент,
	КалендарныеГрафики.ДатаГрафика,
	торо_ЗаявкаНаРемонтИнструменты.Количество,
	МАКСИМУМ(торо_ЗаявкаНаРемонтИнструменты.Количество),
	NULL,
	NULL,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета
ИЗ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований КАК СписокЗаявокНаОснованииДефектовИВнешнихОснований
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КалендарныеГрафики КАК КалендарныеГрафики
		ПО СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект.ПлановыйГрафикРаботы = КалендарныеГрафики.Календарь
			И (КалендарныеГрафики.ДатаГрафика &gt;= НАЧАЛОПЕРИОДА(СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаРемонта, ДЕНЬ))
			И (КалендарныеГрафики.ДатаГрафика &lt;= НАЧАЛОПЕРИОДА(СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаОкончания, ДЕНЬ))
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.Инструменты КАК торо_ЗаявкаНаРемонтИнструменты
		ПО СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета = торо_ЗаявкаНаРемонтИнструменты.Ссылка
			И СписокЗаявокНаОснованииДефектовИВнешнихОснований.ID = торо_ЗаявкаНаРемонтИнструменты.РемонтыОборудования_ID

СГРУППИРОВАТЬ ПО
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ВидРемонтныхРабот,
	торо_ЗаявкаНаРемонтИнструменты.Инструмент,
	КалендарныеГрафики.ДатаГрафика,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета,
	торо_ЗаявкаНаРемонтИнструменты.Количество
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	БазаОтчета.Объект КАК Объект,
	БазаОтчета.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	КалендарныеГрафики.ДатаГрафика КАК Дата,
	торо_РемонтыТрудовыеЗатраты.Квалификация КАК Квалификация,
	торо_РемонтыТрудовыеЗатраты.Количество КАК КоличествоСотрудники,
	НАЧАЛОПЕРИОДА(КалендарныеГрафики.ДатаГрафика, МЕСЯЦ) КАК Период,
	торо_РемонтыТрудовыеЗатраты.Количество КАК МаксимальнаяПотребностьСотрудники,
	СУММА(торо_РемонтыТрудовыеЗатраты.ВремяРаботы * торо_РемонтыТрудовыеЗатраты.Количество / БазаОтчета.КоличествоДней) КАК ВремяРаботы
ПОМЕСТИТЬ ТабСотрудников
ИЗ
	ВТ_КалендарныеГрафики КАК КалендарныеГрафики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ БазаОтчета КАК БазаОтчета
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТехКарты.ТрудовыеЗатраты КАК торо_РемонтыТрудовыеЗатраты
			ПО БазаОтчета.ТехКарта = торо_РемонтыТрудовыеЗатраты.Ссылка
		ПО (БазаОтчета.ГрафикРемонтныхРабот = КалендарныеГрафики.Календарь)
			И КалендарныеГрафики.ДатаГрафика &gt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаРемонта, ДЕНЬ)
			И КалендарныеГрафики.ДатаГрафика &lt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаОкончания, ДЕНЬ)
ГДЕ
	БазаОтчета.Смета ЕСТЬ NULL

СГРУППИРОВАТЬ ПО
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	КалендарныеГрафики.ДатаГрафика,
	торо_РемонтыТрудовыеЗатраты.Квалификация,
	торо_РемонтыТрудовыеЗатраты.Количество,
	НАЧАЛОПЕРИОДА(КалендарныеГрафики.ДатаГрафика, МЕСЯЦ),
	торо_РемонтыТрудовыеЗатраты.Количество

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	КалендарныеГрафики.ДатаГрафика,
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Квалификация,
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество,
	НАЧАЛОПЕРИОДА(КалендарныеГрафики.ДатаГрафика, МЕСЯЦ),
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество,
	СУММА(торо_ЗаявкаНаРемонтТрудовыеЗатраты.ВремяРаботы * торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество / БазаОтчета.КоличествоДней)
ИЗ
	ВТ_КалендарныеГрафики КАК КалендарныеГрафики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ БазаОтчета КАК БазаОтчета
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ТрудовыеЗатраты КАК торо_ЗаявкаНаРемонтТрудовыеЗатраты
			ПО БазаОтчета.Смета = торо_ЗаявкаНаРемонтТрудовыеЗатраты.Ссылка
				И БазаОтчета.ID = торо_ЗаявкаНаРемонтТрудовыеЗатраты.РемонтыОборудования_ID
		ПО (БазаОтчета.ГрафикРемонтныхРабот = КалендарныеГрафики.Календарь)
			И КалендарныеГрафики.ДатаГрафика &gt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаРемонта, ДЕНЬ)
			И КалендарныеГрафики.ДатаГрафика &lt;= НАЧАЛОПЕРИОДА(БазаОтчета.ДатаОкончания, ДЕНЬ)
ГДЕ
	НЕ БазаОтчета.Смета ЕСТЬ NULL

СГРУППИРОВАТЬ ПО
	БазаОтчета.Объект,
	БазаОтчета.ВидРемонтныхРабот,
	КалендарныеГрафики.ДатаГрафика,
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Квалификация,
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество,
	НАЧАЛОПЕРИОДА(КалендарныеГрафики.ДатаГрафика, МЕСЯЦ),
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект,
	СписокЗаявокНаОснованииДефектовИВнешнихОснований.ВидРемонтныхРабот,
	КалендарныеГрафики.ДатаГрафика,
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Квалификация,
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество,
	НАЧАЛОПЕРИОДА(КалендарныеГрафики.ДатаГрафика, МЕСЯЦ),
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество,
	торо_ЗаявкаНаРемонтТрудовыеЗатраты.ВремяРаботы * торо_ЗаявкаНаРемонтТрудовыеЗатраты.Количество / (РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаРемонта, ДЕНЬ), КОНЕЦПЕРИОДА(СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаОкончания, ДЕНЬ), ДЕНЬ) + 1)
ИЗ
	СписокЗаявокНаОснованииДефектовИВнешнихОснований КАК СписокЗаявокНаОснованииДефектовИВнешнихОснований
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КалендарныеГрафики КАК КалендарныеГрафики
		ПО СписокЗаявокНаОснованииДефектовИВнешнихОснований.Объект.ПлановыйГрафикРаботы = КалендарныеГрафики.Календарь
			И (КалендарныеГрафики.ДатаГрафика &gt;= НАЧАЛОПЕРИОДА(СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаРемонта, ДЕНЬ))
			И (КалендарныеГрафики.ДатаГрафика &lt;= НАЧАЛОПЕРИОДА(СписокЗаявокНаОснованииДефектовИВнешнихОснований.ДатаОкончания, ДЕНЬ))
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ТрудовыеЗатраты КАК торо_ЗаявкаНаРемонтТрудовыеЗатраты
		ПО СписокЗаявокНаОснованииДефектовИВнешнихОснований.Смета = торо_ЗаявкаНаРемонтТрудовыеЗатраты.Ссылка
			И СписокЗаявокНаОснованииДефектовИВнешнихОснований.ID = торо_ЗаявкаНаРемонтТрудовыеЗатраты.РемонтыОборудования_ID
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ТабМТО.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	ТабМТО.ВидРемонта КАК ВидРемонта,
	ТабМТО.Номенклатура КАК Номенклатура,
	ТабМТО.Характеристика КАК Характеристика,
	ВЫБОР
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.День)
			ТОГДА НАЧАЛОПЕРИОДА(ТабМТО.Период, ДЕНЬ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
			ТОГДА НАЧАЛОПЕРИОДА(ТабМТО.Период, МЕСЯЦ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год)
			ТОГДА НАЧАЛОПЕРИОДА(ТабМТО.Период, ГОД)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
			ТОГДА НАЧАЛОПЕРИОДА(ТабМТО.Период, КВАРТАЛ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Неделя)
			ТОГДА НАЧАЛОПЕРИОДА(ТабМТО.Период, НЕДЕЛЯ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Декада)
			ТОГДА НАЧАЛОПЕРИОДА(ТабМТО.Период, ДЕКАДА)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Полугодие)
			ТОГДА НАЧАЛОПЕРИОДА(ТабМТО.Период, ПОЛУГОДИЕ)
	КОНЕЦ КАК Период,
	NULL КАК МаксимальнаяПотребностьИнструменты,
	NULL КАК НормативныйРемонтИнструменты,
	ТабМТО.Сумма КАК Сумма,
	ТабМТО.Количество КАК Количество,
	0 КАК Инструмент,
	0 КАК Квалификация,
	NULL КАК ВремяРаботы
ПОМЕСТИТЬ ВТ_Итог
ИЗ
	ТабМТО КАК ТабМТО

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ТабИнструментов.Объект,
	ТабИнструментов.ВидРемонтныхРабот,
	0,
	0,
	ВЫБОР
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.День)
			ТОГДА НАЧАЛОПЕРИОДА(ТабИнструментов.Дата, ДЕНЬ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
			ТОГДА НАЧАЛОПЕРИОДА(ТабИнструментов.Дата, МЕСЯЦ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год)
			ТОГДА НАЧАЛОПЕРИОДА(ТабИнструментов.Дата, ГОД)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
			ТОГДА НАЧАЛОПЕРИОДА(ТабИнструментов.Дата, КВАРТАЛ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Неделя)
			ТОГДА НАЧАЛОПЕРИОДА(ТабИнструментов.Дата, НЕДЕЛЯ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Декада)
			ТОГДА НАЧАЛОПЕРИОДА(ТабИнструментов.Дата, ДЕКАДА)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Полугодие)
			ТОГДА НАЧАЛОПЕРИОДА(ТабИнструментов.Дата, ПОЛУГОДИЕ)
	КОНЕЦ,
	ТабИнструментов.МаксимальнаяПотребностьИнструменты,
	ТабИнструментов.НормативныйРемонтИнструменты,
	NULL,
	NULL,
	ТабИнструментов.Инструмент,
	0,
	NULL
ИЗ
	ТабИнструментов КАК ТабИнструментов

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ТабСотрудников.Объект,
	ТабСотрудников.ВидРемонтныхРабот,
	0,
	0,
	ВЫБОР
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.День)
			ТОГДА НАЧАЛОПЕРИОДА(ТабСотрудников.Дата, ДЕНЬ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
			ТОГДА НАЧАЛОПЕРИОДА(ТабСотрудников.Дата, МЕСЯЦ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год)
			ТОГДА НАЧАЛОПЕРИОДА(ТабСотрудников.Дата, ГОД)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
			ТОГДА НАЧАЛОПЕРИОДА(ТабСотрудников.Дата, КВАРТАЛ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Неделя)
			ТОГДА НАЧАЛОПЕРИОДА(ТабСотрудников.Дата, НЕДЕЛЯ)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Декада)
			ТОГДА НАЧАЛОПЕРИОДА(ТабСотрудников.Дата, ДЕКАДА)
		КОГДА &amp;Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Полугодие)
			ТОГДА НАЧАЛОПЕРИОДА(ТабСотрудников.Дата, ПОЛУГОДИЕ)
	КОНЕЦ,
	ТабСотрудников.МаксимальнаяПотребностьСотрудники,
	NULL,
	NULL,
	NULL,
	0,
	ТабСотрудников.Квалификация,
	ТабСотрудников.ВремяРаботы
ИЗ
	ТабСотрудников КАК ТабСотрудников
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВТ_Итог.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	ВТ_Итог.ВидРемонта КАК ВидРемонта,
	ВТ_Итог.Номенклатура КАК Номенклатура,
	ВТ_Итог.Характеристика КАК Характеристика,
	ВТ_Итог.Период КАК Период,
	ВТ_Итог.МаксимальнаяПотребностьИнструменты КАК МаксимальнаяПотребностьИнструменты,
	ВТ_Итог.НормативныйРемонтИнструменты КАК НормативныйРемонтИнструменты,
	ВТ_Итог.Сумма КАК Сумма,
	ВТ_Итог.Количество КАК Количество,
	ВТ_Итог.Инструмент КАК Инструмент,
	ВТ_Итог.Квалификация КАК Квалификация,
	ВТ_Итог.ВремяРаботы КАК ВремяРаботы,
	торо_ОбъектыРемонта.Ссылка КАК ОбъектИерархии
ИЗ
	ВТ_Итог КАК ВТ_Итог
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		ПО ВТ_Итог.ОбъектРемонтныхРабот = торо_ОбъектыРемонта.Ссылка</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Иерархия</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектИерархии</dataPath>
