#Область Локализация

Функция дс_ДобавитьПараметрыВТекстЗапроса(ТекстЗапроса)
	СтрокиЗамены = Новый Соответствие;

	СтрокиЗамены.Вставить("""Работы завершены""", 	"&РаботыЗавершены");
	СтрокиЗамены.Вставить("""Работы начаты""", 		"&РаботыНачаты");
	СтрокиЗамены.Вставить("""Работы не начаты""", 	"&РаботыНеНачаты");

	Для каждого КодЗамены Из СтрокиЗамены Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, КодЗамены.Ключ, КодЗамены.Значение);
	КонецЦикла;
	
	Возврат ТекстЗапроса;
КонецФункции
 
Процедура дс_ДобавитьПараметрыВСКД()
	Переводы = Новый Соответствие;

	Переводы.Вставить("РаботыЗавершены", 	НСтр("es='El trabajo se haya completado';ru='Работы завершены';en='Work completed'"));
	Переводы.Вставить("РаботыНачаты", 		НСтр("es='El trabajo iniciado';ru='Работы начаты';en='Work started'"));
	Переводы.Вставить("РаботыНеНачаты", 	НСтр("es='El trabajo no se desarrollan';ru='Работы не начаты';en='Work is not started'"));
	
	Для каждого Перевод Из Переводы Цикл
		Если СхемаКомпоновкиДанных.Параметры.Найти(Перевод.Ключ) = Неопределено Тогда
			НовыйПараметр = СхемаКомпоновкиДанных.Параметры.Добавить();
			НовыйПараметр.Имя 			= Перевод.Ключ;
			НовыйПараметр.Значение 		= Перевод.Значение;
			НовыйПараметр.Использование = ИспользованиеПараметраКомпоновкиДанных.Всегда;
			НовыйПараметр.ОграничениеИспользования = Истина;
		КонецЕсли; 
	КонецЦикла; 
КонецПроцедуры

