		<destinationExpression>Объект</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>ГруппыНоменклатуры</sourceDataSet>
		<destinationDataSet>НоменклатураКласса</destinationDataSet>
		<sourceExpression>ГруппаНоменклатуры</sourceExpression>
		<destinationExpression>ГруппаНоменклатуры</destinationExpression>
	</dataSetLink>
