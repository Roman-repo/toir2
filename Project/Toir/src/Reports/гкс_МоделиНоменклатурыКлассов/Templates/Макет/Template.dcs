<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НоменклатураКласса</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипНоменклатуры</dataPath>
			<field>ТипНоменклатуры</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Тип номенклатуры</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ГруппаНоменклатуры</dataPath>
			<field>ГруппаНоменклатуры</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Группа номенклатуры</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	НоменклатураКласса.Ссылка КАК ТипНоменклатуры,
	НоменклатураКласса.Родитель КАК ГруппаНоменклатуры
	//ВЫБОР
	//	КОГДА НоменклатураКласса.ЭтоГруппа
	//		ТОГДА 0
	//	ИНАЧЕ 1
	//КОНЕЦ КАК КоличествоМоделей
ИЗ
	Справочник.НоменклатураКласса КАК НоменклатураКласса
ГДЕ
	НоменклатураКласса.Класс В ИЕРАРХИИ(&amp;ТипНоменклатуры)
	И НЕ НоменклатураКласса.ЭтоГруппа</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>СведенияОНоменклатуре</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипНоменклатуры.ДатаСоздания</dataPath>
			<field>ДатаСоздания</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Объект</dataPath>
			<field>Объект</field>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
			<attributeUseRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</attributeUseRestriction>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипНоменклатуры.АвторИзменения</dataPath>
			<field>АвторИзменения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипНоменклатуры.Автор</dataPath>
			<field>Автор</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипНоменклатуры.ДатаИзменения</dataPath>
			<field>ДатаИзменения</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	СведенияОНоменклатуреКлассов.Объект,
	СведенияОНоменклатуреКлассов.Автор,
	СведенияОНоменклатуреКлассов.ДатаСоздания,
	СведенияОНоменклатуреКлассов.АвторИзменения,
	СведенияОНоменклатуреКлассов.ДатаИзменения
ИЗ
	РегистрСведений.СведенияОНоменклатуреКлассов КАК СведенияОНоменклатуреКлассов</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ГруппыНоменклатуры</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ГруппаНоменклатуры</dataPath>
			<field>ГруппаНоменклатуры</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Группа номенклатуры</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	НоменклатураКласса.Ссылка КАК ГруппаНоменклатуры
ИЗ
	Справочник.НоменклатураКласса КАК НоменклатураКласса
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НоменклатураКласса КАК ВложенныеГруппы
		ПО НоменклатураКласса.Ссылка = ВложенныеГруппы.Родитель
			И (ВложенныеГруппы.ЭтоГруппа)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НоменклатураКласса КАК ВложеннаяНоменклатура
		ПО НоменклатураКласса.Ссылка = ВложеннаяНоменклатура.Родитель
			И (НЕ ВложеннаяНоменклатура.ЭтоГруппа)
ГДЕ
	НоменклатураКласса.ЭтоГруппа
	И НоменклатураКласса.Класс В ИЕРАРХИИ(&amp;ТипНоменклатуры)
	И (ВложенныеГруппы.Ссылка ЕСТЬ NULL
			ИЛИ НЕ ВложеннаяНоменклатура.Ссылка ЕСТЬ NULL)</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>НоменклатураКласса</sourceDataSet>
		<destinationDataSet>СведенияОНоменклатуре</destinationDataSet>
