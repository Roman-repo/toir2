Функция дс_ДобавитьПараметрыВТекстЗапроса(ТекстЗапроса)
	СтрокиЗамены = Новый Соответствие;

	СтрокиЗамены.Вставить("""Факт""", "&Факт");
	СтрокиЗамены.Вставить("""План""", "&План");
	СтрокиЗамены.Вставить("""Останов""", "&Останов");

	Для каждого КодЗамены Из СтрокиЗамены Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, КодЗамены.Ключ, КодЗамены.Значение);
	КонецЦикла;
	
	Возврат ТекстЗапроса;
КонецФункции
 
Процедура дс_ДобавитьПараметрыВСКД()
	Переводы = Новый Соответствие;
	
	Переводы.Вставить("Факт", 		НСтр("es='El hecho de';ru='Факт';en='Fact'"));
	Переводы.Вставить("План", 		НСтр("es='El plan de';ru='План';en='Plan'"));
	Переводы.Вставить("Останов", 	НСтр("es='Parada';ru='Останов';en='Stop'"));
	
	Для каждого Перевод Из Переводы Цикл
		НовыйПараметр = СхемаКомпоновкиДанных.Параметры.Добавить();
		НовыйПараметр.Имя 			= Перевод.Ключ;
		НовыйПараметр.Значение 		= Перевод.Значение;
		НовыйПараметр.Использование = ИспользованиеПараметраКомпоновкиДанных.Всегда;
		НовыйПараметр.ОграничениеИспользования = Истина;
	КонецЦикла; 
КонецПроцедуры

Процедура дс_УстановитьУсловноеОформление()
	Переводы = Новый Соответствие;
	
	Переводы.Вставить("Факт", 		НСтр("es='El hecho de';ru='Факт';en='Fact'"));
	Переводы.Вставить("План", 		НСтр("es='El plan de';ru='План';en='Plan'"));
	Переводы.Вставить("Останов", 	НСтр("es='Parada';ru='Останов';en='Stop'"));
	
	УО = КомпоновщикНастроек.Настройки.УсловноеОформление.Элементы;
	
	Элементы = Новый Массив;
	Для каждого ЭлементУО Из УО Цикл
		дс_ПолучитьВложенныеОтборы(ЭлементУО.Отбор, Элементы);
	КонецЦикла; 
	
	Для каждого ЭлементОтбора Из Элементы Цикл
		Перевод = Переводы[ЭлементОтбора.ПравоеЗначение];
		
		Если Перевод <> Неопределено Тогда
			ЭлементОтбора.ПравоеЗначение = Перевод;
		КонецЕсли; 
	КонецЦикла; 
КонецПроцедуры

Процедура дс_ПолучитьВложенныеОтборы(Элемент, Массив)
	Если ТипЗнч(Элемент) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
		Массив.Добавить(Элемент);
		Возврат;
	Иначе
		Для каждого ПодЭлемент Из Элемент.Элементы Цикл
			дс_ПолучитьВложенныеОтборы(ПодЭлемент, Массив);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура дс_ЗаполнитьВычисляемыеПоля()
	Поля = Новый Соответствие;
	
	Поля.Вставить("ПредставлениеДаты", "ВЫБОР КОГДА &Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал) Тогда Строка(Квартал(ДатаНачала)) + НСтр(""ru = ' квартал '; en = ' quarter '; es = ' trimestre '"") + Строка(Год(ДатаНачала))  КОГДА &Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц) Тогда  ВЫБОР КОГДА Месяц(ДатаНачала) =1 ТОГДА НСтр(""ru = 'Январь '; en = 'January '; es = 'Enero '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=2 ТОГДА НСтр(""ru = 'Февраль '; en = 'February '; es = 'Febrero '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)= 3 ТОГДА НСтр(""ru = 'Март '; en = 'March '; es = 'Marzo '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=4 ТОГДА НСтр(""ru = 'Апрель '; en = 'April '; es = 'Abril '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=5 ТОГДА НСтр(""ru = 'Май '; en = 'May '; es = 'Mayo '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=6 ТОГДА НСтр(""ru = 'Июнь '; en = 'June '; es = 'Junio '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=7 ТОГДА НСтр(""ru = 'Июль '; en = 'July '; es = 'Julio '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)= 8 ТОГДА НСтр(""ru = 'Август '; en = 'August '; es = 'Agosto '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=9 ТОГДА НСтр(""ru = 'Сентябрь '; en = 'September '; es = 'Septiembre '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=10 ТОГДА НСтр(""ru = 'Октябрь '; en = 'October '; es = 'Octubre '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=11 ТОГДА НСтр(""ru = 'Ноябрь '; en = 'November '; es = 'Noviembre '"") + Строка(ГОД(ДатаНачала)) КОГДА Месяц(ДатаНачала)=12 ТОГДА НСтр(""ru = 'Декабрь '; en = 'December '; es = 'Diciembre '"") + Строка(ГОД(ДатаНачала)) КОНЕЦ КОГДА &Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Неделя) Тогда Строка(Неделя(ДатаНачала)) + НСтр(""ru = ' неделя '; en = ' week '; es = ' la semana '"") + Строка(Год(ДатаНачала))  КОГДА &Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Полугодие) Тогда ВЫБОР КОГДА Месяц(ДатаНачала) = 7 Тогда НСтр(""ru = '2 полугодие '; en = '2nd half '; es = '2 semestre '"") + Строка(Год(ДатаНачала))  ИНАЧЕ НСтр(""ru = '1 полугодие '; en = '1H '; es = '1 semestre '"") + Строка(Год(ДатаНачала)) КОНЕЦ КОГДА &Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год) Тогда Строка(ГОД(ДатаНачала)) ИНАЧЕ ДатаНачала КОНЕЦ");
	
