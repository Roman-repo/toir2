#Область Локализация

Функция дс_ДобавитьПараметрыВТекстЗапроса(ТекстЗапроса)
	СтрокиЗамены = Новый Соответствие;

	СтрокиЗамены.Вставить("""Ремонт, выполняемый подрядчиками""", "&_РемонтВыполняемыйПодрядчиками");
	СтрокиЗамены.Вставить("""Материальные затраты""", "&_МатериальныеЗатраты");
	СтрокиЗамены.Вставить("""Трудозатраты""", "&_Трудозатраты");
	СтрокиЗамены.Вставить("""Запчасти""", "&_Запчасти");
	СтрокиЗамены.Вставить("""Установка запчастей""", "&_УстановкаЗапчастей");

	Для каждого КодЗамены Из СтрокиЗамены Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, КодЗамены.Ключ, КодЗамены.Значение);
	КонецЦикла;
	
	Возврат ТекстЗапроса;
КонецФункции
 
Процедура дс_ДобавитьПараметрыВСКД()
	Переводы = Новый Соответствие;
	
	Переводы.Вставить("_РемонтВыполняемыйПодрядчиками", НСтр("es='La reparación ejecutada por contratistas';ru='Ремонт, выполняемый подрядчиками';en='Repairs performed by contractors'"));
	Переводы.Вставить("_МатериальныеЗатраты", НСтр("es='Los costos de los materiales';ru='Материальные затраты';en='Material costs'"));
	Переводы.Вставить("_Трудозатраты", НСтр("es='Mano de obra';ru='Трудозатраты';en='Labor costs'"));
	Переводы.Вставить("_Запчасти", НСтр("es='Las partes de recambio';ru='Запчасти';en='Spare parts'"));
	Переводы.Вставить("_УстановкаЗапчастей", НСтр("es='La instalación de piezas de recambio';ru='Установка запчастей';en='Installation of spare parts'"));
	
	Для каждого Перевод Из Переводы Цикл
		Если СхемаКомпоновкиДанных.Параметры.Найти(Перевод.Ключ) = Неопределено Тогда
			НовыйПараметр = СхемаКомпоновкиДанных.Параметры.Добавить();
			НовыйПараметр.Имя 			= Перевод.Ключ;
			НовыйПараметр.Значение 		= Перевод.Значение;
			НовыйПараметр.Использование = ИспользованиеПараметраКомпоновкиДанных.Всегда;
			НовыйПараметр.ОграничениеИспользования = Истина;
		КонецЕсли; 
	КонецЦикла; 
КонецПроцедуры

Процедура дс_ЗаполнитьРесурсы()
	Переводы = Новый Соответствие;
	
	Переводы.Вставить("""Трудозатраты""", НСтр("es='Mano de obra';ru='Трудозатраты';en='Labor costs'"));
	Переводы.Вставить("""Запчасти""", НСтр("es='Las partes de recambio';ru='Запчасти';en='Spare parts'"));

	Поля = Новый Соответствие;
	Для каждого Поле Из СхемаКомпоновкиДанных.ПоляИтога Цикл
		Выражение = Поле.Выражение;
		
		Для каждого Перевод Из Переводы Цикл
			Выражение = СтрЗаменить(Выражение, Перевод.Ключ, """" + Перевод.Значение + """");
		КонецЦикла;

		Поле.Выражение = Выражение;
	КонецЦикла; 
КонецПроцедуры
 
