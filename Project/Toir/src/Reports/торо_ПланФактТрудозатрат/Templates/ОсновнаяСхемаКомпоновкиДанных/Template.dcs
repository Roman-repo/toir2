					</v8:item>
					<v8:item>
						<v8:lang>es</v8:lang>
						<v8:content>ÙÄÛ=3; ЧН=0; ЧВН =; ЧГ=3,0</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>en</v8:lang>
						<v8:content>ЧДЦ=3; ЧН=0; ЧВН=; ЧГ=3,0</v8:content>
					</v8:item>
				</dcscor:value>
