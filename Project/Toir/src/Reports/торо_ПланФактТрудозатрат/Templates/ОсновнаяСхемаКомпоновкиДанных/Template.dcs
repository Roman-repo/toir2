			<field>Удалить_ID_Корректировок</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>// Данный запрос сохранен для работы настроек заполнения. 
// Но редактировать при необходимости нужно запрос в модуле объекта.

ВЫБРАТЬ РАЗРЕШЕННЫЕ
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ОбъектРемонта КАК ОбъектРемонта,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ВидРемонтныхРабот КАК ВидРемонта,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ДатаНачала КАК ДатаНачалаПлан,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник КАК Документ,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник) = ТИП(Документ.торо_ПланГрафикРемонта)
			ТОГДА "План-график ремонта"
		КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник) = ТИП(Документ.торо_ВыявленныеДефекты)
			ТОГДА "Выявленные дефекты"
		КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник) = ТИП(Документ.торо_ВнешнееОснованиеДляРабот)
			ТОГДА "Предписания"
		ИНАЧЕ "Прочее"
	КОНЕЦ КАК ВидДокумента,
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.РемонтнаяРабота КАК РемонтнаяРабота,
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.ID КАК РемонтнаяРабота_ID,
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.Квалификация КАК Квалификация,
	СУММА(торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.ВремяРаботы * торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.Количество) КАК ВремяРаботы,
	СУММА(торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.Количество) КАК Количество,
	СУММА(торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.Сумма) КАК Сумма
ПОМЕСТИТЬ ПлановыеЗатратыЗаявки
ИЗ
	РегистрНакопления.торо_ПлановыеТрудовыеЗатратыРемонтныхРабот КАК торо_ПлановыеТрудовыеЗатратыРемонтныхРабот
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК торо_ЗаявкаНаРемонтРемонтныеРаботы
		ПО (торо_ЗаявкаНаРемонтРемонтныеРаботы.Ссылка = торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.Регистратор)
			И (торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник ССЫЛКА Документ.торо_ВыявленныеДефекты
					И &amp;РассчетСметПоДефектам
				ИЛИ торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник ССЫЛКА Документ.торо_ВнешнееОснованиеДляРабот
					И &amp;РассчетСметПоВнешнимОснованиям
				ИЛИ торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник ССЫЛКА Документ.торо_ПланГрафикРемонта
					И &amp;РассчетПланГрафиковППР)
			И (торо_ЗаявкаНаРемонтРемонтныеРаботы.ID = торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.РемонтыОборудования_ID)
{ГДЕ
	(торо_ЗаявкаНаРемонтРемонтныеРаботы.ДатаНачала МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания)}

СГРУППИРОВАТЬ ПО
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.ID,
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.Квалификация,
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.РемонтыОборудования_ID,
	торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.РемонтнаяРабота,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ОбъектРемонта,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ВидРемонтныхРабот,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ДатаНачала,
	торо_ЗаявкаНаРемонтРемонтныеРаботы.ДокументИсточник

ИНДЕКСИРОВАТЬ ПО
	РемонтыОборудования_ID
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	торо_ПланГрафикППР.ДатаНачалаРемонтныхРабот КАК ДатаНачалаПлан,
	торо_ПланГрафикППР.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	торо_ПланГрафикППР.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	торо_ПланГрафикППР.Регистратор КАК Документ,
	торо_ПланГрафикППР.ID КАК ID,
	"План-график ремонта" КАК ВидДокумента
ПОМЕСТИТЬ ПлановыеРемонты
ИЗ
	РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних(, ) КАК торо_ПланГрафикППР
ГДЕ
	ВЫБОР
			КОГДА &amp;РассчетПланГрафиковППР
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И торо_ПланГрафикППР.Отменен = ЛОЖЬ
	И торо_ПланГрафикППР.Замещен = ЛОЖЬ
	И НЕ торо_ПланГрафикППР.ID В
				(ВЫБРАТЬ
					ПлановыеЗатратыЗаявки.РемонтыОборудования_ID КАК РемонтыОборудования_ID
				ИЗ
					ПлановыеЗатратыЗаявки КАК ПлановыеЗатратыЗаявки)
{ГДЕ
	(торо_ПланГрафикППР.ДатаНачалаРемонтныхРабот МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания)}

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	торо_ПлановыеМероприятия.ДатаНачала,
	торо_ПлановыеМероприятия.СписокОбъектов,
	торо_ПлановыеМероприятия.ВидМероприятия,
	торо_ПлановыеМероприятия.Регистратор,
	торо_ПлановыеМероприятия.ID,
	"Регламентные мероприятия"
ИЗ
	РегистрСведений.торо_ПлановыеМероприятия.СрезПоследних(, ) КАК торо_ПлановыеМероприятия
ГДЕ
	ВЫБОР
			КОГДА &amp;РассчетРеглМероприятий
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И НЕ торо_ПлановыеМероприятия.Отменен
{ГДЕ
	(торо_ПлановыеМероприятия.ДатаНачала МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания)}

ИНДЕКСИРОВАТЬ ПО
	ОбъектРемонтныхРабот,
	ВидРемонтныхРабот
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	ПлановыеРемонты.ОбъектРемонтныхРабот КАК ОбъектРемонта,
	ПлановыеРемонты.ВидРемонтныхРабот КАК ВидРемонта,
	торо_НормативныеРемонтыОборудования.НормативныйРемонт КАК ИдТехКарты,
	ПлановыеРемонты.ID КАК ID,
	ПлановыеРемонты.ДатаНачалаПлан КАК ДатаНачалаПлан,
	ПлановыеРемонты.Документ КАК Документ,
	ПлановыеРемонты.ВидДокумента КАК ВидДокумента
ПОМЕСТИТЬ НормативныеРемонтыИдентификаторы
ИЗ
	ПлановыеРемонты КАК ПлановыеРемонты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_НормативныеРемонтыОборудования КАК торо_НормативныеРемонтыОборудования
		ПО ПлановыеРемонты.ОбъектРемонтныхРабот = торо_НормативныеРемонтыОборудования.ОбъектРемонта
			И ПлановыеРемонты.ВидРемонтныхРабот = торо_НормативныеРемонтыОборудования.ВидРемонта
			И (торо_НормативныеРемонтыОборудования.Приоритет)
			И (ПлановыеРемонты.Документ ССЫЛКА Документ.торо_ПланГрафикРемонта)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	торо_МаршрутыРегламентныхМероприятий.ОбъектРемонта,
	ПлановыеРемонты.ВидРемонтныхРабот,
	торо_НормативныеРемонтыОборудования.НормативныйРемонт,
	ПлановыеРемонты.ID,
	ПлановыеРемонты.ДатаНачалаПлан,
	ПлановыеРемонты.Документ,
	ПлановыеРемонты.ВидДокумента
ИЗ
	ПлановыеРемонты КАК ПлановыеРемонты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_РегламентныеМероприятияИСпискиОбъектов КАК торо_НормативныеРемонтыОборудования
		ПО ПлановыеРемонты.ОбъектРемонтныхРабот = торо_НормативныеРемонтыОборудования.СписокОбъектов
			И ПлановыеРемонты.ВидРемонтныхРабот = торо_НормативныеРемонтыОборудования.ВидМероприятия
			И (ПлановыеРемонты.Документ ССЫЛКА Документ.торо_ГрафикРегламентныхМероприятийТОиР)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_МаршрутыРегламентныхМероприятий КАК торо_МаршрутыРегламентныхМероприятий
		ПО ПлановыеРемонты.ОбъектРемонтныхРабот = торо_МаршрутыРегламентныхМероприятий.СписокОбъектов
			И (ПлановыеРемонты.Документ ССЫЛКА Документ.торо_ГрафикРегламентныхМероприятийТОиР)

ИНДЕКСИРОВАТЬ ПО
	ИдТехКарты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НормативныеРемонтыИдентификаторы.ОбъектРемонта КАК ОбъектРемонта,
	НормативныеРемонтыИдентификаторы.ВидРемонта КАК ВидРемонта,
	НормативныеРемонтыИдентификаторы.ИдТехКарты КАК ИдТехКарты,
	НормативныеРемонтыИдентификаторы.ID КАК ID,
	НормативныеРемонтыИдентификаторы.ДатаНачалаПлан КАК ДатаНачалаПлан,
	НормативныеРемонтыИдентификаторы.Документ КАК Документ,
	НормативныеРемонтыИдентификаторы.ВидДокумента КАК ВидДокумента,
	МАКСИМУМ(торо_ВерсииТехКарт.Период) КАК ПериодВерсииТехКарты
ПОМЕСТИТЬ ПериодыВерсииТехКарты
ИЗ
	НормативныеРемонтыИдентификаторы КАК НормативныеРемонтыИдентификаторы
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт КАК торо_ВерсииТехКарт
		ПО НормативныеРемонтыИдентификаторы.ИдТехКарты = торо_ВерсииТехКарт.ИдентификаторТехКарты
			И НормативныеРемонтыИдентификаторы.ДатаНачалаПлан &gt;= торо_ВерсииТехКарт.Период

СГРУППИРОВАТЬ ПО
	НормативныеРемонтыИдентификаторы.ВидРемонта,
	НормативныеРемонтыИдентификаторы.ДатаНачалаПлан,
	НормативныеРемонтыИдентификаторы.Документ,
	НормативныеРемонтыИдентификаторы.ID,
	НормативныеРемонтыИдентификаторы.ВидДокумента,
	НормативныеРемонтыИдентификаторы.ОбъектРемонта,
	НормативныеРемонтыИдентификаторы.ИдТехКарты

ИНДЕКСИРОВАТЬ ПО
	ПериодВерсииТехКарты,
	ИдТехКарты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПериодыВерсииТехКарты.ОбъектРемонта КАК ОбъектРемонта,
	ПериодыВерсииТехКарты.ВидРемонта КАК ВидРемонта,
	ПериодыВерсииТехКарты.ID КАК ID,
	ПериодыВерсииТехКарты.ДатаНачалаПлан КАК ДатаНачалаПлан,
	ПериодыВерсииТехКарты.Документ КАК Документ,
	ПериодыВерсииТехКарты.ВидДокумента КАК ВидДокумента,
	торо_ВерсииТехКарт.ТехКарта КАК ТехКарта
ПОМЕСТИТЬ НормативныеРемонты
ИЗ
	ПериодыВерсииТехКарты КАК ПериодыВерсииТехКарты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт КАК торо_ВерсииТехКарт
		ПО ПериодыВерсииТехКарты.ПериодВерсииТехКарты = торо_ВерсииТехКарт.Период
			И ПериодыВерсииТехКарты.ИдТехКарты = торо_ВерсииТехКарт.ИдентификаторТехКарты

ИНДЕКСИРОВАТЬ ПО
	ТехКарта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НормативныеРемонты.ОбъектРемонта КАК ОбъектРемонта,
	НормативныеРемонты.ВидРемонта КАК ВидРемонта,
	НормативныеРемонты.ID КАК ID,
	НормативныеРемонты.ДатаНачалаПлан КАК ДатаНачалаПлан,
	НормативныеРемонты.Документ КАК Документ,
	НормативныеРемонты.ВидДокумента КАК ВидДокумента,
	НормативныеРемонты.ТехКарта КАК Ремонт,
	НормативныеРемонты.ТехКарта КАК ТехКарта
ПОМЕСТИТЬ НормативныеРемонты_ВсеТехКарты
ИЗ
	НормативныеРемонты КАК НормативныеРемонты

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	НормативныеРемонты.ОбъектРемонта,
	НормативныеРемонты.ВидРемонта,
	НормативныеРемонты.ID,
	НормативныеРемонты.ДатаНачалаПлан,
	НормативныеРемонты.Документ,
	НормативныеРемонты.ВидДокумента,
	НормативныеРемонты.ТехКарта,
	торо_СоставИерархическихТехКартРемонтов.Состав
ИЗ
	НормативныеРемонты КАК НормативныеРемонты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_СоставИерархическихТехКартРемонтов КАК торо_СоставИерархическихТехКартРемонтов
		ПО НормативныеРемонты.ТехКарта = торо_СоставИерархическихТехКартРемонтов.ТехКарта

ИНДЕКСИРОВАТЬ ПО
	ТехКарта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НормативныеРемонты_ВсеТехКарты.ID КАК РемонтыОборудования_ID,
	НормативныеРемонты_ВсеТехКарты.ОбъектРемонта КАК ОбъектРемонта,
	НормативныеРемонты_ВсеТехКарты.ВидРемонта КАК ВидРемонта,
	НормативныеРемонты_ВсеТехКарты.ДатаНачалаПлан КАК ДатаНачалаПлан,
	НормативныеРемонты_ВсеТехКарты.Документ КАК Документ,
	НормативныеРемонты_ВсеТехКарты.ВидДокумента КАК ВидДокумента,
	НормативныеРемонты_ВсеТехКарты.Ремонт КАК Ремонт,
	торо_ТехКартыТрудовыеЗатраты.Операция КАК РемонтнаяРабота,
	торо_ТехКартыТрудовыеЗатраты.ID КАК РемонтнаяРабота_ID,
	торо_ТехКартыТрудовыеЗатраты.Квалификация КАК Квалификация,
	СУММА(торо_ТехКартыТрудовыеЗатраты.ВремяРаботы * торо_ТехКартыТрудовыеЗатраты.Количество) КАК ВремяРаботы,
	торо_ТехКартыТрудовыеЗатраты.Количество КАК Количество
ПОМЕСТИТЬ РемонтыСТрудозатратами
ИЗ
	НормативныеРемонты_ВсеТехКарты КАК НормативныеРемонты_ВсеТехКарты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТехКарты.ТрудовыеЗатраты КАК торо_ТехКартыТрудовыеЗатраты
		ПО НормативныеРемонты_ВсеТехКарты.ТехКарта = торо_ТехКартыТрудовыеЗатраты.Ссылка

СГРУППИРОВАТЬ ПО
	НормативныеРемонты_ВсеТехКарты.ДатаНачалаПлан,
	НормативныеРемонты_ВсеТехКарты.Ремонт,
	НормативныеРемонты_ВсеТехКарты.ВидДокумента,
	НормативныеРемонты_ВсеТехКарты.ВидРемонта,
	НормативныеРемонты_ВсеТехКарты.Документ,
	НормативныеРемонты_ВсеТехКарты.ID,
	НормативныеРемонты_ВсеТехКарты.ОбъектРемонта,
	торо_ТехКартыТрудовыеЗатраты.Квалификация,
	торо_ТехКартыТрудовыеЗатраты.Количество,
	торо_ТехКартыТрудовыеЗатраты.Операция,
	торо_ТехКартыТрудовыеЗатраты.ID

ИНДЕКСИРОВАТЬ ПО
	Квалификация,
	ДатаНачалаПлан
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	РемонтыСТрудозатратами.Квалификация КАК Квалификация,
	РемонтыСТрудозатратами.ДатаНачалаПлан КАК ДатаНачалаПлан
ПОМЕСТИТЬ ВТ_Квалификации
ИЗ
	РемонтыСТрудозатратами КАК РемонтыСТрудозатратами

ИНДЕКСИРОВАТЬ ПО
	Квалификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Квалификации.Квалификация КАК Квалификация,
	ВТ_Квалификации.ДатаНачалаПлан КАК ДатаНачалаПлан,
	МАКСИМУМ(торо_СтоимостьЧасаКвалификации.Период) КАК Период
ПОМЕСТИТЬ ВТ_КвалификацииСПериодамиСреза
ИЗ
	ВТ_Квалификации КАК ВТ_Квалификации
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтоимостьЧасаКвалификации КАК торо_СтоимостьЧасаКвалификации
		ПО ВТ_Квалификации.Квалификация = торо_СтоимостьЧасаКвалификации.Квалификация
			И ВТ_Квалификации.ДатаНачалаПлан &gt;= торо_СтоимостьЧасаКвалификации.Период

СГРУППИРОВАТЬ ПО
	ВТ_Квалификации.Квалификация,
	ВТ_Квалификации.ДатаНачалаПлан

ИНДЕКСИРОВАТЬ ПО
	Квалификация,
	Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_КвалификацииСПериодамиСреза.Квалификация КАК Квалификация,
	ВТ_КвалификацииСПериодамиСреза.ДатаНачалаПлан КАК ДатаНачалаПлан,
	торо_СтоимостьЧасаКвалификации.Валюта КАК Валюта,
	торо_СтоимостьЧасаКвалификации.Стоимость КАК Стоимость
ПОМЕСТИТЬ ВТ_СтоимостиКвалификаций
ИЗ
	ВТ_КвалификацииСПериодамиСреза КАК ВТ_КвалификацииСПериодамиСреза
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтоимостьЧасаКвалификации КАК торо_СтоимостьЧасаКвалификации
		ПО ВТ_КвалификацииСПериодамиСреза.Квалификация = торо_СтоимостьЧасаКвалификации.Квалификация
			И ВТ_КвалификацииСПериодамиСреза.Период = торо_СтоимостьЧасаКвалификации.Период

ИНДЕКСИРОВАТЬ ПО
	Валюта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_СтоимостиКвалификаций.Квалификация КАК Квалификация,
	ВТ_СтоимостиКвалификаций.ДатаНачалаПлан КАК ДатаНачалаПлан,
	ВТ_СтоимостиКвалификаций.Валюта КАК Валюта,
	ВТ_СтоимостиКвалификаций.Стоимость КАК Стоимость,
	МАКСИМУМ(КурсыВалют.Период) КАК Период
ПОМЕСТИТЬ ВТ_ПериодыСрезаКурсов
ИЗ
	ВТ_СтоимостиКвалификаций КАК ВТ_СтоимостиКвалификаций
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ВТ_СтоимостиКвалификаций.Валюта = КурсыВалют.Валюта
			И ВТ_СтоимостиКвалификаций.ДатаНачалаПлан &gt;= КурсыВалют.Период

СГРУППИРОВАТЬ ПО
	ВТ_СтоимостиКвалификаций.Квалификация,
	ВТ_СтоимостиКвалификаций.ДатаНачалаПлан,
	ВТ_СтоимостиКвалификаций.Валюта,
	ВТ_СтоимостиКвалификаций.Стоимость

ИНДЕКСИРОВАТЬ ПО
	Валюта,
	Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ПериодыСрезаКурсов.Квалификация КАК Квалификация,
	ВТ_ПериодыСрезаКурсов.ДатаНачалаПлан КАК ДатаНачалаПлан,
	ВТ_ПериодыСрезаКурсов.Валюта КАК Валюта,
	ВТ_ПериодыСрезаКурсов.Стоимость КАК Стоимость,
	ВЫБОР
		КОГДА ЕСТЬNULL(КурсыВалют.Кратность, 1) = 0
			ТОГДА ВТ_ПериодыСрезаКурсов.Стоимость * ЕСТЬNULL(КурсыВалют.Курс, 1)
		ИНАЧЕ ВТ_ПериодыСрезаКурсов.Стоимость * ЕСТЬNULL(КурсыВалют.Курс, 1) / ЕСТЬNULL(КурсыВалют.Кратность, 1)
	КОНЕЦ КАК СтоимостьРуб
ПОМЕСТИТЬ ВТ_СтоимостиКвалификацийРуб
ИЗ
	ВТ_ПериодыСрезаКурсов КАК ВТ_ПериодыСрезаКурсов
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ВТ_ПериодыСрезаКурсов.Валюта = КурсыВалют.Валюта
			И ВТ_ПериодыСрезаКурсов.Период = КурсыВалют.Период

ИНДЕКСИРОВАТЬ ПО
	Квалификация,
	ДатаНачалаПлан
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	РемонтыСТрудозатратами.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
	РемонтыСТрудозатратами.ОбъектРемонта КАК ОбъектРемонта,
	РемонтыСТрудозатратами.ВидРемонта КАК ВидРемонта,
	РемонтыСТрудозатратами.ДатаНачалаПлан КАК ДатаНачалаПлан,
	РемонтыСТрудозатратами.Документ КАК Документ,
	РемонтыСТрудозатратами.ВидДокумента КАК ВидДокумента,
	РемонтыСТрудозатратами.РемонтнаяРабота КАК РемонтнаяРабота,
	РемонтыСТрудозатратами.РемонтнаяРабота_ID КАК РемонтнаяРабота_ID,
	РемонтыСТрудозатратами.Квалификация КАК Квалификация,
	РемонтыСТрудозатратами.ВремяРаботы КАК ВремяРаботы,
	РемонтыСТрудозатратами.Количество КАК Количество,
	ЕСТЬNULL(ВТ_СтоимостиКвалификацийРуб.СтоимостьРуб, 0) * РемонтыСТрудозатратами.ВремяРаботы / 3600 КАК Сумма
ПОМЕСТИТЬ ПлановыеЗатраты
ИЗ
	РемонтыСТрудозатратами КАК РемонтыСТрудозатратами
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтоимостиКвалификацийРуб КАК ВТ_СтоимостиКвалификацийРуб
		ПО РемонтыСТрудозатратами.Квалификация = ВТ_СтоимостиКвалификацийРуб.Квалификация
			И РемонтыСТрудозатратами.ДатаНачалаПлан = ВТ_СтоимостиКвалификацийРуб.ДатаНачалаПлан

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ПлановыеЗатратыЗаявки.РемонтыОборудования_ID,
	ПлановыеЗатратыЗаявки.ОбъектРемонта,
	ПлановыеЗатратыЗаявки.ВидРемонта,
	ПлановыеЗатратыЗаявки.ДатаНачалаПлан,
	ПлановыеЗатратыЗаявки.Документ,
	ПлановыеЗатратыЗаявки.ВидДокумента,
	ПлановыеЗатратыЗаявки.РемонтнаяРабота,
	ПлановыеЗатратыЗаявки.РемонтнаяРабота_ID,
	ПлановыеЗатратыЗаявки.Квалификация,
	ПлановыеЗатратыЗаявки.ВремяРаботы,
	ПлановыеЗатратыЗаявки.Количество,
	ПлановыеЗатратыЗаявки.Сумма
ИЗ
	ПлановыеЗатратыЗаявки КАК ПлановыеЗатратыЗаявки

ИНДЕКСИРОВАТЬ ПО
	РемонтыОборудования_ID,
	ОбъектРемонта,
	РемонтнаяРабота_ID,
	Квалификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
	торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ОбъектРемонта КАК ОбъектРемонта,
	торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ВидРемонтныхРабот КАК ВидРемонта,
	торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ДатаНачала КАК ДатаНачалаФакт,
	"План-график ремонта" КАК ВидДокумента,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтнаяРабота КАК РемонтнаяРабота,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.ID КАК РемонтнаяРабота_ID,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Квалификация КАК Квалификация,
	СУММА(ЕСТЬNULL(торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.ВремяРаботы, 0)) КАК ВремяРаботыФакт,
	СУММА(торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Количество) КАК КоличествоФакт,
	СУММА(торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Сумма) КАК СуммаФакт
ПОМЕСТИТЬ ФактическиеЗатраты
ИЗ
	РегистрНакопления.торо_ФактическиеТрудовыеЗатратыРемонтныхРабот КАК торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеРемонтныеРаботы КАК торо_ЗавершенныеРемонтныеРаботыСрезПоследних
		ПО торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтыОборудования_ID = торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ID
			И торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Регистратор = торо_ЗавершенныеРемонтныеРаботыСрезПоследних.Регистратор
{ГДЕ
	(торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ДатаНачала МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания)}

СГРУППИРОВАТЬ ПО
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтнаяРабота,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.ID,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Квалификация,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтыОборудования_ID,
	торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ОбъектРемонта,
	торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ВидРемонтныхРабот,
	торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ДатаНачала

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтыОборудования_ID,
	торо_АктОВыполненииРегламентногоМероприятия.ОбъектРемонта,
	торо_ЗавершенныеМероприятияСрезПоследних.ВидМероприятия,
	торо_ЗавершенныеМероприятияСрезПоследних.ДатаНачала,
	"Регламентные мероприятия",
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтнаяРабота,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.ID,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Квалификация,
	СУММА(ЕСТЬNULL(торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.ВремяРаботы, 0)),
	СУММА(торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Количество),
	СУММА(торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Сумма)
ИЗ
	РегистрНакопления.торо_ФактическиеТрудовыеЗатратыРемонтныхРабот КАК торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеМероприятия КАК торо_ЗавершенныеМероприятияСрезПоследних
		ПО торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтыОборудования_ID = торо_ЗавершенныеМероприятияСрезПоследних.ID
			И торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Регистратор = торо_ЗавершенныеМероприятияСрезПоследних.Регистратор
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииРегламентногоМероприятия.МероприятияОбъектов КАК торо_АктОВыполненииРегламентногоМероприятия
		ПО торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Регистратор = торо_АктОВыполненииРегламентногоМероприятия.Ссылка
			И торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтыОборудования_ID = торо_АктОВыполненииРегламентногоМероприятия.Мероприятие_ID
{ГДЕ
	(торо_ЗавершенныеМероприятияСрезПоследних.ДатаНачала МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания)}

СГРУППИРОВАТЬ ПО
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтыОборудования_ID,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.Квалификация,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.ID,
	торо_ФактическиеТрудовыеЗатратыРемонтныхРаботОбороты.РемонтнаяРабота,
	торо_АктОВыполненииРегламентногоМероприятия.ОбъектРемонта,
	торо_ЗавершенныеМероприятияСрезПоследних.ВидМероприятия,
	торо_ЗавершенныеМероприятияСрезПоследних.ДатаНачала

ИНДЕКСИРОВАТЬ ПО
	РемонтыОборудования_ID,
	ОбъектРемонта,
	РемонтнаяРабота_ID,
	Квалификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЕСТЬNULL(ПлановыеЗатраты.РемонтыОборудования_ID, ФактическиеЗатраты.РемонтыОборудования_ID) КАК РемонтыОборудования_ID,
	ЕСТЬNULL(ПлановыеЗатраты.ОбъектРемонта, ФактическиеЗатраты.ОбъектРемонта) КАК ОбъектРемонта,
	ЕСТЬNULL(ПлановыеЗатраты.ВидРемонта, ФактическиеЗатраты.ВидРемонта) КАК ВидРемонта,
	ЕСТЬNULL(ПлановыеЗатраты.ДатаНачалаПлан, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаНачалаПлан,
	ЕСТЬNULL(ПлановыеЗатраты.Документ, НЕОПРЕДЕЛЕНО) КАК Документ,
	ЕСТЬNULL(ПлановыеЗатраты.ВидДокумента, ФактическиеЗатраты.ВидДокумента) КАК ВидДокумента,
	ЕСТЬNULL(ПлановыеЗатраты.РемонтнаяРабота, ФактическиеЗатраты.РемонтнаяРабота) КАК РемонтнаяРабота,
	ЕСТЬNULL(ПлановыеЗатраты.РемонтнаяРабота_ID, ФактическиеЗатраты.РемонтнаяРабота_ID) КАК ID,
	ЕСТЬNULL(ПлановыеЗатраты.Квалификация, ФактическиеЗатраты.Квалификация) КАК Квалификация,
	ЕСТЬNULL(ПлановыеЗатраты.ВремяРаботы, 0) КАК ВремяПлан,
	ЕСТЬNULL(ПлановыеЗатраты.Количество, 0) КАК КоличествоПлан,
	ЕСТЬNULL(ПлановыеЗатраты.Сумма, 0) КАК СуммаПлан,
	ЕСТЬNULL(ФактическиеЗатраты.ДатаНачалаФакт, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаНачалаФакт,
	ЕСТЬNULL(ФактическиеЗатраты.ВремяРаботыФакт, 0) КАК ВремяФакт,
	ЕСТЬNULL(ФактическиеЗатраты.КоличествоФакт, 0) КАК КоличествоФакт,
	ЕСТЬNULL(ФактическиеЗатраты.СуммаФакт, 0) КАК СуммаФакт,
	ЕСТЬNULL(ПлановыеЗатраты.ОбъектРемонта, ФактическиеЗатраты.ОбъектРемонта) КАК ОбъектИерархии
ИЗ
	ПлановыеЗатраты КАК ПлановыеЗатраты
		ПОЛНОЕ СОЕДИНЕНИЕ ФактическиеЗатраты КАК ФактическиеЗатраты
		ПО ПлановыеЗатраты.РемонтыОборудования_ID = ФактическиеЗатраты.РемонтыОборудования_ID
			И ПлановыеЗатраты.ОбъектРемонта = ФактическиеЗатраты.ОбъектРемонта
			И ПлановыеЗатраты.РемонтнаяРабота_ID = ФактическиеЗатраты.РемонтнаяРабота_ID
			И ПлановыеЗатраты.Квалификация = ФактическиеЗатраты.Квалификация</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Иерархия</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектИерархии</dataPath>
			<field>ОбъектИерархии</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>РодительИерархии</dataPath>
			<field>РодительИерархии</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Документами.ОбъектИерархии КАК ОбъектИерархии,
	Документами.РодительИерархии КАК РодительИерархии
ИЗ
	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии КАК Документами
ГДЕ
	Документами.ОбъектИерархии В(&amp;Элемент)</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Контроль</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>РодительКонтроль</dataPath>
			<field>РодительКонтроль</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Родитель контроль</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>es</v8:lang>
					<v8:content>Los padres el control</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Parent control</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
			<attributeUseRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</attributeUseRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭлементКонтроль</dataPath>
			<field>ЭлементКонтроль</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Элемент контроль</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>es</v8:lang>
					<v8:content>El elemento el control</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Control element</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
			<attributeUseRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</attributeUseRestriction>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Документами.ОбъектИерархии КАК ЭлементКонтроль,
	Документами.РодительИерархии КАК РодительКонтроль
ИЗ
	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии КАК Документами
ГДЕ
	Документами.РодительИерархии В(&amp;Родитель)</query>
	</dataSet>
