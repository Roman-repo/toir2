	<calculatedField>
		<dataPath>ОтклонениеСумма</dataPath>
		<expression>СуммаФакт - СуммаПлан</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Отклонение сумма</v8:content>
			</v8:item>
			<v8:item>
				<v8:lang>es</v8:lang>
				<v8:content>La desviación la suma</v8:content>
			</v8:item>
