		|	ВТ_ДанныеПредв.Наработка,
		|	ВТ_ДанныеПредв.Показатель,
		|	ВТ_ДанныеПредв.НаработкаКапитальный,
		|	ВТ_ДанныеПредв.ПоказательКапитальный,
		|	ВЫРАЗИТЬ(ВТ_ДанныеПредв.ОбъектРемонтныхРабот КАК Справочник.торо_ОбъектыРемонта)." + ТекИерархия.РеквизитОР + " КАК ОбъектИерархии
		|ИЗ
		|	ВТ_ДанныеПредв КАК ВТ_ДанныеПредв";
		
	Иначе

		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТ_Данные.ДатаКон,
		|	ВТ_Данные.ДатаКонКапитальный,
		|	ВТ_Данные.ОбъектРемонтныхРабот,
		|	ВТ_Данные.ВидРемонтныхРабот,
		|	ВТ_Данные.ВидРемонтаКапитальный,
		|	ВТ_Данные.Наработка,
		|	ВТ_Данные.Показатель,
		|	ВТ_Данные.НаработкаКапитальный,
		|	ВТ_Данные.ПоказательКапитальный
		|ПОМЕСТИТЬ ВТ_ДанныеПредв
		|ИЗ
		|	&ВТ_Данные КАК ВТ_Данные
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДанныеПредв.ДатаКон,
		|	ВТ_ДанныеПредв.ДатаКонКапитальный,
		|	ВТ_ДанныеПредв.ОбъектРемонтныхРабот,
		|	ВТ_ДанныеПредв.ВидРемонтныхРабот,
		|	ВТ_ДанныеПредв.ВидРемонтаКапитальный,
		|	ВТ_ДанныеПредв.Наработка,
		|	ВТ_ДанныеПредв.Показатель,
		|	ВТ_ДанныеПредв.НаработкаКапитальный,
		|	ВТ_ДанныеПредв.ПоказательКапитальный,
		|	ВТ_ДанныеПредв.ОбъектРемонтныхРабот КАК ОбъектИерархии
		|ИЗ
		|	ВТ_ДанныеПредв КАК ВТ_ДанныеПредв";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВТ_Данные", ТабНаработки);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

Функция НайтиДанные(ИмяПоиска, МестоПоиска)
	
	Для каждого Элемент Из МестоПоиска Цикл
		Если Элемент.Имя = ИмяПоиска Тогда
			
			Возврат Элемент;
			
		Иначе
			
			Результат = НайтиДанные(ИмяПоиска, Элемент.Структура);
			Если Результат <> Неопределено Тогда
				Возврат Результат;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецФункции

