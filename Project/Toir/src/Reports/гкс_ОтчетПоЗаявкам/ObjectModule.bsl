	        |	ВсеЗаявки.Акт,
	        |	ВсеЗаявки.Ид_Ремонта,
	        |	ТЧ.Номенклатура,
			// гкс+ [разработка 2021] Куст 09.07.2021
	        |	СУММА(ТЧ.КоличествоЕдиниц * ЕСТЬNULL(ТЧ2.гкс_ПовКоэф.Коэффициент, 1)),
			// гкс- [разработка 2021] Куст 09.07.2021
	        |	1
	        |ИЗ
	        |	ВсеЗаявки КАК ВсеЗаявки
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.МатериальныеЗатраты КАК ТЧ
			// гкс+ [разработка 2021] Куст 09.07.2021
			|			Левое СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтныеРаботы КАК ТЧ2
	        |			ПО ТЧ2.Ссылка = ТЧ.Ссылка
	        |			И ТЧ2.РемонтыОборудования_ID = ТЧ.РемонтыОборудования_ID
			|			И ТЧ2.ID = ТЧ.ID
			// гкс- [разработка 2021] Куст 09.07.2021
	        |		ПО ВсеЗаявки.Акт = ТЧ.Ссылка
	        |			И ВсеЗаявки.Ид_Ремонта = ТЧ.РемонтыОборудования_ID
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВсеЗаявки.Ид_Ремонта,
	        |	ТЧ.Номенклатура,
	        |	ВсеЗаявки.Акт
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВсеМатЗатраты.Ид_Ремонта КАК Ид_Ремонта,
	        |	ВсеМатЗатраты.Номенклатура КАК Номенклатура,
	        |	МАКСИМУМ(ВсеЦены.Период) КАК Период,
	        |	ВсеМатЗатраты.Регистратор КАК Регистратор
	        |ПОМЕСТИТЬ СрезЦенМатЗатрат
	        |ИЗ
	        |	ВсеМатЗатраты КАК ВсеМатЗатраты
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВсеЦены КАК ВсеЦены
	        |		ПО ВсеМатЗатраты.Номенклатура = ВсеЦены.Номенклатура
	        |			И ВсеМатЗатраты.Регистратор.Дата >= ВсеЦены.Период
			|			И ВсеМатЗатраты.Регистратор.Организация.гкс_ВидЦены = ВсеЦены.ВидЦены
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ВсеМатЗатраты.Ид_Ремонта,
	        |	ВсеМатЗатраты.Номенклатура,
	        |	ВсеМатЗатраты.Регистратор
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВсеМатЗатраты.Ид_Ремонта КАК Ид_Ремонта,
			|	ВсеМатЗатраты.Регистратор КАК Заявка,
	        |	ВсеМатЗатраты.Номенклатура КАК Номенклатура,
	        |	ЕстьNull(ВсеМатЗатраты.Количество, 0) КАК Количество,
	        |	ЕстьNull(ВсеЦены.Цена, 0) КАК Цена,
	        |	ВсеЦены.Валюта КАК Валюта
	        |ИЗ
	        |	ВсеМатЗатраты КАК ВсеМатЗатраты
	        |		ЛЕВОЕ СОЕДИНЕНИЕ СрезЦенМатЗатрат КАК СрезЦенМатЗатрат
	        |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВсеЦены КАК ВсеЦены
	        |			ПО СрезЦенМатЗатрат.Номенклатура = ВсеЦены.Номенклатура
	        |				И СрезЦенМатЗатрат.Период = ВсеЦены.Период
			|			И СрезЦенМатЗатрат.Регистратор.Организация.гкс_ВидЦены = ВсеЦены.ВидЦены
	        |		ПО ВсеМатЗатраты.Номенклатура = СрезЦенМатЗатрат.Номенклатура
	        |			И ВсеМатЗатраты.Ид_Ремонта = СрезЦенМатЗатрат.Ид_Ремонта
	        |			И ВсеМатЗатраты.Регистратор = СрезЦенМатЗатрат.Регистратор
	        |ГДЕ
	        |	ВсеМатЗатраты.ТипДокумента = 0
	        |ИТОГИ ПО
	        |	Ид_Ремонта, Заявка
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
			|	ВсеЗаявки.Регистратор КАК Заявка,
	        |	ВсеЗаявки.Ид_Ремонта КАК Ид_Ремонта,
	        |	ТЧ.Исполнитель КАК Исполнитель,
	        |	ТЧ.НомерСтроки КАК НомерСтроки
	        |ИЗ
	        |	ВсеЗаявки КАК ВсеЗаявки
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ИсполнителиПоРемонтам КАК ТЧ
	        |		ПО ВсеЗаявки.Регистратор = ТЧ.Ссылка
	        |			И ВсеЗаявки.Ид_Ремонта = ТЧ.РемонтыОборудования_ID
	        |
	        |УПОРЯДОЧИТЬ ПО
	        |	НомерСтроки
	        |ИТОГИ ПО
	        |	Ид_Ремонта, Заявка
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВсеЗаявки.Ид_Ремонта КАК Ид_Ремонта,
			|	ВсеЗаявки.Акт КАК Акт,
	        |	ТЧ.РемонтнаяРабота КАК РР
	        |ИЗ
	        |	ВсеЗаявки КАК ВсеЗаявки
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтныеРаботы КАК ТЧ
	        |		ПО ВсеЗаявки.Акт = ТЧ.Ссылка
	        |			И ВсеЗаявки.Ид_Ремонта = ТЧ.РемонтыОборудования_ID
	        |			И (ТЧ.РемонтнаяРабота ССЫЛКА Справочник.торо_ИдентификаторыТехКарт)
	        |ИТОГИ ПО
	        |	Ид_Ремонта, Акт
	        |;
	        |
