			|	ЕстьNull(ВсеТрудозатраты.СуммаВремени,0) / 3600 КАК СуммаВремени,
	        |	ЕстьNull(ВсеТрудозатраты.ВремяРаботы, 0) КАК ВремяРаботы,
	        |	ЕстьNull(ВсеТрудозатраты.Количество, 0) КАК Количество,
	        |	ЕстьNull(Рег.Стоимость, 0) КАК Цена
	        |ИЗ
	        |	ВсеТрудозатраты КАК ВсеТрудозатраты
	        |		ЛЕВОЕ СОЕДИНЕНИЕ СрезКвалификаций КАК СрезКвалификаций
	        |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтоимостьЧасаКвалификации КАК Рег
	        |			ПО СрезКвалификаций.Квалификация = Рег.Квалификация
			|				И СрезКвалификаций.Регистратор.Организация = Рег.Организация
	        |				И СрезКвалификаций.Период = Рег.Период
	        |		ПО (СрезКвалификаций.Квалификация = ВсеТрудозатраты.Квалификация)
	        |			И (СрезКвалификаций.Регистратор = ВсеТрудозатраты.Регистратор)
	        |			И (СрезКвалификаций.Ид_Ремонта = ВсеТрудозатраты.Ид_Ремонта)
	        |ГДЕ
	        |	ВсеТрудозатраты.ТипДокумента = 1
	        |ИТОГИ ПО
	        |	Ид_Ремонта, Акт
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
			|	ВсеМатЗатраты.Регистратор КАК Акт,
	        |	ВсеМатЗатраты.Ид_Ремонта КАК Ид_Ремонта,
	        |	ВсеМатЗатраты.Номенклатура КАК Номенклатура,
	        |	ЕстьNull(ВсеМатЗатраты.Количество, 0) КАК Количество,
	        |	ЕстьNull(ВсеЦены.Цена, 0) КАК Цена,
	        |	ВсеЦены.Валюта КАК Валюта
	        |ИЗ
	        |	ВсеМатЗатраты КАК ВсеМатЗатраты
	        |		ЛЕВОЕ СОЕДИНЕНИЕ СрезЦенМатЗатрат КАК СрезЦенМатЗатрат
	        |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВсеЦены КАК ВсеЦены
	        |			ПО СрезЦенМатЗатрат.Номенклатура = ВсеЦены.Номенклатура
	        |				И СрезЦенМатЗатрат.Период = ВсеЦены.Период
			|			И СрезЦенМатЗатрат.Регистратор.Организация.гкс_ВидЦены = ВсеЦены.ВидЦены
	        |		ПО ВсеМатЗатраты.Номенклатура = СрезЦенМатЗатрат.Номенклатура
	        |			И ВсеМатЗатраты.Ид_Ремонта = СрезЦенМатЗатрат.Ид_Ремонта
	        |			И ВсеМатЗатраты.Регистратор = СрезЦенМатЗатрат.Регистратор
	        |ГДЕ
	        |	ВсеМатЗатраты.ТипДокумента = 1
	        |ИТОГИ ПО
	        |	Ид_Ремонта, Акт
			|;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВсеЗаявки.Ид_Ремонта КАК Ид_Ремонта,
			|	ТЧ.Ссылка КАК Акт,
	        |	ТЧ.Исполнитель КАК Исполнитель,
	        |	ТЧ.НомерСтроки КАК НомерСтроки
	        |ИЗ
