
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	
	ДатаНачала = НачалоГода(ТекущаяДата());
	ДатаОкончания = КонецГода(ТекущаяДата());
	МассивПодр = Новый Массив();
	МассивОрг = Новый Массив();
	ВидЦены = Константы.торо_ТипЦеныДляРасчетаСебестоимостиРемонта.Получить();
	
	ПараметрНачала = Новый ПараметрКомпоновкиДанных("ДатаНачала");
	ПараметрОкончания = Новый ПараметрКомпоновкиДанных("ДатаОкончания");
	ПараметрОрганизация = Новый ПараметрКомпоновкиДанных("Организация");
	ПараметрПодразделение = Новый ПараметрКомпоновкиДанных("Подразделение");
	ПараметрПериодОтчета = Новый ПараметрКомпоновкиДанных("ПериодОтчета");
	ПараметрВидЦены = Новый ПараметрКомпоновкиДанных("ВидЦены");
	
	
	Для Каждого СМ Из Настройки.ПараметрыДанных.Элементы Цикл
		Если СМ.Использование = Истина Тогда
			Если СМ.Параметр = ПараметрОрганизация Тогда 
				Если ТипЗнч(СМ.Значение) = Тип("СписокЗначений") Тогда 
					Для Каждого СтрокаСписка Из СМ.Значение Цикл
						МассивОрг.Добавить(СтрокаСписка.Значение);
					КонецЦикла;
				Иначе
					МассивОрг.Добавить(СМ.Значение);
				КонецЕсли;
			КонецЕсли;
			Если СМ.Параметр = ПараметрПодразделение Тогда 
				Если ТипЗнч(СМ.Значение) = Тип("СписокЗначений") Тогда 
					Для Каждого СтрокаСписка Из СМ.Значение Цикл
						МассивПодр.Добавить(СтрокаСписка.Значение);
					КонецЦикла;
				Иначе
					МассивПодр.Добавить(СМ.Значение);
				КонецЕсли;
			КонецЕсли;
			Если СМ.Параметр = ПараметрВидЦены Тогда 
				ВидЦены = СМ.Значение;
			КонецЕсли;
			Если СМ.Параметр = ПараметрНачала Тогда 
				ДатаНачала = СМ.Значение.Дата;
			КонецЕсли;
			Если СМ.Параметр = ПараметрОкончания Тогда 
				ДатаОкончания = СМ.Значение.Дата;
			КонецЕсли;
			Если СМ.Параметр = ПараметрПериодОтчета Тогда 
				ДатаОкончания = СМ.Значение.ДатаОкончания;
				ДатаНачала = СМ.Значение.ДатаНачала;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
		
	НастройкиОсновнойСхемы = КомпоновщикНастроек.ПолучитьНастройки();
	ВнешниеНаборыДанных = Новый Структура;
	ТЧРезультат = ПолучитьТаблицуДанных(ДатаНачала, ДатаОкончания, МассивОрг, МассивПодр);
	ВнешниеНаборыДанных.Вставить("ВТ_Данные", ТЧРезультат);
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиОсновнойСхемы, ДанныеРасшифровки);	
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных, ДанныеРасшифровки);
	
	ПроцессорВыводаВТабличныйДокумент = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВыводаВТабличныйДокумент.УстановитьДокумент(ДокументРезультат);	
	ПроцессорВыводаВТабличныйДокумент.Вывести(ПроцессорКомпоновкиДанных);

КонецПроцедуры

Функция ПолучитьТаблицуДанных(ДатаНачала, ДатаОкончания, МассивОрг, МассивПодр)
	
	Запрос = Новый Запрос();
	Запрос.Текст = ПолучитьТекстЗапроса(МассивПодр.Количество(), МассивОрг.Количество());
	
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	Запрос.УстановитьПараметр("МассивОрг", МассивОрг);
	Запрос.УстановитьПараметр("МассивПодр", МассивПодр);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ПервыйПакет = 10;
	ВторойПакет = ПервыйПакет + 1;
	ТретийПакет = ВторойПакет + 1;
	ЧетПакет = ТретийПакет + 4;
	ПятыйПакет = ЧетПакет + 1;
	ШестПакет = ПятыйПакет + 1;
	СемПакет = ШестПакет + 1;
	ВосьПакет = СемПакет + 1;
	ДевятыйПакет = ВосьПакет + 1;
	
	ТЧ_Результат = РезультатЗапроса[ПервыйПакет].Выгрузить();
	ВыборкаРР = РезультатЗапроса[ВторойПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаТЗ = РезультатЗапроса[ТретийПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМЗ = РезультатЗапроса[ЧетПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИсп = РезультатЗапроса[ПятыйПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаРРАкт = РезультатЗапроса[ШестПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаТЗАкт = РезультатЗапроса[СемПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМЗАкт = РезультатЗапроса[ВосьПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИспАкт = РезультатЗапроса[ДевятыйПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ТЧ_Результат.Колонки.Добавить("КоличествоЧЧ", Новый ОписаниеТипов("Число",,, 
		Новый КвалификаторыЧисла(15,2)));
		ТЧ_Результат.Колонки.Добавить("ФактКоличествоЧЧ", Новый ОписаниеТипов("Число",,, 
		Новый КвалификаторыЧисла(15,2)));
	ТЧ_Результат.Колонки.Добавить("ОписаниеПлановыхРаботЗаявки", Новый ОписаниеТипов("Строка"));
	ТЧ_Результат.Колонки.Добавить("ОписаниеФактическиВыполненныхРабот", Новый ОписаниеТипов("Строка"));
	ТипИсполнитель = Новый Массив();
	ТипИсполнитель.Добавить(Тип("СправочникСсылка.Контрагенты"));
	ТипИсполнитель.Добавить(Тип("СправочникСсылка.СтруктураПредприятия"));
	ТЧ_Результат.Колонки.Добавить("ИсполнительЗаявки", Новый ОписаниеТипов(ТипИсполнитель));
	ТЧ_Результат.Колонки.Добавить("ИсполнительАкта", Новый ОписаниеТипов(ТипИсполнитель));
	
	Для Каждого СТ Из ТЧ_Результат Цикл
		СтруктПоиска = Новый Структура("Ид_Ремонта", СТ.Ид_Ремонта);
		СтруктПоискаАкта = Новый Структура("Ид_Ремонта,Акт", СТ.Ид_Ремонта, СТ.Акт);
		СтруктПоискаЗаявки = Новый Структура("Заявка", СТ.Заявка);
		ВыборкаРР.Сбросить();
		Если ВыборкаРР.НайтиСледующий(СтруктПоиска) Тогда 
			МассивТекста = Новый Массив();
			ВыборкаРР0 = ВыборкаРР.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаРР0.НайтиСледующий(СтруктПоискаЗаявки) Тогда 
				Выборка = ВыборкаРР0.Выбрать();
				Пока Выборка.Следующий() Цикл
					МассивТекста.Добавить(Строка(Выборка.РР));
				КонецЦикла;
			КонецЕсли;
			СТ.ОписаниеПлановыхРаботЗаявки = СтрСоединить(МассивТекста, ", ");
		КонецЕсли;
		//
		ВыборкаТЗ.Сбросить();
		Если ВыборкаТЗ.НайтиСледующий(СтруктПоиска) Тогда 
			ТекСумма = 0;
			СуммаКвалификаций = 0;
			ВыборкаТЗ0 = ВыборкаТЗ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаТЗ0.НайтиСледующий(СтруктПоискаЗаявки) Тогда 
				Выборка = ВыборкаТЗ0.Выбрать();
				Пока Выборка.Следующий() Цикл
					СуммаКвалификаций = СуммаКвалификаций + (Выборка.СуммаВремени * Выборка.Цена);
					ТекСумма = ТекСумма + Выборка.СуммаВремени;
				КонецЦикла;
			КонецЕсли;
			СТ.КоличествоЧЧ = ТекСумма;
			СТ.ПлановаяСтоимостьЗаявки = СТ.ПлановаяСтоимостьЗаявки + СуммаКвалификаций;
			Если СТ.КоличествоЧЧ > 0 Тогда 
				СТ.СтоимостьЧЧ = СуммаКвалификаций / СТ.КоличествоЧЧ;
			КонецЕсли;
		КонецЕсли;
		//
		ВыборкаМЗ.Сбросить();
		Если ВыборкаМЗ.НайтиСледующий(СтруктПоиска) Тогда 
			ТекСумма = 0;
			ВыборкаМЗ0 = ВыборкаМЗ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаМЗ0.НайтиСледующий(СтруктПоискаЗаявки) Тогда 
				Выборка = ВыборкаМЗ0.Выбрать();
				Пока Выборка.Следующий() Цикл
					ТекСумма = ТекСумма + Выборка.Количество * Выборка.Цена;
				КонецЦикла;
			КонецЕсли;
			СТ.СтоимостьМатериалов = ТекСумма;
			СТ.ПлановаяСтоимостьЗаявки = СТ.ПлановаяСтоимостьЗаявки + ТекСумма;
		КонецЕсли;
		//
		ВыборкаИсп.Сбросить();
		Если ВыборкаИсп.НайтиСледующий(СтруктПоиска) Тогда   //
			ПервыйКонтрагент = Неопределено;
			ВыборкаИсп0 = ВыборкаИсп.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаИсп0.НайтиСледующий(СтруктПоискаЗаявки) Тогда
				Выборка = ВыборкаИсп0.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если ПервыйКонтрагент = Неопределено Тогда 
						ПервыйКонтрагент = Выборка.Исполнитель;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			СТ.ИсполнительЗаявки = ПервыйКонтрагент;
		КонецЕсли;
		//
		ВыборкаИспАкт.Сбросить();
		Если ВыборкаИспАкт.НайтиСледующий(СтруктПоиска) Тогда 
			ПервыйКонтрагент = Неопределено;
			ВыборкаИспАкт0 = ВыборкаИспАкт.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаИспАкт0.НайтиСледующий(СтруктПоискаАкта) Тогда 
				Выборка = ВыборкаИспАкт0.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если ПервыйКонтрагент = Неопределено Тогда 
						ПервыйКонтрагент = Выборка.Исполнитель;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			СТ.ИсполнительАкта = ПервыйКонтрагент;
		КонецЕсли;
		//
		ВыборкаРРАкт.Сбросить();
		Если ВыборкаРРАкт.НайтиСледующий(СтруктПоиска) Тогда 
			МассивТекста = Новый Массив();
			ВыборкаРРАкт0 = ВыборкаРРАкт.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаРРАкт0.НайтиСледующий(СтруктПоискаАкта) Тогда 
				Выборка = ВыборкаРРАкт0.Выбрать();
				Пока Выборка.Следующий() Цикл
					МассивТекста.Добавить(Строка(Выборка.РР));
				КонецЦикла;
			КонецЕсли;
			СТ.ОписаниеФактическиВыполненныхРабот = СтрСоединить(МассивТекста, ", ");
		КонецЕсли;
		//
		ВыборкаТЗАкт.Сбросить();
		Если ВыборкаТЗАкт.НайтиСледующий(СтруктПоиска) Тогда 
			ТекСумма = 0;
			СуммаКвалификаций = 0;
			ВыборкаТЗАкт0 = ВыборкаТЗАкт.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаТЗАкт0.НайтиСледующий(СтруктПоискаАкта) Тогда 
				Выборка = ВыборкаТЗАкт0.Выбрать();
				Пока Выборка.Следующий() Цикл
					ТекСумма = ТекСумма + Выборка.СуммаВремени;
					СуммаКвалификаций = СуммаКвалификаций + (Выборка.СуммаВремени * Выборка.Цена);
				КонецЦикла;
			КонецЕсли;
			СТ.ФактическаяСтоимостьРабот = СТ.ФактическаяСтоимостьРабот + СуммаКвалификаций;
			СТ.ФактКоличествоЧЧ = ТекСумма;
			Если СТ.ФактКоличествоЧЧ > 0 Тогда 
				СТ.ФактСтоимостьЧЧ = СуммаКвалификаций / СТ.ФактКоличествоЧЧ;
			КонецЕсли;
		КонецЕсли;
		//
		ВыборкаМЗАкт.Сбросить();
		Если ВыборкаМЗАкт.НайтиСледующий(СтруктПоиска) Тогда 
			ТекСумма = 0;
			ВыборкаМЗАкт0 = ВыборкаМЗАкт.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаМЗАкт0.НайтиСледующий(СтруктПоискаАкта) Тогда 
				Выборка = ВыборкаМЗАкт0.Выбрать();
				Пока Выборка.Следующий() Цикл
					ТекСумма = ТекСумма + Выборка.Количество * Выборка.Цена;
				КонецЦикла;
			КонецЕсли;
			СТ.ФактСтоимостьМатериалов = ТекСумма;
			СТ.ФактическаяСтоимостьРабот = СТ.ФактическаяСтоимостьРабот + ТекСумма;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТЧ_Результат;
КонецФункции

Функция ПолучитьТекстЗапроса(ОтборПодразделение = Ложь, ОтборОрганизация = Ложь)
	Возврат 
	"ВЫБРАТЬ Различные
	   |	РегДок.Ссылка КАК Ссылка,
	   |	РегДок.ID КАК Ид_Ремонта
	   |ПОМЕСТИТЬ Заявки
	   |ИЗ
	   |	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования  КАК РегДок
	   |Где
        |				РегДок.Ссылка.Дата >= &ДатаНачала
        |				И РегДок.Ссылка.Дата < &ДатаОкончания
        |	 "
+ ?(ОтборОрганизация, " И РегДок.Ссылка.Организация В (&МассивОрг) ", "")
+ ?(ОтборПодразделение, " И РегДок.Ссылка.Подразделение В (&МассивПодр) ", "")
+ "
	   | " + " ; " 
+ "ВЫБРАТЬ
  |	ТЧ.Ид_Ремонта КАК Ид_Ремонта,
  |	ДокументыОснования.ДокументОснование КАК ДокументОснование
  |ПОМЕСТИТЬ ОснованияЗаявок
  |ИЗ
  |	Заявки КАК ТЧ
  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ДокументыОснования КАК ДокументыОснования
  |		ПО ТЧ.Ссылка = ДокументыОснования.Ссылка
  |			И (ДокументыОснования.НомерСтроки = 1)
  |;
  |
  |////////////////////////////////////////////////////////////////////////////////
  |ВЫБРАТЬ
  |	АктТЧ.Ссылка КАК Ссылка,
  |	АктТЧ.ДатаНачала КАК ДатаНачалаФакт,
  |	АктТЧ.ДатаОкончания КАК ДатаЗавершенияФакт
  |ПОМЕСТИТЬ Акты
  |ИЗ
  |	Заявки КАК РегДок
  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК АктТЧ
  |		ПО (АктТЧ.ID = РегДок.Ид_Ремонта)
  |;
  |
  |////////////////////////////////////////////////////////////////////////////////
  |ВЫБРАТЬ
  |	Заявки.Ссылка КАК Заявка,
  |	Акты.Ссылка КАК Акт
  |ПОМЕСТИТЬ СоотАктыЗаявок
  |ИЗ
  |	Заявки КАК Заявки
  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.ДокументыОснования КАК Основания
  |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Акты КАК Акты
  |			ПО Основания.Ссылка = Акты.Ссылка
  |		ПО Заявки.Ссылка = Основания.ДокументОснование
  |
  |ОБЪЕДИНИТЬ ВСЕ
  |
  |ВЫБРАТЬ РАЗЛИЧНЫЕ
  |	Заявки.Ссылка,
  |	Акты.Ссылка
  |ИЗ
  |	Заявки КАК Заявки
  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_НарядНаВыполнениеРемонтныхРабот.ДокументыОснования КАК Наряды
