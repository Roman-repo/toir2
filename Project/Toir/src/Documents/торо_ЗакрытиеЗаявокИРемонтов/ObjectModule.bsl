КонецПроцедуры

Процедура ПроверитьСтатусыВыявленныхДефектов(ВыявленныеДефекты)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	торо_ВыявленныеДефектыСписокДефектов.Ссылка КАК Ссылка,
	               |	торо_ВыявленныеДефектыСписокДефектов.ID КАК IDДефекта,
	               |	ЕСТЬNULL(торо_ОтмененныеРемонтыСрезПоследних.ID,"""") КАК IDОтмененный
	               |ИЗ
	               |	Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеРемонты.СрезПоследних КАК торо_ОтмененныеРемонтыСрезПоследних
	               |		ПО торо_ВыявленныеДефектыСписокДефектов.ID = торо_ОтмененныеРемонтыСрезПоследних.ID
	               |ГДЕ
	               |	торо_ВыявленныеДефектыСписокДефектов.Ссылка В(&ВыявленныеДефекты) 
	               |ИТОГИ ПО
	               |	Ссылка";
	Запрос.УстановитьПараметр("ВыявленныеДефекты", ВыявленныеДефекты);
	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	Пока ВыборкаДокументов.Следующий() Цикл
		ВыборкаДефектов = ВыборкаДокументов.Выбрать();
		ЗакрытьДокумент = Истина;
		Пока ВыборкаДефектов.Следующий() Цикл
			Если ВыборкаДефектов.IDДефекта <> ВыборкаДефектов.IDОтмененный Тогда
				ЗакрытьДокумент = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ЗакрытьДокумент Тогда
			ДвижениеПоРегистру_торо_СтатусыДокументовВыявленныхДефектов(ВыборкаДокументов.Ссылка);
			ДвижениеПоРегистру_торо_СтатусыДокументовВыявленныхДефектовУстановленные(ВыборкаДокументов.Ссылка);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

