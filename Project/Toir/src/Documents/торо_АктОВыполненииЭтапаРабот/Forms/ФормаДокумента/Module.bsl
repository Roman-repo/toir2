КонецПроцедуры

&НаСервере
Процедура ОбработатьВыборМассиваРемонтовНаСервере(ВыбранноеЗначение)
	
	МассивIDОпераций = Новый Массив;
	
	Для каждого Элемент Из ВыбранноеЗначение Цикл
		ИДСтрокиРемонта = Неопределено; 
		ИДТекущегоРемонта = Элемент.СтрокаРемонтовОборудования.ID;
		НайденныеСтрокиРемонта = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДТекущегоРемонта));
		Если НайденныеСтрокиРемонта.Количество() <> 0 Тогда
			ИДСтрокиРемонта = НайденныеСтрокиРемонта[0].ПолучитьИдентификатор();
			
			ЗаполнитьДеревоРемонтныхРаботНаСервере(ИДТекущегоРемонта);
			Если ТипЗнч(Элемент.ДокументОснование) = Тип("ДокументСсылка.торо_ЗаявкаНаРемонт") Тогда
				ЗаполнитьМатериалыПоОснованиюНаСервере(Неопределено, ИДСтрокиРемонта, Ложь);
			Иначе
				ЗаполнитьМатериалыПоНормамНаСервере(Неопределено, ИДСтрокиРемонта, Ложь);
			КонецЕсли;
			
			Если ТипЗнч(Элемент.ДокументОснование) = Тип("ДокументСсылка.торо_ПланГрафикРемонта") ИЛИ 
				ТипЗнч(Элемент.ДокументОснование) = Тип("ДокументСсылка.торо_ВыявленныеДефекты") ИЛИ 
				ТипЗнч(Элемент.ДокументОснование) = Тип("ДокументСсылка.торо_ВнешнееОснованиеДляРабот") Тогда
				торо_Ремонты.ЗаполнитьИсполнителейПоНормам(ЭтаФорма, Неопределено, ИДСтрокиРемонта, "ТрудовыеЗатраты");
			КонецЕсли;
			
			МассивIDОперацийРемонта = ПолучитьIDОперацийПоIDРемонта(Объект, ИДТекущегоРемонта);
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивIDОпераций, МассивIDОперацийРемонта);
		КонецЕсли;

	КонецЦикла;
	
	Если МассивIDОпераций.Количество() > 0 Тогда 
		ОтметитьНаличиеАналогов(МассивIDОпераций);
	КонецЕсли;
	
	Для каждого Строка Из Объект.ТрудовыеЗатраты Цикл
		Строка.ВремяРаботыТекст = СформироватьПродолжительность(Строка.ВремяРаботы);
	КонецЦикла;
	
КонецПроцедуры

