			ТекстСообщения = НСтр("es='¡La fecha del documento debe ser más de fechas del documento-razón!';ru='Дата документа должна быть больше даты документа-основания!';en='The date of the document must be greater than the date of the base document!'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
		КонецЕсли;		
	КонецЕсли;
КонецПроцедуры

