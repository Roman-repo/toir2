					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Составила настоящий акт о нижеследующем:</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>es</v8:lang>
							<v8:content>Ha levantado el acta presente de lo siguiente:</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Compiled this act as follows:</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
		</row>
