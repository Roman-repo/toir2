		стрПоиска.ОбъектРемонта = строкаТЧ.ОбъектРемонта;
		масСтрок = Объект.СписокДефектов.НайтиСтроки(стрПоиска); 
		
		Для каждого текСтрока из МасСтрок цикл
			Объект.СписокДефектов.Удалить(текСтрока);
		КонецЦикла;
	КонецЦикла;
	
