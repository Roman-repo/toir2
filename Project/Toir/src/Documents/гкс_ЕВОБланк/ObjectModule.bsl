#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	ДокументОснование = ДанныеЗаполнения;
	Если Не ДанныеЗаполнения = Неопределено Тогда 
		Организация = ДанныеЗаполнения.Организация;
		Подразделение = ДанныеЗаполнения.Подразделение;
		Ответственный = ПараметрыСеанса.ТекущийПользователь;;
		Если ДанныеЗаполнения.СписокДефектов.Количество() Тогда 
			ВидДефекта = ДанныеЗаполнения.СписокДефектов[0].ВидДефекта;
			КорневаяПричина = ДанныеЗаполнения.СписокДефектов[0].гкс_КорневаяПричина;
			ДефектОписание = ДанныеЗаполнения.СписокДефектов[0].ДефектОписание;
		КонецЕсли;
		ДатаОбнаружения = ДанныеЗаполнения.ДатаОбнаружения;
	КонецЕсли;
	торо_ЗаполнениеДокументов.ЗаполнитьСтандартныеРеквизитыШапкиПоУмолчанию(ЭтотОбъект);
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	// Гкс+[TOIR20-465] Зозуля А.В. от 16.10.2024. Изменено:{
	//СтрокиКУдалению = Новый Массив();
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;	
	
	ТекстСообщенияНезаполненныхПолейМероприятий = 
	 "Для записи документа необходимо заполнить Мероприятия по предупреждению, значение поля «%1» в строке № %2"; 
	// } Гкс-[TOIR20-465] Зозуля А.В. от 16.10.2024. 	
	Для Каждого СТ Из МероприятияПоПредупреждению Цикл
		// Гкс+[TOIR20-465] Зозуля А.В. от 16.10.2024. Изменено:{
		//Если ЗначениеЗаполнено(СТ.Мероприятие) = Ложь Тогда 
		//	СтрокиКУдалению.Добавить(СТ);
		//	Продолжить;
		//КонецЕсли;
		//Если ЗначениеЗаполнено(СТ.Ответственный) = Ложь ИЛИ ЗначениеЗаполнено(СТ.Срок) = Ложь Тогда 
		//	СтрокиКУдалению.Добавить(СТ);
		//	Продолжить;
		//КонецЕсли; 
		НомерСтроки = СТ.НомерСтроки;
		Если Не ЗначениеЗаполнено(СТ.Мероприятие) Тогда 
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = СтрШаблон(ТекстСообщенияНезаполненныхПолейМероприятий, "Мероприятие", НомерСтроки);
			Сообщение.Поле = "Объект.МероприятияПоПредупреждению["+(СТ.НомерСтроки-1)+"].Мероприятие"; 
			Сообщение.Сообщить();
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СТ.Ответственный) Тогда 
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = СтрШаблон(ТекстСообщенияНезаполненныхПолейМероприятий, "Ответственный", НомерСтроки);
			Сообщение.Поле = "Объект.МероприятияПоПредупреждению["+(СТ.НомерСтроки-1)+"].Ответственный";
			Сообщение.Сообщить();
		КонецЕсли; 
		Если Не ЗначениеЗаполнено(СТ.Срок) Тогда 
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = СтрШаблон(ТекстСообщенияНезаполненныхПолейМероприятий, "Срок", НомерСтроки);
			Сообщение.Поле = "Объект.МероприятияПоПредупреждению["+(СТ.НомерСтроки-1)+"].Срок";
			Сообщение.Сообщить();
		КонецЕсли;
		// } Гкс-[TOIR20-465] Зозуля А.В. от 16.10.2024.
	КонецЦикла;
	// Гкс+[TOIR20-465] Зозуля А.В. от 16.10.2024. Удалено:{
	//Для Каждого СМ ИЗ СтрокиКУдалению Цикл
	//	МероприятияПоПредупреждению.Удалить(МероприятияПоПредупреждению.Индекс(СМ));
	//КонецЦикла;
	// } Гкс-[TOIR20-465] Зозуля А.В. от 16.10.2024.
	// Гкс+[TOIR20-526] Вялых Д.А. от 07.02.2025. Добавлено:{
	//Если не ЗначениеЗаполнено(ВидНеисправности) Тогда 
	Если Не ЗначениеЗаполнено(ЗонаОтветственности) Тогда
	// } Гкс-[TOIR20-526] Вялых Д.А. от 07.02.2025.
		Отказ = Истина;
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Не указана зона ответственности";
		//Сообщение.Поле = "Объект.ВидНеисправности"; 
		Сообщение.Поле = "Объект.ЗонаОтветственности";
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ДокументОснование = Неопределено;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Если ЗначениеЗаполнено(ДокументОснование) Тогда 
		ОбновляемОснование = Ложь;
		
		ДефектОбъект = ДокументОснование.ПолучитьОбъект();
		Если ДефектОбъект.СписокДефектов.Количество() Тогда
			Если Не (ДефектОбъект.СписокДефектов[0].ВидДефекта = ВидДефекта
				И ДефектОбъект.СписокДефектов[0].гкс_КорневаяПричина = КорневаяПричина
				И ДефектОбъект.СписокДефектов[0].ДефектОписание = ДефектОписание) Тогда
				ОбновляемОснование = Истина;
			КонецЕсли;
		КонецЕсли;
		ОбновляемОснование = ОбновляемОснование ИЛИ Не ДефектОбъект.ДатаОбнаружения = ДатаОбнаружения;
		
		Если ОбновляемОснование Тогда 
			
			ДефектОбъект.СписокДефектов[0].ВидДефекта = ВидДефекта;
			ДефектОбъект.СписокДефектов[0].гкс_КорневаяПричина = КорневаяПричина;
			ДефектОбъект.СписокДефектов[0].ДефектОписание = ДефектОписание;
			ДефектОбъект.ДатаОбнаружения = ДатаОбнаружения;
			ДефектОбъект.Записать(РежимЗаписиДокумента.Запись);
			
			Если ДефектОбъект.Проведен Тогда 
				НаборЗаписей = РегистрыСведений.торо_ВыявленныеДефекты.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(ДефектОбъект.Ссылка);
				НаборЗаписей.Прочитать();
				Если НаборЗаписей.Количество() Тогда 
					НаборЗаписей[0].ВидДефекта = ВидДефекта;
					НаборЗаписей[0].гкс_КорневаяПричина = КорневаяПричина;
				КонецЕсли;
				НаборЗаписей.Записать();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Движения.гкс_ОжидаемыеМероприятияЕвобланк.Записывать = Истина;
	Если РазборТребуется Тогда 
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ
		               |	ТЧ.Ответственный КАК Ответственный,
		               |	ТЧ.Мероприятие КАК Мероприятие,
		               |	ТЧ.Срок КАК Срок
		               |ПОМЕСТИТЬ Исходные
		               |ИЗ
		               |	&ТЧ1 КАК ТЧ
		               |ГДЕ
		               |	ТЧ.Выполнено = ЛОЖЬ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	Исходные.Ответственный КАК Ответственный,
		               |	МАКСИМУМ(Исходные.Мероприятие) КАК Мероприятие,
		               |	Исходные.Срок КАК Срок
		               |ИЗ
		               |	Исходные КАК Исходные
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Исходные.Ответственный,
		               |	Исходные.Срок";
		Запрос.УстановитьПараметр("ТЧ1", МероприятияПоПредупреждению.Выгрузить());
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда 
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				НС = Движения.гкс_ОжидаемыеМероприятияЕвобланк.Добавить();
				НС.Период = Дата;
				НС.Ответственный = Выборка.Ответственный;
				НС.Срок = Выборка.Срок;
				НС.Мероприятие = Выборка.Мероприятие;
				НС.Источник = Ссылка;
			КонецЦикла;
		КонецЕсли
	КонецЕсли;
КонецПроцедуры

#КонецОбласти