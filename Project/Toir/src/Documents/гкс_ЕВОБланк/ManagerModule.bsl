Функция Печать5Почему(МассивОбъектов, ПараметрыПечати) 
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.гкс_ЕВОБланк.ПФ_MXL_5Почему");
	ТабДок = Новый ТабличныйДокумент();
	//	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ЕВОБланк.Ссылка КАК Ссылка,
		|	гкс_ЕВОБланк.КорневаяПричинаТекст КАК КорневаяПричинаТекст
		|ПОМЕСТИТЬ ВсеЕВО
		|ИЗ
		|	Документ.гкс_ЕВОБланк КАК гкс_ЕВОБланк
		|ГДЕ
		|	гкс_ЕВОБланк.Ссылка В(&Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВсеЕВО.Ссылка КАК Ссылка,
		|	ВсеЕВО.КорневаяПричинаТекст КАК КорневаяПричинаТекст,
		|	ДокТЧ.Причина КАК Причина,
		|	ДокТЧ.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	ВсеЕВО КАК ВсеЕВО
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.гкс_ЕВОБланк.АнализПричины КАК ДокТЧ
		|		ПО ВсеЕВО.Ссылка = ДокТЧ.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ ПО
		|	Ссылка";	
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДок = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	

	ЭтоПервый = Истина;
	Пока ВыборкаДок.Следующий() Цикл
		Если ЭтоПервый Тогда 
			ЭтоПервый = Ложь;
		Иначе
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		Шапка = Макет.ПолучитьОбласть("ШапкаОтдельно");
		ТабДок.Вывести(Шапка);
		ДокОб = ВыборкаДок.Ссылка.ПолучитьОбъект();
		//Линия1 = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
		НомерПП = 2;
		СтрокиКорня = ПолучитьДеревоПричин(0, 0, ДокОб.АнализПричины);	
		ПостроитьТаблицуПричин(ТабДок, СтрокиКорня, 2, 2);
		
		
	КонецЦикла;
	//
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.АвтоМасштаб = Истина;
	Возврат ТабДок;
КонецФункции

