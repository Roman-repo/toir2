Функция ПреобразоватьФИО(Сотрудник)
	МассивИмени = СтрРазделить(Строка(Сотрудник)," ",Ложь);
	Если МассивИмени.Количество() > 2 Тогда 
		Возврат МассивИмени[0] +" "+ Лев(МассивИмени[1],1) +". "+ Лев(МассивИмени[2],1)+".";
	КонецЕсли;
	Возврат Сотрудник;
КонецФункции // гкс- [10.23] Деснол 09.04.2024

// гкс+ [10.23] Деснол 19.04.2024
Функция ПолучитьДеревоПричин(РодительИД, Уровень, АнализПричины)	
	МассивОтвета = Новый Массив();
	СтрокиКорня = АнализПричины.НайтиСтроки(Новый Структура("РодительИД", РодительИД));
	Для Каждого СТ Из СтрокиКорня Цикл
		ЭтиСтроки = ПолучитьДеревоПричин(СТ.ИД, Уровень + 1, АнализПричины);
		Если ЭтиСтроки.Количество() Тогда 
			Высота = 0;
			Для Каждого СМ ИЗ ЭтиСтроки Цикл
				Высота = СМ.Высота + Высота;
			КонецЦикла;
		Иначе
			Высота = 1;
		КонецЕсли;
		ТемпСтрукт = Новый Структура("Текст,ИД,ЭтиСтроки", СТ.Причина, СТ.ИД, ЭтиСтроки);
		ТемпСтрукт.Вставить("Высота", Высота);
		ТемпСтрукт.Вставить("Уровень", Уровень);
		ТемпСтрукт.Вставить("КорневаяПричина", СТ.КорневаяПричина);
		МассивОтвета.Добавить(ТемпСтрукт);
	КонецЦикла;
	Возврат МассивОтвета;
КонецФункции // гкс- [10.23] Деснол 19.04.2024

