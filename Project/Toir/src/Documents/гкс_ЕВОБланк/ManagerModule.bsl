#Область СлужебныеПроцедурыИФункции

Функция ПолучитьАктуальнуюСтруктуру(Дефект = Неопределено, Бланк = Неопределено)Экспорт

	Запрос = Новый Запрос;
	Если Бланк = Неопределено Тогда 
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	торо_ВыявленныеДефектыСписокДефектов.ID КАК ID,
			|	торо_ВыявленныеДефектыСписокДефектов.гкс_СимптомДефекта КАК гкс_СимптомДефекта,
			|	торо_ВыявленныеДефектыСписокДефектов.ОбъектРемонта КАК ОбъектРемонта,
			|	торо_ВыявленныеДефектыСписокДефектов.ОтказавшийЭлемент КАК ОтказавшийЭлемент,
			|	торо_ВыявленныеДефектыСписокДефектов.ВидДефекта КАК ВидНеисправности,
			|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.гкс_Влияние КАК Влияние,
			|	торо_ВыявленныеДефектыСписокДефектов.ДефектОписание КАК ДефектОписание,
			|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.ДатаОбнаружения КАК ДатаОбнаружения
			|ПОМЕСТИТЬ НужныеДефекты
			|ИЗ
			|	Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
			|ГДЕ
			|	торо_ВыявленныеДефектыСписокДефектов.Ссылка = &Ссылка";
		Запрос.УстановитьПараметр("Ссылка", Дефект);
	Иначе
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	торо_ВыявленныеДефектыСписокДефектов.ID КАК ID,
			|	торо_ВыявленныеДефектыСписокДефектов.гкс_СимптомДефекта КАК гкс_СимптомДефекта,
			|	торо_ВыявленныеДефектыСписокДефектов.ОтказавшийЭлемент КАК ОтказавшийЭлемент,
			|	торо_ВыявленныеДефектыСписокДефектов.ОбъектРемонта КАК ОбъектРемонта,
			|	торо_ВыявленныеДефектыСписокДефектов.ВидДефекта КАК ВидНеисправности,
			|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.гкс_Влияние КАК Влияние,
			|	торо_ВыявленныеДефектыСписокДефектов.ДефектОписание КАК ДефектОписание,
			|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.ДатаОбнаружения КАК ДатаОбнаружения
			|ПОМЕСТИТЬ НужныеДефекты
			|ИЗ
			|	Документ.гкс_ЕВОБланк КАК гкс_ЕВОБланк
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
			|		ПО гкс_ЕВОБланк.ДокументОснование = торо_ВыявленныеДефектыСписокДефектов.Ссылка
			|ГДЕ
			|	гкс_ЕВОБланк.Ссылка = &Ссылка";
		Запрос.УстановитьПараметр("Ссылка", Бланк);
	КонецЕсли;
	Запрос.Текст = Запрос.Текст + " ; " +
			"ВЫБРАТЬ
			|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.ID КАК ИД,
			|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Родитель_ID КАК Родитель_ИД,
			|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтнаяРабота КАК РемонтнаяРабота,
			|	НужныеДефекты.ID КАК ИДРемонта,
			|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Ссылка КАК Акт,
			|	ТИПЗНАЧЕНИЯ(торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтнаяРабота) = ТИП(Справочник.торо_ИдентификаторыТехКарт) КАК ЭтоТК
			|ПОМЕСТИТЬ ВсеРРИзАкта
			|ИЗ
			|	НужныеДефекты КАК НужныеДефекты
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтныеРаботы КАК торо_АктОВыполненииЭтапаРаботРемонтныеРаботы
			|		ПО НужныеДефекты.ID = торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтыОборудования_ID
			|			И (торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Ссылка.ПометкаУдаления = ЛОЖЬ)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВсеРРИзАкта.ИДРемонта КАК ИДРемонта,
			|	ВсеРРИзАкта.ИД КАК ИД,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			|	СУММА(торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Количество) КАК Количество,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура КАК Номенклатура,
			|	ВсеРРИзАкта.Акт КАК Акт,
			|	ВсеРРИзАкта.Родитель_ИД КАК Родитель_ИД
			|ПОМЕСТИТЬ ВсеМЗИзАкта
			|ИЗ
			|	ВсеРРИзАкта КАК ВсеРРИзАкта
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.МатериальныеЗатраты КАК торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты
			|		ПО ВсеРРИзАкта.Акт = торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Ссылка
			|			И ВсеРРИзАкта.ИДРемонта = торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.РемонтыОборудования_ID
			|			И ВсеРРИзАкта.ИД = торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ID
			|			И (НЕ торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка))
			|
			|СГРУППИРОВАТЬ ПО
			|	ВсеРРИзАкта.ИДРемонта,
			|	ВсеРРИзАкта.ИД,
			|	ВсеРРИзАкта.Акт,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ЕдиницаИзмерения,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура,
			|	ВсеРРИзАкта.Родитель_ИД
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	НужныеДефекты.ID КАК ID,
			|	НужныеДефекты.гкс_СимптомДефекта КАК СимптомДефекта,
			|	НужныеДефекты.ОбъектРемонта КАК ОбъектРемонта,
			|	НужныеДефекты.ОтказавшийЭлемент КАК ОтказавшийЭлемент,
			|	НужныеДефекты.ВидНеисправности КАК ВидНеисправности,
			|	НужныеДефекты.Влияние КАК Влияние,
			|	НужныеДефекты.ДефектОписание КАК ДефектОписание,
			|	НужныеДефекты.ДатаОбнаружения КАК ДатаОбнаружения
			|ИЗ
			|	НужныеДефекты КАК НужныеДефекты
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	гкс_ТехническиеМеста.ЗаводПодразделение КАК Завод,
			|	гкс_ТехническиеМеста.Участок КАК Участок
			|ИЗ
			|	НужныеДефекты КАК НужныеДефекты
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК ЗаявкаРемонты
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
			|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.гкс_ТехническиеМеста КАК гкс_ТехническиеМеста
			|				ПО (гкс_ТекущиеФМОР.ОР = гкс_ТекущиеФМОР.ФМ
			|							И гкс_ТекущиеФМОР.ТМ = гкс_ТехническиеМеста.Ссылка
			|						ИЛИ НЕ гкс_ТекущиеФМОР.ОР = гкс_ТекущиеФМОР.ФМ
			|							И гкс_ТекущиеФМОР.ТМФМ = гкс_ТехническиеМеста.Ссылка)
			|			ПО ЗаявкаРемонты.ОбъектРемонта = гкс_ТекущиеФМОР.ОР
			|		ПО НужныеДефекты.ID = ЗаявкаРемонты.ID
			|			И (ЗаявкаРемонты.Ссылка.ПометкаУдаления = ЛОЖЬ)
			|
			|УПОРЯДОЧИТЬ ПО
			|	ЗаявкаРемонты.Ссылка.Проведен УБЫВ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВсеРРИзАкта.РемонтнаяРабота КАК РР,
			|	ВсеРРИзАкта.ИДРемонта КАК ИДРемонта,
			|	ВсеМЗИзАкта.Номенклатура КАК Номенклатура,
			|	СУММА(ВсеМЗИзАкта.Количество) КАК Количество,
			|	ВсеМЗИзАкта.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			|	ВсеРРИзАкта.Акт КАК Акт,
			|	ВсеРРИзАкта.ИД КАК ИД
			|ИЗ
			|	ВсеРРИзАкта КАК ВсеРРИзАкта
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВсеМЗИзАкта КАК ВсеМЗИзАкта
			|		ПО ВсеРРИзАкта.ИД = ВсеМЗИзАкта.Родитель_ИД
			|			И ВсеРРИзАкта.Акт = ВсеМЗИзАкта.Акт
			|ГДЕ
			|	ВсеРРИзАкта.ЭтоТК = ИСТИНА
			|
			|СГРУППИРОВАТЬ ПО
			|	ВсеРРИзАкта.РемонтнаяРабота,
			|	ВсеРРИзАкта.ИДРемонта,
			|	ВсеМЗИзАкта.Номенклатура,
			|	ВсеМЗИзАкта.ЕдиницаИзмерения,
			|	ВсеРРИзАкта.Акт,
			|	ВсеРРИзАкта.ИД
			|ИТОГИ
			|	МАКСИМУМ(РР)
			|ПО
			|	Акт,
			|	ИД
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	МИНИМУМ(ЕстьNULL(торо_АктОВыполненииЭтапаРаботРемонтыОборудования.ДатаНачала, ДатаВремя(1,1,1))) КАК ДатаНачала,
			|	МАКСИМУМ(ЕстьNULL(торо_АктОВыполненииЭтапаРаботРемонтыОборудования.ДатаОкончания, ДатаВремя(1,1,1))) КАК ДатаОкончания
			|ИЗ
			|	НужныеДефекты КАК НужныеДефекты
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК торо_АктОВыполненииЭтапаРаботРемонтыОборудования
			|		ПО НужныеДефекты.ID = торо_АктОВыполненииЭтапаРаботРемонтыОборудования.ID
			|			И (торо_АктОВыполненииЭтапаРаботРемонтыОборудования.Ссылка.ПометкаУдаления = ЛОЖЬ)";

	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	КВозврату = новый Структура("Завод,Участок,ОписаниеПроблемы,ФункциональноеМесто,ОтказавшийЭлемент,ВидНеисправности,Влияние,ВремяНачалаРаботыТС,ВремяОкончанияРаботыТС");

	КВозврату.Вставить("ДатаОбнаружения", Дата(1,1,1));
	КВозврату.Вставить("ВидДефекта", Неопределено);
	
	Выборка = РезультатЗапроса[3].Выбрать();	
	Пока Выборка.Следующий() Цикл
		КВозврату.Вставить("ОписаниеПроблемы", Строка(Выборка.СимптомДефекта) + Символы.ПС + Выборка.ДефектОписание);
		КВозврату.Вставить("ФункциональноеМесто", Выборка.ОбъектРемонта);
		КВозврату.Вставить("ОтказавшийЭлемент", Выборка.ОтказавшийЭлемент);
		КВозврату.Вставить("ВидНеисправности", Выборка.ВидНеисправности);
		КВозврату.Вставить("Влияние", Выборка.Влияние);
		КВозврату.Вставить("ДатаОбнаружения", Выборка.ДатаОбнаружения);
		КВозврату.Вставить("ВидДефекта", Выборка.ВидНеисправности);
	КонецЦикла;
	
	Выборка = РезультатЗапроса[4].Выбрать();	
	Пока Выборка.Следующий() Цикл
		КВозврату.Завод = Выборка.Завод;
		КВозврату.Участок = Выборка.Участок;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[6].Выбрать();	
	Пока Выборка.Следующий() Цикл
		КВозврату.Вставить("ВремяНачалаРаботыТС",Выборка.ДатаНачала);
		КВозврату.Вставить("ВремяОкончанияРаботыТС",Выборка.ДатаОкончания);
	КонецЦикла;
	Если КВозврату.ВремяНачалаРаботыТС = null Тогда 
		КВозврату.ВремяНачалаРаботыТС = Дата(1,1,1);
	КонецЕсли;
	Если КВозврату.ВремяОкончанияРаботыТС = null Тогда 
		КВозврату.ВремяОкончанияРаботыТС = Дата(1,1,1);
	КонецЕсли;
	
	ТЧ1 = Новый ТаблицаЗначений();
	ТЧ1.Колонки.Добавить("НомерТК", Новый ОписаниеТипов("Число",,, новый КвалификаторыЧисла(5)));
	ТЧ1.Колонки.Добавить("ТехКарта", Новый ОписаниеТипов("СправочникСсылка.торо_ИдентификаторыТехКарт"));
	//
	ТЧ2 = Новый ТаблицаЗначений();
	ТЧ2.Колонки.Добавить("НомерТК", Новый ОписаниеТипов("Число",,,новый КвалификаторыЧисла(5)));
	ТЧ2.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЧ2.Колонки.Добавить("ЕдиницаИзмерения", Новый ОписаниеТипов("СправочникСсылка.УпаковкиНоменклатуры"));
	ТЧ2.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число",,, новый КвалификаторыЧисла(15, 3)));
	//
	НомерПП = 0;
	Выборка1 = РезультатЗапроса[5].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	Пока Выборка1.Следующий() Цикл
		Выборка2 = Выборка1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборка2.Следующий() Цикл
			НомерПП = НомерПП + 1;
			НС = ТЧ1.Добавить();
			НС.НомерТК = НомерПП;
			НС.ТехКарта = Выборка2.РР;
			Выборка = Выборка2.Выбрать();
			Пока Выборка.Следующий() Цикл
				Если ЗначениеЗаполнено(Выборка.Номенклатура) Тогда 
					НС = ТЧ2.Добавить();
					НС.НомерТК = НомерПП;
					ЗаполнитьЗначенияСвойств(НС, Выборка);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	КВозврату.Вставить("РемонтныеРаботы", ТЧ1);
	КВозврату.Вставить("МатЗатраты", ТЧ2);

	Возврат КВозврату;
КонецФункции

Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.гкс_ЕВОБланк";
	КомандаПечати.Идентификатор = "ЕВОБланк";
	КомандаПечати.Представление = НСтр("ru='EWO-бланк';en='EWO-form'");
	КомандаПечати.СразуНаПринтер = ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекЗагрузить(
	"НастройкиТОиР",
	"ПечатьДокументовБезПредварительногоПросмотра",
	Ложь);
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.гкс_ЕВОБланк";
	КомандаПечати.Идентификатор = "ЕВОБланк5Почему";
	КомандаПечати.Представление = НСтр("ru='5 почему';en='5 WHY'");
		
КонецПроцедуры

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	НужноПечататьМакет = УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ЕВОБланк");
	Если НужноПечататьМакет Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"ЕВОБланк",
		НСтр("ru='EWO-бланк';en='EWO-form'"),
		ПечатьБланк2023(МассивОбъектов, ПараметрыПечати),
		, 
		"Документ.гкс_ЕВОБланк.ПФ_MXL_ЕВОБланк");

	КонецЕсли;
	
	НужноПечататьМакет = УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ЕВОБланк5Почему");
	Если НужноПечататьМакет Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"ЕВОБланк5Почему",
		НСтр("ru='5 почему';en='5 WHY'"),
		Печать5Почему(МассивОбъектов, ПараметрыПечати),
		, 
		"Документ.гкс_ЕВОБланк.ПФ_MXL_5Почему");

	КонецЕсли;
	
КонецПроцедуры

Функция ПечатьБланк(МассивОбъектов, ПараметрыПечати) 
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.гкс_ЕВОБланк.ПФ_MXL_ЕВОБланк");
	ТабДок = Новый ТабличныйДокумент();
	
	Шапка1 = Макет.ПолучитьОбласть("Шапка1");
	СтрокаМЗ = Макет.ПолучитьОбласть("СтрокаМЗ");
	СтрокаМ = Макет.ПолучитьОбласть("СтрокаМ");
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	
	//ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	НомерПоследнейСтроки = 1;
	//	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	гкс_ЕВОБланк.Ссылка КАК Ссылка,
		|	гкс_ЕВОБланк.Номер КАК Номер,
		|	гкс_ЕВОБланк.Ответственный КАК ОтветственныйЕВО,
		|	гкс_ЕВОБланк.КорневаяПричина КАК КорневаяПричина,
		|	гкс_ЕВОБланк.ВремяНачалаОстановки КАК ВремяНачалаОстановки,
		|	гкс_ЕВОБланк.ВремяВызоваТС КАК ВремяВызоваТС,
		|	гкс_ЕВОБланк.ВремяЗапуска КАК ВремяЗапуска,
		|	гкс_ЕВОБланк.ТипКорневойПричины КАК ТипКорневойПричины,
		|	торо_ВыявленныеДефектыСписокДефектов.гкс_СимптомДефекта КАК СимптомДефекта,
		|	торо_ВыявленныеДефектыСписокДефектов.ОбъектРемонта КАК ОР,
		|	торо_ВыявленныеДефектыСписокДефектов.ОтказавшийЭлемент КАК Отказавший,
		|	торо_ВыявленныеДефектыСписокДефектов.ВидДефекта КАК ВидДефекта,
		|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.гкс_Влияние КАК Влияние,
		|	торо_ВыявленныеДефектыСписокДефектов.ДефектОписание КАК ДефектОписание,
		|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.КонтактноеЛицоИнициатора КАК КЛИ,
		|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.ДатаОбнаружения КАК ДатаОбнаружения,
		|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.Ответственный КАК ОтветственныйВД,
		|	торо_ВыявленныеДефектыСписокДефектов.ID КАК ИД
		|ПОМЕСТИТЬ ВсеЕВО
		|ИЗ
		|	Документ.гкс_ЕВОБланк КАК гкс_ЕВОБланк
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
		|		ПО гкс_ЕВОБланк.ДокументОснование = торо_ВыявленныеДефектыСписокДефектов.Ссылка
		|ГДЕ
		|	гкс_ЕВОБланк.Ссылка В(&Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВсеЕВО.Ссылка КАК Ссылка,
		|	МИНИМУМ(торо_АктОВыполненииЭтапаРаботРемонтыОборудования.ДатаНачала) КАК ДатаНачала,
		|	МАКСИМУМ(торо_АктОВыполненииЭтапаРаботРемонтыОборудования.ДатаОкончания) КАК ДатаОкончания,
		|	МАКСИМУМ(торо_ИсторияСтатусовСогласованияДокументов.Пользователь) КАК Проверяющий
		|ПОМЕСТИТЬ ИзАкта
		|ИЗ
		|	ВсеЕВО КАК ВсеЕВО
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК торо_АктОВыполненииЭтапаРаботРемонтыОборудования
		|		ПО ВсеЕВО.ИД = торо_АктОВыполненииЭтапаРаботРемонтыОборудования.ID
		|			И (торо_АктОВыполненииЭтапаРаботРемонтыОборудования.Ссылка.ПометкаУдаления = ЛОЖЬ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИсторияСтатусовСогласованияДокументов КАК торо_ИсторияСтатусовСогласованияДокументов
		|		ПО ВсеЕВО.Ссылка = торо_ИсторияСтатусовСогласованияДокументов.СогласуемыйДокумент
		|			И (торо_ИсторияСтатусовСогласованияДокументов.СтатусДокумента = ЗНАЧЕНИЕ(Справочник.торо_СтатусыСогласованияДокументовРемонтныхРабот.Согласован))
		|
		|СГРУППИРОВАТЬ ПО
		|	ВсеЕВО.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВсеЕВО.Ссылка КАК Ссылка,
		|	ВсеЕВО.Номер КАК Номер,
		|	ВсеЕВО.ОтветственныйЕВО КАК ОтветственныйЕВО,
		|	ВсеЕВО.КорневаяПричина КАК КорневаяПричина,
		|	ВсеЕВО.ВремяНачалаОстановки КАК ВремяНачалаОстановки,
		|	ВсеЕВО.ВремяВызоваТС КАК ВремяВызоваТС,
		|	ВсеЕВО.ВремяЗапуска КАК ВремяЗапуска,
		|	ВсеЕВО.ТипКорневойПричины КАК ТипКорневойПричины,
		|	ВсеЕВО.СимптомДефекта КАК СимптомДефекта,
		|	ВсеЕВО.ОР КАК ОР,
		|	ВсеЕВО.Отказавший КАК Отказавший,
		|	ВсеЕВО.ВидДефекта КАК ВидДефекта,
		|	ВсеЕВО.Влияние КАК Влияние,
		|	ВсеЕВО.ДефектОписание КАК ДефектОписание,
		|	ВсеЕВО.КЛИ КАК КЛИ,
		|	ВсеЕВО.ДатаОбнаружения КАК ДатаОбнаружения,
		|	ВсеЕВО.ОтветственныйВД КАК ОтветственныйВД,
		|	ВсеЕВО.ИД КАК ИД,
		|	ИзАкта.ДатаНачала КАК ДатаНачала,
		|	ИзАкта.ДатаОкончания КАК ДатаОкончания,
		|	ИзАкта.Проверяющий КАК Проверяющий,
		|	гкс_ТехническиеМеста.ЗаводПодразделение КАК Завод,
		|	гкс_ТехническиеМеста.Участок КАК Участок
		|ИЗ
		|	ВсеЕВО КАК ВсеЕВО
		|		ЛЕВОЕ СОЕДИНЕНИЕ ИзАкта КАК ИзАкта
		|		ПО ВсеЕВО.Ссылка = ИзАкта.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты.СписокДефектов КАК ДефектРемонты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК ЗаявкаРемонты
		|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
		|					ЛЕВОЕ СОЕДИНЕНИЕ Справочник.гкс_ТехническиеМеста КАК гкс_ТехническиеМеста
		|					ПО (гкс_ТекущиеФМОР.ОР = гкс_ТекущиеФМОР.ФМ
		|								И гкс_ТекущиеФМОР.ТМ = гкс_ТехническиеМеста.Ссылка
		|							ИЛИ НЕ гкс_ТекущиеФМОР.ОР = гкс_ТекущиеФМОР.ФМ
		|								И гкс_ТекущиеФМОР.ТМФМ = гкс_ТехническиеМеста.Ссылка)
		|				ПО ЗаявкаРемонты.ОбъектРемонта = гкс_ТекущиеФМОР.ОР
		|			ПО ДефектРемонты.ID = ЗаявкаРемонты.ID
		|		ПО ВсеЕВО.Ссылка.ДокументОснование = ДефектРемонты.Ссылка
		|ИТОГИ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	гкс_ЕВОБланкМероприятияПоПредупреждению.Мероприятие КАК Мероприятие,
		|	гкс_ЕВОБланкМероприятияПоПредупреждению.Ответственный КАК Ответственный,
		|	гкс_ЕВОБланкМероприятияПоПредупреждению.Срок КАК Срок,
		|	гкс_ЕВОБланкМероприятияПоПредупреждению.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.гкс_ЕВОБланк.МероприятияПоПредупреждению КАК гкс_ЕВОБланкМероприятияПоПредупреждению
		|ГДЕ
		|	гкс_ЕВОБланкМероприятияПоПредупреждению.Ссылка В(&Ссылка)
		|ИТОГИ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	гкс_ЕВОБланкАнализПричины.Причина КАК Причина,
		|	гкс_ЕВОБланкАнализПричины.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.гкс_ЕВОБланк.АнализПричины КАК гкс_ЕВОБланкАнализПричины
		|ГДЕ
		|	гкс_ЕВОБланкАнализПричины.Ссылка В(&Ссылка)
		|ИТОГИ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.ID КАК ИД,
		|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Родитель_ID КАК Родитель_ИД,
		|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтнаяРабота КАК РемонтнаяРабота,
		|	НужныеДефекты.ИД КАК ИДРемонта,
		|	торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Ссылка КАК Акт,
		|	ТИПЗНАЧЕНИЯ(торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтнаяРабота) = ТИП(Справочник.торо_ИдентификаторыТехКарт) КАК ЭтоТК,
		|	НужныеДефекты.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВсеРРИзАкта
		|ИЗ
		|	ВсеЕВО КАК НужныеДефекты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтныеРаботы КАК торо_АктОВыполненииЭтапаРаботРемонтныеРаботы
		|		ПО НужныеДефекты.ИД = торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтыОборудования_ID
		|			И (торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Ссылка.ПометкаУдаления = ЛОЖЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВсеРРИзАкта.ИДРемонта КАК ИДРемонта,
		|	ВсеРРИзАкта.ИД КАК ИД,
		|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура КАК Номенклатура,
		|	ВсеРРИзАкта.Акт КАК Акт,
		|	ВсеРРИзАкта.Родитель_ИД КАК Родитель_ИД
		|ПОМЕСТИТЬ ВсеМЗИзАкта
		|ИЗ
		|	ВсеРРИзАкта КАК ВсеРРИзАкта
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.МатериальныеЗатраты КАК торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты
		|		ПО ВсеРРИзАкта.Акт = торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Ссылка
		|			И ВсеРРИзАкта.ИДРемонта = торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.РемонтыОборудования_ID
		|			И ВсеРРИзАкта.ИД = торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ID
		|
		|СГРУППИРОВАТЬ ПО
		|	ВсеРРИзАкта.ИДРемонта,
		|	ВсеРРИзАкта.ИД,
		|	ВсеРРИзАкта.Акт,
		|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ЕдиницаИзмерения,
		|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура,
		|	ВсеРРИзАкта.Родитель_ИД
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВсеМЗИзАкта.Номенклатура КАК Номенклатура,
		|	ВсеРРИзАкта.Ссылка КАК Ссылка
		|ИЗ
		|	ВсеРРИзАкта КАК ВсеРРИзАкта
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВсеМЗИзАкта КАК ВсеМЗИзАкта
		|		ПО ВсеРРИзАкта.ИД = ВсеМЗИзАкта.Родитель_ИД
		|			И ВсеРРИзАкта.Акт = ВсеМЗИзАкта.Акт
		|ГДЕ
		|	ВсеРРИзАкта.ЭтоТК = ИСТИНА
		|ИТОГИ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВсеРРИзАкта.Ссылка КАК Ссылка,
		|	ВсеРРИзАкта.РемонтнаяРабота КАК РР
		|ИЗ
		|	ВсеРРИзАкта КАК ВсеРРИзАкта
		|ГДЕ
		|	ВсеРРИзАкта.ЭтоТК = ИСТИНА
		|ИТОГИ ПО
		|	Ссылка";	
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);	
	РезультатЗапроса = Запрос.ВыполнитьПакет();	
	Выборка1 = РезультатЗапроса[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	ВыборкаМ1 = РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	ВыборкаА1 = РезультатЗапроса[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	ВыборкаМЗ1 = РезультатЗапроса[7].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	ВыборкаРР1 = РезультатЗапроса[8].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	

	Пока Выборка1.Следующий() Цикл
		Шапка = Макет.ПолучитьОбласть("Шапка"); // Для очистки полей
		Подвал = Макет.ПолучитьОбласть("Подвал");
		Подвал1 = Макет.ПолучитьОбласть("Подвал1");
		//
		Если НомерПоследнейСтроки > 1 Тогда 
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		Выборка = Выборка1.Выбрать();
		Если Выборка.Следующий() Тогда 
			Подвал.Параметры.ОтветственныйЕВО = Выборка.ОтветственныйЕВО;
			Подвал1.Параметры.КорневаяПричина = Выборка.КорневаяПричина;
			Шапка.Параметры.Номер = Выборка.Номер;
			Шапка.Параметры.ВремяВызоваТС = Выборка.ВремяВызоваТС + (СдвигЧП * 3600);
			Шапка.Параметры.ВремяНачалаОстановки = Выборка.ВремяНачалаОстановки + (СдвигЧП * 3600);
			Шапка.Параметры.ВремяЗапуска = Выборка.ВремяЗапуска + (СдвигЧП * 3600);
			Шапка.Параметры.ТипКорневойПричины = Выборка.ТипКорневойПричины;
			//
			Шапка.Параметры.ДатаОбнаружения = Выборка.ДатаОбнаружения + (СдвигЧП * 3600);
			Шапка.Параметры.КЛИ = Выборка.КЛИ;
			Шапка.Параметры.ОР = Выборка.ОР;
			Шапка.Параметры.Отказавший = Выборка.Отказавший;
			Шапка.Параметры.Ответственный = Выборка.ОтветственныйВД;
			Подвал.Параметры.Ответственный = Выборка.ОтветственныйВД;
			Шапка.Параметры.ВидНеисправности = Выборка.ВидДефекта;
			Шапка.Параметры.Влияние = Выборка.Влияние;
			ОписаниеПроблемы = Строка(Выборка.СимптомДефекта) + Символы.ПС + Выборка.ДефектОписание;
			Подвал1.Параметры.ОписаниеПроблемы = ОписаниеПроблемы;
			Шапка.Параметры.ОписаниеПроблемы = ОписаниеПроблемы;
			Шапка.Параметры.Завод = Выборка.Завод;
			Шапка.Параметры.Участок = Выборка.Участок;
			Если Не Выборка.ДатаНачала = null Тогда 
				Шапка.Параметры.ДатаНачала = Выборка.ДатаНачала + (СдвигЧП * 3600);
			КонецЕсли;
			Если Не Выборка.ДатаОкончания = null Тогда 
				Шапка.Параметры.ДатаОкончания = Выборка.ДатаОкончания + (СдвигЧП * 3600);
			КонецЕсли;
