			Пока ВыборкаРР.Следующий() Цикл
				СтрокаРР = СтрокаРР + ?(ЗначениеЗаполнено(СтрокаРР),Символы.ПС,"") + ВыборкаРР.РР;
			КонецЦикла;
		КонецЕсли;
		ВыборкаРР1.Сбросить();
