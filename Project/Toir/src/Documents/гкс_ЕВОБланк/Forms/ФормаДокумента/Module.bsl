&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// ++евобланк
	Если Объект.РазборТребуется И Не гкс_СтатусНаДоработке(СтатусДокументаРегистр) Тогда 
		Если Объект.МероприятияПоПредупреждению.Количество() = 0 Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Таблица мероприятий не заполнена";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
		Если Объект.АнализПричины.Количество() = 0 Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Таблица ""Анализ корневой причины"" не заполнена";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
		Если СокрЛП(Объект.КорневаяПричинаТекст) = "" Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Корневая причина не указана";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Объект.ТипКорневойПричины) Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Тип корневой причины не указан";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Объект.ДиаграммаСобытий) Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Диаграмма событий не указана";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	Если Объект.УровеньОстанова > 0 Тогда 
		Если Не ЗначениеЗаполнено(Объект.ВремяНачалаОстановки) Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Начало периода останова не указано";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	// Гкс+[TOIR20-520] Вялых Д.А. от 29.01.2025. Добавлено:{ 
	Если Не ЗначениеЗаполнено(Объект.ТипПроблемы) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Тип проблемы не указан";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	// } Гкс-[TOIR20-520] Вялых Д.А. от 29.01.2025.
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	// --евобланк
		
	// Согласование++
	торо_РаботаССогласованиями.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	// Согласование--
	
	// гкс+ [Часовые пояса] Куст 14.04.2020
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПСервера(ЭтаФорма,, ТекущийОбъект);
	// гкс- [Часовые пояса] Куст 14.04.2020
КонецПроцедуры

