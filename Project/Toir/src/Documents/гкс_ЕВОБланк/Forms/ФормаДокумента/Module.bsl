			Объект.ДефектОписание = Параметры.ДефектОписание;
		КонецЕсли;
		Если Параметры.Свойство("ВидДефекта") Тогда 
			Объект.ВидДефекта = Параметры.ВидДефекта;
		КонецЕсли;
		Если Параметры.Свойство("КорневаяПричина") Тогда 
			Объект.КорневаяПричина = Параметры.КорневаяПричина;
		КонецЕсли;
		Если Параметры.Свойство("ДатаОбнаружения") Тогда 
			Объект.ДатаОбнаружения = Параметры.ДатаОбнаружения;
		КонецЕсли;
		Объект.Ответственный = ПараметрыСеанса.ТекущийПользователь;
