// гкс+ [10.23] Деснол 18.03.2024
&НаСервере
Процедура гкс_ОтправитьУведомленияНаСервере() Экспорт
	Событие = Константы.гкс_СобытиеПросрочкиМероприятияЕвобланк.Получить();
	Если Не ЗначениеЗаполнено(Событие) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Уведомление не настроено";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	//
	МассивСтрок = Новый Массив();
	КолвоУспех = 0;
	ТекДата = ТекущаяДата();
	Для Каждого СтрокаТЧ Из Объект.МероприятияПоПредупреждению Цикл
		Если Не СтрокаТЧ.Выполнено И СтрокаТЧ.Срок < ТекДата Тогда 
			МассивСтрок.Добавить(Новый Структура("Ответственный,Мероприятие", СтрокаТЧ.Ответственный, СтрокаТЧ.Мероприятие));
		КонецЕсли;
	КонецЦикла;
	Если МассивСтрок.Количество() Тогда 
		ОбМодуль = торо_РаботаСУведомлениями;
		ДокОб = Объект.Ссылка.ПолучитьОбъект();
		СтруктураДанных = Новый Структура();
		торо_РаботаСУведомлениями.ЗаполнитьСтруктуруДанныхДокумента(СтруктураДанных, ДокОб);
		СтруктураДанных.Вставить("ВидДокумента", "гкс_ЕВОБланк");
		Для Каждого СМ Из МассивСтрок Цикл
			СтруктураДанных.Вставить("Ответственный", СМ.Ответственный);
			СтруктураДанных.Вставить("Мероприятие", СМ.Мероприятие);
			ОбМодуль.ЗаписатьУведомленияФМ(СтруктураДанных, Событие);
			КолвоУспех = КолвоУспех + 1;
		КонецЦикла;
	КонецЕсли;
	Если КолвоУспех = 0 Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Нет просроченных мероприятий";
		Сообщение.Сообщить();
	Иначе
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Отправлено уведомлений: " + КолвоУспех;
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры // гкс- [10.23] Деснол 18.03.2024

&НаСервереБезКонтекста
Функция гкс_СтатусНаДоработке(Статус)
	Если Не ЗначениеЗаполнено(Статус) Тогда 
		Возврат Истина;
	КонецЕсли;
	НЗ = РегистрыСведений.гкс_ДополнительныеСвойстваСтатусов.СоздатьНаборЗаписей();
	НЗ.Отбор.Статус.Установить(Статус);
	НЗ.Прочитать();
	Если НЗ.Количество() Тогда 
		Возврат НЗ[0].ЕВОБланкНаДоработке;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

&НаКлиенте
Процедура ОткрытьПоискКорневойПричины(Команда)
	ОпОп = Новый ОписаниеОповещения("СохранитьАнализПричин", ЭтотОбъект);
	ТемпМассив = Новый Массив();
	Для Каждого СТ Из Объект.АнализПричины Цикл
		ТемпСтрукт = Новый Структура("ИД,РодительИД,Причина,КорневаяПричина");
		ЗаполнитьЗначенияСвойств(ТемпСтрукт, СТ);
		ТемпМассив.Добавить(ТемпСтрукт);
	КонецЦикла;
	СтрФормы = Новый Структура("АнализПричины", ТемпМассив);
	ОткрытьФорму("Документ.гкс_ЕВОБланк.Форма.ПоискКорневойПричины", СтрФормы,,,,, ОпОп, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура СохранитьАнализПричин(Результат, ДопПараметры) Экспорт
	Если Не Результат = Неопределено Тогда 
		Объект.АнализПричины.Очистить();
		Для Каждого СМ Из Результат Цикл
			НС = Объект.АнализПричины.Добавить();
			ЗаполнитьЗначенияСвойств(НС, СМ);
			Если СМ.КорневаяПричина Тогда 
				Объект.КорневаяПричинаТекст = СМ.Причина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура гкс_ЗаполнитьСписокУровняОстанова(ЗонаОтветственности, СписокВыбора)
	
	СписокВыбора.Очистить();
	СписокВыбора.Добавить(1, "Остановка производства");
	СписокВыбора.Добавить(2, "Остановка оборудования со снижением производительности");
	СписокВыбора.Добавить(3, "Остановка оборудования без влияния на производство");
	
	Если ЗонаОтветственности = ПредопределенноеЗначение("Перечисление.гкс_ЗоныОтветственности.Производство")
		Или ЗонаОтветственности = ПредопределенноеЗначение("Перечисление.гкс_ЗоныОтветственности.Технология") Тогда 
		СписокВыбора.Добавить(4, "Без остановки производства");
	КонецЕсли;	
		
КонецПроцедуры

