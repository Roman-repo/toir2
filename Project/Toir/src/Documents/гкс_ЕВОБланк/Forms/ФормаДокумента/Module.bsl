&НаКлиенте
Процедура РемонтныеРаботыПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.РемонтныеРаботы.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если ТекДанные.НомерТК = 0 Тогда 
			Элементы.МатЗатраты.ОтборСтрок = Неопределено;
		Иначе
			Элементы.МатЗатраты.ОтборСтрок = Новый ФиксированнаяСтруктура("НомерТК",ТекДанные.НомерТК);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПолучитьАктуальныеДанные()
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	
	ТекСтруктура = Документы.гкс_ЕВОБланк.ПолучитьАктуальнуюСтруктуру(Объект.ДокументОснование, 
		?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Ссылка, Неопределено));
	Завод = ТекСтруктура.Завод;
	Участок = ТекСтруктура.Участок;
	Если ЗначениеЗаполнено(Объект.ВидДефекта) = Ложь Тогда 
		Объект.ВидДефекта = ТекСтруктура.ВидНеисправности;
	КонецЕсли;
	ВидНеисправности = ТекСтруктура.ВидНеисправности;
	Влияние = ТекСтруктура.Влияние;
	ОписаниеПроблемы = ТекСтруктура.ОписаниеПроблемы;
	ОтказавшийЭлемент = ТекСтруктура.ОтказавшийЭлемент;
	ФункциональноеМесто = ТекСтруктура.ФункциональноеМесто;
	ВремяНачалаРаботыТС = ТекСтруктура.ВремяНачалаРаботыТС + (СдвигЧП * 3600);
	ВремяОкончанияРаботыТС = ТекСтруктура.ВремяОкончанияРаботыТС + (СдвигЧП * 3600);
	Объект.ДатаОбнаружения = ТекСтруктура.ДатаОбнаружения;
	//
	МатЗатраты.Загрузить(ТекСтруктура.МатЗатраты);
	Корень = РемонтныеРаботы.ПолучитьЭлементы();
	НоваяСтрока = Корень.Добавить();
	НоваяСтрока.НомерТК = 0;
	НоваяСтрока.ТехКарта = Неопределено;
	Корень = НоваяСтрока.ПолучитьЭлементы();
	Для Каждого СтрокаТаблицы Из ТекСтруктура.РемонтныеРаботы Цикл
		НоваяСтрока = Корень.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьИсториюОборудования(Команда)
	ТекДата = ?(ЗначениеЗаполнено(Объект.Дата),Объект.Дата,ТекущаяДата());
	ПараметрыОтчет = Новый Структура();
	Отборы = Новый Структура();
	Отборы.Вставить("ОбъектРемонта",ФункциональноеМесто);	
	Отборы.Вставить("Период",Новый СтандартныйПериод(НачалоНедели(ТекДата),КонецНедели(ТекДата)));
	ПараметрыОтчет.Вставить("ПараметрыОтбора",Отборы);
	
	ОткрытьФорму("Отчет.торо_ИсторияОстановаЗапускаОборудования.Форма",Новый Структура("ПараметрыОтчета,СформироватьПриОткрытии", ПараметрыОтчет,Истина));

