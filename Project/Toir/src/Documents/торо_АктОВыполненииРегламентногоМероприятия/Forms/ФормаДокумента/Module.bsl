	НайденныеСтрокиМероприятия = Объект.Мероприятия.НайтиСтроки(Новый Структура("ID", РемОборудования ));
	Если НайденныеСтрокиМероприятия.Количество() <> 0 И НайденныеСтрокиМатериала.Количество() = 0 Тогда
