		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СхлопнутыеОграничения.Ограничение КАК Ограничение,
		|	ВсеОР.СтруктураИерархии КАК СтруктураИерархии,
		|	ВсеОР.ОР КАК ОР,
		|	СхлопнутыеОграничения.ФМ КАК ФМ
		|ПОМЕСТИТЬ ОграниченияОР
		|ИЗ
		|	СхлопнутыеОграничения КАК СхлопнутыеОграничения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВсеОР КАК ВсеОР
		|		ПО (СхлопнутыеОграничения.Иерархия = ВсеОР.СтруктураИерархии
		|				ИЛИ СхлопнутыеОграничения.Иерархия = ЗНАЧЕНИЕ(Справочник.торо_СтруктурыОР.ПустаяСсылка))
		|			И (СхлопнутыеОграничения.гкс_Удален = ЛОЖЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.ОбъектРемонта КАК ОбъектРемонта,
		|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.Показатель КАК Показатель,
		|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.Значение КАК Значение,
		|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.ДатаКонтроля КАК ДатаКонтроля
		|ПОМЕСТИТЬ ПоказателиОР
		|ИЗ
		|	РегистрСведений.торо_ЗначенияКонтролируемыхПоказателей.СрезПоследних(
		|			,
		|			ОбъектРемонта В
		|				(ВЫБРАТЬ
		|					ТЧ.ОР
		|				ИЗ
		|					ВсеОР КАК ТЧ)) КАК торо_ЗначенияКонтролируемыхПоказателейСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПоказателиОР.ОбъектРемонта КАК ОбъектРемонта,
		|	ПоказателиОР.Показатель КАК Показатель,
		|	МАКСИМУМ(ПоказателиОР.ДатаКонтроля) КАК ДатаКонтроля
		|ПОМЕСТИТЬ ПоказателиОРМаксимум
		|ИЗ
		|	ПоказателиОР КАК ПоказателиОР
		|
		|СГРУППИРОВАТЬ ПО
		|	ПоказателиОР.ОбъектРемонта,
		|	ПоказателиОР.Показатель
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПоказателиОР.ОбъектРемонта КАК ОбъектРемонта,
		|	ПоказателиОР.Показатель КАК Показатель,
		|	ПоказателиОР.Значение КАК Значение
		|ПОМЕСТИТЬ ПоказателиОРСрез
		|ИЗ
		|	ПоказателиОР КАК ПоказателиОР
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоказателиОРМаксимум КАК ПоказателиОРМаксимум
		|		ПО ПоказателиОР.ОбъектРемонта = ПоказателиОРМаксимум.ОбъектРемонта
		|			И ПоказателиОР.Показатель = ПоказателиОРМаксимум.Показатель
		|			И ПоказателиОР.ДатаКонтроля = ПоказателиОРМаксимум.ДатаКонтроля
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВсеОР.ТОР КАК ТОР,
		|	торо_ТиповыеОРДополнительныеРеквизиты.Свойство КАК Свойство,
		|	торо_ТиповыеОРДополнительныеРеквизиты.Значение КАК Значение,
		|	ВсеОР.ОР КАК ОР
		|ПОМЕСТИТЬ РеквизитыТОР
		|ИЗ
		|	ВсеОР КАК ВсеОР
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ДополнительныеРеквизиты КАК торо_ТиповыеОРДополнительныеРеквизиты
		|		ПО ВсеОР.ТОР = торо_ТиповыеОРДополнительныеРеквизиты.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.ВидСравнения КАК ВидСравнения,
		|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Значение КАК Значение,
		|	ОграниченияОР.ОР КАК ОР,
		|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Характеристика КАК Характеристика,
		|	ОграниченияОР.ФМ КАК ФМ
		|ПОМЕСТИТЬ ОграниченияРеквизиты
		|ИЗ
		|	ОграниченияОР КАК ОграниченияОР
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграничений КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений
		|		ПО ОграниченияОР.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОграниченияОР.ОР КАК ОР,
		|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Характеристика КАК Характеристика,
		|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.ВидСравнения КАК ВидСравнения,
		|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Значение КАК Значение,
		|	ОграниченияОР.ФМ КАК ФМ
		|ПОМЕСТИТЬ ОграниченияПоказатели
		|ИЗ
		|	ОграниченияОР КАК ОграниченияОР
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграниченийПоказатели КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели
		|		ПО ОграниченияОР.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОграниченияРеквизиты.ВидСравнения КАК ВидСравнения,
		|	ОграниченияРеквизиты.Значение КАК План,
		|	ОграниченияРеквизиты.ОР КАК ОР,
		|	РеквизитыТОР.Значение КАК Факт,
		|	РеквизитыТОР.Свойство КАК Свойство,
		|	ОграниченияРеквизиты.ФМ КАК ФМ,
		|	ОграниченияРеквизиты.ФМ.Подразделение КАК Подразделение
		|ИЗ
		|	ОграниченияРеквизиты КАК ОграниченияРеквизиты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РеквизитыТОР КАК РеквизитыТОР
		|		ПО ОграниченияРеквизиты.ОР = РеквизитыТОР.ОР
		|			И ОграниченияРеквизиты.Характеристика = РеквизитыТОР.Свойство
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ОграниченияПоказатели.ВидСравнения,
		|	ОграниченияПоказатели.Значение,
		|	ОграниченияПоказатели.ОР,
		|	ПоказателиОР.Значение,
		|	ПоказателиОР.Показатель,
		|	ОграниченияПоказатели.ФМ,
		|	ОграниченияПоказатели.ФМ.Подразделение
		|ИЗ
		|	ОграниченияПоказатели КАК ОграниченияПоказатели
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоказателиОРСрез КАК ПоказателиОР
		|		ПО ОграниченияПоказатели.Характеристика = ПоказателиОР.Показатель
		|			И ОграниченияПоказатели.ОР = ПоказателиОР.ОбъектРемонта
		|ИТОГИ
		|	МАКСИМУМ(ФМ)
		|ПО
		|	ОР";
	МВТ = Новый МенеджерВременныхТаблиц();
	Результат = ПроверитьОграниченияМассиваОР(,, ЗапросТекст, МВТ);
	
	Если Не Результат = Неопределено Тогда 
		Запрос = Новый Запрос();
		Запрос.МенеджерВременныхТаблиц = МВТ;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЭтиНужноПроверить.Ссылка КАК Ссылка
		|ИЗ
		|	ЭтиНужноПроверить1 КАК ЭтиНужноПроверить
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЭтиНужноПроверить.Док КАК Док
		|ИЗ
		|	ЭтиНужноПроверить2 КАК ЭтиНужноПроверить";
		 РезультатЗапроса = Запрос.ВыполнитьПакет();
		
		Выборка = РезультатЗапроса[0].Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ = 
				РегистрыСведений.торо_ОбъектыДляПроверкиТребованийФМ.СоздатьНаборЗаписей();
			НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Отбор.Объект.Установить(Выборка.Ссылка);
			НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Записать();
		КонецЦикла;
		
		Выборка = РезультатЗапроса[1].Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборЗаписейРегистраторо_ДокументыДляПроверкиТребованийФМ = 
				РегистрыСведений.торо_ДокументыДляПроверкиТребованийФМ.СоздатьНаборЗаписей();
			НаборЗаписейРегистраторо_ДокументыДляПроверкиТребованийФМ.Отбор.ПроверяемыйДокумент.Установить(Выборка.Док);
			НаборЗаписейРегистраторо_ДокументыДляПроверкиТребованийФМ.Записать();
		КонецЦикла;

		//
		Для Каждого СтрокаМассиваНеподходящихОбъектовРемонта Из Результат.НеПодходят Цикл
			СтруктураДанных = Новый Структура("Ссылка,ОбъектРемонта,ТекстТребований,ФМ,ВидДокумента");
			ЗаполнитьЗначенияСвойств(СтруктураДанных, СтрокаМассиваНеподходящихОбъектовРемонта);
			СтруктураДанных.ОбъектРемонта = СтрокаМассиваНеподходящихОбъектовРемонта.Ссылка;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

// Находит функциональное место для объекта ремонта
//
// Параметры:
//  Ссылка - СправочникСсылка.торо_ОбъектыРемонта
Функция НайтиФМ(Ссылка) Экспорт
	Если ЗначениеЗаполнено(Ссылка) = Ложь Тогда 
		Возврат Неопределено;
	КонецЕсли;
	ПоследняяСсылка = Ссылка;
	Иерархия = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
	Запрос = Новый Запрос;
	Пока ЗначениеЗаполнено(ПоследняяСсылка) Цикл
		Если Иерархия.ИзменяетсяДокументами = истина Тогда 
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	1 КАК Приоритет
				|ПОМЕСТИТЬ Уровень1
				|ИЗ
				|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
				|			,
				|			ОбъектИерархии = &Ссылка
				|				И СтруктураИерархии = &Иерархия) КАК РегистрОР
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	2 КАК Приоритет
				|ПОМЕСТИТЬ Уровень2
				|ИЗ
				|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
				|			,
				|			ОбъектИерархии В
				|					(ВЫБРАТЬ
				|						ТЧ.РодительИерархии
				|					ИЗ
				|						Уровень1 КАК ТЧ)
				|				И СтруктураИерархии = &Иерархия) КАК РегистрОР
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	3 КАК Приоритет
				|ПОМЕСТИТЬ Уровень3
				|ИЗ
				|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
				|			,
				|			ОбъектИерархии В
				|					(ВЫБРАТЬ
				|						ТЧ.РодительИерархии
				|					ИЗ
				|						Уровень2 КАК ТЧ)
				|				И СтруктураИерархии = &Иерархия) КАК РегистрОР";
		Иначе
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	1 КАК Приоритет
				|ПОМЕСТИТЬ Уровень1
				|ИЗ
				|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
				|ГДЕ
				|	РегистрОР.ОбъектИерархии = &Ссылка
				|	И РегистрОР.СтруктураИерархии = &Иерархия
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	2 КАК Приоритет
				|ПОМЕСТИТЬ Уровень2
				|ИЗ
				|	Уровень1 КАК Уровень1
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
				|		ПО Уровень1.РодительИерархии = РегистрОР.ОбъектИерархии
				|			И (РегистрОР.СтруктураИерархии = &Иерархия)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	3 КАК Приоритет
				|ПОМЕСТИТЬ Уровень3
				|ИЗ
				|	Уровень2 КАК Уровень1
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
				|		ПО Уровень1.РодительИерархии = РегистрОР.ОбъектИерархии
				|			И (РегистрОР.СтруктураИерархии = &Иерархия)";
		КонецЕсли;
		//
		Запрос.Текст = Запрос.Текст + "
		| ;  "+"ВЫБРАТЬ
		       |	Уровень1.РодительИерархии КАК РодительИерархии,
		       |	Уровень1.ТипОбъекта КАК ТипОбъекта,
		       |	Уровень1.Приоритет КАК Приоритет
		       |ПОМЕСТИТЬ ВсеРодители
		       |ИЗ
		       |	Уровень1 КАК Уровень1
		       |
		       |ОБЪЕДИНИТЬ ВСЕ
		       |
		       |ВЫБРАТЬ
		       |	Уровень2.РодительИерархии,
		       |	Уровень2.ТипОбъекта,
		       |	Уровень2.Приоритет
		       |ИЗ
		       |	Уровень2 КАК Уровень2
		       |
		       |ОБЪЕДИНИТЬ ВСЕ
		       |
		       |ВЫБРАТЬ
		       |	Уровень3.РодительИерархии,
		       |	Уровень3.ТипОбъекта,
		       |	Уровень3.Приоритет
		       |ИЗ
		       |	Уровень3 КАК Уровень3
		       |;
		       |
		       |////////////////////////////////////////////////////////////////////////////////
		       |ВЫБРАТЬ
		       |	ВсеРодители.РодительИерархии КАК РодительИерархии,
		       |	ЕстьNull(ВсеРодители.ТипОбъекта,Ложь) КАК ТипОбъекта,
		       |	ВсеРодители.Приоритет КАК Приоритет
		       |ИЗ
		       |	ВсеРодители КАК ВсеРодители
		       |
		       |УПОРЯДОЧИТЬ ПО
		       |	Приоритет";
		//
		Запрос.УстановитьПараметр("Иерархия", Иерархия);
		Запрос.УстановитьПараметр("Ссылка", ПоследняяСсылка);
		Запрос.УстановитьПараметр("ТипФМ", Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто);
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		ПоследняяСсылка = Неопределено;
		Пока Выборка.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка.РодительИерархии) Тогда 
				ПоследняяСсылка = Выборка.РодительИерархии;
				Если Выборка.ТипОбъекта Тогда 
					ПоследняяСсылка = Неопределено;
					Возврат Выборка.РодительИерархии;
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Находит функциональное место для объекта ремонта
//
// Параметры:
//  Ссылка - СправочникСсылка.торо_ОбъектыРемонта
Функция НайтиТМ(Ссылка) Экспорт
	Если ЗначениеЗаполнено(Ссылка) = Ложь Тогда 
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ТекущиеФМОР.ТМ КАК ТМ
		|ИЗ
		|	РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
		|ГДЕ
		|	гкс_ТекущиеФМОР.ОР = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.ТМ;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

// Проецирует техническое место Объекта ремонта на подчиненные Объекты ремонта
//
// Параметры:
//  Ссылка - СправочникСсылка.торо_ОбъектыРемонта
//  ИсточникПодчиненных - СправочникСсылка.торо_ОбъектыРемонта - Объект ремонта, подчиненные которого нужно обновить
Процедура ПроецироватьТКНаПодчиненных(Ссылка, ИсточникПодчиненных = Неопределено)Экспорт
	Если ЗначениеЗаполнено(Ссылка) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ТекущиеФМОР.ФМ КАК ФМ,
		|	гкс_ТекущиеФМОР.ТМ КАК ТМ,
		|	гкс_ТекущиеФМОР.ТМФМ КАК ТМФМ
		|ИЗ
		|	РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
		|ГДЕ
		|	гкс_ТекущиеФМОР.ОР = &Ссылка
		|	И гкс_ТекущиеФМОР.ФМ = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ТекущееФункциональноеМесто = Выборка.ТМ;
		//
		Иерархия = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
		ПоследняяСсылка = Новый Массив();
		Если ИсточникПодчиненных = Неопределено Тогда 
			ПоследняяСсылка.Добавить(Ссылка);
		Иначе
			ПоследняяСсылка.Добавить(ИсточникПодчиненных);
		КонецЕсли;
		Пока ПоследняяСсылка.Количество() Цикл
			Если Иерархия.ИзменяетсяДокументами = истина Тогда 
				Запрос.Текст = 
					"ВЫБРАТЬ
					|	1 КАК Приоритет,
					|	РегистрОР.ОбъектИерархии КАК ОбъектИерархии
					|ПОМЕСТИТЬ Уровень1
					|ИЗ
					|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(, СтруктураИерархии = &Иерархия) КАК РегистрОР
					|ГДЕ
					|	РегистрОР.РодительИерархии В(&Ссылка)
					|	И НЕ РегистрОР.ОбъектИерархии.ТипОбъекта = &ТипФМ
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	2 КАК Приоритет,
					|	РегистрОР.ОбъектИерархии КАК ОбъектИерархии
					|ПОМЕСТИТЬ Уровень2
					|ИЗ
					|	Уровень1 КАК Уровень1
					|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(, СтруктураИерархии = &Иерархия) КАК РегистрОР
					|		ПО Уровень1.ОбъектИерархии = РегистрОР.РодительИерархии
					|			И (НЕ РегистрОР.ОбъектИерархии.ТипОбъекта = &ТипФМ)
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	3 КАК Приоритет,
					|	РегистрОР.ОбъектИерархии КАК ОбъектИерархии
					|ПОМЕСТИТЬ Уровень3
					|ИЗ
					|	Уровень2 КАК Уровень2
					|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(, СтруктураИерархии = &Иерархия) КАК РегистрОР
					|		ПО Уровень2.ОбъектИерархии = РегистрОР.РодительИерархии
					|			И (НЕ РегистрОР.ОбъектИерархии.ТипОбъекта = &ТипФМ)";
			Иначе
				Запрос.Текст = 
					"ВЫБРАТЬ
					|	1 КАК Приоритет,
					|	РегистрОР.ОбъектИерархии КАК ОбъектИерархии
					|ПОМЕСТИТЬ Уровень1
					|ИЗ
					|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
					|ГДЕ
					|	РегистрОР.РодительИерархии В(&Ссылка)
					|	И НЕ РегистрОР.ОбъектИерархии.ТипОбъекта = &ТипФМ
					|	И РегистрОР.СтруктураИерархии = &Иерархия
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	2 КАК Приоритет,
					|	РегистрОР.ОбъектИерархии КАК ОбъектИерархии
					|ПОМЕСТИТЬ Уровень2
					|ИЗ
					|	Уровень1 КАК Уровень1
					|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
					|		ПО Уровень1.ОбъектИерархии = РегистрОР.РодительИерархии
					|			И (РегистрОР.СтруктураИерархии = &Иерархия)
					|			И (НЕ РегистрОР.ОбъектИерархии.ТипОбъекта = &ТипФМ)
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	3 КАК Приоритет,
					|	РегистрОР.ОбъектИерархии КАК ОбъектИерархии
					|ПОМЕСТИТЬ Уровень3
					|ИЗ
					|	Уровень2 КАК Уровень2
					|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
					|		ПО Уровень2.ОбъектИерархии = РегистрОР.РодительИерархии
					|			И (НЕ РегистрОР.ОбъектИерархии.ТипОбъекта = &ТипФМ)
					|			И (РегистрОР.СтруктураИерархии = &Иерархия)";
			КонецЕсли;
			//
			Запрос.Текст = Запрос.Текст + "
			| ;  "+"ВЫБРАТЬ
			       |	Уровень1.ОбъектИерархии КАК ОбъектИерархии,
			       |	Уровень1.Приоритет КАК Приоритет
			       |ПОМЕСТИТЬ ВсеРодители
			       |ИЗ
			       |	Уровень1 КАК Уровень1
			       |
			       |ОБЪЕДИНИТЬ ВСЕ
			       |
			       |ВЫБРАТЬ
			       |	Уровень2.ОбъектИерархии,
			       |	Уровень2.Приоритет
			       |ИЗ
			       |	Уровень2 КАК Уровень2
			       |
			       |ОБЪЕДИНИТЬ ВСЕ
			       |
			       |ВЫБРАТЬ
			       |	Уровень3.ОбъектИерархии,
			       |	Уровень3.Приоритет
			       |ИЗ
			       |	Уровень3 КАК Уровень3
			       |;
			       |
			       |////////////////////////////////////////////////////////////////////////////////
			       |ВЫБРАТЬ
			       |	ВсеРодители.ОбъектИерархии КАК ОР,
				   |	ВсеРодители.ОбъектИерархии.ЭтоГруппа КАК ЭтоГруппа,
			       |	ВсеРодители.Приоритет КАК Приоритет
			       |ИЗ
			       |	ВсеРодители КАК ВсеРодители
			       |
			       |УПОРЯДОЧИТЬ ПО
			       |	Приоритет";
			//
			Запрос.УстановитьПараметр("Иерархия", Иерархия);
			Запрос.УстановитьПараметр("Ссылка", ПоследняяСсылка);
			Запрос.УстановитьПараметр("ТипФМ", Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто);
			РезультатЗапроса = Запрос.Выполнить();
			Выборка = РезультатЗапроса.Выбрать();
			ПоследняяСсылка = Новый Массив();
			Пока Выборка.Следующий() Цикл
				Если Выборка.ЭтоГруппа = Ложь Тогда 
					УстановитьТКФМ(Выборка.ОР,Ссылка,ТекущееФункциональноеМесто);
				КонецЕсли;
				Если Выборка.Приоритет = 3 Тогда 
					ПоследняяСсылка.Добавить(Выборка.ОР);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьТКФМ(Ссылка, ФункциональноеМесто, ТехническоеМестоФункциональногоМеста)
	Если ЗначениеЗаполнено(Ссылка) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ТекущиеФМОР.ФМ КАК ФМ,
		|	гкс_ТекущиеФМОР.ТМ КАК ТМ,
		|	гкс_ТекущиеФМОР.ТМФМ КАК ТМФМ
		|ИЗ
		|	РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
		|ГДЕ
		|	гкс_ТекущиеФМОР.ОР = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Ссылка);
		НоваяСтрокаНабораЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
		НоваяСтрокаНабораЗаписей.ОР = Ссылка;
		НоваяСтрокаНабораЗаписей.ФМ = ФункциональноеМесто;
		НоваяСтрокаНабораЗаписей.ТМ = Неопределено;
		НоваяСтрокаНабораЗаписей.ТМФМ = ТехническоеМестоФункциональногоМеста;
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		//
		НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Ссылка);
		НоваяСтрокаНабораЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
		НоваяСтрокаНабораЗаписей.ОР = Ссылка;
		НоваяСтрокаНабораЗаписей.ФМ = ФункциональноеМесто;
		НоваяСтрокаНабораЗаписей.ТМ = Выборка.ТМ;
		НоваяСтрокаНабораЗаписей.ТМФМ = ТехническоеМестоФункциональногоМеста;
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
	КонецЕсли;
КонецПроцедуры

// Обновляет запись в регистре текущих функциональных мест для Объекта ремонта
//
// Параметры:
//  Ссылка - СправочникСсылка.торо_ОбъектыРемонта
//  ЭтоФункциональноеМесто - Булево - Обновляется функциональное место
Процедура ОбновитьТекущийФМОР(Ссылка, ЭтоФункциональноеМесто)Экспорт
	Если ЗначениеЗаполнено(Ссылка) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	//
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ТекущиеФМОР.ФМ КАК ФМ,
		|	гкс_ТекущиеФМОР.ТМ КАК ТМ,
		|	гкс_ТекущиеФМОР.ТМФМ КАК ТМФМ
		|ИЗ
		|	РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
		|ГДЕ
		|	гкс_ТекущиеФМОР.ОР = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда
		НужноПроецировать = Ложь; ТекущееФункциональноеМесто = Неопределено;
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Ссылка);
		НоваяСтрокаНабораЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
		НоваяСтрокаНабораЗаписей.ОР = Ссылка;
		Если ЭтоФункциональноеМесто Тогда 
			НоваяСтрокаНабораЗаписей.ФМ = Ссылка;
			ТекущееФункциональноеМесто = Ссылка;
			Если Не Выборка.ФМ = Ссылка Тогда 
				НужноПроецировать = Истина;
			КонецЕсли;
		Иначе
			Если Выборка.ФМ = Ссылка Тогда 
				НоваяСтрокаНабораЗаписей.ФМ = НайтиФМ(Ссылка);
				ТекущееФункциональноеМесто = НоваяСтрокаНабораЗаписей.ФМ;
				НоваяСтрокаНабораЗаписей.ТМФМ = НайтиТМ(ТекущееФункциональноеМесто);
				НужноПроецировать = Истина;
			Иначе
				НоваяСтрокаНабораЗаписей.ФМ = Выборка.ФМ;
				НоваяСтрокаНабораЗаписей.ТМФМ = Выборка.ТМФМ;
			КонецЕсли;
			
		КонецЕсли;
		НоваяСтрокаНабораЗаписей.ТМ = Выборка.ТМ;
		
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
		Если НужноПроецировать Тогда 
			ПроецироватьТКНаПодчиненных(ТекущееФункциональноеМесто, Ссылка);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// Обновляет запись в регистре текущих функциональных мест для Объекта ремонта
//
// Параметры:
//  Ссылка - СправочникСсылка.торо_ОбъектыРемонта
Процедура ОбновитьТекущийОР(Ссылка)Экспорт
	Если ЗначениеЗаполнено(Ссылка) = Ложь Тогда 
		Возврат;
	ИначеЕсли СтрНайти(Строка(Ссылка),"<Объект не найден>") > 0 Тогда 
		Возврат;
	КонецЕсли;
	//
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОбъектыРемонта.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.Ссылка = &Ссылка
		|	И торо_ОбъектыРемонта.ТипОбъекта = &ТипФМ";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ТипФМ", Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой()Тогда
		ТекущееФункциональноеМесто = НайтиФМ(Ссылка);
		
		НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Ссылка);
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Прочитать();
		Если НаборЗаписейРегистрагкс_ТекущиеФМОР.Количество() Тогда 
			ИндексПервойЗаписиНабораЗаписей = 0;
			НоваяСтрокаНаборЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР[ИндексПервойЗаписиНабораЗаписей];
			Если НоваяСтрокаНаборЗаписей.ФМ = ТекущееФункциональноеМесто Тогда 
				Возврат;
			КонецЕсли;
		Иначе
			НоваяСтрокаНаборЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
			НоваяСтрокаНаборЗаписей.ОР = Ссылка;
			НоваяСтрокаНаборЗаписей.ТМ = Неопределено;
		КонецЕсли;
		НоваяСтрокаНаборЗаписей.ФМ = ТекущееФункциональноеМесто;
		ТехническоеМестоФункциональногоМеста = НайтиТМ(ТекущееФункциональноеМесто);
		НоваяСтрокаНаборЗаписей.ТМФМ = ТехническоеМестоФункциональногоМеста;
		НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
		//
		ПроецироватьТКНаПодчиненных(ТекущееФункциональноеМесто, Ссылка);
	КонецЕсли;
КонецПроцедуры