// Проверяет какие объекты ремонта на соответствие требованиям функционального места
//
// Параметры:
//  МассивОР - Массив
//  ФМ - СправочникСсылка.торо_ОбъектыРемонта
//  ТекстЗапроса - Строка
//  МВТ - МенеджерВременныхТаблиц
//  Иерархия - СправочникСсылка.торо_СтруктурыОР
Функция ПроверитьОграниченияМассиваОР(МассивОР = Неопределено, 
							ФункциональноеМесто = Неопределено, ТекстЗапроса = "",
							МВТ = Неопределено, Иерархия = Неопределено)Экспорт
			
	СтрРезультат = Новый Структура("Подходят,НеПодходят",Новый Массив(),Новый Массив());
	
	
	Запрос = Новый Запрос;
	Если не МВТ = Неопределено Тогда 
		Запрос.МенеджерВременныхТаблиц = МВТ;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТекстЗапроса) Тогда 
		Запрос.Текст = ТекстЗапроса;
	Иначе
		Если ЗначениеЗаполнено(ФункциональноеМесто) Тогда 
			Если ТипЗнч(ФункциональноеМесто) = Тип("Массив") Тогда 
				Запрос.Текст = 
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	торо_ОбъектыРемонта.Ссылка КАК ФМ,
					|	торо_ОбъектыРемонта.ТиповойОР КАК ТОР
					|ПОМЕСТИТЬ ФМТОР
					|ИЗ
					|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
					|ГДЕ
					|	торо_ОбъектыРемонта.Ссылка В (&Ссылка)"+"
					|;
					|
					|";
			Иначе
				Запрос.Текст = 
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	торо_ОбъектыРемонта.Ссылка КАК ФМ,
					|	торо_ОбъектыРемонта.ТиповойОР КАК ТОР
					|ПОМЕСТИТЬ ФМТОР
					|ИЗ
					|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
					|ГДЕ
					|	торо_ОбъектыРемонта.Ссылка = &Ссылка"+"
					|;
					|
					|";
			КонецЕсли;
		Иначе
			Запрос.Текст = 
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	торо_ОбъектыРемонта.Ссылка КАК ФМ,
					|	торо_ОбъектыРемонта.ТиповойОР КАК ТОР
					|ПОМЕСТИТЬ ФМТОР
					|ИЗ
					|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
					|ГДЕ
					|	торо_ОбъектыРемонта.ТипОбъекта = ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто)"+"
					|;
					|
					|";
		КонецЕсли;
			Запрос.Текст =  Запрос.Текст +"ВЫБРАТЬ
			                              |	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ограничение КАК Ограничение,
			                              |	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Иерархия КАК Иерархия,
			                              |	ФМТОР.ФМ КАК ФМ,
			                              |	ЛОЖЬ КАК гкс_Удален
			                              |ПОМЕСТИТЬ ВсеОграничения
			                              |ИЗ
			                              |	ФМТОР КАК ФМТОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ОграниченияНаХарактеристикиОборудования КАК торо_ТиповыеОРОграниченияНаХарактеристикиОборудования
			                              |		ПО ФМТОР.ТОР = торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ссылка
			                              |
			                              |ОБЪЕДИНИТЬ ВСЕ
			                              |
			                              |ВЫБРАТЬ РАЗЛИЧНЫЕ
			                              |	торо_ОграниченияНаХарактеристикиОборудования.Ограничение,
			                              |	торо_ОграниченияНаХарактеристикиОборудования.Иерархия,
			                              |	ФМТОР.ФМ,
			                              |	торо_ОграниченияНаХарактеристикиОборудования.гкс_Удален
			                              |ИЗ
			                              |	ФМТОР КАК ФМТОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОграниченияНаХарактеристикиОборудования КАК торо_ОграниченияНаХарактеристикиОборудования
			                              |		ПО ФМТОР.ФМ = торо_ОграниченияНаХарактеристикиОборудования.ФункциональноеМесто
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ
			                              |	ВсеОграничения.Ограничение КАК Ограничение,
			                              |	ВсеОграничения.Иерархия КАК Иерархия,
			                              |	ВсеОграничения.ФМ КАК ФМ,
			                              |	МАКСИМУМ(ВсеОграничения.гкс_Удален) КАК гкс_Удален
			                              |ПОМЕСТИТЬ СхлопнутыеОграничения
			                              |ИЗ
			                              |	ВсеОграничения КАК ВсеОграничения
			                              |
			                              |СГРУППИРОВАТЬ ПО
			                              |	ВсеОграничения.Ограничение,
			                              |	ВсеОграничения.Иерархия,
			                              |	ВсеОграничения.ФМ
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ РАЗЛИЧНЫЕ
			                              |	РегистрОР.ОбъектИерархии КАК ОР,
			                              |	РегистрОР.СтруктураИерархии КАК СтруктураИерархии,
			                              |	РегистрОР.ОбъектИерархии.ТиповойОР КАК ТОР,
			                              |	РегистрОР.РодительИерархии КАК ФМ
			                              |ПОМЕСТИТЬ ВсеОР
			                              |ИЗ
			                              |	ФМТОР КАК ФМТОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
			                              |		ПО ФМТОР.ФМ = РегистрОР.РодительИерархии
			                              |			И (&ОтборОР)
			                              |			И (РегистрОР.СтруктураИерархии = &Иерархия)
			                              |
			                              |ОБЪЕДИНИТЬ ВСЕ
			                              |
			                              |ВЫБРАТЬ
			                              |	РегистрОР.ОбъектИерархии,
			                              |	РегистрОР.СтруктураИерархии,
			                              |	РегистрОР.ОбъектИерархии.ТиповойОР,
			                              |	РегистрОР.РодительИерархии
			                              |ИЗ
			                              |	ФМТОР КАК ФМТОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(, ) КАК РегистрОР
			                              |		ПО ФМТОР.ФМ = РегистрОР.РодительИерархии
			                              |			И (РегистрОР.Удален = ЛОЖЬ)
			                              |			И (&ОтборОР)
			                              |			И (РегистрОР.СтруктураИерархии = &Иерархия)
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ РАЗЛИЧНЫЕ
			                              |	СхлопнутыеОграничения.Ограничение КАК Ограничение,
			                              |	ВсеОР.СтруктураИерархии КАК СтруктураИерархии,
			                              |	ВсеОР.ОР КАК ОР,
			                              |	СхлопнутыеОграничения.ФМ КАК ФМ
			                              |ПОМЕСТИТЬ ОграниченияОР
			                              |ИЗ
			                              |	СхлопнутыеОграничения КАК СхлопнутыеОграничения
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВсеОР КАК ВсеОР
			                              |		ПО (СхлопнутыеОграничения.Иерархия = ВсеОР.СтруктураИерархии
			                              |				ИЛИ СхлопнутыеОграничения.Иерархия = ЗНАЧЕНИЕ(Справочник.торо_СтруктурыОР.ПустаяСсылка))
			                              |			И (СхлопнутыеОграничения.гкс_Удален = ЛОЖЬ)
			                              |			И (ВсеОР.ФМ = СхлопнутыеОграничения.ФМ)
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ РАЗЛИЧНЫЕ
			                              |	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.ОбъектРемонта КАК ОбъектРемонта,
			                              |	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.Показатель КАК Показатель,
			                              |	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.Значение КАК Значение,
			                              |	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.ДатаКонтроля КАК ДатаКонтроля
			                              |ПОМЕСТИТЬ ПоказателиОР
			                              |ИЗ
			                              |	РегистрСведений.торо_ЗначенияКонтролируемыхПоказателей.СрезПоследних(
			                              |			,
			                              |			ОбъектРемонта В
			                              |				(ВЫБРАТЬ
			                              |					ТЧ.ОР
			                              |				ИЗ
			                              |					ВсеОР КАК ТЧ)) КАК торо_ЗначенияКонтролируемыхПоказателейСрезПоследних
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ
			                              |	ПоказателиОР.ОбъектРемонта КАК ОбъектРемонта,
			                              |	ПоказателиОР.Показатель КАК Показатель,
			                              |	МАКСИМУМ(ПоказателиОР.ДатаКонтроля) КАК ДатаКонтроля
			                              |ПОМЕСТИТЬ ПоказателиОРМаксимум
			                              |ИЗ
			                              |	ПоказателиОР КАК ПоказателиОР
			                              |
			                              |СГРУППИРОВАТЬ ПО
			                              |	ПоказателиОР.ОбъектРемонта,
			                              |	ПоказателиОР.Показатель
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ
			                              |	ПоказателиОР.ОбъектРемонта КАК ОбъектРемонта,
			                              |	ПоказателиОР.Показатель КАК Показатель,
			                              |	ПоказателиОР.Значение КАК Значение
			                              |ПОМЕСТИТЬ ПоказателиОРСрез
			                              |ИЗ
			                              |	ПоказателиОР КАК ПоказателиОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоказателиОРМаксимум КАК ПоказателиОРМаксимум
			                              |		ПО ПоказателиОР.ОбъектРемонта = ПоказателиОРМаксимум.ОбъектРемонта
			                              |			И ПоказателиОР.Показатель = ПоказателиОРМаксимум.Показатель
			                              |			И ПоказателиОР.ДатаКонтроля = ПоказателиОРМаксимум.ДатаКонтроля
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ РАЗЛИЧНЫЕ
			                              |	ВсеОР.ТОР КАК ТОР,
			                              |	торо_ТиповыеОРДополнительныеРеквизиты.Свойство КАК Свойство,
			                              |	торо_ТиповыеОРДополнительныеРеквизиты.Значение КАК Значение,
			                              |	ВсеОР.ОР КАК ОР
			                              |ПОМЕСТИТЬ РеквизитыТОР
			                              |ИЗ
			                              |	ВсеОР КАК ВсеОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ДополнительныеРеквизиты КАК торо_ТиповыеОРДополнительныеРеквизиты
			                              |		ПО ВсеОР.ТОР = торо_ТиповыеОРДополнительныеРеквизиты.Ссылка
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ РАЗЛИЧНЫЕ
			                              |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.ВидСравнения КАК ВидСравнения,
			                              |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Значение КАК Значение,
			                              |	ОграниченияОР.ОР КАК ОР,
			                              |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Характеристика КАК Характеристика
			                              |ПОМЕСТИТЬ ОграниченияРеквизиты1
			                              |ИЗ
			                              |	ОграниченияОР КАК ОграниченияОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграничений КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений
			                              |		ПО ОграниченияОР.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Ссылка
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ
			                              |	ОграниченияРеквизиты.ВидСравнения КАК ВидСравнения,
			                              |	ОграниченияРеквизиты.Значение КАК Значение,
			                              |	ОграниченияРеквизиты.ОР КАК ОР,
			                              |	ЕСТЬNULL(торо_ГруппыХарактеристикОборудованияСписокХарактеристик.Характеристика, ОграниченияРеквизиты.Характеристика) КАК Характеристика
			                              |ПОМЕСТИТЬ ОграниченияРеквизиты
			                              |ИЗ
			                              |	ОграниченияРеквизиты1 КАК ОграниченияРеквизиты
			                              |		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.торо_ГруппыХарактеристикОборудования.СписокХарактеристик КАК торо_ГруппыХарактеристикОборудованияСписокХарактеристик
			                              |		ПО ОграниченияРеквизиты.Характеристика = торо_ГруппыХарактеристикОборудованияСписокХарактеристик.Ссылка
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ РАЗЛИЧНЫЕ
			                              |	ОграниченияОР.ОР КАК ОР,
			                              |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Характеристика КАК Характеристика,
			                              |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.ВидСравнения КАК ВидСравнения,
			                              |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Значение КАК Значение
			                              |ПОМЕСТИТЬ ОграниченияПоказатели
			                              |ИЗ
			                              |	ОграниченияОР КАК ОграниченияОР
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграниченийПоказатели КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели
			                              |		ПО ОграниченияОР.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Ссылка
			                              |;
			                              |
			                              |////////////////////////////////////////////////////////////////////////////////
			                              |ВЫБРАТЬ
			                              |	ОграниченияРеквизиты.ВидСравнения КАК ВидСравнения,
			                              |	ОграниченияРеквизиты.Значение КАК План,
			                              |	ОграниченияРеквизиты.ОР КАК ОР,
			                              |	РеквизитыТОР.Значение КАК Факт,
			                              |	РеквизитыТОР.Свойство КАК Свойство
			                              |ИЗ
			                              |	ОграниченияРеквизиты КАК ОграниченияРеквизиты
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РеквизитыТОР КАК РеквизитыТОР
			                              |		ПО ОграниченияРеквизиты.ОР = РеквизитыТОР.ОР
			                              |			И ОграниченияРеквизиты.Характеристика = РеквизитыТОР.Свойство
			                              |
			                              |ОБЪЕДИНИТЬ ВСЕ
			                              |
			                              |ВЫБРАТЬ
			                              |	ОграниченияПоказатели.ВидСравнения,
			                              |	ОграниченияПоказатели.Значение,
			                              |	ОграниченияПоказатели.ОР,
			                              |	ПоказателиОР.Значение,
			                              |	ПоказателиОР.Показатель
			                              |ИЗ
			                              |	ОграниченияПоказатели КАК ОграниченияПоказатели
			                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоказателиОРСрез КАК ПоказателиОР
			                              |		ПО ОграниченияПоказатели.Характеристика = ПоказателиОР.Показатель
			                              |			И ОграниченияПоказатели.ОР = ПоказателиОР.ОбъектРемонта
			                              |ИТОГИ ПО
			                              |	ОР";
		КонецЕсли;
		
	Если ЗначениеЗаполнено(ФункциональноеМесто) Тогда 
		Запрос.УстановитьПараметр("Ссылка", ФункциональноеМесто);
	КонецЕсли;
	Если Не МассивОР = Неопределено Тогда 
		Запрос.УстановитьПараметр("МассивОР", МассивОР);
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"&ОтборОР","РегистрОР.ОбъектИерархии В (&МассивОР)");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И (&ОтборОР)","");
		Запрос.УстановитьПараметр("ОтборОР", Истина);
	КонецЕсли;
	Если Иерархия = Неопределено Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"РегистрОР.СтруктураИерархии = &Иерархия","Истина");
	Иначе
		Запрос.УстановитьПараметр("Иерархия", Иерархия);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		НеПодходит = Ложь;
		ТекстТребований = "";
		Выборка1 = Выборка.Выбрать();
		Пока Выборка1.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка1.Свойство)=Ложь Тогда 
				Продолжить;
			КонецЕсли;
			ТипФакта = ТипЗнч(Выборка1.Факт);
			ТипПлана = ТипЗнч(Выборка1.План);
			Если Не ТипФакта = ТипПлана Тогда 
				Продолжить;
			КонецЕсли;
			Если Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.Равно Тогда 
				Если Не Выборка1.План = Выборка1.Факт Тогда 
					НеПодходит = Истина;
					ТекстТребований = ТекстТребований + Выборка1.Свойство + " Равно " + Выборка1.План +"(сейчас "+Выборка1.Факт+")";
					//Прервать;
				КонецЕсли;
			ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.НеРавно Тогда 
				Если Выборка1.План = Выборка1.Факт Тогда 
					НеПодходит = Истина;
					ТекстТребований = ТекстТребований + Выборка1.Свойство + " Не равно " + Выборка1.План+"(сейчас "+Выборка1.Факт+")";
					//Прервать;
				КонецЕсли;
			ИначеЕсли ТипФакта = Тип("Число") ИЛИ ТипФакта = Тип("Дата") Тогда 
				Если Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.Больше Тогда 
					Если Выборка1.План >= Выборка1.Факт Тогда 
						НеПодходит = Истина;
						ТекстТребований = ТекстТребований + Выборка1.Свойство + " Больше " + Выборка1.План+"(сейчас "+Выборка1.Факт+")";
						//Прервать;
					КонецЕсли;
				ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.БольшеИлиРавно Тогда 
					Если Выборка1.План > Выборка1.Факт Тогда 
						НеПодходит = Истина;
						ТекстТребований = ТекстТребований + Выборка1.Свойство + " Больше или равно " + Выборка1.План+"(сейчас "+Выборка1.Факт+")";
						//Прервать;
					КонецЕсли;
				ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.Меньше Тогда 
					Если Выборка1.План <= Выборка1.Факт Тогда 
						НеПодходит = Истина;
						ТекстТребований = ТекстТребований + Выборка1.Свойство + " Меньше " + Выборка1.План+"(сейчас "+Выборка1.Факт+")";
						//Прервать;
					КонецЕсли;
				ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.МеньшеИлиРавно Тогда 
					Если Выборка1.План < Выборка1.Факт Тогда 
						НеПодходит = Истина;
						ТекстТребований = ТекстТребований + Выборка1.Свойство + " Меньше или равно " + Выборка1.План+"(сейчас "+Выборка1.Факт+")";
						//Прервать;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Если НеПодходит Тогда 
			ВременнаяСтруктура = Новый Структура("Ссылка, ТекстТребований, ФМ, Подразделение");
			ЗаполнитьЗначенияСвойств(ВременнаяСтруктура,Выборка);
			ВременнаяСтруктура.ТекстТребований = ТекстТребований;
			ВременнаяСтруктура.Ссылка = Выборка.ОР;
			СтрРезультат.НеПодходят.Добавить(ВременнаяСтруктура);
			
		Иначе
			СтрРезультат.Подходят.Добавить(Выборка.ОР);
		КонецЕсли;
	КонецЦикла;
	Возврат СтрРезультат;
КонецФункции

// Проверяет наличие оборудования на функциональных местах
