			,,	НСтр("es='¡La instalación de los índices básicos de la elaboración no es cumplida! Por la causa: ';ru='Установка основных показателей наработки не выполнена! По причине: ';en='Setting the key operating indicators has not been completed! Due to: '")+ОписаниеОшибки);
