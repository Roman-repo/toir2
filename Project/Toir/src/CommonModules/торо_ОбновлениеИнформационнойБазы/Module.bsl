	ДокВТранзакции = 50;
	Счетчик = 0;
	ОшибкаВТранзакции = Ложь;
	
	Попытка
		
		Пока Выборка.Следующий() Цикл
			Если НЕ ТранзакцияАктивна() Тогда
				НачатьТранзакцию();
