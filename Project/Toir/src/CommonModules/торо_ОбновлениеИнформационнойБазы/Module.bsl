Процедура УдалениеИДКорректировок_РегистрПлановыеМероприятия() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ПлановыеМероприятия.Регистратор КАК Регистратор,
	|	торо_ПлановыеМероприятия.ID КАК ID,
	|	МАКСИМУМ(торо_ПлановыеМероприятия.НомерСтроки) КАК НомерСтроки,
	|	МАКСИМУМ(торо_ПлановыеМероприятия.Период) КАК ПериодМаксимум,
	|	МИНИМУМ(торо_ПлановыеМероприятия.Период) КАК ПериодМинимум,
	|	КОЛИЧЕСТВО(торо_ПлановыеМероприятия.Удалить_ID_Корректировок) КАК КоличествоКорректировок
	|ИЗ
	|	РегистрСведений.торо_ПлановыеМероприятия КАК торо_ПлановыеМероприятия
	|
	|СГРУППИРОВАТЬ ПО
	|	торо_ПлановыеМероприятия.Регистратор,
	|	торо_ПлановыеМероприятия.ID
	|ИТОГИ
	|	МАКСИМУМ(КоличествоКорректировок)
	|ПО
	|	Регистратор";
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ДокВТранзакции = 50;
	Счетчик = 0;
	ОшибкаВТранзакции = Ложь;
	
	Попытка
		
		Пока Выборка.Следующий() Цикл
			Если НЕ ТранзакцияАктивна() Тогда
				НачатьТранзакцию();
			КонецЕсли;
			
			НужнаЗапись = Ложь;
			
			НаборЗаписей = РегистрыСведений.торо_ПлановыеМероприятия.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Регистратор);
			НаборЗаписей.Прочитать();
			
			Для каждого Запись из НаборЗаписей Цикл
				Если ЗначениеЗаполнено(Запись.Удалить_ID_Корректировок) Тогда
					Запись.Удалить_ID_Корректировок = "";
					НужнаЗапись = Истина;
				КонецЕсли;
				Если ЗначениеЗаполнено(Запись.УдалитьПодразделение) Тогда
					Запись.Подразделение = Запись.УдалитьПодразделение;
					Запись.УдалитьПодразделение = Неопределено;
					НужнаЗапись = Истина;
				КонецЕсли;
			КонецЦикла;
			
			Если Выборка.КоличествоКорректировок > 1 Тогда
				
				СтрокиКУдалению = Новый Массив;
				
				ВыборкаИД = Выборка.Выбрать(ОбходРезультатаЗапроса.Прямой);
				Пока ВыборкаИД.Следующий() Цикл
					Если ВыборкаИД.КоличествоКорректировок > 1 Тогда
						ПроверятьПоДате =  ВыборкаИД.ПериодМаксимум <> ВыборкаИД.ПериодМинимум;
						
						Для каждого Запись из НаборЗаписей Цикл
							Если Запись.ID <> ВыборкаИД.ID Тогда
								Продолжить;	
							КонецЕсли;
							
							Если (ПроверятьПоДате И Запись.Период <> ВыборкаИД.ПериодМаксимум)
								ИЛИ (НЕ ПроверятьПоДате И Запись.НомерСтроки <> ВыборкаИД.НомерСтроки) Тогда
								СтрокиКУдалению.Добавить(Запись);
								НужнаЗапись = Истина;
							КонецЕсли;
						КонецЦикла;
						
					КонецЕсли;
				КонецЦикла;
				
				Для каждого СтрокаКУдалению из СтрокиКУдалению Цикл
					НаборЗаписей.Удалить(СтрокаКУдалению);
				КонецЦикла;
				
			КонецЕсли;
			
			Если НужнаЗапись Тогда
				НаборЗаписей.Записать(Истина);
			КонецЕсли;
			
			Счетчик = Счетчик + 1;
			Если Счетчик = ДокВТранзакции Тогда
				ЗафиксироватьТранзакцию();
				Счетчик = 0;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ТранзакцияАктивна() Тогда
			ЗафиксироватьТранзакцию();
		КонецЕсли;
		
	Исключение
		ОшибкаВТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка,
			,,	НСтр("es='¡La renovación del registro ""las medidas Planificadas"" no es cumplida! Por la causa: ';ru='Обновление регистра ""Плановые мероприятия"" не выполнено! По причине: ';en='Register update for ""Planned events"" failed! Due to: '")+ОписаниеОшибки);
	КонецПопытки;
	
	Если ТранзакцияАктивна() И ОшибкаВТранзакции Тогда
		ОтменитьТранзакцию();
	КонецЕсли;
	
КонецПроцедуры

