		// Годовой
		ВидПлана = Справочники.торо_ВидыСкользящихПланов.Годовой.ПолучитьОбъект();
		ВидПлана.Использование             = Истина;
		ВидПлана.ПериодичностьПланирования = Перечисления.Периодичность.Год;
		ВидПлана.ЧислоОтображаемыхПериодов = 2;
		ВидПлана.ТочностьПланирования      = Перечисления.торо_ДетализацияПлана.Неделя;
		ВидПлана.ВидИсполнителяРабот       = Перечисления.торо_ДетализацияИсполнителя.Подразделение;
		
		ВидПлана.Записать();

		// Среднесрочный
		ВидПлана = Справочники.торо_ВидыСкользящихПланов.Среднесрочный.ПолучитьОбъект();
		ВидПлана.Использование             = Истина;
		ВидПлана.ПериодичностьПланирования = Перечисления.Периодичность.Месяц;
		ВидПлана.ЧислоОтображаемыхПериодов = 3;
		ВидПлана.ТочностьПланирования      = Перечисления.торо_ДетализацияПлана.Неделя;
		ВидПлана.ВидИсполнителяРабот       = Перечисления.торо_ДетализацияИсполнителя.Бригада;

		ВидПлана.Записать();

		// Оперативный
		ВидПлана = Справочники.торо_ВидыСкользящихПланов.Оперативный.ПолучитьОбъект();
		ВидПлана.Использование             = Истина;
		ВидПлана.ПериодичностьПланирования = Перечисления.Периодичность.Неделя;
		ВидПлана.ЧислоОтображаемыхПериодов = 2;
		ВидПлана.ТочностьПланирования      = Перечисления.торо_ДетализацияПлана.Час;
		ВидПлана.ВидИсполнителяРабот       = Перечисления.торо_ДетализацияИсполнителя.Бригада;
		
		ВидПлана.Записать();

	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
									,, НСтр("es='¡La guía ""los Tipos de los planes que se deslizan"" no es rellenada! Por la causa: ';ru='Справочник ""Виды скользящих планов"" НЕ заполнен! По причине: ';en='Directory ""Types of Moving Plans"" is NOT filled! Due to: '") + ОписаниеОшибки);
	КонецПопытки;   
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;

КонецПроцедуры

Процедура ОбновлениеРегистраНакопленияВремяНахожденияВСостоянии() Экспорт
	
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	
	Попытка
	
		ТаблицаОбъектовРемонта = Новый ТаблицаЗначений;
		ТаблицаОбъектовРемонта.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Строка"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ДатаОкончания", Новый ОписаниеТипов("Дата"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ДатаНачала", Новый ОписаниеТипов("Дата"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ОбъектРемонта", Новый ОписаниеТипов("СправочникСсылка.торо_ОбъектыРемонта"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ПричинаПростоя", Новый ОписаниеТипов("СправочникСсылка.торо_ПричиныПростояОборудования"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ИзменятьСостояниеПодчиненныхОР", Новый ОписаниеТипов("Булево"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ВидЭксплуатации", Новый ОписаниеТипов("СправочникСсылка.торо_ВидыЭксплуатации"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ВидПуска", Новый ОписаниеТипов("СправочникСсылка.торо_ВидыПусковОР"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ВидЭксплуатацииНаПериод", Новый ОписаниеТипов("СправочникСсылка.торо_ВидыЭксплуатации"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ВидПускаНаПериод", Новый ОписаниеТипов("СправочникСсылка.торо_ВидыПусковОР"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("Иерархия", Новый ОписаниеТипов("СправочникСсылка.торо_СтруктурыОР"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("ВнешнийОР", Новый ОписаниеТипов("Булево"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("Примечание", Новый ОписаниеТипов("Строка"));
		ТаблицаОбъектовРемонта.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ДокументСсылка.торо_СостоянияОбъектовРемонта"));
		
		ТаблицаОбъектовРемонтаНаПериод = ТаблицаОбъектовРемонта.СкопироватьКолонки();
		 
		ТекстЗапроса =
			"ВЫБРАТЬ
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.Ссылка КАК Ссылка,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.НомерСтроки КАК НомерСтроки,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ДатаОкончания КАК ДатаОкончания,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ДатаНачала КАК ДатаНачала,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ОбъектРемонта КАК ОбъектРемонта,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ПричинаПростоя КАК ПричинаПростоя,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ИзменятьСостояниеПодчиненныхОР КАК ИзменятьСостояниеПодчиненныхОР,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ВидЭксплуатации КАК ВидЭксплуатации,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ВидПуска КАК ВидПуска,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ВидЭксплуатацииНаПериод КАК ВидЭксплуатацииНаПериод,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ВидПускаНаПериод КАК ВидПускаНаПериод,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.Иерархия КАК Иерархия,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.ВнешнийОР КАК ВнешнийОР,
			|	торо_СостоянияОбъектовРемонтаОбъектыРемонта.Примечание КАК Примечание,
			|	торо_СостоянияОбъектовРемонта.Дата КАК Дата
			|ИЗ
			|	Документ.торо_СостоянияОбъектовРемонта.ОбъектыРемонта КАК торо_СостоянияОбъектовРемонтаОбъектыРемонта
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_СостоянияОбъектовРемонта КАК торо_СостоянияОбъектовРемонта
			|		ПО торо_СостоянияОбъектовРемонтаОбъектыРемонта.Ссылка = торо_СостоянияОбъектовРемонта.Ссылка
			|		И торо_СостоянияОбъектовРемонта.ВидОперации = &ВидОперации
			|ГДЕ
			|	торо_СостоянияОбъектовРемонта.Проведен = ИСТИНА";
			
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;
		
		// Вид эксплуатации
		Запрос.УстановитьПараметр("ВидОперации", Перечисления.торо_ВидыОперацийОтклоненияВРаботеОборудования.ВидЭксплуатации);
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
		ПолучитьТаблицуОбъектовРемонта(ТаблицаОбъектовРемонта, РезультатЗапроса);
		ПредыдущиеЭксплуатации = ОпределитьСостоянияОбъектов(ТаблицаОбъектовРемонта, ТаблицаОбъектовРемонта.ВыгрузитьКолонку("ОбъектРемонта"));
		ТаблицаВремяНахожденияВСостоянии = ОпределитьВремяНахожденияВСостоянии(ТаблицаОбъектовРемонта, ПредыдущиеЭксплуатации);
		ДобавитьЗаписиВРегистр(ТаблицаВремяНахожденияВСостоянии);
		
		// Вид эксплуатации на период
		Запрос.УстановитьПараметр("ВидОперации", Перечисления.торо_ВидыОперацийОтклоненияВРаботеОборудования.ВидЭксплуатацииНаПериод);
		РезультатЗапросаНаПериод = Запрос.Выполнить().Выгрузить();
		
		ПолучитьТаблицуОбъектовРемонта(ТаблицаОбъектовРемонтаНаПериод, РезультатЗапросаНаПериод);
		ПредыдущиеЭксплуатацииНаПериод = ОпределитьСостоянияОбъектов(ТаблицаОбъектовРемонтаНаПериод, ТаблицаОбъектовРемонтаНаПериод.ВыгрузитьКолонку("ОбъектРемонта"), Истина);
		ТаблицаВремяНахожденияВСостоянииНаПериод = ОпределитьВремяНахожденияВСостоянии(ТаблицаОбъектовРемонтаНаПериод, ПредыдущиеЭксплуатацииНаПериод);
		ДобавитьЗаписиВРегистр(ТаблицаВремяНахожденияВСостоянииНаПериод);
		
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
									,,НСтр("es='¡El registro de la acumulación ""el Tiempo de la posición en el estado"" no es renovado! Por la causa: ';ru='Регистр накопления ""Время нахождения в состоянии"" НЕ обновлен! По причине: ';en='Accumulation register ""Time in state"" is NOT updated! Due to: '") + ОписаниеОшибки);
	КонецПопытки;   
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;

КонецПроцедуры

Процедура ПолучитьТаблицуОбъектовРемонта(ТаблицаОбъектовРемонта, ОбъектыРемонта)	
	
	Для каждого ТекСтрока из ОбъектыРемонта Цикл
		Если НЕ ТекСтрока.ИзменятьСостояниеПодчиненныхОР Тогда
			НС = ТаблицаОбъектовРемонта.Добавить();
			ЗаполнитьЗначенияСвойств(НС , ТекСтрока);
			
		Иначе
			
			СтруктураПоиска = Новый Структура();
			
			СтруктураПоиска.Вставить("ОбъектРемонта",			ТекСтрока.ОбъектРемонта);
			СтруктураПоиска.Вставить("ДатаНачала",				ТекСтрока.ДатаНачала);
			СтруктураПоиска.Вставить("ДатаОкончания",			ТекСтрока.ДатаОкончания);
			СтруктураПоиска.Вставить("ПричинаПростоя",			ТекСтрока.ПричинаПростоя);
			СтруктураПоиска.Вставить("ВидЭксплуатации",			ТекСтрока.ВидЭксплуатации);
			СтруктураПоиска.Вставить("ВидЭксплуатацииНаПериод",	ТекСтрока.ВидЭксплуатацииНаПериод);
			СтруктураПоиска.Вставить("ВидПуска",				ТекСтрока.ВидПуска);
			СтруктураПоиска.Вставить("ВидПускаНаПериод",		ТекСтрока.ВидПускаНаПериод);
						
			Если ТаблицаОбъектовРемонта.НайтиСтроки(СтруктураПоиска).Количество() Тогда
				Продолжить;
			КонецЕсли;	
			
			НС = ТаблицаОбъектовРемонта.Добавить();
			ЗаполнитьЗначенияСвойств(НС , ТекСтрока);
			
			МассивПодчиненных = торо_РаботаСИерархией20.ПолучитьМассивПодчиненныхОбъектов(ТекСтрока.ОбъектРемонта, ТекСтрока.Иерархия, ТекСтрока.Дата);
			
			Для Каждого ЭлементСписка Из МассивПодчиненных Цикл
				
				   СтруктураПоиска = Новый Структура();
					
					СтруктураПоиска.Вставить("ОбъектРемонта",			ЭлементСписка);
					СтруктураПоиска.Вставить("ДатаНачала",				ТекСтрока.ДатаНачала);
					СтруктураПоиска.Вставить("ДатаОкончания",			ТекСтрока.ДатаОкончания);
					СтруктураПоиска.Вставить("ПричинаПростоя",			ТекСтрока.ПричинаПростоя);
					СтруктураПоиска.Вставить("ВидЭксплуатации",			ТекСтрока.ВидЭксплуатации);
					СтруктураПоиска.Вставить("ВидЭксплуатацииНаПериод",	ТекСтрока.ВидЭксплуатацииНаПериод);
					СтруктураПоиска.Вставить("ВидПуска",				ТекСтрока.ВидПуска);
					СтруктураПоиска.Вставить("ВидПускаНаПериод",		ТекСтрока.ВидПускаНаПериод);
					
					Если ТаблицаОбъектовРемонта.НайтиСтроки(СтруктураПоиска).Количество() Тогда
						Продолжить;
					КонецЕсли;	
					
					НС = ТаблицаОбъектовРемонта.Добавить();
					
					ЗаполнитьЗначенияСвойств(НС , ТекСтрока);
					НС.ОбъектРемонта		 	= ЭлементСписка;
					
			КонецЦикла;	
 				
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция	ОпределитьСостоянияОбъектов(ТаблицаОбъектовРемонта, СписокОР, ВидЭксплуатацииНаПериод = Ложь) 
	
	Если ВидЭксплуатацииНаПериод Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ВременнаяТаблица.ОбъектРемонта КАК ОбъектРемонта,
			|	ВременнаяТаблица.ДатаНачала КАК ДатаНачала,
			|	ВременнаяТаблица.ДатаОкончания КАК ДатаОкончания,
			|	ВременнаяТаблица.ВидЭксплуатации КАК ВидЭксплуатации,
			|	ВременнаяТаблица.ВидЭксплуатацииНаПериод КАК ВидЭксплуатацииНаПериод,
			|	ВременнаяТаблица.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ТаблицаОбъектовРемонта
			|ИЗ
			|	&ТаблицаОР КАК ВременнаяТаблица
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	ОбъектРемонта
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВременнаяТаблица.ОбъектРемонта КАК ОбъектРемонта,
			|	ВременнаяТаблица.ДатаНачала КАК ДатаНачала,
			|	ВременнаяТаблица.ДатаОкончания КАК ДатаОкончания,
			|	ВременнаяТаблица.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ТаблицаОбъектовРемонтаДляЗаполнения
			|ИЗ
			|	ТаблицаОбъектовРемонта КАК ВременнаяТаблица
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	ОбъектРемонта
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТаблицаОбъектыРемонта.ОбъектРемонта КАК ОбъектРемонта,
			|	ТаблицаОбъектыРемонта.ДатаНачала КАК Период,
			|	ТаблицаОбъектыРемонта.ВидЭксплуатацииНаПериод КАК ВидЭксплуатации
			|ПОМЕСТИТЬ ТаблицаПроведенияНачало
			|ИЗ
			|	ТаблицаОбъектовРемонта КАК ТаблицаОбъектыРемонта
			|ГДЕ
			|	ТаблицаОбъектыРемонта.ВидЭксплуатацииНаПериод <> ЗНАЧЕНИЕ(Справочник.торо_ВидыЭксплуатации.ПустаяСсылка)
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	ОбъектРемонта,
			|	Период
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТаблицаОбъектыРемонта.ОбъектРемонта КАК ОбъектРемонта,
			|	ТаблицаОбъектыРемонта.ДатаОкончания КАК Дата,
			|	ТаблицаОбъектыРемонта.ВидЭксплуатации КАК ВидЭксплуатации
			|ПОМЕСТИТЬ ТаблицаПредыдущиеЭксплуатации
			|ИЗ
			|	ТаблицаОбъектовРемонта КАК ТаблицаОбъектыРемонта
			|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПроведенияНачало КАК ТаблицаПроведенияНачало
			|		ПО ТаблицаОбъектыРемонта.ОбъектРемонта = ТаблицаПроведенияНачало.ОбъектРемонта
			|			И ТаблицаОбъектыРемонта.ДатаОкончания = ТаблицаПроведенияНачало.Период
			|ГДЕ
			|	ТаблицаПроведенияНачало.Период ЕСТЬ NULL
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ТаблицаОбъектыРемонта.ОбъектРемонта,
