		|	И ТаблицаОбъектовРемонта.ДатаСреза2 > ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|	И ТаблицаОбъектовРемонта.ВидЭксплуатации2.ТипЭксплуатации = ЗНАЧЕНИЕ(Перечисление.торо_ТипЭксплуатации.Эксплуатация)";
				   
				   
	Запрос.УстановитьПараметр("ПредыдущиеЭксплуатации", ПредыдущиеЭксплуатации);
	ВремяНахожденияВСостоянии = Запрос.Выполнить().Выгрузить();
	
