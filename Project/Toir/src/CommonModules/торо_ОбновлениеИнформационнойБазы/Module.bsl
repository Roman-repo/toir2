			КонецЦикла;

			НаборЗаписей.Записать(Истина);
		
		КонецЦикла;
		
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡Los movimientos de los documentos ""el Acta sobre la ejecución de la medida de reglamento"" por el registro de los gastos reales no son formados! Por la causa: ';ru='Движения документов ""Акт о выполнении регламентного мероприятия"" по регистру фактических материальных затрат НЕ сформированы! По причине: ';en='Documents ""Act on the implementation of regulatory activities"" on the register of actual material costs are NOT formed! Due to: '")+ОписаниеОшибки);
	КонецПопытки;
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
