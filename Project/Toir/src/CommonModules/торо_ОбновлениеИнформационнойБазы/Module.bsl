		               |	торо_ПлановыеМероприятия.Регистратор КАК Регистратор
		               |ПОМЕСТИТЬ Регистр
		               |ИЗ
		               |	РегистрСведений.торо_ПлановыеМероприятия КАК торо_ПлановыеМероприятия
		               |ГДЕ
		               |	торо_ПлановыеМероприятия.СпособВыполнения = &СпособВыполнения
		               |
		               |ИНДЕКСИРОВАТЬ ПО
		               |	Регистратор,
		               |	ID
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	Регистр.СписокОбъектов КАК СписокОбъектов,
		               |	Регистр.ВидМероприятия КАК ВидМероприятия,
		               |	Регистр.ID КАК ID,
		               |	Регистр.Подразделение КАК Подразделение,
		               |	Регистр.Организация КАК Организация,
		               |	Регистр.ДатаНачала КАК ДатаНачала,
		               |	Регистр.ДатаОкончания КАК ДатаОкончания,
		               |	Регистр.Исполнитель КАК Исполнитель,
		               |	Регистр.Отменен КАК Отменен,
		               |	Регистр.СтоимостьРемонта КАК СтоимостьРемонта,
		               |	Регистр.МоментВремени КАК МоментВремени,
		               |	торо_ГрафикРегламентныхМероприятийТОиРПланРемонтов.СпособВыполнения КАК СпособВыполнения,
		               |	Регистр.Регистратор КАК Регистратор
		               |ИЗ
		               |	Регистр КАК Регистр
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ГрафикРегламентныхМероприятийТОиР.ПланРемонтов КАК торо_ГрафикРегламентныхМероприятийТОиРПланРемонтов
		               |		ПО Регистр.Регистратор = торо_ГрафикРегламентныхМероприятийТОиРПланРемонтов.Ссылка
		               |			И Регистр.ID = торо_ГрафикРегламентныхМероприятийТОиРПланРемонтов.ID
		               |ИТОГИ ПО
		               |	Регистратор";
		
		Запрос.УстановитьПараметр("СпособВыполнения", Перечисления.СпособыСтроительства.ПустаяСсылка());
		
		резЗапроса = Запрос.Выполнить();
		
		Если НЕ резЗапроса.Пустой() Тогда
			
			струкПоиска = Новый Структура("СписокОбъектов, ВидМероприятия, ID, Организация");
			
			ВыборкаПоРег = резЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоРег.Следующий() Цикл
				Выборка = ВыборкаПоРег.Выбрать();
				нз = РегистрыСведений.торо_ПлановыеМероприятия.СоздатьНаборЗаписей();
				нз.Отбор.Регистратор.установить(ВыборкаПоРег.Регистратор);
				нз.Прочитать();
				тз = нз.выгрузить();
				датаДок = ВыборкаПоРег.Регистратор.Дата;
				
				Пока Выборка.Следующий() Цикл
					ЗаполнитьЗначенияСвойств(струкПоиска, Выборка);
					мас = тз.найтиСтроки(струкПоиска);
					Если мас.Количество() = 1 И ЗначениеЗаполнено(Выборка.СпособВыполнения) Тогда
						мас[0].СпособВыполнения = Выборка.СпособВыполнения;
					КонецЕсли;
				КонецЦикла;
				
				Для каждого текСтрока из тз Цикл
					Если НЕ ЗначениеЗаполнено(текСтрока.Период) Тогда
						текСтрока.Период = датаДок;
					КонецЕсли;
				КонецЦикла;
				
				нз.Загрузить(тз);
				нз.Записать();
			КонецЦикла;
		КонецЕсли;		
		
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡La renovación del registro de las noticias ""las medidas Planificadas"" no es cumplido! Por la causa: ';ru='Обновление регистра сведений ""Плановые мероприятия"" НЕ выполнена! По причине: ';en='Updating the register of information ""Planned events"" NOT completed! Due to: '")+ОписаниеОшибки);
	КонецПопытки;
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
