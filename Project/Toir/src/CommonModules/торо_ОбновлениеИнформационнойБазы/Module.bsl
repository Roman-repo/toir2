Процедура ЗаполнитьИерархиюВДокументахЖЦ() Экспорт
	
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	Попытка
		ТекСтруктураИерархии = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
															"НастройкиТОиР",
															"ОсновнаяСтруктураИерархии",
															Справочники.торо_СтруктурыОР.ПустаяСсылка());
	
		// документ выбытие
		СписокРодителей = Новый ТаблицаЗначений;
		СписокРодителей.Колонки.Добавить("Номер");
		СписокРодителей.Колонки.Добавить("ТекстовоеОписание");
			
		Запрос = Новый Запрос;
		Запрос.Текст =  "ВЫБРАТЬ
		                |	торо_ВыбытиеОбъектаРемонта.Ссылка КАК Ссылка,
		                |	торо_ВыбытиеОбъектаРемонта.ОбъектРемонта КАК ОбъектРемонта
		                |ИЗ
		                |	Документ.торо_ВыбытиеОбъектаРемонта КАК торо_ВыбытиеОбъектаРемонта
		                |ГДЕ
		                |	торо_ВыбытиеОбъектаРемонта.ТекСтруктураИерархии = ЗНАЧЕНИЕ(Справочник.торо_СтруктурыОР.ПустаяСсылка)";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДокумент = РезультатЗапроса.Выбрать();
		Пока ВыборкаДокумент.Следующий() Цикл
						
			МассивРодителей = Новый Массив;
			СписокРодителей.Очистить();
			торо_РаботаСИерархией20.ЗаполнитьМассивРодителейОбъектаРемонта(ВыборкаДокумент.ОбъектРемонта, МассивРодителей, ТекСтруктураИерархии);
			
			Номер = 1;
			Для каждого Родитель из МассивРодителей Цикл
				НоваяСтрока = СписокРодителей.Добавить();
				НоваяСтрока.ТекстовоеОписание = Строка(Родитель);
				НоваяСтрока.Номер = Номер;
				Номер = Номер + 1;
			КонецЦикла;
			
			СписокРодителей.Сортировать("Номер Убыв");
			ТекстовоеОписаниеПоложения = "";
			КолТабов = 0;
			
			Для каждого Строка Из СписокРодителей Цикл
				КолОтступов = КолТабов;
				СтрокаОтступа = "";
				Пока Не КолОтступов = 0 Цикл
					СтрокаОтступа = СтрокаОтступа + "ˡ-->";
					КолОтступов = КолОтступов -1;
				КонецЦикла;
				Если КолТабов = 0 Тогда
					ТекстовоеОписаниеПоложения = СтрокаОтступа + Строка(Строка.ТекстовоеОписание);
				Иначе
					ТекстовоеОписаниеПоложения = ТекстовоеОписаниеПоложения + Символы.ПС + СтрокаОтступа + Строка(Строка.ТекстовоеОписание);
				КонецЕсли;
				КолТабов = КолТабов + 1;
			КонецЦикла;
			
			Документ = ВыборкаДокумент.Ссылка.ПолучитьОбъект();
			Документ.ТекСтруктураИерархии 	= ТекСтруктураИерархии;
			Документ.ВходилВСостав 			= ТекстовоеОписаниеПоложения;
			Документ.Записать(РежимЗаписиДокумента.Запись);
						
		КонецЦикла;
		
		// документ принятие к учету
		Запрос = Новый Запрос;
		Запрос.Текст =  "ВЫБРАТЬ
		                |	торо_ПринятиеОРКУчету.Ссылка КАК Ссылка,
		                |	торо_ПринятиеОРКУчету.ОбъектРемонта КАК ОбъектРемонта
		                |ИЗ
		                |	Документ.торо_ПринятиеОРКУчету КАК торо_ПринятиеОРКУчету
		                |ГДЕ
		                |	торо_ПринятиеОРКУчету.ТекСтруктураИерархии = ЗНАЧЕНИЕ(Справочник.торо_СтруктурыОР.ПустаяСсылка)";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДокумент = РезультатЗапроса.Выбрать();
		Пока ВыборкаДокумент.Следующий() Цикл
						
			МассивРодителей = Новый Массив;
			СписокРодителей.Очистить();
			торо_РаботаСИерархией20.ЗаполнитьМассивРодителейОбъектаРемонта(ВыборкаДокумент.ОбъектРемонта, МассивРодителей, ТекСтруктураИерархии);
			
			Номер = 1;
			Для каждого Родитель из МассивРодителей Цикл
				НоваяСтрока = СписокРодителей.Добавить();
				НоваяСтрока.ТекстовоеОписание = Строка(Родитель);
				НоваяСтрока.Номер = Номер;
				Номер = Номер + 1;
			КонецЦикла;
			
			СписокРодителей.Сортировать("Номер Убыв");
			ТекстовоеОписаниеПоложения = "";
			КолТабов = 0;
			
			Для каждого Строка Из СписокРодителей Цикл
				КолОтступов = КолТабов;
				СтрокаОтступа = "";
				Пока Не КолОтступов = 0 Цикл
					СтрокаОтступа = СтрокаОтступа + "ˡ-->";
					КолОтступов = КолОтступов -1;
				КонецЦикла;
				Если КолТабов = 0 Тогда
					ТекстовоеОписаниеПоложения = СтрокаОтступа + Строка(Строка.ТекстовоеОписание);
				Иначе
					ТекстовоеОписаниеПоложения = ТекстовоеОписаниеПоложения + Символы.ПС + СтрокаОтступа + Строка(Строка.ТекстовоеОписание);
				КонецЕсли;
				КолТабов = КолТабов + 1;
			КонецЦикла;
			
			Документ = ВыборкаДокумент.Ссылка.ПолучитьОбъект();
			Документ.ТекСтруктураИерархии 	= ТекСтруктураИерархии;
			Документ.ВходитВСостав 			= ТекстовоеОписаниеПоложения;
			Документ.Записать(РежимЗаписиДокумента.Запись);
						
		КонецЦикла;
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡Los documentos ""la Aceptación del objeto de la reparación al recuento"" y ""la Salida del objeto de la reparación"" no son renovados! Por la causa: ';ru='Документы ""Принятие объекта ремонта к учету"" и ""Выбытие объекта ремонта"" НЕ обновлены! По причине: ';en='The documents ""Acceptance of the repair object for accounting"" and ""Retirement of the repair object"" are NOT updated! Due to: '") + ОписаниеОшибки);
	КонецПопытки;   
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

Процедура ОбновлениеРегистраОтмененныеЗаявки() Экспорт
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеЗаявки.Ссылка КАК Ссылка,
		               |	торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеЗаявки.Заявка КАК Заявка,
		               |	торо_ЗаявкиПоРемонтам.IDРемонта КАК ID,
		               |	ЕСТЬNULL(торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеРемонты.Отменен, ЛОЖЬ) КАК Отменен,
		               |	ЕСТЬNULL(торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеРемонты.Перенесен, ЛОЖЬ) КАК Перенесен
		               |ИЗ
		               |	Документ.торо_ЗакрытиеЗаявокИРемонтов.ЗакрываемыеЗаявки КАК торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеЗаявки
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК торо_ЗаявкиПоРемонтам
		               |		ПО торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеЗаявки.Заявка = торо_ЗаявкиПоРемонтам.Регистратор
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ЗакрытиеЗаявокИРемонтов.ЗакрываемыеРемонты КАК торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеРемонты
		               |		ПО торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеЗаявки.Ссылка = торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеРемонты.Ссылка
		               |			И (торо_ЗаявкиПоРемонтам.IDРемонта = торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеРемонты.ID)
		               |ГДЕ
		               |	торо_ЗакрытиеЗаявокИРемонтовЗакрываемыеЗаявки.Ссылка.Проведен
		               |ИТОГИ ПО
		               |	Ссылка,
		               |	Заявка";
		
		ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
		
		Пока ВыборкаДокументов.Следующий() Цикл
			НаборЗаписей = РегистрыСведений.торо_ОтмененныеЗаявки.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаДокументов.Ссылка);
			НаборЗаписей.Прочитать();
			НаборЗаписей.Очистить();
			
			ВыборкаЗаявок = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Заявка");
			Пока ВыборкаЗаявок.Следующий() Цикл
				ВыборкаРемонтов = ВыборкаЗаявок.Выбрать();
				Пока ВыборкаРемонтов.Следующий() Цикл
					Запись = НаборЗаписей.Добавить();
					Запись.ИДРемонта = ВыборкаРемонтов.ID;
					Запись.Регистратор = ВыборкаДокументов.Ссылка;
					Запись.Заявка = ВыборкаЗаявок.Заявка;
					Если ВыборкаРемонтов.Отменен Тогда
						Запись.ПричинаЗакрытия = Справочники.торо_ПричиныЗакрытияЗаявок.ОтменаРемонта;
					ИначеЕсли ВыборкаРемонтов.Перенесен Тогда
						Запись.ПричинаЗакрытия = Справочники.торо_ПричиныЗакрытияЗаявок.ПереносРемонта;
					Иначе
						Запись.ПричинаЗакрытия = Справочники.торо_ПричиныЗакрытияЗаявок.ПустаяСсылка();
					КонецЕсли;
				КонецЦикла;	
			КонецЦикла;
			НаборЗаписей.Записать();
		КонецЦикла;
		
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡Los movimientos de los documentos por el registro ""las demandas Anuladas"" no son formados! Por la causa: ';ru='Движения документов по регистру ""Отмененные заявки"" НЕ сформированы! По причине: ';en='Documents movement on the register ""Canceled applications"" are NOT formed! Due to: '")+ОписаниеОшибки);
	КонецПопытки;
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

Процедура ОбновлениеИсполнителейВДокументахЗаявки() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РемонтныеРаботы.Ссылка КАК Ссылка,
	|	РемонтныеРаботы.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
	|	РемонтныеРаботы.ID КАК ID,
	|	Исполнители.НомерСтроки КАК НомерСтроки,
	|	Исполнители.Исполнитель КАК Исполнитель,
	|	Исполнители.ДоговорКонтрагента КАК ДоговорБригада
	|ПОМЕСТИТЬ ВТ_ИсполнителиРемРаботВсе
	|ИЗ
	|	Документ.торо_ЗаявкаНаРемонт.УдалитьИсполнителиРемонтныхРабот КАК Исполнители
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтныеРаботы КАК РемонтныеРаботы
	|		ПО Исполнители.Ссылка = РемонтныеРаботы.Ссылка
	|			И Исполнители.РемонтыОборудования_ID = РемонтныеРаботы.РемонтыОборудования_ID
	|			И Исполнители.ID = РемонтныеРаботы.ID
	|			И (РемонтныеРаботы.Исполнитель = НЕОПРЕДЕЛЕНО)
	|			И (РемонтныеРаботы.РемонтнаяРабота ССЫЛКА Справочник.торо_ИдентификаторыТехКарт)
	|			И (Исполнители.Исполнитель ССЫЛКА Справочник.Контрагенты
	|				ИЛИ Исполнители.Исполнитель ССЫЛКА Справочник.СтруктураПредприятия)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка,
	|	РемонтыОборудования_ID,
	|	ID,
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИсполнителиРемРаботВсе.Ссылка КАК Ссылка,
	|	ВТ_ИсполнителиРемРаботВсе.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
	|	ВТ_ИсполнителиРемРаботВсе.ID КАК ID,
	|	МИНИМУМ(ВТ_ИсполнителиРемРаботВсе.НомерСтроки) КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ_МинНомерСтроки
	|ИЗ
	|	ВТ_ИсполнителиРемРаботВсе КАК ВТ_ИсполнителиРемРаботВсе
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ИсполнителиРемРаботВсе.Ссылка,
	|	ВТ_ИсполнителиРемРаботВсе.РемонтыОборудования_ID,
	|	ВТ_ИсполнителиРемРаботВсе.ID
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка,
	|	РемонтыОборудования_ID,
	|	ID,
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИсполнителиРемРаботВсе.Ссылка КАК Ссылка,
	|	ВТ_ИсполнителиРемРаботВсе.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
	|	ВТ_ИсполнителиРемРаботВсе.ID КАК ID,
	|	ВТ_ИсполнителиРемРаботВсе.Исполнитель КАК Исполнитель,
	|	ВТ_ИсполнителиРемРаботВсе.ДоговорБригада КАК ДоговорБригада
	|ИЗ
	|	ВТ_ИсполнителиРемРаботВсе КАК ВТ_ИсполнителиРемРаботВсе
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МинНомерСтроки КАК ВТ_МинНомерСтроки
	|		ПО ВТ_ИсполнителиРемРаботВсе.Ссылка = ВТ_МинНомерСтроки.Ссылка
	|			И ВТ_ИсполнителиРемРаботВсе.РемонтыОборудования_ID = ВТ_МинНомерСтроки.РемонтыОборудования_ID
	|			И ВТ_ИсполнителиРемРаботВсе.ID = ВТ_МинНомерСтроки.ID
	|			И ВТ_ИсполнителиРемРаботВсе.НомерСтроки = ВТ_МинНомерСтроки.НомерСтроки
	|ИТОГИ ПО
	|	Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ДокВТранзакции = 500;
	Счетчик = 0;
	ОшибкаВТранзакции = Ложь;
	
	Попытка
		
		Пока Выборка.Следующий() Цикл
			Если НЕ ТранзакцияАктивна() Тогда
				НачатьТранзакцию();
			КонецЕсли;
			
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			// Дозаполнение исполнителей в дереве рем. работ.
			ВыборкаДеталейОперации = Выборка.Выбрать(ОбходРезультатаЗапроса.Прямой);
			СтруктураПоиска = Новый Структура("РемонтыОборудования_ID, ID");
			
			Пока ВыборкаДеталейОперации.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтруктураПоиска, ВыборкаДеталейОперации);
				СтрокиРемРабот = ДокументОбъект.РемонтныеРаботы.НайтиСтроки(СтруктураПоиска);
				Для каждого СтрокаРемРабот из СтрокиРемРабот Цикл
					СтрокаРемРабот.Исполнитель = ВыборкаДеталейОперации.Исполнитель;
					СтрокаРемРабот.ДоговорБригада = ВыборкаДеталейОперации.ДоговорБригада;
				КонецЦикла;
			КонецЦикла;
			
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			
			Счетчик = Счетчик + 1;
			Если Счетчик = ДокВТранзакции Тогда
				ЗафиксироватьТранзакцию();
				Счетчик = 0;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ТранзакцияАктивна() Тогда
			ЗафиксироватьТранзакцию();
		КонецЕсли;
		
	Исключение
		ОшибкаВТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка,
				,,	НСтр("es='¡La renovación de los ejecutores en los documentos ""la Demanda por la reparación"" no es cumplida! Por la causa: ';ru='Обновление исполнителей в документах ""Заявка на ремонт"" не выполнено! По причине: ';en='Update performers in the documents ""Request for repair"" is not completed! Due to: '")+ОписаниеОшибки);
	КонецПопытки;
	
	Если ТранзакцияАктивна() И ОшибкаВТранзакции Тогда
		ОтменитьТранзакцию();
	КонецЕсли;
	
КонецПроцедуры

