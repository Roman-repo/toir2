Процедура УдалениеБитыхСсылокИзНастроекРМТехСпециалиста() Экспорт
	
	Ошибка = Ложь;
	
	Попытка
		
		ВыборкаПользователей = Справочники.Пользователи.Выбрать();
		
		Пока ВыборкаПользователей.Следующий() Цикл
			
			УИД = ВыборкаПользователей.Ссылка.УникальныйИдентификатор();
			
			ЗначениеНастроек = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("Обработка.торо_РабочееМестоТехническогоСпециалиста", УИД);
			Если ЗначениеНастроек = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если ЗначениеНастроек.Свойство("ТаблицаКритичности") Тогда
				МассивКУдалению = Новый Массив;
				Для каждого Строка из ЗначениеНастроек.ТаблицаКритичности Цикл
					СправочникОбъект = Строка.Критичность.ПолучитьОбъект();
					Если СправочникОбъект = Неопределено Тогда
						МассивКУдалению.Добавить(Строка);
					КонецЕсли;
				КонецЦикла;
				
				Для каждого Строка из МассивКУдалению Цикл
					ЗначениеНастроек.ТаблицаКритичности.Удалить(Строка);
				КонецЦикла;
				
				Если МассивКУдалению.Количество() > 0 Тогда
					ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("Обработка.торо_РабочееМестоТехническогоСпециалиста", УИД, ЗначениеНастроек);
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
	Исключение
		Ошибка = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,ОписаниеОшибки);
	КонецПопытки;  
	
