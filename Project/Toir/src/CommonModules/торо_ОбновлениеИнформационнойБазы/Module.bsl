Процедура СформироватьЗановоДвиженияПоРегиструВнешнихОснованийДляРабот() Экспорт
		
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	Попытка
		
		// удаление возможных лишних движений, сделанных в 13ом релизе
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	торо_ВнешниеОснованияДляРабот.Регистратор КАК Регистратор
		               |ИЗ
		               |	РегистрСведений.торо_ВнешниеОснованияДляРабот КАК торо_ВнешниеОснованияДляРабот
		               |ГДЕ
		               |	торо_ВнешниеОснованияДляРабот.Регистратор.Проведен = ЛОЖЬ";
		
		ВыборкаДокументов = Запрос.Выполнить().Выбрать();
		
		Пока ВыборкаДокументов.Следующий() Цикл
			
			НаборЗаписей = РегистрыСведений.торо_ВнешниеОснованияДляРабот.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаДокументов.Регистратор);
			НаборЗаписей.Прочитать();
			НаборЗаписей.Очистить();
			НаборЗаписей.Записать(Истина);
		
		КонецЦикла;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ВыявленныеДефектыДокументыОснования.ДокументОснование КАК ДокументОснование,
		|	торо_ВыявленныеДефектыДокументыОснования.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_Основания
		|ИЗ
		|	Документ.торо_ВыявленныеДефекты.ДокументыОснования КАК торо_ВыявленныеДефектыДокументыОснования
		|ГДЕ
		|	торо_ВыявленныеДефектыДокументыОснования.Ссылка.Проведен = ИСТИНА
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_АктОВыполненииЭтапаРаботДокументыОснования.ДокументОснование,
		|	торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка
		|ИЗ
		|	Документ.торо_АктОВыполненииЭтапаРабот.ДокументыОснования КАК торо_АктОВыполненииЭтапаРаботДокументыОснования
		|ГДЕ
		|	торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка.Проведен = ИСТИНА
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_ЗаявкаНаРемонтДокументыОснования.ДокументОснование,
		|	торо_ЗаявкаНаРемонтДокументыОснования.Ссылка
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.ДокументыОснования КАК торо_ЗаявкаНаРемонтДокументыОснования
		|ГДЕ
		|	торо_ЗаявкаНаРемонтДокументыОснования.Ссылка.Проведен = ИСТИНА
		|
