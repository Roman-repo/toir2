	НачатьТранзакцию();
	Попытка
		
		// Выбрать проведенные документы, где есть хотя бы одна строка материальных затрат. 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_АктОВыполненииРегламентногоМероприятияМатериальныеЗатраты.Ссылка
