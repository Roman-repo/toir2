Процедура ПеренестиИсполнителейПоРемонтамВЗаявках() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Исполнители.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
	|	Исполнители.Исполнитель КАК Исполнитель,
	|	Исполнители.ДоговорКонтрагента КАК УточнениеИсполнителя,
	|	Исполнители.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.торо_ЗаявкаНаРемонт.УдалитьИсполнителиРемонтныхРабот КАК Исполнители
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ИсполнителиПоРемонтам КАК ИсполнителиПоРемонтам
	|		ПО Исполнители.Ссылка = ИсполнителиПоРемонтам.Ссылка
	|			И Исполнители.РемонтыОборудования_ID = ИсполнителиПоРемонтам.РемонтыОборудования_ID
	|			И Исполнители.Исполнитель = ИсполнителиПоРемонтам.Исполнитель
	|			И Исполнители.ДоговорКонтрагента = ИсполнителиПоРемонтам.УточнениеИсполнителя
	|ГДЕ
	|	(Исполнители.Исполнитель ССЫЛКА Справочник.Контрагенты
	|			ИЛИ Исполнители.Исполнитель ССЫЛКА Справочник.СтруктураПредприятия)
	|	И ИсполнителиПоРемонтам.РемонтыОборудования_ID ЕСТЬ NULL
	|	И Исполнители.РемонтыОборудования_ID <> """"
	|ИТОГИ ПО
	|	Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ДокВТранзакции = 500;
	Счетчик = 0;
	ОшибкаВТранзакции = Ложь;
	
