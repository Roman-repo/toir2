					Движение.ОбъектРемонта = Коэффициент.ОбъектРемонта;
					Движение.ВидКоэффициента = Коэффициент.ВидКоэффициента;
					Движение.ЗначениеКоэффициента = Коэффициент.ЗначениеКоэффициента;
					Движение.Использование = Коэффициент.Использование;
					
					Если Коэффициент.РаспространятьНаПодчиненных Тогда
						// получить список подчиненных
						СписокОР = торо_РаботаСИерархией20.ПолучитьМассивПодчиненныхОбъектов(Коэффициент.ОбъектРемонта, Коэффициент.Иерархия);
						Для каждого ОбъектРемонта Из СписокОР Цикл
							Движение = НаборЗаписей.Добавить();
							
							Движение.Период = Коэффициент.ДатаНачалаИспользования;
							Движение.ОбъектРемонта = ОбъектРемонта;
							Движение.ВидКоэффициента = Коэффициент.ВидКоэффициента;
							Движение.ЗначениеКоэффициента = Коэффициент.ЗначениеКоэффициента;
							Движение.Использование = Коэффициент.Использование;				
						КонецЦикла; 
					КонецЕсли; 
				КонецЦикла; 
				
			КонецЕсли; 
			НаборЗаписей.Записать(Истина);			
		КонецЦикла;		
	
	Исключение
		ОшибкаТранзакции = Истина;
