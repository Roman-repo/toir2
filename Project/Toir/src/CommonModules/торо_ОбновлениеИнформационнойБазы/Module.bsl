	КонецЕсли;
	
	Таб = Запрос.Выполнить().Выгрузить();
	
	Возврат Таб;
	
КонецФункции

Функция ОпределитьВремяНахожденияВСостоянии(ТаблицаОбъектовРемонта, ПредыдущиеЭксплуатации)
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.Календари"));
	
	Если ПредыдущиеЭксплуатации.Колонки.Найти("ПлановыйГрафикРаботы") = Неопределено Тогда
		ПредыдущиеЭксплуатации.Колонки.Добавить("ПлановыйГрафикРаботы", Новый ОписаниеТипов(МассивТипов));
	КонецЕсли;
	
	Для Каждого СтрокаТО Из ПредыдущиеЭксплуатации Цикл
		
		СтрокаТО.ПлановыйГрафикРаботы = СтрокаТО.ОбъектРемонта.ПлановыйГрафикРаботы;
		
