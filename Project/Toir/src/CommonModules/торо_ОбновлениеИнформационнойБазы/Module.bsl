Процедура ДобавитьДокументыИзВнешнихОснованийВДокументыОснования() Экспорт
		
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ЗаявкаНаРемонтЗакрываемыеПредписания.ID КАК ID,
		|	торо_ЗаявкаНаРемонтЗакрываемыеПредписания.ОбъектРемонта КАК ОбъектРемонта,
		|	торо_ЗаявкаНаРемонтЗакрываемыеПредписания.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ЗакрываемыеПредписания
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.ЗакрываемыеПредписания КАК торо_ЗаявкаНаРемонтЗакрываемыеПредписания
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_АктОВыполненииЭтапаРаботЗакрываемыеПредписания.ID,
		|	торо_АктОВыполненииЭтапаРаботЗакрываемыеПредписания.ОбъектРемонта,
		|	торо_АктОВыполненииЭтапаРаботЗакрываемыеПредписания.Ссылка
		|ИЗ
		|	Документ.торо_АктОВыполненииЭтапаРабот.ЗакрываемыеПредписания КАК торо_АктОВыполненииЭтапаРаботЗакрываемыеПредписания
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_НарядНаВыполнениеРемонтныхРаботЗакрываемыеПредписания.ID,
		|	торо_НарядНаВыполнениеРемонтныхРаботЗакрываемыеПредписания.ОбъектРемонта,
		|	торо_НарядНаВыполнениеРемонтныхРаботЗакрываемыеПредписания.Ссылка
		|ИЗ
		|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.ЗакрываемыеПредписания КАК торо_НарядНаВыполнениеРемонтныхРаботЗакрываемыеПредписания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ВнешниеОснованияДляРабот.Регистратор КАК Регистратор,
		|	ВТ_ЗакрываемыеПредписания.Ссылка КАК Ссылка
		|ИЗ
		|	РегистрСведений.торо_ВнешниеОснованияДляРабот КАК торо_ВнешниеОснованияДляРабот
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЗакрываемыеПредписания КАК ВТ_ЗакрываемыеПредписания
		|		ПО торо_ВнешниеОснованияДляРабот.ID = ВТ_ЗакрываемыеПредписания.ID
		|			И торо_ВнешниеОснованияДляРабот.ОбъектРемонта = ВТ_ЗакрываемыеПредписания.ОбъектРемонта
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(торо_ВнешниеОснованияДляРабот.Регистратор) = ТИП(Документ.торо_ВнешнееОснованиеДляРабот)
		|
		|СГРУППИРОВАТЬ ПО
		|	торо_ВнешниеОснованияДляРабот.Регистратор,
		|	ВТ_ЗакрываемыеПредписания.Ссылка
		|ИТОГИ ПО
		|	Ссылка";
		
		ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
		
		Пока ВыборкаДокументов.Следующий() Цикл
			
			ВнешнееОснование = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой); 
			
			ОбъектДокумента = ВыборкаДокументов.Ссылка.ПолучитьОбъект();
			
			Пока ВнешнееОснование.Следующий() Цикл
				ТЧДокументовОснований = ОбъектДокумента.ДокументыОснования;
				Если ТЧДокументовОснований.Найти(ВнешнееОснование.Регистратор, "ДокументОснование") = Неопределено Тогда
					НоваяСтрока = ОбъектДокумента.ДокументыОснования.Добавить();
					НоваяСтрока.ДокументОснование = ВнешнееОснование.Регистратор;
				КонецЕсли; 
				
			КонецЦикла;
			
			ОбъектДокумента.Записать();
		КонецЦикла;
		
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡Los documentos con вкладки ""las razones Exteriores para los trabajos"" en вкладку ""los Documentos de la razón"" no son añadidos! Por la causa: ';ru='Документы с вкладки ""Внешние основания для работ"" на вкладку ""Документы основания"" НЕ добавлены! По причине: ';en='Documents from the tab ""External basis for work"" to the tab ""Documents of the basis"" are NOT added! Because of: '")+ОписаниеОшибки);
	КонецПопытки;
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;

КонецПроцедуры

