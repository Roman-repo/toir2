		СписокНарядов = рз[6].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		СписокАктов = рз[7].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока СписокНарядов.Следующий() Цикл
			
			докОб = СписокНарядов.Ссылка.ПолучитьОбъект();
			
			Выборка = СписокНарядов.Выбрать();
			Пока Выборка.Следующий() Цикл
				нс = ДокОб.МероприятияОбъектов.Добавить();
				ЗаполнитьЗначенияСвойств(нс, выборка);
			КонецЦикла;
			
			докОб.БезусловнаяЗапись = Истина;
			Если докОб.Проведен Тогда 
				докОб.Записать(РежимЗаписиДокумента.Проведение);
			Иначе
				докОб.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
			
		КонецЦикла;
		
		Пока СписокАктов.Следующий() Цикл
			
			докОб = СписокАктов.Ссылка.ПолучитьОбъект();
			
			Выборка = СписокАктов.Выбрать();
			Пока Выборка.Следующий() Цикл
				нс = ДокОб.МероприятияОбъектов.Добавить();
				ЗаполнитьЗначенияСвойств(нс, выборка);
				нс.Выполнено = НЕ Выборка.ЕстьВыпМероприятия;
			КонецЦикла;
			
			докОб.БезусловнаяЗапись = Истина;
			Если докОб.Проведен Тогда 
