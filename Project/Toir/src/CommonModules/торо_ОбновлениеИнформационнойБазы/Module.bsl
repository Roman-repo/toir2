		|ГДЕ
		|	торо_РегламентныеМероприятияИСпискиОбъектов.СпособУчетаДатыОтсчета = &СпособУчетаДатыОтсчета";
		
		Запрос.УстановитьПараметр("СпособУчетаДатыОтсчета", Перечисления.торо_СпособыУчетаДатыОтсчетаПриПланированииРемонтныхРабот.НеИспользоватьДатуВводаВЭксплуатацию);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			Запись = РегистрыСведений.торо_РегламентныеМероприятияИСпискиОбъектов.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(Запись, Выборка);
			Запись.Прочитать();
			Если Запись.Выбран() Тогда
				Запись.СпособУчетаДатыОтсчета = Перечисления.торо_СпособыУчетаДатыОтсчетаПриПланированииРемонтныхРабот.ПоПоследнемуРемонтуИлиДатеПланирования;
				Запись.Записать(Истина);
			КонецЕсли;
		КонецЦикла;

	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡La renovación del modo del recuento de la fecha de la lectura de los trabajos de reparación ""Por la última reparación"" no es cumplida! Por la causa: ';ru='Обновление способа учета даты отсчета ремонтных работ ""По последнему ремонту"" не выполнено! По причине: ';en='Updating the method for recording the countdown date for repair work ""Last Repair"" has not been completed! Due to: '")+ОписаниеОшибки);
	КонецПопытки;   
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли; 	
	
