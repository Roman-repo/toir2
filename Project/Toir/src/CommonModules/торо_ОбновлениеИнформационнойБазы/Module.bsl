		                |	Документ.торо_ЗаявкаНаРемонт.РемонтныеРаботы КАК торо_ЗаявкаНаРемонтРемонтныеРаботы
		                |ГДЕ
		                |	торо_ЗаявкаНаРемонтРемонтныеРаботы.Количество = 0";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДокумент = РезультатЗапроса.Выбрать();
		Пока ВыборкаДокумент.Следующий() Цикл
						
			Документ = ВыборкаДокумент.Ссылка.ПолучитьОбъект();
			РемонтныеРаботы = Документ.РемонтныеРаботы;
			Для каждого Строка Из РемонтныеРаботы Цикл
				Если Строка.Количество = 0 Тогда
					Строка.Количество = 1;
				КонецЕсли; 
			КонецЦикла;  
			Документ.Записать(РежимЗаписиДокумента.Запись);
			
			НаборЗаписей = РегистрыНакопления.торо_ПроцентВыполненныхРабот.СоздатьНаборЗаписей();
