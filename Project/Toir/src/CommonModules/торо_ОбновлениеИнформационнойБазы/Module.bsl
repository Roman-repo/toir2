		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДокумент = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаДокумент.Следующий() Цикл
			ВыборкаИД = ВыборкаДокумент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
			Пока ВыборкаИД.Следующий() Цикл
				ВыборкаОбъект = ВыборкаИД.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаОбъект.Следующий() Цикл
					ВыборкаДата = ВыборкаОбъект.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаДата.Следующий() Цикл
						Если ЗначениеЗаполнено(ВыборкаДата.ДокументИсточник) //И 
							//НЕ ТипЗнч(ВыборкаДата.ДокументИсточник) = Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") И
							//НЕ ТипЗнч(ВыборкаДата.ДокументИсточник) = Тип("ДокументСсылка.торо_НарядНаРегламентноеМероприятие") 
							Тогда
							
							НовыйДокумент = Документы.торо_ПлановыеЗатраты.СоздатьДокумент();
							НовыйДокумент.Дата = ВыборкаДата.Дата;
							НовыйДокумент.ДокументПлана = ВыборкаДата.ДокументИсточник;
							НовыйДокумент.ОбъектРемонта = ВыборкаДата.ОбъектРемонта;
							НовыйДокумент.РемонтыОборудования_ID = ВыборкаДата.ID;
							
							Выборка = ВыборкаДата.Выбрать();
							Пока Выборка.Следующий() Цикл
								НоваяСтрока = НовыйДокумент.ТехКарты.Добавить();
								НоваяСтрока.ТехКарта = Выборка.РемонтнаяРабота;
								НоваяСтрока.ТехКарта_ID = Выборка.ID_РР;
							КонецЦикла;
							НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла; 
		КонецЦикла; 	
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡Los documentos ""los gastos Planificados"" no son formados! Por la causa: ';ru='Документы ""Плановые затраты"" НЕ сформированы! По причине: ';en='Documents ""Planned costs"" are NOT generated! Due to: '")+ОписаниеОшибки);
	КонецПопытки;
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
		
КонецПроцедуры

