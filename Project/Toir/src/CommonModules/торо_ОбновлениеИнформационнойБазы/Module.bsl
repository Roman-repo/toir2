		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Срез КАК ВТ_Срез
		|		ПО ВТ_МинДаты.ОбъектРемонта = ВТ_Срез.ОбъектРемонта
		|			И ВТ_МинДаты.Период = ВТ_Срез.Период";
		
		Выборка = Запрос.Выполнить().Выбрать();
