	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	
	Попытка
		
		// Стратегический
		ВидПлана = Справочники.торо_ВидыСкользящихПланов.Стратегический.ПолучитьОбъект();
		ВидПлана.Использование             = Истина;
		ВидПлана.ПериодичностьПланирования = Перечисления.Периодичность.Год;
		ВидПлана.ЧислоОтображаемыхПериодов = 10;
		ВидПлана.ТочностьПланирования      = Перечисления.торо_ДетализацияПлана.Год;
		ВидПлана.ВидИсполнителяРабот       = Перечисления.торо_ДетализацияИсполнителя.Подразделение;
		
		ВидПлана.Записать();
		
		// Долгосрочный
		ВидПлана = Справочники.торо_ВидыСкользящихПланов.Долгосрочный.ПолучитьОбъект();
		ВидПлана.Использование             = Истина;
		ВидПлана.ПериодичностьПланирования = Перечисления.Периодичность.Год;
