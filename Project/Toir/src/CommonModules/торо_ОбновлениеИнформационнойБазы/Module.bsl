Процедура ОбновлениеУпорядочиванияОбъектовРемонта() Экспорт
	
	НачатьТранзакцию();
	ОшибкаТранзакции = Ложь;
	
	Попытка
	
		ВыборкаСтруктурОР = Справочники.торо_СтруктурыОР.Выбрать();
		
		Пока ВыборкаСтруктурОР.Следующий() Цикл
			
			ЗапросДляПроверкиНаличияДублей = Новый Запрос;
			ЗапросДляПроверкиНаличияДублей.Текст = 
			"ВЫБРАТЬ
			|	торо_ПорядокОРПоИерархии.РеквизитДопУпорядочиванияОР КАК РеквизитДопУпорядочиванияОР,
			|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ торо_ПорядокОРПоИерархии.ОбъектРемонта) КАК ОбъектРемонта
			|ИЗ
			|	РегистрСведений.торо_ПорядокОРПоИерархии КАК торо_ПорядокОРПоИерархии
			|ГДЕ
			|	торо_ПорядокОРПоИерархии.СтруктураИерархии = &СтруктураИерархии
			|
			|СГРУППИРОВАТЬ ПО
			|	торо_ПорядокОРПоИерархии.РеквизитДопУпорядочиванияОР
			|
			|ИМЕЮЩИЕ
			|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ торо_ПорядокОРПоИерархии.ОбъектРемонта) > 1";
												   
			ЗапросДляПроверкиНаличияДублей.Параметры.Вставить("СтруктураИерархии", ВыборкаСтруктурОР.Ссылка);
			РезультатЗапросаДляПроверкиНаличияДублей = ЗапросДляПроверкиНаличияДублей.Выполнить();
			
			Если НЕ РезультатЗапросаДляПроверкиНаличияДублей.Пустой() ИЛИ ВыборкаСтруктурОР.ИзменяетсяДокументами Тогда
				торо_НастройкаПорядкаЭлементовСлужебныйВызовСервера.ПерезаполнитьПорядокЭлементовВИерархии(ВыборкаСтруктурОР.Ссылка);
			КонецЕсли;
			
		КонецЦикла;
	
	Исключение
		
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	НСтр("es='¡La renovación упорядочивания de los objetos de la reparación no es cumplida! Por la causa: ';ru='Обновление упорядочивания объектов ремонта не выполнено! По причине: ';en='Updating ordering of repair objects failed! Due to: '")+ОписаниеОшибки);
		
