			|	ИтоговыеСостояния.ОбъектРемонта,
			|	ИтоговыеСостояния.ВидЭксплуатации1,
			|	ИтоговыеСостояния.ВидЭксплуатации2,
			|	ИтоговыеСостояния.ДатаСреза1,
			|	ИтоговыеСостояния.ДатаСреза2,
			|	ИтоговыеСостояния.ПричинаПростоя,
			|	ТаблицаОбъектовРемонта.Ссылка";
		
		Запрос.УстановитьПараметр("ТаблицаОР",ТаблицаОбъектовРемонта);
