		ВыборкаДокументов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
		
		Пока ВыборкаДокументов.Следующий() Цикл
			
			ДокВыборка = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой); 
			ДокументОбъект = ВыборкаДокументов.Ссылка.ПолучитьОбъект();
			ДокументОбъект.КоэффициентыРемонтныхОсобенностей.Очистить();
			
			Пока ДокВыборка.Следующий() Цикл
				Если ЗначениеЗаполнено(ДокВыборка.ВидКоэффициента) Тогда
					НоваяСтрока = ДокументОбъект.КоэффициентыРемонтныхОсобенностей.Добавить();
