Процедура ДобавитьЗаписиВРегистр(ТаблицаВремяНахожденияВСостоянии)
	
	Для Каждого СтрокаТЗ Из ТаблицаВремяНахожденияВСостоянии Цикл
		
		Эксплуатация = СтрокаТЗ.ВидЭксплуатации;
		
		Если ЗначениеЗаполнено(Эксплуатация) Тогда
						
			Если Эксплуатация.ТипЭксплуатации = Перечисления.торо_ТипЭксплуатации.Эксплуатация Тогда
				
				Если СтрокаТЗ.ВремяПростоя > 0 Тогда
					Движение = РегистрыНакопления.торо_ВремяНахожденияВСостоянии.СоздатьНаборЗаписей();
					Движение.Отбор.Регистратор.Установить(СтрокаТЗ.Ссылка);
					Движение.Прочитать();
					ЗаписьРегистра = Движение.Добавить();
					ЗаписьРегистра.Регистратор 					= СтрокаТЗ.Ссылка;
					ЗаписьРегистра.ВремяНахожденияВСостоянии 	= СтрокаТЗ.ВремяПростоя;
					ЗаписьРегистра.ДатаИзмененияСостояния 		= СтрокаТЗ.ДатаОкончания;
					ЗаписьРегистра.ОбъектРемонта 				= СтрокаТЗ.ОбъектРемонта;
					ЗаписьРегистра.ВидЭксплуатации 				= Эксплуатация;
					ЗаписьРегистра.Период						= СтрокаТЗ.Период;
					Движение.Записать(Истина);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновлениеДокументовПлановыхЗатрат() Экспорт 
	
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		                |	торо_ПлановыеЗатраты.Ссылка КАК Ссылка
		                |ИЗ
		                |	Документ.торо_ПлановыеЗатраты КАК торо_ПлановыеЗатраты
		                |ГДЕ
		                |	торо_ПлановыеЗатраты.Проведен";
		
		Результат = Запрос.Выполнить();
		ВыборкаДокументов = Результат.Выбрать();
		
		Пока ВыборкаДокументов.Следующий() Цикл
			Док = ВыборкаДокументов.Ссылка.ПолучитьОбъект();
			Если НЕ Док = Неопределено Тогда
				Док.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
		КонецЦикла;
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	АктРМ_Мероприятия.Ссылка КАК Ссылка
		               |ИЗ
		               |	Документ.торо_АктОВыполненииРегламентногоМероприятия.Мероприятия КАК АктРМ_Мероприятия
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.торо_ПроцентВыполненныхРабот КАК торо_ПроцентВыполненныхРабот
		               |		ПО АктРМ_Мероприятия.ID = торо_ПроцентВыполненныхРабот.IDРемонта
		               |			И (торо_ПроцентВыполненныхРабот.Регистратор ССЫЛКА Документ.торо_ПлановыеЗатраты)
		               |ГДЕ
					   |    торо_ПроцентВыполненныхРабот.Регистратор ЕСТЬ NULL
		               |	И АктРМ_Мероприятия.Ссылка.Проведен
		               |
					   |СГРУППИРОВАТЬ ПО
					   |	АктРМ_Мероприятия.Ссылка";
		
		Результат = Запрос.Выполнить();
		ВыборкаАктов = Результат.Выбрать();
		
		Пока ВыборкаАктов.Следующий() Цикл
			ДокАкт = ВыборкаАктов.Ссылка.ПолучитьОбъект();
			Если НЕ ДокАкт = Неопределено Тогда
				торо_ПроцентыВыполнения.СоздатьДокументыПлановыхЗатрат(ДокАкт.Мероприятия, ДокАкт.РемонтныеРаботы, Истина);
			КонецЕсли;	
		КонецЦикла;
				
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
									,, НСтр("es='¡La renovación de los documentos ""los gastos Planificados"" no es cumplida! Por la causa: ';ru='Обновление документов ""Плановые затраты"" не выполнено! По причине: ';en='Updating planned cost documents failed! Due to: '") + ОписаниеОшибки);
	КонецПопытки;   
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновлениеРегистраСоставИерархическихТКРемонтов() Экспорт        
	
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	
	Попытка
		
