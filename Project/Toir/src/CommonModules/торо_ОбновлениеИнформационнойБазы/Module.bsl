		Запрос.УстановитьПараметр("ТаблицаОР",ТаблицаОбъектовРемонта);
		Запрос.УстановитьПараметр("ОР",СписокОР);
		
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
