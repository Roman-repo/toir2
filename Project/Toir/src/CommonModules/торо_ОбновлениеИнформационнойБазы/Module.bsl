Процедура ПометкаНаУдалениеНаборовДопРеквизитовОР(Параметры = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НаборыДополнительныхРеквизитовИСведений.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Наборы
	|ИЗ
	|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.НаборыДополнительныхРеквизитовИСведений КАК НаборыДополнительныхРеквизитовИСведений
	|		ПО торо_ОбъектыРемонта.УдалитьНаборСвойств = НаборыДополнительныхРеквизитовИСведений.Ссылка
	|			И (НаборыДополнительныхРеквизитовИСведений.ПометкаУдаления = ЛОЖЬ)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_Наборы.Ссылка КАК Ссылка,
	|	НаборыДополнительныхРеквизитовИСведенийДополнительныеРеквизиты.Свойство КАК Свойство
	|ИЗ
	|	ВТ_Наборы КАК ВТ_Наборы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаборыДополнительныхРеквизитовИСведений.ДополнительныеРеквизиты КАК НаборыДополнительныхРеквизитовИСведенийДополнительныеРеквизиты
	|		ПО ВТ_Наборы.Ссылка = НаборыДополнительныхРеквизитовИСведенийДополнительныеРеквизиты.Ссылка
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ВТ_Наборы.Ссылка,
	|	НаборыДополнительныхРеквизитовИСведенийДополнительныеСведения.Свойство
	|ИЗ
	|	ВТ_Наборы КАК ВТ_Наборы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаборыДополнительныхРеквизитовИСведений.ДополнительныеСведения КАК НаборыДополнительныхРеквизитовИСведенийДополнительныеСведения
	|		ПО ВТ_Наборы.Ссылка = НаборыДополнительныхРеквизитовИСведенийДополнительныеСведения.Ссылка
	|ИТОГИ ПО
	|	Ссылка";
	
	ВыборкаНаборов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	
	Пока ВыборкаНаборов.Следующий() Цикл
		Попытка
			НачатьТранзакцию();
			
			НаборОбъект = ВыборкаНаборов.Ссылка.ПолучитьОбъект();
			Для каждого Строка из НаборОбъект.ДополнительныеРеквизиты Цикл
				Строка.ПометкаУдаления = Истина;
			КонецЦикла;
			Для каждого Строка из НаборОбъект.ДополнительныеСведения Цикл
				Строка.ПометкаУдаления = Истина;
			КонецЦикла;
			НаборОбъект.Записать();
			НаборОбъект.УстановитьПометкуУдаления(Истина);
			
			ВыборкаСвойств = ВыборкаНаборов.Выбрать(ОбходРезультатаЗапроса.Прямой);
			Пока ВыборкаСвойств.Следующий() Цикл
				Если ЗначениеЗаполнено(ВыборкаСвойств.Свойство) Тогда
					СвойствоОбъект = ВыборкаСвойств.Свойство.ПолучитьОбъект();
					СвойствоОбъект.УстановитьПометкуУдаления(Истина);
				КонецЕсли;
			КонецЦикла;
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
			ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
					ВыборкаНаборов.Ссылка,,
					НСтр("es='No consiguió поменить a la desaparición el juego de los requisitos adicionales por la causa: ';ru='Не удалось поменить на удаление набор дополнительных реквизитов по причине: ';en='Failed to change the set of additional details for deletion due to: '") + ОписаниеОшибки);
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновлениеРегистраНакопленияторо_ПлановыеЗатратыЗапчастей() Экспорт
	
	ОшибкаТранзакции = Ложь;
	НачатьТранзакцию();
	
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ТаблицаЗапчастей.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		               |	ТаблицаЗапчастей.Номенклатура КАК Номенклатура,
		               |	ТаблицаЗапчастей.Количество КАК Количество,
		               |	ТаблицаЗапчастей.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
		               |	ТаблицаЗапчастей.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		               |	ТаблицаЗапчастей.Ссылка КАК Ссылка
		               |ПОМЕСТИТЬ ТаблицаЗатратЗапчастей
		               |ИЗ
		               |	Документ.торо_ЗаявкаНаРемонт.ЗапчастиРемонта КАК ТаблицаЗапчастей
		               |ГДЕ
		               |	ТаблицаЗапчастей.Ссылка.Проведен = ИСТИНА
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	торо_ЗаявкаНаРемонтРемонтыОборудования.ID КАК РемонтыОборудования_ID,
		               |	торо_ЗаявкаНаРемонтРемонтыОборудования.ДатаНачала КАК ДатаНачала
		               |ПОМЕСТИТЬ ТаблицаРемонтовОборудования
		               |ИЗ
		               |	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК торо_ЗаявкаНаРемонтРемонтыОборудования
		               |ГДЕ
		               |	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Проведен = ИСТИНА
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаЗатратЗапчастей.Номенклатура КАК Номенклатура,
		               |	СУММА(ВЫБОР
		               |			КОГДА ЕСТЬNULL(ТаблицаЗатратЗапчастей.ЕдиницаИзмерения.Коэффициент, 0) = 0
		               |				ТОГДА 1
		               |			ИНАЧЕ ТаблицаЗатратЗапчастей.ЕдиницаИзмерения.Коэффициент
		               |		КОНЕЦ * ТаблицаЗатратЗапчастей.Количество) КАК Количество,
		               |	ТаблицаЗатратЗапчастей.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
		               |	ТаблицаЗатратЗапчастей.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		               |	ТаблицаЗатратЗапчастей.Ссылка КАК Регистратор,
		               |	торо_ЗаявкаНаРемонтРемонтныеРаботы.ДатаНачала КАК Период
		               |ИЗ
		               |	ТаблицаЗатратЗапчастей КАК ТаблицаЗатратЗапчастей
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРемонтовОборудования КАК торо_ЗаявкаНаРемонтРемонтныеРаботы
		               |		ПО ТаблицаЗатратЗапчастей.РемонтыОборудования_ID = торо_ЗаявкаНаРемонтРемонтныеРаботы.РемонтыОборудования_ID
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ТаблицаЗатратЗапчастей.Номенклатура,
		               |	ТаблицаЗатратЗапчастей.ХарактеристикаНоменклатуры,
		               |	ТаблицаЗатратЗапчастей.РемонтыОборудования_ID,
		               |	ТаблицаЗатратЗапчастей.Ссылка,
		               |	торо_ЗаявкаНаРемонтРемонтныеРаботы.ДатаНачала
		               |ИТОГИ ПО
		               |	Регистратор";
		
		ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Регистратор");
		
		Пока ВыборкаДокументов.Следующий() Цикл
			НаборЗаписей = РегистрыНакопления.торо_ПлановыеЗатратыЗапчастей.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаДокументов.Регистратор);
			НаборЗаписей.Прочитать();
			НаборЗаписей.Очистить();
			
			ВыборкаЗатрат = ВыборкаДокументов.Выбрать();
			Пока ВыборкаЗатрат.Следующий() Цикл
				Запись = НаборЗаписей.Добавить();
				ЗаполнитьЗначенияСвойств(Запись, ВыборкаЗатрат);
			КонецЦикла;	
			НаборЗаписей.Записать();
		КонецЦикла;
			
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
									,,НСтр("es='¡El registro de la acumulación ""los gastos Planificados de las partes de recambio"" no es renovado! Por la causa: ';ru='Регистр накопления ""Плановые затраты запчастей"" НЕ обновлен! По причине: ';en='Accumulation register ""Planned costs of spare parts"" is NOT updated! Due to: '") + ОписаниеОшибки);
	КонецПопытки;   
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;

КонецПроцедуры


#КонецОбласти