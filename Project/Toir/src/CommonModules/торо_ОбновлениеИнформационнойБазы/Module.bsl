Процедура ЗаполнитьОдинРегистрУстановленныхСтатусовДокументов(ИмяРегистра)
	
	НачатьТранзакцию();
	ОшибкаТранзакции = Ложь;
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_СтатусыДокументов.Регистратор КАК Регистратор
		|ИЗ
		|	РегистрСведений."+ИмяРегистра+" КАК торо_СтатусыДокументов
		|ГДЕ
		|	НЕ торо_СтатусыДокументов.Регистратор В
		|				(ВЫБРАТЬ
		|					торо_СтатусыДокументовУстановленные.Регистратор
		|				ИЗ
		|					РегистрСведений."+ИмяРегистра+"Установленные КАК торо_СтатусыДокументовУстановленные)";
		
		ВыборкаРегистраторов = Запрос.Выполнить().Выбрать();
		Пока ВыборкаРегистраторов.Следующий() Цикл
			НаборЗаписейИсходный = Вычислить("РегистрыСведений."+ИмяРегистра+".СоздатьНаборЗаписей()");
			НаборЗаписейИсходный.Отбор.Регистратор.Установить(ВыборкаРегистраторов.Регистратор);
			НаборЗаписейИсходный.Прочитать();
			
			НаборЗаписейНовый = Вычислить("РегистрыСведений."+ИмяРегистра+"Установленные.СоздатьНаборЗаписей()");
			НаборЗаписейНовый.Отбор.Регистратор.Установить(ВыборкаРегистраторов.Регистратор);
			НаборЗаписейНовый.Прочитать();
			НаборЗаписейНовый.Очистить();
			
			Для каждого ЗаписьИсходная из НаборЗаписейИсходный Цикл
				Если ЗаписьИсходная.СтатусУстановлен Тогда
					ЗаписьНовая = НаборЗаписейНовый.Добавить();
					ЗаполнитьЗначенияСвойств(ЗаписьНовая, ЗаписьИсходная);
				КонецЕсли;
			КонецЦикла;
			
			НаборЗаписейНовый.Записать(Истина);
		КонецЦикла;
		
	Исключение
		ОшибкаТранзакции = Истина;
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La renovación de la base informativa';ru='Обновление информационной базы';en='Infobase update'"), УровеньЖурналаРегистрации.Ошибка, 
			,,	СтрШаблон(НСтр("es='¡El relleno del registro %1 no es cumplido! Por la causa: ';ru='Заполнение регистра %1 не выполнено! По причине: ';en='Filling register%1 failed! Due to: '"), ИмяРегистра+"Установленные")+ОписаниеОшибки);
	КонецПопытки;   
	
	Если ОшибкаТранзакции Тогда
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли; 
	
КонецПроцедуры

