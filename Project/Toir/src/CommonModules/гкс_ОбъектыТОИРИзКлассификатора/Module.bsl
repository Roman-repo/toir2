Функция ПолучитьИерархиюОРПоДокументам(Группа)
	
	СтруктураПараметровИерархии = Новый Структура;
	СтруктураПараметровИерархии.Вставить("ИерархическийСправочник", Ложь);
	СтруктураПараметровИерархии.Вставить("ИзменяетсяДокументами", Истина);
	СтруктураПараметровИерархии.Вставить("КонечныеЭлементыВДереве", Истина);
	СтруктураПараметровИерархии.Вставить("РазрешенВводНовыхОР", Истина);
	СтруктураПараметровИерархии.Вставить("РеквизитОР", "");
	СтруктураПараметровИерархии.Вставить("СтроитсяАвтоматически", Ложь);
	СтруктураПараметровИерархии.Вставить("ТекСтруктураИерархии", 
			ПредопределенноеЗначение("Справочник.торо_СтруктурыОР.ОсновнаяИерархия"));
	СтруктураПараметровИерархии.Вставить("ТипРеквизитаОР", "");
	
	МассивГруппОР = Новый Массив;
	
	ИерархияОРРекурсия(СтруктураПараметровИерархии, Группа, МассивГруппОР);
	
	Возврат МассивГруппОР;
		
КонецФункции

Процедура ИерархияОРРекурсия(СтруктураПараметровИерархии, Группа, МассивГруппОР)
	
	МассивСтрок = 
		торо_РаботаСИерархией20.ПолучитьМассивСтрокОдногоУровняИерархииСКоличествомПодчиненных(СтруктураПараметровИерархии, 
															Группа, 
															Ложь, 
															Неопределено, 
															Истина, 
															Неопределено);
															
	Для каждого ТекСтрока Из МассивСтрок Цикл
		
		Если ТекСтрока.ЭтоГруппа Тогда
			
			ИерархияОРРекурсия(СтруктураПараметровИерархии, ТекСтрока.ОбъектРемонта, МассивГруппОР);
			МассивГруппОР.Добавить(ТекСтрока.ОбъектРемонта);
			
		КонецЕсли; 
		
	КонецЦикла; 											
		
КонецПроцедуры    

