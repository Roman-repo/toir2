////////////////////////////////////////////////////////////////////////////////
//
// Функция ЗначениеАтрибута
//
// Описание: Значение атрибута класса.	
//
// Параметры:
//	НомКласса - СправочникСсылка.НоменклатураКласса - Объект ТОИР
//	Атрибут - ПланВидовХарактеристикСсылка.АтрибутыКласса - ОбъектКлассификатора.
//
// Возвращаемое значение: 
//	ЗначениеАтрибутаКласса - ЗначениеАтрибутаКласса.
//
Функция ЗначениеАтрибута(НомКласса, Атрибут)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
		|	ЗначенияАтрибутовКласса.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса
		|ИЗ
		|	РегистрСведений.ЗначенияАтрибутовКласса КАК ЗначенияАтрибутовКласса
		|ГДЕ
		|	ЗначенияАтрибутовКласса.Класс = &Класс
		|	И ЗначенияАтрибутовКласса.АтрибутКласса = &АтрибутКласса";
	
	Запрос.УстановитьПараметр("АтрибутКласса", Атрибут);
	Запрос.УстановитьПараметр("Класс", НомКласса);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();

	Возврат ВыборкаДетальныеЗаписи.ЗначениеАтрибутаКласса;
	
КонецФункции
 
////////////////////////////////////////////////////////////////////////////////
//
// Функция НайтиПоСоответствию
//
// Описание: Поиск объекта ТОИР по ссылке на объект классификатора.	
//
// Параметры:
//	ОбъектКлассификатора - СправочникСсылка.Классы, СправочникСсылка.НоменклатураКласса - Объект ТОИР
//	ТипОбъекта - ПеречислениеСсылка.гкс_ТипОбъектаТОИР - ОбъектКлассификатора.
//
// Возвращаемое значение: 
//	СправочникСсылка - Найденное значение.
//
Функция НайтиПоСоответствию(ОбъектКлассификатора, ТипОбъекта = Неопределено)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	гкс_СоответствиеОбъектовКлассификатораИТОИР.ОбъектТОИР КАК ОбъектТОИР
		|ИЗ
		|	РегистрСведений.гкс_СоответствиеОбъектовКлассификатораИТОИР КАК гкс_СоответствиеОбъектовКлассификатораИТОИР
		|ГДЕ
		|	гкс_СоответствиеОбъектовКлассификатораИТОИР.ОбъектКлассификатора = &ОбъектКлассификатора
		|	И гкс_СоответствиеОбъектовКлассификатораИТОИР.ТипОбъекта = &ТипОбъекта";
	
	Запрос.УстановитьПараметр("ОбъектКлассификатора", ОбъектКлассификатора);
	Запрос.УстановитьПараметр("ТипОбъекта", ТипОбъекта);
	
	Если ТипОбъекта = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И гкс_СоответствиеОбъектовКлассификатораИТОИР.ТипОбъекта = &ТипОбъекта", "");
	КонецЕсли; 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();

	Возврат ВыборкаДетальныеЗаписи.ОбъектТОИР;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ОбработатьСтрокиТехОпераций
//
// Описание: Заполнение списка операций на основании множественных значений атрибутов. 	
// 
// Параметры:
//	ВыборкаСтроки - ВыборкаИзРезультатаЗапроса - ВыборкаИзРезультатаЗапроса
//	СоответствиеСтрокГуИДам - Соответствие - соответствие для связи строк различных табличных частей
//	ТЗСписокОпераций - ТаблицаЗначений - ТЗСписокОпераций.
//
Процедура ОбработатьСтрокиТехОпераций(ВыборкаСтроки,
									СоответствиеСтрокГуИДам,
									ТЗСписокОпераций)
	                                                             
	Пока ВыборкаСтроки.Следующий() Цикл
		ВыборкаСтрокиРодителя = ВыборкаСтроки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСтрокиРодителя.Следующий() Цикл
			ГУИДСтроки = Новый УникальныйИдентификатор;
			СоответствиеСтрокГуИДам.Вставить(ВыборкаСтрокиРодителя.ИДСтроки, ГУИДСтроки);
			СтрокаТЗ = ТЗСписокОпераций.Добавить();
			Выборка = ВыборкаСтрокиРодителя.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтрокаТЗ.ID = ГУИДСтроки;
				Если Выборка.ИмяДляОбменаАтрибутТаблицы = "ВидОперации" Тогда
					СтрокаТЗ.Операция = Выборка.ЗначениеАтрибутаТаблицы;	
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "ДлительностьОперации" Тогда
					СтрокаТЗ.Продолжительность = Выборка.ЗначениеАтрибутаТаблицы;
					Если Выборка.ЗначениеАтрибутаТаблицы = Неопределено Тогда
						СтрокаТЗ.НормаВремениВСекундах = 0;
					Иначе
						СтрокаТЗ.НормаВремениВСекундах = Выборка.ЗначениеАтрибутаТаблицы * 60;
					КонецЕсли; 
				КонецЕсли; 
			КонецЦикла; 
		КонецЦикла; 
	КонецЦикла;
					
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
//
// Функция ОбработатьСтрокиИнструменты
//
// Описание: Заполнение списка Инструментов на основании множественных значений атрибутов. 	
// 
// Параметры:
//	ВыборкаСтроки - ВыборкаИзРезультатаЗапроса - ВыборкаИзРезультатаЗапроса
//	СоответствиеСтрокГуИДам - Соответствие - соответствие для связи строк различных табличных частей
//	ТЗИнструменты - ТаблицаЗначений - ТЗИнструменты.
//
Процедура ОбработатьСтрокиИнструменты(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗИнструменты)
									
	Пока ВыборкаСтроки.Следующий() Цикл
	ВыборкаСтрокиРодителя = ВыборкаСтроки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСтрокиРодителя.Следующий() Цикл
			Выборка = ВыборкаСтрокиРодителя.Выбрать();
			СтрокаТЗ = ТЗИнструменты.Добавить();
			СтрокаТЗ.ID = СоответствиеСтрокГуИДам[ВыборкаСтрокиРодителя.ИДСтрокиРодителя];
			СтрокаТЗ.Количество = 1;
			
			Пока Выборка.Следующий() Цикл							
				Если Выборка.ИмяДляОбменаАтрибутТаблицы = "Номенклатура" Тогда
					СтрокаТЗ.Инструмент = Выборка.ЗначениеАтрибутаТаблицы;	
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "ЕдиницаИзмерения" Тогда
					СтрокаТЗ.ЕдиницаИзмерения = Выборка.ЗначениеАтрибутаТаблицы;	
				КонецЕсли; 														
			КонецЦикла; 
		КонецЦикла; 
	КонецЦикла; 	
	
КонецПроцедуры

