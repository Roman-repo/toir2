// Описание: Заполнение списка материальных затрат на основании множественных значений атрибутов. 	
// 
// Параметры:
//	ВыборкаСтроки - ВыборкаИзРезультатаЗапроса - ВыборкаИзРезультатаЗапроса
//	СоответствиеСтрокГуИДам - Соответствие - соответствие для связи строк различных табличных частей
//	ТЗМатЗатраты - ТаблицаЗначений - ТЗМатЗатраты.
//
Процедура ОбработатьСтрокиМатериальныеЗатраты(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗМатЗатраты)
	
	Пока ВыборкаСтроки.Следующий() Цикл
	ВыборкаСтрокиРодителя = ВыборкаСтроки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСтрокиРодителя.Следующий() Цикл
			Выборка = ВыборкаСтрокиРодителя.Выбрать();
			СтрокаТЗ = ТЗМатЗатраты.Добавить();
			СтрокаТЗ.ID = СоответствиеСтрокГуИДам[ВыборкаСтрокиРодителя.ИДСтрокиРодителя];
			Пока Выборка.Следующий() Цикл
				Если Выборка.ИмяДляОбменаАтрибутТаблицы = "Номенклатура" Тогда
					СтрокаТЗ.Номенклатура = Выборка.ЗначениеАтрибутаТаблицы;	
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "ЕдиницаИзмерения" Тогда
					СтрокаТЗ.ЕдиницаИзмерения = Выборка.ЗначениеАтрибутаТаблицы;	
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "Количество" Тогда
					СтрокаТЗ.Количество = Выборка.ЗначениеАтрибутаТаблицы;	
				КонецЕсли; 														
			КонецЦикла; 
		КонецЦикла; 
	КонецЦикла; 	
	
КонецПроцедуры
 
////////////////////////////////////////////////////////////////////////////////
//
// Функция ОбработатьСтрокиТехКарт
//
// Описание: Заполнение структуру данных тех. карт. 	
// 
// Параметры:
//	ВыборкаСтроки - ВыборкаИзРезультатаЗапроса - ВыборкаИзРезультатаЗапроса
//	СоответствиеСтрокГуИДам - Соответствие - соответствие для связи строк различных табличных частей
//	ИсходящиеДанные - Структура - Данные тех карты.
//
Процедура ОбработатьСтрокиТехКарт(ВыборкаСтроки, СоответствиеСтрокГуИДам, ИсходящиеДанные)
	
	Периодичность = 0;
	Наименование = "";
	СпособПланирования = Неопределено;
	ТипТехКарты = Неопределено;
	
	Пока ВыборкаСтроки.Следующий() Цикл
	ВыборкаСтрокиРодителя = ВыборкаСтроки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСтрокиРодителя.Следующий() Цикл
			Выборка = ВыборкаСтрокиРодителя.Выбрать();
			Пока Выборка.Следующий() Цикл
				Если Выборка.ИмяДляОбменаАтрибутТаблицы = "Периодичность" Тогда
					Периодичность = Выборка.ЗначениеАтрибутаТаблицы;													
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "СпособПланирования" Тогда
					СпособПланирования = Выборка.ЗначениеАтрибутаТаблицы;													
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "ТипТехКарты" Тогда
					ТипТехКарты = Выборка.ЗначениеАтрибутаТаблицы;													
				КонецЕсли; 
				Наименование = Выборка.ЗначениеАтрибутаКласса;
			КонецЦикла; 
		КонецЦикла; 
	КонецЦикла; 
	ИсходящиеДанные.Вставить("НормаВремени", ?(Не ЗначениеЗаполнено(Периодичность), 1, Периодичность));	
	ИсходящиеДанные.Вставить("Наименование", СокрЛП(Наименование));	
	ИсходящиеДанные.Вставить("СпособПланирования", СпособПланирования);	
	ИсходящиеДанные.Вставить("ТипТехКарты", ТипТехКарты);	
	
КонецПроцедуры
 
////////////////////////////////////////////////////////////////////////////////
//
// Функция ДобавитьСтрокуНормативныхРемонтов
//
// Описание: ДобавитьСтрокуНормативныхРемонтов.
//
// Параметры:
//	ТОР - СправочникСсылка.торо_ТиповыеОР  
//	ИдКарта - СправочникСсылка.торо_ИдентификаторыТехКарт
//	ИсходящиеДанные - Структура - Данные тех карты.
//
Процедура ДобавитьСтрокуНормативныхРемонтов(ТОР, ИдКарта, ИсходящиеДанные)
	
	НормРемонт = ТОР.НормативныеРемонты.Добавить();					
	НормРемонт.НормативныйРемонт = ИдКарта;
	НормРемонт.Статус = ПредопределенноеЗначение("Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Редактируется");
	НормРемонт.ГрафикРемонтныхРабот = ПредопределенноеЗначение("Справочник.Календари.Круглосуточно");
	НормРемонт.СпособВыполнения = ПредопределенноеЗначение("Перечисление.СпособыСтроительства.Подрядный");
	НормРемонт.СпособУчетаДатыОтсчета = ПредопределенноеЗначение("Перечисление.торо_СпособыУчетаДатыОтсчетаПриПланированииРемонтныхРабот.ПоПоследнемуРемонтуИлиДатеПланирования");						
	ВидыРемонтов = ТОР.НормативныеРемонты.ВыгрузитьКолонку("ВидРемонта");
	Если ИсходящиеДанные.Свойство("ТипТехКарты") И ЗначениеЗаполнено(ИсходящиеДанные.ТипТехКарты) Тогда
		ВидРемонта = ВидРемонта(ИсходящиеДанные.ТипТехКарты, ВидыРемонтов);
	Иначе
		ВидРемонта = ВидРемонта(ИдКарта, ВидыРемонтов);
	КонецЕсли; 
	НормРемонт.ВидРемонта = ВидРемонта;
	
	Если ИсходящиеДанные.Свойство("СпособПланирования") И ЗначениеЗаполнено(ИсходящиеДанные.СпособПланирования) Тогда
		НормРемонт.СпособПланирования = СпособПланирования(СокрЛП(ИсходящиеДанные.СпособПланирования));						
	Иначе
		НормРемонт.СпособПланирования = ПредопределенноеЗначение("Справочник.торо_СпособыПланированияРемонтныхРабот.Ежегодно");
	КонецЕсли; 
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
//
// Функция СоздатьТехКарту
//
// Описание: Сообщение журнала регистрации	
//
// Параметры:
//	ИсходящиеДанные - Структура - Данные тех карты.
//
// Возвращаемое значение: 
//	СправочникСсылка.торо_ИдентификаторыТехКарт - СправочникСсылка.торо_ИдентификаторыТехКарт.
//
Функция СоздатьТехКарту(ИсходящиеДанные)
	
	НоваяКарта = Ложь;
	ТехКарта = НайтиПоСоответствию(ИсходящиеДанные.ТехКарта, ПредопределенноеЗначение("Перечисление.гкс_ТипОбъектаТОИР.ТехКрата"));	
	Если ТехКарта = Неопределено Тогда
		НоваяКарта = Истина;
		ТехКарта = Справочники.торо_ТехКарты.СоздатьЭлемент();
	Иначе
		ТехКарта = ТехКарта.ПолучитьОбъект();
	КонецЕсли;
	
	ТехКарта.Наименование = ИсходящиеДанные.Наименование;
	ТехКарта.НормаВремени = ИсходящиеДанные.НормаВремени * 3600;
	ТехКарта.ДатаПринятия = НачалоМесяца(ТекущаяДатаСеанса());
	
	ЗаполнитьОперации(ИсходящиеДанные, ТехКарта);
	ЗаполнитьИзмеряемыеПоказатели(ИсходящиеДанные, ТехКарта);
	
	ТехКарта.Записать();		
	
	Если НоваяКарта Тогда
		ИДКарты = СоздатьИДКарту(ТехКарта, ИсходящиеДанные);
	Иначе
		ИДКарты = ПолучитьИДКарты(ТехКарта, ИсходящиеДанные);
	КонецЕсли; 
	
	Возврат ИДКарты;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ВидРемонта
//
// Описание: поиск вида ремонта тех карты.	
//
// Параметры:
//	ИдКарта - СправочникСсылка.торо_ИдентификаторыТехКарт
//	ВидыРемонтов - Массив - Массив видов ремонта.
//
// Возвращаемое значение: 
//	СправочникСсылка.торо_ВидыРемонтов - ВидРемонта.
//
Функция ВидРемонта(ИдКарта, ВидыРемонтов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	торо_ВидыРемонтов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ВидыРемонтов КАК торо_ВидыРемонтов
		|ГДЕ
		|	торо_ВидыРемонтов.Наименование = &Наименование
		|	И НЕ торо_ВидыРемонтов.Ссылка В (&ВидыРемонтов)";
	
	Запрос.УстановитьПараметр("ВидыРемонтов", ВидыРемонтов);
	Запрос.УстановитьПараметр("Наименование", ИДКарта.Наименование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	ВидРемонта = ВыборкаДетальныеЗаписи.Ссылка;
	Если Не ЗначениеЗаполнено(ВидРемонта) Тогда
		НовыйВидРемонта = Справочники.торо_ВидыРемонтов.СоздатьЭлемент();
		НовыйВидРемонта.Наименование = ИдКарта.Наименование;
		НовыйВидРемонта.ГрафикМероприятий = Истина;
		НовыйВидРемонта.ПланГрафикППР = Истина;
		НовыйВидРемонта.Записать();
		ВидРемонта = НовыйВидРемонта.Ссылка;
	КонецЕсли; 
	
	Возврат ВидРемонта;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция СпособПланирования
//
// Описание: Возвращает ссылку на способ планирования ремонтных работ.
//
// Параметры:
//	СпособПланированияИмя - Строка
//
// Возвращаемое значение: 
//	СправочникСсылка.торо_СпособыПланированияРемонтныхРабот - СправочникСсылка.торо_СпособыПланированияРемонтныхРабот.
//
Функция СпособПланирования(СпособПланированияИмя)
	
	СпособПланирования = торо_СпособыПланированияРемонтныхРаботПоНаименованию(СпособПланированияИмя);
	Если Не ЗначениеЗаполнено(СпособПланирования) Тогда
		НовыйСпособПланирования = Справочники.торо_СпособыПланированияРемонтныхРабот.СоздатьЭлемент();
		НовыйСпособПланирования.Наименование = СпособПланированияИмя;
		НовыйСпособПланирования.Записать();
		СпособПланирования = НовыйСпособПланирования.Ссылка;
	КонецЕсли; 
	
	Возврат СпособПланирования;
	
КонецФункции      

////////////////////////////////////////////////////////////////////////////////
//
// Функция ЗаполнитьОперации
//
// Описание: Заполнение списка операций в тех карте.
//
// Параметры:
//	ИсходящиеДанные - Структура
//	ТехКарта - СправочникСсылка.торо_ТехКарты - заполняемая тех карта.
//
Процедура ЗаполнитьОперации(ИсходящиеДанные, ТехКарта)
	
	ТехКарта.СписокОпераций.Очистить();
		
	Операции = ИсходящиеДанные.СписокОпераций;
	Для каждого ТекСтрока Из Операции Цикл
		Если ТекСтрока.Операция = Неопределено Тогда
			Продолжить;			
		КонецЕсли; 
		
		ТехОперация = НайтиПоСоответствию(ТекСтрока.Операция);
		Если ТехОперация = Неопределено Тогда
			ТехОперация = Справочники.торо_ТехнологическиеОперации.СоздатьЭлемент();
		Иначе
		    ТехОперация = ТехОперация.ПолучитьОбъект();
		КонецЕсли; 
		
		ТехОперация.Наименование = ТекСтрока.Операция.Наименование;
		ТехОперация.НормаВремени = ТекСтрока.НормаВремениВСекундах;
		
		ТехОперация.Записать();
		
		ДобавитьСоответствиеОбъектов(ТехОперация.Ссылка, ТекСтрока.Операция);
		
		НовСтрока = ТехКарта.СписокОпераций.Добавить();
		НовСтрока.ID = ТекСтрока.ID;
		НовСтрока.Количество = 1;
		НовСтрока.Продолжительность = ТекСтрока.НормаВремениВСекундах;
		НовСтрока.Операция = ТехОперация.Ссылка;		
		
	КонецЦикла;     		

КонецПроцедуры 

////////////////////////////////////////////////////////////////////////////////
//
// Функция ЗаполнитьИзмеряемыеПоказатели
//
// Описание: Заполнение списка измеряемых показателей в тех карте.
//
// Параметры:
//	ИсходящиеДанные - Структура
//	ТехКарта - СправочникСсылка.торо_ТехКарты - заполняемая тех карта.
//
Процедура ЗаполнитьИзмеряемыеПоказатели(ИсходящиеДанные, ТехКарта)
	
	ИзмеряемыеПоказатели = ИсходящиеДанные.ИзмеряемыеПоказатели;
	ИзмеряемыеПоказателиТОиР = ТехКарта.ИзмеряемыеПоказатели;
	
	ИзмеряемыеПоказателиТОиР.Очистить();
	Для каждого ТекПоказатель Из ИзмеряемыеПоказатели Цикл
		НоваяСтрока = ИзмеряемыеПоказателиТОиР.Добавить();
		ПоказательТОИР = СсылкаНаПоказатель(ТекПоказатель.Показатель, ТекПоказатель.ЕдиницаИзмерения);
		НоваяСтрока.ID = ТекПоказатель.ID;
		НоваяСтрока.Показатель = ПоказательТОИР;
	КонецЦикла; 

КонецПроцедуры 

////////////////////////////////////////////////////////////////////////////////
//
// Функция ПолучитьИДКарты
//
// Описание: Поиск Идентификатора Тех карты по ссылке на тех карту.
//
// Параметры:
//	ТехКарта - СправочникСсылка.торо_ТехКарты - заполняемая тех карта.
//	ИсходящиеДанные - Структура
//
// Возвращаемое значение: 
//	СправочникСсылка.торо_ИдентификаторыТехКарт - торо_ИдентификаторыТехКарт.
//
Функция ПолучитьИДКарты(ТехКарта, ИсходящиеДанные)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
		|	торо_ВерсииТехКартСрезПоследних.ИдентификаторТехКарты КАК ИдентификаторТехКарты
		|ИЗ
		|	РегистрСведений.торо_ВерсииТехКарт.СрезПоследних КАК торо_ВерсииТехКартСрезПоследних
		|ГДЕ
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта = &ТехКарта";
	
	Запрос.УстановитьПараметр("ТехКарта", ТехКарта.ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат СоздатьИДКарту(ТехКарта, ИсходящиеДанные);		
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	Возврат ВыборкаДетальныеЗаписи.ИдентификаторТехКарты;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция СоздатьИДКарту
//
// Описание: Создает элемент справочника торо_ИдентификаторыТехКарт.
//
// Параметры:
//	ТехКарта - СправочникСсылка.торо_ТехКарты - заполняемая тех карта.
//	ИсходящиеДанные - Структура
//
// Возвращаемое значение: 
//	СправочникСсылка.торо_ИдентификаторыТехКарт - торо_ИдентификаторыТехКарт.
//
Функция СоздатьИДКарту(ТехКарта, ИсходящиеДанные)
	
	ИдентификаторТехКарты = Справочники.торо_ИдентификаторыТехКарт.СоздатьЭлемент();
	ИдентификаторТехКарты.Наименование = ИсходящиеДанные.Наименование;
	ИдентификаторТехКарты.Статус = ПредопределенноеЗначение("Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Действует");
	ИдентификаторТехКарты.Записать();
	
	ДобавитьСоответствиеОбъектов(ТехКарта.Ссылка, ИсходящиеДанные.ТехКарта, ПредопределенноеЗначение("Перечисление.гкс_ТипОбъектаТОИР.ТехКрата"));
	
	НаборЗаписейИдентификатора = РегистрыСведений.торо_ВерсииТехКарт.СоздатьНаборЗаписей();
	НаборЗаписейИдентификатора.Отбор.ИдентификаторТехКарты.Установить(ИдентификаторТехКарты.Ссылка);
	НоваяЗапись = НаборЗаписейИдентификатора.Добавить();
	НоваяЗапись.Период = НачалоМесяца(ТекущаяДатаСеанса());
	НоваяЗапись.ИдентификаторТехКарты = ИдентификаторТехКарты.Ссылка;
	НоваяЗапись.ТехКарта = ТехКарта.Ссылка;
	НаборЗаписейИдентификатора.Записать();		
	
	Возврат ИдентификаторТехКарты.Ссылка;
		
КонецФункции          

////////////////////////////////////////////////////////////////////////////////
//
// Функция СсылкаНаПоказатель
//
// Описание: Получает ссылку на измеряемый показатель.
//
// Параметры:
//	ТекПоказатель - СправочникСсылка.НоменклатураКласса - показатель в классификаторе.
//	ЕдиницаИзмерения - СправочникСсылка.ЕдиницыИзмерения.
//
// Возвращаемое значение: 
//	ПланВидовХарактеристик.торо_ИзмеряемыеПоказателиОбъектовРемонта - Измеряемы показатель.
//
Функция СсылкаНаПоказатель(ТекПоказатель, ЕдиницаИзмерения)
	
	Если Не ЗначениеЗаполнено(ТекПоказатель) Тогда
		Возврат Неопределено;		
	КонецЕсли; 
	
	ЕдИзмИмя = "";
	
	ТекПоказательИмя = гкс_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекПоказатель, "Наименование");
	Если ЗначениеЗаполнено(ЕдиницаИзмерения) Тогда
		ЕдИзмИмя = гкс_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЕдиницаИзмерения, "Наименование");
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
		|	ПоказателиТОИР.Ссылка КАК Ссылка
		|ИЗ
		|	ПланВидовХарактеристик.торо_ИзмеряемыеПоказателиОбъектовРемонта КАК ПоказателиТОИР
		|ГДЕ
		|	ПоказателиТОИР.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", ТекПоказательИмя);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		НовыйПоказатель = ПланыВидовХарактеристик.торо_ИзмеряемыеПоказателиОбъектовРемонта.СоздатьЭлемент();
		НовыйПоказатель.Наименование = ТекПоказательИмя;
		Если ЕдИзмИмя <> "" Тогда
			ЕдИзм = ЕдИзмПоИмени(ЕдИзмИмя);
			НовыйПоказатель.ЕдиницаИзмерения = ЕдИзм;    			
		КонецЕсли; 
		НовыйПоказатель.Записать();		
		Возврат НовыйПоказатель.Ссылка;
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	ПоказательТОИР = ВыборкаДетальныеЗаписи.Ссылка;
	Если ЗначениеЗаполнено(ПоказательТОИР) И Не ЗначениеЗаполнено(ПоказательТОИР.ЕдиницаИзмерения) Тогда
		ПоказательТОИРОбъект = ПоказательТОИР.ПолучитьОбъект();		
		ПоказательТОИРОбъект.ЕдиницаИзмерения = ЕдИзмПоИмени(ЕдИзмИмя);
		ПоказательТОИРОбъект.Записать();
		ПоказательТОИР = ПоказательТОИРОбъект.Ссылка;
	КонецЕсли; 
	
	Возврат ПоказательТОИР;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ЕдИзмПоИмени
//
// Описание: Сообщение журнала регистрации	
//
// Возвращаемое значение: 
//	Строка - Сообщение журнала регистрации.
//
Функция ЕдИзмПоИмени(ЕдИзмИмя)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
		|	ЕдиницыИзмерения.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
		|ГДЕ
		|	ЕдиницыИзмерения.НаименованиеПолное = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", ЕдИзмИмя);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		ЕдИзм = ДобавитьЕдИзмИзКлассификатора(ЕдИзмИмя);	
		
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	ЕдИзм = ВыборкаДетальныеЗаписи.Ссылка;
	
	Возврат ЕдИзм;	
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ДобавитьЕдИзмИзКлассификатора
//
// Описание: Сообщение журнала регистрации	
//
// Возвращаемое значение: 
//	Строка - Сообщение журнала регистрации.
//
Функция ДобавитьЕдИзмИзКлассификатора(ЕдИзмИмя)
	
	ЕдИзм = Неопределено;
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла();
	Макет = Справочники.ЕдиницыИзмерения.ПолучитьМакет("КлассификаторЕдиницИзмерения");
	Макет.Записать(ИмяВременногоФайла);
	Дерево = ЗначениеИзФайла(ИмяВременногоФайла);
	
	СтрокаДерева = Дерево.Строки.Найти(ЕдИзмИмя, "Наименование", Истина);
	
	Если ЗначениеЗаполнено(СтрокаДерева) Тогда
		СправочникОбъект = Справочники.ЕдиницыИзмерения.СоздатьЭлемент();
			
		Если ЗначениеЗаполнено(СтрокаДерева.УсловноеОбозначениеНациональное) Тогда
			Наименование = СтрокаДерева.УсловноеОбозначениеНациональное;
		ИначеЕсли ЗначениеЗаполнено(СтрокаДерева.УсловноеОбозначениеМеждународное) Тогда
			Наименование = СтрокаДерева.УсловноеОбозначениеМеждународное;
		ИначеЕсли ЗначениеЗаполнено(СтрокаДерева.КодовоеБуквенноеОбозначениеНациональное) Тогда
			Наименование = СтрокаДерева.КодовоеБуквенноеОбозначениеНациональное;
		ИначеЕсли ЗначениеЗаполнено(СтрокаДерева.КодовоеБуквенноеОбозначениеМеждународное) Тогда
			Наименование = СтрокаДерева.КодовоеБуквенноеОбозначениеМеждународное;
		Иначе
			Наименование = СтрокаДерева.Наименование;
		КонецЕсли;
			
		СправочникОбъект.Наименование            = СтрЗаменить(Наименование,Символы.ПС,"/");
		СправочникОбъект.МеждународноеСокращение = СтрЗаменить(СтрокаДерева.КодовоеБуквенноеОбозначениеМеждународное,Символы.ПС,"/");
		СправочникОбъект.НаименованиеПолное      = СтрЗаменить(СтрокаДерева.Наименование,Символы.ПС,"/");
		СправочникОбъект.Код                     = СтрокаДерева.КодЧисловой;
		
		Если СтрокаДерева.ВесоваяЕдиницаИзмерения Тогда
			СправочникОбъект.ТипЕдиницыИзмерения = Перечисления.ТипыЕдиницИзмерения.Весовая;
		Иначе
			КодыШтучныхТоваров = КодыШтучныхТоваров();
			Если КодыШтучныхТоваров.Найти(СтрокаДерева.КодЧисловой) <> Неопределено Тогда
				СправочникОбъект.ТипЕдиницыИзмерения = Перечисления.ТипыЕдиницИзмерения.Штучная;
			КонецЕсли;
		КонецЕсли;
		
		СправочникОбъект.Записать();
		
		ЕдИзм = СправочникОбъект.Ссылка;
	КонецЕсли;
	
	Возврат ЕдИзм;
	
КонецФункции

