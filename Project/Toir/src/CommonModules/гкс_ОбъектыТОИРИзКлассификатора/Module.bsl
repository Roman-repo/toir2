#Область СлужебныеПроцедурыИФункции

////////////////////////////////////////////////////////////////////////////////
//
// Процедура СоздатьОбъектыТОИР
//
// Описание: Создает объекты ТОИР из объектов Классификатора.
//
Процедура СоздатьОбъектыТОИР() Экспорт
	
	Отказ = Ложь;
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.гкс_СоздатьОбъектыТОИРИзКлассификатора);
	
	ИмяСобытия = ИмяСобытияЖурналаРегистрации();
	
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация, , ,
		НСтр("ru = 'Начато регламентное создание объектов ТОИР'"));
	
	СозданиеТОР();
	СозданиеОР();
		
	Если Отказ Тогда
		ЗаписьЖурналаРегистрации(
			ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка,
			, 
			,
			НСтр("ru = 'Во время создания объектов ТОИР произошли ошибки'"));
		ВызватьИсключение НСтр("ru = 'Регламентное задание не выполнено.'");
	Иначе
		ЗаписьЖурналаРегистрации(
			ИмяСобытия,
			УровеньЖурналаРегистрации.Информация,
			,
			,
			НСтр("ru = 'Завершено регламентное создание объектов ТОИР.'"));
	КонецЕсли;	
	
КонецПроцедуры 

////////////////////////////////////////////////////////////////////////////////
//
// Функция ИмяСобытияЖурналаРегистрации
//
// Описание: Сообщение журнала регистрации	
//
// Возвращаемое значение: 
//	Строка - Сообщение журнала регистрации.
//
Функция ИмяСобытияЖурналаРегистрации() Экспорт
	Возврат НСтр("ru = 'Загрузка заданий из Jira'", ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка());
КонецФункции

#Область ТиповыеОбъектыРемонта  

////////////////////////////////////////////////////////////////////////////////
//
// Функция СозданиеТОР
//
// Описание: Создание типовых объектов ремонта.
//
Процедура СозданиеТОР()
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	СоздатьИерархиюНаСервере(МенеджерВТ);
	СоздатьТиповыеОрНаСервере(МенеджерВТ);
		
КонецПроцедуры  

////////////////////////////////////////////////////////////////////////////////
//
// Функция СоздатьИерархиюНаСервере
//
// Описание: Создание новых групп типовых объектов ремонта.
//
// Параметры 
//	МенеджерВТ - МенеджерВременныхТаблиц - МенеджерВременныхТаблиц.
//
Процедура СоздатьИерархиюНаСервере(МенеджерВТ)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст = ТекстЗапроса_ТиповыеОРКДобавлению();
			
	Запрос.УстановитьПараметр("Оборудование", 
		ПредопределенноеЗначение("Справочник.Классы.Оборудование"));
	Запрос.УстановитьПараметр("КодГруппы", 
		ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.КодГруппы"));
	Запрос.УстановитьПараметр("ВыгружатьОР", 
		ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ВыгружатьВТиповыеОР"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		КодГруппыСсылка = Выборка.СсылкаГруппыОборудования;
		
		Если Выборка.СоздатьКодГруппы Тогда
			
			КодГруппы = Справочники.гкс_ГруппыОборудования.СоздатьЭлемент();
			
			КодГруппы.Наименование = Выборка.ИмяГруппыОборудования;
			КодГруппы.Код = Выборка.КодГруппыОборудования;
			КодГруппы.Записать();
			
			ДобавитьСоответствиеОбъектов(Выборка.СсылкаГруппы, КодГруппы.Ссылка);
			КодГруппыСсылка = КодГруппы.Ссылка;
			
		КонецЕсли; 
		
		Если Не ЗначениеЗаполнено(Выборка.ГруппаТОР) Тогда
			ГруппаТОР = Справочники.торо_ТиповыеОР.СоздатьГруппу();
		
			ГруппаТОР.Наименование = Выборка.КлассНаименование;
			ГруппаТОР.КодГруппы = КодГруппы;
			Если ЗначениеЗаполнено(Выборка.ГруппаТОРРодитель) Тогда
				ГруппаТОР.Родитель = Выборка.ГруппаТОРРодитель;						
			КонецЕсли; 
			ГруппаТОР.Записать();
		КонецЕсли; 
	КонецЦикла;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
//
// Функция СоздатьТиповыеОрНаСервере
//
// Описание: Создание новых типовых объектов.
//
// Параметры 
//	МенеджерВТ - МенеджерВременныхТаблиц - МенеджерВременныхТаблиц.
//
Процедура СоздатьТиповыеОрНаСервере(МенеджерВТ)
	
	ГруппыОборудования = СоответствиеГруппыОборудования();
	
	ОбъектыДляЗаполнения = ПодготовитьОбъектыДляЗаполнения();
	
	СтрокиТабличныхАтрибутов = ОбъектыДляЗаполнения.СтрокиТабличныхАтрибутов;
	ЗначенияТабличныхАтрибутов = ОбъектыДляЗаполнения.ЗначенияТабличныхАтрибутов;
	ТЗМатЗатраты = ОбъектыДляЗаполнения.ТЗМатЗатраты;
	ТЗПоказатели = ОбъектыДляЗаполнения.ТЗПоказатели;
	ТЗИсполнитель = ОбъектыДляЗаполнения.ТЗИсполнитель;
	ТЗИнструменты = ОбъектыДляЗаполнения.ТЗИнструменты;
	ТЗСписокОпераций = ОбъектыДляЗаполнения.ТЗСписокОпераций;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст = ТекстЗапроса_НоменклатураКласса();
	Запрос.УстановитьПараметр("ТипОбъекта", ПредопределенноеЗначение("Перечисление.гкс_ТипОбъектаТОИР.ПустаяСсылка")); 
	
	РезультатЗапросаТОР = Запрос.Выполнить();
	
	ВыборкаТОР = РезультатЗапросаТОР.Выбрать();
	Пока ВыборкаТОР.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаТОР.ТОРСсылкаПоРегистру) Тогда
			ТОР = ВыборкаТОР.ТОРСсылкаПоРегистру.ПолучитьОбъект();
		Иначе
			ТОР = Справочники.торо_ТиповыеОР.СоздатьЭлемент();
		КонецЕсли; 
		
		ТОР.Наименование = ВыборкаТОР.Наименование;
		Если ЗначениеЗаполнено(ВыборкаТОР.ТОРРодитель) Тогда
			ТОР.Родитель = ВыборкаТОР.ТОРРодитель;	
		КонецЕсли; 
		ТОР.ТипОбъекта = ПредопределенноеЗначение("Перечисление.торо_ТипыОбъектовRCM.Объект");

		ТЗМатЗатраты.Очистить();
		ТЗПоказатели.Очистить();
		ТЗИсполнитель.Очистить();
		ТЗИнструменты.Очистить();
		СтрокиТабличныхАтрибутов.Очистить();
		ЗначенияТабличныхАтрибутов.Очистить();	

		НоменклатураКласса = ВыборкаТОР.Ссылка;

		СписокРодителей  = Справочники.Классы.ПолучитьТаблицуРодителей(НоменклатураКласса.Класс);

		ТаблицаАтрибутов = Справочники.Классы.ПолучитьТаблицуАтрибутов(СписокРодителей);
		
		СтрокаПроизводитель = 
			ТаблицаАтрибутов.НайтиСтроки(Новый Структура("АтрибутКласса", 
				ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.Производитель")));
		Если СтрокаПроизводитель.Количество() > 0 Тогда
			ТОР.Изготовитель = Строка(СтрокаПроизводитель[0].ЗначениеАтрибутаКласса);
			Если Не ЗначениеЗаполнено(Тор.Изготовитель) Тогда
				ТОР.Изготовитель = ЗначениеАтрибута(ВыборкаТОР.Ссылка, 
									ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.Производитель"));
			КонецЕсли; 			
		КонецЕсли; 	
		СтрокаКодГруппы = 
			ТаблицаАтрибутов.НайтиСтроки(Новый Структура("АтрибутКласса", 
				ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.КодГруппы")));
		Если СтрокаКодГруппы.Количество() > 0 Тогда
			КодГруппы = СтрокаКодГруппы[0].ЗначениеАтрибутаКласса;
			КодГруппыТОИР = НайтиПоСоответствию(КодГруппы);
			Если Не ЗначениеЗаполнено(КодГруппыТОИР) Тогда
				ПоискКодГруппыТОИР = ГруппыОборудования[КодГруппы.Код];
				Если ПоискКодГруппыТОИР = Неопределено Тогда
					КодГруппыТОИР = Справочники.гкс_ГруппыОборудования.СоздатьЭлемент();
					КодГруппыТОИР.Наименование = КодГруппы.Наименование;
					КодГруппыТОИР.Код = КодГруппы.Код;
					КодГруппыТОИР.Записать();
				Иначе
					КодГруппыТОИР = ПоискКодГруппыТОИР;
				КонецЕсли; 
				
				ДобавитьСоответствиеОбъектов(КодГруппы.Ссылка, КодГруппыТОИР.Ссылка);
			КонецЕсли; 
			ТОР.КодГруппы = КодГруппыТОИР;
		КонецЕсли; 	
		
		ДанныеТабличныхАтрибутов = ТаблицаАтрибутов.Скопировать(Новый Структура("КлассТабличнаяЧасть", Истина), "АтрибутКласса").ВыгрузитьКолонку("АтрибутКласса");

		РегистрыСведений.МножественныеЗначенияАтрибутов.ПрочитатьЗначенияТабличныхАтрибутов(НоменклатураКласса, 
																				Неопределено, 
																				ДанныеТабличныхАтрибутов, 
																				1, 
																				Неопределено, 
																				СтрокиТабличныхАтрибутов, 
																				ЗначенияТабличныхАтрибутов);

		БылиПустыеСтроки = Ложь;																				
		Для каждого ТекСтрока Из СтрокиТабличныхАтрибутов Цикл
			Если Не ЗначениеЗаполнено(ТекСтрока.ЗначениеАтрибутаКласса) Тогда
				ТекСтрока.ЗначениеАтрибутаКласса = ТекСтрока.ИсточникЗначений;					
				Если Не ЗначениеЗаполнено(ТекСтрока.Наименование) Тогда
					ТекСтрока.Наименование = Строка(ТекСтрока.ИсточникЗначений);
				КонецЕсли; 
				БылиПустыеСтроки = Истина;
			КонецЕсли; 
		КонецЦикла; 			
		
		АтрибутТехКарта = ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ТехКарты");
		ТехКарты = СтрокиТабличныхАтрибутов.НайтиСтроки(Новый Структура("АтрибутКласса", АтрибутТехКарта));

		СоответствиеИДСтрокИНомеровТехКарт = Новый Соответствие;	
		Для каждого ТехКарта Из ТехКарты Цикл
			ТехКарта.ТехКарта = ТехКарта.ЗначениеАтрибутаКласса;
			СоответствиеИДСтрокИНомеровТехКарт.Вставить(ТехКарта.ИдСтроки, ТехКарта.ЗначениеАтрибутаКласса);
		КонецЦикла; 

		Для каждого ТекСтрока Из СтрокиТабличныхАтрибутов Цикл
			Если ТекСтрока.ИДСтрокиРодителя = 0 Тогда
				Продолжить;			
			КонецЕсли;     		
			ТекСтрока.ТехКарта = СоответствиеИДСтрокИНомеровТехКарт[ТекСтрока.ИДСтрокиРодителя];
			СоответствиеИДСтрокИНомеровТехКарт.Вставить(ТекСтрока.ИДСтроки, ТекСтрока.ТехКарта);
		КонецЦикла; 														
											
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("СтрокиТабличныхАтрибутов", СтрокиТабличныхАтрибутов);
		Запрос.УстановитьПараметр("ЗначенияТабличныхАтрибутов", ЗначенияТабличныхАтрибутов);
		Запрос.Текст = ТекстЗапроса_ТехКарты();    					
		РезультатЗапросаТК = Запрос.Выполнить();

		СоответствиеСтрокГуИДам = Новый Соответствие;

		ВыборкаТехКарта = РезультатЗапросаТК.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаТехКарта.Следующий() Цикл
			ТЗСписокОпераций.Очистить();
			СпособПланирования = Неопределено;
			ТипТехКарты = Неопределено;
			ИсходящиеДанные = новый Структура;
			ИсходящиеДанные.Вставить("НормаВремени", 0);
			Если ВыборкаТехКарта.ТехКарта = ПредопределенноеЗначение("Справочник.НоменклатураКласса.ПустаяСсылка") Тогда
				Продолжить;			
			КонецЕсли; 
			ИсходящиеДанные.Вставить("ТехКарта", ВыборкаТехКарта.ТехКарта);
			ИсходящиеДанные.Вставить("Наименование", СокрЛП(ВыборкаТехКарта.ТехКарта));
			ВыборкаАтрибут = ВыборкаТехКарта.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаАтрибут.Следующий() Цикл
				ВыборкаСтроки = ВыборкаАтрибут.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Если ВыборкаАтрибут.ИмяДляОбмена = "ТехОперации" Тогда
					ОбработатьСтрокиТехОпераций(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗСписокОпераций);             					 		
				ИначеЕсли ВыборкаАтрибут.ИмяДляОбмена = "Инструменты" Тогда
					ОбработатьСтрокиИнструменты(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗИнструменты);    					
				ИначеЕсли ВыборкаАтрибут.ИмяДляОбмена = "Исполнители" Тогда
					ОбработатьСтрокиИсполнители(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗИсполнитель);
				ИначеЕсли ВыборкаАтрибут.ИмяДляОбмена = "Показатели" Тогда
					ОбработатьСтрокиПоказатели(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗПоказатели, ТЗСписокОпераций);
				ИначеЕсли ВыборкаАтрибут.ИмяДляОбмена = "МатериальныеЗатраты" Тогда				 
					ОбработатьСтрокиМатериальныеЗатраты(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗМатЗатраты);
				ИначеЕсли ВыборкаАтрибут.ИмяДляОбмена = "ТехКарта" Тогда				 
					ОбработатьСтрокиТехКарт(ВыборкаСтроки, СоответствиеСтрокГуИДам, ИсходящиеДанные);
				КонецЕсли; 
			КонецЦикла;   
			
			ИсходящиеДанные.Вставить("СписокОпераций", 			ТЗСписокОпераций);
			ИсходящиеДанные.Вставить("ИнструментыИТехника", 	ТЗИнструменты);
			ИсходящиеДанные.Вставить("СписокИсполнителей", 		ТЗИсполнитель);
			ИсходящиеДанные.Вставить("ИзмеряемыеПоказатели",	ТЗПоказатели);
			ИсходящиеДанные.Вставить("МатериальныеЗатраты", 	ТЗМатЗатраты);

			Если ИсходящиеДанные.Наименование <> "" Тогда
					
				ИдКарта =  СоздатьТехКарту(ИсходящиеДанные);  
				Если ЗначениеЗаполнено(ИдКарта) Тогда
					ДобавитьСтрокуНормативныхРемонтов(ТОР, ИдКарта, ИсходящиеДанные);  				
				КонецЕсли; 
			КонецЕсли; 
			
		КонецЦикла;
		
		ТОР.Записать();
		
		ДобавитьСоответствиеОбъектов(ТОР.Ссылка, ВыборкаТОР.Ссылка);
		
	КонецЦикла;  
	
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
//
// Функция ТекстЗапроса_ТиповыеОРКДобавлению
//
// Описание: ТекстЗапроса_ТиповыеОРКДобавлению.
//
// Возвращаемое значение: 
//	Строка - ТекстЗапроса.
//
Функция ТекстЗапроса_ТиповыеОРКДобавлению()
	
	Возврат "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	        |	Классы.Ссылка КАК Ссылка
	        |ПОМЕСТИТЬ ВыгружаемаяИерархия
	        |ИЗ
	        |	Справочник.Классы КАК Классы
	        |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияАтрибутовКласса КАК ЗначенияАтрибутовКласса
	        |		ПО Классы.Ссылка = ЗначенияАтрибутовКласса.Класс
	        |ГДЕ
	        |	ЗначенияАтрибутовКласса.АтрибутКласса = &ВыгружатьОР
	        |	И ЗначенияАтрибутовКласса.ЗначениеАтрибутаКласса = ИСТИНА
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	Классы.Ссылка КАК Ссылка,
	        |	Классы.Наименование КАК Наименование,
	        |	Классы.Родитель.Наименование КАК Родитель,
	        |	Классы.Родитель КАК РодительСсылка
	        |ПОМЕСТИТЬ ВыгружаемыеКлассы
	        |ИЗ
	        |	Справочник.Классы КАК Классы
	        |ГДЕ
	        |	Классы.Ссылка В ИЕРАРХИИ
	        |			(ВЫБРАТЬ
	        |				ВыгружаемаяИерархия.Ссылка КАК Ссылка
	        |			ИЗ
	        |				ВыгружаемаяИерархия КАК ВыгружаемаяИерархия)
	        |	И Классы.Ссылка <> &Оборудование
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ЗначенияАтрибутовКласса.Класс КАК Класс,
	        |	ВЫРАЗИТЬ(ЗначенияАтрибутовКласса.ЗначениеАтрибутаКласса КАК Справочник.ВариантыЗначенийАтрибутовКласса).Наименование КАК ИмяГруппы,
	        |	ВЫРАЗИТЬ(ЗначенияАтрибутовКласса.ЗначениеАтрибутаКласса КАК Справочник.ВариантыЗначенийАтрибутовКласса).Код КАК КодГруппы,
	        |	ВЫРАЗИТЬ(ЗначенияАтрибутовКласса.ЗначениеАтрибутаКласса КАК Справочник.ВариантыЗначенийАтрибутовКласса).Ссылка КАК СсылкаГруппы
	        |ПОМЕСТИТЬ КодыГрупп
	        |ИЗ
	        |	РегистрСведений.ЗначенияАтрибутовКласса КАК ЗначенияАтрибутовКласса
	        |ГДЕ
	        |	ЗначенияАтрибутовКласса.Класс В
	        |			(ВЫБРАТЬ
	        |				ВыгружаемыеКлассы.Ссылка КАК Ссылка
	        |			ИЗ
	        |				ВыгружаемыеКлассы КАК ВыгружаемыеКлассы)
	        |	И ЗначенияАтрибутовКласса.АтрибутКласса = &КодГруппы
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	торо_ТиповыеОР.Ссылка КАК Ссылка,
	        |	торо_ТиповыеОР.Наименование КАК Наименование
	        |ПОМЕСТИТЬ ГруппыТиповыхОР
	        |ИЗ
	        |	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
	        |ГДЕ
	        |	торо_ТиповыеОР.ЭтоГруппа
	        |	И торо_ТиповыеОР.Наименование В
	        |			(ВЫБРАТЬ
	        |				ВыгружаемыеКлассы.Наименование КАК Наименование
	        |			ИЗ
	        |				ВыгружаемыеКлассы КАК ВыгружаемыеКлассы)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ВыгружаемыеКлассы.Ссылка КАК КлассСсылка,
	        |	ВыгружаемыеКлассы.Наименование КАК КлассНаименование,
	        |	ВЫБОР
	        |		КОГДА ВыгружаемыеКлассы.РодительСсылка В
	        |				(ВЫБРАТЬ
	        |					ВыгружаемыеКлассы.Ссылка КАК Ссылка
	        |				ИЗ
	        |					ВыгружаемыеКлассы КАК ВыгружаемыеКлассы)
	        |			ТОГДА ВыгружаемыеКлассы.Родитель
	        |		ИНАЧЕ """"
	        |	КОНЕЦ КАК КлассРодитель,
	        |	ГруппыТиповыхОР.Ссылка КАК ГруппаТОР,
	        |	КодыГрупп.ИмяГруппы КАК ИмяГруппыОборудования,
	        |	КодыГрупп.КодГруппы КАК КодГруппыОборудования,
	        |	гкс_ГруппыОборудования.Ссылка КАК СсылкаГруппыОборудования,
	        |	ВЫБОР
	        |		КОГДА гкс_ГруппыОборудования.Ссылка ЕСТЬ NULL
	        |				И НЕ КодыГрупп.КодГруппы ЕСТЬ NULL
	        |			ТОГДА ИСТИНА
	        |		ИНАЧЕ ЛОЖЬ
	        |	КОНЕЦ КАК СоздатьКодГруппы,
	        |	КодыГрупп.СсылкаГруппы КАК СсылкаГруппы,
	        |	ВЫБОР
	        |		КОГДА ВыгружаемыеКлассы.РодительСсылка В
	        |				(ВЫБРАТЬ
	        |					ВыгружаемыеКлассы.Ссылка КАК Ссылка
	        |				ИЗ
	        |					ВыгружаемыеКлассы КАК ВыгружаемыеКлассы)
	        |			ТОГДА ГруппыТиповыхОРРодители.Ссылка
	        |		ИНАЧЕ """"
	        |	КОНЕЦ КАК ГруппаТОРРодитель
	        |ИЗ
	        |	ВыгружаемыеКлассы КАК ВыгружаемыеКлассы
	        |		ЛЕВОЕ СОЕДИНЕНИЕ КодыГрупп КАК КодыГрупп
	        |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.гкс_ГруппыОборудования КАК гкс_ГруппыОборудования
	        |			ПО КодыГрупп.КодГруппы = гкс_ГруппыОборудования.Код
	        |		ПО ВыгружаемыеКлассы.Ссылка = КодыГрупп.Класс
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ГруппыТиповыхОР КАК ГруппыТиповыхОР
	        |		ПО ВыгружаемыеКлассы.Наименование = ГруппыТиповыхОР.Наименование
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР КАК ГруппыТиповыхОРРодители
	        |		ПО ВыгружаемыеКлассы.Родитель = ГруппыТиповыхОРРодители.Наименование";
	
		
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ТекстЗапроса_НоменклатураКласса
//
// Описание: ТекстЗапроса_НоменклатураКласса.
//
// Возвращаемое значение: 
//	Строка - ТекстЗапроса.
//
Функция ТекстЗапроса_НоменклатураКласса()
	
	Возврат  "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	         |	НоменклатураКласса.Ссылка КАК Ссылка,
	         |	НоменклатураКласса.Наименование КАК Наименование,
	         |	торо_ТиповыеОР.Ссылка КАК ТОРСсылка,
	         |	Родители.Ссылка КАК ТОРРодитель
	         |ПОМЕСТИТЬ ВременнаяТаблица_ПроверкаТОР
	         |ИЗ
	         |	Справочник.НоменклатураКласса КАК НоменклатураКласса
	         |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
	         |		ПО НоменклатураКласса.Наименование = торо_ТиповыеОР.Наименование
	         |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР КАК Родители
	         |		ПО НоменклатураКласса.Родитель.Наименование = Родители.Наименование
	         |ГДЕ
	         |	НоменклатураКласса.Класс В
	         |			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	         |				ВыгружаемыеКлассы.Ссылка КАК Ссылка
	         |			ИЗ
	         |				ВыгружаемыеКлассы КАК ВыгружаемыеКлассы)
	         |	И НЕ НоменклатураКласса.ЭтоГруппа
	         |	И торо_ТиповыеОР.Ссылка ЕСТЬ NULL
	         |;
	         |
	         |////////////////////////////////////////////////////////////////////////////////
	         |ВЫБРАТЬ
	         |	гкс_СоответствиеОбъектовКлассификатораИТОИР.ОбъектКлассификатора КАК ОбъектКлассификатора,
	         |	гкс_СоответствиеОбъектовКлассификатораИТОИР.ОбъектТОИР КАК ОбъектТОИР
	         |ПОМЕСТИТЬ ТОРПоРегиструСоответствия
	         |ИЗ
	         |	РегистрСведений.гкс_СоответствиеОбъектовКлассификатораИТОИР КАК гкс_СоответствиеОбъектовКлассификатораИТОИР
	         |ГДЕ
	         |	гкс_СоответствиеОбъектовКлассификатораИТОИР.ТипОбъекта = &ТипОбъекта
	         |	И гкс_СоответствиеОбъектовКлассификатораИТОИР.ОбъектКлассификатора В
	         |			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	         |				ВременнаяТаблица_ПроверкаТОР.Ссылка КАК Ссылка
	         |			ИЗ
	         |				ВременнаяТаблица_ПроверкаТОР КАК ВременнаяТаблица_ПроверкаТОР)
	         |;
	         |
	         |////////////////////////////////////////////////////////////////////////////////
	         |ВЫБРАТЬ
	         |	ВременнаяТаблица_ПроверкаТОР.Ссылка КАК Ссылка,
	         |	ВременнаяТаблица_ПроверкаТОР.Наименование КАК Наименование,
	         |	ВременнаяТаблица_ПроверкаТОР.ТОРСсылка КАК ТОРСсылка,
	         |	ВременнаяТаблица_ПроверкаТОР.ТОРРодитель КАК ТОРРодитель,
	         |	ТОРПоРегиструСоответствия.ОбъектТОИР КАК ТОРСсылкаПоРегистру
	         |ИЗ
	         |	ВременнаяТаблица_ПроверкаТОР КАК ВременнаяТаблица_ПроверкаТОР
	         |		ЛЕВОЕ СОЕДИНЕНИЕ ТОРПоРегиструСоответствия КАК ТОРПоРегиструСоответствия
	         |		ПО ВременнаяТаблица_ПроверкаТОР.Ссылка = ТОРПоРегиструСоответствия.ОбъектКлассификатора";
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ТекстЗапроса_ТехКарты
//
// Описание: ТекстЗапроса_ТехКарты.
//
// Возвращаемое значение: 
//	Строка - ТекстЗапроса.
//
Функция ТекстЗапроса_ТехКарты()
	
	Возврат "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтрокиТабличныхАтрибутов.АтрибутКласса,
		|	СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса,
		|	СтрокиТабличныхАтрибутов.ИДСтроки,
		|	СтрокиТабличныхАтрибутов.ИДСтрокиРодителя,
		|	СтрокиТабличныхАтрибутов.ИсточникЗначений,
		|	СтрокиТабличныхАтрибутов.ИсходныйНомерСтроки,
		|	СтрокиТабличныхАтрибутов.Наименование,
		|	СтрокиТабличныхАтрибутов.НоменклатураКласса,
		|	СтрокиТабличныхАтрибутов.ОбъектыНоменклатуры,
		|	СтрокиТабличныхАтрибутов.Порядок,
		|	СтрокиТабличныхАтрибутов.ТехКарта
		|ПОМЕСТИТЬ ВТ_СтрокиТабличныхАтрибутов
		|ИЗ
		|	&СтрокиТабличныхАтрибутов КАК СтрокиТабличныхАтрибутов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗначенияТабличныхАтрибутов.АтрибутКласса,
		|	ЗначенияТабличныхАтрибутов.АтрибутТаблицы,
		|	ЗначенияТабличныхАтрибутов.ЗначениеАтрибутаТаблицы КАК ЗначениеАтрибутаТаблицы,
		|	ЗначенияТабличныхАтрибутов.ИДСтроки,
		|	ЗначенияТабличныхАтрибутов.ИДСтрокиРодителя
		|ПОМЕСТИТЬ ВТ_ЗначенияТабличныхАтрибутов
		|ИЗ
		|	&ЗначенияТабличныхАтрибутов КАК ЗначенияТабличныхАтрибутов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СтрокиТабличныхАтрибутов.ТехКарта КАК ТехКарта,
		|	ВТ_ЗначенияТабличныхАтрибутов.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_ЗначенияТабличныхАтрибутов.ИДСтроки КАК ИДСтроки,
		|	ВТ_ЗначенияТабличныхАтрибутов.ИДСтрокиРодителя КАК ИДСтрокиРодителя,
		|	ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса,
		|	ВТ_ЗначенияТабличныхАтрибутов.АтрибутТаблицы,
		|	ВТ_ЗначенияТабличныхАтрибутов.ЗначениеАтрибутаТаблицы,
		|	АтрибутыКласса.ИмяДляОбмена КАК ИмяДляОбмена,
		|	АтрибутыКласса1.ИмяДляОбмена КАК ИмяДляОбменаАтрибутТаблицы
		|ИЗ
		|	ВТ_СтрокиТабличныхАтрибутов КАК ВТ_СтрокиТабличныхАтрибутов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗначенияТабличныхАтрибутов КАК ВТ_ЗначенияТабличныхАтрибутов
		|			ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.АтрибутыКласса КАК АтрибутыКласса
		|			ПО ВТ_ЗначенияТабличныхАтрибутов.АтрибутКласса = АтрибутыКласса.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.АтрибутыКласса КАК АтрибутыКласса1
		|			ПО ВТ_ЗначенияТабличныхАтрибутов.АтрибутТаблицы = АтрибутыКласса1.Ссылка
		|		ПО ВТ_СтрокиТабличныхАтрибутов.ИДСтроки = ВТ_ЗначенияТабличныхАтрибутов.ИДСтроки
		|			И ВТ_СтрокиТабличныхАтрибутов.АтрибутКласса = ВТ_ЗначенияТабличныхАтрибутов.АтрибутКласса
		|
		|УПОРЯДОЧИТЬ ПО
		|	ИДСтрокиРодителя,
		|	ИДСтроки
		|ИТОГИ
		|	МАКСИМУМ(ИмяДляОбмена)
		|ПО
		|	ТехКарта,
		|	АтрибутКласса,
		|	ИДСтроки,
		|	ИДСтрокиРодителя";
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ДобавитьСоответствиеОбъектов
//
// Описание: Добавляет соответствие в РС гкс_СоответствиеОбъектовКлассификатораИТОИР.
//
// Параметры:
//	ОбъектТоир - СправочникСсылка.Классы, СправочникСсылка.НоменклатураКласса - Объект ТОИР
//	ОбъектКлассификатора - СправочникСсылка - ОбъектКлассификатора
//	ТипОбъекта - ПеречислениеСсылка.гкс_ТипОбъектаТОИР - ТипОбъекта.
//
Процедура ДобавитьСоответствиеОбъектов(ОбъектТоир, ОбъектКлассификатора, ТипОбъекта = Неопределено)
	
	НаборЗаписейСооттветствия = РегистрыСведений.гкс_СоответствиеОбъектовКлассификатораИТОИР.СоздатьНаборЗаписей();
	НаборЗаписейСооттветствия.Отбор.ОбъектКлассификатора.Установить(ОбъектКлассификатора);
	Если ЗначениеЗаполнено(ТипОбъекта) Тогда
		НаборЗаписейСооттветствия.Отбор.ТипОбъекта.Установить(ТипОбъекта);
	КонецЕсли; 
	НаборЗаписейСооттветствия.Прочитать();
	НаборЗаписейСооттветствия.Очистить();
	НоваяЗапись = НаборЗаписейСооттветствия.Добавить();
	Если ЗначениеЗаполнено(ТипОбъекта) Тогда
		НоваяЗапись.ТипОбъекта = ТипОбъекта;
	КонецЕсли; 
	НоваяЗапись.ОбъектКлассификатора = ОбъектКлассификатора;
	НоваяЗапись.ОбъектТОИР = ОбъектТоир;

	НаборЗаписейСооттветствия.Записать();

КонецПроцедуры 

////////////////////////////////////////////////////////////////////////////////
//
// Функция СоответствиеГруппыОборудования
//
// Описание: Заполняет соответствие всемы кодами групп оборудорвания с ссылками.
//
// Возвращаемое значение: 
//	Соответствие - Ключ: код группы, Значение: СправочникСсылка.гкс_КодыГруппОборудования.
//
Функция СоответствиеГруппыОборудования()
	
	Соответствие = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ГруппыОборудования.Код КАК Код,
		|	гкс_ГруппыОборудования.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.гкс_ГруппыОборудования КАК гкс_ГруппыОборудования
		|ГДЕ
		|	гкс_ГруппыОборудования.Код <> """"";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Соответствие.Вставить(ВыборкаДетальныеЗаписи.Код, ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
//
// Функция ПодготовитьОбъектыДляЗаполнения
//
// Описание: Подготовка пустых структур, ТЗ и т.д. для заполнения данных по значениям атрибутов.
//
// Возвращаемое значение: 
//	Структура - пустые структуры для заполнения.
//
Функция ПодготовитьОбъектыДляЗаполнения()
	
	СтруктураДляЗаполнения = Новый Структура;
	
	ОписаниеТипСтрока = Новый ОписаниеТипов("Строка");

	ДобавляемыеТипы = Перечисления.ТипВсеСсылки().Типы();
	ДобавляемыеТипы.Добавить(Тип("Строка"));
	ДобавляемыеТипы.Добавить(Тип("Число"));
	ДобавляемыеТипы.Добавить(Тип("Дата"));

	ТипВсеСсылки =  Новый ОписаниеТипов(Справочники.ТипВсеСсылки(), ДобавляемыеТипы);

	МассивТипПВХ = Новый Массив;
	МассивТипПВХ.Добавить(Тип("ПланВидовХарактеристикСсылка.АтрибутыКласса")); 
	МассивТипПВХ.Добавить(Тип("СправочникСсылка.ВложенныеАтрибутыКласса")); 
