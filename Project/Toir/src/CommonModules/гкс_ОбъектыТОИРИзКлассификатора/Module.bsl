////////////////////////////////////////////////////////////////////////////////
//
// Функция СозданиеОР
//
// Описание: Создание новых объектов ремонта.
//
Процедура СозданиеОР()
	
	Группа = Константы.гкс_ОсновнаяГруппаОбъектовРемонта.Получить();
	СоздатьИерархиюОРНаСервере(Группа);
	СоздатьОРНаСервере();        
		
КонецПроцедуры
 
////////////////////////////////////////////////////////////////////////////////
//
// Функция СоздатьИерархиюОРНаСервере
//
// Описание: Создание/добавление новых групп объектов ремонта.
//
// Параметры:
//	Группа - Константа.гкс_ОсновнаяГруппаОбъектовРемонта - Группа объектов ремонта,
//								в которую создаются все объекты ремонта по умолчанию.
//
Процедура СоздатьИерархиюОРНаСервере(Группа)
	
	ИерархияПоДокументам = ПолучитьИерархиюОРПоДокументам(Группа);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ГруппыВИерархии", ИерархияПоДокументам);
	Запрос.Текст = ТекстЗапроса_ИерархияОР();
			
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Добавленные = Новый Соответствие;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Наименование) Тогда
			
			НоваяГруппа = Справочники.торо_ОбъектыРемонта.СоздатьГруппу();        				
			
			НоваяГруппа.Наименование = ВыборкаДетальныеЗаписи.Наименование;
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ОРРодитель) Тогда
				Родитель = ВыборкаДетальныеЗаписи.ОРРодитель;
			Иначе
				Родитель = Группа;
			КонецЕсли; 
			НоваяГруппа.Записать();
			
			Добавленные.Вставить(НоваяГруппа.Ссылка, Родитель);
		КонецЕсли; 
		
	КонецЦикла;
	
	Если Добавленные.Количество() > 0 Тогда
		ДокументДобавленияВИерархию = Документы.торо_ИзменениеПоложенияВСтруктуреИерархии.СоздатьДокумент();
		ДокументДобавленияВИерархию.СтруктураИерархии = ПредопределенноеЗначение("Справочник.торо_СтруктурыОР.ОсновнаяИерархия");
		ДокументДобавленияВИерархию.Дата = ТекущаяДатаСеанса();
		Для каждого ТекСтрока Из Добавленные Цикл
			НоваяСтрока = ДокументДобавленияВИерархию.ПоложенияВСтруктуреИерархии.Добавить();
			НоваяСтрока.ОбъектИерархии = ТекСтрока.Ключ;
			НоваяСтрока.РодительИерархии = ТекСтрока.Значение;
			НоваяСтрока.ПредыдущееПоложение = "Внесен в структуру иерархии";
			НоваяСтрока.Удален = Ложь;
		КонецЦикла; 
		ДокументДобавленияВИерархию.Записать(РежимЗаписиДокумента.Проведение);		
	КонецЕсли; 	
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
//
// Функция СоздатьОРНаСервере
//
// Описание: Создание нового объекта ремонта с установкой в иерархии документом.	
//
Процедура СоздатьОРНаСервере()

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса_ОРКСозданию();
			
	РезультатЗапроса = Запрос.Выполнить();
	МассивОР = Новый Массив; 
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ГрафикКруглосуточно = ПредопределенноеЗначение("Справочник.Календари.Круглосуточно");
		ДокументДобавленияВИерархию = Документы.торо_ИзменениеПоложенияВСтруктуреИерархии.СоздатьДокумент();
		ДокументДобавленияВИерархию.СтруктураИерархии = ПредопределенноеЗначение("Справочник.торо_СтруктурыОР.ОсновнаяИерархия");
		ДокументДобавленияВИерархию.Дата = ТекущаяДатаСеанса();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ОР) Тогда
				НовыйОбъектРемонта = ВыборкаДетальныеЗаписи.ОР.ПолучитьОбъект();
			Иначе
				НовыйОбъектРемонта = Справочники.торо_ОбъектыРемонта.СоздатьЭлемент();
			КонецЕсли; 
			НовыйОбъектРемонта.Наименование = ВыборкаДетальныеЗаписи.ТОРНаименование;
			НовыйОбъектРемонта.Изготовитель = ВыборкаДетальныеЗаписи.ТОРИзготовитель;
			НовыйОбъектРемонта.ПлановыйГрафикРаботы = ГрафикКруглосуточно;
			НовыйОбъектРемонта.ТиповойОР = ВыборкаДетальныеЗаписи.ТОР;
			НовыйОбъектРемонта.ДатаВыпуска = Дата(2018, 2, 10);
			НовыйОбъектРемонта.ДатаВводаВЭксплуатацию = Дата(2018, 2, 14);
			НовыйОбъектРемонта.Записать();
			МассивОР.Добавить(НовыйОбъектРемонта.Ссылка);
			
			НоваяСтрока = ДокументДобавленияВИерархию.ПоложенияВСтруктуреИерархии.Добавить();
			НоваяСтрока.ОбъектИерархии = НовыйОбъектРемонта.Ссылка;
			НоваяСтрока.РодительИерархии = ВыборкаДетальныеЗаписи.ОРРодитель;
			НоваяСтрока.ПредыдущееПоложение = "Внесен в структуру иерархии";
			НоваяСтрока.Удален = Ложь;
		КонецЦикла;
	
		ДокументДобавленияВИерархию.Записать(РежимЗаписиДокумента.Проведение);		
		
	КонецЕсли; 
	
	Если МассивОР.Количество() > 0 Тогда
		ЗаполнитьНормативныеРемонтыОРНаСервере(МассивОР);			
	КонецЕсли; 

КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
//
// Функция ЗаполнитьНормативныеРемонтыОРНаСервере
//
// Описание: Заполнение РС нормативных ремонтов на основании ТЧ 
//			Нормативные ремонты справочника типовые объекты ремонта.
//
// Параметры:
//	МассивОР - Массив - массив Объектов ремонта.
//
Процедура ЗаполнитьНормативныеРемонтыОРНаСервере(МассивОР)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОР", МассивОР);
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	торо_ОбъектыРемонта.Ссылка КАК ОбъектРемонта,
		|	торо_ТиповыеОРНормативныеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРНормативныеРемонты.Ссылка КАК ТиповойОР,
		|	торо_ТиповыеОРНормативныеРемонты.НормативныйРемонт КАК НормативныйРемонт,
		|	торо_ТиповыеОРНормативныеРемонты.СпособПланирования КАК СпособПланирования,
		|	торо_ТиповыеОРНормативныеРемонты.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
		|	торо_ТиповыеОРНормативныеРемонты.СпособВыполнения КАК СпособВыполнения,
		|	торо_ТиповыеОРНормативныеРемонты.СпособУчетаДатыОтсчета КАК СпособУчетаДатыОтсчета
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.НормативныеРемонты КАК торо_ТиповыеОРНормативныеРемонты
		|		ПО торо_ОбъектыРемонта.ТиповойОР = торо_ТиповыеОРНормативныеРемонты.Ссылка
		|ГДЕ
		|	НЕ торо_ОбъектыРемонта.ЭтоГруппа
		|	И НЕ торо_ТиповыеОРНормативныеРемонты.Ссылка ЕСТЬ NULL
		|	И НЕ торо_ТиповыеОРНормативныеРемонты.Ссылка.ПометкаУдаления
		|	И торо_ОбъектыРемонта.Ссылка В (&МассивОР)
		|ИТОГИ
		|	МАКСИМУМ(ТиповойОР)
		|ПО
		|	ОбъектРемонта";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока Выборка.Следующий() Цикл
		
		НаборЗаписей = РегистрыСведений.торо_НормативныеРемонтыОборудования.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ОбъектРемонта.Установить(Выборка.ОбъектРемонта);
		НаборЗаписей.Отбор.ТиповойОР.Установить(Выборка.ТиповойОР);
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить();
		
		ВыборкаДетЗаписи = Выборка.Выбрать();
		Проверка = Новый Массив;
		Пока ВыборкаДетЗаписи.Следующий() Цикл
			Если Проверка.Найти(ВыборкаДетЗаписи.ВидРемонта) <> Неопределено Тогда
				Продолжить;				
			КонецЕсли; 
			
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, ВыборкаДетЗаписи);
			Проверка.Добавить(ВыборкаДетЗаписи.ВидРемонта);
			
		КонецЦикла; 
		
		НаборЗаписей.Записать();
				
	КонецЦикла;

КонецПроцедуры

