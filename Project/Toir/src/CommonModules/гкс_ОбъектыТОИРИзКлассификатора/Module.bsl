Функция ТекстЗапроса_ОРКСозданию()
	
	Возврат "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	торо_ОбъектыРемонта.Ссылка КАК ОРРодитель,
			|	торо_ОбъектыРемонта.Наименование КАК ОРРодительНаименование
			|ПОМЕСТИТЬ ВременнаяТаблица_ГруппыОР
			|ИЗ
			|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
			|ГДЕ
			|	торо_ОбъектыРемонта.ЭтоГруппа
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	торо_ТиповыеОР.Ссылка КАК ТОР,
			|	ВременнаяТаблица_ГруппыОР.ОРРодитель КАК ОРРодитель,
			|	торо_ТиповыеОР.Наименование КАК ТОРНаименование,
			|	торо_ТиповыеОР.Изготовитель КАК ТОРИзготовитель
			|ПОМЕСТИТЬ ВременнаяТаблица_ТОР
			|ИЗ
			|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблица_ГруппыОР КАК ВременнаяТаблица_ГруппыОР
			|		ПО торо_ТиповыеОР.Родитель.Наименование = ВременнаяТаблица_ГруппыОР.ОРРодительНаименование
			|ГДЕ
			|	НЕ торо_ТиповыеОР.ПометкаУдаления
			|	И НЕ торо_ТиповыеОР.ЭтоГруппа
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВременнаяТаблица_ТОР.ТОР КАК ТОР,
			|	ВременнаяТаблица_ТОР.ОРРодитель КАК ОРРодитель,
			|	ВременнаяТаблица_ТОР.ТОРНаименование КАК ТОРНаименование,
			|	ВременнаяТаблица_ТОР.ТОРИзготовитель КАК ТОРИзготовитель,
			|	торо_ОбъектыРемонта.Ссылка КАК ОР
			|ИЗ
			|	ВременнаяТаблица_ТОР КАК ВременнаяТаблица_ТОР
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
			|		ПО ВременнаяТаблица_ТОР.ТОР = торо_ОбъектыРемонта.ТиповойОР
			|ГДЕ
			|	(торо_ОбъектыРемонта.Ссылка ЕСТЬ NULL
			|			ИЛИ торо_ОбъектыРемонта.ПлановыйГрафикРаботы = ЗНАЧЕНИЕ(Справочник.Календари.ПустаяСсылка))";

		
