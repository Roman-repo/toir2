////////////////////////////////////////////////////////////////////////////////
//
// Функция ОбработатьСтрокиПоказатели
//
// Описание: Заполнение списка Показателей на основании множественных значений атрибутов. 	
// 
// Параметры:
//	ВыборкаСтроки - ВыборкаИзРезультатаЗапроса - ВыборкаИзРезультатаЗапроса
//	СоответствиеСтрокГуИДам - Соответствие - соответствие для связи строк различных табличных частей
//	ТЗПоказатели - ТаблицаЗначений - ТЗПоказатели
//	ТЗСписокОпераций - ТаблицаЗначений - ТЗСписокОпераций.
//
Процедура ОбработатьСтрокиПоказатели(ВыборкаСтроки, СоответствиеСтрокГуИДам, ТЗПоказатели, ТЗСписокОпераций)
	
	Пока ВыборкаСтроки.Следующий() Цикл
	ВыборкаСтрокиРодителя = ВыборкаСтроки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСтрокиРодителя.Следующий() Цикл
			Выборка = ВыборкаСтрокиРодителя.Выбрать();
			СтрокаТЗ = ТЗПоказатели.Добавить();
			СтрокаТЗ.ID = СоответствиеСтрокГуИДам[ВыборкаСтрокиРодителя.ИДСтрокиРодителя];
			СтрокаОперации = ТЗСписокОпераций.НайтиСтроки(Новый Структура("ID",СтрокаТЗ.ID));
			Если СтрокаОперации.Количество() > 0 Тогда
				СтрокаТЗ.Операция = СтрокаОперации[0].Операция;
			КонецЕсли; 
			Пока Выборка.Следующий() Цикл
				Если Выборка.ИмяДляОбменаАтрибутТаблицы = "КонтролируемыйПоказатель" Тогда
					СтрокаТЗ.Показатель = Выборка.ЗначениеАтрибутаТаблицы;	
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "ЕдиницаИзмерения" Тогда 
					СтрокаТЗ.ЕдиницаИзмерения = Выборка.ЗначениеАтрибутаТаблицы;	
				ИначеЕсли Выборка.ИмяДляОбменаАтрибутТаблицы = "Значение" Тогда
					СтрокаТЗ.Значение = Выборка.ЗначениеАтрибутаТаблицы;	
				КонецЕсли; 	
			КонецЦикла; 
		КонецЦикла; 
	КонецЦикла; 
	
КонецПроцедуры

