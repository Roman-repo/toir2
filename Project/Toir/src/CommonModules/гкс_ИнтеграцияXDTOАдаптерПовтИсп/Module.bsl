// Функция ПолучитьПолноеИмяИзXDTO
//
// Описание: Поиск имени объекта метаданных текущей ИБ по имени типа XDTO.
//
// Параметры
//  ИмяТипаXDTO - Строка - ИмяТипаXDTO
//
// Возвращаемое значение: 
//	Строка - имя объекта метаданных текущей ИБ.
//   
// Гкс+[CPM30-1106] Селимов от 09.07.2020. Добавлено:{
Функция ПолучитьПолноеИмяИзXDTO(ИмяТипаXDTO) Экспорт
	
	ТаблицаСоответствия = СоответствиеТипов();
	Строка = ТаблицаСоответствия.Найти(ИмяТипаXDTO, "ИмяXDTO");
	Если Строка = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Строка.ИмяТипа;
	
КонецФункции  // } Гкс-[CPM30-1106]

// Функция СоответствиеТипов
