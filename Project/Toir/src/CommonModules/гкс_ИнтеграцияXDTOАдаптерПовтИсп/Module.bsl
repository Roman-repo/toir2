#Область СлужебныеПроцедурыИФункции

// Процедура ДобавитьСтроку
//
// Описание: добавление строки в таблицу значений Соответствия типов.
//
// Параметры
//  Таблица - ТаблицаЗначений - Таблица, в которую добавляется строка
//  ИмяXDTO - Строка - имя типа объекта XDTO
//  ИмяТипа - Строка - имя типа текущей ИБ
//  ИспользоватьМенеджер - Булево - ИспользоватьМенеджер
//
// Гкс+[CPM30-1106] Селимов от 09.07.2020. Добавлено:{
Процедура ДобавитьСтроку(Таблица, ИмяXDTO, ИмяТипа, ИспользоватьМенеджер = Ложь) Экспорт
	
	НоваяСтрока = Таблица.Добавить();
	НоваяСтрока.ИмяXDTO = ИмяXDTO;
	НоваяСтрока.ИмяТипа = ИмяТипа;
	НоваяСтрока.ИспользоватьМенеджер = ИспользоватьМенеджер;
	
КонецПроцедуры  // } Гкс-[CPM30-1106]

Функция ПолучитьПриложениеПоИмени(НаименованиеПриложения) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Приложение = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_УчастникиОбменаRMQ.Ссылка КАК Приложение
		|ИЗ
		|	Справочник.гкс_УчастникиОбменаRMQ КАК гкс_УчастникиОбменаRMQ
		|ГДЕ
		|	гкс_УчастникиОбменаRMQ.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", НаименованиеПриложения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Приложение = Выборка.Приложение;
		
	КонецЕсли;
	
	Возврат Приложение;

КонецФункции               

#КонецОбласти
