Функция ПолучитьИмяБазовогоТипаПоТипуОбъекта(ТипОбъекта)
    
    МетаданныеТипа = Метаданные.НайтиПоТипу(ТипОбъекта);
    
    Если МетаданныеТипа = Неопределено Тогда
        
        Возврат "УдалениеОбъекта";
        
    ИначеЕсли Метаданные.РегистрыСведений.Содержит(МетаданныеТипа) Тогда
        
        Возврат "РегистрыСведений";
        
    ИначеЕсли Метаданные.Документы.Содержит(МетаданныеТипа) Тогда
        
        Возврат "Документы";
        
    ИначеЕсли Метаданные.Справочники.Содержит(МетаданныеТипа) Тогда
        
        Возврат "Справочники";    
        
    ИначеЕсли Метаданные.РегистрыНакопления.Содержит(МетаданныеТипа) Тогда
    
        Возврат "РегистрыНакопления";    
        
    ИначеЕсли Метаданные.РегистрыБухгалтерии.Содержит(МетаданныеТипа) Тогда
    
        Возврат "РегистрыБухгалтерии";    
       
    Иначе
       
        Возврат "";
        
    КонецЕсли;
            
КонецФункции

// [Строит динамический нелокализованный список для формы списка] 
Процедура ПостроитьДинамическийСписокформы(Форма)
	Если СтрНайти(Форма.Параметры.ТипМетаданных,"Регистр") > 0 Тогда 
		Возврат;
	КонецЕсли;
	//
	нТабл = Форма.Элементы.Добавить("Список",Тип("ТаблицаФормы"));
	нТабл.ПутьКДанным = "Список";
	нТабл.Высота = 3;
	нТабл.ВариантУправленияВысотой = ВариантУправленияВысотойТаблицы.ПоСодержимому;

	ЭтоФормаВыбора = Форма.Параметры.ВидФормы = "ФормаВыбора";
	
	ОсновнаяТаблицаИмя = Лев(Форма.Параметры.ТипМетаданных,СтрДлина(Форма.Параметры.ТипМетаданных)-1) + "." + Форма.Параметры.ТипОбъектаИБ;
	Форма.Список.ПроизвольныйЗапрос = Истина;
	Форма.Список.Основнаятаблица = ОсновнаяТаблицаИмя;
	СтандартныеРеквизиты = Новый Массив();
	СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Ссылка",
		Новый ОписаниеТипов(Лев(Форма.Параметры.ТипМетаданных,СтрДлина(Форма.Параметры.ТипМетаданных)-1)+"Ссылка."+Форма.Параметры.ТипОбъектаИБ)));
	Если Форма.Параметры.ТипМетаданных = "Справочники" Тогда 
		// >> [Деснол] [Ушаков А.Д.] [20.09.2019]
		СтандартныеРеквизитыМета = Метаданные.Справочники[Форма.Параметры.ТипОбъектаИБ].СтандартныеРеквизиты;
		ДлинаНаименования = СтандартныеРеквизитыМета["Наименование"].Тип.КвалификаторыСтроки.Длина;
		СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Наименование",Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(ДлинаНаименования))));
		
		Для каждого СтандартныйРеквизит Из СтандартныеРеквизитыМета Цикл
			Если СтандартныйРеквизит.Имя = "Код" Тогда
				ДлинаКода = СтандартныйРеквизит.Тип.КвалификаторыСтроки.Длина;
				СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Код",Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(ДлинаКода))));
			КонецЕсли; 
		КонецЦикла; 
		
		//Если ЭтоФормаВыбора Тогда
		//	Для каждого СтандартныйРеквизит Из СтандартныеРеквизиты Цикл
		//		Если СтандартныйРеквизит.Имя = "Ссылка" Тогда
		//			СтандартныеРеквизиты.Удалить(СтандартныеРеквизиты.Найти(СтандартныйРеквизит));
		//		КонецЕсли; 
		//	КонецЦикла; 
		//КонецЕсли;
		
		//СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Код",Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50))));
		// << [Деснол] [Ушаков А.Д.] [20.09.2019] 
		СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Предопределенный",Новый ОписаниеТипов("Булево")));
	ИначеЕсли Форма.Параметры.ТипМетаданных = "Документы" Тогда 
		СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Дата",Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя))));
		СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Номер",Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50))));
		СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","Проведен",Новый ОписаниеТипов("Булево")));
	КонецЕсли;
	СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","ПометкаУдаления",Новый ОписаниеТипов("Булево")));
	//СтандартныеРеквизиты.Добавить(Новый Структура("Имя,Тип","СтандартнаяКартинка",Новый ОписаниеТипов("Картинка")));
	//
	// >> [Деснол] [Ушаков А.Д.] [20.09.2019] 
	//ТекстЗапроса = "Выбрать 
	ТекстЗапроса = "//Локализация
	|Выбрать 
	// << [Деснол] [Ушаков А.Д.] [20.09.2019] 
	| //";

	Для Каждого Реквизит Из СтандартныеРеквизиты Цикл
		ТекстЗапроса = ТекстЗапроса + ",
		|	ТЧ."+Реквизит.Имя + " КАК "+Реквизит.Имя;
	КонецЦикла;
	
	// >> [Деснол] [Ушаков А.Д.] [20.09.2019]
	Если Не ЭтоФормаВыбора Тогда
		Для Каждого Реквизит Из Метаданные[Форма.Параметры.ТипМетаданных][Форма.Параметры.ТипОбъектаИБ].Реквизиты Цикл
			ТекстЗапроса = ТекстЗапроса + ",
			|	ТЧ."+Реквизит.Имя + " КАК "+Реквизит.Имя;
		КонецЦикла;
	КонецЕсли; 
	// << [Деснол] [Ушаков А.Д.] [20.09.2019] 
	//
	ТекстЗапроса = ТекстЗапроса + " 
	|	ИЗ " + ОсновнаяТаблицаИмя + " КАК ТЧ";
	Форма.Список.ТекстЗапроса = ТекстЗапроса;
	//
	Для Каждого Реквизит Из СтандартныеРеквизиты Цикл
		НЭлем = Форма.Элементы.Добавить(Реквизит.Имя, Тип("ПолеФормы"), Форма.Элементы["Список"]);
		Если Реквизит.Тип = Новый ОписаниеТипов("Булево") Тогда 
			НЭлем.Вид = ВидПоляФормы.ПолеФлажка;
		Иначе
			НЭлем.Вид = ВидПоляФормы.ПолеВвода;
		КонецЕсли;
		НЭлем.ПутьКДанным = "Список."+Реквизит.Имя;
		Если Реквизит.Имя = "Предопределенный" ИЛИ Реквизит.Имя = "ПометкаУдаления" ИЛИ Реквизит.Имя = "Проведен" Тогда 
			НЭлем.Видимость = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Если ЭтоФормаВыбора Тогда
		Форма.Элементы.Ссылка.Видимость = Ложь;
		Форма.Список.УстановитьОбязательноеИспользование("Ссылка", Истина);
	КонецЕсли; 
	
	Если Не ЭтоФормаВыбора Тогда
		Для Каждого Реквизит Из Метаданные[Форма.Параметры.ТипМетаданных][Форма.Параметры.ТипОбъектаИБ].Реквизиты Цикл
			НЭлем = Форма.Элементы.Добавить(Реквизит.Имя, Тип("ПолеФормы"), Форма.Элементы["Список"]);
			Если Реквизит.Тип = Новый ОписаниеТипов("Булево") Тогда 
				НЭлем.Вид = ВидПоляФормы.ПолеФлажка;
			Иначе
				НЭлем.Вид = ВидПоляФормы.ПолеВвода;
			КонецЕсли;
			НЭлем.ПутьКДанным = "Список."+Реквизит.Имя;
		КонецЦикла;
	КонецЕсли; 
	//
	Форма.Элементы.Список.ПутьКДаннымКартинкиСтроки = "Список.СтандартнаяКартинка";
КонецПроцедуры

// [Возвращает перевод реквизита по ссылке и языку] 
Функция ПолучитьЗначениеРеквизитаОбъекта(ID, Реквизит, Язык)
	Отбор = Новый Структура("ID,Язык,Реквизит", ID, Язык, Реквизит); 
	НЗ = РегистрыСведений.торо_Переводы.Получить(Отбор);
	
	Значение = НЗ.Текст;
	
	Возврат Значение;
КонецФункции

// Проверяет, является ли текущий язык языком по умолчанию 
Функция ЭтоЯзыкПоУмолчанию()
	ТекущийЯзыкЭтоЯзыкПоУмолчанию = ПараметрыСеанса.торо_ТекущийЯзыкЭтоЯзыкПоУмолчанию;
	Возврат ТекущийЯзыкЭтоЯзыкПоУмолчанию;
КонецФункции

#КонецОбласти 

