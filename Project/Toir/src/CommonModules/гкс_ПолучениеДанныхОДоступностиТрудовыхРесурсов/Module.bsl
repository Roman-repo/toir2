// гкс_ПолучениеДанныхОДоступностиТрудовыхРесурсов: получение данных о плановых рабочих часах сотрудников из баз ЗУП
//	на будущие периоды
//  
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныеПроцедурыИФункции

Процедура гкс_ПолучениеДанныхОДоступностиТрудовыхРесурсов() Экспорт
	
	НастройкаИнтеграции = ПредопределенноеЗначение("Справочник.гкс_ПроизвольныеНастройкиИнтеграций.ЗагрузкаИзЗУП");
	Настройки = Справочники.гкс_ПроизвольныеНастройкиИнтеграций.ПолучитьСвойства(НастройкаИнтеграции, "Все");
	Если Не ТипЗнч(Настройки.ДопСвойства) = Тип("ТаблицаЗначений") Тогда 
		Возврат;		
	КонецЕсли; 
	
	Для каждого Настройка Из Настройки.ДопСвойства Цикл
		
		НачалоЗапроса = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		Запрос = СформироватьТекстЗапроса(Настройка);
		ОтветТекст = ВыполнитьЗапросКЗУП(Запрос, Настройки.Свойства);
		ОбработатьОтвет(ОтветТекст);
		
		ДобавитьЗапросВЛог(Запрос, Настройки.Свойства, ОтветТекст, НачалоЗапроса);		
		
	КонецЦикла; 
	
КонецПроцедуры

Функция СформироватьТекстЗапроса(Настройка)
	
	Отбор = Новый Структура;
	Отбор.Вставить("Организация", Настройка.Организация);
	Отбор.Вставить("ЦФО", Настройка.Подразделение);
	Отбор.Вставить("ДатаС", Настройка.ДатаС);
	Отбор.Вставить("ДатаПо", Настройка.ДатаПо);
	
	ОтборXDTO	= ПолучитьОтборXDTO(Отбор);
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("UTF-8");
	Запись.ЗаписатьОбъявлениеXML();

	ФабрикаXDTO.ЗаписатьXML(Запись, ОтборXDTO, , , , НазначениеТипаXML.Явное);
	
	ТекстСообщения = Запись.Закрыть();
	
	Возврат ТекстСообщения;	
	
КонецФункции
 
Функция ВыполнитьЗапросКЗУП(Запрос, Настройка) Экспорт
	
	СтруктураВозврата	= Новый Структура("ВыполненоУспешно, Идентификатор", Истина, "");

	Попытка 
		Клиент = ОчередьСообщений.НовыйКлиентАсинхронногоСервиса(Настройка["Очередь"]);
		НомерСообщения = Клиент.Вызвать(Настройка["Метод"], Новый Структура("Сообщение", Запрос));										
		ТаймаутПоУмолчанию = 30000;
		Таймаут = ?(Настройка["Таймаут"] = Неопределено, ТаймаутПоУмолчанию, Настройка["Таймаут"]);		
		Ответ = Клиент.ОжидатьОтвет(Таймаут);                              	
	Исключение
		Ответ	= "";
		СтруктураВозврата.ВыполненоУспешно	= Ложь;
		ЗаписьЖурналаРегистрации("ЗапросДанныхТрудозатрат",
									УровеньЖурналаРегистрации.Ошибка, 
									, 
									, 
									ОписаниеОшибки());
	КонецПопытки;
	
	Если  ТипЗнч(Ответ) = Тип("ФиксированнаяСтруктура") Тогда                         	
		ОтветТекст = Ответ.result.value;
	Иначе
		СтруктураВозврата.ВыполненоУспешно = Ложь;			
	КонецЕсли;
		
	Возврат ОтветТекст;
	
КонецФункции

Процедура ОбработатьОтвет(ОтветТекст) Экспорт
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ОтветТекст);
	ЧтениеXML.ПерейтиКСодержимому();
	Ответ = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	
	Если Не Ответ.Установлено("Row") Тогда
		Возврат;
	КонецЕсли; 
	СоответствиеНаименованийСвойств = ПолучитьСоответствиеНаименованийСвойств();
	
	ТЗДляЗаполнения = ПолучитьТЗДляЗаполнения();
	ТЗ = СписокXDTOВТаблицуЗначений(Ответ.Row, СоответствиеНаименованийСвойств, ТЗДляЗаполнения);
	ЗаписатьДанныеВДокумент(ТЗ);
	
КонецПроцедуры 

Функция ПолучитьСоответствиеНаименованийСвойств()
	
	СоответствиеНаименованийСвойств = Новый Соответствие;
	СоответствиеНаименованийСвойств.Вставить("Company", 		"Организация");
	СоответствиеНаименованийСвойств.Вставить("CostCenter", 		"Подразделение");
	СоответствиеНаименованийСвойств.Вставить("JobTitle", 		"Должность");
	СоответствиеНаименованийСвойств.Вставить("Date", 			"ПериодПланирования");
	СоответствиеНаименованийСвойств.Вставить("WorkersCount", 	"КоличествоСотрудников");
	СоответствиеНаименованийСвойств.Вставить("WorkingHours", 	"Часы");
	
	СоответствиеНаименованийСвойств.Вставить("Организация", 			"Company");
	СоответствиеНаименованийСвойств.Вставить("Подразделение", 			"CostCenter");
	СоответствиеНаименованийСвойств.Вставить("Должность", 				"JobTitle");
	СоответствиеНаименованийСвойств.Вставить("ПериодПланирования", 		"Date");
	СоответствиеНаименованийСвойств.Вставить("КоличествоСотрудников", 	"WorkersCount");
	СоответствиеНаименованийСвойств.Вставить("Часы", 					"WorkingHours");
	
	Возврат СоответствиеНаименованийСвойств;
		
КонецФункции

Процедура ЗаписатьДанныеВДокумент(ТЗ)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаСДанными", ТЗ);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСДанными.Организация КАК Организация,
		|	ТаблицаСДанными.Подразделение КАК Подразделение,
		|	ТаблицаСДанными.Должность КАК Должность,
		|	ТаблицаСДанными.ПериодПланирования КАК ПериодПланирования,
		|	ТаблицаСДанными.КоличествоСотрудников КАК КоличествоСотрудников,
		|	ТаблицаСДанными.Часы КАК Часы
		|ПОМЕСТИТЬ ВТ_ТаблицаСДанными
		|ИЗ
		|	&ТаблицаСДанными КАК ТаблицаСДанными
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	гкс_СоответствияДолжностейИКвалификацийСрезПоследних.Организация КАК Организация,
		|	гкс_СоответствияДолжностейИКвалификацийСрезПоследних.Подразделение КАК Подразделение,
		|	гкс_СоответствияДолжностейИКвалификацийСрезПоследних.Должность КАК Должность,
		|	гкс_СоответствияДолжностейИКвалификацийСрезПоследних.Квалификация КАК Квалификация
		|ПОМЕСТИТЬ КвалификацииДолжностей
		|ИЗ
		|	РегистрСведений.гкс_СоответствияДолжностейИКвалификаций.СрезПоследних(
		|			,
		|			(Организация, Подразделение, Должность) В
		|				(ВЫБРАТЬ
		|					ВТ_ТаблицаСДанными.Организация КАК Организация,
		|					ВТ_ТаблицаСДанными.Подразделение КАК Подразделение,
		|					ВТ_ТаблицаСДанными.Должность КАК Должность
		|				ИЗ
		|					ВТ_ТаблицаСДанными КАК ВТ_ТаблицаСДанными
		|				СГРУППИРОВАТЬ ПО
		|					ВТ_ТаблицаСДанными.Подразделение,
		|					ВТ_ТаблицаСДанными.Должность,
		|					ВТ_ТаблицаСДанными.Организация)) КАК гкс_СоответствияДолжностейИКвалификацийСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТаблицаСДанными.Организация КАК Организация,
		|	ВТ_ТаблицаСДанными.Подразделение КАК Подразделение,
		|	ВТ_ТаблицаСДанными.Должность КАК Должность,
		|	ВТ_ТаблицаСДанными.ПериодПланирования КАК ПериодПланирования,
		|	ВТ_ТаблицаСДанными.КоличествоСотрудников КАК КоличествоСотрудников,
		|	ВТ_ТаблицаСДанными.Часы КАК Доступно,
		|	КвалификацииДолжностей.Квалификация КАК Квалификация
		|ИЗ
		|	ВТ_ТаблицаСДанными КАК ВТ_ТаблицаСДанными
		|		ЛЕВОЕ СОЕДИНЕНИЕ КвалификацииДолжностей КАК КвалификацииДолжностей
		|		ПО ВТ_ТаблицаСДанными.Организация = КвалификацииДолжностей.Организация
		|			И ВТ_ТаблицаСДанными.Подразделение = КвалификацииДолжностей.Подразделение
		|			И ВТ_ТаблицаСДанными.Должность = КвалификацииДолжностей.Должность
		|ИТОГИ ПО
		|	Организация";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаОрганизация = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаОрганизация.Следующий() Цикл
		НовыйДокумент = Документы.гкс_ВводДанныхПоТрудовымРесурсам.СоздатьДокумент();		
		НовыйДокумент.Дата = ТекущаяДатаСеанса();
		НовыйДокумент.ВидОперации = Перечисления.гкс_ВидыОперацииВводДанныхПоТрудовымРесурсам.ВводДанных;
		НовыйДокумент.Организация = ВыборкаОрганизация.Организация;
		НовыйДокумент.Комментарий = "Создано регламентным заданием, данными из ЗУП";
		НовыйДокумент.Ответственный = Пользователи.ТекущийПользователь();
		
		Выборка = ВыборкаОрганизация.Выбрать();	
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = НовыйДокумент.Трудозатраты.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка); 
			НоваяСтрока.ВидДвижения = Перечисления.гкс_ВидДвижения.Приход;
		КонецЦикла;
		НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;
		
КонецПроцедуры

Функция ПолучитьОтборXDTO(Отбор)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Менеджер = гкс_ОбщегоНазначения.ОбщийМодуль("Обработки.гкс_ОбработчикСообщенийАсинхронногоСервиса");	
	
	ОбъектXDTO = Менеджер.СоздатьОбъект("ASWorkForceAvailabilityRequest", 
										Метаданные.ПакетыXDTO.гкс_AsynxExchangeServices.ПространствоИмен);
										
	ДанныеОбъекта = Новый Структура;
	ДанныеОбъекта.Вставить("Company", Отбор.Организация);
	ДанныеОбъекта.Вставить("CostCenter", Отбор.ЦФО);
	ДанныеОбъекта.Вставить("DateFrom", Отбор.ДатаС);
	ДанныеОбъекта.Вставить("DateTo", Отбор.ДатаПо);

	ЗаполнитьЗначенияСвойствXDTO(ОбъектXDTO, ДанныеОбъекта);
	
	Возврат ОбъектXDTO;
	
КонецФункции

Функция ПолучитьТЗДляЗаполнения()
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ТЗ.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия"));
	ТЗ.Колонки.Добавить("Должность", Новый ОписаниеТипов("СправочникСсылка.Должности"));
	ТЗ.Колонки.Добавить("ПериодПланирования", Новый ОписаниеТипов("Дата"));
	ТЗ.Колонки.Добавить("КоличествоСотрудников", Новый ОписаниеТипов("Число"));
	ТЗ.Колонки.Добавить("Часы", Новый ОписаниеТипов("Число"));

	Возврат ТЗ;

КонецФункции

Функция СписокXDTOВТаблицуЗначений(СписокXDTO, СоответствиеНаименованийСвойств = Неопределено,  ТЗ = Неопределено)
	
	Если ТЗ = Неопределено И СписокXDTO.Количество() > 0 Тогда
		ТЗ = Новый ТаблицаЗначений;
		Для Каждого Свойство Из СписокXDTO[0].Свойства() Цикл
			Если СоответствиеНаименованийСвойств = Неопределено Тогда
				ТЗ.Колонки.Добавить(Свойство.Имя);
			Иначе
				ТЗ.Колонки.Добавить(СоответствиеНаименованийСвойств[Свойство.Имя]);
			КонецЕсли; 
		КонецЦикла;
	КонецЕсли; 
	
	СтрокиСНеНайденнымиЗначениями = Новый Массив;
	Для каждого ТекСтрокаXDTO Из СписокXDTO Цикл
		Если ТекСтрокаXDTO.WorkingHours = Неопределено Тогда
			Продолжить;			
		КонецЕсли; 
		СтрокаТЗ = ТЗ.Добавить();
		Для Каждого Колонка Из ТЗ.Колонки Цикл
			Реквизит = СоответствиеНаименованийСвойств[Колонка.Имя];
			гкс_ИнтеграцияXDTOАдаптер.ЗаполнитьРеквизитИзСвойстваXDTO(СтрокаТЗ[Колонка.Имя], ТекСтрокаXDTO, Реквизит);				
			Если Не ЗначениеЗаполнено(СтрокаТЗ[Колонка.Имя]) Тогда
				 СтрокиСНеНайденнымиЗначениями.Добавить(СтрокаТЗ);
				 Прервать;
			КонецЕсли; 
		КонецЦикла;
	КонецЦикла;
	Для каждого СтрокаКУдалению Из СтрокиСНеНайденнымиЗначениями Цикл
		ТЗ.Удалить(СтрокаКУдалению);		
	КонецЦикла; 
	
	Возврат ТЗ;
		
КонецФункции    

//Приемник - ОбъектXDTO
//Источник - Структура
Процедура ЗаполнитьЗначенияСвойствXDTO(Приемник, Знач Источник, СписокСвойств = Неопределено, ИсключаяСвойства="") Экспорт 
	
	Если ТипЗнч(СписокСвойств) = Тип("Строка") Тогда
		ЗаполняемыеСвойства = Новый Структура(СписокСвойств);
		
	ИначеЕсли ТипЗнч(СписокСвойств) = Тип("Структура") Тогда
		ЗаполняемыеСвойства = СписокСвойств;
		
	ИначеЕсли ТипЗнч(СписокСвойств) = Тип("СписокXDTO") Тогда	
		ЗаполняемыеСвойства = Новый Структура;
		Для Каждого Элемент Из СписокСвойств Цикл
			ЗаполняемыеСвойства.Вставить(Элемент);
		КонецЦикла;	
		
	Иначе
		ЗаполняемыеСвойства = Новый Структура;
	КонецЕсли;

	ИсключаемыеСвойства = Новый Структура(ИсключаяСвойства);
	
	Для каждого КлючИЗначение Из Источник Цикл
		
		Если ЗаполняемыеСвойства.Количество() > 0 И НЕ ЗаполняемыеСвойства.Свойство(КлючИЗначение.Ключ) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ИсключаемыеСвойства.Количество() > 0 И ИсключаемыеСвойства.Свойство(КлючИЗначение.Ключ) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КлючИЗначение.Значение) Тогда 
			Приемник[КлючИЗначение.Ключ] = ПолучитьЗначениеXDTO(КлючИЗначение.Значение);
		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьЗначениеXDTO(Значение, ТолькоСсылка =  Ложь) Экспорт
	
	Результат = Неопределено;
	
	Если ОбщегоНазначения.ЭтоСсылка(ТипЗнч(Значение)) Тогда 
		
		Если ТолькоСсылка Тогда
			Результат = ПолучитьObjectIDпоСсылке(Значение);
		Иначе
			МетаданныеЗначения = Значение.Метаданные();
			ИмяТипаXDTO = ПолучитьИмяТипаXDTO(МетаданныеЗначения.ПолноеИмя());
			Результат = СоздатьОбъект(ИмяТипаXDTO);
			Результат.name     = Строка(Значение);
			Результат.ObjectID = ПолучитьObjectIDпоСсылке(Значение);
			Если ИмяТипаXDTO = "ASCompany" Тогда
				Результат.CodeInn = Значение.ИНН;				
			КонецЕсли; 
			
		КонецЕсли;
		
	Иначе	
		Результат = Значение;
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьИмяТипаXDTO(ПолноеИмя) Экспорт
	
	ТаблицаСоответствия = СоответствиеТипов();
	Строка = ТаблицаСоответствия.Найти(ПолноеИмя, "ИмяТипа");
	Если Строка = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Строка.ИмяXDTO;
	
КонецФункции

Функция ПолучитьObjectIDпоСсылке(Ссылка) Экспорт
	
	ОбъектИД      = СоздатьОбъект("ASObjectID");
	ОбъектИД.id   = ПолучитьIDПоСсылке(Ссылка);
	ОбъектИД.type = ПолучитьИмяТипаXDTO(Ссылка.Метаданные().ПолноеИмя());
	
	Возврат ОбъектИД;
	
КонецФункции

Функция ПолучитьIDПоСсылке(Ссылка)
	
	Если Ссылка.Пустая() Тогда 
		Возврат "";
	КонецЕсли;	
	
	Если ОбщегоНазначения.ЭтоПеречисление(Ссылка.Метаданные()) Тогда
		Возврат ОбщегоНазначения.ИмяЗначенияПеречисления(Ссылка);
	Иначе	
		Возврат Строка(Ссылка.УникальныйИдентификатор());
	КонецЕсли;		
	
КонецФункции 

// Проверяет тип объекта XDTO
//
// Параметры:
//   ОбъектXDTO - ОбъектXDTO - проверяемый объект
//   Тип - Строка - имя типа XDTO
// Возвращаемое значение:
//   Булево - Истина, если объект является объектом указанного типа
//
Функция ПроверитьТип(ОбъектXDTO, Тип, ПространствоИмен) Экспорт
	
	Возврат (ТипЗнч(ОбъектXDTO) = Тип("ОбъектXDTO"))
		И (ОбъектXDTO.Тип() = ФабрикаXDTO.Тип(ПространствоИмен, Тип));
	
КонецФункции	

// Создает XDTO объект указанного типа из пространства имен "http://www.1c.ru/dm"
// 
// Параметры:
//   ТипОбъекта - Строка - имя типа XDTO
// Возвращаемое значение:
//   ОбъектXDTO - созданный объект указанного типа
//
Функция СоздатьОбъект(ТипОбъекта) Экспорт
	
	Возврат ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(Метаданные.ПакетыXDTO.гкс_AsynxExchangeServices.ПространствоИмен, ТипОбъекта));
	
КонецФункции

Функция СериализоватьИзXDTO(Объект) Экспорт
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("UTF-8");
	Запись.ЗаписатьОбъявлениеXML();

	ФабрикаXDTO.ЗаписатьXML(Запись, Объект, , , , НазначениеТипаXML.Явное);
	
	Возврат Запись.Закрыть();
	
КонецФункции

Функция СоответствиеТипов() Экспорт
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("ИмяXDTO", Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("ИмяТипа",	Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("ИспользоватьМенеджер",	Новый ОписаниеТипов("Булево"));
	
	//добавление соответствий типов
	ДобавитьСтроку(Таблица, "ASCompany", 				"Справочник.Организации");
	ДобавитьСтроку(Таблица, "ASCostCenter", 			"Справочник.СтруктураПредприятия");
	
	Возврат Таблица;
	
КонецФункции     

Процедура ДобавитьСтроку(Таблица, ИмяXDTO, ИмяТипа,ИспользоватьМенеджер = Ложь)
	
	НоваяСтрока = Таблица.Добавить();
	НоваяСтрока.ИмяXDTO = ИмяXDTO;
	НоваяСтрока.ИмяТипа = ИмяТипа;
	НоваяСтрока.ИспользоватьМенеджер = ИспользоватьМенеджер;
	
КонецПроцедуры

Процедура ДобавитьЗапросВЛог(Данные, Настройки, Ответ, НачалоЗапроса)
	
	ЗаписьЛога = Новый Структура;
			
	ЗаписьЛога.Вставить("Ответ", Ответ);
	ЗаписьЛога.Вставить("Запрос", Данные);
	ЗаписьЛога.Вставить("Метод", Настройки["Метод"]);
	ЗаписьЛога.Вставить("ИмяСервиса", Настройки["Очередь"]);
	ЗаписьЛога.Вставить("Длительность", (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоЗапроса) / 1000);
	
	гкс_АсинхронныеСервисыВызовСервера.ЗаписатьВЛог(ЗаписьЛога);
		
КонецПроцедуры

#КонецОбласти

