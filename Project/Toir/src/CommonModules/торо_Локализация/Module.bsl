Функция ПолучитьЯзыки() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_Языки.Ссылка КАК Ссылка,
		|	торо_Языки.Код КАК Код
		|ИЗ
		|	Справочник.торо_Языки КАК торо_Языки";
	
	ТаблицаЯзыков = Запрос.Выполнить().Выгрузить();
	
	Возврат ТаблицаЯзыков;
КонецФункции  

Функция ПолучитьЯзыкиМассивом() Экспорт
	ТаблицаЯзыков = ПолучитьЯзыки();
	МассивЯзыков = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаЯзыков);
	
	Возврат МассивЯзыков;
КонецФункции  

