#Область ФормыВспомогательное

Функция ЭтоПользовательскаяФорма(Источник, ВидФормы)
	ЭтоПользовательскаяФорма = Ложь;
	
	МетаданныеИсточника = ПолучитьМетаданныеИсточника(Источник);
	Формы = Метаданные[МетаданныеИсточника.ТипМетаданных][МетаданныеИсточника.ТипОбъектаИБ].Формы;
	
	СоответствиеФорм = Новый Соответствие;
	// >> [Деснол] [Ушаков А.Д.] [20.09.2019] 
	СоответствиеФорм.Вставить("ФормаОбъекта", 	СтрРазделить("ФормаЭлемента,ФормаДокумента", ","));
	СоответствиеФорм.Вставить("ФормаВыбора", 	СтрРазделить("ФормаВыбора", ","));
	// << [Деснол] [Ушаков А.Д.] [20.09.2019] 
	СоответствиеФорм.Вставить("ФормаСписка", 	СтрРазделить("ФормаСписка", ","));
	
	НазваниеВидаФормы = СоответствиеФорм[ВидФормы];
	
	Если НазваниеВидаФормы <> Неопределено Тогда
		Для каждого Форма Из Формы Цикл
			Если НазваниеВидаФормы.Найти(Форма.Имя) <> Неопределено Тогда
				ЭтоПользовательскаяФорма = Истина;
				Прервать;
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	
	Возврат ЭтоПользовательскаяФорма;
КонецФункции

// [Недоработана] 
Функция ПолучитьМетаданныеИсточника(Источник)
	ПодстрокиТипа = СтрРазделить(Источник, ".");
	
	СоответствиеТипов = Новый Соответствие;
	СоответствиеТипов.Вставить("СправочникМенеджер", 		"Справочники");
	СоответствиеТипов.Вставить("ДокументМенеджер", 			"Документы");
	СоответствиеТипов.Вставить("РегистрСведенийМенеджер", 	"РегистрыСведений");
	
	ТипМетаданных = СоответствиеТипов[ПодстрокиТипа[0]];
	ТипОбъектаИБ = ПодстрокиТипа[1];
	
	МетаданныеИсточника = Новый Структура("ТипМетаданных,ТипОбъектаИБ", ТипМетаданных, ТипОбъектаИБ);
	
	Возврат МетаданныеИсточника;
КонецФункции

// Возвращает масиив имен макетов, доступных к локализации
