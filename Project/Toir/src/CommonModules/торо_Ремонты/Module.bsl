#Область ПрограммныйИнтерфейс

// Строит диаграмму Ганта для графика ППР.
// Делегирует построение приватной процедуре в зависимости от режима иерархии.
//
// Параметры:
//  Диаграмма              - Диаграмма  - диаграмма Ганта.
//  ТаблицаДанныхППР       - ТаблицаЗначений - исходные данные.
//  СтруктураИерархии      - СправочникСсылка.торо_СтруктурыОР - структура иерархии.
//  ОтображатьИерархию     - Булево - отображать иерархию.
//  ИспользоватьИерархию   - Булево - использовать иерархию.
//  РезультатЗапроса       - РезультатЗапроса - результат запроса (не используется).
//  ЭтоКорректировка       - Булево - признак корректировки.
//  Редактировать          - Булево - разрешить редактирование.
//  ИспользоватьРасшифровку - Булево - добавлять расшифровку к точкам.
//  ДиаграммаДляОтчета     - Булево - диаграмма строится для отчёта.
//  СортироватьПоНаименованию - Булево - сортировать по наименованию.
//
Процедура ПостроитьДиаграммуГантаДляППР(Диаграмма, ТаблицаДанныхППР, СтруктураИерархии = Неопределено, ОтображатьИерархию = Ложь, ИспользоватьИерархию = Ложь, РезультатЗапроса = Неопределено, ЭтоКорректировка = Ложь, Редактировать = Истина, ИспользоватьРасшифровку = Истина, ДиаграммаДляОтчета = Ложь, СортироватьПоНаименованию = Истина) Экспорт

	НастройкиГанта = ИнициализироватьНастройкиДиаграммы(Диаграмма, ТаблицаДанныхППР);
	НастройкиГанта.Вставить("ИспользоватьРасшифровку",    ИспользоватьРасшифровку);
	НастройкиГанта.Вставить("ЭтоКорректировка",           ЭтоКорректировка);
	НастройкиГанта.Вставить("Редактировать",               Редактировать);
	НастройкиГанта.Вставить("СортироватьПоНаименованию",  СортироватьПоНаименованию);

	Если Не ОтображатьИерархию И НЕ ИспользоватьИерархию Тогда
		ПостроитьГантаБезИерархии(Диаграмма, ТаблицаДанныхППР, НастройкиГанта);
	ИначеЕсли Не ЗначениеЗаполнено(СтруктураИерархии) И НЕ ИспользоватьИерархию Тогда
		ПостроитьГантаСПоложением(Диаграмма, ТаблицаДанныхППР, НастройкиГанта);
	ИначеЕсли НЕ ИспользоватьИерархию И СтруктураИерархии.ИзменяетсяДокументами Тогда
		ПостроитьГантаСИзменяемойИерархией(Диаграмма, ТаблицаДанныхППР, НастройкиГанта, СтруктураИерархии);
	ИначеЕсли ИспользоватьИерархию Тогда
		ПостроитьГантаСДеревомИерархии(Диаграмма, ТаблицаДанныхППР, НастройкиГанта);
	Иначе
		ПостроитьГантаСПоложениемИСтруктурой(Диаграмма, ТаблицаДанныхППР, НастройкиГанта, СтруктураИерархии);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Инициализирует диаграмму и возвращает структуру с настройками.
//
// Параметры:
//  Диаграмма        - Диаграмма        - диаграмма Ганта.
//  ТаблицаДанныхППР - ТаблицаЗначений  - исходные данные.
//
// Возвращаемое значение:
//  Структура - НастройкиГанта: ЕстьЦепочки, ТекДата, СтруктураЦветов, СерияРемонт.
//
Функция ИнициализироватьНастройкиДиаграммы(Диаграмма, ТаблицаДанныхППР)

	ОписаниеБулево = Новый ОписаниеТипов(Новый Массив);
	ОписаниеБулево = Новый ОписаниеТипов("Булево");

	ЕстьЦепочки = ТаблицаДанныхППР.Колонки.Найти("Цепочка") <> Неопределено;

	Если ТаблицаДанныхППР.Колонки.Найти("ЕстьВЗ") = Неопределено Тогда
		ТаблицаДанныхППР.Колонки.Добавить("ЕстьВЗ", ОписаниеБулево);
		ТаблицаДанныхППР.ЗаполнитьЗначения(Ложь, "ЕстьВЗ");
	КонецЕсли;

	Если ТаблицаДанныхППР.Колонки.Найти("ЕстьДвиженияПоВЗ") = Неопределено Тогда
		ТаблицаДанныхППР.Колонки.Добавить("ЕстьДвиженияПоВЗ", ОписаниеБулево);
		ТаблицаДанныхППР.ЗаполнитьЗначения(Ложь, "ЕстьДвиженияПоВЗ");
	КонецЕсли;

	Если ТаблицаДанныхППР.Колонки.Найти("ID") = Неопределено Тогда
		ТаблицаДанныхППР.Колонки.Добавить("ID", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(36)));
		ТаблицаДанныхППР.ЗаполнитьЗначения("", "ID");
	КонецЕсли;

	Диаграмма.Очистить();
	Диаграмма.АвтоОпределениеПолногоИнтервала = Ложь;

	СерияРемонт = Диаграмма.Серии.Добавить();
	СерияРемонт.Текст = "График ремонта";

	СтруктураЦветов = Новый Структура;
	СтруктураЦветов.Вставить("ЦветВыполненого",          WebЦвета.Черный);
	СтруктураЦветов.Вставить("ЦветИзмененного",          WebЦвета.Томатный);
	СтруктураЦветов.Вставить("ЦветОтмененного",          WebЦвета.Красный);
	СтруктураЦветов.Вставить("ЦветЗапланированного",     WebЦвета.Васильковый);
	СтруктураЦветов.Вставить("ЦветЗамещенногоИсходного", WebЦвета.СеребристоСерый);
	СтруктураЦветов.Вставить("ЦветИсходного",            WebЦвета.ГолубойСоСтальнымОттенком);
	СтруктураЦветов.Вставить("ЦветЗамещенного",          WebЦвета.СветлоСерый);

	НастройкиГанта = Новый Структура;
	НастройкиГанта.Вставить("ЕстьЦепочки",    ЕстьЦепочки);
	НастройкиГанта.Вставить("ТекДата",         ТекущаяДата());
	НастройкиГанта.Вставить("СтруктураЦветов", СтруктураЦветов);
	НастройкиГанта.Вставить("СерияРемонт",     СерияРемонт);

	Возврат НастройкиГанта;

КонецФункции

// Строит текст пакетного запроса ППР — базовую часть (помещение во временную таблицу).
// Возвращает начальный текст с полями и необязательными колонками.
Функция ПостроитьБазовыйТекстЗапросаГанта(НастройкиГанта)

	ЕстьЦепочки           = НастройкиГанта.ЕстьЦепочки;
	СортироватьПоНаименованию = НастройкиГанта.СортироватьПоНаименованию;

	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаДанныхППР.ОбъектРемонтныхРабот,
	|	ТаблицаДанныхППР.ВидРемонтныхРабот,
	|	ТаблицаДанныхППР.ID,
	|	ТаблицаДанныхППР.ДатаНач,
	|	ТаблицаДанныхППР.ДатаКон,
	|	ТаблицаДанныхППР.ДатаНачСт,
	|	ТаблицаДанныхППР.ДатаКонСт,
	|	ТаблицаДанныхППР.ЕстьВЗ,
	|	ТаблицаДанныхППР.ЕстьДвиженияПоВЗ,
	|	ТаблицаДанныхППР.Отменен,
	|	ТаблицаДанныхППР.Замещен,
	|	ТаблицаДанныхППР.ЗамещенСт,
	|	ТаблицаДанныхППР.ДоступенДляРедактирования";
	Если НЕ СортироватьПоНаименованию Тогда
		ТекстЗапроса = ТекстЗапроса + ", ТаблицаДанныхППР.НомерОР";
	КонецЕсли;
	Если ЕстьЦепочки Тогда
		ТекстЗапроса = ТекстЗапроса + ", ТаблицаДанныхППР.Цепочка, ТаблицаДанныхППР.НомерСтрокиВРЦепочки";
	КонецЕсли;
	ТекстЗапроса = ТекстЗапроса + "
	|ПОМЕСТИТЬ ТаблицаДанныхППР
	|ИЗ
	|	&ТаблицаДанныхППР КАК ТаблицаДанныхППР
	|;
	|";

	Возврат ТекстЗапроса;

КонецФункции

// Формирует суффикс УПОРЯДОЧИТЬ ПО для запроса диаграммы.
Функция ПостроитьСуффиксУпорядочивания(НастройкиГанта, ДобавитьПоложение = Ложь)

	ЕстьЦепочки           = НастройкиГанта.ЕстьЦепочки;
	СортироватьПоНаименованию = НастройкиГанта.СортироватьПоНаименованию;

	Если СортироватьПоНаименованию Тогда
		Если ЕстьЦепочки Тогда
			Суффикс = "
			|УПОРЯДОЧИТЬ ПО
			|	ОбъектРемонтныхРабот.Наименование,
			|	НомерСтрокиВРЦепочки,
			|	ВидРемонтныхРабот.Наименование,
			|	ДатаНач,
			|	ДатаКон";
		Иначе
			Суффикс = "
			|УПОРЯДОЧИТЬ ПО
			|	ОбъектРемонтныхРабот.Наименование,
			|	ВидРемонтныхРабот.Наименование,
			|	ДатаНач,
			|	ДатаКон";
		КонецЕсли;
	Иначе
		Если ЕстьЦепочки Тогда
			Суффикс = "
			|УПОРЯДОЧИТЬ ПО
			|	НомерОР,
			|	ВидРемонтныхРабот.Наименование,
			|	НомерСтрокиВРЦепочки";
		Иначе
			Суффикс = "
			|УПОРЯДОЧИТЬ ПО
			|	НомерОР,
			|	ВидРемонтныхРабот.Наименование";
		КонецЕсли;
	КонецЕсли;

	Возврат Суффикс;

КонецФункции

// Строит диаграмму Ганта без иерархии (вариант 1).
Процедура ПостроитьГантаБезИерархии(Диаграмма, ТаблицаДанныхППР, НастройкиГанта)

	ЕстьЦепочки = НастройкиГанта.ЕстьЦепочки;

	Запрос = Новый Запрос;
	Запрос.Текст = ПостроитьБазовыйТекстЗапросаГанта(НастройкиГанта);
	Запрос.Текст = Запрос.Текст + "
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаДанныхППР.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	|	ТаблицаДанныхППР.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	ТаблицаДанныхППР.ДокументППР,
	|	ТаблицаДанныхППР.ID,
	|	ТаблицаДанныхППР.ДатаНач КАК ДатаНач,
	|	ТаблицаДанныхППР.ДатаКон КАК ДатаКон,
	|	ТаблицаДанныхППР.ДатаНачСт,
	|	ТаблицаДанныхППР.ДатаКонСт,
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаДанныхППР.ОбъектРемонтныхРабот),
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаДанныхППР.ВидРемонтныхРабот),
	|	ТаблицаДанныхППР.ЕстьВЗ,
	|	ТаблицаДанныхППР.ЕстьДвиженияПоВЗ,
	|	ТаблицаДанныхППР.Отменен,
	|	ТаблицаДанныхППР.ЗамещенСт,
	|	ТаблицаДанныхППР.Замещен,
	|	ТаблицаДанныхППР.ДоступенДляРедактирования";
	Если НЕ НастройкиГанта.СортироватьПоНаименованию Тогда
		Запрос.Текст = Запрос.Текст + ", ТаблицаДанныхППР.НомерОР";
	КонецЕсли;
	Если ЕстьЦепочки Тогда
		Запрос.Текст = Запрос.Текст + ", ТаблицаДанныхППР.Цепочка, ТаблицаДанныхППР.НомерСтрокиВРЦепочки";
	КонецЕсли;
	Запрос.Текст = Запрос.Текст + "
	|ИЗ
	|	ТаблицаДанныхППР КАК ТаблицаДанныхППР
	|ГДЕ ДатаНач > ДАТАВРЕМЯ(1,1,1,0,0,0)";
	Запрос.Текст = Запрос.Текст + ПостроитьСуффиксУпорядочивания(НастройкиГанта);
	Запрос.Текст = Запрос.Текст + "
	|ИТОГИ ПО
	|	ОбъектРемонтныхРабот";
	Если ЕстьЦепочки Тогда
		Запрос.Текст = Запрос.Текст + ", НомерСтрокиВРЦепочки";
	КонецЕсли;
	Запрос.Текст = Запрос.Текст + ", ВидРемонтныхРабот";

	Запрос.УстановитьПараметр("ТаблицаДанныхППР", ТаблицаДанныхППР);

	ВыборкаПоОР = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПоОР.Следующий() Цикл

		ТочкаОРР = Диаграмма.Точки.Добавить();
		ТочкаОРР.Текст = ВыборкаПоОР.ОбъектРемонтныхРаботПредставление;
		Если НастройкиГанта.ИспользоватьРасшифровку Тогда
			ТочкаОРР.Расшифровка = ВыборкаПоОР.ОбъектРемонтныхРабот;
		КонецЕсли;

		ВыборкаПоВРИлиЦепочкам = ВыборкаПоОР.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПоВРИлиЦепочкам.Следующий() Цикл
			Если ЕстьЦепочки Тогда
				ВыборкаПоВР = ВыборкаПоВРИлиЦепочкам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПоВР.Следующий() Цикл
					ВывестиЧастьГрафикаПервыйВариант(ВыборкаПоВР, ВыборкаПоОР, НастройкиГанта.ТекДата, ТочкаОРР, НастройкиГанта.СерияРемонт, Диаграмма, НастройкиГанта.СтруктураЦветов, НастройкиГанта.ИспользоватьРасшифровку, НастройкиГанта.ЭтоКорректировка, НастройкиГанта.Редактировать);
				КонецЦикла;
			Иначе
				ВывестиЧастьГрафикаПервыйВариант(ВыборкаПоВРИлиЦепочкам, ВыборкаПоОР, НастройкиГанта.ТекДата, ТочкаОРР, НастройкиГанта.СерияРемонт, Диаграмма, НастройкиГанта.СтруктураЦветов, НастройкиГанта.ИспользоватьРасшифровку, НастройкиГанта.ЭтоКорректировка, НастройкиГанта.Редактировать);
			КонецЕсли;
		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

// Строит диаграмму Ганта с положением из родителя ОР (вариант 2).
Процедура ПостроитьГантаСПоложением(Диаграмма, ТаблицаДанныхППР, НастройкиГанта)

	ЕстьЦепочки = НастройкиГанта.ЕстьЦепочки;

	Запрос = Новый Запрос;
	Запрос.Текст = ПостроитьБазовыйТекстЗапросаГанта(НастройкиГанта);
	Запрос.Текст = Запрос.Текст + "
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаДанныхППР.ОбъектРемонтныхРабот.Родитель КАК Положение,
	|	ТаблицаДанныхППР.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	|	ТаблицаДанныхППР.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	ТаблицаДанныхППР.ID,
	|	ТаблицаДанныхППР.ДатаНач КАК ДатаНач,
	|	ТаблицаДанныхППР.ДатаКон КАК ДатаКон,
	|	ТаблицаДанныхППР.ДатаНачСт,
	|	ТаблицаДанныхППР.ДатаКонСт,
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаДанныхППР.ОбъектРемонтныхРабот),
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаДанныхППР.ВидРемонтныхРабот),
	|	ТаблицаДанныхППР.ЕстьВЗ,
	|	ТаблицаДанныхППР.ЕстьДвиженияПоВЗ,
	|	ТаблицаДанныхППР.Отменен,
	|	ТаблицаДанныхППР.Замещен,
	|	ТаблицаДанныхППР.ЗамещенСт,
	|	ТаблицаДанныхППР.ДоступенДляРедактирования";
	Если НЕ НастройкиГанта.СортироватьПоНаименованию Тогда
		Запрос.Текст = Запрос.Текст + ", ТаблицаДанныхППР.НомерОР";
	КонецЕсли;
	Если ЕстьЦепочки Тогда
		Запрос.Текст = Запрос.Текст + ", ТаблицаДанныхППР.Цепочка, ТаблицаДанныхППР.НомерСтрокиВРЦепочки";
	КонецЕсли;
	Запрос.Текст = Запрос.Текст + "
	|ИЗ
	|	ТаблицаДанныхППР КАК ТаблицаДанныхППР
	|ГДЕ ДатаНач > ДАТАВРЕМЯ(1,1,1,0,0,0)";
	Запрос.Текст = Запрос.Текст + ПостроитьСуффиксУпорядочивания(НастройкиГанта);
	Запрос.Текст = Запрос.Текст + "
	|ИТОГИ ПО
	|	Положение,
	|	ОбъектРемонтныхРабот";
	Если ЕстьЦепочки Тогда
		Запрос.Текст = Запрос.Текст + ", НомерСтрокиВРЦепочки";
	КонецЕсли;
	Запрос.Текст = Запрос.Текст + ", ВидРемонтныхРабот";

	Запрос.УстановитьПараметр("ТаблицаДанныхППР", ТаблицаДанныхППР);

	ВыборкаПоПоложению = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПоПоложению.Следующий() Цикл

		ТочкаПоложение = Диаграмма.Точки.Добавить();
		ТочкаПоложение.Текст = СокрЛП(ВыборкаПоПоложению.Положение);
		Если НастройкиГанта.ИспользоватьРасшифровку Тогда
			ТочкаПоложение.Расшифровка = ВыборкаПоПоложению.Положение;
		КонецЕсли;

		ВыборкаПоОР = ВыборкаПоПоложению.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПоОР.Следующий() Цикл

			ТочкаОРР = ТочкаПоложение.Точки.Добавить();
