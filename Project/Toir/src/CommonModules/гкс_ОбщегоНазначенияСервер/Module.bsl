#Область СлужебныеПроцедурыИФункции

// Находит ОР по Измерению и обновляет у них Кодировку
Процедура ОбновитьКодировкиОР(Измерение) Экспорт
	ТипИзмерения = ТипЗнч(Измерение);
	Если ТипИзмерения = Тип("СправочникСсылка.торо_ОбъектыРемонта") Тогда 
		ОбновитьКодировкуПоСсылкеОР(Измерение);
	ИначеЕсли ТипИзмерения = Тип("СправочникСсылка.торо_ТиповыеОР") Тогда 
		ОбновитьКодировкуПоСсылкеТОР(Измерение);
	ИначеЕсли ТипИзмерения = Тип("СправочникСсылка.торо_НаправленияОбъектовРемонтныхРабот") Тогда 
		ОбновитьКодировкуПоНаправлению(Измерение);
	ИначеЕсли ТипИзмерения = Тип("СправочникСсылка.гкс_МестаИПлощадки") Тогда 
		ОбновитьКодировкуПоТехМесту(Измерение, ".МестоПлощадка");
	ИначеЕсли ТипИзмерения = Тип("СправочникСсылка.гкс_ЗаводыИПодразделения") Тогда 
		ОбновитьКодировкуПоТехМесту(Измерение, ".ЗаводПодразделение");
	ИначеЕсли ТипИзмерения = Тип("СправочникСсылка.гкс_Участки") Тогда 
		ОбновитьКодировкуПоТехМесту(Измерение, ".Участок");
	ИначеЕсли ТипИзмерения = Тип("СправочникСсылка.гкс_ТехническиеМеста") Тогда 
		ОбновитьКодировкуПоТехМесту(Измерение);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьКодировкуПоСсылкеОР(Ссылка)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОбъектыРемонта.ТиповойОР КАК ТиповойОР,
		|	торо_ОбъектыРемонта.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ТОР
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА гкс_ТекущиеФМОР.ОР = гкс_ТекущиеФМОР.ФМ
		|			ТОГДА гкс_ТекущиеФМОР.ТМ
		|		ИНАЧЕ гкс_ТекущиеФМОР.ТМФМ
		|	КОНЕЦ КАК ТМ,
		|	гкс_ТекущиеФМОР.ОР КАК ОР
		|ПОМЕСТИТЬ НужноеТМ
		|ИЗ
		|	РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
		|ГДЕ
		|	гкс_ТекущиеФМОР.ОР = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ТОР.ТиповойОР.Направление.гкс_Кодировка, """") КАК Направление,
		|	ЕСТЬNULL(НужноеТМ.ТМ.МестоПлощадка.Кодировка, """") КАК Площадка,
		|	ЕСТЬNULL(НужноеТМ.ТМ.ЗаводПодразделение.Кодировка, """") КАК Завод,
		|	ЕСТЬNULL(НужноеТМ.ТМ.Участок.Кодировка, """") КАК Участок,
		|	ЕСТЬNULL(ТОР.Ссылка, НужноеТМ.ОР) КАК Ссылка
		|ИЗ
		|	ТОР КАК ТОР
		|		ПОЛНОЕ СОЕДИНЕНИЕ НужноеТМ КАК НужноеТМ
		|		ПО ТОР.Ссылка = НужноеТМ.ОР";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.гкс_КодировкаОР.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ОР.Установить(Выборка.Ссылка);
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.ОР = Выборка.Ссылка;
		НоваяЗапись.Текст = Строка(Выборка.Площадка) + "." + Выборка.Завод + "." + Выборка.Участок + "." + Выборка.Направление;
		НаборЗаписей.Записать();
	КонецЦикла;
	
КонецПроцедуры

