	ДанныеТехКарт = Новый Структура;
	ТехКарты = Новый Массив;
	ПодчиненныеТехКарты = Новый Массив;
	
	ТехКартыТОР(ТОРСсылка, ТехКарты);
	
	Если СПодчиенными Тогда
		ПодчиненныеТехКарты(ТехКарты, ПодчиненныеТехКарты);			
