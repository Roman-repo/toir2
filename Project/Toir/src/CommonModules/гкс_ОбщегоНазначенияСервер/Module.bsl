Процедура гкс_ПроверкаВыполненияМероприятий() Экспорт
	Событие = Константы.гкс_СобытиеПросрочкиМероприятияЕвобланк.Получить();
	Если Не ЗначениеЗаполнено(Событие) Тогда 
		Возврат;
	КонецЕсли;
	//
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Рег.Срок КАК Срок,
	|	Рег.Мероприятие КАК Мероприятие,
	|	Рег.Ответственный КАК Ответственный,
	|	Рег.Регистратор КАК Ссылка
	|ИЗ
	|	РегистрСведений.гкс_ОжидаемыеМероприятияЕвобланк КАК Рег
	|Где Рег.Срок < &ТекДата
	|ИТОГИ ПО
	|	Ссылка";
	
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда 
		ОбМодуль = торо_РаботаСУведомлениями;
		ВыборкаДок = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаДок.Следующий() Цикл
			ДокОб = ВыборкаДок.Ссылка.ПолучитьОбъект();
			СтруктураДанных = Новый Структура();
			торо_РаботаСУведомлениями.ЗаполнитьСтруктуруДанныхДокумента(СтруктураДанных, ДокОб);
			СтруктураДанных.Вставить("ВидДокумента", "гкс_ЕВОБланк");
			Выборка = ВыборкаДок.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтруктураДанных.Вставить("Ответственный", Выборка.Ответственный);
				СтруктураДанных.Вставить("Мероприятие", Выборка.Мероприятие);
				ОбМодуль.ЗаписатьУведомленияФМ(СтруктураДанных, Событие);
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

