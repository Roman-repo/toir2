////////////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ПЕРЕМЕННЫЕ
&НаКлиенте
Перем СозданыАкты;

#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ДокОснование") Тогда
		ДокОснование = Параметры.ДокОснование;
	КонецЕсли;
	
	Если Параметры.Свойство("ТабОперацийБезНаряда") Тогда
		
		ТабОперацийБезНаряда = Параметры.ТабОперацийБезНаряда.Выгрузить();
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	Таб.ВводитьНаряд,
		|	Таб.ОбъектРемонта,
		|	Таб.ВидРемонта,
		|	Таб.РемонтнаяРабота,
		|	Таб.ДатаНачалаРемонта,
		|	Таб.ДатаОкончанияРемонта,
		|	Таб.ID
		|ПОМЕСТИТЬ ТабОперацийБезНаряда
		|ИЗ
		|	&ТабОперацийБезНаряда КАК Таб
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТабОперацийБезНаряда.ВводитьНаряд,
		|	ТабОперацийБезНаряда.ОбъектРемонта КАК ОбъектРемонта,
		|	ТабОперацийБезНаряда.ВидРемонта КАК ВидРемонта,
		|	ТабОперацийБезНаряда.РемонтнаяРабота,
		|	ТабОперацийБезНаряда.ДатаНачалаРемонта КАК ДатаНачалаРемонта,
		|	ТабОперацийБезНаряда.ДатаОкончанияРемонта КАК ДатаОкончанияРемонта,
		|	ТабОперацийБезНаряда.ID
		|ИЗ
		|	ТабОперацийБезНаряда КАК ТабОперацийБезНаряда
		|ИТОГИ ПО
		|	ОбъектРемонта,
		|	ДатаНачалаРемонта,
		|	ВидРемонта";
		
		Запрос.УстановитьПараметр("ТабОперацийБезНаряда", ТабОперацийБезНаряда);
		Результат = Запрос.Выполнить();
		ВыборкаОбъектРемонта = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Дерево = РеквизитФормыВЗначение("РемонтныеРаботы");
		
		Пока ВыборкаОбъектРемонта.Следующий() Цикл
			
			НоваяСтрока = Дерево.Строки.Добавить();
			НоваяСтрока.Объект = ВыборкаОбъектРемонта.ОбъектРемонта;
			
			ВыборкаДатаНачала = ВыборкаОбъектРемонта.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаДатаНачала.Следующий() Цикл
								
				ВыборкаВидРемонта = ВыборкаДатаНачала.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаВидРемонта.Следующий() Цикл
					НС = НоваяСтрока.Строки.Добавить();
					НС.Объект = ВыборкаВидРемонта.ВидРемонта;
					
					ВыборкаДетЗаписи = ВыборкаВидРемонта.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					
					Пока ВыборкаДетЗаписи.Следующий() Цикл
						
						НС.ДатаНачала = ВыборкаДетЗаписи.ДатаНачалаРемонта;
						НС.ДатаОкончания = ВыборкаДетЗаписи.ДатаОкончанияРемонта;
						
						НовСтр = НС.Строки.Добавить();
						НовСтр.Объект = ВыборкаДетЗаписи.РемонтнаяРабота;	
						НовСтр.ID = ВыборкаДетЗаписи.ID;
						
					КонецЦикла;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
		ЗначениеВРеквизитФормы(Дерево, "РемонтныеРаботы");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Развернуть(Команды.Развернуть);
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	Если Не СозданыАкты Тогда
		ТекстСообщения = НСтр("es='Es imposible crear ""el Acta sobre la ejecución de la etapa de los trabajos"" ya que el documento-razón contiene las reparaciones a los trabajos del peligro subido. ¡Es necesario obligatoriamente introducir el documento ""el Vestido de la ejecución de los trabajos de reparación""!';ru='Невозможно создать ""Акт о выполнении этапа работ"" поскольку документ-основание содержит ремонты с работами повышенной опасности. Требуется обязательно ввести документ ""Наряд на выполнение ремонтных работ""!';en='Unable to create an “Act on the implementation of the work phase” because the base document contains repairs with hazardous work. It is required to enter the document ""Order for repair work""!'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРемонтныеРаботы

&НаКлиенте
Процедура РемонтныеРаботыВыбранПриИзменении(Элемент)
	
	ТекСтрока = Элементы.РемонтныеРаботы.ТекущиеДанные;
	
	Если НЕ ТекСтрока = Неопределено Тогда
		ПроставитьГалочкиПоВеткеВниз (ТекСтрока, ТекСтрока.Выбран);
		ПроставитьГалочкиПоВеткеВверх(ТекСтрока, ТекСтрока.Выбран);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура ВвестиНаряды(Команда)
	
	МассивРемонтов = ВвестиНарядыНаСервере();
	
	Если МассивРемонтов <> Неопределено ИЛИ ИзНормативов = Истина Тогда 
		
		СтруктураПараметров = Новый Структура;
		Основание = Новый Структура;
		Основание.Вставить("Основание", ДокОснование);
		Основание.Вставить("ОпасныеРаботы", Истина);
		Основание.Вставить("ИзНормативов", ИзНормативов);
		Основание.Вставить("РемонтыОборудования", ВыбранныеОперации);
		Основание.Вставить("МассивРемонтов", МассивРемонтов);
		СтруктураПараметров.Вставить("Основание", Основание);
		ОткрытьФорму("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ФормаОбъекта", СтруктураПараметров);
		
		СозданыАкты = Истина;
		Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВыделение(Команда)
	
	Для каждого Стр Из РемонтныеРаботы.ПолучитьЭлементы() Цикл
		
		Стр.Выбран = Ложь;
		ПроставитьГалочкиПоВеткеВниз (Стр, Ложь);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьВсе(Команда)
	
	Для каждого Стр Из РемонтныеРаботы.ПолучитьЭлементы() Цикл
		
		Стр.Выбран = Истина;
		ПроставитьГалочкиПоВеткеВниз (Стр, Истина);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Развернуть(Команда)	
	Для Каждого ТекСтрока Из РемонтныеРаботы.ПолучитьЭлементы() Цикл
		Элементы.РемонтныеРаботы.Развернуть(ТекСтрока.ПолучитьИдентификатор(), Истина);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура Свернуть(Команда)
	
	Для каждого Стр Из РемонтныеРаботы.ПолучитьЭлементы() Цикл
		
		СвернутьПодчиненные(Стр);
		Элементы.РемонтныеРаботы.Свернуть(Стр.ПолучитьИдентификатор());
		
	КонецЦикла; 
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Функция ВвестиНарядыНаСервере()
	
	Дерево = РеквизитФормыВЗначение("РемонтныеРаботы");
	
	Рез = Дерево.Строки.Найти(Истина, "Выбран", Истина); 
	
	Если Рез <> Неопределено Тогда
		
		Для каждого СтрокаОР Из Дерево.Строки Цикл
			
			Если СтрокаОР.Выбран Тогда
		
				Для каждого СтрокаВР ИЗ СтрокаОР.Строки Цикл
		
					Если СтрокаВР.Выбран Тогда
												
						Для Каждого СтрокаОперации ИЗ СтрокаВР.Строки Цикл
							
							Если СтрокаОперации.Выбран Тогда
								НС = ВыбранныеОперации.Добавить();
								НС.ДатаНачалаРемонта = СтрокаВР.ДатаНачала;
								НС.ДатаОкончанияРемонта = СтрокаВР.ДатаОкончания; 
								НС.ВидРемонта = СтрокаВР.Объект;
								НС.ID = СтрокаОперации.ID;
								НС.РемонтнаяРабота = СтрокаОперации.Объект;
								НС.ОбъектРемонта = СтрокаОР.Объект;
							КонецЕсли;
							
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ВыбранныеОперации.Количество() И (ТипЗнч(ДокОснование) = Тип("ДокументСсылка.торо_ВнешнееОснованиеДляРабот") ИЛИ ТипЗнч(ДокОснование) = Тип("ДокументСсылка.торо_ЗаявкаНаРемонт")) Тогда
		
			ТабIDИРабот = ВыбранныеОперации.Выгрузить(,"ID, РемонтнаяРабота");
			ТабIDИРабот.Свернуть("ID, РемонтнаяРабота");
			МассивID = ТабIDИРабот.ВыгрузитьКолонку("ID");
			МассивРабот = ТабIDИРабот.ВыгрузитьКолонку("РемонтнаяРабота");
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	Таб.ID КАК ID,
			|	Таб.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
			|	Таб.РемонтнаяРабота КАК РемонтнаяРабота,
			|	Таб.Родитель_ID КАК Родитель_ID,
			|	Таб.Количество КАК Количество
			|ПОМЕСТИТЬ ТабРемРаб
			|ИЗ
			|	&Таб КАК Таб
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТабРемРаб.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
			|	ТабРемРаб.ID КАК ID,
			|	ТабРемРаб.РемонтнаяРабота КАК РемонтнаяРабота,
			|	ТабРемРаб.Родитель_ID КАК Родитель_ID,
			|	ТабРемРаб.Количество КАК Количество
			|ИЗ
			|	ТабРемРаб КАК ТабРемРаб
			|ГДЕ
			|	ТабРемРаб.РемонтыОборудования_ID В(&МассивРемонтыОборудования_ID)
			|		И ТабРемРаб.РемонтнаяРабота В(&МассивРемонтныеРаботы)";
			
			Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.торо_ВнешнееОснованиеДляРабот") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "Таб.РемонтыОборудования_ID", "Таб.Предписание_ID");
			КонецЕсли;
			
			Запрос.УстановитьПараметр("МассивРемонтыОборудования_ID", МассивID);
			Запрос.УстановитьПараметр("МассивРемонтныеРаботы", МассивРабот);
			Запрос.УстановитьПараметр("Таб", ДокОснование.РемонтныеРаботы);
			
			Результат = Запрос.Выполнить();
			
			Выборка = Результат.Выбрать();
			
			МассивВозврата = Новый Массив;
			Пока Выборка.Следующий() Цикл
				
				Ремонт = Новый Структура("ID, РемонтыОборудования_ID, РемонтнаяРабота, Родитель_ID, Количество");
				ЗаполнитьЗначенияСвойств(Ремонт, Выборка);
				МассивВозврата.Добавить(Ремонт);
				
			КонецЦикла;
			
			Возврат МассивВозврата;
		ИначеЕсли ВыбранныеОперации.Количество() И (ТипЗнч(ДокОснование) = Тип("ДокументСсылка.торо_ВыявленныеДефекты") ИЛИ ТипЗнч(ДокОснование) = Тип("ДокументСсылка.торо_ПланГрафикРемонта")) Тогда
			
			ИзНормативов = Истина;
			Возврат Неопределено;			
			
		КонецЕсли;
		
	Иначе
		
		ТекстСообщения = НСтр("es='¡No es escogido ni una reparación!';ru='Не выбран ни один ремонт!';en='No repair selected!'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура ПроставитьГалочкиПоВеткеВниз(СтрокаДерева, ЗначГалки)
	
	Для Каждого Элем Из СтрокаДерева.ПолучитьЭлементы() Цикл
		
		Элем.Выбран = ЗначГалки;
		ПроставитьГалочкиПоВеткеВниз(Элем, ЗначГалки);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроставитьГалочкиПоВеткеВверх(СтрокаДерева, ЗначГалки)
	
	СтрРодитель = СтрокаДерева.ПолучитьРодителя();
	
	Если СтрРодитель <> Неопределено И НЕ СтрРодитель.Выбран Тогда 
		
		СтрРодитель.Выбран = ЗначГалки;
		ПроставитьГалочкиПоВеткеВверх(СтрРодитель, ЗначГалки);
		
	КонецЕсли;
	
		СтрокаДерева.Выбран = ЗначГалки;
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьПодчиненные(Строка)
	
	Для каждого Стр Из Строка.ПолучитьЭлементы() Цикл
		
		СвернутьПодчиненные(Стр);
		Элементы.РемонтныеРаботы.Свернуть(Стр.ПолучитьИдентификатор());
		
	КонецЦикла; 	
	
КонецПроцедуры

#Если Клиент Тогда
	СозданыАкты = Ложь;
#КонецЕсли

#КонецОбласти



