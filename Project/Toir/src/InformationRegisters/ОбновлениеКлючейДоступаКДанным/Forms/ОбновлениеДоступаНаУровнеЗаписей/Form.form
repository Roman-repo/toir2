        <title>
          <key>ru</key>
          <value>Рассчитывать прогресс по количеству данных</value>
        </title>
        <title>
          <key>es</key>
          <value>Contar el progreso por la cantidad de los datos</value>
        </title>
        <title>
          <key>en</key>
          <value>Calculate the progress of the amount of data</value>
        </title>
        <visible>true</visible>
        <enabled>true</enabled>
