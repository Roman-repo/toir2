  <resources uuid="a52f2de4-f414-4837-9b1a-6d8f282e1327">
    <name>ХешСумма</name>
    <synonym>
      <key>ru</key>
      <value>Хеш сумма</value>
    </synonym>
    <synonym>
      <key>es</key>
      <value>Хеш la suma</value>
    </synonym>
    <synonym>
      <key>en</key>
      <value>Hash amount</value>
    </synonym>
    <type>
      <types>String</types>
      <stringQualifiers>
        <length>48</length>
      </stringQualifiers>
    </type>
    <toolTip>
      <key>ru</key>
      <value>Хеш-сумма версии параметров ограничения доступа для отслеживания изменений в информационной базе по сравнению с версией в оперативной памяти</value>
    </toolTip>
    <toolTip>
      <key>es</key>
      <value>La hesh-suma de versión de los parámetros de la restricción del acceso para la observación de los cambios en la base informativa en comparación con la versión en la memoria operativa</value>
    </toolTip>
    <toolTip>
      <key>en</key>
      <value>Hash sum of the version of access restriction parameters for tracking changes in the infobase compared to the version in main memory</value>
    </toolTip>
    <minValue xsi:type="core:UndefinedValue"/>
    <maxValue xsi:type="core:UndefinedValue"/>
    <fullTextSearch>Use</fullTextSearch>
    <dataHistory>Use</dataHistory>
    <fillValue xsi:type="core:StringValue">
      <value></value>
    </fillValue>
  </resources>
  <resources uuid="d126a11e-c770-4309-941f-cbcdd5cbad5d">
    <name>ДляШаблоновВСеансахПользователей</name>
    <synonym>
      <key>ru</key>
      <value>Для шаблонов в сеансах пользователей</value>
