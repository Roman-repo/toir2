      <key>en</key>
      <value>For templates in user sessions</value>
    </synonym>
    <type>
      <types>ValueStorage</types>
    </type>
    <toolTip>
      <key>ru</key>
      <value>Параметры ограничения доступа, используемые только для установки параметров сеанса для шаблонов, используемых при ограничении доступа пользователей</value>
    </toolTip>
    <toolTip>
      <key>es</key>
      <value>Los parámetros de la restricción del acceso, usado solamente para la instalación de los parámetros de la sesión para los modelos usados a la restricción del acceso de los usuarios</value>
    </toolTip>
    <toolTip>
      <key>en</key>
      <value>Access restriction settings used only to set session parameters for templates used when restricting user access</value>
    </toolTip>
    <minValue xsi:type="core:UndefinedValue"/>
    <maxValue xsi:type="core:UndefinedValue"/>
    <fullTextSearch>Use</fullTextSearch>
    <dataHistory>Use</dataHistory>
    <fillValue xsi:type="core:UndefinedValue"/>
  </resources>
