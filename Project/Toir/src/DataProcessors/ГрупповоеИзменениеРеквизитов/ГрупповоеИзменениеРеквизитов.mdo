  <attributes uuid="7d2a37b1-a1a0-435a-846a-95e255655044">
    <name>ИзменятьВТранзакции</name>
    <synonym>
      <key>ru</key>
      <value>Изменять в транзакции</value>
    </synonym>
    <synonym>
      <key>es</key>
      <value>Cambiar en la transacción</value>
    </synonym>
    <synonym>
      <key>en</key>
      <value>Change in transaction</value>
    </synonym>
    <type>
      <types>Boolean</types>
    </type>
    <toolTip>
      <key>ru</key>
      <value>При невозможности изменения элементов в транзакции, все изменения будут отменены.</value>
    </toolTip>
    <toolTip>
      <key>es</key>
      <value>A la imposibilidad del cambio de los elementos en las transacciones, todos los cambios serán anulados.</value>
    </toolTip>
    <toolTip>
      <key>en</key>
      <value>If it is impossible to change the elements in the transaction, all changes will be discarded.</value>
    </toolTip>
    <minValue xsi:type="core:UndefinedValue"/>
    <maxValue xsi:type="core:UndefinedValue"/>
  </attributes>
  <attributes uuid="109db64c-00dc-490e-99a5-4430d9344e99">
    <name>ПрерыватьПриОшибке</name>
    <synonym>
      <key>ru</key>
      <value>Прерывать при ошибке</value>
    </synonym>
    <synonym>
      <key>es</key>
      <value>Interrumpir a la falta</value>
    </synonym>
    <synonym>
      <key>en</key>
      <value>Abort on error</value>
    </synonym>
    <type>
      <types>Boolean</types>
    </type>
    <toolTip>
      <key>ru</key>
      <value>Предупреждать, если во время изменения элементов возникнут ошибки.</value>
    </toolTip>
    <toolTip>
      <key>es</key>
      <value>Advertir, si durante el cambio de los elementos surgen las faltas.</value>
    </toolTip>
    <toolTip>
      <key>en</key>
      <value>Warn if errors occur during item changes.</value>
    </toolTip>
