  <attributes>
    <name>Мероприятия</name>
    <title>
      <key>ru</key>
      <value>Мероприятия</value>
    </title>
    <title>
      <key>es</key>
      <value>Las medidas</value>
    </title>
    <title>
      <key>en</key>
      <value>Events</value>
    </title>
    <id>22</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Мероприятия.ID_Ремонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Мероприятия.ВидРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Мероприятия.Документ</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Мероприятия.Завершенные</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Мероприятия.ТипДокумента</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ,
	торо_ПланГрафикППР.ID КАК ID_Ремонта,
	торо_ПланГрафикППР.СписокОбъектов КАК ОбъектРемонта,
	торо_ПланГрафикППР.ВидМероприятия КАК ВидРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала КАК ПланируемаяДатаНачалаРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания КАК ПланируемаяДатаОкончанияРемонта,
	ВЫБОР
		КОГДА торо_ПланГрафикППР.Исполнитель = НЕОПРЕДЕЛЕНО
				И торо_ПланГрафикППР.СпособВыполнения = ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Подрядный)
			ТОГДА ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		ИНАЧЕ торо_ПланГрафикППР.Исполнитель
	КОНЕЦ КАК Исполнитель,
	торо_ПланГрафикППР.Организация КАК Организация,
	торо_ПланГрафикППР.Подразделение КАК Подразделение,
	ВЫБОР
		КОГДА торо_ЗавершенныеМероприятия.ID ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК Завершенные,
	&quot;торо_ГрафикРегламентныхМероприятийТОиР&quot; КАК ТипДокумента,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование КАК ДокументПлановыхДат
ИЗ
	РегистрСведений.торо_ПлановыеМероприятия.СрезПоследних(
			,
			&amp;ФОИспользоватьРегламентныеМероприятия
				И ВЫБОР
					КОГДА НЕ &amp;ПоВсемОрганизациям
						ТОГДА Организация = &amp;Организация
					ИНАЧЕ ИСТИНА
				КОНЕЦ) КАК торо_ПланГрафикППР
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеМероприятия КАК торо_ЗавершенныеМероприятия
		ПО торо_ПланГрафикППР.ID = торо_ЗавершенныеМероприятия.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		ПО торо_ПланГрафикППР.ID = торо_АктуальныеПлановыеДатыРемонтов.IDРемонта
ГДЕ
	НЕ торо_ПланГрафикППР.Отменен
	И ЕСТЬNULL(торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала, ДАТАВРЕМЯ(1,1,1)) &lt;= &amp;ПлановыйПериод
	И ВЫБОР
			КОГДА НЕ &amp;ПоВсемПодразделениям
				ТОГДА ВЫБОР
						КОГДА торо_ПланГрафикППР.Исполнитель = НЕОПРЕДЕЛЕНО
							ТОГДА ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
						ИНАЧЕ торо_ПланГрафикППР.Исполнитель
					КОНЕЦ В ИЕРАРХИИ (&amp;Исполнитель)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И НЕ торо_ПланГрафикППР.Регистратор.Организация ЕСТЬ NULL
	И ВЫБОР
			КОГДА НЕ &amp;Завершенные
				ТОГДА торо_ЗавершенныеМероприятия.ID ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
