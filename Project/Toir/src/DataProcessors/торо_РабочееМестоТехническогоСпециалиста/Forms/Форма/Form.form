    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ID_Ремонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.IDОсновного</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Бригада</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ВидРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Документ</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Завершенные</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Исполнитель</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ОбъектРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Организация</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ПланируемаяДатаНачалаРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ПланируемаяДатаОкончанияРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Подразделение</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.СпособВыполнения</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ТипДокумента</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ,
	&quot;торо_ВнешнееОснованиеДляРабот&quot; КАК ТипДокумента,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование КАК ДокументПлановыхДат,
	ЛОЖЬ КАК Перенесенный,
	торо_ПредписанияСрезПоследних.ОбъектРемонта КАК ОбъектРемонта,
	&amp;торо_ВидРемонтаВО КАК ВидРемонта,
	ВЫБОР
		КОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания
		ИНАЧЕ торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала
	КОНЕЦ КАК ПланируемаяДатаНачалаРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания КАК ПланируемаяДатаОкончанияРемонта,
	ЕСТЬNULL(торо_Заявка.Исполнитель, торо_Предписание.Исполнитель) КАК Исполнитель,
	торо_ПредписанияСрезПоследних.Организация КАК Организация,
	NULL КАК КритичностьДефекта,
	ВЫБОР
		КОГДА НЕ ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ТОГДА &quot;Устранен (внешнее основание)&quot;
		КОГДА НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
					И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
			ТОГДА &quot;Устраняется (внешнее основание)&quot;
		КОГДА НЕ торо_Заявка.IDРемонта ЕСТЬ NULL
				И &amp;ИспользоватьСметы
			ТОГДА &quot;Запланировано устранение (внешнее основание)&quot;
		ИНАЧЕ &quot;Зарегистрирован (внешнее основание)&quot;
	КОНЕЦ КАК СтатусОР,
	торо_ПредписанияСрезПоследних.ID КАК ID_Ремонта,
	торо_ПредписанияСрезПоследних.Подразделение КАК Подразделение,
	торо_ПредписанияСрезПоследних.Период КАК Период,
	ВЫБОР
		КОГДА торо_Заявка.Регистратор ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ВведенаЗаявка,
	торо_ОбъектыРемонта.Приоритет КАК ПриоритетОР,
	ВЫБОР
		КОГДА торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации = ЗНАЧЕНИЕ(Справочник.торо_ВидыЭксплуатации.ПустаяСсылка)
			ТОГДА &quot;Не установлено&quot;
		ИНАЧЕ торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации
	КОНЕЦ КАК СостояниеОР,
	ВЫБОР
		КОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК Завершенные,
	торо_Ремонты.ГарантийныйРемонт КАК ГарантийныйРемонт,
	ЕСТЬNULL(торо_СтатусыДокументовВнешнихОснованийСрезПоследних.СтатусДокумента, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.ПустаяССылка)) КАК СтатусДокумента,
	торо_ОстановочныеРемонтыСрезПоследних.IDОсновного КАК IDОсновного,
	ЕСТЬNULL(торо_Заявка.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО) КАК Бригада,
	ВЫБОР
		КОГДА торо_Заявка.Исполнитель ЕСТЬ NULL
			ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
		ИНАЧЕ ВЫБОР
				КОГДА ТИПЗНАЧЕНИЯ(торо_Заявка.Исполнитель) = ТИП(Справочник.Контрагенты)
					ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Подрядный)
				ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
			КОНЕЦ
	КОНЕЦ КАК СпособВыполнения
{ВЫБРАТЬ
	Документ.*,
	ТипДокумента,
	ДокументПлановыхДат.* КАК ДокументПлановыхДат,
	Перенесенный,
	ОбъектРемонта.*,
	ВидРемонта,
	ПланируемаяДатаНачалаРемонта,
	ПланируемаяДатаОкончанияРемонта,
	Организация.*,
	КритичностьДефекта,
	СтатусОР,
	ID_Ремонта,
	Подразделение.*,
	Период,
	Исполнитель.*,
	ВведенаЗаявка,
	ПриоритетОР.*,
	СостояниеОР.*,
	Завершенные,
	ГарантийныйРемонт,
	СтатусДокумента,
	IDОсновного,
	Бригада.*,
	СпособВыполнения.*}
ИЗ
	РегистрСведений.торо_ВнешниеОснованияДляРабот.СрезПоследних(, &amp;ФОИспользоватьВнешниеОснования) КАК торо_ПредписанияСрезПоследних
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВнешнееОснованиеДляРабот.ОбследованноеОборудование КАК торо_Предписание
		ПО торо_ПредписанияСрезПоследних.ID = торо_Предписание.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НарядыПоРемонтам.СрезПоследних(, ) КАК торо_НарядыПоРемонтам
		ПО торо_ПредписанияСрезПоследних.ID = торо_НарядыПоРемонтам.IDРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктыПоРемонтам.СрезПоследних(, ) КАК торо_АктыПоРемонтам
		ПО торо_ПредписанияСрезПоследних.ID = торо_АктыПоРемонтам.IDРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам.СрезПоследних(, ) КАК торо_Заявка
		ПО торо_ПредписанияСрезПоследних.ID = торо_Заявка.IDРемонта
			И (НЕ торо_Заявка.Регистратор В
					(ВЫБРАТЬ
						торо_ОтмененныеЗаявки.Заявка
					ИЗ
						РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущееСостояниеОР.СрезПоследних(&amp;ТекДата, ) КАК торо_ТекущееСостояниеОРСрезПоследних
		ПО торо_ПредписанияСрезПоследних.ОбъектРемонта = торо_ТекущееСостояниеОРСрезПоследних.ОбъектРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеРемонтныеРаботы КАК ЗакрытыеЗаявки
		ПО торо_ПредписанияСрезПоследних.ОбъектРемонта = ЗакрытыеЗаявки.ОбъектРемонта
			И торо_ПредписанияСрезПоследних.ID = ЗакрытыеЗаявки.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_Ремонты
		ПО торо_ПредписанияСрезПоследних.ID = торо_Ремонты.ID
			И (торо_Предписание.Ссылка = торо_Ремонты.Регистратор)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыДокументовВнешнихОснованийУстановленные.СрезПоследних(&amp;ТекДата, &amp;ИспользоватьСтатусыДокументов) КАК торо_СтатусыДокументовВнешнихОснованийСрезПоследних
		ПО (торо_Предписание.Ссылка = торо_СтатусыДокументовВнешнихОснованийСрезПоследних.ИзменяемыйДокумент)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		ПО торо_ПредписанияСрезПоследних.ОбъектРемонта = торо_ОбъектыРемонта.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОстановочныеРемонты.СрезПоследних(, ) КАК торо_ОстановочныеРемонтыСрезПоследних
		ПО торо_ПредписанияСрезПоследних.ID = торо_ОстановочныеРемонтыСрезПоследних.IDЗависимого
			И (НЕ торо_ОстановочныеРемонтыСрезПоследних.Отвязан)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		ПО торо_ПредписанияСрезПоследних.ID = торо_АктуальныеПлановыеДатыРемонтов.IDРемонта
ГДЕ
	ВЫБОР
			КОГДА НЕ &amp;ПоВсемОрганизациям
				ТОГДА торо_ПредписанияСрезПоследних.Организация = &amp;Организация
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ТИПЗНАЧЕНИЯ(торо_ПредписанияСрезПоследних.Регистратор) &lt;> ТИП(Документ.торо_ВыявленныеДефекты)
	И ВЫБОР
			КОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания
			ИНАЧЕ торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала
		КОНЕЦ &lt;= &amp;ПлановыйПериод
	И НЕ торо_Предписание.Ссылка.Организация ЕСТЬ NULL
	И ВЫБОР
			КОГДА НЕ &amp;Завершенные
				ТОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;ПоВсемПодразделениям
				ТОГДА торо_ПредписанияСрезПоследних.Подразделение В (&amp;Исполнитель)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
{ГДЕ
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки.* КАК Документ,
	(&quot;Внешнее основание для работ&quot;) КАК ТипДокумента,
	(ЛОЖЬ) КАК Перенесенный,
	торо_ПредписанияСрезПоследних.ОбъектРемонта.*,
	(&amp;торо_ВидРемонтаВО) КАК ВидРемонта,
	(ВЫБОР
			КОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания
		КОНЕЦ) КАК ПланируемаяДатаНачалаРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания КАК ПланируемаяДатаОкончанияРемонта,
	(ЕСТЬNULL(торо_Заявка.Исполнитель, торо_Предписание.Исполнитель)).* КАК Исполнитель,
	торо_ПредписанияСрезПоследних.Организация.*,
	(ВЫБОР
			КОГДА НЕ ЗакрытыеЗаявки.ID ЕСТЬ NULL
				ТОГДА &quot;Устранен (внешнее основание)&quot;
			КОГДА НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
						И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
				ТОГДА &quot;Устраняется (внешнее основание)&quot;
			КОГДА НЕ торо_Заявка.IDРемонта ЕСТЬ NULL
					И &amp;ИспользоватьСметы
				ТОГДА &quot;Запланировано устранение (внешнее основание)&quot;
			ИНАЧЕ &quot;Зарегистрирован (внешнее основание)&quot;
		КОНЕЦ) КАК СтатусОР,
	торо_ПредписанияСрезПоследних.ID КАК ID_Ремонта,
	торо_ПредписанияСрезПоследних.Подразделение.*,
	торо_ПредписанияСрезПоследних.Период,
	(ВЫБОР
			КОГДА торо_Заявка.Регистратор ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ВведенаЗаявка,
	торо_ОбъектыРемонта.Приоритет.* КАК ПриоритетОР,
	(ВЫБОР
			КОГДА торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации = ЗНАЧЕНИЕ(Справочник.торо_ВидыЭксплуатации.ПустаяСсылка)
				ТОГДА &quot;Не установлено&quot;
			ИНАЧЕ торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации
		КОНЕЦ).* КАК СостояниеОР,
	(ВЫБОР
			КОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК Завершенные,
	торо_Ремонты.ГарантийныйРемонт,
	(ЕСТЬNULL(торо_СтатусыДокументовВнешнихОснованийСрезПоследних.СтатусДокумента, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.ПустаяССылка))).* КАК СтатусДокумента,
	торо_ОстановочныеРемонтыСрезПоследних.IDОсновного,
	(ЕСТЬNULL(торо_Заявка.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО)).* КАК Бригада,
	(ВЫБОР
			КОГДА торо_Заявка.Исполнитель ЕСТЬ NULL
				ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
			ИНАЧЕ ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(торо_Заявка.Исполнитель) = ТИП(Справочник.Контрагенты)
						ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Подрядный)
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
				КОНЕЦ
		КОНЕЦ).* КАК СпособВыполнения,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование.* КАК ДокументПлановыхДат}

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки,
	&quot;торо_ПланГрафикРемонта&quot;,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование,
	ТИПЗНАЧЕНИЯ(торо_ПланГрафикППР.Регистратор) = ТИП(Документ.торо_ЗакрытиеЗаявокИРемонтов),
	торо_ПланГрафикППР.ОбъектРемонтныхРабот,
	торо_ПланГрафикППР.ВидРемонтныхРабот,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания,
	ЕСТЬNULL(торо_ЗаявкаНаРемонт.Исполнитель, торо_ПланГрафикППР.Исполнитель),
	торо_ПланГрафикППР.Организация,
	NULL,
	ВЫБОР
		КОГДА НЕ ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ТОГДА &quot;Выполнен (план-график ППР)&quot;
		КОГДА НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
					И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
			ТОГДА &quot;Выполняется (план-график ППР)&quot;
		КОГДА НЕ торо_ЗаявкаНаРемонт.IDРемонта ЕСТЬ NULL
				И &amp;ИспользоватьСметы
			ТОГДА &quot;Запланировано выполнение (план-график ППР)&quot;
		ИНАЧЕ &quot;Введен ППР (план-график ППР)&quot;
	КОНЕЦ,
	торо_ПланГрафикППР.ID,
	торо_ПланГрафикППР.Подразделение,
	торо_ПланГрафикППР.Период,
	ВЫБОР
		КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ,
	торо_ОбъектыРемонта.Приоритет,
	ВЫБОР
		КОГДА торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации = ЗНАЧЕНИЕ(Справочник.торо_ВидыЭксплуатации.ПустаяСсылка)
			ТОГДА &quot;Не установлено&quot;
		ИНАЧЕ торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации
	КОНЕЦ,
	ВЫБОР
		КОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ,
	ЛОЖЬ,
	&quot;Статус не определен&quot;,
	торо_ОстановочныеРемонтыСрезПоследних.IDОсновного,
	ЕСТЬNULL(торо_ЗаявкаНаРемонт.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО),
	ВЫБОР
		КОГДА торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
			ТОГДА торо_ПланГрафикППР.СпособВыполнения
		ИНАЧЕ ВЫБОР
				КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.Исполнитель) = ТИП(Справочник.Контрагенты)
					ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Подрядный)
				ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
			КОНЕЦ
	КОНЕЦ
ИЗ
	РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних(, &amp;ФОИспользоватьППР) КАК торо_ПланГрафикППР
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеРемонтныеРаботы КАК ЗакрытыеЗаявки
		ПО торо_ПланГрафикППР.ID = ЗакрытыеЗаявки.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам.СрезПоследних(, ) КАК торо_ЗаявкаНаРемонт
		ПО торо_ПланГрафикППР.ID = торо_ЗаявкаНаРемонт.IDРемонта
			И (НЕ торо_ЗаявкаНаРемонт.Регистратор В
					(ВЫБРАТЬ
						торо_ОтмененныеЗаявки.Заявка
					ИЗ
						РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НарядыПоРемонтам.СрезПоследних(, ) КАК торо_НарядыПоРемонтам
		ПО торо_ПланГрафикППР.ID = торо_НарядыПоРемонтам.IDРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктыПоРемонтам.СрезПоследних(, ) КАК торо_АктыПоРемонтам
		ПО торо_ПланГрафикППР.ID = торо_АктыПоРемонтам.IDРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущееСостояниеОР.СрезПоследних(&amp;ТекДата, ) КАК торо_ТекущееСостояниеОРСрезПоследних
		ПО торо_ПланГрафикППР.ОбъектРемонтныхРабот = торо_ТекущееСостояниеОРСрезПоследних.ОбъектРемонта
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		ПО торо_ПланГрафикППР.ОбъектРемонтныхРабот = торо_ОбъектыРемонта.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОстановочныеРемонты.СрезПоследних КАК торо_ОстановочныеРемонтыСрезПоследних
		ПО торо_ПланГрафикППР.ID = торо_ОстановочныеРемонтыСрезПоследних.IDЗависимого
			И (НЕ торо_ОстановочныеРемонтыСрезПоследних.Отвязан)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		ПО торо_ПланГрафикППР.ID = торо_АктуальныеПлановыеДатыРемонтов.IDРемонта
ГДЕ
	ВЫБОР
			КОГДА НЕ &amp;ПоВсемОрганизациям
				ТОГДА торо_ПланГрафикППР.Организация = &amp;Организация
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;ПоВсемПодразделениям
				ТОГДА торо_ПланГрафикППР.Подразделение В (&amp;Исполнитель)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И НЕ торо_ПланГрафикППР.Отменен
	И НЕ торо_ПланГрафикППР.Замещен
	И торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала &lt;= &amp;ПлановыйПериод
	И ВЫБОР
			КОГДА НЕ &amp;Завершенные
				ТОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ
{ГДЕ
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки.* КАК Документ,
	(&quot;План-график ППР&quot;) КАК ТипДокумента,
	(ТИПЗНАЧЕНИЯ(торо_ПланГрафикППР.Регистратор) = ТИП(Документ.торо_ЗакрытиеЗаявокИРемонтов)) КАК Перенесенный,
	торо_ПланГрафикППР.ОбъектРемонтныхРабот.* КАК ОбъектРемонта,
	торо_ПланГрафикППР.ВидРемонтныхРабот.* КАК ВидРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала КАК ПланируемаяДатаНачалаРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания КАК ПланируемаяДатаОкончанияРемонта,
	(ЕСТЬNULL(торо_ЗаявкаНаРемонт.Исполнитель, торо_ПланГрафикППР.Исполнитель)).* КАК Исполнитель,
	торо_ПланГрафикППР.Организация.*,
	(ВЫБОР
			КОГДА НЕ ЗакрытыеЗаявки.ID ЕСТЬ NULL
				ТОГДА &quot;Выполнен (план-график ППР)&quot;
			КОГДА НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
						И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
				ТОГДА &quot;Выполняется (план-график ППР)&quot;
			КОГДА НЕ торо_ЗаявкаНаРемонт.IDРемонта ЕСТЬ NULL
					И &amp;ИспользоватьСметы
				ТОГДА &quot;Запланировано выполнение (план-график ППР)&quot;
			ИНАЧЕ &quot;Введен ППР (план-график ППР)&quot;
		КОНЕЦ) КАК СтатусОР,
	торо_ПланГрафикППР.ID КАК ID_Ремонта,
	торо_ПланГрафикППР.Подразделение.*,
	торо_ПланГрафикППР.Период,
	(ВЫБОР
			КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ВведенаЗаявка,
	торо_ОбъектыРемонта.Приоритет.* КАК ПриоритетОР,
	(ВЫБОР
			КОГДА торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации = ЗНАЧЕНИЕ(Справочник.торо_ВидыЭксплуатации.ПустаяСсылка)
				ТОГДА &quot;Не установлено&quot;
			ИНАЧЕ торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации
		КОНЕЦ).* КАК СостояниеОР,
	(ВЫБОР
			КОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК Завершенные,
	(ЛОЖЬ) КАК ГарантийныйРемонт,
	(&quot;Статус не определен&quot;) КАК СтатусДокумента,
	торо_ОстановочныеРемонтыСрезПоследних.IDОсновного,
	(ЕСТЬNULL(торо_ЗаявкаНаРемонт.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО)).* КАК Бригада,
	(ВЫБОР
			КОГДА торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
				ТОГДА торо_ПланГрафикППР.СпособВыполнения
			ИНАЧЕ ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.Исполнитель) = ТИП(Справочник.Контрагенты)
						ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Подрядный)
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
				КОНЕЦ
		КОНЕЦ).* КАК СпособВыполнения,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование.* КАК ДокументПлановыхДат}

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки,
	&quot;торо_ВыявленныеДефекты&quot;,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование,
	ЛОЖЬ,
	торо_ВыявленныеДефекты.ОтказавшийЭлемент,
	&amp;торо_ВидРемонтаВД,
	ВЫБОР
		КОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА торо_ВыявленныеДефекты.Период
		ИНАЧЕ торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала
	КОНЕЦ,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания,
	ЕСТЬNULL(торо_Заявка.Исполнитель, торо_ВыявленныеДефекты.ПодразделениеИсполнитель),
	торо_ВыявленныеДефекты.Организация,
	торо_ВыявленныеДефекты.КритичностьДефекта,
	ВЫБОР
		КОГДА НЕ ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ТОГДА &quot;Устранен (выявленный дефект)&quot;
		КОГДА НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
					И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
			ТОГДА &quot;Устраняется (выявленный дефект)&quot;
		КОГДА НЕ торо_Заявка.IDРемонта ЕСТЬ NULL
				И &amp;ИспользоватьСметы
			ТОГДА &quot;Запланировано устранение (выявленный дефект)&quot;
		ИНАЧЕ &quot;Зарегистрирован (выявленный дефект)&quot;
	КОНЕЦ,
	торо_ВыявленныеДефекты.ID,
	торо_ВыявленныеДефекты.Подразделение,
	торо_ВыявленныеДефекты.Период,
	ВЫБОР
		КОГДА торо_Заявка.Регистратор ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ,
	торо_ОбъектыРемонта.Приоритет,
	ВЫБОР
		КОГДА торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации = ЗНАЧЕНИЕ(Справочник.торо_ВидыЭксплуатации.ПустаяСсылка)
			ТОГДА &quot;Не установлено&quot;
		ИНАЧЕ торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации
	КОНЕЦ,
	ВЫБОР
		КОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ,
	торо_Ремонты.ГарантийныйРемонт,
	ЕСТЬNULL(торо_СтатусыДокументовВыявленныхДефектовСрезПоследних.СтатусДокумента, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.ПустаяССылка)),
	торо_ОстановочныеРемонтыСрезПоследних.IDОсновного,
	ЕСТЬNULL(торо_Заявка.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО),
	ВЫБОР
		КОГДА торо_Заявка.Исполнитель ЕСТЬ NULL
			ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
		ИНАЧЕ ВЫБОР
				КОГДА ТИПЗНАЧЕНИЯ(торо_Заявка.Исполнитель) = ТИП(Справочник.Контрагенты)
					ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Подрядный)
				ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
			КОНЕЦ
	КОНЕЦ
ИЗ
	РегистрСведений.торо_ВыявленныеДефекты КАК торо_ВыявленныеДефекты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеРемонты.СрезПоследних КАК торо_ОтмененныеРемонтыСрезПоследних
		ПО торо_ВыявленныеДефекты.ID = торо_ОтмененныеРемонтыСрезПоследних.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НарядыПоРемонтам.СрезПоследних(, ) КАК торо_НарядыПоРемонтам
		ПО торо_ВыявленныеДефекты.ID = торо_НарядыПоРемонтам.IDРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктыПоРемонтам.СрезПоследних(, ) КАК торо_АктыПоРемонтам
		ПО торо_ВыявленныеДефекты.ID = торо_АктыПоРемонтам.IDРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам.СрезПоследних(, ) КАК торо_Заявка
		ПО торо_ВыявленныеДефекты.ID = торо_Заявка.IDРемонта
			И (НЕ торо_Заявка.Регистратор В
					(ВЫБРАТЬ
						торо_ОтмененныеЗаявки.Заявка
					ИЗ
						РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущееСостояниеОР.СрезПоследних(&amp;ТекДата, ) КАК торо_ТекущееСостояниеОРСрезПоследних
		ПО торо_ВыявленныеДефекты.ОтказавшийЭлемент = торо_ТекущееСостояниеОРСрезПоследних.ОбъектРемонта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеРемонтныеРаботы КАК ЗакрытыеЗаявки
		ПО торо_ВыявленныеДефекты.ОтказавшийЭлемент = ЗакрытыеЗаявки.ОбъектРемонта
			И торо_ВыявленныеДефекты.ID = ЗакрытыеЗаявки.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_Ремонты
		ПО торо_ВыявленныеДефекты.ID = торо_Ремонты.ID
			И торо_ВыявленныеДефекты.Регистратор = торо_Ремонты.Регистратор
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыДокументовВыявленныхДефектовУстановленные.СрезПоследних(&amp;ТекДата, &amp;ИспользоватьСтатусыДокументов) КАК торо_СтатусыДокументовВыявленныхДефектовСрезПоследних
		ПО торо_ВыявленныеДефекты.Регистратор = торо_СтатусыДокументовВыявленныхДефектовСрезПоследних.ИзменяемыйДокумент
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		ПО торо_ВыявленныеДефекты.ОтказавшийЭлемент = торо_ОбъектыРемонта.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОстановочныеРемонты.СрезПоследних КАК торо_ОстановочныеРемонтыСрезПоследних
		ПО торо_ВыявленныеДефекты.ID = торо_ОстановочныеРемонтыСрезПоследних.IDЗависимого
			И (НЕ торо_ОстановочныеРемонтыСрезПоследних.Отвязан)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		ПО торо_ВыявленныеДефекты.ID = торо_АктуальныеПлановыеДатыРемонтов.IDРемонта
ГДЕ
	ВЫБОР
			КОГДА &amp;ФОИспользоватьДефекты
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И ВЫБОР
			КОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА торо_ВыявленныеДефекты.Период
			ИНАЧЕ торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала
		КОНЕЦ &lt;= &amp;ПлановыйПериод
	И ВЫБОР
			КОГДА НЕ &amp;ПоВсемОрганизациям
				ТОГДА торо_ВыявленныеДефекты.Организация = &amp;Организация
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И НЕ торо_ВыявленныеДефекты.Регистратор.Организация ЕСТЬ NULL
	И ВЫБОР
			КОГДА НЕ &amp;Завершенные
				ТОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;ПоВсемПодразделениям
				ТОГДА торо_ВыявленныеДефекты.Подразделение В (&amp;Исполнитель)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И торо_ОтмененныеРемонтыСрезПоследних.Регистратор ЕСТЬ NULL
{ГДЕ
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки.* КАК Документ,
	(&quot;Выявленные дефекты&quot;) КАК ТипДокумента,
	(ЛОЖЬ) КАК Перенесенный,
	торо_ВыявленныеДефекты.ОтказавшийЭлемент.* КАК ОбъектРемонта,
	(&amp;торо_ВидРемонтаВД) КАК ВидРемонта,
	(ВЫБОР
			КОГДА торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА торо_ВыявленныеДефекты.Период
			ИНАЧЕ торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала
		КОНЕЦ) КАК ПланируемаяДатаНачалаРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания КАК ПланируемаяДатаОкончанияРемонта,
	(ЕСТЬNULL(торо_Заявка.Исполнитель, торо_ВыявленныеДефекты.ПодразделениеИсполнитель)).* КАК Исполнитель,
	торо_ВыявленныеДефекты.Организация.*,
	торо_ВыявленныеДефекты.КритичностьДефекта.*,
	(ВЫБОР
			КОГДА НЕ ЗакрытыеЗаявки.ID ЕСТЬ NULL
				ТОГДА &quot;Устранен (выявленный дефект)&quot;
			КОГДА НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
						И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
				ТОГДА &quot;Устраняется (выявленный дефект)&quot;
			КОГДА НЕ торо_Заявка.IDРемонта ЕСТЬ NULL
					И &amp;ИспользоватьСметы
				ТОГДА &quot;Запланировано устранение (выявленный дефект)&quot;
			ИНАЧЕ &quot;Зарегистрирован (выявленный дефект)&quot;
		КОНЕЦ) КАК СтатусОР,
	торо_ВыявленныеДефекты.ID КАК ID_Ремонта,
	торо_ВыявленныеДефекты.Подразделение.*,
	торо_ВыявленныеДефекты.Период,
	(ВЫБОР
			КОГДА торо_Заявка.Регистратор ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ВведенаЗаявка,
	торо_ОбъектыРемонта.Приоритет.* КАК ПриоритетОР,
	(ВЫБОР
			КОГДА торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации = ЗНАЧЕНИЕ(Справочник.торо_ВидыЭксплуатации.ПустаяСсылка)
				ТОГДА &quot;Не установлено&quot;
			ИНАЧЕ торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации
		КОНЕЦ).* КАК СостояниеОР,
	(ВЫБОР
			КОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК Завершенные,
	торо_Ремонты.ГарантийныйРемонт,
	(ЕСТЬNULL(торо_СтатусыДокументовВыявленныхДефектовСрезПоследних.СтатусДокумента, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.ПустаяССылка))).* КАК СтатусДокумента,
	торо_ОстановочныеРемонтыСрезПоследних.IDОсновного,
	(ЕСТЬNULL(торо_Заявка.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО)).* КАК Бригада,
	(ВЫБОР
			КОГДА торо_Заявка.Исполнитель ЕСТЬ NULL
				ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
			ИНАЧЕ ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(торо_Заявка.Исполнитель) = ТИП(Справочник.Контрагенты)
						ТОГДА ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Подрядный)
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособыСтроительства.Хозспособ)
				КОНЕЦ
		КОНЕЦ).* КАК СпособВыполнения,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование.* КАК ДокументПлановыхДат}</queryText>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
    </extInfo>
  </attributes>
