		ПоказатьЗначение(Неопределено, Элемент.ТекущиеДанные.Документ);
		
	ИначеЕсли Поле.Имя = "МероприятияДокументПлановыхДат" Тогда
		
		ПоказатьЗначение(Неопределено, Элемент.ТекущиеДанные.ДокументПлановыхДат);
		
	КонецЕсли;	
	
