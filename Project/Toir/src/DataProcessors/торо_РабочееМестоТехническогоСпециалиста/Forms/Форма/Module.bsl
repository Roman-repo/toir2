&НаКлиенте
Процедура УстановитьПараметрыДинамическогоСпискаКлиент(ОбновитьЗаявки = Истина
														, ОбновитьНаряды              = Истина
														, ОбновитьАкты                = Истина
														, ОбновитьРегламентныеНаряды  = Истина
														, ОбновитьРегламентныеАкты    = Истина)
												 
	УстановитьПараметрыДинамическогоСписка(ОбновитьЗаявки, ОбновитьНаряды, ОбновитьАкты, ОбновитьРегламентныеНаряды, 
		ОбновитьРегламентныеАкты);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьПараметрыДинамическогоСписка(ОбновитьЗаявки = Истина
												, ОбновитьНаряды             = Истина
												, ОбновитьАкты               = Истина
												, ОбновитьРегламентныеНаряды = Истина
												, ОбновитьРегламентныеАкты   = Истина)
	
	ИтогоПлановыхДней = 0;
	СекундВДне = 86400;
																								
	Если ЗначениеЗаполнено(Объект.Периодичность) Тогда 
		
		ИтогоПлановыхДней = ПолучитьИтогПлановыхДней(Объект.Периодичность, Объект.ПлановыйПериод, 
			Объект.ДатаАктуальности);
	КонецЕсли;
	
	Если ОбновитьЗаявки ИЛИ ОбновитьАкты или ОбновитьНаряды Тогда
		
		Ремонты.Параметры.УстановитьЗначениеПараметра("Организация"                   , Объект.Организация);
		
		Если Объект.ИспользоватьОтборПоПодразделению Тогда
		
			Если Объект.ПодчиненныеПодразделения Тогда
				
				Если НЕ ЗначениеЗаполнено(Объект.Исполнитель) Тогда
					МассивПодчиненныхПодразделений = Новый Массив;
				Иначе
					МассивПодчиненныхПодразделений = ПолучитьМассивПодчиненныхПодразделений(Объект.Исполнитель);
				КонецЕсли;
				
				Ремонты.Параметры.УстановитьЗначениеПараметра("Исполнитель", МассивПодчиненныхПодразделений);
				
			Иначе
				
				Если НЕ ЗначениеЗаполнено(Объект.Исполнитель) Тогда
					Исполнители = Новый Массив;
					Исполнители.Добавить(ОбщегоНазначенияКлиент.ПредопределенныйЭлемент(
						"Справочник.СтруктураПредприятия"));
				Иначе
					Исполнители = Объект.Исполнитель;	
				КонецЕсли;
				Ремонты.Параметры.УстановитьЗначениеПараметра("Исполнитель", Исполнители);
				
			КонецЕсли;
			
		Иначе
			Ремонты.Параметры.УстановитьЗначениеПараметра("Исполнитель", Новый Массив);
		КонецЕсли;
		
		КонстантыВыдРемонта = ПолучитьКонстантыВидРемонта();
		
		Ремонты.Параметры.УстановитьЗначениеПараметра("Завершенные", Объект.Завершенные);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ПлановыйПериод", 
			КонецДня(Объект.ДатаАктуальности + ИтогоПлановыхДней * СекундВДне));
		Ремонты.Параметры.УстановитьЗначениеПараметра("ПоВсемОрганизациям", 
			?(Не ЗначениеЗаполнено(Объект.Организация), Истина, Ложь));
		Ремонты.Параметры.УстановитьЗначениеПараметра("ПоВсемПодразделениям", 
			НЕ Объект.ИспользоватьОтборПоПодразделению);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ТекДата", ТекущаяДата());
		Ремонты.Параметры.УстановитьЗначениеПараметра("торо_ВидРемонтаВД", 
			КонстантыВыдРемонта.торо_ВидРемонтаПриВводеНаОснованииВыявленныхДефектов);
		Ремонты.Параметры.УстановитьЗначениеПараметра("торо_ВидРемонтаВО", 
			КонстантыВыдРемонта.торо_ВидРемонтаПриВводеНаОснованииВнешнихОснований);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ФОИспользоватьВнешниеОснования", ФОИспользоватьВнешниеОснования);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ФОИспользоватьДефекты", ФОИспользоватьДефекты);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ФОИспользоватьППР", ФОИспользоватьППР);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ИспользоватьСметы", ФОИспользоватьСметы);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ИспользоватьСтатусыДокументов", ФОИспользоватьСтатусыДокументов);
		
		Если Не Ремонты.Параметры.Элементы.Найти("гкс_ПодразделениеВладелец") = Неопределено Тогда 
			СтруктураПроверки = Новый Структура("гкс_ИспользоватьОтборПодразделениеВладелец", Неопределено);
			ЗаполнитьЗначенияСвойств(СтруктураПроверки, ЭтотОбъект);
			Если Не СтруктураПроверки.гкс_ИспользоватьОтборПодразделениеВладелец = Неопределено 
				И СтруктураПроверки.гкс_ИспользоватьОтборПодразделениеВладелец = Истина Тогда 
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_ИспользоватьПодразделениеВладелец", Истина);
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_ПодразделениеВладелец", 
					ЭтотОбъект["гкс_ОтборПодразделениеВладелец"]);
			Иначе
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_ИспользоватьПодразделениеВладелец", Ложь);
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_ПодразделениеВладелец" , Неопределено);
			КонецЕсли;
		КонецЕсли;
		// гкс+ [8220] Тарасов 19.10.2020
		Если Не Ремонты.Параметры.Элементы.Найти("гкс_СрочностьВоздействия") = Неопределено Тогда 
			СтруктураПроверки = Новый Структура("гкс_ИспользоватьОтборСрочностьВоздействия", Неопределено);
			ЗаполнитьЗначенияСвойств(СтруктураПроверки, ЭтотОбъект);
			Если Не СтруктураПроверки.гкс_ИспользоватьОтборСрочностьВоздействия = Неопределено 
				И СтруктураПроверки.гкс_ИспользоватьОтборСрочностьВоздействия = Истина Тогда 
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_ИспользоватьСрочностьВоздействия", Истина);
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_СрочностьВоздействия", 
					ЭтотОбъект["гкс_ОтборСрочностьВоздействия"]);
			Иначе
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_ИспользоватьСрочностьВоздействия", Ложь);
				Ремонты.Параметры.УстановитьЗначениеПараметра("гкс_СрочностьВоздействия", Неопределено);
			КонецЕсли;
		КонецЕсли;
		// гкс- [8220] Тарасов 19.10.2020
		
		Элементы.Ремонты.АвтоОбновление = Объект.АвтоматическоеОбновление;
		Элементы.Ремонты.ПериодАвтоОбновления = Объект.ПериодОбновления;
		
	КонецЕсли; 
	
	Если ОбновитьРегламентныеАкты Тогда
		
		Если Объект.ИспользоватьОтборПоПодразделению Тогда
			Если НЕ ЗначениеЗаполнено(Объект.Исполнитель) Тогда
				Исполнители = Новый Массив;
				Исполнители.Добавить(ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Справочник.СтруктураПредприятия"));
			Иначе
				Исполнители = Объект.Исполнитель;	
			КонецЕсли;
			Мероприятия.Параметры.УстановитьЗначениеПараметра("Исполнитель", Исполнители);
		Иначе	
			Мероприятия.Параметры.УстановитьЗначениеПараметра("Исполнитель", Объект.Исполнитель);
		КонецЕсли;
		
		Мероприятия.Параметры.УстановитьЗначениеПараметра("Организация", Объект.Организация);
		Мероприятия.Параметры.УстановитьЗначениеПараметра("Завершенные", Объект.Завершенные);
		Мероприятия.Параметры.УстановитьЗначениеПараметра("ПлановыйПериод", 
			КонецДня(Объект.ДатаАктуальности + ИтогоПлановыхДней * СекундВДне));
		Мероприятия.Параметры.УстановитьЗначениеПараметра("ПоВсемОрганизациям", 
			?(Не ЗначениеЗаполнено(Объект.Организация), Истина, Ложь));
		Мероприятия.Параметры.УстановитьЗначениеПараметра("ПоВсемПодразделениям", 
			НЕ Объект.ИспользоватьОтборПоПодразделению);
		Мероприятия.Параметры.УстановитьЗначениеПараметра("ФОИспользоватьРегламентныеМероприятия", 
			ФОИспользоватьРегламентныеМероприятия);
		
		УстановитьЗапросИПараметрыДинСпискаРегламентныхАктов();
	КонецЕсли;
	
	Если ФОИспользоватьРегламентныеМероприятия Тогда
		Элементы.Мероприятия.АвтоОбновление = Объект.АвтоматическоеОбновление;
		Элементы.Мероприятия.ПериодАвтоОбновления = Объект.ПериодОбновления;	
	КонецЕсли; 
	
	Если ОбновитьЗаявки Тогда
		УстановитьЗапросИПараметрыДинСпискаЗаявок();	
	КонецЕсли; 	
	
	Если ОбновитьНаряды Тогда
		УстановитьЗапросИПараметрыДинСпискаНарядов();
	КонецЕсли;
	
	Если ОбновитьАкты Тогда
		УстановитьЗапросИПараметрыДинСпискаАктов();
	КонецЕсли; 
	
	Если ОбновитьРегламентныеНаряды Тогда
		УстановитьЗапросИПараметрыДинСпискаРегламентныхНарядов(); 
	КонецЕсли;
			
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьИтогПлановыхДней(Периодичность, ПлановыйПериод, ДатаАктуальности)	
			
	ИтогоПлановыхДней = 0;
	ПлановыйПериод = Формат(ПлановыйПериод, "ЧГ=");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РАЗНОСТЬДАТ(&ДатаНачала, ДОБАВИТЬКДАТЕ(&ДатаНачала, &Периодичность, &ПлановыйПериод), ДЕНЬ) КАК ПлановыйПериод";		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Периодичность", Строка(Периодичность));
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ПлановыйПериод", Строка(ПлановыйПериод));
 
	Запрос.УстановитьПараметр("ДатаНачала", ДатаАктуальности);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ИтогоПлановыхДней = Выборка.ПлановыйПериод;
	КонецЕсли;
	
	Возврат ИтогоПлановыхДней;

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьМассивПодчиненныхПодразделений(Исполнитель) 
	
	МассивПодчиненныхПодразделений = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Подразделения.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СтруктураПредприятия КАК Подразделения
		|ГДЕ
		|	Подразделения.Ссылка В ИЕРАРХИИ(&Ссылка)";
	Запрос.УстановитьПараметр("Ссылка", Исполнитель);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивПодчиненныхПодразделений = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат МассивПодчиненныхПодразделений; 
					
КонецФункции  

&НаСервереБезКонтекста
Функция ПолучитьКонстантыВидРемонта()
	
	КонстантыВидРемонта = Новый Структура;
	КонстантыВидРемонта.Вставить("торо_ВидРемонтаПриВводеНаОснованииВыявленныхДефектов", 
		Константы.торо_ВидРемонтаПриВводеНаОснованииВыявленныхДефектов.Получить());
	КонстантыВидРемонта.Вставить("торо_ВидРемонтаПриВводеНаОснованииВнешнихОснований",
		Константы.торо_ВидРемонтаПриВводеНаОснованииВнешнихОснований.Получить());
		
	Возврат КонстантыВидРемонта; 
		
КонецФункции

// Заполняет заявки по выбранным ремонтам
//
&НаСервере
Процедура УстановитьЗапросИПараметрыДинСпискаЗаявок()
	
	Если Не ИспользоватьУправлениеРемонтами
		ИЛИ Не ФОИспользоватьСметы Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.ID КАК ID_Ремонта,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка КАК ДокументЗаявка,
	|	ВЫБОР
	|		КОГДА торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Проведен
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Картинка,
	|	ЕСТЬNULL(торо_СтатусыРемонтовВЗаявкахСрезПоследних.Статус, торо_СтатусыДокументовЗаявокУстановленныеСрезПоследних.СтатусДокумента) КАК Статус
	|ИЗ
	|	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК торо_ЗаявкаНаРемонтРемонтыОборудования
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки
	|		ПО торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка = торо_ОтмененныеЗаявки.Заявка 
	|			И торо_ЗаявкаНаРемонтРемонтыОборудования.ID = торо_ОтмененныеЗаявки.ИДРемонта 
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыРемонтовВЗаявках.СрезПоследних КАК торо_СтатусыРемонтовВЗаявкахСрезПоследних
	|		ПО торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ЗаявкаНаРемонт
	|			И торо_ЗаявкаНаРемонтРемонтыОборудования.ID = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ИДРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыДокументовЗаявокУстановленные.СрезПоследних КАК торо_СтатусыДокументовЗаявокУстановленныеСрезПоследних
	|		ПО торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка = торо_СтатусыДокументовЗаявокУстановленныеСрезПоследних.ИзменяемыйДокумент
	|ГДЕ
	|	торо_ОтмененныеЗаявки.Заявка ЕСТЬ NULL
	|	И ВЫБОР
	|			КОГДА &ПоказыватьНепроведенные
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Проведен
	|		КОНЕЦ
	|	И НЕ торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка.ПометкаУдаления";
	
	ЗаявкиНаРемонт.ТекстЗапроса = Запрос.Текст;
	ЗаявкиНаРемонт.Параметры.УстановитьЗначениеПараметра("ПоказыватьНепроведенные", Объект.НеПроведенные);
	
	Элементы.ЗаявкиНаРемонт.АвтоОбновление = Объект.АвтоматическоеОбновление;
	Элементы.ЗаявкиНаРемонт.ПериодАвтоОбновления = Объект.ПериодОбновления;
	
КонецПроцедуры

