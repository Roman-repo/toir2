&НаКлиенте
Процедура СоздатьДокументы(Команда)
	Если ФОИспользоватьУчетНаработки Тогда
	    Если УчетНаработки.Количество() > 0 Тогда
			СозданныйДокумент = СоздатьДокументыНаработкаСервер();
			Если ЗначениеЗаполнено(СозданныйДокумент) Тогда
				ТекстСообщения = НСтр("es='Es creado el documento el Recuento de la elaboración de la maquinaria: ';ru='Создан документ Учет наработки оборудования: ';en='Created a document Accounting equipment operating time: '") + СозданныйДокумент;
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, СозданныйДокумент);
				
				УчетНаработки.Очистить();
				НаработкаПодчиненныхОбъектов.Очистить();
				ТаблицаПодобранныхОР.Очистить();
			КонецЕсли;
		Иначе	
			ТекстСообщения = НСтр("es='de la maquinaria. El documento no puede ser creado.';ru='Не заполнена табличная часть наработок оборудования. Документ не может быть создан.';en='The tabular part of equipment operating time is not filled. The document could not be created.'");
		    ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли; 
	
	Если ФОИспользоватьУчетСостояния Тогда
	    Если УчетСостояний.Количество() > 0 Тогда	
			СозданныйДокумент = СоздатьДокументыУчетСостоянийСервер();
			Если ЗначениеЗаполнено(СозданныйДокумент) Тогда
				ТекстСообщения = НСтр("es='Es creado el documento el Recuento de los estados de la maquinaria: ';ru='Создан документ Учет состояний оборудования: ';en='Created the document Accounting status of equipment: '") + СозданныйДокумент;
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, СозданныйДокумент);
				
				УчетСостояний.Очистить();
				ВернутьПервоначальныйУчетСостояний(Ложь, "Дата изменения состояния", Ложь);
			КонецЕсли;
		Иначе
			ТекстСообщения = НСтр("es='de la maquinaria. El documento no puede ser creado ';ru='Не заполнена табличная часть состояний оборудования. Документ не может быть создан ';en='The tabular part of the equipment states is not filled. Document cannot be created. '");
		    ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	
	Если ФОИспользоватьУчетКонтролируемыхПоказателей Тогда
	    Если УчетКонтролируемыхПоказателейПоказатели.Количество() > 0 Тогда
			СозданныйДокумент = СоздатьДокументыУчетКонтролируемыхПоказателейСервер();
			Если ЗначениеЗаполнено(СозданныйДокумент) Тогда
				ТекстСообщения = НСтр("es='Es creado el documento el Recuento de los índices controlados: ';ru='Создан документ Учет контролируемых показателей: ';en='Created a document Accounting for controlled indicators: '") + СозданныйДокумент;
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, СозданныйДокумент);
				
				УчетКонтролируемыхПоказателейПоказатели.Очистить();
			КонецЕсли;
		Иначе
			ТекстСообщения = НСтр("es='la parte tabular de los índices controlados. El documento no puede ser creado ';ru='Не заполнена табличная часть контролируемых показателей. Документ не может быть создан ';en='The tabular part of the monitored indicators is not filled. Document cannot be created. '");
		    ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьНаработкуОР(Команда)
	МассивОР = Новый Массив;
	МассивОР.Добавить(ОбъектРемонта);
	
	Если ЗначениеЗаполнено(ВариантУчетаИерархииЭлементов)
		И ВариантУчетаИерархииЭлементов <> ПредопределенноеЗначение("Перечисление.торо_ВариантыУчетаИерархииЭлементовПриПодборе.НеУчитыватьИерархию") Тогда
		МассивВыбранныхСтрок = торо_РаботаСИерархией20.ДополнитьОтобратьМассивВыбранныхСтрок(МассивОР, ВариантУчетаИерархииЭлементов, ТекСтруктураИерархии, Ложь);
		МассивОР.Очистить();
		Для каждого ТекДанные из МассивВыбранныхСтрок Цикл
			МассивОР.Добавить(ТекДанные.Ссылка);       
		КонецЦикла;
	КонецЕсли;
	
	ПодборПараметровНаработки(МассивОР);
