				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, СозданныйДокумент);
				
				УчетНаработки.Очистить();
				НаработкаПодчиненныхОбъектов.Очистить();
				ТаблицаПодобранныхОР.Очистить();
			КонецЕсли;	
		КонецЕсли;
	Иначе
		ТекстСообщения = НСтр("es='de la maquinaria. El documento no puede ser creado.';ru='Не заполнена табличная часть наработок оборудования. Документ не может быть создан.';en='The tabular part of equipment operating time is not filled. The document could not be created.'");
	    ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;	
