		ТекстВопроса = НСтр("es='¿Crear el documento el recuento de los índices de control?';ru='Создать документ учет контрольных показателей ?';en='Create a accounting estimates document?'");
		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьДокументУчетКонтрПоказателейПерсональный", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
