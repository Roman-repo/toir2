КонецПроцедуры

&НаКлиенте
Процедура СоздатьПозициюДокументаУчетСостояния(Команда)
	Если Не ЗначениеЗаполнено(ОбъектРемонта) Тогда
		ТекстСообщения = НСтр("es='de la reparación.';ru='Не выбран объект ремонта.';en='No repair object selected.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	СтруктураВидОперации = Новый Структура("ВидОперации", ВидОперации);
	МассивОР = Новый Массив;
	МассивОР.Добавить(ОбъектРемонта);
	
	Если ЗначениеЗаполнено(ВариантУчетаИерархииЭлементов)
		И ВариантУчетаИерархииЭлементов <> ПредопределенноеЗначение("Перечисление.торо_ВариантыУчетаИерархииЭлементовПриПодборе.НеУчитыватьИерархию") Тогда
		МассивВыбранныхСтрок = торо_РаботаСИерархией20.ДополнитьОтобратьМассивВыбранныхСтрок(МассивОР, ВариантУчетаИерархииЭлементов, ТекСтруктураИерархии, Ложь);
		МассивОР.Очистить();
		
		Для каждого ТекДанные Из МассивВыбранныхСтрок Цикл
			МассивОР.Добавить(ТекДанные.Ссылка);       
		КонецЦикла;
	КонецЕсли;
	
	Если МассивОР.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВидОперации.Вставить("ОбъектРемонта", МассивОР);
	
	ДопПоляДляСтруктурыВозврата = Неопределено;
	СтруктураВидОперации.Вставить("ДопПоляДляСтруктурыВозврата", ДопПоляДляСтруктурыВозврата);
			
	Если Не ГрупповоеФормированиеСостояния Тогда
		СтруктураВозврата = ПолучитьИнформациюОбОбъектахТЗСостояний();
		Если СтруктураВозврата.КоличествоРазличныхОР > 1 Или (СтруктураВозврата.КоличествоРазличныхОР = 1 И Не ОбъектРемонта = СтруктураВозврата.ОбъектРемонта) Тогда
		    УчетСостояний.Очистить();
		КонецЕсли;
	КонецЕсли;
	
	ОбработкаДобавленияСостояния(СтруктураВидОперации);
КонецПроцедуры

