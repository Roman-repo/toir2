  <attributes>
    <name>СписокНоменклатура</name>
    <title>
      <key>ru</key>
      <value>Список номенклатуры</value>
    </title>
    <title>
      <key>es</key>
      <value>La lista de la nomenclatura</value>
    </title>
    <title>
      <key>en</key>
      <value>List of omenclature</value>
    </title>
    <id>11</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокНоменклатура.ВидНоменклатуры</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокНоменклатура.Характеристика</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокНоменклатура.ХарактеристикиИспользуются</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникНоменклатура.Артикул КАК Артикул,
	СправочникНоменклатура.Ссылка КАК Номенклатура,
	СправочникНоменклатура.Родитель КАК Родитель,
	СправочникНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	СправочникНоменклатура.ВидНоменклатуры КАК ВидНоменклатуры,
	СправочникНоменклатура.ИспользованиеХарактеристик КАК ИспользованиеХарактеристик,
	ВЫБОР
		КОГДА СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеДляВидаНоменклатуры)
				ИЛИ СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ХарактеристикиИспользуются,
	СправочникНоменклатура.ПометкаУдаления КАК ПометкаУдаления,
	ВЫБОР
		КОГДА СправочникНоменклатура.ВидНоменклатуры.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоТовар,
	ВЫБОР
		КОГДА СправочникНоменклатура.ВидНоменклатуры.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоУслуга,
	СправочникНоменклатура.ВидНоменклатуры.ТипНоменклатуры КАК ТипНоменклатуры
ПОМЕСТИТЬ СписокНом
ИЗ
	Справочник.Номенклатура КАК СправочникНоменклатура
ГДЕ
	СправочникНоменклатура.ЭтоГруппа = ЛОЖЬ

ИНДЕКСИРОВАТЬ ПО
	Номенклатура,
	ВидНоменклатуры,
	СправочникНоменклатура.ИспользованиеХарактеристик
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СписокНом.Артикул КАК Артикул,
	СписокНом.Номенклатура КАК Номенклатура,
	СписокНом.Родитель КАК Родитель,
	СписокНом.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	СписокНом.ХарактеристикиИспользуются КАК ХарактеристикиИспользуются,
	ВЫБОР
		КОГДА НЕ ХарактеристикиНоменклатурыИнд.Ссылка ЕСТЬ NULL
			ТОГДА ХарактеристикиНоменклатурыИнд.Ссылка
		КОГДА НЕ ХарактеристикиНоменклатурыОбщ.Ссылка ЕСТЬ NULL
			ТОГДА ХарактеристикиНоменклатурыОбщ.Ссылка
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	КОНЕЦ КАК Характеристика,
	СписокНом.ВидНоменклатуры КАК ВидНоменклатуры,
	СписокНом.ПометкаУдаления КАК ПометкаУдаления,
	СписокНом.ТипНоменклатуры КАК ТипНоменклатуры,
	СписокНом.ЭтоТовар КАК ЭтоТовар,
	СписокНом.ЭтоУслуга КАК ЭтоУслуга
ПОМЕСТИТЬ НоменклатураСХарактеристиками
ИЗ
	СписокНом КАК СписокНом
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатурыИнд
		ПО (&amp;ФОИспользоватьХарактеристикиНоменклатуры)
			И (СписокНом.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры))
			И СписокНом.Номенклатура = ХарактеристикиНоменклатурыИнд.Владелец
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатурыОбщ
		ПО (&amp;ФОИспользоватьХарактеристикиНоменклатуры)
			И (СписокНом.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеДляВидаНоменклатуры))
			И СписокНом.ВидНоменклатуры = ХарактеристикиНоменклатурыОбщ.Владелец
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	НоменклатураСХарактеристиками.Артикул КАК Артикул,
	НоменклатураСХарактеристиками.Номенклатура КАК Номенклатура,
	НоменклатураСХарактеристиками.Родитель КАК Родитель,
	НоменклатураСХарактеристиками.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	НоменклатураСХарактеристиками.ХарактеристикиИспользуются КАК ХарактеристикиИспользуются,
	НоменклатураСХарактеристиками.Характеристика КАК Характеристика,
	НоменклатураСХарактеристиками.ВидНоменклатуры КАК ВидНоменклатуры,
	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0)) КАК ВНаличии,
	НоменклатураСХарактеристиками.ПометкаУдаления КАК ПометкаУдаления,
	НоменклатураСХарактеристиками.ЭтоТовар КАК ЭтоТовар,
	НоменклатураСХарактеристиками.ЭтоУслуга КАК ЭтоУслуга,
	НоменклатураСХарактеристиками.ТипНоменклатуры КАК ТипНоменклатуры
ИЗ
	НоменклатураСХарактеристиками КАК НоменклатураСХарактеристиками
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&amp;Дата, ) КАК ТоварыНаСкладахОстатки
		ПО НоменклатураСХарактеристиками.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
			И НоменклатураСХарактеристиками.Характеристика = ТоварыНаСкладахОстатки.Характеристика
ГДЕ
	ВЫБОР
			КОГДА &amp;ИспользоватьОтборПоСкладу
				ТОГДА ТоварыНаСкладахОстатки.Склад = &amp;Склад
			ИНАЧЕ ИСТИНА
		КОНЕЦ

СГРУППИРОВАТЬ ПО
	НоменклатураСХарактеристиками.Артикул,
	НоменклатураСХарактеристиками.Номенклатура,
	НоменклатураСХарактеристиками.Родитель,
	НоменклатураСХарактеристиками.ЕдиницаИзмерения,
	НоменклатураСХарактеристиками.ХарактеристикиИспользуются,
	НоменклатураСХарактеристиками.Характеристика,
	НоменклатураСХарактеристиками.ПометкаУдаления,
	НоменклатураСХарактеристиками.ВидНоменклатуры,
	НоменклатураСХарактеристиками.ЭтоТовар,
	НоменклатураСХарактеристиками.ЭтоУслуга,
	НоменклатураСХарактеристиками.ТипНоменклатуры</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
