Процедура ЗаписатьАтрибуты()
	
	// Атрибуты текущего уровня (для записи в РС Назначение атрибутов).
	СтруктураОтбораПоСтатусу = Новый Структура("СтатусНаследования", 1);
	СтрокиДобавленоАтрибут   = Объект.Атрибуты.Выгрузить(СтруктураОтбораПоСтатусу);
	
	СтруктураОтбораПоСтатусу.СтатусНаследования = 2;
	СтрокиДобавленоВложенные = Объект.Атрибуты.НайтиСтроки(СтруктураОтбораПоСтатусу);
	Для Каждого СтрокаВложенный ИЗ СтрокиДобавленоВложенные Цикл
		СтрокаДобавлено = СтрокиДобавленоАтрибут.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДобавлено, СтрокаВложенный);
	КонецЦикла;
	
	// Наследуемые атрибуты.
	СтруктураОтбораПоСтатусу.СтатусНаследования = 3;
	СтрокиНаследованыеАтрибуты = Объект.Атрибуты.Выгрузить(СтруктураОтбораПоСтатусу);
	
	// Ненаследуемые атрибуты.
	СтруктураОтбораПоСтатусу.СтатусНаследования = 4;
	СтрокиЗапрещено = Объект.Атрибуты.Выгрузить(СтруктураОтбораПоСтатусу);
	
	ТипСтрока = Тип("Строка");
	
	// Значения атрибутов.
	СтрокиЗначенияАтрибутов = Объект.Атрибуты.Выгрузить(Новый Структура("УровеньЗначения", 1));
	КолВо = СтрокиЗначенияАтрибутов.Количество();
	Для Н = 1 По КолВо Цикл
		СтрокаТЗ = СтрокиЗначенияАтрибутов[КолВо - Н];
		Если СтрокаТЗ.МножественноеЗначение 
				И НЕ СтрокаТЗ.ТипЗначения.СодержитТип(ТипСтрока) Тогда
			СтрокиЗначенияАтрибутов.Удалить(СтрокаТЗ);
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДобавленоАтрибуты",            СтрокиДобавленоАтрибут.ВыгрузитьКолонку("АтрибутКласса"));
	Запрос.УстановитьПараметр("ДанныеДобавленныхАтрибутов",   СтрокиДобавленоАтрибут);
	Запрос.УстановитьПараметр("ДанныеНаследованныхАтрибутов", СтрокиНаследованыеАтрибуты);
	Запрос.УстановитьПараметр("ЗапрещеныАтрибуты",            СтрокиЗапрещено.ВыгрузитьКолонку("АтрибутКласса"));
	Запрос.УстановитьПараметр("ЗначенияАтрибутов",            СтрокиЗначенияАтрибутов);
	Запрос.УстановитьПараметр("Класс",                        Объект.Класс.Ссылка);
	Запрос.Текст = ТекстЗапросаИзмененияАтрибутовВременныеТаблицы();
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаИзмененияАтрибутовТаблицыИзменения();
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	// Удаление строк из назначения атрибутов атрибутов.
	ВыборкаИзменений = РезультатыЗапроса[0].Выбрать();
	Пока ВыборкаИзменений.Следующий() Цикл
		Запись = РегистрыСведений.НазначениеАтрибутов.СоздатьМенеджерЗаписи();
		Запись.Класс = Объект.Класс.Ссылка;
		Запись.АтрибутКласса = ВыборкаИзменений.АтрибутКласса;
		Запись.Удалить();
	КонецЦикла;
	
	// Ненаследуемые значения.
	ВыборкаИзменений = РезультатыЗапроса[1].Выбрать();
	Пока ВыборкаИзменений.Следующий() Цикл
		Запись = РегистрыСведений.НенаследуемыеЗначения.СоздатьМенеджерЗаписи();
		Запись.Класс = Объект.Класс.Ссылка;
		Запись.АтрибутКласса = ВыборкаИзменений.АтрибутКласса;
		Если ВыборкаИзменений.ВидДействия > 0 Тогда
			Запись.НеНаследуемыйАтрибут = Истина;
			Запись.Записать();
		Иначе
			Запись.Удалить();
		КонецЕсли;
	КонецЦикла;
	
	// Значения атрибутов класса.
	ВыборкаИзменений = РезультатыЗапроса[2].Выбрать();
	Пока ВыборкаИзменений.Следующий() Цикл
		Запись = РегистрыСведений.ЗначенияАтрибутовКласса.СоздатьМенеджерЗаписи();
		Запись.Класс = Объект.Класс.Ссылка;
		Запись.АтрибутКласса = ВыборкаИзменений.АтрибутКласса;
		Если ВыборкаИзменений.ВидДействия > 0 Тогда
			Запись.ЗначениеАтрибутаКласса = ВыборкаИзменений.ЗначениеАтрибутаКласса;
			Запись.Записать();
		Иначе
			Запись.Удалить();
		КонецЕсли;
	КонецЦикла;
	
	РежимыЗаполненияАтрибутов = Новый Соответствие;
	
	// Измененные свойства атрибутов.
	ВыборкаИзменений = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаИзменений.Следующий() Цикл
		Запись = РегистрыСведений.НазначениеАтрибутов.СоздатьМенеджерЗаписи();
		Запись.Класс = Объект.Класс.Ссылка;
		ЗаполнитьЗначенияСвойств(Запись, ВыборкаИзменений);
		Запись.Записать();
		
		Если ВыборкаИзменений.РежимЗаполненияИзменен Тогда
			РежимыЗаполненияАтрибутов.Вставить(ВыборкаИзменений.АтрибутКласса, ВыборкаИзменений.РежимЗаполнения);
		КонецЕсли;
	КонецЦикла;
	
	Если РежимыЗаполненияАтрибутов.Количество() > 0 Тогда
		ВыборкаПоВложеннымКлассам = РезультатыЗапроса[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ТаблицаАтрибутовВложенныхКлассов = РезультатыЗапроса[5].Выгрузить();
		ОбработатьРежимЗаполненияВложенныхКлассов(ВыборкаПоВложеннымКлассам, 
			ТаблицаАтрибутовВложенныхКлассов, РежимыЗаполненияАтрибутов);
	КонецЕсли;
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбработатьРежимЗаполненияВложенныхКлассов(ВыборкаПоВложеннымКлассам, 
		ТаблицаАтрибутовВложенныхКлассов, РежимыЗаполненияАтрибутов)
	
	РежимыЗаполнения = Перечисления.РежимыЗаполненияАтрибутов;
	ИндексыРежимовЗаполнения = Новый Соответствие;
	ИндексыРежимовЗаполнения.Вставить(РежимыЗаполнения.Необязательный,              0);
	ИндексыРежимовЗаполнения.Вставить(РежимыЗаполнения.ОбязательныйДляОбъекта,      1);
	ИндексыРежимовЗаполнения.Вставить(РежимыЗаполнения.ОбязательныйДляНоменклатуры, 2);
	ИндексыРежимовЗаполнения.Вставить(РежимыЗаполнения.ОбязательныйДляКласса,       3);
	
	СтруктураПоиска = Новый Структура("Класс");
	Пока ВыборкаПоВложеннымКлассам.Следующий() Цикл
		
		Если НЕ ВыборкаПоВложеннымКлассам.ЭтоЛист Тогда
			РежимыЗаполненияВложенных = Новый Соответствие;
			Для Каждого КлючИЗначение ИЗ РежимыЗаполненияАтрибутов Цикл
				РежимыЗаполненияВложенных.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
			КонецЦикла;
		КонецЕсли;
		
		СтруктураПоиска.Класс = ВыборкаПоВложеннымКлассам.Ссылка;
		НайденоВложенныеАтрибуты = ТаблицаАтрибутовВложенныхКлассов.НайтиСтроки(СтруктураПоиска);
		Если НайденоВложенныеАтрибуты.Количество() > 0 Тогда
			Для Каждого СтрокаАтрибута ИЗ НайденоВложенныеАтрибуты Цикл
				
				РежимЗаполнения = СтрокаАтрибута.РежимЗаполнения;
				РежимРодителя = РежимыЗаполненияАтрибутов[СтрокаАтрибута.АтрибутКласса];
				
				Если РежимЗаполнения = РежимРодителя Тогда
					Продолжить;
				КонецЕсли;
				
				Запись = РегистрыСведений.НазначениеАтрибутов.СоздатьМенеджерЗаписи();
				ЗаполнитьЗначенияСвойств(Запись, СтрокаАтрибута);
				Запись.РежимЗаполнения = РежимРодителя;
				Запись.Записать();
				
				Если НЕ ВыборкаПоВложеннымКлассам.ЭтоЛист Тогда
					РежимыЗаполненияВложенных.Вставить(СтрокаАтрибута.АтрибутКласса, РежимРодителя);
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
		Если НЕ ВыборкаПоВложеннымКлассам.ЭтоЛист Тогда
			ВыборкаРекурсивно = ВыборкаПоВложеннымКлассам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			ОбработатьРежимЗаполненияВложенныхКлассов(ВыборкаРекурсивно, 
				ТаблицаАтрибутовВложенныхКлассов, РежимыЗаполненияВложенных);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Списочные атрибуты.

&НаСервере
Функция ТекстЗапросаИзмененияСписочныхАтрибутовВременныеТаблицы()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ДобавленныеЗначения.АтрибутКласса КАК АтрибутКласса,
		|	ДобавленныеЗначения.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	ДобавленныеЗначения.ДоступноеЗначение КАК ДоступноеЗначение,
		|	ДобавленныеЗначения.ИспользуемоеЗначение КАК ИспользуемоеЗначение
		|ПОМЕСТИТЬ ВТ_ДобавленныеЗначения
		|ИЗ
		|	&ДобавленныеЗначения КАК ДобавленныеЗначения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДобавленныеЗначения.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_ДобавленныеЗначения.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	1 КАК ВидДействия
		|ПОМЕСТИТЬ ВТ_ИзмененияМножественныеЗначенияАтрибутов
		|ИЗ
		|	ВТ_ДобавленныеЗначения КАК ВТ_ДобавленныеЗначения
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МножественныеЗначенияАтрибутов.АтрибутКласса,
		|	МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса,
		|	-1
		|ИЗ
		|	РегистрСведений.МножественныеЗначенияАтрибутов КАК МножественныеЗначенияАтрибутов
		|ГДЕ
		|	МножественныеЗначенияАтрибутов.Класс = &Класс
		|	И НЕ МножественныеЗначенияАтрибутов.ТабличныйАтрибут
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутов.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	СУММА(ВТ_ИзмененияМножественныеЗначенияАтрибутов.ВидДействия) КАК ВидДействия
		|ПОМЕСТИТЬ ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто
		|ИЗ
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутов КАК ВТ_ИзмененияМножественныеЗначенияАтрибутов
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутов.АтрибутКласса,
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НенаследуемыеЗначения.АтрибутКласса КАК АтрибутКласса,
		|	НенаследуемыеЗначения.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса
		|ПОМЕСТИТЬ ВТ_НенаследуемыеЗначения
		|ИЗ
		|	&НенаследуемыеЗначения КАК НенаследуемыеЗначения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_НенаследуемыеЗначения.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_НенаследуемыеЗначения.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	1 КАК ВидДействия
		|ПОМЕСТИТЬ ВТ_ИзмененияНенаследуемыеЗначения
		|ИЗ
		|	ВТ_НенаследуемыеЗначения КАК ВТ_НенаследуемыеЗначения
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НенаследуемыеЗначения.АтрибутКласса,
		|	НенаследуемыеЗначения.ЗначениеАтрибутаКласса,
		|	-1
		|ИЗ
		|	РегистрСведений.НенаследуемыеЗначения КАК НенаследуемыеЗначения
		|ГДЕ
		|	НенаследуемыеЗначения.Класс = &Класс
		|	И НенаследуемыеЗначения.АтрибутКласса В  (&СписочныеАтрибутыКласса)
		|	И НЕ НенаследуемыеЗначения.НеНаследуемыйАтрибут";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция ТекстЗапросаИзмененияСписочныхАтрибутовТаблицыИзменения()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.АтрибутКласса,
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.ЗначениеАтрибутаКласса,
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.ВидДействия,
		|	ВТ_ДобавленныеЗначения.ДоступноеЗначение,
		|	ВТ_ДобавленныеЗначения.ИспользуемоеЗначение
		|ИЗ
		|	ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто КАК ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДобавленныеЗначения КАК ВТ_ДобавленныеЗначения
		|		ПО ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.АтрибутКласса = ВТ_ДобавленныеЗначения.АтрибутКласса
		|			И ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.ЗначениеАтрибутаКласса = ВТ_ДобавленныеЗначения.ЗначениеАтрибутаКласса
		|			И (ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.ВидДействия >= 0)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МножественныеЗначенияАтрибутов КАК МножественныеЗначенияАтрибутов
		|		ПО ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.АтрибутКласса = МножественныеЗначенияАтрибутов.АтрибутКласса
		|			И ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.ЗначениеАтрибутаКласса = МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса
		|			И (ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.ВидДействия = 0)
		|			И (МножественныеЗначенияАтрибутов.Класс = &Класс)
		|ГДЕ
		|	(ВТ_ИзмененияМножественныеЗначенияАтрибутовСвернуто.ВидДействия <> 0
		|			ИЛИ ВТ_ДобавленныеЗначения.ДоступноеЗначение <> ЕСТЬNULL(МножественныеЗначенияАтрибутов.ДоступноеЗначение, ЛОЖЬ)
		|			ИЛИ ВТ_ДобавленныеЗначения.ИспользуемоеЗначение <> ЕСТЬNULL(МножественныеЗначенияАтрибутов.ИспользуемоеЗначение, ЛОЖЬ))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИзмененияНенаследуемыеЗначения.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_ИзмененияНенаследуемыеЗначения.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	СУММА(ВТ_ИзмененияНенаследуемыеЗначения.ВидДействия) КАК ВидДействия
		|ИЗ
		|	ВТ_ИзмененияНенаследуемыеЗначения КАК ВТ_ИзмененияНенаследуемыеЗначения
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ИзмененияНенаследуемыеЗначения.АтрибутКласса,
		|	ВТ_ИзмененияНенаследуемыеЗначения.ЗначениеАтрибутаКласса
		|
		|ИМЕЮЩИЕ
		|	СУММА(ВТ_ИзмененияНенаследуемыеЗначения.ВидДействия) <> 0";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Процедура ЗаписатьЗначенияСписочныхАтрибутов()
	
	СтрокиДобавленныеЗначения   = Объект.ЗначенияСписочныхАтрибутов.Выгрузить(Новый Структура("СтатусНаследования", 2));
	СтрокиНенаследуемыеЗначения = Объект.ЗначенияСписочныхАтрибутов.Выгрузить(Новый Структура("СтатусНаследования", 4));
	
	ТаблицаАтрибуты = Объект.ЗначенияСписочныхАтрибутов.Выгрузить(, "АтрибутКласса");
	ТаблицаАтрибуты.Свернуть("АтрибутКласса");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Класс", Объект.Класс.Ссылка);
	Запрос.УстановитьПараметр("ДобавленныеЗначения", СтрокиДобавленныеЗначения);
	Запрос.УстановитьПараметр("НенаследуемыеЗначения", СтрокиНенаследуемыеЗначения);
	Запрос.УстановитьПараметр("СписочныеАтрибутыКласса", ТаблицаАтрибуты.ВыгрузитьКолонку("АтрибутКласса"));

	Запрос.Текст = ТекстЗапросаИзмененияСписочныхАтрибутовВременныеТаблицы();
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаИзмененияСписочныхАтрибутовТаблицыИзменения();
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	// Использование в составе объектов.
	ВыборкаИзменений = РезультатыЗапроса[0].Выбрать();
	Пока ВыборкаИзменений.Следующий() Цикл
		Запись = РегистрыСведений.МножественныеЗначенияАтрибутов.СоздатьМенеджерЗаписи();
		Запись.Класс = Объект.Класс.Ссылка;
		ЗаполнитьЗначенияСвойств(Запись, ВыборкаИзменений);
		Если ВыборкаИзменений.ВидДействия >= 0 Тогда
			Запись.Записать();
		Иначе
			Запись.Удалить();
		КонецЕсли;
	КонецЦикла;
	
	// Ненаследуемые значения.
	ВыборкаИзменений = РезультатыЗапроса[1].Выбрать();
	Пока ВыборкаИзменений.Следующий() Цикл
		Запись = РегистрыСведений.НенаследуемыеЗначения.СоздатьМенеджерЗаписи();
		Запись.Класс                  = Объект.Класс.Ссылка;
		Запись.АтрибутКласса          = ВыборкаИзменений.АтрибутКласса;
		Запись.ЗначениеАтрибутаКласса = ВыборкаИзменений.ЗначениеАтрибутаКласса;
		Если ВыборкаИзменений.ВидДействия > 0 Тогда
			Запись.Записать();
		Иначе
			Запись.Удалить();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Табличные атрибуты.

&НаСервере
Функция ТекстЗапросаИерархияКлассовСтрокТабличныхАтрибутов()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтрокиТабличныхАтрибутов.ИДСтрокиРодителя,
		|	СтрокиТабличныхАтрибутов.АтрибутКласса,
		|	СтрокиТабличныхАтрибутов.ИДСтроки,
		|	СтрокиТабличныхАтрибутов.Порядок,
		|	СтрокиТабличныхАтрибутов.СтатусНаследования,
		|	СтрокиТабличныхАтрибутов.ИсточникЗначений,
		|	СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса,
		|	СтрокиТабличныхАтрибутов.Наименование
		|ПОМЕСТИТЬ ВТ_СтрокиТабличныхАтрибутовНовые
		|ИЗ
		|	&СтрокиТабличныхАтрибутов КАК СтрокиТабличныхАтрибутов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗначенияТабличныхАтрибутов.ИДСтрокиРодителя,
		|	ЗначенияТабличныхАтрибутов.АтрибутКласса,
		|	ЗначенияТабличныхАтрибутов.АтрибутТаблицы,
		|	ЗначенияТабличныхАтрибутов.ЗначениеАтрибутаТаблицы,
		|	ЗначенияТабличныхАтрибутов.ИДСтроки
		|ПОМЕСТИТЬ ВТ_ЗначенияТабличныхАтрибутов
		|ИЗ
		|	&ЗначенияТабличныхАтрибутов КАК ЗначенияТабличныхАтрибутов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Классы.Ссылка КАК КлассДляЧтения,
		|	Классы.Ссылка КАК Класс
		|ИЗ
		|	Справочник.Классы КАК Классы
		|ГДЕ
		|	НЕ Классы.ПометкаУдаления
		|	И Классы.Ссылка В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ВТ_СтрокиТабличныхАтрибутовНовые.ЗначениеАтрибутаКласса
		|			ИЗ
		|				ВТ_СтрокиТабличныхАтрибутовНовые КАК ВТ_СтрокиТабличныхАтрибутовНовые
		|		
		|			ОБЪЕДИНИТЬ ВСЕ
		|		
		|			ВЫБРАТЬ
		|				&Класс)
		|ИТОГИ
		|	МАКСИМУМ(КлассДляЧтения)
		|ПО
		|	Класс,
		|	Класс ТОЛЬКО ИЕРАРХИЯ";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция ТекстЗапросаДанныеТабличныхАтрибутов()
	
	ТекстЗапроса =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ТаблицаАтрибутов.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_ТаблицаАтрибутов.Порядок КАК Порядок
		|ИЗ
		|	ВТ_ТаблицаАтрибутов КАК ВТ_ТаблицаАтрибутов
		|ГДЕ
		|	ВТ_ТаблицаАтрибутов.МножественноеЗначение
		|	И ВТ_ТаблицаАтрибутов.КлассТабличнаяЧасть
		|
		|УПОРЯДОЧИТЬ ПО
		|	Порядок,
		|	АтрибутКласса
		|АВТОУПОРЯДОЧИВАНИЕ";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере 
Функция ТекстЗапросаЗначенияАтрибутовСтрокВременныеТаблицы()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ЗначениеАтрибутаКласса КАК КлассДляЧтения,
		|	ВТ_ЗначенияТабличныхАтрибутов.АтрибутТаблицы,
		|	ВТ_ЗначенияТабличныхАтрибутов.ЗначениеАтрибутаТаблицы
		|ПОМЕСТИТЬ ВТ_ЗначенияАтрибутовСтрокДляЗаписи
		|ИЗ
		|	ВТ_СтрокиТабличныхАтрибутовНовые КАК ВТ_СтрокиТабличныхАтрибутовНовые
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЗначенияТабличныхАтрибутов КАК ВТ_ЗначенияТабличныхАтрибутов
		|		ПО ВТ_СтрокиТабличныхАтрибутовНовые.ИДСтрокиРодителя = ВТ_ЗначенияТабличныхАтрибутов.ИДСтрокиРодителя
		|			И ВТ_СтрокиТабличныхАтрибутовНовые.АтрибутКласса = ВТ_ЗначенияТабличныхАтрибутов.АтрибутКласса
		|			И ВТ_СтрокиТабличныхАтрибутовНовые.ИДСтроки = ВТ_ЗначенияТабличныхАтрибутов.ИДСтроки
		|ГДЕ
		|	ВТ_ЗначенияТабличныхАтрибутов.АтрибутТаблицы ССЫЛКА ПланВидовХарактеристик.АтрибутыКласса
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ЗначениеАтрибутаКласса КАК Класс,
		|	ВТ_СтрокиТабличныхАтрибутовПодчиненныхНовые.АтрибутКласса,
		|	ВТ_СтрокиТабличныхАтрибутовПодчиненныхНовые.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	ВТ_СтрокиТабличныхАтрибутовПодчиненныхНовые.Порядок
		|ПОМЕСТИТЬ ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи
		|ИЗ
		|	ВТ_СтрокиТабличныхАтрибутовНовые КАК ВТ_СтрокиТабличныхАтрибутовНовые
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СтрокиТабличныхАтрибутовНовые КАК ВТ_СтрокиТабличныхАтрибутовПодчиненныхНовые
		|		ПО ВТ_СтрокиТабличныхАтрибутовНовые.ИДСтроки = ВТ_СтрокиТабличныхАтрибутовПодчиненныхНовые.ИДСтрокиРодителя
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&Класс,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.АтрибутКласса,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ЗначениеАтрибутаКласса,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.Порядок
		|ИЗ
		|	ВТ_СтрокиТабличныхАтрибутовНовые КАК ВТ_СтрокиТабличныхАтрибутовНовые
		|ГДЕ
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ИДСтрокиРодителя = 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СтрокиТабличныхАтрибутов.КлассДляЧтения,
		|	СтрокиТабличныхАтрибутов.АтрибутКласса,
		|	СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса,
		|	СтрокиТабличныхАтрибутов.ИсточникЗначений,
		|	СтрокиТабличныхАтрибутов.СтатусНаследования,
		|	СтрокиТабличныхАтрибутов.Порядок,
		|	СтрокиТабличныхАтрибутов.Уровень,
		|	СтрокиТабличныхАтрибутов.УровеньТекКласса
		|ПОМЕСТИТЬ ВТ_СтрокиТабличныхАтрибутов
		|ИЗ
		|	&СтрокиТабличныхАтрибутов КАК СтрокиТабличныхАтрибутов";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере 
Функция ТекстЗапросаЗначенияАтрибутовСтрок()
	
	// 0 - Значения атрибутов строк таб.частей.
	// 1 - Строки табличных атрибутов.
	// 2 - Ненаследуемые атрибуты.
	// 3 - Переименование строк.
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВТ_ЗначенияАтрибутовСтрокДляЗаписи.КлассДляЧтения,
		|	ВТ_ЗначенияАтрибутовСтрокДляЗаписи.АтрибутТаблицы КАК АтрибутКласса,
		|	ВТ_ЗначенияАтрибутовСтрокДляЗаписи.ЗначениеАтрибутаТаблицы КАК ЗначениеАтрибутаКласса
		|ИЗ
		|	ВТ_ЗначенияАтрибутовСтрокДляЗаписи КАК ВТ_ЗначенияАтрибутовСтрокДляЗаписи
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТаблицаАтрибутов КАК ВТ_ТаблицаАтрибутов
		|		ПО (ВТ_ТаблицаАтрибутов.КлассДляЧтения = ВТ_ЗначенияАтрибутовСтрокДляЗаписи.КлассДляЧтения)
		|			И (ВТ_ТаблицаАтрибутов.АтрибутКласса = ВТ_ЗначенияАтрибутовСтрокДляЗаписи.АтрибутТаблицы)
		|ГДЕ
		|	(ВТ_ТаблицаАтрибутов.ЗначениеАтрибутаКласса ЕСТЬ NULL
		|			ИЛИ НЕ ВТ_ЗначенияАтрибутовСтрокДляЗаписи.ЗначениеАтрибутаТаблицы = ВТ_ТаблицаАтрибутов.ЗначениеАтрибутаКласса)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.Класс,
		|	ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.АтрибутКласса,
		|	ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.ЗначениеАтрибутаКласса,
		|	ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.Порядок,
		|	1 КАК ВидДействия
		|ИЗ
		|	ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи КАК ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтрокиТабличныхАтрибутов КАК ВТ_СтрокиТабличныхАтрибутов
		|		ПО ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.Класс = ВТ_СтрокиТабличныхАтрибутов.КлассДляЧтения
		|			И ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.АтрибутКласса = ВТ_СтрокиТабличныхАтрибутов.АтрибутКласса
		|			И ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.ЗначениеАтрибутаКласса = ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса
		|ГДЕ
		|	(ВТ_СтрокиТабличныхАтрибутов.Порядок ЕСТЬ NULL
		|			ИЛИ НЕ ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.Порядок = ВТ_СтрокиТабличныхАтрибутов.Порядок)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_СтрокиТабличныхАтрибутов.КлассДляЧтения,
		|	ВТ_СтрокиТабличныхАтрибутов.АтрибутКласса,
		|	ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса,
		|	0,
		|	-1
		|ИЗ
		|	ВТ_СтрокиТабличныхАтрибутов КАК ВТ_СтрокиТабличныхАтрибутов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи КАК ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи
		|		ПО ВТ_СтрокиТабличныхАтрибутов.КлассДляЧтения = ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.Класс
		|			И ВТ_СтрокиТабличныхАтрибутов.АтрибутКласса = ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.АтрибутКласса
		|			И ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса = ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.ЗначениеАтрибутаКласса
		|ГДЕ
		|	ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.ЗначениеАтрибутаКласса ЕСТЬ NULL
		|	И ВТ_СтрокиТабличныхАтрибутов.Уровень = ВТ_СтрокиТабличныхАтрибутов.УровеньТекКласса
		|	И НЕ ЕСТЬNULL(ВЫРАЗИТЬ(ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса КАК Справочник.Классы).ПометкаУдаления, ИСТИНА)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СтрокиТабличныхАтрибутов.КлассДляЧтения,
		|	ВТ_СтрокиТабличныхАтрибутов.АтрибутКласса,
		|	ВЫБОР
		|		КОГДА НЕ ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса = ЗНАЧЕНИЕ(Справочник.Классы.ПустаяСсылка)
		|			ТОГДА ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса
		|		ИНАЧЕ ВТ_СтрокиТабличныхАтрибутов.ИсточникЗначений
		|	КОНЕЦ КАК ЗначениеАтрибутаКласса
		|ИЗ
		|	ВТ_СтрокиТабличныхАтрибутов КАК ВТ_СтрокиТабличныхАтрибутов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи КАК ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи
		|		ПО ВТ_СтрокиТабличныхАтрибутов.КлассДляЧтения = ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.Класс
		|			И ВТ_СтрокиТабличныхАтрибутов.АтрибутКласса = ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.АтрибутКласса
		|			И ВТ_СтрокиТабличныхАтрибутов.ЗначениеАтрибутаКласса = ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.ЗначениеАтрибутаКласса
		|ГДЕ
		|	ВТ_МножественныеЗначенияТабличныхАтрибутовДляЗаписи.ЗначениеАтрибутаКласса ЕСТЬ NULL
		|	И ВТ_СтрокиТабличныхАтрибутов.Уровень < ВТ_СтрокиТабличныхАтрибутов.УровеньТекКласса
		|	И ВТ_СтрокиТабличныхАтрибутов.СтатусНаследования <= 3
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.Наименование,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ИсточникЗначений,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ИДСтрокиРодителя,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.АтрибутКласса,
		|	ВТ_СтрокиТабличныхАтрибутовНовые.ИДСтроки
		|ИЗ
		|	ВТ_СтрокиТабличныхАтрибутовНовые КАК ВТ_СтрокиТабличныхАтрибутовНовые
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Классы КАК Классы
		|		ПО ВТ_СтрокиТабличныхАтрибутовНовые.ЗначениеАтрибутаКласса = Классы.Ссылка
		|ГДЕ
		|	(ВТ_СтрокиТабличныхАтрибутовНовые.Наименование <> Классы.Наименование
		|			ИЛИ ВТ_СтрокиТабличныхАтрибутовНовые.Наименование = """")
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗначениеАтрибутаКласса
		|АВТОУПОРЯДОЧИВАНИЕ";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция СформироватьНаименованиеСтрокиТабличногоАтрибута(СтрокаТЧ, КодЭлемента)
	
	Если СтрокаТЧ.АтрибутКласса = ПланыВидовХарактеристик.АтрибутыКласса.ТехКарты Тогда
		Если ПустаяСтрока(СтрокаТЧ.Наименование) Тогда
			НайденоТипТехКарты = Объект.ЗначенияТабличныхАтрибутов.НайтиСтроки(Новый Структура(
				"ИДСтрокиРодителя, АтрибутКласса, ИДСтроки, АтрибутТаблицы",
				СтрокаТЧ.ИДСтрокиРодителя, СтрокаТЧ.АтрибутКласса, СтрокаТЧ.ИДСтроки,
				ПланыВидовХарактеристик.АтрибутыКласса.ТипТехКарты));
			Если НайденоТипТехКарты.Количество() > 0 И ЗначениеЗаполнено(НайденоТипТехКарты[0].ЗначениеАтрибутаТаблицы) Тогда
				Результат = Строка(НайденоТипТехКарты[0].ЗначениеАтрибутаТаблицы);
			Иначе
				Результат = Строка(СтрокаТЧ.ИсточникЗначений);
			КонецЕсли;
		Иначе
			Результат = СтрокаТЧ.Наименование;
		КонецЕсли;
	Иначе
		Результат = Строка(СтрокаТЧ.ИсточникЗначений) + "/" + ШаблоныСтрокКлиентСервер.УдалитьНезначащиеНули(КодЭлемента);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаписатьЗначенияТабличныхАтрибутов()
	
	// 1. Запись классов новых строк.
	Для Каждого СтрокаТЧ ИЗ Объект.СтрокиТабличныхАтрибутов Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ЗначениеАтрибутаКласса) Тогда
			НовыйКласс = Справочники.Классы.СоздатьЭлемент();
			НовыйКласс.Родитель            = СтрокаТЧ.ИсточникЗначений;
			НовыйКласс.КлассТабличнаяЧасть = Истина;
			НовыйКласс.НоменклатураКласса  = СтрокаТЧ.НоменклатураКласса;
			НовыйКласс.ОбъектыНоменклатуры = СтрокаТЧ.ОбъектыНоменклатуры;
			НовыйКласс.Статус = Перечисления.СтатусыОбъектовНСИ.Активный;
			НовыйКласс.УстановитьНовыйКод();
			НовыйКласс.Наименование = СформироватьНаименованиеСтрокиТабличногоАтрибута(СтрокаТЧ, НовыйКласс.Код);
			НовыйКласс.Записать();
			
			СтрокаТЧ.ЗначениеАтрибутаКласса = НовыйКласс.Ссылка;
			СтрокаТЧ.Наименование           = НовыйКласс.Наименование;
		КонецЕсли;
	КонецЦикла;
	
	// 2. Чтение атрибутов классов.
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.УстановитьПараметр("СтрокиТабличныхАтрибутов",   Объект.СтрокиТабличныхАтрибутов.Выгрузить());
	Запрос.УстановитьПараметр("ЗначенияТабличныхАтрибутов", Объект.ЗначенияТабличныхАтрибутов.Выгрузить());
	Запрос.УстановитьПараметр("Класс", Объект.Класс.Ссылка);
	Запрос.Текст = ТекстЗапросаИерархияКлассовСтрокТабличныхАтрибутов();
	
	// Таблица родителей для чтения атрибутов строк табличных частей.
	ТаблицаРодителей = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.Прямой);
	ТаблицаРодителей.Колонки.Добавить("Уровень", Новый ОписаниеТипов("Число"));
	
	ТекКлассДляЧтения = Неопределено;
	Для Каждого СтрокаТЗ ИЗ ТаблицаРодителей Цикл
		Если НЕ СтрокаТЗ.КлассДляЧтения = ТекКлассДляЧтения Тогда
			Н = 0;
			ТекКлассДляЧтения = СтрокаТЗ.КлассДляЧтения;
			ПредКласс = Неопределено;
		КонецЕсли;
		Если НЕ ПредКласс = СтрокаТЗ.Класс Тогда
			СтрокаТЗ.Уровень = Н;
			Н = Н + 1;
			ПредКласс = СтрокаТЗ.Класс;
		КонецЕсли;
	КонецЦикла;
	
	НайденоУдалить = ТаблицаРодителей.НайтиСтроки(Новый Структура("Уровень", 0));
	Для Каждого СтрокаТЗ ИЗ НайденоУдалить Цикл
		ТаблицаРодителей.Удалить(СтрокаТЗ);
	КонецЦикла;
	
	// Записанные значения атрибутов строк таб.частей.
	Справочники.Классы.ПолучитьТаблицуАтрибутов(ТаблицаРодителей, МенеджерВТ);
	
	// Таблица списочных атрибутов строк таб.частей (вложеные таб.части).
	Запрос.Текст = ТекстЗапросаДанныеТабличныхАтрибутов();
	ТаблицаАтрибутов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("АтрибутКласса");
	
	// Записанные строки таб.частей.
	СтрокиТабличныхАтрибутов = Справочники.Классы.ПолучитьСтрокиТабличныхАтрибутов(ТаблицаРодителей, ТаблицаАтрибутов);
	
	// Сравниваем записанные строки с данными формы.
	Запрос.УстановитьПараметр("СтрокиТабличныхАтрибутов", СтрокиТабличныхАтрибутов);
	Запрос.Текст = ТекстЗапросаЗначенияАтрибутовСтрокВременныеТаблицы();
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаЗначенияАтрибутовСтрок();
	Результаты = Запрос.ВыполнитьПакет();
	
	// 3. Запись изменений.
	
	// Значения атрибутов строк таб.частей.
	Выборка = Результаты[0].Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись = РегистрыСведений.ЗначенияАтрибутовКласса.СоздатьМенеджерЗаписи();
		Запись.Класс                  = Выборка.КлассДляЧтения;
		Запись.АтрибутКласса          = Выборка.АтрибутКласса;
		Запись.ЗначениеАтрибутаКласса = Выборка.ЗначениеАтрибутаКласса;
		Запись.Записать();
	КонецЦикла;
	
	// Строки табличных атрибутов.
	Выборка = Результаты[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись = РегистрыСведений.МножественныеЗначенияАтрибутов.СоздатьМенеджерЗаписи();
		Запись.Класс                  = Выборка.Класс;
		Запись.АтрибутКласса          = Выборка.АтрибутКласса;
		Запись.ЗначениеАтрибутаКласса = Выборка.ЗначениеАтрибутаКласса;
		Если Выборка.ВидДействия > 0 Тогда
			Запись.Порядок = Выборка.Порядок;
			Запись.ИспользуемоеЗначение = Истина;
			Запись.ТабличныйАтрибут = Истина;
			Запись.Записать();
		Иначе
			Запись.Удалить();
		КонецЕсли;
	КонецЦикла;
	
	// Ненаследуемые атрибуты.
	Выборка = Результаты[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись = РегистрыСведений.НенаследуемыеЗначения.СоздатьМенеджерЗаписи();
		Запись.Класс                  = Выборка.КлассДляЧтения;
		Запись.АтрибутКласса          = Выборка.АтрибутКласса;
		Запись.ЗначениеАтрибутаКласса = Выборка.ЗначениеАтрибутаКласса;
		Запись.Записать();
	КонецЦикла;
	
	// Переименование строк.
	Выборка = Результаты[3].Выбрать();
	Пока Выборка.Следующий() Цикл
		СпрОбъект = Выборка.ЗначениеАтрибутаКласса.ПолучитьОбъект();
		СпрОбъект.Наименование = СформироватьНаименованиеСтрокиТабличногоАтрибута(Выборка, СпрОбъект.Код);
		СпрОбъект.Записать();
	КонецЦикла;
	
КонецПроцедуры

