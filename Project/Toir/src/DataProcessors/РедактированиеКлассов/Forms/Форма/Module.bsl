#Область ОбработчикиСобытийТаблицыФормыКлассы

&НаКлиенте
Процедура КлассыСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если Модифицированность Тогда
		ТекстВопроса = НСтр("ru='Данные были изменены. Сохранить изменения?'");
		ДопПараметры = Новый Структура("ВыбраннаяСтрока, РежимДобавления", ВыбраннаяСтрока, 0);
		ПоказатьВопрос(Новый ОписаниеОповещения("ПодготовитьФормуРедактированияКлассаЗавершение", ЭтаФорма, ДопПараметры),
			ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		Возврат;
	КонецЕсли;
	
	Если Редактирование И ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
		СнятьБлокировкуКласса();
	КонецЕсли;
	
	Пользователь = Неопределено;
	ОбъектЗаблокирован = ОбъектРедактируется(ВыбраннаяСтрока, Ложь, Пользователь);
	Если ОбъектЗаблокирован Тогда
		ШаблонПредупреждения = НСтр("ru = 'Класс ''%1'' заблокирован для редактирования пользователем ''%2''.'");
		ТекстПредупреждения = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
			ШаблонПредупреждения, Строка(ВыбраннаяСтрока), Строка(Пользователь));
		ПоказатьПредупреждение(, ТекстПредупреждения);
		
		ВыбратьОбъектРедактирования(Неопределено);
		
		ОтменитьРедактированиеНаСервере();
		Возврат;
		
	КонецЕсли;
	
	ПодготовитьФормуРедактированияКласса(ВыбраннаяСтрока);
	Если ПереключательАтрибутов > 1 Тогда 
		ПереключательАтрибутов = 0;
		ПереключитьСтраницуФормы();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КлассыСписокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;
	ТекСтрока = Элементы.КлассыСписок.ТекущаяСтрока;
	Если Модифицированность Тогда
		ТекстВопроса = НСтр("ru='Данные были изменены. Сохранить изменения?'");
		ДопПараметры = Новый Структура("ВыбраннаяСтрока, РежимДобавления", ТекСтрока, ?(Копирование, 2, 1));
		ПоказатьВопрос(Новый ОписаниеОповещения("ПодготовитьФормуРедактированияКлассаЗавершение", ЭтаФорма, ДопПараметры), 
			ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		Возврат;
	КонецЕсли;
	
	Если ТекСтрока = Неопределено Тогда
		ТекСтрока = Родитель;
	КонецЕсли;
	
	ПодготовитьФормуРедактированияКласса(ТекСтрока, ?(Копирование, 2, 1));
	Если ПереключательАтрибутов > 1 Тогда 
		ПереключательАтрибутов = 0;
		ПереключитьСтраницуФормы();
	КонецЕсли;
	
	Если НЕ Элементы.КлассыСписок.ТекущийРодитель = Объект.Родитель Тогда
		Элементы.КлассыСписок.ТекущийРодитель = Объект.Родитель;
	КонецЕсли;
	
КонецПроцедуры

