		|	КОНЕЦ КАК ДоступноеЗначение,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатурыНеПрямоеЗначение.ДоступноеЗначение, ЛОЖЬ) = ИСТИНА
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК МожноИзменятьДоступноеЗначение,
		|	&ТипАтрибутаОбъектНоменклатуры КАК МожноИзменятьИспользуемоеЗначение,
		|	ВТ_ОбъектыНоменклатурыПровекаПрямогоЗначения.Класс КАК Класс,
		|	ВТ_ОбъектыНоменклатурыПровекаПрямогоЗначения.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВТ_ОбъектыНоменклатурыПровекаПрямогоЗначения КАК ВТ_ОбъектыНоменклатурыПровекаПрямогоЗначения
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатуры КАК ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатурыПрямоеЗначение
		|		ПО ВТ_ОбъектыНоменклатурыПровекаПрямогоЗначения.ЗначениеАтрибутаКласса = ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатурыПрямоеЗначение.ЗначениеАтрибутаКласса
		|			И (ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатурыПрямоеЗначение.ПрямоеЗначение)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатуры КАК ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатурыНеПрямоеЗначение
		|		ПО ВТ_ОбъектыНоменклатурыПровекаПрямогоЗначения.ЗначениеАтрибутаКласса = ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатурыНеПрямоеЗначение.ЗначениеАтрибутаКласса
		|			И (НЕ ВТ_ЗначенияСписочныхАтрибутовКлассаОбъектыНоменклатурыНеПрямоеЗначение.ПрямоеЗначение)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗначениеАтрибутаКласса,
		|	СтатусНаследования
		|ИТОГИ
		|	ВЫБОР
		|		КОГДА Номенклатура ЕСТЬ NULL
		|			ТОГДА Класс
		|		ИНАЧЕ Номенклатура
		|	КОНЕЦ КАК ЗначениеАтрибутаКласса,
		|	1 КАК СтатусНаследования
		|ПО
		|	Класс,
		|	Номенклатура
		|АВТОУПОРЯДОЧИВАНИЕ";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция ОбработатьДеревоСписочныхЗначенийАтрибутов(ДеревоЗначений, ИсточникЗначений)
	
	ДеревоРезультат = ДеревоЗначений.Скопировать();
	ДеревоРезультат.Строки.Очистить();
	
	ТекРодитель = ДеревоЗначений;
	ТекИд = ТекРодитель.Строки.Количество(); // от последнего элемента до первого
	
	ТекРодительНового = ДеревоРезультат;
	
	СтекОбхода = Новый Массив;
	Пока ТекИд > 0 ИЛИ СтекОбхода.Количество() > 0 Цикл
		Если ТекИд > 0 Тогда
			СтрокаДерева = ТекРодитель.Строки[ТекИд - 1];
			
			Если СтрокаДерева.Строки.Количество() > 0 Тогда
				// Если в дочерних строках есть этот же атрибут, значит надо удалить дубль.
				СтрокаНайдено = СтрокаДерева.Строки.Найти(СтрокаДерева.ЗначениеАтрибутаКласса, "ЗначениеАтрибутаКласса");
				Если НЕ СтрокаНайдено = Неопределено Тогда
					Если СтрокаНайдено.Строки.Количество() > 0 Тогда
						ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаНайдено.Строки[0]);
					Иначе
						ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаНайдено);
					КонецЕсли;
					СтрокаДерева.Строки.Удалить(СтрокаНайдено);
				КонецЕсли;
				
				Если СтрокаДерева.ЗначениеАтрибутаКласса = ИсточникЗначений Тогда
					СтрокаДерева.ВИерархии = Ложь;
				КонецЕсли;
				
				СтрокаНового = Неопределено;
				// Не учитываем элементы верхних уровней (уровнем выше, чем источик значений).
				Если СтрокаДерева.ВИерархии Тогда
					СтрокаНового = ТекРодительНового.Строки.Вставить(0);
					ЗаполнитьЗначенияСвойств(СтрокаНового, СтрокаДерева);
					Если НЕ ТекРодительНового = ДеревоРезультат Тогда
						Если ТекРодительНового.ДоступноеЗначениеНаследуемое Тогда
							СтрокаНового.ДоступноеЗначениеНаследуемое   = ТекРодительНового.ДоступноеЗначениеНаследуемое;
							СтрокаНового.МожноИзменятьДоступноеЗначение = Ложь;
						КонецЕсли;
						
						Если ТекРодительНового.ДоступноеЗначение И СтрокаНового.СтатусНаследования <= 3 Тогда
							СтрокаНового.ДоступноеЗначение              = Истина;
							СтрокаНового.МожноИзменятьДоступноеЗначение = Ложь;
							СтрокаНового.СтатусНаследования             = ТекРодительНового.СтатусНаследования;
							СтрокаНового.ДоступноеЗначениеНаследуемое   = ТекРодительНового.ДоступноеЗначениеНаследуемое
							
						ИначеЕсли ТекРодительНового.СтатусНаследования > 3 Тогда
							СтрокаНового.ДоступноеЗначение              = Ложь;
							СтрокаНового.МожноИзменятьДоступноеЗначение = Ложь;
							СтрокаНового.СтатусНаследования             = ТекРодительНового.СтатусНаследования;
							СтрокаНового.ДоступноеЗначениеНаследуемое   = ТекРодительНового.ДоступноеЗначениеНаследуемое
							
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
				Если СтрокаДерева.Строки.Количество() > 0 Тогда
					// Если есть дочерние строки, перейдем на уровень ниже.
					СтекОбхода.Вставить(0, ТекИд - 1);
					ТекРодитель = СтрокаДерева;
					ТекИд = ТекРодитель.Строки.Количество();
					Если НЕ СтрокаНового = Неопределено Тогда
						ТекРодительНового = СтрокаНового;
					КонецЕсли;
				Иначе
					ТекИд = ТекРодитель.Строки.Индекс(СтрокаДерева);
				КонецЕсли;
			Иначе
				СтрокаНового = Неопределено;
				Если СтрокаДерева.ВИерархии Тогда
					СтрокаНового = ТекРодительНового.Строки.Вставить(0);
					ЗаполнитьЗначенияСвойств(СтрокаНового, СтрокаДерева);
					Если НЕ ТекРодительНового = ДеревоРезультат Тогда
						Если ТекРодительНового.ДоступноеЗначениеНаследуемое Тогда
							СтрокаНового.ДоступноеЗначениеНаследуемое   = ТекРодительНового.ДоступноеЗначениеНаследуемое;
							СтрокаНового.МожноИзменятьДоступноеЗначение = Ложь;
						КонецЕсли;
						
						Если ТекРодительНового.ДоступноеЗначение И СтрокаНового.СтатусНаследования <= 3 Тогда
							СтрокаНового.ДоступноеЗначение              = Истина;
							СтрокаНового.МожноИзменятьДоступноеЗначение = Ложь;
							СтрокаНового.СтатусНаследования             = ТекРодительНового.СтатусНаследования;
							СтрокаНового.ДоступноеЗначениеНаследуемое   = ТекРодительНового.ДоступноеЗначениеНаследуемое
							
						ИначеЕсли ТекРодительНового.СтатусНаследования > 3 Тогда
							СтрокаНового.ДоступноеЗначение              = Ложь;
							СтрокаНового.МожноИзменятьДоступноеЗначение = Ложь;
							СтрокаНового.СтатусНаследования             = ТекРодительНового.СтатусНаследования;
							СтрокаНового.ДоступноеЗначениеНаследуемое   = ТекРодительНового.ДоступноеЗначениеНаследуемое
							
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
				ТекИд = ТекРодитель.Строки.Индекс(СтрокаДерева);
			КонецЕсли;
		КонецЕсли;
		
		Если ТекИд <= 0 И СтекОбхода.Количество() > 0 Тогда
			ТекИд = СтекОбхода[0];
			СтекОбхода.Удалить(0);
			Если ТекРодитель.ВИерархии Тогда
				ТекРодительНового = ТекРодительНового.Родитель;
				Если ТекРодительНового = Неопределено Тогда
					ТекРодительНового = ДеревоРезультат;
				КонецЕсли;
			КонецЕсли;
			ТекРодитель = ТекРодитель.Родитель;
			Если ТекРодитель = Неопределено Тогда
				ТекРодитель = ДеревоЗначений;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ДеревоРезультат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьСоответствиеКолонокПодчиненныхОбъектов(ИДОбъекта, КолонкиАтрибутовПодчиненныхОбъектов)
	Результат = Новый Соответствие;
	Найдено = КолонкиАтрибутовПодчиненныхОбъектов.НайтиСтроки(Новый Структура("ИДОбъекта", ИДОбъекта));
	Для Каждого СтрокаКолонка ИЗ Найдено Цикл
		Результат.Вставить(СтрокаКолонка.АтрибутКласса, СтрокаКолонка);
	КонецЦикла;
	Возврат Результат;
КонецФункции

&НаСервере
Функция ПолучитьТаблицыАтрибутовТехкарт()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА НазначениеАтрибутов.Класс В (ЗНАЧЕНИЕ(Справочник.Классы.СтрокиТехОпераций), ЗНАЧЕНИЕ(Справочник.Классы.ВложенныеТехКарты))
		|			ТОГДА 0
		|		КОГДА НазначениеАтрибутов.Класс = ЗНАЧЕНИЕ(Справочник.Классы.ТехнологическиеКарты)
		|			ТОГДА 1
		|	КОНЕЦ КАК ИДОбъекта,
		|	НазначениеАтрибутов.АтрибутКласса,
		|	ВЫБОР
		|		КОГДА НазначениеАтрибутов.АтрибутКласса ССЫЛКА ПланВидовХарактеристик.АтрибутыКласса
		|			ТОГДА АтрибутыКласса.ТипЗначения
		|		КОГДА НазначениеАтрибутов.АтрибутКласса ССЫЛКА Справочник.ВложенныеАтрибутыКласса
		|				И ВложенныеАтрибутыКласса.АтрибутКласса ССЫЛКА ПланВидовХарактеристик.АтрибутыКласса
		|			ТОГДА ВЫРАЗИТЬ(ВложенныеАтрибутыКласса.АтрибутКласса КАК ПланВидовХарактеристик.АтрибутыКласса).ТипЗначения
		|	КОНЕЦ КАК ТипЗначения,
		|	НазначениеАтрибутов.МинЗначение,
		|	НазначениеАтрибутов.МаксЗначение,
		|	НазначениеАтрибутов.РежимЗаполнения,
		|	НазначениеАтрибутов.РежимИспользования,
		|	НазначениеАтрибутов.Формат,
		|	ВЫБОР
		|		КОГДА НазначениеАтрибутов.АтрибутКласса ССЫЛКА ПланВидовХарактеристик.АтрибутыКласса
		|			ТОГДА НазначениеАтрибутов.ИсточникЗначений
		|		КОГДА НазначениеАтрибутов.АтрибутКласса ССЫЛКА Справочник.ВложенныеАтрибутыКласса
		|			ТОГДА ВложенныеАтрибутыКласса.Источник
		|	КОНЕЦ КАК ИсточникЗначений,
		|	ВЫБОР
		|		КОГДА НазначениеАтрибутов.АтрибутКласса ССЫЛКА Справочник.ВложенныеАтрибутыКласса
		|				И ВложенныеАтрибутыКласса.АтрибутКласса ССЫЛКА Перечисление.РеквизитыКлассаНоменклатуры
		|			ТОГДА ВложенныеАтрибутыКласса.АтрибутКласса
		|	КОНЕЦ КАК ВложенныйРеквизит,
		|	НазначениеАтрибутов.СписокДоступныхЗначений,
		|	НазначениеАтрибутов.МножественноеЗначение,
		|	НазначениеАтрибутов.Порядок КАК Порядок,
		|	ВЫБОР
		|		КОГДА НазначениеАтрибутов.АтрибутКласса = ЗНАЧЕНИЕ(ПланВидовХарактеристик.АтрибутыКласса.ТипТехКарты)
		|			ТОГДА ""ТипТехКарты""
		|		КОГДА НазначениеАтрибутов.АтрибутКласса = ЗНАЧЕНИЕ(ПланВидовХарактеристик.АтрибутыКласса.ВидОперации)
		|			ТОГДА ""ВидОперации""
		|		КОГДА НазначениеАтрибутов.АтрибутКласса = ЗНАЧЕНИЕ(ПланВидовХарактеристик.АтрибутыКласса.ОбъектОперации)
		|			ТОГДА ""ОбъектОперации""
		|		КОГДА НазначениеАтрибутов.АтрибутКласса = ЗНАЧЕНИЕ(ПланВидовХарактеристик.АтрибутыКласса.ТехКарты)
		|			ТОГДА ""ТехКартаВложенная""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК ИмяКолонки,
		|	ВЫБОР
		|		КОГДА НазначениеАтрибутов.ИсточникЗначений ССЫЛКА Справочник.Классы
		|				И НЕ НазначениеАтрибутов.ИсточникЗначений = ЗНАЧЕНИЕ(Справочник.Классы.ПустаяСсылка)
		|			ТОГДА ВЫРАЗИТЬ(НазначениеАтрибутов.ИсточникЗначений КАК Справочник.Классы).КлассТабличнаяЧасть
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК КлассТабличнаяЧасть
		|ПОМЕСТИТЬ ВТ_ВсеАтрибуты
		|ИЗ
		|	РегистрСведений.НазначениеАтрибутов КАК НазначениеАтрибутов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.АтрибутыКласса КАК АтрибутыКласса
		|		ПО НазначениеАтрибутов.АтрибутКласса = АтрибутыКласса.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВложенныеАтрибутыКласса КАК ВложенныеАтрибутыКласса
		|		ПО НазначениеАтрибутов.АтрибутКласса = ВложенныеАтрибутыКласса.Ссылка
		|ГДЕ
		|	НазначениеАтрибутов.Класс В 
		|			(ЗНАЧЕНИЕ(Справочник.Классы.СтрокиТехОпераций), 
		|			 ЗНАЧЕНИЕ(Справочник.Классы.ВложенныеТехКарты), 
		|			 ЗНАЧЕНИЕ(Справочник.Классы.ТехнологическиеКарты))
		|		И НЕ (НазначениеАтрибутов.Класс, НазначениеАтрибутов.АтрибутКласса) В 
		|			(ВЫБРАТЬ ЗНАЧЕНИЕ(Справочник.Классы.ВложенныеТехКарты), ЗНАЧЕНИЕ(ПланВидовХарактеристик.АтрибутыКласса.ОбъектОперации))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсеАтрибуты.ИДОбъекта,
		|	ВТ_ВсеАтрибуты.АтрибутКласса,
		|	ВТ_ВсеАтрибуты.ТипЗначения,
		|	ВТ_ВсеАтрибуты.ВложенныйРеквизит,
		|	ВТ_ВсеАтрибуты.МинЗначение,
		|	ВТ_ВсеАтрибуты.МаксЗначение,
		|	ВТ_ВсеАтрибуты.РежимЗаполнения,
		|	ВТ_ВсеАтрибуты.РежимИспользования,
		|	ВТ_ВсеАтрибуты.Формат,
		|	ВТ_ВсеАтрибуты.ИсточникЗначений,
		|	ВТ_ВсеАтрибуты.СписокДоступныхЗначений,
		|	ВТ_ВсеАтрибуты.МножественноеЗначение,
		|	ВТ_ВсеАтрибуты.Порядок КАК Порядок,
		|	ВЫРАЗИТЬ(ВТ_ВсеАтрибуты.ИмяКолонки КАК СТРОКА(50)) КАК ИмяКолонки,
		|	ВТ_ВсеАтрибуты.КлассТабличнаяЧасть
		|ИЗ
		|	ВТ_ВсеАтрибуты КАК ВТ_ВсеАтрибуты
		|ГДЕ
		|	ВТ_ВсеАтрибуты.ИДОбъекта = 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	Порядок
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсеАтрибуты.ИДОбъекта,
		|	ВТ_ВсеАтрибуты.АтрибутКласса,
		|	ВТ_ВсеАтрибуты.ТипЗначения,
		|	ВТ_ВсеАтрибуты.ВложенныйРеквизит,
		|	ВТ_ВсеАтрибуты.МинЗначение,
		|	ВТ_ВсеАтрибуты.МаксЗначение,
		|	ВТ_ВсеАтрибуты.РежимЗаполнения,
		|	ВТ_ВсеАтрибуты.РежимИспользования,
		|	ВТ_ВсеАтрибуты.Формат,
		|	ВТ_ВсеАтрибуты.ИсточникЗначений,
		|	ВТ_ВсеАтрибуты.СписокДоступныхЗначений,
		|	ВТ_ВсеАтрибуты.МножественноеЗначение,
		|	ВТ_ВсеАтрибуты.Порядок КАК Порядок,
		|	ВЫРАЗИТЬ(ВТ_ВсеАтрибуты.ИмяКолонки КАК СТРОКА(50)) КАК ИмяКолонки,
		|	ВТ_ВсеАтрибуты.КлассТабличнаяЧасть
		|ИЗ
		|	ВТ_ВсеАтрибуты КАК ВТ_ВсеАтрибуты
		|ГДЕ
		|	ВТ_ВсеАтрибуты.ИДОбъекта = 1
		|
		|УПОРЯДОЧИТЬ ПО
		|	Порядок
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсеАтрибуты.АтрибутКласса,
		|	ВТ_ВсеАтрибуты.ИсточникЗначений,
		|	ВЫРАЗИТЬ(ВТ_ВсеАтрибуты.ИсточникЗначений КАК ПланВидовХарактеристик.АтрибутыКласса).ТипЗначения КАК ТипИсточникаЗначений,
		|	ВТ_ВсеАтрибуты.ВложенныйРеквизит
		|ИЗ
		|	ВТ_ВсеАтрибуты КАК ВТ_ВсеАтрибуты
		|ГДЕ
		|	НЕ ВТ_ВсеАтрибуты.ВложенныйРеквизит ЕСТЬ NULL";
	РезультатыЗапросов = Запрос.ВыполнитьПакет();
	
	Результат = Новый Массив;
	
	ТипыЗначенийРеквизитов = Новый Соответствие;
	
	ВыборкаВложенныхРеквизитов = РезультатыЗапросов[3].Выбрать();
	Пока ВыборкаВложенныхРеквизитов.Следующий() Цикл 
		ТипРеквизита = ТипыЗначенийРеквизитов[ВыборкаВложенныхРеквизитов.АтрибутКласса];
		Если ТипРеквизита = Неопределено Тогда
			МетаданныеСпр = Метаданные.НайтиПоТипу(ВыборкаВложенныхРеквизитов.ТипИсточникаЗначений.Типы()[0]);
			МетаданныеРеквизита = Перечисления.РеквизитыКлассаНоменклатуры.ПолучитьМетаданныеРеквизита(МетаданныеСпр, 
				ВыборкаВложенныхРеквизитов.ВложенныйРеквизит);
			ТипыЗначенийРеквизитов.Вставить(ВыборкаВложенныхРеквизитов.АтрибутКласса, МетаданныеРеквизита.Тип);
		КонецЕсли;
	КонецЦикла;
	
	ТипВложенныйАтрибут = Тип("СправочникСсылка.ВложенныеАтрибутыКласса");
	
	ТаблицаАтрибутов = РезультатыЗапросов[1].Выгрузить();
	ТаблицаАтрибутов.Колонки.Добавить("ТипЗначенияРеквизита", Новый ОписаниеТипов("Строка"));
	
	Для Каждого СтрокаТаблицы ИЗ ТаблицаАтрибутов Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ТипЗначения) И ТипЗнч(СтрокаТаблицы.АтрибутКласса) = ТипВложенныйАтрибут Тогда
			ТипРеквизита = ТипыЗначенийРеквизитов[СтрокаТаблицы.АтрибутКласса];
			Если НЕ ТипРеквизита = Неопределено Тогда
				СтрокаТаблицы.ТипЗначения = ТипРеквизита;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Результат.Добавить(Новый Структура("ИДОбъекта, ИмяТаблицы, ТаблицаАтрибутов", 
		0, "СоставТехКарты", ТаблицаАтрибутов));
	
	ТаблицаАтрибутов = РезультатыЗапросов[2].Выгрузить();
	ТаблицаАтрибутов.Колонки.Добавить("ТипЗначенияРеквизита", Новый ОписаниеТипов("Строка"));
	
	Для Каждого СтрокаТаблицы ИЗ ТаблицаАтрибутов Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ТипЗначения) И ТипЗнч(СтрокаТаблицы.АтрибутКласса) = ТипВложенныйАтрибут Тогда
			ТипРеквизита = ТипыЗначенийРеквизитов[СтрокаТаблицы.АтрибутКласса];
			Если НЕ ТипРеквизита = Неопределено Тогда
				СтрокаТаблицы.ТипЗначения = ТипРеквизита;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Результат.Добавить(Новый Структура("ИДОбъекта, ИмяТаблицы, ТаблицаАтрибутов", 
		1, "ТехКарты", ТаблицаАтрибутов));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УдалитьКолонкиАтрибутовПодчиненныхОбъектов(ИДОбъекта, ИмяТаблицы)
	
	Найдено = КолонкиАтрибутовПодчиненныхОбъектов.НайтиСтроки(Новый Структура("ИДОбъекта", ИДОбъекта));
	МассивУдаляемых = Новый Массив;
	Для Каждого СтрокаКолонка ИЗ Найдено Цикл
		Если НЕ ПустаяСтрока(СтрокаКолонка.ИмяКолонки) Тогда
			МассивУдаляемых.Добавить(ИмяТаблицы + "." + СтрокаКолонка.ИмяКолонки);
			Элементы.Удалить(Элементы[СтрокаКолонка.ИмяПоля]);
		КонецЕсли;
		КолонкиАтрибутовПодчиненныхОбъектов.Удалить(СтрокаКолонка);
	КонецЦикла;
	
	ИзменитьРеквизиты(, МассивУдаляемых);
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьКолонкиАтрибутовПодчиненныхОбъектов(ИДОбъекта, ИмяТаблицы, ТаблицаАтрибутов, Знач ИмяЭлемента="")
	
	КолонкиТаблицы = ТаблицаАтрибутов.Колонки;
	ЕстьСтатусНаследования  = НЕ (КолонкиТаблицы.Найти("СтатусНаследования") = Неопределено);
	ЕстьКлассТабличнаяЧасть = НЕ (КолонкиТаблицы.Найти("КлассТабличнаяЧасть") = Неопределено);
	
	Если ИмяЭлемента = "" Тогда
		ИмяЭлемента = ИмяТаблицы;
	КонецЕсли;
	
	ТипСтрока = Тип("Строка");
	
	Н = 1;
	МассивДобавляемых = Новый Массив;
	Для Каждого СтрокаКолонки ИЗ ТаблицаАтрибутов Цикл
		ЭтоНенаследуемый = ЕстьСтатусНаследования И СтрокаКолонки.СтатусНаследования > 3;
		Если НЕ ЗначениеЗаполнено(СтрокаКолонки.ТипЗначения) И ЗначениеЗаполнено(СтрокаКолонки.ТипЗначенияРеквизита) Тогда
			СтрокаКолонки.ТипЗначения = ЗначениеИзСтрокиВнутр(СтрокаКолонки.ТипЗначенияРеквизита);
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаКолонки.ТипЗначения) Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтоСтрока = СтрокаКолонки.ТипЗначения.СодержитТип(ТипСтрока);
		Если ЭтоНенаследуемый ИЛИ НЕ ЭтоСтрока И СтрокаКолонки.МножественноеЗначение Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаКолонки.ИмяКолонки) Тогда
			ИмяРеквизита = ИмяТаблицы + "Атрибут" + Н;
			НовыйРеквизит = Новый РеквизитФормы(
				ИмяРеквизита, СтрокаКолонки.ТипЗначения, ИмяТаблицы, Строка(СтрокаКолонки.АтрибутКласса));
			МассивДобавляемых.Добавить(НовыйРеквизит);
			СтрокаКолонки.ИмяКолонки = ИмяРеквизита;
		Иначе
			ИмяРеквизита = СтрокаКолонки.ИмяКолонки;
		КонецЕсли;
		
		СтрокаТЧ = КолонкиАтрибутовПодчиненныхОбъектов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаКолонки);
		СтрокаТЧ.ИмяПоля = ИмяЭлемента + ИмяРеквизита;
		СтрокаТЧ.ИДОбъекта = ИДОбъекта;
		СтрокаТЧ.ЭтоВложенныйАтрибут = (ТипЗнч(СтрокаТЧ.АтрибутКласса) = Тип("СправочникСсылка.ВложенныеАтрибутыКласса"));
		
		Н = Н + 1;
	КонецЦикла;
	
	ИзменитьРеквизиты(МассивДобавляемых);
	
	Для Каждого СтрокаКолонки ИЗ ТаблицаАтрибутов Цикл
		Если ПустаяСтрока(СтрокаКолонки.ИмяКолонки) Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяПоля = ИмяЭлемента + СтрокаКолонки.ИмяКолонки;
		
		Найдено = Элементы.Найти(ИмяПоля);
		Если Не Найдено = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НовыйЭлемент = Элементы.Добавить(ИмяПоля, Тип("ПолеФормы"), Элементы[ИмяЭлемента]);
		НовыйЭлемент.Вид         = ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным = ИмяТаблицы + "." + СтрокаКолонки.ИмяКолонки;
		НовыйЭлемент.Заголовок   = Строка(СтрокаКолонки.АтрибутКласса);
		НовыйЭлемент.Видимость   = Истина;
		НовыйЭлемент.Ширина      = 14;
		НовыйЭлемент.ТолькоПросмотр = (ТипЗнч(СтрокаКолонки.АтрибутКласса) = Тип("СправочникСсылка.ВложенныеАтрибутыКласса"));
		
		Если СтрокаКолонки.РежимЗаполнения = Перечисления.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры Тогда
			НовыйЭлемент.АвтоОтметкаНезаполненного = Истина;
		КонецЕсли;
		
		НовыйЭлемент.УстановитьДействие("НачалоВыбора", "АтрибутПодчиненногоНачалоВыбора");
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВложенныеТабличныеЧасти(ТаблицаАтрибутов, ТипОбъекта, СписокЗначений)
	
	Для Каждого СтрокаАтрибут ИЗ ТаблицаАтрибутов Цикл
		Если СтрокаАтрибут.КлассТабличнаяЧасть И СтрокаАтрибут.МножественноеЗначение Тогда
			СписочныйАтрибут = СписочныеАтрибуты.Добавить();
			СписочныйАтрибут.ИДАтрибута          = НайтиНовыйИД(СписочныеАтрибуты, "ИДАтрибута", 2);
			СписочныйАтрибут.АтрибутКласса       = СтрокаАтрибут.АтрибутКласса;
			СписочныйАтрибут.КлассТабличнаяЧасть = Истина;
			СписочныйАтрибут.ТипОбъекта          = ТипОбъекта;
			СписочныйАтрибут.ИсточникЗначений    = СтрокаАтрибут.ИсточникЗначений;
			
			СписокЗначений.Добавить(СписочныйАтрибут.ИДАтрибута, Строка(СписочныйАтрибут.АтрибутКласса));
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере 
Функция ТекстЗапросаТипыСтрок()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Классы.Ссылка КАК СтрокаОпераций,
		|	0 КАК ТипСтроки
		|ИЗ
		|	Справочник.Классы КАК Классы
		|ГДЕ
		|	Классы.Ссылка В(&ЗначенияСтрок)
		|	И Классы.Ссылка В ИЕРАРХИИ (ЗНАЧЕНИЕ(Справочник.Классы.СтрокиТехОпераций))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Классы.Ссылка,
		|	2
		|ИЗ
		|	Справочник.Классы КАК Классы
		|ГДЕ
		|	Классы.Ссылка В(&ЗначенияСтрок)
		|	И Классы.Ссылка В ИЕРАРХИИ (ЗНАЧЕНИЕ(Справочник.Классы.ВложенныеТехКарты))";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Процедура ВывестиСоставТехКартыНаСервере(ТехКарта)
	
	Если ТехКарта < 0 Тогда
		СоставТехКарты.ПолучитьЭлементы().Очистить();
		Возврат;
	КонецЕсли;
	
	ДеревоСоставТехКарты = РеквизитФормыВЗначение("СоставТехКарты");
	ДеревоСоставТехКарты.Строки.Очистить();
	
	Объект.СтрокиТабличныхАтрибутов.Сортировать("ИДСтрокиРодителя, АтрибутКласса, Порядок");
	СтруктураПоиска = Новый Структура("ИДСтрокиРодителя", ТехКарта);
	НайденоСтроки = Объект.СтрокиТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	
	ВложеннаяТехКарта = Справочники.Классы.ВложенныеТехКарты;
	
	СоответствиеСтрокТабличногоАтрибута = Новый Соответствие;
	СтруктураПоискаПоТипам = Новый Структура("СтрокаОпераций");
	
	Для Каждого СтрокаОперация ИЗ НайденоСтроки Цикл
		
		СтрокаСостава = ДеревоСоставТехКарты.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаСостава, СтрокаОперация);
		СоответствиеСтрокТабличногоАтрибута.Вставить(СтрокаОперация.ИДСтроки, СтрокаСостава);
		
		ЕстьЗначениеАтрибутаКласса = ЗначениеЗаполнено(СтрокаОперация.ЗначениеАтрибутаКласса);
		
		Если НЕ ЕстьЗначениеАтрибутаКласса 
				И СтрокаОперация.ИсточникЗначений = ВложеннаяТехКарта Тогда
			СтрокаСостава.ТипСтроки = 2;
			
		ИначеЕсли ЕстьЗначениеАтрибутаКласса Тогда
			СтруктураПоискаПоТипам.СтрокаОпераций = СтрокаОперация.ЗначениеАтрибутаКласса;
			НайденоТипы = ТипыСтрок.НайтиСтроки(СтруктураПоискаПоТипам);
			Если НайденоТипы.Количество() > 0 Тогда
				СтрокаСостава.ТипСтроки = НайденоТипы[0].ТипСтроки;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	// Заполнение таб.части.
	Объект.ЗначенияТабличныхАтрибутов.Сортировать("ИДСтрокиРодителя, АтрибутКласса, ИДСтроки");
	НайденоЗначения = Объект.ЗначенияТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	
	СоответствиеКолонок = ПолучитьСоответствиеКолонокПодчиненныхОбъектов(0, КолонкиАтрибутовПодчиненныхОбъектов);
	ТипОбъектНоменклатуры = Тип("СправочникСсылка.ОбъектыНоменклатуры");
	ТипНоменклатураКласса = Тип("СправочникСсылка.НоменклатураКласса");
	ТипКласс = Тип("СправочникСсылка.Классы");
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(ТипОбъектНоменклатуры);
	МассивТипов.Добавить(ТипНоменклатураКласса);
	МассивТипов.Добавить(ТипКласс);
	
	Для Каждого СтрокаЗначение ИЗ НайденоЗначения Цикл
		СтрокаТЧ = СоответствиеСтрокТабличногоАтрибута[СтрокаЗначение.ИДСтроки];
		Если СтрокаТЧ = Неопределено Тогда
			СтрокаТЧ = ДеревоСоставТехКарты.Строки.Добавить();
			СтрокаТЧ.ИДСтроки = СтрокаЗначение.ИДСтроки;
			СоответствиеСтрокТабличногоАтрибута.Вставить(СтрокаЗначение.ИДСтроки, СтрокаТЧ);
		КонецЕсли;
		
		СтрокаКолонка = СоответствиеКолонок[СтрокаЗначение.АтрибутТаблицы];
		Если НЕ СтрокаКолонка = Неопределено Тогда
			СоставнойТип = (СтрокаКолонка.ТипЗначения.СодержитТип(ТипНоменклатураКласса) 
				ИЛИ СтрокаКолонка.ТипЗначения.СодержитТип(ТипОбъектНоменклатуры));
			ЭтоЭлементСоставногоТипа = СоставнойТип 
				И НЕ (МассивТипов.Найти(ТипЗнч(СтрокаЗначение.ЗначениеАтрибутаТаблицы)) = Неопределено);
			СтрокаТЧ[СтрокаКолонка.ИмяКолонки] = ?(СоставнойТип И ЭтоЭлементСоставногоТипа,
				СтрокаЗначение.ЗначениеАтрибутаТаблицы,
				СтрокаКолонка.ТипЗначения.ПривестиЗначение(СтрокаЗначение.ЗначениеАтрибутаТаблицы));
		КонецЕсли;
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ДеревоСоставТехКарты, "СоставТехКарты");
	
	ОбновитьДанныеТекКласса();
	
КонецПроцедуры

&НаСервере
Процедура ВывестиТехкартыНаСервере()
	
	ВывестиТаблицуВложенногоАтрибута("ТехКарты", 0, ПланыВидовХарактеристик.АтрибутыКласса.ТехКарты, 1);
	
	// Заполним наиментвание типа тех.карты.
	СоответствиеКолонок = ПолучитьСоответствиеКолонокПодчиненныхОбъектов(1, КолонкиАтрибутовПодчиненныхОбъектов);
	АтрибутТипТХ = ПланыВидовХарактеристик.АтрибутыКласса.ТипТехКарты;
	СтрокаКолонка = СоответствиеКолонок[АтрибутТипТХ];
	Для Каждого СтрокаТЧ ИЗ ТехКарты Цикл
		СтрокаТЧ.НаименованиеТипа = Строка(СтрокаТЧ[СтрокаКолонка.ИмяКолонки]);
	КонецЦикла;
	
	// Операции, доступные для подбора.
	ВывесиДоступныеОперацииНаСервере();
	
	// Типы строк операций.
	ЗначенияСтрок = Объект.СтрокиТабличныхАтрибутов.Выгрузить(Новый Структура("АтрибутКласса", 
		ПланыВидовХарактеристик.АтрибутыКласса.ТехОперации), "ИсточникЗначений, ЗначениеАтрибутаКласса");
	Для Каждого СтрокаТЗ ИЗ ЗначенияСтрок Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЗ.ЗначениеАтрибутаКласса) Тогда
			СтрокаТЗ.ЗначениеАтрибутаКласса = СтрокаТЗ.ИсточникЗначений;
		КонецЕсли;
	КонецЦикла;
	ЗначенияСтрок = ЗначенияСтрок.ВыгрузитьКолонку("ЗначениеАтрибутаКласса");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗначенияСтрок", ЗначенияСтрок);
	Запрос.Текст = ТекстЗапросаТипыСтрок();
	ЗначениеВРеквизитФормы(Запрос.Выполнить().Выгрузить(), "ТипыСтрок");
	
	ТекТехКарта = -1;
	ТекОперация = -1;
	
	// Таб.части операций.
	ПодготовитьВложеннуюТаблицуТехкарт();
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьВложеннуюТаблицуТехкарт()
	
	Если ТекТаблицаТехКарты = ПланыВидовХарактеристик.АтрибутыКласса.ТехОперации Тогда
		ТипОбъекта = 1;
		ТекТаблицаНаВывод    = "ТекТаблицаОперации";
		ПереключательТаблицы = "ПереключательТабличныхАтрибутовОпераций";
		ИмяЭлементаТаблицы   = "ЗначениеТабличногоАтрибутаОперации";
	Иначе
		ТипОбъекта = 2;
		ТекТаблицаНаВывод    = "ТекТаблицаТехКарты";
		ПереключательТаблицы = "ПереключательТабличныхАтрибутовТехКарт";
		ИмяЭлементаТаблицы   = "ЗначениеТабличногоАтрибутаТехКарты";
	КонецЕсли;
	
	НайденоТабЧасти = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта", ТипОбъекта));
	Если НайденоТабЧасти.Количество() > 0 Тогда
		ИсточникЗначений = Неопределено;
		// Поиск таблицы на вывод.
		Если ЗначениеЗаполнено(ЭтаФорма[ТекТаблицаНаВывод]) Тогда
			Для Каждого СтрокаАтрибут ИЗ НайденоТабЧасти Цикл
				Если СтрокаАтрибут.АтрибутКласса = ЭтаФорма[ТекТаблицаНаВывод] Тогда
					ИсточникЗначений = СтрокаАтрибут.ИсточникЗначений;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		// Если таблица на вывод не найдена, выберем первую вложенную таблицу.
		Если ИсточникЗначений = Неопределено Тогда
			ЭтаФорма[ТекТаблицаНаВывод]    = НайденоТабЧасти[0].АтрибутКласса;
			ИсточникЗначений               = НайденоТабЧасти[0].ИсточникЗначений;
			ЭтаФорма[ПереключательТаблицы] = НайденоТабЧасти[0].ИДАтрибута;
		КонецЕсли;
		
		ПодготовитьТаблицуВложенногоАтрибута(ИсточникЗначений, ИмяЭлементаТаблицы);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьТаблицуВложенногоАтрибута(ИсточникЗначений, ИмяЭлемента)
	
	ТекСписокРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(ИсточникЗначений);
	ТаблицаАтрибутов   = Справочники.Классы.ПолучитьТаблицуАтрибутов(ТекСписокРодителей);
	ТаблицаАтрибутов.Колонки.Добавить("ИмяКолонки", Новый ОписаниеТипов("Строка"));
	
	УдалитьКолонкиАтрибутовПодчиненныхОбъектов(2, "ЗначениеТабличногоАтрибута");
	ПодготовитьКолонкиАтрибутовПодчиненныхОбъектов(2, "ЗначениеТабличногоАтрибута", ТаблицаАтрибутов, ИмяЭлемента);
	
КонецПроцедуры

&НаСервере
Процедура ВывестиТаблицуВложенногоАтрибута(Знач ТаблицаФормы, ИДСтрокиРодителя, АтрибутКласса, ИДОбъекта)
	
	ТаблицаФормы = ЭтаФорма[ТаблицаФормы];
	
	СтруктураПоиска = Новый Структура("ИДСтрокиРодителя, АтрибутКласса", ИДСтрокиРодителя, АтрибутКласса);
	ТаблицаСтрок = Объект.СтрокиТабличныхАтрибутов.Выгрузить(СтруктураПоиска);
	ТаблицаСтрок.Сортировать("Порядок");
	ТаблицаФормы.Загрузить(ТаблицаСтрок);
	
	СоответствиеСтрокТабличногоАтрибута = Новый Соответствие;
	Для Каждого СтрокаТЗ ИЗ ТаблицаФормы Цикл
		СоответствиеСтрокТабличногоАтрибута.Вставить(СтрокаТЗ.ИДСтроки, СтрокаТЗ);
	КонецЦикла;
	
	// Заполнение колонок таб.части.
	Объект.ЗначенияТабличныхАтрибутов.Сортировать("ИДСтрокиРодителя, АтрибутКласса, ИДСтроки");
	НайденоЗначения = Объект.ЗначенияТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	
	СоответствиеКолонок = ПолучитьСоответствиеКолонокПодчиненныхОбъектов(ИДОбъекта, КолонкиАтрибутовПодчиненныхОбъектов);
	
	Для Каждого СтрокаЗначение ИЗ НайденоЗначения Цикл
		СтрокаТЧ = СоответствиеСтрокТабличногоАтрибута[СтрокаЗначение.ИДСтроки];
		Если СтрокаТЧ = Неопределено Тогда
			СтрокаТЧ = ТаблицаФормы.Добавить();
			СтрокаТЧ.ИДСтроки = СтрокаЗначение.ИДСтроки;
			СоответствиеСтрокТабличногоАтрибута.Вставить(СтрокаЗначение.ИДСтроки, СтрокаТЧ);
		КонецЕсли;
		
		СтрокаКолонка = СоответствиеКолонок[СтрокаЗначение.АтрибутТаблицы];
		Если НЕ СтрокаКолонка = Неопределено Тогда
			СтрокаТЧ[СтрокаКолонка.ИмяКолонки] = 
				СтрокаКолонка.ТипЗначения.ПривестиЗначение(СтрокаЗначение.ЗначениеАтрибутаТаблицы);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПоместитьТаблицуУзловойСтруктурыВоВременноеХранилище()
	
	ДеревоВыбора = РеквизитФормыВЗначение("ДоступныеОперации");
	ДеревоВыбора.Строки.Очистить();
	
	// Узловая структура.
	СтруктураПоиска = Новый Структура("АтрибутКласса, ИспользуемоеЗначение",
		ПланыВидовХарактеристик.АтрибутыКласса.УзловаяСтруктура, Истина);
	МассивУзлов = Объект.ЗначенияСписочныхАтрибутов.Выгрузить(
		СтруктураПоиска, "ЗначениеАтрибутаКласса").ВыгрузитьКолонку("ЗначениеАтрибутаКласса");
	ВывестиУзлыОперации(МассивУзлов, ДеревоВыбора.Строки, , Ложь);
	
	ДеревоВыбора.Колонки.Добавить("ДоступенВыбор", Новый ОписаниеТипов("Булево"));
	Для Каждого СтрокаДерева ИЗ ДеревоВыбора.Строки Цикл 
		СтрокаДерева.ДоступенВыбор = Истина;
		Если СтрокаДерева.Строки.Количество() > 0 Тогда
			Для Каждого ПодстрокаДерева ИЗ СтрокаДерева.Строки Цикл
				ПодстрокаДерева.ДоступенВыбор = Истина;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	// Тек.класс.
	СтрокаДерева = ДеревоВыбора.Строки.Вставить(0);
	СтрокаДерева.КартинкаСтрок = 1;
	СтрокаДерева.Объект = Объект.Класс.Ссылка;
	СтрокаДерева.ДоступенВыбор = Истина;
	Если НЕ ЗначениеЗаполнено(СтрокаДерева.Объект) Тогда
		СтрокаДерева.ПредставлениеЗначения = ?(ПустаяСтрока(Объект.Наименование), НСтр("ru='(Этот класс)'"), Объект.Наименование);
	КонецЕсли;
	
	Адрес = ПоместитьВоВременноеХранилище(ДеревоВыбора, УникальныйИдентификатор);
	Возврат Адрес;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПорядокСтрокТабличныхАтрибутов(ТаблицаФормы, ИДСтрокиРодителя, АтрибутКласса)
	
	// Настройка порядка строк.
	СоответствиеСтрок = Новый Соответствие;
	Для Каждого СтрокаТЧ ИЗ ТаблицаФормы Цикл
		СоответствиеСтрок.Вставить(СтрокаТЧ.ИДСтроки, ТаблицаФормы.Индекс(СтрокаТЧ));
	КонецЦикла;
	
	НайденоПорядок = Объект.СтрокиТабличныхАтрибутов.НайтиСтроки(
		Новый Структура("ИДСтрокиРодителя, АтрибутКласса", ИДСтрокиРодителя, АтрибутКласса));
	Для Каждого СтрокаПорядок ИЗ НайденоПорядок Цикл
		СтрокаПорядок.Порядок = СоответствиеСтрок[СтрокаПорядок.ИДСтроки];
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВложенныеСтрокиТабличногоАтрибута(ИДСтроки)
	
	СтруктураПоиска = Новый Структура("ИДСтрокиРодителя", ИДСтроки);
	
	Найдено = Объект.СтрокиТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	Для Каждого СтрокаНайдено ИЗ Найдено Цикл
		УдалитьВложенныеСтрокиТабличногоАтрибута(СтрокаНайдено.ИДСтроки);
		Объект.СтрокиТабличныхАтрибутов.Удалить(СтрокаНайдено);
	КонецЦикла;
	
	Найдено = Объект.ЗначенияТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	Для Каждого СтрокаНайдено ИЗ Найдено Цикл
		Объект.ЗначенияТабличныхАтрибутов.Удалить(СтрокаНайдено);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВыбранныеСтрокиТабличногоАтрибута(ТаблицаФормы, Выбраны, ИДСтрокиРодителя, АтрибутКласса)
	
	СтруктураПоиска = Новый Структура("ИДСтрокиРодителя, АтрибутКласса, ИДСтроки", ИДСтрокиРодителя, АтрибутКласса);
	
	Для Каждого ИДСтроки ИЗ Выбраны Цикл
		СтрокаКУдалению = ТаблицаФормы.НайтиПоИдентификатору(ИДСтроки);
		СтруктураПоиска.ИДСтроки = СтрокаКУдалению.ИДСтроки;
		
		Найдено = Объект.СтрокиТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
		Если Найдено.Количество() > 0 Тогда
			Объект.СтрокиТабличныхАтрибутов.Удалить(Найдено[0]);
		КонецЕсли;
		
		Найдено = Объект.ЗначенияТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
		Для Каждого СтрокаЗначение ИЗ Найдено Цикл
			Объект.ЗначенияТабличныхАтрибутов.Удалить(СтрокаЗначение);
		КонецЦикла;
		
		УдалитьВложенныеСтрокиТабличногоАтрибута(СтруктураПоиска.ИДСтроки);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоместитьЗначенияАтрибутовСтрокВДанныеОбработки(ТекДанные, ОтменаРедактирования, ИДСтрокиРодителя, АтрибутКласса, ИДОбъекта)
	
	СтруктураПоиска = Новый Структура("ИДСтрокиРодителя, АтрибутКласса, ИДСтроки", 
		ИДСтрокиРодителя, АтрибутКласса, ТекДанные.ИДСтроки);
	
	НайденоЗначения = Объект.ЗначенияТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	НайденоКолонки  = КолонкиАтрибутовПодчиненныхОбъектов.НайтиСтроки(Новый Структура("ИДОбъекта", ИДОбъекта));
	
	АтрибутКлассаВложеннаяКарта = ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ТехКарты");
	ТипКласс = Новый ОписаниеТипов("СправочникСсылка.Классы");

	// Чтение вложенных атрибутов.
	НайденоВложенныеАтрибуты = КолонкиАтрибутовПодчиненныхОбъектов.НайтиСтроки(Новый Структура("ИДОбъекта, ЭтоВложенныйАтрибут", ИДОбъекта, Истина));
	Если НайденоВложенныеАтрибуты.Количество() > 0 Тогда
		СоответствиеОбъектов        = Новый Соответствие;
		МассивВложенныхАтрибутов    = Новый Массив;
		МассивКлассовДляЧтения      = Новый Массив;
		МассивНоменклатурыДляЧтения = Новый Массив;
		
		Для Каждого СтрокаВложенныйАтрибут ИЗ НайденоВложенныеАтрибуты Цикл
			МассивВложенныхАтрибутов.Добавить(СтрокаВложенныйАтрибут.АтрибутКласса);
			Для Каждого КолонкаИсточник ИЗ НайденоКолонки Цикл
				Если КолонкаИсточник.АтрибутКласса = СтрокаВложенныйАтрибут.ИсточникЗначений Тогда
					ОбъектИсточник = ТекДанные[КолонкаИсточник.ИмяКолонки];
					Если ЗначениеЗаполнено(ОбъектИсточник) И СоответствиеОбъектов[СтрокаВложенныйАтрибут.ИсточникЗначений] = Неопределено Тогда
						СоответствиеОбъектов.Вставить(СтрокаВложенныйАтрибут.ИсточникЗначений, ОбъектИсточник);
						Если ТипЗнч(ОбъектИсточник) = Тип("СправочникСсылка.Классы") Тогда
							МассивКлассовДляЧтения.Добавить(ОбъектИсточник);
						ИначеЕсли ТипЗнч(ОбъектИсточник) = Тип("СправочникСсылка.НоменклатураКласса") Тогда
							МассивНоменклатурыДляЧтения.Добавить(ОбъектИсточник);
						КонецЕсли;
					КонецЕсли;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		ЗначенияВложенныхАтрибутов = ПрочитатьЗначенияВложенныхАтрибутов(СоответствиеОбъектов,
			МассивКлассовДляЧтения, МассивНоменклатурыДляЧтения, МассивВложенныхАтрибутов);
	КонецЕсли;
	
	Для Каждого СтрокаКолонка ИЗ НайденоКолонки Цикл
		Заполнено = Ложь;
		Если СтрокаКолонка.ЭтоВложенныйАтрибут Тогда
			Если НЕ ЗначенияВложенныхАтрибутов = Неопределено Тогда
				ЗначениеВложенногоАтрибута = ЗначенияВложенныхАтрибутов[СтрокаКолонка.АтрибутКласса];
			Иначе
				ЗначениеВложенногоАтрибута = Неопределено;
			КонецЕсли;
			
			ТекДанные[СтрокаКолонка.ИмяКолонки] = ЗначениеВложенногоАтрибута;
			
			Для Каждого СтрокаЗначение ИЗ НайденоЗначения Цикл
				Если СтрокаКолонка.АтрибутКласса = СтрокаЗначение.АтрибутТаблицы Тогда
					СтрокаЗначение.ЗначениеАтрибутаТаблицы = ЗначениеВложенногоАтрибута;
					Заполнено = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если НЕ Заполнено И ЗначениеЗаполнено(ЗначениеВложенногоАтрибута) Тогда
				СтрокаЗначение = Объект.ЗначенияТабличныхАтрибутов.Добавить();
				СтрокаЗначение.ИДСтрокиРодителя        = ИДСтрокиРодителя;
				СтрокаЗначение.АтрибутКласса           = АтрибутКласса;
				СтрокаЗначение.АтрибутТаблицы          = СтрокаКолонка.АтрибутКласса;
				СтрокаЗначение.ИДСтроки                = ТекДанные.ИДСтроки;
				СтрокаЗначение.ЗначениеАтрибутаТаблицы = ЗначениеВложенногоАтрибута;
			КонецЕсли;
			
		Иначе
			Для Каждого СтрокаЗначение ИЗ НайденоЗначения Цикл
				Если СтрокаКолонка.АтрибутКласса = СтрокаЗначение.АтрибутТаблицы Тогда
					Если ОтменаРедактирования Тогда
						// Восстановление предыдущих значений.
						Если СтрокаКолонка.АтрибутКласса = АтрибутКлассаВложеннаяКарта Тогда
							ТекДанные[СтрокаКолонка.ИмяКолонки] = ТипКласс.ПривестиЗначение(СтрокаЗначение.ЗначениеАтрибутаТаблицы);
						Иначе
							ТекДанные[СтрокаКолонка.ИмяКолонки] = 
								СтрокаКолонка.ТипЗначения.ПривестиЗначение(СтрокаЗначение.ЗначениеАтрибутаТаблицы);
						КонецЕсли;
					Иначе
						// Сохранение новых значений.
						СтрокаЗначение.ЗначениеАтрибутаТаблицы = ТекДанные[СтрокаКолонка.ИмяКолонки];
					КонецЕсли;
					Заполнено = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если НЕ Заполнено Тогда
				Если ОтменаРедактирования Тогда
					// Восстановление предыдущих значений.
					ТекДанные[СтрокаКолонка.ИмяКолонки] = СтрокаКолонка.ТипЗначения.ПривестиЗначение();
				Иначе
					// Сохранение новых значений.
					СтрокаЗначение = Объект.ЗначенияТабличныхАтрибутов.Добавить();
					СтрокаЗначение.ИДСтрокиРодителя        = ИДСтрокиРодителя;
					СтрокаЗначение.АтрибутКласса           = АтрибутКласса;
					СтрокаЗначение.АтрибутТаблицы          = СтрокаКолонка.АтрибутКласса;
					СтрокаЗначение.ИДСтроки                = ТекДанные.ИДСтроки;
					СтрокаЗначение.ЗначениеАтрибутаТаблицы = ТекДанные[СтрокаКолонка.ИмяКолонки];
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПрочитатьЗначенияВложенныхАтрибутов(СоответствиеОбъектов, 
		МассивКлассовДляЧтения, МассивНоменклатурыДляЧтения, МассивВложенныхАтрибутов)
	
	Возврат Справочники.ВложенныеАтрибутыКласса.ПрочитатьЗначенияВложенныхАтрибутов(СоответствиеОбъектов, 
		МассивКлассовДляЧтения, МассивНоменклатурыДляЧтения, МассивВложенныхАтрибутов);
	
КонецФункции

&НаКлиенте
Процедура РазвернутьСвернутьДеревоФормы(ЭлементДерево, ДеревоФормы, РежимРазвернуть=Истина)
	
	ЭлементыДерева = ДеревоФормы.ПолучитьЭлементы();
	Для Каждого СтрокаДерева ИЗ ЭлементыДерева Цикл
		Если РежимРазвернуть Тогда
			ЭлементДерево.Развернуть(СтрокаДерева.ПолучитьИдентификатор(), Истина);
		Иначе
			ЭлементДерево.Свернуть(СтрокаДерева.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтрокуУзла(СтрокиДерева, СоответствиеСтрокУзлов, ТекКласс)
	
	УзелРодитель = СоответствиеСтрокУзлов[ТекКласс];
	Если УзелРодитель = Неопределено Тогда
		СтрокаТекКласс = СтрокиДерева.Добавить();
		СтрокаТекКласс.КартинкаСтрок = 1;
		СтрокаТекКласс.ТипСтроки     = 1;
		СтрокаТекКласс.Объект = ТекКласс;
		
		СоответствиеСтрокУзлов.Вставить(ТекКласс, СтрокаТекКласс);
	ИначеЕсли ТипЗнч(УзелРодитель) = Тип("СправочникСсылка.Классы") Тогда
		СтрокаУзла = ПолучитьСтрокуУзла(СтрокиДерева, СоответствиеСтрокУзлов, УзелРодитель);
		СтрокиВложенные = СтрокаУзла.Строки;
		
		СтрокаТекКласс = СтрокиВложенные.Добавить();
		СтрокаТекКласс.КартинкаСтрок = 1;
		СтрокаТекКласс.ТипСтроки     = 1;
		СтрокаТекКласс.Объект = ТекКласс;
		
		СоответствиеСтрокУзлов.Вставить(ТекКласс, СтрокаТекКласс);
	Иначе
		СтрокаТекКласс = УзелРодитель;
	КонецЕсли;
	
	
	Возврат СтрокаТекКласс;
	
КонецФункции

&НаСервере
Процедура ВывестиУзлыОперации(МассивУзлов, СтрокиДерева, СоответствиеСтрокУзлов=Неопределено, ВыводитьВидыОпераций=Истина)
	
	Если СоответствиеСтрокУзлов = Неопределено Тогда
		СоответствиеСтрокУзлов = Новый Соответствие;
	КонецЕсли;
	
	ТаблицаРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(МассивУзлов);
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	// Получаем значения атрибутов узлов (доступные виды операций, узловая структура).
	АтрибутДоступныеОперации = ПланыВидовХарактеристик.АтрибутыКласса.ДоступныеВидыОпераций;
	АтрибутУзловаяСтруктура = ПланыВидовХарактеристик.АтрибутыКласса.УзловаяСтруктура;
	
	АтрибутыКласса = Новый Массив;
	АтрибутыКласса.Добавить(АтрибутУзловаяСтруктура);
	АтрибутыКласса.Добавить(АтрибутДоступныеОперации);
	
	ТаблицаАтрибутов = Справочники.Классы.ПолучитьЗначенияСписочныхАтрибутов(ТаблицаРодителей, АтрибутыКласса);
	
	МассивУзловВложенных = Новый Массив;
	ТекКласс = Неопределено;
	
	Для Каждого СтрокаТаблицы ИЗ ТаблицаАтрибутов Цикл
		Если СтрокаТаблицы.АтрибутКласса = АтрибутДоступныеОперации Тогда
			Если НЕ ТекКласс = СтрокаТаблицы.КлассДляЧтения Тогда
				СтрокаУзла = ПолучитьСтрокуУзла(СтрокиДерева, СоответствиеСтрокУзлов, СтрокаТаблицы.КлассДляЧтения);
				СтрокиОпераций = СтрокаУзла.Строки;
				ТекКласс = СтрокаТаблицы.КлассДляЧтения;
			КонецЕсли;
			
			Если ВыводитьВидыОпераций Тогда
				СтрокаОперации = СтрокиОпераций.Добавить();
				СтрокаОперации.КартинкаСтрок = 3;
				СтрокаОперации.ТипСтроки     = 2;
				СтрокаОперации.Объект = СтрокаТаблицы.ЗначениеАтрибутаКласса;
			КонецЕсли;
			
		ИначеЕсли СтрокаТаблицы.АтрибутКласса = АтрибутУзловаяСтруктура Тогда
			ТекКлассДляЧтения = СоответствиеСтрокУзлов[СтрокаТаблицы.ЗначениеАтрибутаКласса];
			Если ТекКлассДляЧтения = Неопределено И НЕ СтрокаТаблицы.ЗначениеАтрибутаКласса = СтрокаТаблицы.КлассДляЧтения Тогда
				МассивУзловВложенных.Добавить(СтрокаТаблицы.ЗначениеАтрибутаКласса);
				СоответствиеСтрокУзлов.Вставить(СтрокаТаблицы.ЗначениеАтрибутаКласса, СтрокаТаблицы.КлассДляЧтения);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	// Получаем тех.карты по узлам.
	
	ТабличныеАтрибуты = Новый Массив();
	ТабличныеАтрибуты.Добавить(ПланыВидовХарактеристик.АтрибутыКласса.ТехКарты);
	
	ТаблицаТехКарт = Справочники.Классы.ПолучитьСтрокиТабличныхАтрибутов(ТаблицаРодителей, ТабличныеАтрибуты);
		
	ТекКласс = Неопределено;
	Для Каждого СтрокаТК ИЗ ТаблицаТехКарт Цикл
		Если НЕ ТекКласс = СтрокаТК.КлассДляЧтения Тогда
			СтрокаУзла = ПолучитьСтрокуУзла(СтрокиДерева, СоответствиеСтрокУзлов, СтрокаТК.КлассДляЧтения);
			СтрокиВложенные = СтрокаУзла.Строки;
			ТекКласс = СтрокаТК.КлассДляЧтения;
		КонецЕсли;
		
		Если ВыводитьВидыОпераций Тогда
			СтрокаВложеннойТехкарты = СтрокиВложенные.Добавить();
			СтрокаВложеннойТехкарты.КартинкаСтрок = 2;
			СтрокаВложеннойТехкарты.ТипСтроки     = 3;
			СтрокаВложеннойТехкарты.Объект = ?(ЗначениеЗаполнено(СтрокаТК.ЗначениеАтрибутаКласса), 
				СтрокаТК.ЗначениеАтрибутаКласса, СтрокаТК.ИсточникЗначений);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивУзловВложенных.Количество() > 0 Тогда
		ВывестиУзлыОперации(МассивУзловВложенных, СтрокиДерева, СоответствиеСтрокУзлов, ВыводитьВидыОпераций);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВывесиДоступныеОперацииНаСервере()
	
	ДеревоОпераций = РеквизитФормыВЗначение("ДоступныеОперации");
	ДеревоОпераций.Строки.Очистить();
	
	// Узловая структура.
	СтруктураПоиска = Новый Структура("АтрибутКласса, ИспользуемоеЗначение",
		ПланыВидовХарактеристик.АтрибутыКласса.УзловаяСтруктура, Истина);
	МассивУзлов = Объект.ЗначенияСписочныхАтрибутов.Выгрузить(
		СтруктураПоиска, "ЗначениеАтрибутаКласса").ВыгрузитьКолонку("ЗначениеАтрибутаКласса");
	ВывестиУзлыОперации(МассивУзлов, ДеревоОпераций.Строки);
	
	ЗначениеВРеквизитФормы(ДеревоОпераций, "ДоступныеОперации");
	
	ОбновитьДанныеТекКласса();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеТекКласса()
	
	ЭлементыОпераций = ДоступныеОперации.ПолучитьЭлементы();
	Если ЭлементыОпераций.Количество() > 0 И ЭлементыОпераций[0].Объект = Объект.Класс.Ссылка Тогда
		СтрокаТекКласс = ЭлементыОпераций[0];
		СтрокаТекКласс.ПолучитьЭлементы().Очистить();
	КонецЕсли;
	
	СтруктураПоиска = Новый Структура("АтрибутКласса, ИспользуемоеЗначение",
		ПланыВидовХарактеристик.АтрибутыКласса.ДоступныеВидыОпераций, Истина);
	СписокОпераций = Объект.ЗначенияСписочныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	Если СписокОпераций.Количество() > 0 Тогда
		
		Если СтрокаТекКласс = Неопределено Тогда
			СтрокаТекКласс = ЭлементыОпераций.Вставить(0);
			СтрокаТекКласс.КартинкаСтрок = 1;
			СтрокаТекКласс.ТипСтроки     = 0;
			СтрокаТекКласс.Объект = Объект.Класс.Ссылка;
			Если НЕ ЗначениеЗаполнено(СтрокаТекКласс.Объект) Тогда
				СтрокаТекКласс.ПредставлениеЗначения = 
					?(ПустаяСтрока(Объект.Наименование), НСтр("ru='(Этот класс)'"), Объект.Наименование);
			КонецЕсли;
		КонецЕсли;
		
		СтрокиОпераций = СтрокаТекКласс.ПолучитьЭлементы();
		Для Каждого СтрокаНайдено ИЗ СписокОпераций Цикл
			Если СтрокаНайдено.СтатусНаследования <= 3 Тогда
				СтрокаОперации = СтрокиОпераций.Добавить();
				СтрокаОперации.КартинкаСтрок = 3;
				СтрокаОперации.ТипСтроки     = 2;
				СтрокаОперации.Объект = СтрокаНайдено.ЗначениеАтрибутаКласса;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	// 2. Тех.карты тек.класса.
	СтруктураПоиска = Новый Структура("АтрибутКласса", ПланыВидовХарактеристик.АтрибутыКласса.ТехКарты);
	СписокТК = Объект.СтрокиТабличныхАтрибутов.НайтиСтроки(СтруктураПоиска);
	Если СписокТК.Количество() > 1 И ТекТехКарта >= 0 Тогда
		
		Если СтрокаТекКласс = Неопределено Тогда
			СтрокаТекКласс = ЭлементыОпераций.Вставить(0);
			СтрокаТекКласс.КартинкаСтрок = 1;
			СтрокаТекКласс.ТипСтроки     = 0;
			СтрокаТекКласс.Объект = Объект.Класс.Ссылка;
			Если НЕ ЗначениеЗаполнено(СтрокаТекКласс.Объект) Тогда
				СтрокаТекКласс.ПредставлениеЗначения = 
					?(ПустаяСтрока(Объект.Наименование), НСтр("ru='(Этот класс)'"), Объект.Наименование);
			КонецЕсли;
		КонецЕсли;
		
		СтрокиОпераций = СтрокаТекКласс.ПолучитьЭлементы();
		Для Каждого СтрокаТК ИЗ СписокТК Цикл
			Если НЕ СтрокаТК.ИДСтроки = ТекТехКарта Тогда
				СтрокаТехКарты = СтрокиОпераций.Добавить();
				СтрокаТехКарты.КартинкаСтрок = 2;
				СтрокаТехКарты.ТипСтроки     = 3;
				СтрокаТехКарты.Объект = ?(ЗначениеЗаполнено(СтрокаТК.ЗначениеАтрибутаКласса), 
					СтрокаТК.ЗначениеАтрибутаКласса, СтрокаТК.ИсточникЗначений);
				Если НЕ ЗначениеЗаполнено(СтрокаТК.ЗначениеАтрибутаКласса) Тогда
					СтрокаТехКарты.ПредставлениеЗначения = СтрокаТК.Наименование;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиЗначенияТабличногоАтрибутаНаСервере(АтрибутКласса)
	
	// Подготовка колонок.
	СтруктураПоиска = Новый Структура("АтрибутКласса", АтрибутКласса);
	Найдено = Объект.Атрибуты.НайтиСтроки(СтруктураПоиска);
	Если Найдено.Количество() > 0 Тогда
		ИсточникЗначений = Найдено[0].ИсточникЗначений;
	КонецЕсли;
	
	ТекСписокРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(ИсточникЗначений);
	ТаблицаАтрибутов   = Справочники.Классы.ПолучитьТаблицуАтрибутов(ТекСписокРодителей);
	ТаблицаАтрибутов.Колонки.Добавить("ИмяКолонки", Новый ОписаниеТипов("Строка"));
	
	УдалитьКолонкиАтрибутовПодчиненныхОбъектов(2, "ЗначениеТабличногоАтрибута");
	ПодготовитьКолонкиАтрибутовПодчиненныхОбъектов(2, "ЗначениеТабличногоАтрибута", ТаблицаАтрибутов);
	
	// Заполнение строк таб.части.
	ВывестиТаблицуВложенногоАтрибута("ЗначениеТабличногоАтрибута", 0, АтрибутКласса, 2);
	
КонецПроцедуры

&НаСервере
Процедура ВывестиЗначенияСписочногоАтрибутаНаСервере(АтрибутКласса)
	
	Найдено = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", АтрибутКласса));
	Если Найдено.Количество() > 0 Тогда
		ИсточникЗначений = Найдено[0].ИсточникЗначений;
		ТипЗначения = Найдено[0].ТипЗначения;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("ЗначенияСписочныхАтрибутовКласса", Объект.ЗначенияСписочныхАтрибутов.Выгрузить());
	Запрос.УстановитьПараметр("АтрибутКласса",    АтрибутКласса);
	Запрос.УстановитьПараметр("ИсточникЗначений", ИсточникЗначений);
	Запрос.УстановитьПараметр("ИсточникКласс", Редактирование
		И ЗначениеЗаполнено(ИсточникЗначений) И ТипЗнч(ИсточникЗначений) = Тип("СправочникСсылка.Классы"));
	Запрос.УстановитьПараметр("ИсточникНоменклатура", Редактирование
		И ЗначениеЗаполнено(ИсточникЗначений) И ТипЗнч(ИсточникЗначений) = Тип("СправочникСсылка.НоменклатураКласса"));
	Запрос.УстановитьПараметр("ТипАтрибутаНоменклатура", 
		ТипЗначения.СодержитТип(Тип("СправочникСсылка.НоменклатураКласса")));
	Запрос.УстановитьПараметр("ТипАтрибутаОбъектНоменклатуры", 
		ТипЗначения.СодержитТип(Тип("СправочникСсылка.ОбъектыНоменклатуры")));
		
	Запрос.Текст = ТекстЗапросаЗначенияСписочныхАтрибутовВременныеТаблицы();
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаЗначенияСписочныхАтрибутовСИерархией();
	РезультатыЗапросов = Запрос.ВыполнитьПакет();
	
	// Классы.
	ДеревоЗначений = РезультатыЗапросов[0].Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	ДеревоЗначений = ОбработатьДеревоСписочныхЗначенийАтрибутов(ДеревоЗначений, ИсточникЗначений);
	ЗначениеВРеквизитФормы(ДеревоЗначений, "ЗначенияСписочногоАтрибута");
	
	// Номенклатура классов.
	ДеревоЗначений = РезультатыЗапросов[1].Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	ЗначениеВРеквизитФормы(ДеревоЗначений, "ЗначенияСписочногоАтрибутаНоменклатура");
	
	// Объекты номенклатуры.
	ДеревоЗначений = РезультатыЗапросов[2].Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	ЗначениеВРеквизитФормы(ДеревоЗначений, "ЗначенияСписочногоАтрибутаОбъектыНоменклатуры");
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьВидимостьЭлементовЗначенийСписочногоАтрибута()
			
	// Настройка элементов формы.
	НайденоАтрибуты = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", ТекСписочныйАтрибут));
	
	ТекИсточникЗначений = НайденоАтрибуты[0].ИсточникЗначений;
	Элементы.ТекИсточникЗначений.Видимость = НайденоАтрибуты[0].НуженИсточникЗначений;
	Если Элементы.ТекИсточникЗначений.Видимость Тогда
		
		ТипОбъектНоменклатуры = Тип("СправочникСсылка.ОбъектыНоменклатуры");
		ЕстьОбъектНоменклатуры = НайденоАтрибуты[0].ТипЗначения.СодержитТип(ТипОбъектНоменклатуры);
		Элементы.ТекИсточникЗначений.ВыбиратьТип = ЕстьОбъектНоменклатуры;
		ТолькоДляОбъекта = (НайденоАтрибуты[0].РежимИспользования =
			ПредопределенноеЗначение("Перечисление.РежимыИспользованияАтрибутов.ТолькоДляОбъектовНоменклатуры"));
		// Условие выбора класса в качестве значения.
		ВидимостьЗначениеКлассаИспользуемое = 
			(НЕ НайденоАтрибуты[0].СоставнойТипЗначения И 
				НЕ ТолькоДляОбъекта И 
				НайденоАтрибуты[0].МножественноеЗначение);
		// Класс мы можем выбрать: 
		//  1. Если в качестве источника значений не указан объект более низкого уровня.
		//  2. Если класс может значение атрибута - множественное, или источник значений - списочный.
		//  3. Если список подходящих классов не пустой или тип атрибута не составной 
		//     (надо показать пользователю хотябы пустой список).
		ВидимостьЗначенияКлассы = (НЕ ЗначениеЗаполнено(ТекИсточникЗначений) 
				ИЛИ ТипЗнч(ТекИсточникЗначений) = Тип("СправочникСсылка.Классы")) 
			И (ВидимостьЗначениеКлассаИспользуемое ИЛИ НайденоАтрибуты[0].СписокДоступныхЗначений)
			И (НЕ НайденоАтрибуты[0].СоставнойТипЗначения ИЛИ ЗначенияСписочногоАтрибута.ПолучитьЭлементы().Количество() > 0);
		
		Элементы.ЗначенияСписочногоАтрибута.Видимость                = ВидимостьЗначенияКлассы;
		Элементы.КоманднаяПанельЗначенияСписочногоАтрибута.Видимость = ВидимостьЗначенияКлассы;
		
		Элементы.ЗначенияСписочногоАтрибутаИспользуемоеЗначение.Видимость = ВидимостьЗначениеКлассаИспользуемое;
		Элементы.ЗначенияСписочногоАтрибутаДоступноеЗначение.Видимость = НайденоАтрибуты[0].СписокДоступныхЗначений;
		
		// Условие выбора номенклатуры в качестве значения.
		ВидимостьЗначениеНоменклатурыИспользуемое = 
			(НЕ ЕстьОбъектНоменклатуры И 
				НЕ ТолькоДляОбъекта И 
				НайденоАтрибуты[0].МножественноеЗначение);
		// Номенклатуру мы можем выбрать, если тип - составной, и в качестве источника не указана конкретная номенклатура.
		ВидимостьНоменклатура = (НайденоАтрибуты[0].СоставнойТипЗначения И (НЕ ЗначениеЗаполнено(ТекИсточникЗначений) 
				ИЛИ НЕ ТипЗнч(ТекИсточникЗначений) = Тип("СправочникСсылка.НоменклатураКласса")))
			И (ВидимостьЗначениеНоменклатурыИспользуемое ИЛИ НайденоАтрибуты[0].СписокДоступныхЗначений);
		
		Элементы.ЗначенияСписочногоАтрибутаНоменклатура.Видимость                = ВидимостьНоменклатура;
		Элементы.КоманднаяПанельЗначенияСписочногоАтрибутаНоменклатура.Видимость = ВидимостьНоменклатура;
		
		Элементы.ЗначенияСписочногоАтрибутаНоменклатураИспользуемоеЗначение.Видимость = 
			ВидимостьЗначениеНоменклатурыИспользуемое;
		Элементы.ЗначенияСписочногоАтрибутаНоменклатураДоступноеЗначение.Видимость = 
			НайденоАтрибуты[0].СписокДоступныхЗначений;
		
		// Объекты номенклатуры мы можем выбирать, если тип атрибута - объект номенклатуры.
		Элементы.ЗначенияСписочногоАтрибутаОбъектыНоменклатуры.Видимость                = ЕстьОбъектНоменклатуры;
		Элементы.КоманднаяПанельЗначенияСписочногоАтрибутаОбъектыНоменклатуры.Видимость = ЕстьОбъектНоменклатуры;
		
		Элементы.ЗначенияСписочногоАтрибутаОбъектыНоменклатурыИспользуемоеЗначение.Видимость = 
			НЕ ТолькоДляОбъекта И 
			НайденоАтрибуты[0].МножественноеЗначение;
		Элементы.ЗначенияСписочногоАтрибутаОбъектыНоменклатурыДоступноеЗначение.Видимость = 
			НайденоАтрибуты[0].СписокДоступныхЗначений;
		
	КонецЕсли;
	
	ЭлементыДерева = ЗначенияСписочногоАтрибута.ПолучитьЭлементы();
	Для Каждого СтрокаСписка ИЗ ЭлементыДерева Цикл
		Элементы.ЗначенияСписочногоАтрибута.Развернуть(СтрокаСписка.ПолучитьИдентификатор(), Истина);
	КонецЦикла;
	
	ЭлементыДерева = ЗначенияСписочногоАтрибутаНоменклатура.ПолучитьЭлементы();
	Для Каждого СтрокаСписка ИЗ ЭлементыДерева Цикл
		Элементы.ЗначенияСписочногоАтрибутаНоменклатура.Развернуть(СтрокаСписка.ПолучитьИдентификатор(), Истина);
	КонецЦикла;
	
	ЭлементыДерева = ЗначенияСписочногоАтрибутаОбъектыНоменклатуры.ПолучитьЭлементы();
	Для Каждого СтрокаСписка ИЗ ЭлементыДерева Цикл
		Элементы.ЗначенияСписочногоАтрибутаОбъектыНоменклатуры.Развернуть(СтрокаСписка.ПолучитьИдентификатор(), Истина);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииЗначенияСписочногоАтрибута(ТекДанные, ИзменитьДоступноеДляВложенных=Ложь)
	
	// Запись изменений в таб.часть обработки.
	Найдено = Объект.ЗначенияСписочныхАтрибутов.НайтиСтроки(
		Новый Структура("АтрибутКласса, ЗначениеАтрибутаКласса", ТекСписочныйАтрибут, ТекДанные.ЗначениеАтрибутаКласса));
	Если (ТекДанные.СтатусНаследования > 2 ИЛИ ТекДанные.ИспользуемоеЗначение ИЛИ ТекДанные.ДоступноеЗначение
			И ТекДанные.МожноИзменятьДоступноеЗначение) Тогда
		Если Найдено.Количество() = 0 Тогда
			СтрокаЗначений = Объект.ЗначенияСписочныхАтрибутов.Добавить();
			СтрокаЗначений.АтрибутКласса = ТекСписочныйАтрибут;
		Иначе
			СтрокаЗначений = Найдено[0];
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаЗначений, ТекДанные);
		СтрокаЗначений.ДоступноеЗначение = ТекДанные.ДоступноеЗначение
			И ТекДанные.МожноИзменятьДоступноеЗначение;
		
	ИначеЕсли Найдено.Количество() > 0 Тогда
		Объект.ЗначенияСписочныхАтрибутов.Удалить(Найдено[0]);
	КонецЕсли;
	
	Если ТипЗнч(ТекДанные.ЗначениеАтрибутаКласса) = Тип("СправочникСсылка.Классы") Тогда
		МассивПроверяемых = Новый Массив;
		МассивПроверяемых.Добавить(ТекДанные.ЗначениеАтрибутаКласса);
		
		// Автоматически проставить флажки вложенных.
		ВложенныеЭлементы = ТекДанные.ПолучитьЭлементы();
		Если ВложенныеЭлементы.Количество() > 0 Тогда
			Для Каждого СтрокаВложенных ИЗ ВложенныеЭлементы Цикл
				Если ИзменитьДоступноеДляВложенных Тогда
					Если ТекДанные.ДоступноеЗначение Тогда
						СтрокаВложенных.ДоступноеЗначение = Истина;
						СтрокаВложенных.МожноИзменятьДоступноеЗначение = Ложь;
					Иначе
						СтрокаВложенных.ДоступноеЗначение = Ложь;
						СтрокаВложенных.МожноИзменятьДоступноеЗначение = Истина;
					КонецЕсли;
					ПриИзмененииЗначенияСписочногоАтрибута(СтрокаВложенных, ИзменитьДоступноеДляВложенных);
				Иначе
					МассивПроверяемых.Добавить(СтрокаВложенных.ЗначениеАтрибутаКласса);
					ДобавитьПодчиненныеЭлементы(СтрокаВложенных, МассивПроверяемых);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		// Связанная номенклатура класса.
		ЭлементыКлассов = ЗначенияСписочногоАтрибутаНоменклатура.ПолучитьЭлементы();
		Для Каждого ТекКласс ИЗ ЭлементыКлассов Цикл
			Если НЕ МассивПроверяемых.Найти(ТекКласс.ЗначениеАтрибутаКласса) = Неопределено Тогда
				ЭлементыНоменклатуры = ТекКласс.ПолучитьЭлементы();
				Для Каждого ТекНоменклатура ИЗ ЭлементыНоменклатуры Цикл
					Изменено = Ложь;
					Если ТекДанные.ДоступноеЗначение Тогда
						ТекНоменклатура.ДоступноеЗначение = Истина;
						ТекНоменклатура.МожноИзменятьДоступноеЗначение = Ложь;
						Изменено = Истина;
					ИначеЕсли НЕ ТекНоменклатура.МожноИзменятьДоступноеЗначение Тогда
						ТекНоменклатура.ДоступноеЗначение = Ложь;
						ТекНоменклатура.МожноИзменятьДоступноеЗначение = Истина;
						Изменено = Истина;
					КонецЕсли;
					Если Изменено Тогда
						ПриИзмененииЗначенияСписочногоАтрибута(ТекНоменклатура);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ТекДанные.ЗначениеАтрибутаКласса) = Тип("СправочникСсылка.НоменклатураКласса") Тогда
		
		// Связанные объекты номенклатуры.
		ЭлементыКлассов = ЗначенияСписочногоАтрибутаОбъектыНоменклатуры.ПолучитьЭлементы();
		Для Каждого ТекКласс ИЗ ЭлементыКлассов Цикл
			ЭлементыНоменклатуры = ТекКласс.ПолучитьЭлементы();
			Для Каждого ТекНоменклатура ИЗ ЭлементыНоменклатуры Цикл
				Если ТекНоменклатура.ЗначениеАтрибутаКласса = ТекДанные.ЗначениеАтрибутаКласса Тогда
					ЭлементыОбъектов = ТекНоменклатура.ПолучитьЭлементы();
					Для Каждого ТекОбъект ИЗ ЭлементыОбъектов Цикл
						Изменено = Ложь;
						Если ТекДанные.ДоступноеЗначение Тогда
							ТекОбъект.ДоступноеЗначение = Истина;
							ТекОбъект.МожноИзменятьДоступноеЗначение = Ложь;
							Изменено = Истина;
						ИначеЕсли НЕ ТекОбъект.МожноИзменятьДоступноеЗначение Тогда
							ТекОбъект.ДоступноеЗначение = Ложь;
							ТекОбъект.МожноИзменятьДоступноеЗначение = Истина;
							Изменено = Истина;
						КонецЕсли;
						Если Изменено Тогда
							ПриИзмененииЗначенияСписочногоАтрибута(ТекОбъект);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПодчиненныеЭлементы(СтрокаВложенных, МассивДобавления)
	
	ВложенныеЭлементы = СтрокаВложенных.ПолучитьЭлементы();
	Если ВложенныеЭлементы.Количество() > 0 Тогда
		Для Каждого СледующийУровень ИЗ ВложенныеЭлементы Цикл
			МассивДобавления.Добавить(СледующийУровень.ЗначениеАтрибутаКласса);
			ДобавитьПодчиненныеЭлементы(СледующийУровень, МассивДобавления);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьЭлементыУправленияТаблицами()
	
	Результат = Новый Соответствие;
	Результат.Вставить("ЗначенияСписочногоАтрибута", 
		Элементы.ЗначенияСписочногоАтрибутаКоманды);
	Результат.Вставить("ЗначенияСписочногоАтрибутаНоменклатура", 
		Элементы.ЗначенияСписочногоАтрибутаКомандыНоменклатуры);
	Результат.Вставить("ЗначенияСписочногоАтрибутаОбъектыНоменклатуры", 
		Элементы.ЗначенияСписочногоАтрибутаКомандыОбъектов);
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ТекущийПользователь()
	
	Возврат ПараметрыСеанса.ТекущийПользователь;
	
КонецФункции

&НаСервереБезКонтекста
Функция ОбъектРедактируется(Класс, ТекущимПользователем=Истина, Пользователь=Неопределено)
	
	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект",               Класс);
	Запрос.УстановитьПараметр("ТекПользователь",      ТекущийПользователь());
	Запрос.УстановитьПараметр("ТекущимПользователем", ТекущимПользователем);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаРедактированияКлассов.Объект,
		|	БлокировкаРедактированияКлассов.Пользователь
		|ИЗ
		|	РегистрСведений.БлокировкаРедактированияКлассов КАК БлокировкаРедактированияКлассов
		|ГДЕ
		|	БлокировкаРедактированияКлассов.Объект = &Объект
		|	И (БлокировкаРедактированияКлассов.Пользователь = &ТекПользователь) = &ТекущимПользователем";
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		Результат = Истина;
		Пользователь = РезультатЗапроса.Пользователь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ПроверитьЗаблокироватьРедактированиеКлассаНаСервере(Знач Класс, Отказ, Блокировать=Истина, ТолькоВверх=Ложь)
	
	Если Класс = Неопределено Тогда
		Класс = Объект.Класс.Ссылка;
	КонецЕсли;
	
	ТекПользователь = ТекущийПользователь();
	
	МассивРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(Класс).ВыгрузитьКолонку("Класс");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", Класс);
	Запрос.УстановитьПараметр("ТекПользователь", ТекПользователь);
	Запрос.УстановитьПараметр("МассивРодителей", МассивРодителей);
	Запрос.УстановитьПараметр("ТолькоВверх", ТолькоВверх);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаРедактированияКлассов.Объект,
		|	БлокировкаРедактированияКлассов.Пользователь
		|ИЗ
		|	РегистрСведений.БлокировкаРедактированияКлассов КАК БлокировкаРедактированияКлассов
		|ГДЕ
		|	(НЕ &ТолькоВверх
		|				И БлокировкаРедактированияКлассов.Объект В ИЕРАРХИИ (&Объект)
		|			ИЛИ БлокировкаРедактированияКлассов.Объект В (&МассивРодителей))
		|	И НЕ БлокировкаРедактированияКлассов.Пользователь = &ТекПользователь";
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		ШаблонСообщения = НСтр("ru = 'Класс ''%1'' заблокирован пользователем ''%2'', редактирующим класс ''%3'''");
		ТекстСообщения = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(ШаблонСообщения, 
			Строка(Класс), Строка(Результат.Пользователь), Строка(Результат.Объект));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;
	
	Если НЕ Отказ И Блокировать Тогда
		
		Попытка 
			СпрОбъект = ДанныеФормыВЗначение(Объект.Класс, Тип("СправочникОбъект.Классы"));
			СпрОбъект.Заблокировать();
			ЗначениеВДанныеФормы(СпрОбъект, Объект.Класс);
		Исключение 
			ШаблонСообщения = НСтр("ru = 'Ошибка блокировки класса ''%1'' для редактирования'");
			ТекстСообщения = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
				ШаблонСообщения, Строка(Класс));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, Отказ);
		КонецПопытки;
		
		Если НЕ Отказ Тогда
			Запись = РегистрыСведений.БлокировкаРедактированияКлассов.СоздатьМенеджерЗаписи();
			Запись.Объект = Класс;
			Запись.Пользователь = ТекПользователь;
			Запись.Записать();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СнятьБлокировкуКласса()
	Запись = РегистрыСведений.БлокировкаРедактированияКлассов.СоздатьМенеджерЗаписи();
	Запись.Объект = Объект.Класс.Ссылка;
	Запись.Удалить();
КонецПроцедуры

&НаСервере
Процедура ОтменитьРедактированиеНаСервере()
	
	Если ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
		СнятьБлокировкуКласса();
		ПодготовитьФормуРедактированияКласса(Объект.Класс.Ссылка);
		ПереключательАтрибутов = 0;
		Элементы.ГруппаСтарницыАтрибутов.ТекущаяСтраница = Элементы.ГруппаСтраницаОбщие;
	Иначе
		ШаблонПустаяСсылка = Справочники.ШаблоныЗаполнения.ПустаяСсылка();
		СчетчикПустаяСсылка = Справочники.Счетчики.ПустаяСсылка();
		ПустыеЗначения = Новый Структура("Наименование, НаименованиеПолное, Код, ОтображатьВИерархииТО, Родитель, 
			|ЗначениеАтрибута, НоменклатураКласса, ОбъектыНоменклатуры, КлассТабличнаяЧасть, Статус, НомерПоСчетчику, 
			|ШагСчетчика, ПрисвоенНомерПоШаблону, ФорматКодаРодителя, ШаблонКодаРодителя, РежимКонтроляДублейПоНаименованию,
			|КонтрольДублейВПределахКласса, " + СписокРеквизитовКодированияИменования(),
			"", "", "", Ложь, Справочники.Классы.ПустаяСсылка(), 
			Ложь, Ложь, Ложь, Ложь, Перечисления.СтатусыОбъектовНСИ.ПустаяСсылка(), 
			0, 0, Ложь, "", ШаблонПустаяСсылка, Перечисления.РежимыКонтроляДублей.ПустаяСсылка(),
			Справочники.Классы.ПустаяСсылка(),
			"", ШаблонПустаяСсылка, ШаблонПустаяСсылка, СчетчикПустаяСсылка,
			"", ШаблонПустаяСсылка, ШаблонПустаяСсылка, СчетчикПустаяСсылка,
			"", ШаблонПустаяСсылка, ШаблонПустаяСсылка, СчетчикПустаяСсылка);
		ЗаполнитьЗначенияСвойств(Объект, ПустыеЗначения);
		
		Объект.Атрибуты.Очистить();
		Объект.ЗначенияСписочныхАтрибутов.Очистить();
		Объект.СтрокиТабличныхАтрибутов.Очистить();
		Объект.ЗначенияТабличныхАтрибутов.Очистить();
		
		ЗаголовокРедактируемогоЭлемента = НСтр("ru='(Выберите элемент для редактирования или создайте новый)'");
		
		ПереключательАтрибутов = 0;
		Элементы.ГруппаСтарницыАтрибутов.ТекущаяСтраница = Элементы.ГруппаСтраницаОбщие;
		Элементы.НоменклатураКласса.Доступность  = Истина;
		Элементы.ЗначениеАтрибута.Доступность    = Истина;
		Элементы.ОбъектыНоменклатуры.Доступность = Ложь;
		
		Элементы.ГруппаПараметрыНоменклатуры.Доступность        = Ложь;
		Элементы.ГруппаПараметрыОбъектаНоменклатуры.Доступность = Ложь;
		
		Элементы.ГруппаСтраницыКонтрольДублейПоНаименованию.ТекущаяСтраница = 
			Элементы.ГруппаСтраницаКонтрольДублейКакУРодителя;
		КонтрольДублейКакУРодителя = "";
		
		УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияНоменклатуры(), Ложь);
		УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияОбъектов(),     Ложь);
		
		Модифицированность = Ложь;
		Элементы.ГруппаПраваяКолонка.ТолькоПросмотр = Истина;
		УстановитьРежимТолькоПросмотра(Истина, Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере 
Процедура УстановитьАвтоотметкуНезаполненных(СписокРеквизитов, АвтоотметкаНезаполненного)
	
	МассивРеквизитов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СписокРеквизитов);
	Для Каждого ИмяРеквизита ИЗ МассивРеквизитов Цикл
		Элементы[СокрЛП(ИмяРеквизита)].АвтоОтметкаНезаполненного = АвтоотметкаНезаполненного;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьРежимТолькоПросмотра(ТолькоПросмотр, ВозможноРедактироватьКласс=Истина)
	
	Редактирование = НЕ ТолькоПросмотр;
	
	Элементы.ГруппаРеквизитыШапки.ТолькоПросмотр                  = ТолькоПросмотр;
	//Элементы.ГруппаСтарницыАтрибутов.ТолькоПросмотр               = ТолькоПросмотр;
	Элементы.ГруппаСтраницаОбщие.ТолькоПросмотр                   = ТолькоПросмотр;
	Элементы.ГруппаСтраницаПростыеАтрибуты.ТолькоПросмотр         = ТолькоПросмотр;
	Элементы.ГруппаСтраницаСписочныйАтрибут.ТолькоПросмотр        = ТолькоПросмотр;
	Элементы.ГруппаСтраницаТабличныйАтрибут.ТолькоПросмотр        = ТолькоПросмотр;
	Элементы.ГруппаТехКарты.ТолькоПросмотр                        = ТолькоПросмотр;
	Элементы.СоставТехКарты.ТолькоПросмотр                        = ТолькоПросмотр;
	Элементы.ЗначениеТабличногоАтрибутаОперации.ТолькоПросмотр    = ТолькоПросмотр;
	Элементы.ГруппаВложенныеТабличныеЧастиТехКарты.ТолькоПросмотр = ТолькоПросмотр;
	
	Элементы.СформироватьКодПоШаблону.Доступность                             = НЕ ТолькоПросмотр;
	Элементы.ГруппаКомандыДобавленияОпераций.Доступность                      = НЕ ТолькоПросмотр;
	Элементы.ЗначениеТабличногоАтрибутаНастройкаНаследованияСтрок.Доступность = НЕ ТолькоПросмотр;
	
	Элементы.ГруппаВсеАтрибуты.Видимость = НЕ ТолькоПросмотр;
	
	Элементы.ГруппаКомандыДобавленияОпераций.Видимость = НЕ ТолькоПросмотр;
	Элементы.ГруппаПанельПодбораОпераций.Видимость     = НЕ ТолькоПросмотр;
	
	Если ТолькоПросмотр Тогда
		Элементы.ЗаписатьИзменения.Доступность        = Ложь;
		Элементы.ЗаписатьИзменения.КнопкаПоУмолчанию  = Ложь;
		Элементы.РедактироватьКласс.Видимость         = ВозможноРедактироватьКласс;
		Элементы.РедактироватьКласс.КнопкаПоУмолчанию = ВозможноРедактироватьКласс;
		
		// Элементы управления атрибутами (обычными и списочными) не доступны в режиме просмотра.
		Элементы.АтрибутыКомандаНаследовать.Доступность   = Ложь;
		Элементы.АтрибутыКомандаНеНаследовать.Доступность = Ложь;
		
		Элементы.ЗначенияСписочногоАтрибутаКомандаНаследоватьЗначение.Доступность   = Ложь;
		Элементы.ЗначенияСписочногоАтрибутаКомандаНеНаследоватьЗначение.Доступность = Ложь;
		
		Элементы.ЗначенияСписочногоАтрибутаКомандаНаследоватьЗначениеОбъектНоменклатуры.Доступность   = Ложь;
		Элементы.ЗначенияСписочногоАтрибутаКомандаНеНаследоватьЗначениеОбъектНоменклатуры.Доступность = Ложь;
		
		Элементы.ЗначенияСписочногоАтрибутаКомандаНаследоватьЗначениеНоменклатуры.Доступность   = Ложь;
		Элементы.ЗначенияСписочногоАтрибутаКомандаНеНаследоватьЗначениеНоменклатуры.Доступность = Ложь;
	Иначе
		Элементы.РедактироватьКласс.Видимость         = Ложь;
		Элементы.РедактироватьКласс.КнопкаПоУмолчанию = Ложь;
		Элементы.ЗаписатьИзменения.Доступность        = Истина;
		Элементы.ЗаписатьИзменения.КнопкаПоУмолчанию  = Истина;
		
		НастроитьОтображениеДанныхАтрибута(Объект, Элементы, ТекРежимЗаполненияАтрибутаШаблона, Редактирование);
		
		ТекДанные = Неопределено;
		ИДСтроки = Элементы.ЗначенияСписочногоАтрибута.ТекущаяСтрока;
		Если НЕ ИДСтроки = Неопределено Тогда
			ТекДанные = ЗначенияСписочногоАтрибута.НайтиПоИдентификатору(ИДСтроки);
		КонецЕсли;
		
		НастроитьКомандыУправленияЗначениямиСписочногоАтрибута(Объект, Элементы, ТекДанные, Редактирование);
	КонецЕсли;
	
	Элементы.ОтменитьРедактирование.Видимость       = НЕ ТолькоПросмотр;
	
КонецПроцедуры

&НаСервере
Функция СписокРеквизитовКодированияИменования()
	
	СписокРеквизитов = 
		СписокРеквизитовКодированияИменованияКлассов() + ", "
		+ СписокРеквизитовКодированияИменованияНоменклатуры() + ", "
		+ СписокРеквизитовКодированияИменованияОбъектов();
	Возврат СписокРеквизитов;
	
КонецФункции

&НаСервере
Функция СписокРеквизитовКодированияИменованияКлассов()
	
	СписокРеквизитов = 
		"ФорматКодаКласса, ШаблонКодаКласса, ШаблонНаименованияКласса, СчетчикКлассов";
	Возврат СписокРеквизитов;
	
КонецФункции

&НаСервере
Функция СписокРеквизитовКодированияИменованияНоменклатуры()
	
	СписокРеквизитов = 
		"ФорматКодаНоменклатуры, ШаблонКодаНоменклатуры, ШаблонНаименованияНоменклатуры, СчетчикНоменклатуры";
	Возврат СписокРеквизитов;
	
КонецФункции

&НаСервере
Функция СписокРеквизитовКодированияИменованияОбъектов()
	
	СписокРеквизитов = 
		"ФорматКодаОбъекта, ШаблонКодаОбъекта, ШаблонНаименованияОбъекта, СчетчикОбъектовНоменклатуры";
	Возврат СписокРеквизитов;
	
КонецФункции

&НаСервере
Процедура СформироватьКодПоШаблонуНаСервере()
	
	НомерПоСчетчику = Объект.НомерПоСчетчику;
	ШагСчетчика     = Объект.ШагСчетчика;
	
	Отказ = Ложь;
	Если НЕ Объект.ПрисвоенНомерПоШаблону Тогда
		НомерПоСчетчику = 0;
	КонецЕсли;
	
	НовыйКод = ШаблоныСтрокСервер.СформироватьЗначениеПоШаблону(
		Объект.Класс.Ссылка, Объект.ШаблонКодаРодителя, НомерПоСчетчику, ШагСчетчика, Отказ);
	Если НЕ Отказ Тогда
		Объект.Код             = НовыйКод;
		Объект.НомерПоСчетчику = НомерПоСчетчику;
		Объект.ШагСчетчика     = ШагСчетчика;
		Объект.ПрисвоенНомерПоШаблону = Истина;
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РодительПриИзмененииНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Объект.Родитель) Тогда
		ТекРодительКласса = Объект.Родитель;
		Возврат;
	КонецЕсли;
	
	// Сохраняем прежние значения.
	ТаблицаАтрибутов                  = Объект.Атрибуты.Выгрузить();
	ТаблицаСписочныхАтрибутов         = Объект.ЗначенияСписочныхАтрибутов.Выгрузить();
		
	Отказ = Ложь;
	ПроверитьЗаблокироватьРедактированиеКлассаНаСервере(Объект.Родитель, Отказ, Ложь, Истина);
	Если Отказ Тогда
		Объект.Родитель = ТекРодительКласса;
		Возврат;
	КонецЕсли;
	
	РеквизитыРодителя = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъекта(Объект.Родитель, 
		"КлассТабличнаяЧасть, " + СписокРеквизитовКодированияИменования());
	ЗаполнитьЗначенияСвойств(Объект, РеквизитыРодителя);
	
	Если НЕ ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
		ЗаголовокРедактируемогоЭлемента = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
			НСтр("ru='Редактирование классов: Создание (Родитель:%1)'"), Объект.Родитель);
	КонецЕсли;
	
	ЗаполнитьСписокРодителей();
	
	// Заполняем атрибуты.
	ЗаполнитьАтрибуты(Неопределено);
	
	// Переносим прежние значения атрибутов.
	СтруктураПоиска = Новый Структура("АтрибутКласса");
	ТекИД = 0;
	
	Если ТаблицаАтрибутов.Количество() > 0 Тогда
		Для Каждого СтрокаАтрибут ИЗ ТаблицаАтрибутов Цикл
			Если СтрокаАтрибут.СтатусНаследования > 4 Тогда
				Продолжить;
			КонецЕсли;
			
			ЭтоСтрока = СтрокаАтрибут.ТипЗначения.СодержитТип(Тип("Строка"));
			ДобавитьСписочныйАтрибут = Ложь;
			
			СтруктураПоиска.АтрибутКласса = СтрокаАтрибут.АтрибутКласса;
			НайденоАтрибуты = Объект.Атрибуты.НайтиСтроки(СтруктураПоиска);
			Если НайденоАтрибуты.Количество() > 0 Тогда
				СтрокаТЧ = НайденоАтрибуты[0];
				// Если атрибут до изменения родителя был ненаследуемым, то и после изменения он будет ненаследуемым.
				Если СтрокаАтрибут.СтатусНаследования = 4 И СтрокаТЧ.СтатусНаследования = 3 Тогда
					СтрокаТЧ.СтатусНаследования = 4;
					СтрокаТЧ.ЗначениеАтрибутаКласса = СтрокаТЧ.ТипЗначения.Привести();
					СтрокаТЧ.УровеньЗначения = 0;
					Если СтрокаАтрибут.МножественноеЗначение ИЛИ СтрокаАтрибут.СписокДоступныхЗначений Тогда
						НайденоСписочные = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, СтрокаАтрибут.АтрибутКласса));
						Если НайденоСписочные.Количество() > 0 Тогда
							ЭлементСписка = Элементы.ПереключательАтрибутов.СписокВыбора.НайтиПоЗначению(НайденоСписочные[0].ИДАтрибута);
							Если НЕ ЭлементСписка = Неопределено Тогда
								Элементы.ПереключательАтрибутов.СписокВыбора.Удалить(ЭлементСписка);
							КонецЕсли;
							СписочныеАтрибуты.Удалить(НайденоСписочные[0]);
						КонецЕсли;
					КонецЕсли;
					
				// Если он был наследуемым, копируем его настройки как были до изменения.
				ИначеЕсли СтрокаАтрибут.СтатусНаследования = 3 И СтрокаТЧ.СтатусНаследования = 3 Тогда
					ДобавитьСписочныйАтрибут = (НЕ ЭтоСтрока И НЕ СтрокаТЧ.МножественноеЗначение И НЕ СтрокаТЧ.СписокДоступныхЗначений
						И (СтрокаАтрибут.МножественноеЗначение ИЛИ СтрокаАтрибут.СписокДоступныхЗначений));
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаАтрибут);
					
				// Если он был добавленным, а теперь наследуемый - не копируем некоторые настройки.
				ИначеЕсли СтрокаАтрибут.СтатусНаследования = 1 И СтрокаТЧ.СтатусНаследования = 3 Тогда
					ДобавитьСписочныйАтрибут = (НЕ ЭтоСтрока И НЕ СтрокаТЧ.МножественноеЗначение И НЕ СтрокаТЧ.СписокДоступныхЗначений
						И (СтрокаАтрибут.МножественноеЗначение ИЛИ СтрокаАтрибут.СписокДоступныхЗначений));
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаАтрибут, , 
						"СтатусНаследования, РежимИспользования, РежимЗаполнения, РежимЗаполненияРодителя");
					
				КонецЕсли;
				
				ИдНайдено = Объект.Атрибуты.Индекс(СтрокаТЧ);
				Если НЕ ИдНайдено = ТекИД Тогда
					Объект.Атрибуты.Сдвинуть(ИдНайдено, ТекИд - ИдНайдено);
				КонецЕсли;
				ТекИД = ТекИД + 1;
				
			Иначе
				// Если у нового родителя такого атрибута нет, а у старого родителя - он был новым, тогда добавляем этот атрибут.
				Если СтрокаАтрибут.СтатусНаследования = 1 Тогда
					СтрокаТЧ = Объект.Атрибуты.Вставить(ТекИД);
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаАтрибут);
					Если СтрокаТЧ.МножественноеЗначение И НЕ ЭтоСтрока Тогда
						СтрокаТЧ.ЗначениеАтрибутаКласса = СтрокаТЧ.ТипЗначения.ПривестиЗначение();
						СтрокаТЧ.УровеньЗначения = 0;
					КонецЕсли;
					ДобавитьСписочныйАтрибут = (НЕ ЭтоСтрока 
						И (СтрокаАтрибут.МножественноеЗначение ИЛИ СтрокаАтрибут.СписокДоступныхЗначений));
					ТекИД = ТекИД + 1;
				КонецЕсли;
				
			КонецЕсли;
			
			Если ДобавитьСписочныйАтрибут Тогда
				ДобавитьСписочныйАтрибут(СтрокаТЧ.АтрибутКласса, СтрокаТЧ.КлассТабличнаяЧасть, СтрокаТЧ.ИсточникЗначений);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Заполнение списочных атрибутов.
	Объект.ЗначенияСписочныхАтрибутов.Очистить();
	МассивАтрибутов = СписочныеАтрибуты.Выгрузить(Новый Структура("ТипОбъекта, КлассТабличнаяЧасть", 0, Ложь)).ВыгрузитьКолонку("АтрибутКласса");
	Если МассивАтрибутов.Количество() > 0 Тогда
		ЗаполнитьЗначенияСписочныхАтрибутов(Неопределено, МассивАтрибутов);
	КонецЕсли;
	
	Если ТаблицаСписочныхАтрибутов.Количество() > 0 Тогда
		
		СтруктураПоиска = Новый Структура("АтрибутКласса, ЗначениеАтрибутаКласса");
		
		Для Каждого СтрокаСписочного ИЗ ТаблицаСписочныхАтрибутов Цикл
			ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаСписочного);
			НайденоСписочные = Объект.ЗначенияСписочныхАтрибутов.НайтиСтроки(СтруктураПоиска);
			Если НайденоСписочные.Количество() > 0 Тогда
				СтрокаТЧ = НайденоСписочные[0];
				Если СтрокаСписочного.СтатусНаследования = 4 И СтрокаТЧ.СтатусНаследования = 3 Тогда
					СтрокаТЧ.СтатусНаследования   = 4;
					СтрокаТЧ.ДоступноеЗначение    = Ложь;
					СтрокаТЧ.ИспользуемоеЗначение = Ложь;
				ИначеЕсли СтрокаСписочного.СтатусНаследования = 2 И СтрокаТЧ.СтатусНаследования = 2 Тогда
					СтрокаТЧ.ДоступноеЗначение    = СтрокаСписочного.ДоступноеЗначение;
					СтрокаТЧ.ИспользуемоеЗначение = СтрокаСписочного.ИспользуемоеЗначение;
				КонецЕсли;
			Иначе
				Если СтрокаСписочного.СтатусНаследования = 2 Тогда
					СтрокаТЧ = Объект.ЗначенияСписочныхАтрибутов.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаСписочного);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	// Заполнение табличных атрибутов.
	ЗаполнитьЗначенияТабличныхАтрибутов(Неопределено);
	
	ТекРодительКласса = Объект.Родитель;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПредставлениеРежимаКонтроляДублей(Знач СписокРодителей)
	ДанныеКонтроляДублей = Справочники.Классы.ПолучитьРежимКонтроляДублейПоНаименованию(СписокРодителей);
	Возврат ДанныеКонтроляДублей.РежимКонтроляДублейПредставление;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСписокВложенныхАтрибутов(ИсточникЗначений)
	
	СписокВложенныхАтрибутов = Неопределено;
	
	Если ТипЗнч(ИсточникЗначений) = Тип("СправочникСсылка.Классы") Тогда
		ТаблицаРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(ИсточникЗначений);
		ТаблицаАтрибутов = Справочники.Классы.ПолучитьТаблицуАтрибутов(ТаблицаРодителей, , Ложь);
		
		СписокВложенныхАтрибутов = Новый СписокЗначений;
		ПеречислениеРеквизитов = Перечисления.РеквизитыКлассаНоменклатуры;
		Для Каждого Значение ИЗ ПеречислениеРеквизитов Цикл
			СписокВложенныхАтрибутов.Добавить(Значение);
		КонецЦикла;
		
		Для Каждого СтрокаАтрибут ИЗ ТаблицаАтрибутов Цикл
			Если СтрокаАтрибут.МножественноеЗначение
					ИЛИ НЕ ТипЗнч(СтрокаАтрибут.АтрибутКласса) = Тип("ПланВидовХарактеристикСсылка.АтрибутыКласса") Тогда
				Продолжить;
			КонецЕсли;
			СписокВложенныхАтрибутов.Добавить(СтрокаАтрибут.АтрибутКласса);
		КонецЦикла;
	КонецЕсли;
	
	Возврат СписокВложенныхАтрибутов;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьВложенныйАтрибут(Источник, АтрибутКласса)
	
	Возврат Справочники.ВложенныеАтрибутыКласса.ПолучитьВложенныйАтрибут(Источник, АтрибутКласса);
	
КонецФункции

&НаСервере
Функция ПолучитьРодителяПоКлассу(Класс)
	
	Возврат Справочники.НоменклатураКласса.ПолучитьРодителяПоКлассу(Класс);
	
КонецФункции
 
#КонецОбласти

////////////////////////////////////////////////////////////////////////////////
// Процедуры и функции заполнения обработки

#Область ПроцедурыИФункцииЗаполненияОбработки

&НаСервере
Процедура ВыбратьОбъектРедактирования(Ссылка)
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		СпрОбъект = Ссылка.ПолучитьОбъект();
	Иначе
		СпрОбъект = Справочники.Классы.СоздатьЭлемент();
	КонецЕсли;
	ЗначениеВДанныеФормы(СпрОбъект, Объект.Класс);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодготовитьФормуРедактированияКлассаЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ЗаписатьНаСервере();
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	Если Редактирование И ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
		СнятьБлокировкуКласса();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДополнительныеПараметры.ВыбраннаяСтрока) И ДополнительныеПараметры.РежимДобавления = 0 Тогда
		Пользователь = Неопределено;
		ОбъектЗаблокирован = ОбъектРедактируется(ДополнительныеПараметры.ВыбраннаяСтрока, Ложь, Пользователь);
		Если ОбъектЗаблокирован Тогда
			ШаблонПредупреждения = НСтр("ru = 'Класс ''%1'' заблокирован для редактирования пользователем ''%2''.'");
			ТекстПредупреждения = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
				ШаблонПредупреждения, Строка(ДополнительныеПараметры.ВыбраннаяСтрока), Строка(Пользователь));
			ПоказатьПредупреждение(, ТекстПредупреждения);
			
			ВыбратьОбъектРедактирования(Неопределено);
			
			ОтменитьРедактированиеНаСервере();
			Возврат;
			
		КонецЕсли;
	КонецЕсли;
	
	ПодготовитьФормуРедактированияКласса(
		ДополнительныеПараметры.ВыбраннаяСтрока, ДополнительныеПараметры.РежимДобавления);
	Если ПереключательАтрибутов > 1 Тогда 
		ПереключательАтрибутов = 0;
		ПереключитьСтраницуФормы();
	КонецЕсли;
	
	Если НЕ Элементы.КлассыСписок.ТекущийРодитель = Объект.Родитель Тогда
		Элементы.КлассыСписок.ТекущийРодитель = Объект.Родитель;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокРодителей()
	
	НовыйСписокРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(
		Объект.Родитель, "ФорматКодаКласса, ШаблонКодаКласса, ШаблонНаименованияКласса,
		|РежимКонтроляДублейПоНаименованию, КонтрольДублейВПределахКласса");
	
	Если ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
		СтрокаТЗ = НовыйСписокРодителей.Добавить();
		СтрокаТЗ.Класс   = Объект.Класс.Ссылка;
		СтрокаТЗ.Уровень = НовыйСписокРодителей.Количество();
	КонецЕсли;
	
	СписокРодителей.Загрузить(НовыйСписокРодителей);
	
	// Заполняем данные родителя.
	Объект.ШаблонКодаРодителя = Справочники.Классы.ПолучитьЗначениеРодителя(
		СписокРодителей, СписокРодителей.Количество() - 1, "ШаблонКодаКласса");
	Объект.ФорматКодаРодителя = Справочники.Классы.ПолучитьЗначениеРодителя(
		СписокРодителей, СписокРодителей.Количество() - 1, "ФорматКодаКласса");
		
	СписокВыбора = Элементы.КонтрольДублейВПределахКласса.СписокВыбора;
	СписокВыбора.Очистить();
	СписокВыбора.ЗагрузитьЗначения(НовыйСписокРодителей.ВыгрузитьКолонку("Класс"));
	ПустоеЗначение = СписокВыбора.Вставить(0, Справочники.Классы.ПустаяСсылка(), НСтр("ru='(Текущий класс)'"));
	
	Если НЕ ЗначениеЗаполнено(Объект.РежимКонтроляДублейПоНаименованию) Тогда
		ДанныеКонтроляДублей = Справочники.Классы.ПолучитьРежимКонтроляДублейПоНаименованию(СписокРодителей);
		КонтрольДублейКакУРодителя = ДанныеКонтроляДублей.РежимКонтроляДублейПредставление;
	Иначе
		КонтрольДублейКакУРодителя = "";
	КонецЕсли;
	
	// Заполнение реквизитов класса по родителю.
	Если НЕ ЗначениеЗаполнено(Объект.ШаблонКодаКласса) И ЗначениеЗаполнено(Объект.ШаблонКодаРодителя) Тогда
		Объект.ШаблонКодаКласса = Объект.ШаблонКодаРодителя;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.ФорматКодаКласса) И ЗначениеЗаполнено(Объект.ФорматКодаРодителя) Тогда
		Объект.ФорматКодаКласса = Объект.ФорматКодаРодителя;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуРедактированияКласса(ВыбраннаяСтрока, Режим=0)
	
	Модифицированность = Ложь;
	РежимРедактирования = Ложь;
	
	// Редактирование класса.
	Если Режим = 0 Тогда
		ВыбратьОбъектРедактирования(ВыбраннаяСтрока);
		РеквизитыКласса = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъекта(ВыбраннаяСтрока, 
			"Наименование, Код, Родитель, ОтображатьВИерархииТО, Статус, НаименованиеПолное, 
			|ЗначениеАтрибута, НоменклатураКласса, ОбъектыНоменклатуры, КлассТабличнаяЧасть, 
			|НомерПоСчетчику, ШагСчетчика, ПрисвоенНомерПоШаблону, РежимКонтроляДублейПоНаименованию,
			|КонтрольДублейВПределахКласса, " + СписокРеквизитовКодированияИменования());
		ИсточникЗаполнения = ВыбраннаяСтрока;
		Если НЕ ЗначениеЗаполнено(РеквизитыКласса.Статус) Тогда
			РеквизитыКласса.Статус = Перечисления.СтатусыОбъектовНСИ.Черновик;
		КонецЕсли;
		
		РежимРедактирования = ОбъектРедактируется(ВыбраннаяСтрока);
		
		ЗаголовокРедактируемогоЭлемента = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
			НСтр("ru='Редактирование классов: %1'"), РеквизитыКласса.Наименование);
		
	// Создание класса.
	ИначеЕсли Режим = 1 Тогда
		
		ВыбратьОбъектРедактирования(Неопределено);
		
		РеквизитыКласса = Новый Структура("Родитель, ОтображатьВИерархииТО, Статус, 
			|ЗначениеАтрибута, НоменклатураКласса, ОбъектыНоменклатуры, Код, Наименование, 
			|НаименованиеПолное, НомерПоСчетчику, ШагСчетчика, ПрисвоенНомерПоШаблону, 
			|РежимКонтроляДублейПоНаименованию, КонтрольДублейВПределахКласса", 
			ВыбраннаяСтрока, Истина, Перечисления.СтатусыОбъектовНСИ.Черновик, 
			Истина, Истина, Ложь, "", "", "", 0, 0, Ложь,
			Перечисления.РежимыКонтроляДублей.ПустаяСсылка(), Справочники.Классы.ПустаяСсылка());
		РеквизитыРодителя = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъекта(ВыбраннаяСтрока, 
			"КлассТабличнаяЧасть, " + СписокРеквизитовКодированияИменования());
		Для Каждого КлючИЗначение ИЗ РеквизитыРодителя Цикл
			РеквизитыКласса.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
		КонецЦикла;
		
		ИсточникЗаполнения = Неопределено;
		
		Отказ = Ложь;
		ПроверитьЗаблокироватьРедактированиеКлассаНаСервере(ВыбраннаяСтрока, Отказ, Ложь, Истина);
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
		
		РежимРедактирования = Истина;
		
		ЗаголовокРедактируемогоЭлемента = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
			НСтр("ru='Редактирование классов: Создание (Родитель:%1)'"), ВыбраннаяСтрока);
		
	// Копирование класса.
	ИначеЕсли Режим = 2 Тогда
		ВыбратьОбъектРедактирования(Неопределено);
		
		Объект.Код = "";
		
		РеквизитыКласса = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъекта(
			ВыбраннаяСтрока, "Наименование, Родитель, ОтображатьВИерархииТО, НаименованиеПолное, 
			|ЗначениеАтрибута, НоменклатураКласса, ОбъектыНоменклатуры, КлассТабличнаяЧасть, 
			|РежимКонтроляДублейПоНаименованию, КонтрольДублейВПределахКласса,
			|" + СписокРеквизитовКодированияИменования());
		РеквизитыКласса.Вставить("Статус", Перечисления.СтатусыОбъектовНСИ.Черновик);
		РеквизитыКласса.Вставить("НомерПоСчетчику", 0);
		РеквизитыКласса.Вставить("ШагСчетчика",     0);
		РеквизитыКласса.Вставить("ПрисвоенНомерПоШаблону", Ложь);
		
		ИсточникЗаполнения = ВыбраннаяСтрока;
		
		Отказ = Ложь;
		ПроверитьЗаблокироватьРедактированиеКлассаНаСервере(РеквизитыКласса.Родитель, Отказ, Ложь, Истина);
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
		
		РежимРедактирования = Истина;
		
		ЗаголовокРедактируемогоЭлемента = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
			НСтр("ru='Редактирование классов: Создание (Копирование:%1)'"), ВыбраннаяСтрока);
		
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, РеквизитыКласса);
	
	ТекРодительКласса = Объект.Родитель;
	
	Элементы.ГруппаПраваяКолонка.ТолькоПросмотр = Ложь;
	Элементы.НоменклатураКласса.Доступность     = НЕ Объект.КлассТабличнаяЧасть;
	Элементы.ЗначениеАтрибута.Доступность       = НЕ Объект.КлассТабличнаяЧасть;
	Элементы.ОбъектыНоменклатуры.Доступность    = Объект.НоменклатураКласса;
	
	Элементы.ГруппаПараметрыКласса.Видимость = ЗначениеЗаполнено(Объект.Родитель);
	
	Элементы.ГруппаПараметрыНоменклатуры.Доступность        = Объект.НоменклатураКласса;
	Элементы.ГруппаПараметрыОбъектаНоменклатуры.Доступность = Объект.ОбъектыНоменклатуры;
	
	Элементы.ГруппаСтраницыКонтрольДублейПоНаименованию.ТекущаяСтраница = 
		?(Объект.РежимКонтроляДублейПоНаименованию = Перечисления.РежимыКонтроляДублей.ВПределахКласса,
			Элементы.ГруппаСтраницаКонтрольДублейВПределахКласса,
			Элементы.ГруппаСтраницаКонтрольДублейКакУРодителя);
	
	УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияНоменклатуры(), Объект.НоменклатураКласса);
	УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияОбъектов(),     Объект.ОбъектыНоменклатуры);
	
	УстановитьРежимТолькоПросмотра(НЕ РежимРедактирования, ПравоИзменениеКлассов);
	
	ЗаполнитьСписокРодителей();
	ЗаполнитьАтрибуты(ИсточникЗаполнения);
	
	Объект.ЗначенияСписочныхАтрибутов.Очистить();
	МассивАтрибутов = СписочныеАтрибуты.Выгрузить(Новый Структура("ТипОбъекта, КлассТабличнаяЧасть", 0, Ложь)).ВыгрузитьКолонку("АтрибутКласса");
	Если МассивАтрибутов.Количество() > 0 Тогда
		ЗаполнитьЗначенияСписочныхАтрибутов(ИсточникЗаполнения, МассивАтрибутов);
	КонецЕсли;
	
	ЗаполнитьЗначенияТабличныхАтрибутов(ИсточникЗаполнения);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НайтиНовыйИД(ТаблицаФормы, КолонкаИД, Знач МинИД = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(МинИД) Тогда
		МинИД = 1;
	КонецЕсли;
	
	НовыйИД = Макс(ТаблицаФормы.Количество() + 1, МинИД);
	СтруктураПоиска = Новый Структура(КолонкаИД, НовыйИД);
	
	Найдено = Истина;
	Пока Найдено Цикл
		Найдено = (ТаблицаФормы.НайтиСтроки(СтруктураПоиска).Количество() > 0);
		Если Найдено Тогда
			НовыйИД = НовыйИД + 1;
			СтруктураПоиска[КолонкаИД] = НовыйИД;
		КонецЕсли;
	КонецЦикла;
	
	Возврат НовыйИД;
	
КонецФункции

// Атрибуты.

&НаСервере
Функция ПолучитьДополненныйСписокРодителей(Знач ИсточникЗаполнения)
	
	Если ИсточникЗаполнения = Неопределено Тогда
		ИсточникЗаполнения = Справочники.Классы.ПустаяСсылка();
	КонецЕсли;
	
	ПараметрСписокРодителей = СписокРодителей.Выгрузить();
	ПараметрСписокРодителей.Колонки.Добавить("КлассДляЧтения", Новый ОписаниеТипов("СправочникСсылка.Классы"));
	ПараметрСписокРодителей.ЗаполнитьЗначения(ИсточникЗаполнения, "КлассДляЧтения");
	
	Если ПараметрСписокРодителей.Количество() = 0 Тогда
		ПоследняяСтрока = ПараметрСписокРодителей.Добавить();
		ПоследняяСтрока.Класс          = ИсточникЗаполнения;
		ПоследняяСтрока.КлассДляЧтения = ИсточникЗаполнения;
		ПоследняяСтрока.Уровень        = ПараметрСписокРодителей.Количество();
	Иначе
		ПоследняяСтрока = ПараметрСписокРодителей[ПараметрСписокРодителей.Количество() - 1];
		Если ПоследняяСтрока.Класс = Объект.Класс.Ссылка Тогда
			ПоследняяСтрока.Класс = ИсточникЗаполнения;
		ИначеЕсли НЕ ПоследняяСтрока.Класс = ИсточникЗаполнения Тогда
			ПоследняяСтрока = ПараметрСписокРодителей.Добавить();
			ПоследняяСтрока.Класс          = ИсточникЗаполнения;
			ПоследняяСтрока.КлассДляЧтения = ИсточникЗаполнения;
			ПоследняяСтрока.Уровень        = ПараметрСписокРодителей.Количество();
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПараметрСписокРодителей;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьАтрибуты(ИсточникЗаполнения)
	
	// Получаем иерархию классов для получения наследуемых атрибутов и значений.
	ТипОбъектНоменклатуры = Тип("СправочникСсылка.ОбъектыНоменклатуры");
	ТипНоменклатураКласса = Тип("СправочникСсылка.НоменклатураКласса");
	ТипКласс              = Тип("СправочникСсылка.Классы");
	ПустойКласс           = Справочники.Классы.ПустаяСсылка();
	ОписаниеТиповБулево   = Новый ОписаниеТипов("Булево");
	ОписаниеТиповСсылка   = Новый ОписаниеТипов("СправочникСсылка.Классы, СправочникСсылка.НоменклатураКласса");
	
	МассивТипов = ОписаниеТиповСсылка.Типы();
	МассивТипов.Добавить(ТипОбъектНоменклатуры);
	ОписаниеТиповСоставной = Новый ОписаниеТипов(МассивТипов);
	
	МассивСписочныхАктуальных = Новый Массив;
	СоответствиеАтрибутСтрока = Новый Соответствие;
	
	ПараметрСписокРодителей = ПолучитьДополненныйСписокРодителей(ИсточникЗаполнения);
	ТаблицаАтрибутов = Справочники.Классы.ПолучитьТаблицуАтрибутов(ПараметрСписокРодителей);
	
	ТаблицаАтрибутов.Колонки.Добавить("НуженИсточникЗначений",    ОписаниеТиповБулево);
	ТаблицаАтрибутов.Колонки.Добавить("СоставнойТипЗначения",     ОписаниеТиповБулево);
	ТаблицаАтрибутов.Колонки.Добавить("ЭтоВложенныйАтрибут",      ОписаниеТиповБулево);
	ТаблицаАтрибутов.Колонки.Добавить("ЭтотАтрибутВШаблоне", 
		Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(1,0,ДопустимыйЗнак.Неотрицательный)));
	ТаблицаАтрибутов.Колонки.Добавить("ТипЗначенияПредставление", Новый ОписаниеТипов("Строка"));
	ТаблицаАтрибутов.Колонки.Добавить("ЗначениеАтрибутаКлассаСоставное", ОписаниеТиповСоставной); 
	
	ТаблицаСписочныеАтрибуты = РеквизитФормыВЗначение("СписочныеАтрибуты");
	
	СтруктураАтрибутов = ПолучитьАтрибутыШаблонов(Объект.ШаблонКодаКласса, Объект.ШаблонНаименованияКласса, 
		Объект.ШаблонКодаНоменклатуры, Объект.ШаблонНаименованияНоменклатуры, 
		Объект.ШаблонКодаОбъекта, Объект.ШаблонНаименованияОбъекта);
	
	ТипЧисло  = Тип("Число");
	ТипДата   = Тип("Дата");
	ТипСтрока = Тип("Строка");
	
	Для Каждого СтрокаТЗ ИЗ ТаблицаАтрибутов Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЗ.ТипЗначения) И ЗначениеЗаполнено(СтрокаТЗ.ТипЗначенияРеквизита) Тогда
			СтрокаТЗ.ТипЗначения = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ТипЗначенияРеквизита);
		КонецЕсли;
		ТипЗначения = СтрокаТЗ.ТипЗначения;
		
		Если ЗначениеЗаполнено(ТипЗначения) Тогда
			СтрокаТЗ.ЗначениеАтрибутаКласса = ТипЗначения.ПривестиЗначение(СтрокаТЗ.ЗначениеАтрибутаКласса);
			Если ТипЗначения.СодержитТип(ТипЧисло)
					ИЛИ ТипЗначения.СодержитТип(ТипДата) Тогда
				СтрокаТЗ.МинЗначение  = ТипЗначения.ПривестиЗначение(СтрокаТЗ.МинЗначение);
				СтрокаТЗ.МаксЗначение = ТипЗначения.ПривестиЗначение(СтрокаТЗ.МаксЗначение);
			КонецЕсли;
		КонецЕсли;
		СтрокаТЗ.ЭтоВложенныйАтрибут = (ТипЗнч(СтрокаТЗ.АтрибутКласса) = Тип("СправочникСсылка.ВложенныеАтрибутыКласса"));
		Если (НЕ СтруктураАтрибутов.АтрибутыШаблонаКласса = Неопределено) 
				И (НЕ СтруктураАтрибутов.АтрибутыШаблонаКласса.Найти(СтрокаТЗ.АтрибутКласса) = Неопределено) Тогда
			СтрокаТЗ.ЭтотАтрибутВШаблоне = 1;
		ИначеЕсли (НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры = Неопределено) 
				И (НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры.Найти(СтрокаТЗ.АтрибутКласса) = Неопределено) Тогда
			СтрокаТЗ.ЭтотАтрибутВШаблоне = 2;
		ИначеЕсли (НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта = Неопределено) 
				И (НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта.Найти(СтрокаТЗ.АтрибутКласса) = Неопределено) Тогда
			СтрокаТЗ.ЭтотАтрибутВШаблоне = 3;
		КонецЕсли;
		
		// Проверка типа атрибута.
		КлассИлиНоменклатура   = НЕ СтрокаТЗ.ЭтоВложенныйАтрибут И ОписаниеТиповСсылка.СодержитТип(СтрокаТЗ.ТипЗначения.Типы()[0]);
		ЕстьНоменклатураКласса = НЕ СтрокаТЗ.ЭтоВложенныйАтрибут И СтрокаТЗ.ТипЗначения.СодержитТип(ТипНоменклатураКласса);
		ЕстьОбъектНоменклатуры = НЕ СтрокаТЗ.ЭтоВложенныйАтрибут И СтрокаТЗ.ТипЗначения.СодержитТип(ТипОбъектНоменклатуры);
		
		СтрокаТЗ.СоставнойТипЗначения = (ЕстьНоменклатураКласса ИЛИ ЕстьОбъектНоменклатуры);
		СтрокаТЗ.НуженИсточникЗначений = (КлассИлиНоменклатура ИЛИ ЕстьОбъектНоменклатуры);
		
		// Представление значения атрибута.
		Если КлассИлиНоменклатура И НЕ СтрокаТЗ.СоставнойТипЗначения 
				И ЗначениеЗаполнено(СтрокаТЗ.ИсточникЗначений) Тогда
			СтрокаТЗ.ТипЗначенияПредставление = "(" + Строка(СтрокаТЗ.ИсточникЗначений) + ")";
		Иначе
			СтрокаТЗ.ТипЗначенияПредставление = "(" + Строка(СтрокаТЗ.ТипЗначения) + ")";
		КонецЕсли;
		
		Если КлассИлиНоменклатура И НЕ ЕстьОбъектНоменклатуры
				И НЕ ТипЗнч(СтрокаТЗ.ИсточникЗначений) = ТипКласс Тогда
			СтрокаТЗ.ИсточникЗначений = ПустойКласс;
		КонецЕсли;
		
		Если СтрокаТЗ.СоставнойТипЗначения Тогда
			СтрокаТЗ.ЗначениеАтрибутаКлассаСоставное = ?(ЗначениеЗаполнено(СтрокаТЗ.ЗначениеАтрибутаКласса),
				СтрокаТЗ.ЗначениеАтрибутаКласса, СтрокаТЗ.ИсточникЗначений);
		КонецЕсли;
		
		Если СтрокаТЗ.СтатусНаследования <= 3 И ЗначениеЗаполнено(ТипЗначения) И НЕ ТипЗначения.СодержитТип(ТипСтрока) 
				И (СтрокаТЗ.МножественноеЗначение ИЛИ СтрокаТЗ.СписокДоступныхЗначений) Тогда
			
			МассивСписочныхАктуальных.Добавить(СтрокаТЗ.АтрибутКласса);
			
			Найдено = ТаблицаСписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, СтрокаТЗ.АтрибутКласса));
			Если Найдено.Количество() = 0 Тогда
				СписочныйАтрибут = ТаблицаСписочныеАтрибуты.Добавить();
				СписочныйАтрибут.ИДАтрибута          = НайтиНовыйИД(ТаблицаСписочныеАтрибуты, "ИДАтрибута", 2);
				СписочныйАтрибут.АтрибутКласса       = СтрокаТЗ.АтрибутКласса;
				СписочныйАтрибут.КлассТабличнаяЧасть = СтрокаТЗ.КлассТабличнаяЧасть;
				СписочныйАтрибут.ТипОбъекта          = 0;
				СписочныйАтрибут.ИсточникЗначений    = СтрокаТЗ.ИсточникЗначений;
				СоответствиеАтрибутСтрока.Вставить(СтрокаТЗ.АтрибутКласса, СписочныйАтрибут);
			Иначе
				СоответствиеАтрибутСтрока.Вставить(СтрокаТЗ.АтрибутКласса, Найдено[0]);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Объект.Атрибуты.Загрузить(ТаблицаАтрибутов);
	
	// Удаляем лишние списочные атрибуты.
	КолВо = ТаблицаСписочныеАтрибуты.Количество();
	Для Н = 1 По КолВо Цикл
		СписочныйАтрибут = ТаблицаСписочныеАтрибуты[КолВо - Н];
		Если СписочныйАтрибут.ТипОбъекта = 0 
				И СоответствиеАтрибутСтрока[СписочныйАтрибут.АтрибутКласса] = Неопределено Тогда
			ТаблицаСписочныеАтрибуты.Удалить(КолВо - Н);
		КонецЕсли;
	КонецЦикла;
	
	// Очищаем список страниц списочных атрибутов.
	КолВо = Элементы.ПереключательАтрибутов.СписокВыбора.Количество();
	Для Н = 1 По КолВо - 2 Цикл
		Элементы.ПереключательАтрибутов.СписокВыбора.Удалить(КолВо - Н);
	КонецЦикла;
	
	ТаблицаСписочныеАтрибуты.Сортировать("ТипОбъекта");
	
	// Настраиваем список страниц списочных атрибутов.
	Н = 0;
	Для Каждого АтрибутКласса ИЗ МассивСписочныхАктуальных Цикл
		СписочныйАтрибут = СоответствиеАтрибутСтрока[АтрибутКласса];
		Индекс = ТаблицаСписочныеАтрибуты.Индекс(СписочныйАтрибут);
		Если НЕ Индекс = Н Тогда
			ТаблицаСписочныеАтрибуты.Сдвинуть(Индекс, Н - Индекс);
		КонецЕсли;
		
		Элементы.ПереключательАтрибутов.СписокВыбора.Добавить(СписочныйАтрибут.ИДАтрибута, АтрибутКласса);
		Н = Н + 1;
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ТаблицаСписочныеАтрибуты, "СписочныеАтрибуты");
	
КонецПроцедуры

// Списочные атрибуты.

&НаСервере
Процедура ЗаполнитьЗначенияСписочныхАтрибутов(ИсточникЗаполнения, АтрибутКласса=Неопределено)
	
	ПараметрСписокРодителей = ПолучитьДополненныйСписокРодителей(ИсточникЗаполнения);
	
	ОтборПоАтрибуту = (ЗначениеЗаполнено(АтрибутКласса));
	
	ТаблицаАтрибутов = Справочники.Классы.ПолучитьЗначенияСписочныхАтрибутов(ПараметрСписокРодителей, АтрибутКласса);
	Если НЕ ОтборПоАтрибуту Тогда
		Объект.ЗначенияСписочныхАтрибутов.Загрузить(ТаблицаАтрибутов);
	Иначе
		Для Каждого СтрокаТЗ ИЗ ТаблицаАтрибутов Цикл
			НоваяСтрока = Объект.ЗначенияСписочныхАтрибутов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Табличные атрибуты.

&НаСервере
Функция ТекстЗапросаТаблицаРодителей()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Классы.Ссылка КАК КлассДляЧтения,
		|	Классы.Ссылка КАК Класс
		|ИЗ
		|	Справочник.Классы КАК Классы
		|ГДЕ
		|	НЕ Классы.ПометкаУдаления
		|	И Классы.Ссылка В (&КлассыДляЧтения)
		|ИТОГИ
		|	МАКСИМУМ(КлассДляЧтения)
		|ПО
		|	Класс,
		|	Класс ТОЛЬКО ИЕРАРХИЯ";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Процедура ПрочитатьЗначенияТабличныхАтрибутов(ПараметрСписокРодителей, ДанныеТабличныхАтрибутов, НовыйИДСтроки = 1, СоответствиеИДСтрок = Неопределено)
	
	// Чтение строк табличных атрибутов.
	ТаблицаАтрибутов = Справочники.Классы.ПолучитьСтрокиТабличныхАтрибутов(
		ПараметрСписокРодителей, ДанныеТабличныхАтрибутов);
	ТаблицаАтрибутов.Колонки.Добавить("ИДСтроки");
	
	Если ТаблицаАтрибутов.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	СоответствиеИДСтрокВложенных = Новый Соответствие;
	СтрокиТаблицы = Новый Массив;
	
	Для Каждого СтрокаТЗ ИЗ ТаблицаАтрибутов Цикл
		
		Если СтрокаТЗ.СтатусНаследования > 3 Тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеПоиска = ?(ЗначениеЗаполнено(СтрокаТЗ.ЗначениеАтрибутаКласса), 
			СтрокаТЗ.ЗначениеАтрибутаКласса, СтрокаТЗ.ИсточникЗначений);
			
		// Формируем соответствие для быстрого добавления элементов следующего уровня вложенности.
		МассивСтрок = СоответствиеИДСтрокВложенных[ЗначениеПоиска];
		Если МассивСтрок = Неопределено Тогда
			МассивСтрок = Новый Массив;
			СоответствиеИДСтрокВложенных.Вставить(ЗначениеПоиска, МассивСтрок);
			СтрокиТаблицы.Добавить(ЗначениеПоиска);
		КонецЕсли;
		
		// Ищем строки-родители для текущего уровня вложенности (если уровень - первый, то родитель - корень дерева).
		Если СоответствиеИДСтрок = Неопределено Тогда
			МассивРодителей = Новый Массив;
			МассивРодителей.Добавить(Новый Структура("ИДСтроки, ЗначениеАтрибутаКласса, СтатусНаследования", 0, Неопределено, 1));
		Иначе
			МассивРодителей = СоответствиеИДСтрок[СтрокаТЗ.КлассДляЧтения];
			Если МассивРодителей = Неопределено Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		// Добавляем строку в найденные строки-родители.
		Для Каждого СтрокаРодитель ИЗ МассивРодителей Цикл
			СтрокаТЗ.ИДСтроки = НовыйИДСтроки;
			
			СтрокаТЧ = Объект.СтрокиТабличныхАтрибутов.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТЗ);
			
			СтрокаТЧ.ИДСтрокиРодителя   = СтрокаРодитель.ИДСтроки;
			Если СтрокаРодитель.ИДСтроки > 0 И НЕ ЗначениеЗаполнено(СтрокаРодитель.ЗначениеАтрибутаКласса) Тогда
				// Если родительская строка - наследуемая, то и текущая строка - тоже наследуемая.
				СтрокаТЧ.СтатусНаследования = Макс(СтрокаТЧ.СтатусНаследования, СтрокаРодитель.СтатусНаследования);
				Если ЗначениеЗаполнено(СтрокаТЧ.ЗначениеАтрибутаКласса) И СтрокаТЧ.СтатусНаследования >= 3 Тогда 
					СтрокаТЧ.ИсточникЗначений = СтрокаТЧ.ЗначениеАтрибутаКласса;
					СтрокаТЧ.ЗначениеАтрибутаКласса = Справочники.Классы.ПустаяСсылка();
				КонецЕсли;
			КонецЕсли;
			МассивСтрок.Добавить(СтрокаТЧ);
			
			НовыйИДСтроки = НовыйИДСтроки + 1;
		КонецЦикла;
	КонецЦикла;
	
	// Чтение значений атрибутов строк.
	
	// Таблица родителей для чтения атрибутов строк.
	ТаблицаРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(СтрокиТаблицы);
	
	ДанныеТабличныхАтрибутовВложенных = Новый Массив;
	МассивОбъектовДляЧтения = Новый Массив;
	
	СтруктураПоискаРодителя = Новый Структура("Класс");
	
	// Вывод значений атрибутов строк.
	ЗначенияАтрибутов = Справочники.Классы.ПолучитьТаблицуАтрибутов(ТаблицаРодителей);
	Для Каждого СтрокаЗначений ИЗ ЗначенияАтрибутов Цикл
		Если СтрокаЗначений.МножественноеЗначение И СтрокаЗначений.КлассТабличнаяЧасть Тогда
			ДанныеТабличныхАтрибутовВложенных.Добавить(СтрокаЗначений.АтрибутКласса);
		КонецЕсли;
		
		МассивСтрок = СоответствиеИДСтрокВложенных[СтрокаЗначений.КлассДляЧтения];
		Если МассивСтрок = Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
		// Подмена объекта назначения в иерархии наследования.
		Если СтрокаЗначений.АтрибутКласса = ПланыВидовХарактеристик.АтрибутыКласса.ОбъектОперации 
				И ЗначениеЗаполнено(СтрокаЗначений.ЗначениеАтрибутаКласса) Тогда
			СтруктураПоискаРодителя.Класс = СтрокаЗначений.ЗначениеАтрибутаКласса;
			Найдено = СписокРодителей.НайтиСтроки(СтруктураПоискаРодителя);
			Если Найдено.Количество() > 0 Тогда
				СтрокаЗначений.ЗначениеАтрибутаКласса = Объект.Класс.Ссылка;
			КонецЕсли;
		КонецЕсли;
		
		// Добавление значений атрибутов строк в данные обработки.
		Для Каждого СтрокаТаб ИЗ МассивСтрок Цикл
			СтрокаТЧ = Объект.ЗначенияТабличныхАтрибутов.Добавить();
			СтрокаТЧ.ИДСтрокиРодителя        = СтрокаТаб.ИДСтрокиРодителя;
			СтрокаТЧ.АтрибутКласса           = СтрокаТаб.АтрибутКласса;
			СтрокаТЧ.ИДСтроки                = СтрокаТаб.ИДСтроки;
			СтрокаТЧ.АтрибутТаблицы          = СтрокаЗначений.АтрибутКласса;
			СтрокаТЧ.ЗначениеАтрибутаТаблицы = СтрокаЗначений.ЗначениеАтрибутаКласса;
		КонецЦикла;
	КонецЦикла;
	
	
	Если ДанныеТабличныхАтрибутовВложенных.Количество() > 0 Тогда
		ПрочитатьЗначенияТабличныхАтрибутов(
			ТаблицаРодителей, ДанныеТабличныхАтрибутовВложенных, НовыйИДСтроки, СоответствиеИДСтрокВложенных);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначенияТабличныхАтрибутов(ИсточникЗаполнения)
	
	Объект.СтрокиТабличныхАтрибутов.Очистить();
	Объект.ЗначенияТабличныхАтрибутов.Очистить();
	
	// Чтение строк табличных атрибутов.
	ДанныеТабличныхАтрибутов = СписочныеАтрибуты.Выгрузить(
		Новый Структура("ТипОбъекта, КлассТабличнаяЧасть", 0, Истина), "АтрибутКласса").ВыгрузитьКолонку("АтрибутКласса");
	Если ДанныеТабличныхАтрибутов.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	НовыйИДСтроки = 1;
	ПараметрСписокРодителей = ПолучитьДополненныйСписокРодителей(ИсточникЗаполнения);
	ПрочитатьЗначенияТабличныхАтрибутов(ПараметрСписокРодителей, ДанныеТабличныхАтрибутов, НовыйИДСтроки);
	
КонецПроцедуры

#КонецОбласти

////////////////////////////////////////////////////////////////////////////////
// Запись изменений в базу данных.

#Область ПроцедурыИФункцииЗаписиИзмененийВБазу

&НаСервере
Процедура ЗаписатьНаСервере()
	
	Если НЕ Редактирование Тогда
		Модифицированность = Ложь;
		Возврат;
	КонецЕсли;
	
	СнятьБлокировку = Истина;
	ЭтоНовый = Ложь;
	
	// Если формат и шаблон кода - наследуются от родителя, 
	// тогда в текущем классе записываем пустые значения.
	Если Объект.ФорматКодаКласса = Объект.ФорматКодаРодителя Тогда
		Объект.ФорматКодаКласса = "";
	КонецЕсли;
	Если Объект.ШаблонКодаКласса = Объект.ШаблонКодаРодителя Тогда
		Объект.ШаблонКодаКласса = Справочники.ШаблоныЗаполнения.ПустаяСсылка();
	КонецЕсли;
	
	// 1. Реквизиты шапки.
	Если ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
		Изменено = Ложь;
		РеквизитыШапки = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъекта(Объект.Класс.Ссылка, 
			"Наименование, НаименованиеПолное, Код, Родитель, ОтображатьВИерархииТО, 
			|ЗначениеАтрибута, НоменклатураКласса, ОбъектыНоменклатуры, Статус, КлассТабличнаяЧасть, 
			|НомерПоСчетчику, ШагСчетчика, ПрисвоенНомерПоШаблону, РежимКонтроляДублейПоНаименованию,
			|КонтрольДублейВПределахКласса, " + СписокРеквизитовКодированияИменования());
		Для Каждого КлючИЗначение ИЗ РеквизитыШапки Цикл
			Если НЕ Объект[КлючИЗначение.Ключ] = КлючИЗначение.Значение Тогда
				Изменено = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Иначе
		ЭтоНовый = Истина;
		Изменено = Истина;
		СнятьБлокировку = Ложь;
	КонецЕсли;
	
	Если Изменено Тогда
		Попытка
			СпрОбъект = ДанныеФормыВЗначение(Объект.Класс, Тип("СправочникОбъект.Классы"));
			ЗаполнитьЗначенияСвойств(СпрОбъект, Объект);
			СпрОбъект.Записать();
			ЗаполнитьЗначенияСвойств(Объект, СпрОбъект, "Код, ПрисвоенНомерПоШаблону, НомерПоСчетчику, ШагСчетчика");
			ЗначениеВДанныеФормы(СпрОбъект, Объект.Класс);
			
		Исключение
			ОбщегоНазначения.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации("Запись класса", УровеньЖурналаРегистрации.Ошибка, СпрОбъект.Метаданные(), 
				СпрОбъект.Ссылка, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
 			ВыбратьОбъектРедактирования(Неопределено);
			ОтменитьРедактированиеНаСервере();
			Возврат;
			
		КонецПопытки;
		
		Элементы.КлассыСписок.Обновить();
		Если ЭтоНовый Тогда
			Объект.Код = Объект.Класс.Код;
			Элементы.КлассыСписок.ТекущаяСтрока = Объект.Класс.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	ЗаписьЖурналаРегистрации("Запись класса", УровеньЖурналаРегистрации.Информация, 
		Метаданные.Справочники.Классы, Объект.Класс.Ссылка, "Начало записи");
	
	// Если формат и шаблон кода - наследуются от родителя, 
	// восстанавливаем значения родителя.
	Если НЕ ЗначениеЗаполнено(Объект.ШаблонКодаКласса) И ЗначениеЗаполнено(Объект.ШаблонКодаРодителя) Тогда
		Объект.ШаблонКодаКласса = Объект.ШаблонКодаРодителя;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.ФорматКодаКласса) И ЗначениеЗаполнено(Объект.ФорматКодаРодителя) Тогда
		Объект.ФорматКодаКласса = Объект.ФорматКодаРодителя;
	КонецЕсли;
	
	// 3. Атрибуты.
	ЗаписатьАтрибуты();
	
	// 4. Значения списочных атрибутов.
	ЗаписатьЗначенияСписочныхАтрибутов();
	
	// 5. Значения табличных атрибутов.
	ЗаписатьЗначенияТабличныхАтрибутов();
	
	ЗаписьЖурналаРегистрации("Запись класса", УровеньЖурналаРегистрации.Информация, 
		Метаданные.Справочники.Классы, Объект.Класс.Ссылка, "Окончание записи");
	
	Модифицированность = Ложь;
	
	Если СнятьБлокировку Тогда
		СнятьБлокировкуКласса();
	КонецЕсли;
	
КонецПроцедуры

// Простые атрибуты.

&НаСервере
Функция ТекстЗапросаИзмененияИспользованияВСоставеОбъектов()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ТаблицаИспользования.Класс КАК Класс,
		|	ТаблицаИспользования.АтрибутКласса КАК АтрибутКласса
		|ПОМЕСТИТЬ ВТ_ТаблицаИспользования
		|ИЗ
		|	&ТаблицаИспользования КАК ТаблицаИспользования
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МножественныеЗначенияАтрибутов.Класс КАК Класс,
		|	МножественныеЗначенияАтрибутов.АтрибутКласса КАК АтрибутКласса,
		|	-1 КАК ВидДействия
		|ПОМЕСТИТЬ ВТ_ДанныеСравнения
		|ИЗ
		|	РегистрСведений.МножественныеЗначенияАтрибутов КАК МножественныеЗначенияАтрибутов
		|ГДЕ
		|	МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса = &Класс
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ТаблицаИспользования.Класс,
		|	ВТ_ТаблицаИспользования.АтрибутКласса,
		|	1
		|ИЗ
		|	ВТ_ТаблицаИспользования КАК ВТ_ТаблицаИспользования
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДанныеСравнения.Класс КАК Класс,
		|	ВТ_ДанныеСравнения.АтрибутКласса КАК АтрибутКласса,
		|	СУММА(ВТ_ДанныеСравнения.ВидДействия) КАК ВидДействия
		|ИЗ
		|	ВТ_ДанныеСравнения КАК ВТ_ДанныеСравнения
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ДанныеСравнения.Класс,
		|	ВТ_ДанныеСравнения.АтрибутКласса
		|
		|ИМЕЮЩИЕ
		|	СУММА(ВТ_ДанныеСравнения.ВидДействия) <> 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	Класс,
		|	АтрибутКласса
		|АВТОУПОРЯДОЧИВАНИЕ";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция ТекстЗапросаИзмененияАтрибутовВременныеТаблицы()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ДанныеАтрибутов.АтрибутКласса,
		|	ДанныеАтрибутов.НомерСтроки КАК Порядок,
		|	ДанныеАтрибутов.РежимИспользования,
		|	ДанныеАтрибутов.РежимЗаполнения,
		|	ДанныеАтрибутов.МножественноеЗначение,
		|	ДанныеАтрибутов.СписокДоступныхЗначений,
		|	ДанныеАтрибутов.ИсточникЗначений,
		|	ДанныеАтрибутов.МинЗначение,
		|	ДанныеАтрибутов.МаксЗначение,
		|	ДанныеАтрибутов.ДобавлениеСтрокТабЧастиВНоменклатуреКласса,
		|	ДанныеАтрибутов.ДобавлениеСтрокТабЧастиВОбъектахНоменклатуры,
		|	ДанныеАтрибутов.Формат
		|ПОМЕСТИТЬ ВТ_ДанныеДобавленныхАтрибутов
		|ИЗ
		|	&ДанныеДобавленныхАтрибутов КАК ДанныеАтрибутов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеАтрибутов.АтрибутКласса,
		|	ДанныеАтрибутов.НомерСтроки КАК Порядок,
		|	ДанныеАтрибутов.РежимИспользования,
		|	ДанныеАтрибутов.РежимЗаполнения,
		|	ДанныеАтрибутов.МножественноеЗначение,
		|	ДанныеАтрибутов.СписокДоступныхЗначений,
		|	ДанныеАтрибутов.ИсточникЗначений,
		|	ДанныеАтрибутов.МинЗначение,
		|	ДанныеАтрибутов.МаксЗначение,
		|	ДанныеАтрибутов.ДобавлениеСтрокТабЧастиВНоменклатуреКласса,
		|	ДанныеАтрибутов.ДобавлениеСтрокТабЧастиВОбъектахНоменклатуры,
		|	ДанныеАтрибутов.Формат
		|ПОМЕСТИТЬ ВТ_ДанныеНаследованныхАтрибутов
		|ИЗ
		|	&ДанныеНаследованныхАтрибутов КАК ДанныеАтрибутов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НазначениеАтрибутов.АтрибутКласса,
		|	НазначениеАтрибутов.РежимИспользования,
		|	НазначениеАтрибутов.РежимЗаполнения,
		|	НазначениеАтрибутов.МножественноеЗначение,
		|	НазначениеАтрибутов.СписокДоступныхЗначений,
		|	НазначениеАтрибутов.ИсточникЗначений,
		|	НазначениеАтрибутов.МинЗначение,
		|	НазначениеАтрибутов.МаксЗначение,
		|	НазначениеАтрибутов.ДобавлениеСтрокТабЧастиВНоменклатуреКласса,
		|	НазначениеАтрибутов.ДобавлениеСтрокТабЧастиВОбъектахНоменклатуры,
		|	НазначениеАтрибутов.Формат,
		|	НазначениеАтрибутов.Порядок
		|ПОМЕСТИТЬ ВТ_ДанныеАтрибутовСохраненные
		|ИЗ
		|	РегистрСведений.НазначениеАтрибутов КАК НазначениеАтрибутов
		|ГДЕ
		|	НазначениеАтрибутов.Класс = &Класс
		|	И (НазначениеАтрибутов.АтрибутКласса ССЫЛКА ПланВидовХарактеристик.АтрибутыКласса
		|		ИЛИ НазначениеАтрибутов.АтрибутКласса ССЫЛКА Справочник.ВложенныеАтрибутыКласса)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДанныеДобавленныхАтрибутов.АтрибутКласса,
		|	ВТ_ДанныеДобавленныхАтрибутов.Порядок,
		|	ВТ_ДанныеДобавленныхАтрибутов.РежимИспользования,
		|	ВТ_ДанныеДобавленныхАтрибутов.РежимЗаполнения,
		|	ВТ_ДанныеДобавленныхАтрибутов.МножественноеЗначение,
		|	ВТ_ДанныеДобавленныхАтрибутов.СписокДоступныхЗначений,
		|	ВТ_ДанныеДобавленныхАтрибутов.ИсточникЗначений,
		|	ВТ_ДанныеДобавленныхАтрибутов.МинЗначение,
		|	ВТ_ДанныеДобавленныхАтрибутов.МаксЗначение,
		|	ВТ_ДанныеДобавленныхАтрибутов.ДобавлениеСтрокТабЧастиВНоменклатуреКласса,
		|	ВТ_ДанныеДобавленныхАтрибутов.ДобавлениеСтрокТабЧастиВОбъектахНоменклатуры,
		|	ВТ_ДанныеДобавленныхАтрибутов.Формат,
		|	ВЫБОР 
		|		КОГДА НЕ ВТ_ДанныеДобавленныхАтрибутов.РежимЗаполнения = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.РежимЗаполнения, НЕОПРЕДЕЛЕНО) 
		|			ТОГДА ИСТИНА 
		|		ИНАЧЕ ЛОЖЬ 
		|	КОНЕЦ КАК РежимЗаполненияИзменен
		|ПОМЕСТИТЬ ВТ_ДанныеИзмененныхАтрибутов
		|ИЗ
		|	ВТ_ДанныеДобавленныхАтрибутов КАК ВТ_ДанныеДобавленныхАтрибутов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеАтрибутовСохраненные КАК ВТ_ДанныеАтрибутовСохраненные
		|		ПО ВТ_ДанныеДобавленныхАтрибутов.АтрибутКласса = ВТ_ДанныеАтрибутовСохраненные.АтрибутКласса
		|ГДЕ
		|	(НЕ ВТ_ДанныеДобавленныхАтрибутов.РежимИспользования = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.РежимИспользования, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.РежимЗаполнения = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.РежимЗаполнения, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.МножественноеЗначение = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.МножественноеЗначение, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.СписокДоступныхЗначений = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.СписокДоступныхЗначений, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.ИсточникЗначений = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.ИсточникЗначений, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.МинЗначение = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.МинЗначение, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.МаксЗначение = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.МаксЗначение, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.ДобавлениеСтрокТабЧастиВНоменклатуреКласса = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.ДобавлениеСтрокТабЧастиВНоменклатуреКласса, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.ДобавлениеСтрокТабЧастиВОбъектахНоменклатуры = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.ДобавлениеСтрокТабЧастиВОбъектахНоменклатуры, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.Формат = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.Формат, НЕОПРЕДЕЛЕНО)
		|			ИЛИ НЕ ВТ_ДанныеДобавленныхАтрибутов.Порядок = ЕСТЬNULL(ВТ_ДанныеАтрибутовСохраненные.Порядок, НЕОПРЕДЕЛЕНО))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
