&НаКлиенте
Процедура АтрибутыЗначениеАтрибутаКлассаСоставноеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные.ТипЗначения.СодержитТип(Тип("СправочникСсылка.ОбъектыНоменклатуры")) Тогда
		КоличествоТипов = 3;
	Иначе
		КоличествоТипов = 2;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("КоличествоТипов, Ключ", 
		КоличествоТипов, ТекДанные.ЗначениеАтрибутаКлассаСоставное);
	ОткрытьФорму("Обработка.РедактированиеКлассов.Форма.ФормаВыборкаСоставногоЗначения", 
		ПараметрыОткрытия, Элемент, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыЗначениеАтрибутаКлассаСоставноеПриИзменении(Элемент)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТекДанные.ТипЗначения.СодержитТип(ТипЗнч(ТекДанные.ЗначениеАтрибутаКлассаСоставное)) Тогда
		ТекДанные.ИсточникЗначений = ТекДанные.ЗначениеАтрибутаКлассаСоставное;
		ТекДанные.ЗначениеАтрибутаКласса = ТекДанные.ТипЗначения.ПривестиЗначение();
	Иначе
		ТекДанные.ЗначениеАтрибутаКласса = ТекДанные.ЗначениеАтрибутаКлассаСоставное;
		Если НЕ ЗначениеЗаполнено(ТекДанные.ЗначениеАтрибутаКлассаСоставное) Тогда
			ТекДанные.ИсточникЗначений = ПредопределенноеЗначение("Справочник.Классы.ПустаяСсылка");
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТекДанные.ЗначениеАтрибутаКласса) Тогда
		ТекДанные.УровеньЗначения = 0;
	Иначе
		ТекДанные.УровеньЗначения = 1;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыЗначениеАтрибутаКлассаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Классы"))
			И НЕ ТекДанные.СписокДоступныхЗначений И ЗначениеЗаполнено(ТекДанные.ИсточникЗначений)Тогда
		СтандартнаяОбработка = Ложь;
		ОткрытьФорму("Справочник.Классы.ФормаВыбора", Новый Структура("РодительВерхнегоУровня", ТекДанные.ИсточникЗначений), Элемент, ЭтаФорма);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыМногострочноеРедактированиеПриИзменении(Элемент)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	
	ТипЧисло  = Ложь;
	ТипДата   = Ложь;
	ТипСтрока = Ложь;
	ТипБулево = Ложь;
	ПроверитьИспользованиеПримитивныхТипов(ТекДанные.ТипЗначения, ТипЧисло, ТипДата, ТипБулево, ТипСтрока);
	
	ТекДанные.МножественноеЗначениеКартинка = ?(ТекДанные.МножественноеЗначение И НЕ ТипСтрока, 0, 1);
	
	Элементы.АтрибутыФормат.Доступность = НЕ ТекДанные.МножественноеЗначение И (ТипЧисло ИЛИ ТипДата ИЛИ ТипСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыМножественноеЗначениеПриИзменении(Элемент)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	ЭтоСтрока = ТекДанные.ТипЗначения.СодержитТип(Тип("Строка"));
	ТекДанные.МножественноеЗначениеКартинка = ?(ТекДанные.МножественноеЗначение И НЕ ЭтоСтрока, 0, 1);
	Если ТекДанные.МножественноеЗначение И НЕ ЭтоСтрока Тогда
		ТекДанные.ЗначениеАтрибутаКласса = ТекДанные.ТипЗначения.ПривестиЗначение();
		ТекДанные.УровеньЗначения = 0;
	КонецЕсли;
	
	Если НЕ ЭтоСтрока И (ТекДанные.МножественноеЗначение ИЛИ ТекДанные.СписокДоступныхЗначений) Тогда
		ДобавитьСписочныйАтрибут(ТекДанные.АтрибутКласса, ТекДанные.КлассТабличнаяЧасть, ТекДанные.ИсточникЗначений);
	Иначе
		Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, ТекДанные.АтрибутКласса));
		Если Найдено.Количество() > 0 Тогда
			ЭлементСписка = Элементы.ПереключательАтрибутов.СписокВыбора.НайтиПоЗначению(Найдено[0].ИДАтрибута);
			Если НЕ ЭлементСписка = Неопределено Тогда
				Элементы.ПереключательАтрибутов.СписокВыбора.Удалить(ЭлементСписка);
			КонецЕсли;
			СписочныеАтрибуты.Удалить(Найдено[0]);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыСписокДоступныхЗначенийПриИзменении(Элемент)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	ТекДанные.СписокДоступныхЗначений = (ТекДанные.СписокДоступныхЗначенийПереключатель = 1);
	Элементы.АтрибутыИсточникЗначений.Доступность = НЕ ТекДанные.СписокДоступныхЗначений;
	
	Если ТекДанные.МножественноеЗначение ИЛИ ТекДанные.СписокДоступныхЗначений Тогда
		ДобавитьСписочныйАтрибут(ТекДанные.АтрибутКласса, ТекДанные.КлассТабличнаяЧасть, ТекДанные.ИсточникЗначений);
	Иначе
		Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, ТекДанные.АтрибутКласса));
		Если Найдено.Количество() > 0 Тогда
			ЭлементСписка = Элементы.ПереключательАтрибутов.СписокВыбора.НайтиПоЗначению(Найдено[0].ИДАтрибута);
			Если НЕ ЭлементСписка = Неопределено Тогда
				Элементы.ПереключательАтрибутов.СписокВыбора.Удалить(ЭлементСписка);
			КонецЕсли;
			СписочныеАтрибуты.Удалить(Найдено[0]);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыИсточникЗначенийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если НЕ Элемент.ВыбиратьТип Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	ПараметрыОткрытия = Новый Структура("КоличествоТипов, Ключ", 
		2, ТекДанные.ИсточникЗначений);
	ОткрытьФорму("Обработка.РедактированиеКлассов.Форма.ФормаВыборкаСоставногоЗначения", 
		ПараметрыОткрытия, Элемент, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыИсточникЗначенийПриИзменении(Элемент)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные.СоставнойТипЗначения Тогда
		Если НЕ ТекДанные.ТипЗначения.СодержитТип(ТипЗнч(ТекДанные.ЗначениеАтрибутаКлассаСоставное)) Тогда
			ТекДанные.ЗначениеАтрибутаКлассаСоставное = ТекДанные.ИсточникЗначений;
		КонецЕсли;
	КонецЕсли;
	Если ТекДанные.МножественноеЗначение Тогда
		НайденоАтрибуты = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, ТекДанные.АтрибутКласса));
		НайденоАтрибуты[0].ИсточникЗначений = ТекДанные.ИсточникЗначений;
		НайденоАтрибуты[0].КлассТабличнаяЧасть = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъекта(
			ТекДанные.ИсточникЗначений, "КлассТабличнаяЧасть");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыРежимИспользованияПриИзменении(Элемент)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Элементы.АтрибутыРежимЗаполнения.СписокВыбора.ЗагрузитьЗначения(
		ПолучитьСписокРежимовЗаполнения(ТекДанные.РежимИспользования, ТекДанные.РежимЗаполненияРодителя));
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийТаблицыФормыВсеАтрибуты

&НаКлиенте
Процедура ВсеАтрибутыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураАтрибутов = ПолучитьАтрибутыШаблонов(Объект.ШаблонКодаКласса, Объект.ШаблонНаименованияКласса, 
		Объект.ШаблонКодаНоменклатуры, Объект.ШаблонНаименованияНоменклатуры, 
		Объект.ШаблонКодаОбъекта, Объект.ШаблонНаименованияОбъекта);
	
	Если Элементы.ВсеАтрибуты.ВыделенныеСтроки.Количество() > 1 Тогда
		Для Каждого АтрибутКласса ИЗ Элементы.ВсеАтрибуты.ВыделенныеСтроки Цикл
			ДобавитьАтрибут(АтрибутКласса, СтруктураАтрибутов.АтрибутыШаблонаКласса, 
				СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры, СтруктураАтрибутов.АтрибутыШаблонаОбъекта);
		КонецЦикла;
	Иначе
		ДобавитьАтрибут(ВыбраннаяСтрока, СтруктураАтрибутов.АтрибутыШаблонаКласса, 
			СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры, СтруктураАтрибутов.АтрибутыШаблонаОбъекта);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийТаблицыФормыЗначенияСписочногоАтрибута

&НаКлиенте
Процедура ТекИсточникЗначенийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если НЕ Элемент.ВыбиратьТип Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОткрытия = Новый Структура("КоличествоТипов, Ключ", 
		2, ТекИсточникЗначений);
	ОткрытьФорму("Обработка.РедактированиеКлассов.Форма.ФормаВыборкаСоставногоЗначения", 
		ПараметрыОткрытия, Элемент, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ТекИсточникЗначенийПриИзменении(Элемент)
	
	НайденоАтрибуты = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", ТекСписочныйАтрибут));
	НайденоАтрибуты[0].ИсточникЗначений = ТекИсточникЗначений;
	Если НайденоАтрибуты[0].СоставнойТипЗначения Тогда
		Если НЕ НайденоАтрибуты[0].ТипЗначения.СодержитТип(ТипЗнч(НайденоАтрибуты[0].ЗначениеАтрибутаКлассаСоставное)) Тогда
			НайденоАтрибуты[0].ЗначениеАтрибутаКлассаСоставное = НайденоАтрибуты[0].ИсточникЗначений;
		КонецЕсли;
	КонецЕсли;
	
	НайденоАтрибуты = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, ТекСписочныйАтрибут));
	НайденоАтрибуты[0].ИсточникЗначений = ТекИсточникЗначений;
	НайденоАтрибуты[0].КлассТабличнаяЧасть = ?(ЗначениеЗаполнено(ТекИсточникЗначений), 
		УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъекта(
			ТекИсточникЗначений, "КлассТабличнаяЧасть"), Ложь);
	
	// Вывод значений для выбора.
	ВывестиЗначенияСписочногоАтрибутаНаСервере(ТекСписочныйАтрибут);
	
	НастроитьВидимостьЭлементовЗначенийСписочногоАтрибута();
	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияСписочногоАтрибутаПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.ЗначенияСписочногоАтрибута.ТекущиеДанные;
	НастроитьКомандыУправленияЗначениямиСписочногоАтрибута(Объект, Элементы, ТекДанные, Редактирование);
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияСписочногоАтрибутаИспользуемоеЗначениеПриИзменении(Элемент)
	
	ТекДанные = Элементы.ЗначенияСписочногоАтрибута.ТекущиеДанные;
	ПриИзмененииЗначенияСписочногоАтрибута(ТекДанные);
		
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияСписочногоАтрибутаДоступноеЗначениеПриИзменении(Элемент)
	
	ТекДанные = Элементы.ЗначенияСписочногоАтрибута.ТекущиеДанные;
	ПриИзмененииЗначенияСписочногоАтрибута(ТекДанные, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияСписочногоАтрибутаНоменклатураИспользуемоеЗначениеПриИзменении(Элемент)
	
	ТекДанные = Элементы.ЗначенияСписочногоАтрибутаНоменклатура.ТекущиеДанные;
	ПриИзмененииЗначенияСписочногоАтрибута(ТекДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияСписочногоАтрибутаНоменклатураДоступноеЗначениеПриИзменении(Элемент)
	
	ТекДанные = Элементы.ЗначенияСписочногоАтрибутаНоменклатура.ТекущиеДанные;
	ПриИзмененииЗначенияСписочногоАтрибута(ТекДанные);
	
