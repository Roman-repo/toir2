#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаНеНаследоватьАтрибут(Команда)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные = Неопределено ИЛИ ТекДанные.СтатусНаследования = 4 Тогда 
		Возврат;
	КонецЕсли;
	
	УдалитьАтрибут(3); // Построчно, удалять только унаследованные.
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаНаследоватьАтрибут(Команда)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Изменено = Ложь;
	ЭтоСтрока = ТекДанные.ТипЗначения.СодержитТип(Тип("Строка"));
	
	КолВоАтрибутов = Элементы.Атрибуты.ВыделенныеСтроки.Количество();
	Если КолВоАтрибутов = 1 И ТекДанные.СтатусНаследования = 4 Тогда
		ТекДанные.СтатусНаследования = 3;
		ПараметрыЗаполнения = ПолучитьЗначениеАтрибута(ТекДанные.АтрибутКласса);
		ЗаполнитьЗначенияСвойств(ТекДанные, ПараметрыЗаполнения);
		Если НЕ ЭтоСтрока И (ТекДанные.МножественноеЗначение ИЛИ ТекДанные.СписокДоступныхЗначений) Тогда
			ДобавитьСписочныйАтрибут(ТекДанные.АтрибутКласса, ТекДанные.КлассТабличнаяЧасть, ТекДанные.ИсточникЗначений);
		КонецЕсли;
		Изменено = Истина;
	ИначеЕсли КолВоАтрибутов > 1 Тогда
		Для Каждого ИДСтроки ИЗ Элементы.Атрибуты.ВыделенныеСтроки Цикл
			СтрокаТЧ = Объект.Атрибуты.НайтиПоИдентификатору(ИДСтроки);
			Если СтрокаТЧ.СтатусНаследования = 4 Тогда
				СтрокаТЧ.СтатусНаследования = 3;
				ПараметрыЗаполнения = ПолучитьЗначениеАтрибута(СтрокаТЧ.АтрибутКласса);
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, ПараметрыЗаполнения);
				Если НЕ ЭтоСтрока И (СтрокаТЧ.МножественноеЗначение ИЛИ СтрокаТЧ.СписокДоступныхЗначений) Тогда
					ДобавитьСписочныйАтрибут(СтрокаТЧ.АтрибутКласса, СтрокаТЧ.КлассТабличнаяЧасть, СтрокаТЧ.ИсточникЗначений);
				КонецЕсли;
				Изменено = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	НастроитьОтображениеДанныхАтрибута(Объект, Элементы, ТекРежимЗаполненияАтрибутаШаблона, Редактирование);
	Модифицированность = Модифицированность ИЛИ Изменено;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВложенныйАтрибут(Команда)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные = Неопределено 
			ИЛИ ТекДанные.МножественноеЗначение
			ИЛИ НЕ ТекДанные.НуженИсточникЗначений
			ИЛИ НЕ ТипЗнч(ТекДанные.АтрибутКласса) = Тип("ПланВидовХарактеристикСсылка.АтрибутыКласса")
			ИЛИ НЕ ЗначениеЗаполнено(ТекДанные.ИсточникЗначений) Тогда
		Возврат;
	КонецЕсли;
	
	СписокВыбора = ПолучитьСписокВложенныхАтрибутов(ТекДанные.ИсточникЗначений);
	Если НЕ СписокВыбора = Неопределено Тогда
		ТекущийЭлемент = Элементы.АтрибутыАтрибутКласса;
		ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьВложенныйАтрибутЗавершение", ЭтаФорма, ТекДанные.АтрибутКласса);
		ПоказатьВыборИзСписка(ОписаниеОповещения, СписокВыбора, Элементы.Атрибуты);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаУдалитьАтрибут(Команда)
	УдалитьАтрибут(1); // Построчно, без учета новых, добавленных из наборов.
КонецПроцедуры

&НаКлиенте
Процедура КомандаДобавитьАтрибут(Команда)
	
	ТекСтрока = Элементы.ВсеАтрибуты.ТекущаяСтрока;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураАтрибутов = ПолучитьАтрибутыШаблонов(Объект.ШаблонКодаКласса, Объект.ШаблонНаименованияКласса, 
		Объект.ШаблонКодаНоменклатуры, Объект.ШаблонНаименованияНоменклатуры, 
		Объект.ШаблонКодаОбъекта, Объект.ШаблонНаименованияОбъекта);
	
	Если Элементы.ВсеАтрибуты.ВыделенныеСтроки.Количество() > 1 Тогда
		Для Каждого АтрибутКласса ИЗ Элементы.ВсеАтрибуты.ВыделенныеСтроки Цикл
			ДобавитьАтрибут(АтрибутКласса, СтруктураАтрибутов.АтрибутыШаблонаКласса, 
				СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры, СтруктураАтрибутов.АтрибутыШаблонаОбъекта);
		КонецЦикла;
	Иначе
		ДобавитьАтрибут(ТекСтрока, СтруктураАтрибутов.АтрибутыШаблонаКласса, 
			СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры, СтруктураАтрибутов.АтрибутыШаблонаОбъекта);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаНаследоватьЗначение(Команда)
	
	ТекДанные = Элементы.ЗначенияСписочногоАтрибута.ТекущиеДанные;
	Если ТекДанные = Неопределено ИЛИ НЕ ТекДанные.СтатусНаследования = 4 Тогда 
		Возврат;
	КонецЕсли;
	
	ТекРодитель = ТекДанные.ПолучитьРодителя();
	// Если родитель ненаследуемый, то подчиненный не может быть наследуемым.
	Если НЕ ТекРодитель = Неопределено И ТекРодитель.СтатусНаследования > 3 Тогда
		Возврат;
	КонецЕсли;
	
	ТекДанные.СтатусНаследования = 3;
	ТекДанные.ДоступноеЗначение = ТекДанные.ДоступноеЗначениеНаследуемое;
	
	УстановитьСтатусНаследованияДляПодчиненных(ТекДанные);
	
	Найдено = Объект.ЗначенияСписочныхАтрибутов.НайтиСтроки(
		Новый Структура("АтрибутКласса, ЗначениеАтрибутаКласса", ТекСписочныйАтрибут, ТекДанные.ЗначениеАтрибутаКласса));
	Если Найдено.Количество() > 0 Тогда
		Найдено[0].СтатусНаследования   = ТекДанные.СтатусНаследования;
		Найдено[0].ДоступноеЗначение    = Истина;
		Найдено[0].ИспользуемоеЗначение = ТекДанные.ИспользуемоеЗначение;
	КонецЕсли;
	
	НастроитьКомандыУправленияЗначениямиСписочногоАтрибута(Объект, Элементы, ТекДанные, Редактирование);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаНеНаследоватьЗначение(Команда)
	
	ТекДанные = Элементы.ЗначенияСписочногоАтрибута.ТекущиеДанные;
	Если ТекДанные = Неопределено ИЛИ НЕ ТекДанные.СтатусНаследования = 3 Тогда 
		Возврат;
	КонецЕсли;
	
	ТекДанные.СтатусНаследования = 4;
	
	ТекРодитель = ТекДанные.ПолучитьРодителя();
	Если НЕ ТекДанные.МожноИзменятьДоступноеЗначение Тогда
		ТекДанные.ДоступноеЗначение = Ложь;
		ТекДанные.ИспользуемоеЗначение = Ложь;
		
		УстановитьСтатусНаследованияДляПодчиненных(ТекДанные);
	КонецЕсли;
	
	Найдено = Объект.ЗначенияСписочныхАтрибутов.НайтиСтроки(
		Новый Структура("АтрибутКласса, ЗначениеАтрибутаКласса", ТекСписочныйАтрибут, ТекДанные.ЗначениеАтрибутаКласса));
	Если Найдено.Количество() > 0 Тогда
		СтрокаАтрибута = Найдено[0];
		СтрокаАтрибута.СтатусНаследования   = ТекДанные.СтатусНаследования;
		СтрокаАтрибута.ДоступноеЗначение    = ТекДанные.ДоступноеЗначение И ТекДанные.МожноИзменятьДоступноеЗначение;
		СтрокаАтрибута.ИспользуемоеЗначение = ТекДанные.ИспользуемоеЗначение;
		
	ИначеЕсли ТекРодитель.СтатусНаследования = 3 И НЕ ТекРодитель.МожноИзменятьДоступноеЗначение Тогда
		СтрокаАтрибута = Объект.ЗначенияСписочныхАтрибутов.Добавить();
		
		СтрокаАтрибута.АтрибутКласса          = ТекСписочныйАтрибут;
		СтрокаАтрибута.ЗначениеАтрибутаКласса = ТекДанные.ЗначениеАтрибутаКласса;
		СтрокаАтрибута.СтатусНаследования     = ТекДанные.СтатусНаследования;
		
		СтрокаАтрибута.ДоступноеЗначение    = Ложь;
		СтрокаАтрибута.ИспользуемоеЗначение = Ложь;
	КонецЕсли;	
	
	НастроитьКомандыУправленияЗначениямиСписочногоАтрибута(Объект, Элементы, ТекДанные, Редактирование);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаУдалитьТехКарту(Команда)
	
	ТекСтрока = Элементы.ТехКарты.ТекущаяСтрока;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекДанные = Элементы.ТехКарты.ТекущиеДанные;
	Если ТекДанные.Новая Тогда
		ШаблонВопроса = НСтр("ru='Удалить новую тех.карту %1? Состав тех.карты будет утерян.'");
	Иначе
		ШаблонВопроса = НСтр("ru='Удалить тех.карту %1? Несохраненные изменения будут утеряны.'");
	КонецЕсли;
	ТекстВопроса = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
		ШаблонВопроса, Строка(ТекДанные.ТипТехКарты));
	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьТехКартуЗавершение", ЭтаФорма, ТекСтрока);
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаДобавитьТехОперацию(Команда)
	
	Если Элементы.ГруппаСтарницыРежимовПодбораОпераций.ТекущаяСтраница = Элементы.ГруппаВсеВидыОперацийПоСправочнику Тогда
		ВидОперации = Элементы.ВсеВидыОпераций.ТекущаяСтрока;
		ТекДанные = Элементы.ТехКарты.ТекущиеДанные;
		Если ВидОперации = Неопределено ИЛИ ТекДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		ОбъектОперации = Объект.Класс.Ссылка;
		ТипСтроки = 0;
	Иначе
		ТекДанные = Элементы.ДоступныеОперации.ТекущиеДанные;
		Если ТекДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Если ТекДанные.ТипСтроки > 1 Тогда
			ВидОперации = ТекДанные.Объект;
			ОбъектОперации = ТекДанные.ПолучитьРодителя().Объект;
			ТипСтроки = ?(ТекДанные.ТипСтроки = 2, 0, 2);
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ДобавитьТехОперацию(ВидОперации, ОбъектОперации, ТипСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаУдалитьТехОперацию(Команда)
	
	Выбраны = Элементы.СоставТехКарты.ВыделенныеСтроки;
	
	УдалитьТехОперацию(Выбраны, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИзменения(Команда)
	ЗаписатьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьКласс(Команда)
	
	Отказ = Ложь;
	ПроверитьЗаблокироватьРедактированиеКлассаНаСервере(, Отказ);
	
	Если НЕ Отказ Тогда
		Элементы.ГруппаПраваяКолонка.ТолькоПросмотр = Ложь;
		УстановитьРежимТолькоПросмотра(Ложь, ПравоИзменениеКлассов);
		Если ТекСписочныйАтрибут = ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ТехКарты")
				И ТекТаблицаТехКарты = ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ТехОперации") 
				И Элементы.ГруппаСтарницыРежимовПодбораОпераций.ТекущаяСтраница = Элементы.ГруппаДоступныеОперации Тогда
			РазвернутьСвернутьДеревоФормы(Элементы.ДоступныеОперации, ДоступныеОперации);
		ИначеЕсли ПереключательАтрибутов > 1 Тогда
			Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, ИДАтрибута", 0, ПереключательАтрибутов));
			Если НЕ ТекСписочныйАтрибут = ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ТехКарты") 
					И (Найдено.Количество() = 0 ИЛИ НЕ Найдено[0].КлассТабличнаяЧасть) Тогда
				//
				ВывестиЗначенияСписочногоАтрибутаНаСервере(ТекСписочныйАтрибут);
				НастроитьВидимостьЭлементовЗначенийСписочногоАтрибута();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьРедактирование(Команда)
	ОтменитьРедактированиеНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПодборОперацийПоСправочнику(Команда)
	
	Элементы.ПодборОперацийПоСправочнику.Пометка = Истина;
	Элементы.ПодборОперацийПоДоступнымОперациям.Пометка = Ложь;
	Элементы.ГруппаСтарницыРежимовПодбораОпераций.ТекущаяСтраница = Элементы.ГруппаВсеВидыОперацийПоСправочнику;
	Элементы.ГруппаКомандыДоступныхОпераций.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодборОперацийПоДоступнымОперациям(Команда)
	
	Элементы.ПодборОперацийПоСправочнику.Пометка = Ложь;
	Элементы.ПодборОперацийПоДоступнымОперациям.Пометка = Истина;
	Элементы.ГруппаСтарницыРежимовПодбораОпераций.ТекущаяСтраница = Элементы.ГруппаДоступныеОперации;
	Элементы.ГруппаКомандыДоступныхОпераций.Видимость = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьКодПоШаблону(Команда)
	
	Отказ = Ложь;
	Если НЕ ЗначениеЗаполнено(Объект.ШаблонКодаРодителя) Тогда
		ТекстСообщения = НСтр("ru='Не возможно сформировать код по шаблону. Не заполнен шаблон кода у класса-родителя.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , , , Отказ);
	КонецЕсли;
	Если НЕ Отказ И (НЕ ЗначениеЗаполнено(Объект.Класс.Ссылка) ИЛИ Модифицированность) Тогда
		ТекстСообщения = НСтр("ru='Перед формированием кода по шаблону необходимо записать класс.
			|Записать изменения в классе?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("СформироватьКодПоШаблонуЗавершение", ЭтаФорма), ТекстСообщения, РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	Если НЕ Отказ Тогда
		СформироватьКодПоШаблонуНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РазрвернутьВсеОперации(Команда)
	РазвернутьСвернутьДеревоФормы(Элементы.ДоступныеОперации, ДоступныеОперации);
КонецПроцедуры

&НаКлиенте
Процедура СвернутьВсеОперации(Команда)
	РазвернутьСвернутьДеревоФормы(Элементы.ДоступныеОперации, ДоступныеОперации, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура НастройкаНаследованияСтрок(Команда)
	
	Если НЕ ЗначениеЗаполнено(Объект.Класс.Ссылка) ИЛИ НЕ ЗначениеЗаполнено(ТекСписочныйАтрибут) Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		ТекстВопроса = НСтр("ru='Перед настройкой наследования строк необходимо записать изменения класса.
			|Записать изменения?'");
		ОписаниеОповещения = Новый ОписаниеОповещения("НастройкаНаследованияСтрокЗавершение", ЭтаФорма, Истина);
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		НастройкаНаследованияСтрокЗавершение(КодВозвратаДиалога.Да);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьРазвернутьТехКарты(Команда)
	
	Видимость = НЕ Элементы.ТехКарты.Видимость;
	
	Элементы.ТехКарты.Видимость = Видимость;
	Элементы.ТехКартыГруппаСтандартныеКоманды.Видимость = Видимость;
	Элементы.ТехКартыСвернутьРазвернутьТехКарты.Картинка = ?(Видимость,
		БиблиотекаКартинок.гкс_ПанельРазвернута, БиблиотекаКартинок.гкс_ПанельСвернута);
	
	Если Видимость Тогда
		Элементы.ЗначениеТабличногоАтрибутаОперации.Видимость = Ложь;
		Элементы.СвернутьРазвернутьТабличныеАтрибутыОпераций.Картинка = БиблиотекаКартинок.гкс_ПанельСвернута;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьРазвернутьТабличныеАтрибутыОпераций(Команда)
	
	Видимость = НЕ Элементы.ЗначениеТабличногоАтрибутаОперации.Видимость;
	
	Элементы.ЗначениеТабличногоАтрибутаОперации.Видимость = Видимость;
	Элементы.СвернутьРазвернутьТабличныеАтрибутыОпераций.Картинка = ?(Видимость,
		БиблиотекаКартинок.гкс_ПанельРазвернута, БиблиотекаКартинок.гкс_ПанельСвернута);
	
	Если Видимость Тогда
		Элементы.ТехКарты.Видимость = Ложь;
		Элементы.ТехКартыГруппаСтандартныеКоманды.Видимость = Ложь;
		Элементы.ТехКартыСвернутьРазвернутьТехКарты.Картинка = БиблиотекаКартинок.гкс_ПанельСвернута;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьРазвернутьДеревоКлассов(Команда)
	Элементы.ГруппаЛеваяКолонка.Видимость = НЕ Элементы.ГруппаЛеваяКолонка.Видимость;
	Элементы.СвернутьРазвернутьДеревоКлассов.Пометка = Элементы.ГруппаЛеваяКолонка.Видимость;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

////////////////////////////////////////////////////////////////////////////////
// Процедуры и функции управления интерфейсом пользователя

#Область ПроцедурыИФункцииУправленияИнтерфейсомПользователя

&НаКлиенте 
Процедура АтрибутПодчиненногоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	НайденоСтроки = КолонкиАтрибутовПодчиненныхОбъектов.НайтиСтроки(Новый Структура("ИмяПоля", Элемент.Имя));
	Если НайденоСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектНоменклатуры = Тип("СправочникСсылка.ОбъектыНоменклатуры");
	ТипНоменклатураКласса = Тип("СправочникСсылка.НоменклатураКласса");
	ТипКлассы             = Тип("СправочникСсылка.Классы");
	
	СтрокаАтрибута = НайденоСтроки[0];
	
	ЭтоОбъектНоменклатуры = СтрокаАтрибута.ТипЗначения.СодержитТип(ТипОбъектНоменклатуры);
	ЭтоНоменклатураКласса = СтрокаАтрибута.ТипЗначения.СодержитТип(ТипНоменклатураКласса);
	ЭтоКласс              = СтрокаАтрибута.ТипЗначения.СодержитТип(ТипКлассы);
	
	Если ЭтоКласс ИЛИ ЭтоНоменклатураКласса ИЛИ ЭтоОбъектНоменклатуры Тогда
		
		ТипИсточника  = ?(ЗначениеЗаполнено(СтрокаАтрибута.ИсточникЗначений), ТипЗнч(СтрокаАтрибута.ИсточникЗначений), Неопределено);
		ИсточникКласс = (ТипИсточника = ТипКлассы);
		ИсточникНоменклатура = (ТипИсточника = ТипНоменклатураКласса);
		СоставнойТип = (ЭтоНоменклатураКласса И ИсточникКласс
				ИЛИ ЭтоОбъектНоменклатуры И ИсточникКласс);
		
		Если НЕ СтрокаАтрибута.СписокДоступныхЗначений Тогда
			Если НЕ СоставнойТип Тогда
				Если ЭтоНоменклатураКласса И ИсточникКласс Тогда
					СтандартнаяОбработка = Ложь;
					
					ПараметрыОтбора = Новый Структура("Класс, ЭтоГруппа", СтрокаАтрибута.ИсточникЗначений, Ложь);
					
					ПараметрыВыбора = Новый Структура();
					ПараметрыВыбора.Вставить("Отбор", ПараметрыОтбора);
					
					ФормаВыбора = ПолучитьФорму("Справочник.НоменклатураКласса.ФормаВыбора", ПараметрыВыбора, Элемент, УникальныйИдентификатор);
					ФормаВыбора.Элементы.Список.Отображение = ОтображениеТаблицы.Список;
					
					ФормаВыбора.Открыть();
				КонецЕсли;
			Иначе
				Если ЭтоНоменклатураКласса И ИсточникКласс Тогда
					СтандартнаяОбработка = Ложь;
					
					ФормаВыбора = ПолучитьФорму("Справочник.НоменклатураКласса.ФормаВыбора", , Элемент, УникальныйИдентификатор);
					
					УправлениеНСИФункцииКлиентСерверПереопределяемый.УстановитьЭлементОтбораДинамическогоСписка(ФормаВыбора.Список, 
						"Класс", СтрокаАтрибута.ИсточникЗначений, ВидСравненияКомпоновкиДанных.ВИерархии,, Истина);
					ФормаВыбора.Элементы.Список.РодительВерхнегоУровня = 
						ПолучитьРодителяПоКлассу(СтрокаАтрибута.ИсточникЗначений);
					
					ФормаВыбора.Открыть();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ЗаписатьНаСервере();
		Закрыть();
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Нет Тогда 
		Модифицированность = Ложь;
		Если ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
			СнятьБлокировкуКласса();
		КонецЕсли;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АтрибутыПередУдалениемЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если НЕ РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	Для Каждого СтрокаТЧ ИЗ ДополнительныеПараметры.СтрокиКУдалению Цикл
		// Защита от ошибки.
		Если Объект.Атрибуты.НайтиПоИдентификатору(СтрокаТЧ.ПолучитьИдентификатор()) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаТЧ.МножественноеЗначение ИЛИ СтрокаТЧ.СписокДоступныхЗначений Тогда
			Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, СтрокаТЧ.АтрибутКласса));
			Если Найдено.Количество() > 0 Тогда
				ЭлементСписка = Элементы.ПереключательАтрибутов.СписокВыбора.НайтиПоЗначению(Найдено[0].ИДАтрибута);
				Если НЕ ЭлементСписка = Неопределено Тогда
					Элементы.ПереключательАтрибутов.СписокВыбора.Удалить(ЭлементСписка);
				КонецЕсли;
				СписочныеАтрибуты.Удалить(Найдено[0]);
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаТЧ.СтатусНаследования = 3 Тогда
			СтрокаТЧ.СтатусНаследования = 4;
			СтрокаТЧ.ЗначениеАтрибутаКласса = СтрокаТЧ.ТипЗначения.ПривестиЗначение();
			СтрокаТЧ.УровеньЗначения = 0;
		Иначе
			Объект.Атрибуты.Удалить(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
	НастроитьОтображениеДанныхАтрибута(Объект, Элементы, ТекРежимЗаполненияАтрибутаШаблона, Редактирование);
	
	Если ЗначениеЗаполнено(ДополнительныеПараметры.АктивироватьАтрибут) Тогда
		Элементы.ВсеАтрибуты.ТекущаяСтрока = ДополнительныеПараметры.АктивироватьАтрибут;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьТехКартуЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если НЕ РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ТекСтрока = ТехКарты.НайтиПоИдентификатору(ДополнительныеПараметры);
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТехКарты.Удалить(ТекСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьКодПоШаблонуЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если НЕ РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьНаСервере();
	СформироватьКодПоШаблонуНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаНаследованияСтрокЗавершение(РезультатВопроса, ДополнительныеПараметры=Неопределено) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Если ДополнительныеПараметры = Истина Тогда
			ЗаписатьНаСервере();
		КонецЕсли;
		
		НайденоАтрибуты = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", ТекСписочныйАтрибут));
		ПараметрыОткрытия = Новый Структура("Класс, ТабличнаяЧасть, ИсточникЗначений",
			Объект.Класс.Ссылка, ТекСписочныйАтрибут, НайденоАтрибуты[0].ИсточникЗначений);
		ОткрытьФорму("Обработка.НастройкаНаследованияСтрокТабличныхЧастей.Форма", 
			ПараметрыОткрытия, ЭтаФорма, УникальныйИдентификатор);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВложенныйАтрибутЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Найдено = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", ДополнительныеПараметры));
	Если Найдено.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	ИндексВставки = Объект.Атрибуты.Индекс(Найдено[0]) + 1;
	
	ВложенныйАтрибут = ПолучитьВложенныйАтрибут(ДополнительныеПараметры, ВыбранныйЭлемент.Значение);
	
	// Защита от дублирования.
	Найдено = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", ВложенныйАтрибут));
	Если Найдено.Количество() > 0 Тогда
		Элементы.Атрибуты.ТекущаяСтрока = Найдено[0].ПолучитьИдентификатор();
		Возврат;
	КонецЕсли;
	
	СтрокаАтрибут = Объект.Атрибуты.Вставить(ИндексВставки);
	СтрокаАтрибут.АтрибутКласса                 = ВложенныйАтрибут;
	СтрокаАтрибут.СтатусНаследования            = 2;
	СтрокаАтрибут.МножественноеЗначениеКартинка = 1;
	СтрокаАтрибут.ЭтоВложенныйАтрибут           = Истина;
	СтрокаАтрибут.ТипЗначения                   = ПолучитьТипАтрибута(ВыбранныйЭлемент.Значение, ДополнительныеПараметры);
	СтрокаАтрибут.ТипЗначенияПредставление      = "(" + Строка(СтрокаАтрибут.ТипЗначения) + ")";
	
	Элементы.Атрибуты.ТекущаяСтрока = СтрокаАтрибут.ПолучитьИдентификатор();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьТипАтрибута(АтрибутКласса, ИсточникЗначений)
	
	Если ТипЗнч(АтрибутКласса) = Тип("ПланВидовХарактеристикСсылка.АтрибутыКласса") Тогда
		Результат = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъекта(АтрибутКласса, "ТипЗначения");
	ИначеЕсли ТипЗнч(АтрибутКласса)  = Тип("ПеречислениеСсылка.РеквизитыКлассаНоменклатуры") И ЗначениеЗаполнено(АтрибутКласса) Тогда
		
		ТипИсточника = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъекта(ИсточникЗначений, "ТипЗначения");
		МетаданныеСпр = Метаданные.НайтиПоТипу(ТипИсточника.Типы()[0]);
		Если НЕ МетаданныеСпр = Неопределено Тогда
			РеквизитСпр = Перечисления.РеквизитыКлассаНоменклатуры.ПолучитьМетаданныеРеквизита(МетаданныеСпр, АтрибутКласса);
			Если НЕ РеквизитСпр = Неопределено Тогда
				Результат = РеквизитСпр.Тип;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте 
Процедура ПроверкаБлокировкиКласса() Экспорт
	
	Если ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
		Пользователь = Неопределено;
		ОбъектЗаблокирован = ОбъектРедактируется(Объект.Класс.Ссылка, Ложь, Пользователь);
		
		Если ОбъектЗаблокирован Тогда
			ШаблонПредупреждения = НСтр("ru = 'Класс ''%1'' заблокирован для редактирования пользователем ''%2''.'");
			ТекстПредупреждения = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
				ШаблонПредупреждения, Строка(Объект.Класс.Ссылка), Строка(Пользователь));
			ПоказатьПредупреждение(, ТекстПредупреждения);
			
			ВыбратьОбъектРедактирования(Неопределено);
			
			ОтменитьРедактированиеНаСервере();
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПереключитьСтраницуФормы()
	
	Если ПереключательАтрибутов = 0 Тогда
		Элементы.ГруппаСтарницыАтрибутов.ТекущаяСтраница = Элементы.ГруппаСтраницаОбщие;
	ИначеЕсли ПереключательАтрибутов = 1 Тогда
		Элементы.ГруппаСтарницыАтрибутов.ТекущаяСтраница = Элементы.ГруппаСтраницаПростыеАтрибуты;
		НастроитьОтображениеДанныхАтрибута(Объект, Элементы, ТекРежимЗаполненияАтрибутаШаблона, Редактирование);
	Иначе
		Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, ИДАтрибута", 0, ПереключательАтрибутов));
		Если Найдено.Количество() > 0 Тогда
			ТекСписочныйАтрибут = Найдено[0].АтрибутКласса;
			НайденоАтрибуты = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", ТекСписочныйАтрибут));
			Если ТекСписочныйАтрибут = ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ТехКарты") 
					И НайденоАтрибуты[0].МножественноеЗначение Тогда
				// Вывод тех.карты.
				ВывестиТехкартыНаСервере();
				
				РазвернутьСвернутьДеревоФормы(Элементы.ДоступныеОперации, ДоступныеОперации);
				
				Элементы.ГруппаСтарницыАтрибутов.ТекущаяСтраница = Элементы.ГруппаСтраницаТехнологическаяКарта;
			ИначеЕсли Найдено[0].КлассТабличнаяЧасть И НайденоАтрибуты[0].МножественноеЗначение Тогда
				// Вывод табличной части.
				ВывестиЗначенияТабличногоАтрибутаНаСервере(ТекСписочныйАтрибут);
				
				Элементы.ГруппаСтарницыАтрибутов.ТекущаяСтраница = Элементы.ГруппаСтраницаТабличныйАтрибут;
			Иначе
				// Вывод значений для выбора.
				ВывестиЗначенияСписочногоАтрибутаНаСервере(ТекСписочныйАтрибут);
				
				Элементы.ГруппаСтарницыАтрибутов.ТекущаяСтраница = Элементы.ГруппаСтраницаСписочныйАтрибут;
				
				// Настройка элементов формы.
				НастроитьВидимостьЭлементовЗначенийСписочногоАтрибута();
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьСпискиАтрибутовДляОбработки(Объект, Элементы)
	
	ИДСтроки = Элементы.Атрибуты.ТекущаяСтрока;
	ТекДанные = Неопределено;
	Если НЕ ИДСтроки = Неопределено Тогда
		ТекДанные = Объект.Атрибуты.НайтиПоИдентификатору(ИДСтроки);
	КонецЕсли;
	
	СтатусыНаследования = Новый Соответствие;
	НаборыАтрибутов = Новый Соответствие;
	ЕдиничныеАтрибуты = Новый Массив;
	
	КолВоАтрибутов = Элементы.Атрибуты.ВыделенныеСтроки.Количество();
	Если КолВоАтрибутов > 1 Тогда
		Для Каждого ИДСтроки ИЗ Элементы.Атрибуты.ВыделенныеСтроки Цикл
			СтрокаТЧ = Объект.Атрибуты.НайтиПоИдентификатору(ИДСтроки);
			
			// Выделенные строки в разрезе статусов наследования.
			МассивСтрок = СтатусыНаследования[СтрокаТЧ.СтатусНаследования];
			Если МассивСтрок = Неопределено Тогда
				МассивСтрок = Новый Массив;
				СтатусыНаследования.Вставить(СтрокаТЧ.СтатусНаследования, МассивСтрок);
			КонецЕсли;
			МассивСтрок.Добавить(СтрокаТЧ);
			
			Если СтрокаТЧ.СтатусНаследования <= 3 Тогда 
				
				// Единичные строки.
				Если НЕ ЗначениеЗаполнено(СтрокаТЧ.НаборАтрибутов) ИЛИ СтрокаТЧ.СтатусНаследования = 3 Тогда
					ЕдиничныеАтрибуты.Добавить(СтрокаТЧ);
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли НЕ ТекДанные = Неопределено Тогда
		// Выделенные строки в разрезе статусов наследования.
		МассивСтрок = Новый Массив;
		МассивСтрок.Добавить(ТекДанные);
		СтатусыНаследования.Вставить(?(ТекДанные = Неопределено, 0, ТекДанные.СтатусНаследования), МассивСтрок);
		Если ТекДанные.СтатусНаследования <= 4 Тогда
			// Единичные строки.
			Если НЕ ЗначениеЗаполнено(ТекДанные.НаборАтрибутов) ИЛИ ТекДанные.СтатусНаследования = 3 Тогда
				ЕдиничныеАтрибуты.Добавить(ТекДанные);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Новый Структура("СтатусыНаследования, НаборыАтрибутов, ЕдиничныеАтрибуты", СтатусыНаследования, НаборыАтрибутов, ЕдиничныеАтрибуты);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПроверитьИспользованиеПримитивныхТипов(ОписаниеТипов, ТипЧисло, ТипДата, ТипБулево, ТипСтрока)
	
	ТипЧисло  = Ложь;
	ТипДата   = Ложь;
	ТипСтрока = Ложь;
	ТипБулево = Ложь;
	Если ОписаниеТипов.СодержитТип(Тип("Число")) Тогда
		ТипЧисло = Истина;
	ИначеЕсли ОписаниеТипов.СодержитТип(Тип("Дата")) Тогда
		ТипДата = Истина;
	ИначеЕсли ОписаниеТипов.СодержитТип(Тип("Строка")) Тогда
		ТипСтрока = Истина;
	ИначеЕсли ОписаниеТипов.СодержитТип(Тип("Булево")) Тогда
		ТипБулево = Истина;
	КонецЕсли;
	
	Возврат ТипЧисло ИЛИ ТипСтрока ИЛИ ТипДата ИЛИ ТипБулево;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьПараметрыВыбора(Имя, Значение)
	
	ПараметрВыбора = Новый ПараметрВыбора(Имя, Значение);
	Результат = Новый Массив;
	Результат.Добавить(ПараметрВыбора);
	Возврат Новый ФиксированныйМассив(Результат);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция РежимЗаполненияСтроже(Режим1, Режим2)
	
	Если Режим1 = Режим2 Тогда
		Результат = Режим1;
	ИначеЕсли НЕ ЗначениеЗаполнено(Режим1) И ЗначениеЗаполнено(Режим2) Тогда
		Результат = Режим2;
	ИначеЕсли НЕ ЗначениеЗаполнено(Режим2) И ЗначениеЗаполнено(Режим1) Тогда
		Результат = Режим1;
	Иначе

		РежимыЗаполнения = "Перечисление.РежимыЗаполненияАтрибутов.";
		
		УровниРежимов = Новый Массив;
		УровниРежимов.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "Необязательный"));
		УровниРежимов.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляОбъекта"));
		УровниРежимов.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляНоменклатуры"));
		УровниРежимов.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляКласса"));
		УровниРежимов.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "ФиксированноеЗначение"));
		
		Н1 = УровниРежимов.Найти(Режим1);
		Н2 = УровниРежимов.Найти(Режим2);
		
		Результат = ?(Н1 > Н2, Режим1, Режим2);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьСписокРежимовЗаполнения(РежимИспользования, РежимЗаполненияРодителя)
	
	ТолькоДляОбъета = (РежимИспользования = ПредопределенноеЗначение("Перечисление.РежимыИспользованияАтрибутов.ТолькоДляОбъектовНоменклатуры"));
	РежимыЗаполнения = "Перечисление.РежимыЗаполненияАтрибутов.";
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(РежимЗаполненияРодителя)
			ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляОбъекта")
			ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "Необязательный") Тогда
		Результат.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляОбъекта"));
	КонецЕсли;
	Если НЕ ТолькоДляОбъета Тогда
		Если НЕ ЗначениеЗаполнено(РежимЗаполненияРодителя)
				ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляОбъекта")
				ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляНоменклатуры")
				ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "Необязательный") Тогда
			Результат.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляНоменклатуры"));
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(РежимЗаполненияРодителя)
				ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляОбъекта")
				ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляНоменклатуры")
				ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляКласса")
				ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "Необязательный") Тогда
			Результат.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "ОбязательныйДляКласса"));
		КонецЕсли;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(РежимЗаполненияРодителя)
			ИЛИ РежимЗаполненияРодителя = ПредопределенноеЗначение(РежимыЗаполнения + "Необязательный") Тогда
		Результат.Добавить(ПредопределенноеЗначение(РежимыЗаполнения + "Необязательный"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьОтображениеДанныхАтрибута(Объект, Элементы, ТекРежимЗаполненияАтрибутаШаблона, Редактирование)
	
	СтруктураВыбора = ПолучитьСпискиАтрибутовДляОбработки(Объект, Элементы);
	
	СтатусыНаследования = СтруктураВыбора.СтатусыНаследования;
	НаборыАтрибутов     = СтруктураВыбора.НаборыАтрибутов;
	ЕдиничныеАтрибуты   = СтруктураВыбора.ЕдиничныеАтрибуты;
	
	ДоступностьКомандыНеНаследовать = Ложь;
	ДоступностьКомандыНаследовать   = Ложь;
	ПометкаКомандыНеНаследовать     = Ложь;
	ПометкаКомандыНаследовать       = Ложь;
	
	// Если выбраны унаследованные атрибуты, команды управления наследованием доступны.
	Если Редактирование Тогда
		Для Каждого КлючИЗначение ИЗ СтатусыНаследования Цикл
			СтатусНаследования = КлючИЗначение.Ключ;
			Если СтатусНаследования = 3 Тогда 
				ДоступностьКомандыНеНаследовать = Истина;
				ДоступностьКомандыНаследовать   = Истина;
				ПометкаКомандыНаследовать       = Истина;
				
			ИначеЕсли СтатусНаследования = 4 Тогда
				ДоступностьКомандыНеНаследовать = Истина;
				ДоступностьКомандыНаследовать   = Истина;
				ПометкаКомандыНеНаследовать     = Истина;
				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Элементы.АтрибутыКомандаНеНаследовать.Доступность = ДоступностьКомандыНеНаследовать;
	Элементы.АтрибутыКомандаНеНаследовать.Пометка     = ПометкаКомандыНеНаследовать;
	Элементы.АтрибутыКомандаНаследовать.Доступность   = ДоступностьКомандыНаследовать;
	Элементы.АтрибутыКомандаНаследовать.Пометка       = ПометкаКомандыНаследовать;
	
	Элементы.КомандаУдалитьАтрибут.Доступность = 
		ЕдиничныеАтрибуты.Количество() > 0;
	
	// Настройка параметров атрибутов.
	ИДСтроки = Элементы.Атрибуты.ТекущаяСтрока;
	ТекДанные = Неопределено;
	Если НЕ ИДСтроки = Неопределено Тогда
		ТекДанные = Объект.Атрибуты.НайтиПоИдентификатору(ИДСтроки);
	КонецЕсли;
	
	Если ТекДанные = Неопределено ИЛИ ТекДанные.ЭтоВложенныйАтрибут Тогда
		Элементы.ГруппаПараметрыАтрибута.ТолькоПросмотр = Истина;
		Элементы.ДобавитьВложенныйАтрибут.Доступность   = Ложь;
		Элементы.АтрибутыРежимИспользования.Видимость   = Ложь;
		Элементы.АтрибутыРежимЗаполнения.Видимость      = Ложь;
		Элементы.ГруппаПараметрыАтрибутаСтраницы.Видимость = Ложь;
	Иначе
		Элементы.ГруппаПараметрыАтрибута.ТолькоПросмотр    = (ТекДанные.СтатусНаследования > 3);
		Элементы.АтрибутыРежимИспользования.ТолькоПросмотр = (ТекДанные.СтатусНаследования > 2);
		
		Элементы.ДобавитьВложенныйАтрибут.Доступность = Редактирование И НЕ ТекДанные.ЭтоВложенныйАтрибут 
			И НЕ ТекДанные.МножественноеЗначение И ТекДанные.НуженИсточникЗначений
			И ТипЗнч(ТекДанные.АтрибутКласса) = Тип("ПланВидовХарактеристикСсылка.АтрибутыКласса")
			И ЗначениеЗаполнено(ТекДанные.ИсточникЗначений);
		
		Элементы.АтрибутыРежимИспользования.Видимость      = Истина;
		Элементы.ГруппаПараметрыАтрибутаСтраницы.Видимость = Истина;
		
		ТипЧисло  = Ложь;
		ТипДата   = Ложь;
		ТипСтрока = Ложь;
		ТипБулево = Ложь;
		ПроверитьИспользованиеПримитивныхТипов(ТекДанные.ТипЗначения, ТипЧисло, ТипДата, ТипБулево, ТипСтрока);
		
		Элементы.ГруппаПараметрыАтрибутаСтраницы.ТекущаяСтраница = ?(ТипЧисло ИЛИ ТипДата ИЛИ ТипСтрока ИЛИ ТипБулево,
			Элементы.ГруппаПараметрыАтрибутаПримитивныйТип, Элементы.ГруппаПараметрыАтрибутаСсылочныйТип);
			
		Элементы.АтрибутыРежимЗаполнения.Видимость = Истина;
		
		Если НЕ ЗначениеЗаполнено(ТекДанные.ЭтотАтрибутВШаблоне) Тогда
			РежимОграничения = ТекДанные.РежимЗаполненияРодителя;
		Иначе
			Если ТекДанные.ЭтотАтрибутВШаблоне = 1 Тогда
				РежимПоШаблону = ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса");
			ИначеЕсли ТекДанные.ЭтотАтрибутВШаблоне = 2 Тогда
				РежимПоШаблону = ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры");
			ИначеЕсли ТекДанные.ЭтотАтрибутВШаблоне = 3 Тогда
				РежимПоШаблону = ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляОбъекта");
			КонецЕсли;
			РежимОграничения = РежимЗаполненияСтроже(ТекДанные.РежимЗаполненияРодителя, РежимПоШаблону);
		КонецЕсли;
		
		Элементы.АтрибутыРежимЗаполнения.СписокВыбора.ЗагрузитьЗначения(
			ПолучитьСписокРежимовЗаполнения(ТекДанные.РежимИспользования, РежимОграничения));
		// Ссылочный тип.
		//Элементы.АтрибутыМножественноеЗначение.Доступность = НЕ ТекДанные.КлассТабличнаяЧасть;
		Элементы.АтрибутыИсточникЗначений.Доступность = 
			ТекДанные.НуженИсточникЗначений И НЕ ТекДанные.СписокДоступныхЗначений
				И (НЕ ТекДанные.КлассТабличнаяЧасть ИЛИ ТекДанные.СтатусНаследования < 3);
		Элементы.АтрибутыСписокДоступныхЗначений.Доступность = 
			ТекДанные.НуженИсточникЗначений И НЕ ТекДанные.КлассТабличнаяЧасть;
		
		ТипОбъектНоменклатуры  = Тип("СправочникСсылка.ОбъектыНоменклатуры");
		ЕстьОбъектНоменклатуры = ТекДанные.ТипЗначения.СодержитТип(ТипОбъектНоменклатуры);
		Элементы.АтрибутыИсточникЗначений.ВыбиратьТип = ЕстьОбъектНоменклатуры;
		
		Элементы.ГруппаДобавлениеСтрокТабЧасти.Видимость = ТекДанные.НуженИсточникЗначений 
			И ТекДанные.КлассТабличнаяЧасть И ТекДанные.МножественноеЗначение;
		Элементы.ГруппаДобавлениеСтрокТабЧасти.ТолькоПросмотр = НЕ (ТекДанные.СтатусНаследования < 3);
		
		// Примитивный тип.
		Элементы.ГруппаДиапазонЗначений.Доступность = ТипЧисло ИЛИ ТипДата;
		Элементы.АтрибутыФормат.Доступность = НЕ ТекДанные.МножественноеЗначение И (ТипЧисло ИЛИ ТипДата ИЛИ ТипСтрока);
		Элементы.АтрибутыМногострочноеРедактирование.Доступность = ТипСтрока;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьАтрибут(РежимУдаления)
	
	ТекДанные = Элементы.Атрибуты.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВыбора = ПолучитьСпискиАтрибутовДляОбработки(Объект, Элементы);
	
	СтатусыНаследования = СтруктураВыбора.СтатусыНаследования;
	НаборыАтрибутов     = СтруктураВыбора.НаборыАтрибутов;
	ЕдиничныеАтрибуты   = СтруктураВыбора.ЕдиничныеАтрибуты;
	
	СтатусыУдалятьПострочно     = Неопределено;
	СтатусыНеУчитыватьПострочно = Неопределено;
	СтатусыУдалятьНаборы        = Неопределено;
	
	СтрокиСтатуса = СтатусыНаследования[1];
	ЕстьУдаляемыеЕдиничные = ЗначениеЗаполнено(СтрокиСтатуса) И (СтрокиСтатуса.Количество() > 0);
	СтрокиСтатуса = СтатусыНаследования[2];
	ЕстьУдаляемыеЕдиничные = ЕстьУдаляемыеЕдиничные ИЛИ ЗначениеЗаполнено(СтрокиСтатуса) И (СтрокиСтатуса.Количество() > 0);
	СтрокиСтатуса = СтатусыНаследования[3];
	ЕстьНенаследуемые = ЗначениеЗаполнено(СтрокиСтатуса) И (СтрокиСтатуса.Количество() > 0);
	
	Если РежимУдаления = 4 Тогда
		СтатусыУдалятьПострочно = "Все"; // Построчно все
		СтатусыУдалятьНаборы = 2;        // Наборы - со статусом 2.
	ИначеЕсли РежимУдаления = 3 Тогда
		СтатусыУдалятьПострочно = 3;  // Построчно со статусом 3.
		ЕстьУдаляемыеЕдиничные = Ложь;
	ИначеЕсли РежимУДаления = 2 Тогда
		СтатусыУдалятьНаборы = "Все"; // Наборы - все.
		ЕстьУдаляемыеЕдиничные = Ложь;
	ИначеЕсли РежимУдаления = 1 Тогда
		СтатусыУдалятьПострочно = "Все"; // Построчно все
	КонецЕсли;
	
	АктивироватьАтрибут = Неопределено;
	СтрокиКУдалению = Новый Массив; 
	Если СтатусыУдалятьПострочно = 3 Тогда
		СтрокиКУдалению = СтатусыНаследования[3];
		АктивироватьАтрибут = СтрокиКУдалению[СтрокиКУдалению.ВГраница()].АтрибутКласса;
	ИначеЕсли СтатусыУдалятьПострочно = "Все" Тогда
		Для Каждого КлючИЗначение ИЗ СтатусыНаследования Цикл
			Если КлючИЗначение.Ключ > 3 ИЛИ КлючИЗначение.Ключ = СтатусыНеУчитыватьПострочно Тогда
				Продолжить;
			КонецЕсли;
			Для Каждого Строка ИЗ КлючИЗначение.Значение Цикл
				СтрокиКУдалению.Добавить(Строка);
				АктивироватьАтрибут = Строка.АтрибутКласса;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	АктивироватьНабор = Неопределено;
	КолВоКУдалению = СтрокиКУдалению.Количество();
	Если КолВоКУдалению > 0 Тогда
		Если ЕстьУдаляемыеЕдиничные Тогда
			Если КолВоКУдалению > 1 Тогда
				ТекстВопроса = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
					НСтр("ru='Удалить %1 атрибутов?'"), КолВоКУдалению);
			Иначе
				ТекстВопроса = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
					НСтр("ru='Удалить атрибут %1?'"), Строка(СтрокиКУдалению[0].АтрибутКласса));
			КонецЕсли;
		ИначеЕсли ЕстьНенаследуемые Тогда
			Если КолВоКУдалению > 1 Тогда
				ТекстВопроса = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
					НСтр("ru='Запретить наследование %1 атрибутов?'"), КолВоКУдалению);
			Иначе
				ТекстВопроса = УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
					НСтр("ru='Запретить наследование атрибута %1?'"), Строка(СтрокиКУдалению[0].АтрибутКласса));
			КонецЕсли;
		КонецЕсли;
		
		ДопПараметры = Новый Структура("СтрокиКУдалению, АктивироватьАтрибут, АктивироватьНабор",
			СтрокиКУдалению, АктивироватьАтрибут, АктивироватьНабор);
		ПоказатьВопрос(Новый ОписаниеОповещения("АтрибутыПередУдалениемЗавершение", ЭтаФорма, ДопПараметры), 
			ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьАтрибут(АтрибутКласса, АтрибутыШаблонаКласса, АтрибутыШаблонаНоменклатуры, АтрибутыШаблонаОбъекта)
	
	Найдено = Объект.Атрибуты.НайтиСтроки(Новый Структура("АтрибутКласса", АтрибутКласса));
	Изменено = Ложь;
	
	Если Найдено.Количество() = 0 Тогда
		РеквизитыАтрибута = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъекта(
			АтрибутКласса, "ЭтоГруппа, ТипЗначения, МножественноеЗначение, ИсточникЗначений");
		Если РеквизитыАтрибута.ЭтоГруппа Тогда 
			Возврат;
		КонецЕсли;
		
		ЭтоСтрока = РеквизитыАтрибута.ТипЗначения.СодержитТип(Тип("Строка"));
		
		СтрокаТЧ = Объект.Атрибуты.Добавить();
		СтрокаТЧ.АтрибутКласса          = АтрибутКласса;
		СтрокаТЧ.МножественноеЗначение  = РеквизитыАтрибута.МножественноеЗначение;
		СтрокаТЧ.МножественноеЗначениеКартинка = ?(РеквизитыАтрибута.МножественноеЗначение И НЕ ЭтоСтрока, 0, 1);
		СтрокаТЧ.СтатусНаследования     = 1;
		СтрокаТЧ.ТипЗначения            = РеквизитыАтрибута.ТипЗначения;
		СтрокаТЧ.ЗначениеАтрибутаКласса = СтрокаТЧ.ТипЗначения.ПривестиЗначение();
		
		СтрокаТЧ.РежимИспользования = ПредопределенноеЗначение("Перечисление.РежимыИспользованияАтрибутов.БезОграничений");
		СтрокаТЧ.РежимЗаполнения    = ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.Необязательный");
		Если НЕ АтрибутыШаблонаКласса = Неопределено И НЕ АтрибутыШаблонаКласса.Найти(АтрибутКласса) = Неопределено Тогда
			СтрокаТЧ.ЭтотАтрибутВШаблоне = 1;
			СтрокаТЧ.РежимЗаполнения = ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса");
		ИначеЕсли НЕ АтрибутыШаблонаНоменклатуры = Неопределено И НЕ АтрибутыШаблонаНоменклатуры.Найти(АтрибутКласса) = Неопределено Тогда
			СтрокаТЧ.ЭтотАтрибутВШаблоне = 2;
			СтрокаТЧ.РежимЗаполнения = ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры");
		ИначеЕсли НЕ АтрибутыШаблонаОбъекта = Неопределено И НЕ АтрибутыШаблонаОбъекта.Найти(АтрибутКласса) = Неопределено Тогда
			СтрокаТЧ.ЭтотАтрибутВШаблоне = 3;
			СтрокаТЧ.РежимЗаполнения = ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляОбъекта");
		КонецЕсли;
		
		ОписаниеТиповСсылка = Новый ОписаниеТипов("СправочникСсылка.Классы, СправочникСсылка.НоменклатураКласса");
		ТипОбъектНоменклатуры = Тип("СправочникСсылка.ОбъектыНоменклатуры");
		ТипНоменклатураКласса = Тип("СправочникСсылка.НоменклатураКласса");
		ТипКласс              = Тип("СправочникСсылка.Классы");
		
		ПустойКласс = ПредопределенноеЗначение("Справочник.Классы.ПустаяСсылка");
		
		КлассИлиНоменклатура = ОписаниеТиповСсылка.СодержитТип(СтрокаТЧ.ТипЗначения.Типы()[0]);
		ЕстьНоменклатураКласса = СтрокаТЧ.ТипЗначения.СодержитТип(ТипНоменклатураКласса);
		ЕстьОбъектНоменклатуры = СтрокаТЧ.ТипЗначения.СодержитТип(ТипОбъектНоменклатуры);
		
		СтрокаТЧ.НуженИсточникЗначений = (КлассИлиНоменклатура ИЛИ ЕстьОбъектНоменклатуры);
		
		Если КлассИлиНоменклатура И НЕ ЕстьОбъектНоменклатуры
				И (НЕ ТипЗнч(РеквизитыАтрибута.ИсточникЗначений) = ТипКласс) Тогда
			СтрокаТЧ.ИсточникЗначений = ПустойКласс;
		Иначе
			СтрокаТЧ.ИсточникЗначений = РеквизитыАтрибута.ИсточникЗначений;
		КонецЕсли;
		
		КлассТабличнаяЧасть = Ложь;
		Если ЗначениеЗаполнено(СтрокаТЧ.ИсточникЗначений) 
				И ТипЗнч(СтрокаТЧ.ИсточникЗначений) = ТипКласс Тогда
			КлассТабличнаяЧасть = ?(ЗначениеЗаполнено(СтрокаТЧ.ИсточникЗначений), 
				УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъекта(
					СтрокаТЧ.ИсточникЗначений, "КлассТабличнаяЧасть"), Ложь);
		КонецЕсли;
		СтрокаТЧ.КлассТабличнаяЧасть = КлассТабличнаяЧасть;
		
		СтрокаТЧ.СоставнойТипЗначения = (ЕстьНоменклатураКласса ИЛИ ЕстьОбъектНоменклатуры);
		Если СтрокаТЧ.СоставнойТипЗначения Тогда
			СтрокаТЧ.ЗначениеАтрибутаКлассаСоставное = СтрокаТЧ.ИсточникЗначений;
		КонецЕсли;
		
		Если КлассИлиНоменклатура И НЕ СтрокаТЧ.СоставнойТипЗначения 
				И ЗначениеЗаполнено(СтрокаТЧ.ИсточникЗначений) Тогда
			СтрокаТЧ.ТипЗначенияПредставление = "(" + Строка(СтрокаТЧ.ИсточникЗначений) + ")";
		Иначе
			СтрокаТЧ.ТипЗначенияПредставление = "(" + Строка(СтрокаТЧ.ТипЗначения) + ")";
		КонецЕсли;
		
		Если НЕ ЭтоСтрока И СтрокаТЧ.МножественноеЗначение Тогда
			ДобавитьСписочныйАтрибут(СтрокаТЧ.АтрибутКласса, СтрокаТЧ.КлассТабличнаяЧасть, СтрокаТЧ.ИсточникЗначений);
		КонецЕсли;
		
		Изменено = Истина;
		
	Иначе
		СтрокаТЧ = Найдено[0];
		Если СтрокаТЧ.СтатусНаследования = 4 Тогда
			СтрокаТЧ.СтатусНаследования = 3;
			ПараметрыЗаполнения = ПолучитьЗначениеАтрибута(СтрокаТЧ.АтрибутКласса);
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, ПараметрыЗаполнения);
			ЭтоСтрока = СтрокаТЧ.ТипЗначения.СодержитТип(Тип("Строка"));
			
			Если НЕ ЭтоСтрока И (СтрокаТЧ.МножественноеЗначение ИЛИ СтрокаТЧ.СписокДоступныхЗначений) Тогда
				ДобавитьСписочныйАтрибут(СтрокаТЧ.АтрибутКласса, СтрокаТЧ.КлассТабличнаяЧасть, СтрокаТЧ.ИсточникЗначений);
			КонецЕсли;
			
			Изменено = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.Атрибуты.ТекущаяСтрока = СтрокаТЧ.ПолучитьИдентификатор();
	
	Модифицированность = Модифицированность ИЛИ Изменено;
	НастроитьОтображениеДанныхАтрибута(Объект, Элементы, ТекРежимЗаполненияАтрибутаШаблона, Редактирование);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьАтрибутыШаблонов(ШаблонКодаКласса, ШаблонНаименованияКласса, ШаблонКодаНоменклатуры, 
		ШаблонНаименованияНоменклатуры, ШаблонКодаОбъекта, ШаблонНаименованияОбъекта)
	
	Если ЗначениеЗаполнено(ШаблонКодаКласса) Тогда
		АтрибутыШаблонаКласса = ПолучитьАтрибутыШаблона(ШаблонКодаКласса);
	КонецЕсли;
	Если ЗначениеЗаполнено(ШаблонНаименованияКласса) Тогда
		АтрибутыШаблонаНаименованияКласса = ПолучитьАтрибутыШаблона(ШаблонНаименованияКласса);
		Если НЕ АтрибутыШаблонаКласса = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(АтрибутыШаблонаКласса, АтрибутыШаблонаНаименованияКласса);
		Иначе
			АтрибутыШаблонаКласса = АтрибутыШаблонаНаименованияКласса;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ШаблонКодаНоменклатуры) Тогда
		АтрибутыШаблонаНоменклатуры = ПолучитьАтрибутыШаблона(ШаблонКодаНоменклатуры);
	КонецЕсли;
	Если ЗначениеЗаполнено(ШаблонНаименованияНоменклатуры) Тогда
		АтрибутыШаблонаНаименованияНоменклатуры = ПолучитьАтрибутыШаблона(ШаблонНаименованияНоменклатуры);
		Если НЕ АтрибутыШаблонаНоменклатуры = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(АтрибутыШаблонаНоменклатуры, АтрибутыШаблонаНаименованияНоменклатуры);
		Иначе
			АтрибутыШаблонаНоменклатуры = АтрибутыШаблонаНаименованияНоменклатуры;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ШаблонКодаОбъекта) Тогда
		АтрибутыШаблонаОбъекта = ПолучитьАтрибутыШаблона(ШаблонКодаОбъекта);
	КонецЕсли;
	Если ЗначениеЗаполнено(ШаблонНаименованияОбъекта) Тогда
		АтрибутыШаблонаНаименованияОбъекта = ПолучитьАтрибутыШаблона(ШаблонНаименованияОбъекта);
		Если НЕ АтрибутыШаблонаОбъекта = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(АтрибутыШаблонаОбъекта, АтрибутыШаблонаНаименованияОбъекта);
		Иначе
			АтрибутыШаблонаОбъекта = АтрибутыШаблонаНаименованияОбъекта;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Новый Структура("АтрибутыШаблонаКласса, АтрибутыШаблонаНоменклатуры, АтрибутыШаблонаОбъекта", 
		АтрибутыШаблонаКласса, АтрибутыШаблонаНоменклатуры, АтрибутыШаблонаОбъекта);
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьАтрибутыШаблона(ШаблонЗаполнения)
	
	ЭлементыШаблона = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъекта(
		ШаблонЗаполнения, "ЭлементыШаблона").Выгрузить();
	СтрокиШаблона = ЭлементыШаблона.Скопировать(Новый Структура("ТипСтроки", Перечисления.ТипыСтрокШаблона.АтрибутОбъекта));
	Возврат СтрокиШаблона.ВыгрузитьКолонку("АтрибутКласса");
	
КонецФункции

&НаСервере
Процедура ДобавитьСписочныйАтрибут(АтрибутКласса, КлассТабличнаяЧасть, ИсточникЗначений)
	
	Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса", 0, АтрибутКласса));
	Если Найдено.Количество() = 0 Тогда
		
		СписочныйАтрибут = СписочныеАтрибуты.Добавить();
		СписочныйАтрибут.ИДАтрибута          = НайтиНовыйИД(СписочныеАтрибуты, "ИДАтрибута", 2);
		СписочныйАтрибут.АтрибутКласса       = АтрибутКласса;
		СписочныйАтрибут.КлассТабличнаяЧасть = КлассТабличнаяЧасть;
		СписочныйАтрибут.ТипОбъекта          = 0;
		СписочныйАтрибут.ИсточникЗначений    = ИсточникЗначений;
		
		Если НЕ КлассТабличнаяЧасть Тогда
			НайденоЗначения = Объект.ЗначенияСписочныхАтрибутов.НайтиСтроки(Новый Структура("АтрибутКласса", АтрибутКласса));
			Если НайденоЗначения.Количество() = 0 Тогда 
				ЗаполнитьЗначенияСписочныхАтрибутов(Объект.Класс.Ссылка, АтрибутКласса);
			КонецЕсли;
		КонецЕсли;
		
		СписокСтраницАтрибутов = Элементы.ПереключательАтрибутов.СписокВыбора;
		СписокСтраницАтрибутов.Добавить(СписочныйАтрибут.ИДАтрибута, АтрибутКласса);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьТехОперацию(ВидОперации, Знач ОбъектОперации = Неопределено, ТипСтроки=0)
	
	Если ТекТехКарта < 0 Тогда
		Возврат
	КонецЕсли;
	
	СтрокаТехОперации = Неопределено;
	ЭлементыОпераций = СоставТехКарты.ПолучитьЭлементы();
	
	Если ОбъектОперации = Неопределено Тогда
		ОбъектОперации = Объект.Класс.Ссылка;
	КонецЕсли;
	
	Если СтрокаТехОперации = Неопределено Тогда
		СтрокаТехОперации = ЭлементыОпераций.Добавить();
		СтрокаТехОперации.ТипСтроки = ТипСтроки;
		Если ТипСтроки = 0 Тогда
			СтрокаТехОперации.ВидОперации = ВидОперации;
		Иначе
			СтрокаТехОперации.ТехКартаВложенная = ВидОперации;
		КонецЕсли;
		СтрокаТехОперации.СтатусНаследования = 1;
		СтрокаТехОперации.ИДСтроки = НайтиНовыйИД(Объект.СтрокиТабличныхАтрибутов, "ИДСтроки");
		СтрокаТехОперации.ОбъектОперации = ОбъектОперации;
	КонецЕсли;
	
	Элементы.СоставТехКарты.ТекущаяСтрока = СтрокаТехОперации.ПолучитьИдентификатор();
	Элементы.СоставТехКарты.ТекущийЭлемент = ?(ТипСтроки = 0, 
		Элементы.СоставТехКартыВидОперации, Элементы.СоставТехКартыТехКартаВложенная);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьСтрокуТехОперации() Экспорт
	
	Элементы.СоставТехКарты.ИзменитьСтроку();
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьТехОперацию(Выбраны, УдалитьИзДерева=Ложь)
	
	ТекДанныеТехКарты = Элементы.ТехКарты.ТекущиеДанные;
	Если ТекДанныеТехКарты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	УдалитьВыбранныеСтрокиТабличногоАтрибута(СоставТехКарты, Выбраны, ТекДанныеТехКарты.ИДСтроки, 
		ПредопределенноеЗначение("ПланВидовХарактеристик.АтрибутыКласса.ТехОперации"));
	
	Если УдалитьИзДерева Тогда
		ЭлементыДерева = СоставТехКарты.ПолучитьЭлементы();
		Для Каждого ИДСтроки ИЗ Выбраны Цикл
			СтрокаКУдалению = СоставТехКарты.НайтиПоИдентификатору(ИДСтроки);
				ЭлементыДерева.Удалить(СтрокаКУдалению);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаЗначенияАтрибутовМаксУровень()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВТ_МаксУровниЗначений.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_ЗначенияАтрибутов.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	ВЫБОР
		|		КОГДА ВТ_ЗначенияАтрибутов.УровеньНаследования ЕСТЬ NULL
		|			ТОГДА 0
		|		ИНАЧЕ ВТ_ЗначенияАтрибутов.УровеньНаследования * 2 + 1
		|	КОНЕЦ КАК УровеньЗначения
		|ИЗ
		|	ВТ_МаксУровниЗначений КАК ВТ_МаксУровниЗначений
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗначенияАтрибутов КАК ВТ_ЗначенияАтрибутов
		|		ПО ВТ_МаксУровниЗначений.АтрибутКласса = ВТ_ЗначенияАтрибутов.АтрибутКласса
		|			И ВТ_МаксУровниЗначений.Уровень = ВТ_ЗначенияАтрибутов.Уровень";
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Функция ПолучитьЗначениеАтрибута(АтрибутКласса)
	
	СтруктураВозврата = 
		Новый Структура("ЗначениеАтрибутаКласса, УровеньЗначения", ПолучитьПустоеЗначениеАтрибута(АтрибутКласса));
		
	ПараметрСписокРодителей = СписокРодителей.Выгрузить();
	ПараметрСписокРодителей.Колонки.Добавить("КлассДляЧтения", Новый ОписаниеТипов("СправочникСсылка.Классы"));
	ПараметрСписокРодителей.ЗаполнитьЗначения(Объект.Класс.Ссылка, "КлассДляЧтения");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("АтрибутКласса",   АтрибутКласса);
	Запрос.УстановитьПараметр("Класс",           Объект.Класс.Ссылка);
	Запрос.УстановитьПараметр("СписокРодителей", ПараметрСписокРодителей);
	ТекстУсловияПоНенаследуемым = "
		|	И НЕ НенаследуемыеЗначения.Класс = &Класс";
	ТекстУсловияПоЗначениям = "
		|	И ЗначенияАтрибутовКласса.АтрибутКласса = &АтрибутКласса";
	
	Запрос.Текст = Справочники.Классы.ТекстЗапросаСписокРодителей() 
			+ УправлениеНСИФункцииВызовСервераПереопределяемый.ТекстРазделителяЗапросовПакета()
		+ Справочники.Классы.ТекстЗапросаНеНаследуемыеАтрибуты(ТекстУсловияПоНенаследуемым) 
			+ УправлениеНСИФункцииВызовСервераПереопределяемый.ТекстРазделителяЗапросовПакета()
		+ Справочники.Классы.ТекстЗапросаЗначенияАтрибутов(ТекстУсловияПоЗначениям)         
			+ УправлениеНСИФункцииВызовСервераПереопределяемый.ТекстРазделителяЗапросовПакета()
		+ ТекстЗапросаЗначенияАтрибутовМаксУровень()
		;
		
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, Результат);
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьПустоеЗначениеАтрибута(АтрибутКласса)
	
	Если ТипЗнч(АтрибутКласса) = Тип("ПланВидовХарактеристикСсылка.АтрибутыКласса") Тогда
		ТипЗначения = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъекта(
			АтрибутКласса, "ТипЗначения");
	ИначеЕсли ТипЗнч(АтрибутКласса) = Тип("СправочникСсылка.ВложенныеАтрибутыКласса") Тогда
		ЗначенияРеквизитов = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъекта(
			АтрибутКласса, Новый Структура("АтрибутКласса, ТипЗначения",
			"АтрибутКласса", "ВЫРАЗИТЬ(АтрибутКласса КАК ПланВидовХарактеристик.АтрибутыКласса).ТипЗначения"));
		ТипАтрибута = ТипЗнч(ЗначенияРеквизитов.АтрибутКласса);
		Если ТипАтрибута = Тип("ПланВидовХарактеристикСсылка.АтрибутыКласса") Тогда
			ТипЗначения = ЗначенияРеквизитов.ТипЗначения;
		ИначеЕсли ТипАтрибута = Тип("ПеречислениеСсылка.РеквизитыКлассаНоменклатуры") Тогда
			МетаданныеСпр = Метаданные.НайтиПоТипу(ЗначенияРеквизитов.ТипЗначения.Типы()[0]);
			МетаданныеРеквизита = Перечисления.РеквизитыКлассаНоменклатуры.ПолучитьМетаданныеРеквизита(
				МетаданныеСпр, Значенияреквизитов.АтрибутКласса);
			ТипЗначения = МетаданныеРеквизита.Тип;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ?(НЕ ТипЗначения = Неопределено, ТипЗначения.ПривестиЗначение(), Неопределено);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьКомандыУправленияЗначениямиСписочногоАтрибута(Объект, Элементы, ТекДанные, Редактирование)
	
	Если Редактирование И НЕ ТекДанные = Неопределено И ТекДанные.СтатусНаследования = 3 Тогда
		ДоступностьКомандУправления = Истина;
		ПометкаНаследовать = Истина;
		ПометкаНеНаследовать = Ложь;
	ИначеЕсли Редактирование И НЕ ТекДанные = Неопределено И ТекДанные.СтатусНаследования = 4 Тогда
		ДоступностьКомандУправления = Истина;
		ПометкаНаследовать = Ложь;
		ПометкаНеНаследовать = Истина;
	Иначе
		ДоступностьКомандУправления = Ложь;
		ПометкаНаследовать = Ложь;
		ПометкаНеНаследовать = Ложь;
	КонецЕсли;
	
	Элементы.ЗначенияСписочногоАтрибутаКомандаНаследоватьЗначение.Доступность = ДоступностьКомандУправления;
	Элементы.ЗначенияСписочногоАтрибутаКомандаНаследоватьЗначение.Пометка     = ПометкаНаследовать;
	
	Элементы.ЗначенияСписочногоАтрибутаКомандаНеНаследоватьЗначение.Доступность = ДоступностьКомандУправления;
	Элементы.ЗначенияСписочногоАтрибутаКомандаНеНаследоватьЗначение.Пометка     = ПометкаНеНаследовать;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусНаследованияДляПодчиненных(ТекДанные)
	
	ВложенныеЭлементы = ТекДанные.ПолучитьЭлементы();
	Для Каждого ТекЭлемент ИЗ ВложенныеЭлементы Цикл
		ТекЭлемент.СтатусНаследования   = ТекДанные.СтатусНаследования;
		ТекЭлемент.ДоступноеЗначение    = ТекДанные.ДоступноеЗначение;
		Если НЕ ТекДанные.ДоступноеЗначение Тогда
			ТекЭлемент.ИспользуемоеЗначение = Ложь;
		КонецЕсли;
		УстановитьСтатусНаследованияДляПодчиненных(ТекЭлемент);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаЗначенияСписочныхАтрибутовВременныеТаблицы()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ЗначенияСписочныхАтрибутовКласса.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	ЗначенияСписочныхАтрибутовКласса.АтрибутКласса КАК АтрибутКласса,
		|	ЗначенияСписочныхАтрибутовКласса.СтатусНаследования КАК СтатусНаследования,
		|	ЗначенияСписочныхАтрибутовКласса.ДоступноеЗначение КАК ДоступноеЗначение,
