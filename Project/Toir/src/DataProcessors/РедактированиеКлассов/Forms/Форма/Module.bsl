
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаголовокРедактируемогоЭлемента = НСтр("ru='(Выберите элемент для редактирования или создайте новый)'");
	
	// Подготовим колонки тех.карт.
	ТаблицыТехКарт = ПолучитьТаблицыАтрибутовТехкарт();
	// Состав тех.карты.
	ПодготовитьКолонкиАтрибутовПодчиненныхОбъектов(
		ТаблицыТехКарт[0].ИдОбъекта, ТаблицыТехКарт[0].ИмяТаблицы, ТаблицыТехКарт[0].ТаблицаАтрибутов);
	// Тех.карты.
	ПодготовитьКолонкиАтрибутовПодчиненныхОбъектов(
		ТаблицыТехКарт[1].ИдОбъекта, ТаблицыТехКарт[1].ИмяТаблицы, ТаблицыТехКарт[1].ТаблицаАтрибутов);
	
	// Заполним список табличных атрибутов операций.
	СписокТабличныхАтрибутовОпераций = Элементы.ПереключательТабличныхАтрибутовОпераций.СписокВыбора;
	ЗаполнитьВложенныеТабличныеЧасти(ТаблицыТехКарт[0].ТаблицаАтрибутов, 1, СписокТабличныхАтрибутовОпераций);
	Если СписокТабличныхАтрибутовОпераций.Количество() = 0 Тогда
		Элементы.ГруппаПереключательТаблицОпераций.Видимость  = Ложь;
		Элементы.ЗначениеТабличногоАтрибутаОперации.Видимость      = Ложь;
	КонецЕсли;
	
	// Заполним список табличных атрибутов тех.карт.
	СписокТабличныхАтрибутовТехКарт = Элементы.ПереключательТабличныхАтрибутовТехКарт.СписокВыбора;
	ЗаполнитьВложенныеТабличныеЧасти(ТаблицыТехКарт[1].ТаблицаАтрибутов, 2, СписокТабличныхАтрибутовТехКарт);
	Если СписокТабличныхАтрибутовОпераций.Количество() = 0 Тогда
		Элементы.ПереключательТабличныхАтрибутовТехКарт.Видимость = Ложь;
	Иначе
		Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта, АтрибутКласса",
			2, ПланыВидовХарактеристик.АтрибутыКласса.ТехОперации));
		Если Найдено.Количество() > 0 Тогда
			ПереключательТабличныхАтрибутовТехКарт = Найдено[0].ИДАтрибута;
			ТекТаблицаТехКарты = ПланыВидовХарактеристик.АтрибутыКласса.ТехОперации;
		Иначе
			Найдено = СписочныеАтрибуты.НайтиСтроки(Новый Структура("ТипОбъекта", 2));
			ПереключательТабличныхАтрибутовТехКарт = Найдено[0].ИДАтрибута;
			ТекТаблицаТехКарты                     = Найдено[0].АтрибутКласса;
		КонецЕсли;
	КонецЕсли;
	
	ПравоИзменениеКлассов = ПравоДоступа("Изменение", Метаданные.Справочники.Классы);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПодключитьОбработчикОжидания("ПроверкаБлокировкиКласса", 5);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Модифицированность Тогда
		Если ЗавершениеРаботы = Истина Тогда
			Отказ = Истина;
			ТекстПредупреждения = НСтр("ru='Данные были изменены. Все изменения будут потеряны.'");
		Иначе
			Отказ = Истина;
			ТекстВопроса = НСтр("ru='Данные были изменены. Сохранить изменения?'");
			ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтаФорма), 
				ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		КонецЕсли;
		
	Иначе
		Если Редактирование И ЗначениеЗаполнено(Объект.Класс.Ссылка) Тогда
			СнятьБлокировкуКласса();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура КодПриИзменении(Элемент)
	
	Объект.ПрисвоенНомерПоШаблону = Ложь;
	Объект.НомерПоСчетчику         = 0;
	Объект.ШагСчетчика             = 0;
	
КонецПроцедуры

&НаКлиенте
Процедура ПереключательАтрибутовПриИзменении(Элемент)
	
	ПереключитьСтраницуФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура НоменклатураКлассаПриИзменении(Элемент)
	
	Элементы.ГруппаПараметрыНоменклатуры.Доступность = Объект.НоменклатураКласса;
	УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияНоменклатуры(), Объект.НоменклатураКласса);
	
	Элементы.ОбъектыНоменклатуры.Доступность = Объект.НоменклатураКласса;
	Если Объект.ОбъектыНоменклатуры И НЕ Объект.НоменклатураКласса Тогда
		Объект.ОбъектыНоменклатуры = Ложь;
		Элементы.ГруппаПараметрыОбъектаНоменклатуры.Доступность = Ложь;
		УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияОбъектов(), Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыНоменклатурыПриИзменении(Элемент)
	
	Элементы.ГруппаПараметрыОбъектаНоменклатуры.Доступность = Объект.ОбъектыНоменклатуры;
	УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияОбъектов(), Объект.ОбъектыНоменклатуры);
	
КонецПроцедуры

&НаКлиенте
Процедура КлассТабличнаяЧастьПриИзменении(Элемент)
	
	Элементы.НоменклатураКласса.Доступность = НЕ Объект.КлассТабличнаяЧасть;
	Элементы.ЗначениеАтрибута.Доступность   = НЕ Объект.КлассТабличнаяЧасть;
	Если Объект.КлассТабличнаяЧасть Тогда
		Объект.ЗначениеАтрибута   = Ложь;
		Объект.НоменклатураКласса = Истина;
		Элементы.ГруппаПараметрыНоменклатуры.Доступность = Истина;
		УстановитьАвтоотметкуНезаполненных(СписокРеквизитовКодированияИменованияНоменклатуры(), Истина);
		
		Элементы.ОбъектыНоменклатуры.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РодительПриИзменении(Элемент)
	РодительПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура РежимКонтроляДублейПоНаименованиюПриИзменении(Элемент)
	
	Элементы.ГруппаСтраницыКонтрольДублейПоНаименованию.ТекущаяСтраница = 
		?(Объект.РежимКонтроляДублейПоНаименованию = ПредопределенноеЗначение("Перечисление.РежимыКонтроляДублей.ВПределахКласса"),
			Элементы.ГруппаСтраницаКонтрольДублейВПределахКласса,
			Элементы.ГруппаСтраницаКонтрольДублейКакУРодителя);
	
	Если НЕ ЗначениеЗаполнено(Объект.РежимКонтроляДублейПоНаименованию) Тогда
		КонтрольДублейКакУРодителя = ПолучитьПредставлениеРежимаКонтроляДублей(СписокРодителей);
	Иначе
		КонтрольДублейКакУРодителя = "";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ШаблонНаименованияНоменклатурыПриИзменении(Элемент)
	
	СтруктураАтрибутов = ПолучитьАтрибутыШаблонов(Неопределено, Неопределено, 
		Объект.ШаблонКодаНоменклатуры, Объект.ШаблонНаименованияНоменклатуры, 
		Объект.ШаблонКодаОбъекта, Объект.ШаблонНаименованияОбъекта);
		
	НеучитываемыеРежимы = Новый Массив();
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры"));
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса"));
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ФиксированноеЗначение"));
	
	Для Каждого СтрокаАтрибут ИЗ Объект.Атрибуты Цикл
		Если НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры = Неопределено 
				И НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
			Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
					И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
				СтрокаАтрибут.РежимЗаполнения = 
					ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры");
			КонецЕсли;
			
			Если СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0 ИЛИ СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3 Тогда
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2;
			КонецЕсли;
			
		ИначеЕсли СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2 Тогда
			
			Если НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта = Неопределено
					И НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
				
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3;
				Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
						И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
					СтрокаАтрибут.РежимЗаполнения = 
						ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляОбъекта");
				КонецЕсли;
				
			Иначе
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ШаблонКодаНоменклатурыПриИзменении(Элемент)
	
	СтруктураАтрибутов = ПолучитьАтрибутыШаблонов(Неопределено, Неопределено, 
		Объект.ШаблонКодаНоменклатуры, Объект.ШаблонНаименованияНоменклатуры, 
		Объект.ШаблонКодаОбъекта, Объект.ШаблонНаименованияОбъекта);
	
	НеучитываемыеРежимы = Новый Массив();
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры"));
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса"));
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ФиксированноеЗначение"));
	
	Для Каждого СтрокаАтрибут ИЗ Объект.Атрибуты Цикл
		Если НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры = Неопределено 
				И НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
			
			Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
					И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
				СтрокаАтрибут.РежимЗаполнения = 
					ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры");
			КонецЕсли;
			
			Если СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0 ИЛИ СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3 Тогда
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2;
			КонецЕсли;
			
		ИначеЕсли СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2 Тогда
			
			Если НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта = Неопределено
					И НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
				
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3;
				Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
						И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
					СтрокаАтрибут.РежимЗаполнения = 
						ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляОбъекта");
				КонецЕсли;
				
			Иначе
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0;
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ШаблонНаименованияКлассаПриИзменении(Элемент)
	
	СтруктураАтрибутов = ПолучитьАтрибутыШаблонов(Объект.ШаблонКодаКласса, Объект.ШаблонНаименованияКласса, 
		Объект.ШаблонКодаНоменклатуры, Объект.ШаблонНаименованияНоменклатуры, 
		Объект.ШаблонКодаОбъекта, Объект.ШаблонНаименованияОбъекта);
	
	НеучитываемыеРежимы = Новый Массив();
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса"));
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ФиксированноеЗначение"));
		
	ОбязательныйДляНоменклатуры = 
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры");
		
	Для Каждого СтрокаАтрибут ИЗ Объект.Атрибуты Цикл
		Если НЕ СтруктураАтрибутов.АтрибутыШаблонаКласса = Неопределено 
				И НЕ СтруктураАтрибутов.АтрибутыШаблонаКласса.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
			
			Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
					И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
				СтрокаАтрибут.РежимЗаполнения = 
					ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса");
				Если СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0 
						ИЛИ СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2 ИЛИ СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3 Тогда
					СтрокаАтрибут.ЭтотАтрибутВШаблоне = 1;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли СтрокаАтрибут.ЭтотАтрибутВШаблоне = 1 Тогда
			
			Если НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры = Неопределено
					И НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
				
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2;
				Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
						И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
					СтрокаАтрибут.РежимЗаполнения = ОбязательныйДляНоменклатуры;
				КонецЕсли;
				
			ИначеЕсли НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта = Неопределено
					И НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
				
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3;
				Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
						И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено
						И НЕ СтрокаАтрибут.РежимЗаполненияРодителя = ОбязательныйДляНоменклатуры 
						И НЕ СтрокаАтрибут.РежимЗаполнения = ОбязательныйДляНоменклатуры Тогда
					СтрокаАтрибут.РежимЗаполнения = 
						ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляОбъекта");
				КонецЕсли;
				
			Иначе
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0;
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ШаблонКодаКлассаПриИзменении(Элемент)
	
	СтруктураАтрибутов = ПолучитьАтрибутыШаблонов(Объект.ШаблонКодаКласса, Объект.ШаблонНаименованияКласса, 
		Объект.ШаблонКодаНоменклатуры, Объект.ШаблонНаименованияНоменклатуры, 
		Объект.ШаблонКодаОбъекта, Объект.ШаблонНаименованияОбъекта);
	
	НеучитываемыеРежимы = Новый Массив();
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса"));
	НеучитываемыеРежимы.Добавить(
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ФиксированноеЗначение"));
		
	ОбязательныйДляНоменклатуры = 
		ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры");
	
	Для Каждого СтрокаАтрибут ИЗ Объект.Атрибуты Цикл
		Если НЕ СтруктураАтрибутов.АтрибутыШаблонаКласса = Неопределено 
				И НЕ СтруктураАтрибутов.АтрибутыШаблонаКласса.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
			
			Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
					И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
				СтрокаАтрибут.РежимЗаполнения = 
					ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляКласса");
				Если СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0 
						ИЛИ СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2 ИЛИ СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3 Тогда
					СтрокаАтрибут.ЭтотАтрибутВШаблоне = 1;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли СтрокаАтрибут.ЭтотАтрибутВШаблоне = 1 Тогда
			
			Если НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры = Неопределено
					И НЕ СтруктураАтрибутов.АтрибутыШаблонаНоменклатуры.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
				
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 2;
				Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
						И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено Тогда
					СтрокаАтрибут.РежимЗаполнения = 
						ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляНоменклатуры");
				КонецЕсли;
				
			ИначеЕсли НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта = Неопределено
					И НЕ СтруктураАтрибутов.АтрибутыШаблонаОбъекта.Найти(СтрокаАтрибут.АтрибутКласса) = Неопределено Тогда
				
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 3;
				Если НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполненияРодителя) = Неопределено
						И НеучитываемыеРежимы.Найти(СтрокаАтрибут.РежимЗаполнения) = Неопределено
						И НЕ СтрокаАтрибут.РежимЗаполненияРодителя = ОбязательныйДляНоменклатуры 
						И НЕ СтрокаАтрибут.РежимЗаполнения = ОбязательныйДляНоменклатуры Тогда
					СтрокаАтрибут.РежимЗаполнения = 
						ПредопределенноеЗначение("Перечисление.РежимыЗаполненияАтрибутов.ОбязательныйДляОбъекта");
				КонецЕсли;
				
			Иначе
				СтрокаАтрибут.ЭтотАтрибутВШаблоне = 0;
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

