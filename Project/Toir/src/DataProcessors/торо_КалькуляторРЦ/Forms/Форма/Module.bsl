	//|	торо_ВводНачальныхДанныхВыполненныеРаботы.ДатаОкончанияРемонта,
	//|	торо_ВводНачальныхДанныхВыполненныеРаботы.ДатаОкончанияРемонта,
	//|	торо_ВводНачальныхДанныхВыполненныеРаботы.ВидРемонтныхРабот,
	//|	торо_ВводНачальныхДанныхВыполненныеРаботы.Ссылка,
	//|	ТаблицаОР.ОбъектРемонтныхРабот,
	//|	""""
	//|ИЗ
	//|	Документ.торо_ВводНачальныхДанных.ВыполненныеРаботы КАК торо_ВводНачальныхДанныхВыполненныеРаботы
	//|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВводНачальныхДанных КАК торо_ВводНачальныхДанных
	//|		ПО торо_ВводНачальныхДанныхВыполненныеРаботы.Ссылка = торо_ВводНачальныхДанных.Ссылка
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаОР КАК ТаблицаОР
	//|		ПО торо_ВводНачальныхДанныхВыполненныеРаботы.ОбъектРемонта = ТаблицаОР.ОбъектРемонтныхРабот
	//|			И торо_ВводНачальныхДанныхВыполненныеРаботы.ВидРемонтныхРабот = ТаблицаОР.ВидРемонтныхРабот
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СДублями.ДатаНачалаФакт КАК ДатаНачала,
	|	СДублями.ДатаОкончанияФакт КАК ДатаОкончания,
	|	СДублями.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	СДублями.Ссылка КАК Регистратор,
	|	СДублями.ОбъектРемонтныхРабот КАК ОбъектРемонта,
	|	СДублями.ID КАК ID
	|ИЗ
	|	СДублями КАК СДублями
	|ГДЕ
	|	ВЫБОР
	|			КОГДА СДублями.Ссылка ЕСТЬ NULL
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ СДублями.Ссылка.Организация ЕСТЬ NULL
	|		КОНЕЦ
	|	И СДублями.Ссылка.Проведен = ИСТИНА
	|
	|СГРУППИРОВАТЬ ПО
	|	СДублями.ДатаНачалаФакт,
	|	СДублями.ДатаОкончанияФакт,
	|	СДублями.ВидРемонтныхРабот,
	|	СДублями.Ссылка,
	|	СДублями.ОбъектРемонтныхРабот,
	|	СДублями.ID";	
	
	Запрос.УстановитьПараметр("ТаблицаОР", ТаблицаОР);			  
	ЗавершенныеРемонтныеРаботыОбъект = РеквизитФормыВЗначение("ЗавершенныеРемонтныеРаботы");			   
	ТаблицаЗавершенных = Запрос.Выполнить().Выгрузить();
	
	ИмяОР = "ОбъектРемонта";
	ИмяВР = "ВидРемонтныхРабот";
	УдалитьДублирующиесяСтрокиПоОРИВР(ТаблицаЗавершенных,ЗавершенныеРемонтныеРаботыОбъект,ЗамещатьНормативы,ИмяОР,ИмяВР);
	Для Каждого Строка Из ТаблицаЗавершенных Цикл
		НоваяСтрока = ЗавершенныеРемонтныеРаботыОбъект.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
	КонецЦикла;
	ЗначениеВРеквизитФормы(ЗавершенныеРемонтныеРаботыОбъект, "ЗавершенныеРемонтныеРаботы");

