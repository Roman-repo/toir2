Функция ДобавитьСтрокуОРВДерево(СтрокаПоложенияОР, ОбъектРемонта, ТиповойОР)
		
	СтрокаОР = СтрокаПоложенияОР.ПолучитьЭлементы().Добавить();
	СтрокаОР.Ремонты = ОбъектРемонта;
	СтрокаОР.ОбъектРемонта = ОбъектРемонта;
