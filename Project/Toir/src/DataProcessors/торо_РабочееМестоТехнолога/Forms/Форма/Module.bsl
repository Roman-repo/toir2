&НаКлиенте
Процедура ДеревоОкончаниеПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка)
	торо_РаботаСИерархией20Клиент.ОбновитьДеревоИерархии(ЭтотОбъект, "Дерево");
	Для Каждого СМ Из ПараметрыПеретаскивания.Значение Цикл
		Для Каждого СТ Из ПроверенныеОР Цикл
			Если СТ.ОР = СМ.Ссылка Тогда 
				ПроверенныеОР.Удалить(СТ);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	ДозаполнитьДеревоНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура СоздатьФМ(Команда)
	Если Этаформа.ТекущийЭлемент = Элементы.Дерево Тогда 
		ТекДанные = Элементы.Дерево.ТекущиеДанные;
	Иначе
		ТекДанные = Элементы.Список.ТекущиеДанные;
	КонецЕсли;
	Если Не ТекДанные = Неопределено Тогда 
		// Справочники.торо_ОбъектыРемонта.ПустаяСсылка()
		СтруктураОпОп = Новый Структура();
		ОпОп = Новый ОписаниеОповещения("ПослеСозданияФМ",ЭтотОбъект,СтруктураОпОп);
		ТемпРодитель = ТекДанные.Ссылка;
		ОткрытьФорму("Справочник.торо_ОбъектыРемонта.Форма.ФормаЭлемента",Новый Структура("СтруктураИерархии, РодительИерархии, СоздатьФМ", ТекСтруктураИерархии, ТемпРодитель,Истина),,,,,ОпОп);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеСозданияФМ(Результат, ДопПараметры)Экспорт
	торо_РаботаСИерархией20Клиент.ОбновитьДеревоИерархии(ЭтотОбъект, "Дерево");
	ДозаполнитьДеревоНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьФМИзИерархии(Команда)
	Если Этаформа.ТекущийЭлемент = Элементы.Дерево Тогда 
		ТекДанные = Элементы.Дерево.ТекущиеДанные;
	Иначе
		ТекДанные = Элементы.Список.ТекущиеДанные;
	КонецЕсли;

	Если Не ТекДанные = Неопределено Тогда 
		ТемпРодитель = ТекДанные.Ссылка;
		СтруктураОпОп = Новый Структура("Родитель, Иерархия", ТемпРодитель, ТекСтруктураИерархии);
		ОписаниеОповещенияПослеВыбора = Новый ОписаниеОповещения("ДобавитьФМВИерархию", ЭтотОбъект, СтруктураОпОп);
		СтрПарметрыФормы = Новый Структура("ОтборТипОбъекта,ИспользоватьОтборТипОбъекта",
				ТипОбъектаФМ, Истина);
		ОткрытьФорму("Справочник.торо_ОбъектыРемонта.ФормаВыбора", СтрПарметрыФормы,,,,, ОписаниеОповещенияПослеВыбора, 
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьФМВИерархию(Результат, ДопПараметры)Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда 
		
		ДобавитьФМВИерархиюНаСервере(Результат,ДопПараметры.Родитель,ДопПараметры.Иерархия);
		торо_РаботаСИерархией20Клиент.ОбновитьДеревоИерархии(ЭтотОбъект, "Дерево");
		ДозаполнитьДеревоНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьФМВИерархиюНаСервере(ФМ, Родитель, Иерархия)
	Если ТипЗнч(ФМ) = Тип("Массив") Тогда 
		Для Каждого СМ Из ФМ Цикл
			Если Иерархия.ИзменяетсяДокументами Тогда 
				Док = Документы.торо_ИзменениеПоложенияВСтруктуреИерархии.СоздатьДокумент();
				Док.Дата = ТекущаяДата();
				Док.Комментарий = "Добавлен из другой иерархии";
				Док.СтруктураИерархии = Иерархия;
				Док.Ответственный = ПараметрыСеанса.ТекущийПользователь;
				НС = Док.ПоложенияВСтруктуреИерархии.Добавить();
				НС.ОбъектИерархии = СМ;
				НС.РодительИерархии = Родитель;
				Док.Записать(РежимЗаписиДокумента.Проведение);
			Иначе
				НЗ = РегистрыСведений.торо_ИерархическиеСтруктурыОР.СоздатьНаборЗаписей();
				НЗ.Отбор.ОбъектИерархии.Установить(СМ);
				НЗ.Отбор.СтруктураИерархии.Установить(Иерархия);
				НС = НЗ.Добавить();
				НС.ОбъектИерархии = СМ;
				НС.СтруктураИерархии = Иерархия;
				НС.РодительИерархии = Родитель;
				НЗ.Записать();
			КонецЕсли;
		КонецЦикла;
	Иначе
		Если Иерархия.ИзменяетсяДокументами Тогда 
			Док = Документы.торо_ИзменениеПоложенияВСтруктуреИерархии.СоздатьДокумент();
			Док.Дата = ТекущаяДата();
			Док.Комментарий = "Добавлен из другой иерархии";
			Док.СтруктураИерархии = Иерархия;
			Док.Ответственный = ПараметрыСеанса.ТекущийПользователь;
			НС = Док.ПоложенияВСтруктуреИерархии.Добавить();
			НС.ОбъектИерархии = ФМ;
			НС.РодительИерархии = Родитель;
			Док.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			НЗ = РегистрыСведений.торо_ИерархическиеСтруктурыОР.СоздатьНаборЗаписей();
			НЗ.Отбор.ОбъектИерархии.Установить(ФМ);
			НЗ.Отбор.СтруктураИерархии.Установить(Иерархия);
			НС = НЗ.Добавить();
			НС.ОбъектИерархии = ФМ;
			НС.СтруктураИерархии = Иерархия;
			НС.РодительИерархии = Родитель;
			НЗ.Записать();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
//
&НаСервере
Процедура ПроверитьФМНаСервере(Ссылка=Неопределено,ЭтоФМ = Ложь,ВсюИерархию = Ложь)
	Если ЭтоФМ Тогда 
		Результат = гкс_ПроверкаФункциональныхМест.ПроверитьОграниченияМассиваОР(,Ссылка);
	ИначеЕсли ВсюИерархию Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	торо_ИерархическиеСтруктурыОР.РодительИерархии КАК Ссылка
			|ПОМЕСТИТЬ ВсеФМ
			|ИЗ
			|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК торо_ИерархическиеСтруктурыОР
			|ГДЕ
			|	торо_ИерархическиеСтруктурыОР.СтруктураИерархии = &СтруктураИерархии
			|	И торо_ИерархическиеСтруктурыОР.РодительИерархии.ТипОбъекта = &ТипОбъекта
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии
			|ИЗ
			|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(, СтруктураИерархии = &СтруктураИерархии) КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних
			|ГДЕ
			|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии.ТипОбъекта = &ТипОбъекта
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	торо_ИерархическиеСтруктурыОР.ОбъектИерархии
			|ИЗ
			|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК торо_ИерархическиеСтруктурыОР
			|ГДЕ
			|	торо_ИерархическиеСтруктурыОР.СтруктураИерархии = &СтруктураИерархии
			|	И торо_ИерархическиеСтруктурыОР.ОбъектИерархии.ТипОбъекта = &ТипОбъекта
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии
			|ИЗ
			|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(, СтруктураИерархии = &СтруктураИерархии) КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних
			|ГДЕ
			|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии.ТипОбъекта = &ТипОбъекта
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВсеФМ.Ссылка КАК Ссылка
			|ИЗ
			|	ВсеФМ КАК ВсеФМ";
		
		Запрос.УстановитьПараметр("СтруктураИерархии", ТекСтруктураИерархии);
		Запрос.УстановитьПараметр("ТипОбъекта", ТипОбъектаФМ);
		
		ТемпМассив = Новый Массив();
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() = Ложь Тогда 
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				ТемпМассив.Добавить(Выборка.Ссылка);
			КонецЦикла;
			Результат = гкс_ПроверкаФункциональныхМест.ПроверитьОграниченияМассиваОР(,ТемпМассив);
		Иначе
			Возврат;
		КонецЕсли;
	Иначе

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	торо_ИерархическиеСтруктурыОР.РодительИерархии КАК Ссылка
			|ИЗ
			|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК торо_ИерархическиеСтруктурыОР
			|ГДЕ
			|	торо_ИерархическиеСтруктурыОР.СтруктураИерархии = &СтруктураИерархии
			|	И торо_ИерархическиеСтруктурыОР.ОбъектИерархии = &Ссылка
			|	И торо_ИерархическиеСтруктурыОР.РодительИерархии.ТипОбъекта = &ТипОбъекта
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии
			|ИЗ
			|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
			|			,
			|			СтруктураИерархии = &СтруктураИерархии
			|				И ОбъектИерархии = &Ссылка) КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних
			|ГДЕ
			|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии.ТипОбъекта = &ТипОбъекта";
		
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Запрос.УстановитьПараметр("СтруктураИерархии", ТекСтруктураИерархии);
		Запрос.УстановитьПараметр("ТипОбъекта", ТипОбъектаФМ);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() = Ложь Тогда 
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			Результат = гкс_ПроверкаФункциональныхМест.ПроверитьОграниченияМассиваОР(,Выборка.Ссылка);
		Иначе
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Структура") Тогда 
		Если Результат.Свойство("НеПодходят") Тогда 
			Для Каждого СМ Из Результат.НеПодходят Цикл
				НеНайден = Истина;
				Для Каждого СТ ИЗ ПроверенныеОР Цикл
					Если СТ.ОР = СМ.Ссылка Тогда 
						СТ.Подходит = Ложь;
						НеНайден = Ложь;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Если НеНайден Тогда 
					НС = ПроверенныеОР.Добавить();
					НС.ОР = СМ.Ссылка;
					НС.Подходит = Ложь;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если Результат.Свойство("Подходят")  Тогда 
			Найденные = Новый Массив();
			Для Каждого СТ ИЗ ПроверенныеОР Цикл
				Если Не Результат.Подходят.Найти(СТ.ОР) = Неопределено Тогда 
					СТ.Подходит = Истина;
					Найденные.Добавить(СТ.ОР);
					Если Найденные.Количество() = Результат.Подходят.Количество() Тогда 
						Прервать;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			Если не Найденные.Количество() = Результат.Подходят.Количество() Тогда 
				Для Каждого СМ Из Результат.Подходят Цикл
					Если Найденные.Найти(СМ) = Неопределено Тогда 
						НС = ПроверенныеОР.Добавить();
						НС.ОР = СМ;
						НС.Подходит = Истина;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	ДозаполнитьДерево();
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьФМ(Команда)
	ТекущиеДанные = Элементы.Дерево.ТекущиеДанные;
	Если Не ТекущиеДанные = Неопределено Тогда 
		Если ТекущиеДанные.ТипОбъекта = ТипОбъектаФМ Тогда 
			ПроверитьФМНаСервере(ТекущиеДанные.Ссылка,Истина);
		Иначе
			ПроверитьФМНаСервере(ТекущиеДанные.Ссылка,Ложь);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьВсе(Команда)
	ПроверитьФМНаСервере(,Ложь,Истина);
КонецПроцедуры
// отметить проверенные строки в дереве
&НаСервере
Процедура ДозаполнитьДерево()
	Если ПроверенныеОР.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	МассивПодходит = Новый Массив();
	МассивНеПодходит = Новый Массив();
	Для Каждого СТ Из ПроверенныеОР Цикл 
		Если СТ.Подходит Тогда 
			МассивПодходит.Добавить(СТ.ОР);
		Иначе
			МассивНеПодходит.Добавить(СТ.ОР);
		КонецЕсли;
	КонецЦикла;
	ДозаполнитьДеревоГлубже(Дерево,МассивПодходит,МассивНеПодходит);
КонецПроцедуры

&НаСервере
Процедура ДозаполнитьДеревоГлубже(ТекУровень,МассивДа,МассивНет)
	Корень = ТекУровень.ПолучитьЭлементы();
	Для Каждого СТ Из Корень Цикл
		СТ.Подходит = Ложь;
		СТ.НеПодходит = Ложь;
		Если Не МассивДа.Найти(СТ.Ссылка) = Неопределено Тогда 
			СТ.Подходит = Истина;
		ИначеЕсли Не МассивНет.Найти(СТ.Ссылка) = Неопределено Тогда 
			СТ.НеПодходит = Истина;
		КонецЕсли;
		ДозаполнитьДеревоГлубже(СТ,МассивДа,МассивНет);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДозаполнитьДеревоНаКлиенте()
	Если ПроверенныеОР.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	МассивПодходит = Новый Массив();
	МассивНеПодходит = Новый Массив();
	Для Каждого СТ Из ПроверенныеОР Цикл 
		Если СТ.Подходит Тогда 
			МассивПодходит.Добавить(СТ.ОР);
		Иначе
			МассивНеПодходит.Добавить(СТ.ОР);
		КонецЕсли;
	КонецЦикла;
	ДозаполнитьДеревоГлубжеНаКлиенте(Дерево,МассивПодходит,МассивНеПодходит);
КонецПроцедуры

&НаКлиенте
Процедура ДозаполнитьДеревоГлубжеНаКлиенте(ТекУровень,МассивДа,МассивНет)
	Корень = ТекУровень.ПолучитьЭлементы();
	Для Каждого СТ Из Корень Цикл
		СТ.Подходит = Ложь;
		СТ.НеПодходит = Ложь;
		Если Не МассивДа.Найти(СТ.Ссылка) = Неопределено Тогда 
			СТ.Подходит = Истина;
		ИначеЕсли Не МассивНет.Найти(СТ.Ссылка) = Неопределено Тогда 
			СТ.НеПодходит = Истина;
		КонецЕсли;
		ДозаполнитьДеревоГлубжеНаКлиенте(СТ,МассивДа,МассивНет);
	КонецЦикла;
	
КонецПроцедуры
//
&НаКлиенте
Процедура ПроверенныеОРВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекДанные = Элементы.ПроверенныеОР.ТекущиеДанные;
	Если не ТекДанные = Неопределено Тогда 
		ИдСтроки = Неопределено;
		НайтиСтрокуДереваГлубже(Дерево,ТекДанные.ОР,ИдСтроки);
		Если ЗначениеЗаполнено(ИдСтроки) Тогда 
			Элементы.Дерево.ТекущаяСтрока = ИдСтроки;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НайтиСтрокуДереваГлубже(ТекУровень,Ссылка,ИдСтроки = Неопределено)
	Корень = ТекУровень.ПолучитьЭлементы();
	Для Каждого СТ Из Корень Цикл
		Если ЗначениеЗаполнено(ИдСтроки) Тогда 
			Возврат;
		КонецЕсли;
		Если СТ.Ссылка = Ссылка Тогда 
			ИдСтроки = СТ.ПолучитьИдентификатор();
			Возврат;
		КонецЕсли;
		НайтиСтрокуДереваГлубже(СТ,Ссылка,ИдСтроки);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ИзмененаСтруктураИерархииОР" Тогда
		торо_РаботаСИерархией20Клиент.ОбновитьДеревоИерархии(ЭтотОбъект, "Дерево");
		ТекДанные = Элементы.Дерево.ТекущиеДанные;
		Если НЕ ТекДанные = Неопределено Тогда 
			Для Каждого СТ Из ПроверенныеОР Цикл
				Если СТ.ОР = ТекДанные.Ссылка Тогда 
					ПроверенныеОР.Удалить(СТ);
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		ДозаполнитьДеревоНаКлиенте();
	ИначеЕсли ИмяСобытия = "ЗаписанОбъектРемонта" Тогда
		торо_РаботаСИерархией20Клиент.ОбновитьДеревоИерархии(ЭтотОбъект, "Дерево");
		//ДозаполнитьДеревоНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

