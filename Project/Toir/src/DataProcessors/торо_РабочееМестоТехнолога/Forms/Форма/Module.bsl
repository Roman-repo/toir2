
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ТипОбъектаФМ = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто;
	ТипПоиска = "Наименование";
	
	ТекСтруктураИерархии = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
	"НастройкиТОиР",
	"ОсновнаяСтруктураИерархии",
	Истина);
	
	ИспользоватьКартинкиТОР = Константы.торо_ИспользоватьКартинкиТиповыхОбъектов.Получить();
	
	РазрешитьПеретаскиваниеОРВИерархии = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("НастройкиТОиР", "РазрешитьПеретаскиваниеОРВИерархии", Истина);
	
	ОбработатьИзменениеИерархииНаСервере();
	
	Если ИспользоватьКартинкиТОР Тогда 
		Элементы.Дерево.ПутьКДаннымКартинкиСтроки = "Дерево.КартинкаОтображаемая";
	Иначе 
		Элементы.Дерево.ПутьКДаннымКартинкиСтроки = "Дерево.Картинка";
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеИерархииНаСервере()
	
	торо_РаботаСИерархией20.ЗаполнитьПараметрыИерархии(ЭтаФорма);
	СтруктураПараметровИерархии.КонечныеЭлементыВДереве = Истина;
	ПустойРодитель = торо_РаботаСИерархией20.ПустойРодительПоСтруктуреИерархии(СтруктураПараметровИерархии);
	торо_РаботаСИерархией20.УстановитьЗапросВСпискеПоИерархии(Список, СтруктураПараметровИерархии, ПустойРодитель);
	торо_РаботаСИерархией20КлиентСервер.УстановитьОтборСпискаПоРодителю(Список, ПустойРодитель, Ложь);
	торо_РаботаСИерархией20КлиентСервер.НачатьЗаполнениеДереваИерархии(Дерево, СтруктураПараметровИерархии, ПустойРодитель);
	
	Если ИспользоватьКартинкиТОР Тогда
		ОбновитьКартинкиЭлементовДереваНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаСервере 
Процедура ОбновитьКартинкиЭлементовДереваНаСервере(ИдентификаторСтроки = 0)
	торо_РаботаСИерархией20.ОбновитьКартинкиЭлементовДереваНаСервере(Дерево, ИдентификаторСтроки);
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПередРазворачиванием(Элемент, Строка, Отказ)
	
	торо_РаботаСИерархией20Клиент.ДеревоПередРазворачиванием(Дерево, Строка, СтруктураПараметровИерархии);
	Если ИспользоватьКартинкиТОР Тогда
		ОбновитьКартинкиЭлементовДереваНаСервере(Строка);
	КонецЕсли;
	
	ДозаполнитьДеревоНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПередНачаломИзменения(Элемент, Отказ)
	торо_РаботаСИерархией20Клиент.ПередНачаломИзменения(Элемент, Отказ, ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПриАктивизацииСтроки(Элемент)
	ПодключитьОбработчикОжидания("ЗаполнитьДанныеОРНаКлиенте",0.1,Истина);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеОРНаКлиенте()
	ТекущиеДанные = Элементы.Дерево.ТекущиеДанные;
	Если Не ТекущиеДанные = Неопределено Тогда 
		Если ТекущиеДанные.ТипОбъекта = ТипОбъектаФМ Тогда 
			ОбновитьОграничения(ТекущиеДанные.Ссылка,Истина);
			ИзмеряемыеПоказатели.Очистить();
			ПаспортныеХарактеристики.Очистить();
		Иначе
			ОбновитьОграничения(ТекущиеДанные.Ссылка,Ложь);
			ОбновитьХарактеристика(ТекущиеДанные.Ссылка);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
// Таблица ограничений
&НаСервере
Процедура ОбновитьОграничения(Ссылка, ЭтоФМ)
	Ограничения.Очистить();
	Запрос = Новый Запрос;
	Если ЭтоФМ Тогда 
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	торо_ОбъектыРемонта.Ссылка КАК ФМ,
			|	торо_ОбъектыРемонта.ТиповойОР КАК ФМТОР
			|ПОМЕСТИТЬ ТекФМ
			|ИЗ
			|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
			|ГДЕ
			|	торо_ОбъектыРемонта.Ссылка = &Ссылка
			|";
	Иначе
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ИерархическиеСтруктурыОР.РодительИерархии КАК ФМ,
		|	торо_ИерархическиеСтруктурыОР.РодительИерархии.ТиповойОР КАК ТОР
		|ПОМЕСТИТЬ НужныйРодитель
		|ИЗ
		|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК торо_ИерархическиеСтруктурыОР
		|ГДЕ
		|	торо_ИерархическиеСтруктурыОР.СтруктураИерархии = &Иерархия
		|	И торо_ИерархическиеСтруктурыОР.ОбъектИерархии = &Ссылка
		|	И торо_ИерархическиеСтруктурыОР.РодительИерархии.ТипОбъекта = ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии,
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии.ТиповойОР
		|ИЗ
		|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
		|			,
		|			ОбъектИерархии = &Ссылка
		|				И СтруктураИерархии = &Иерархия) КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних
		|ГДЕ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии.ТипОбъекта = ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	НужныйРодитель.ТОР КАК ФМТОР,
		|	НужныйРодитель.ФМ КАК ФМ
		|ПОМЕСТИТЬ ТекФМ
		|ИЗ
		|	НужныйРодитель КАК НужныйРодитель";
	КонецЕсли;
	Запрос.Текст = Запрос.Текст + " ;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|"+"ВЫБРАТЬ РАЗЛИЧНЫЕ
		   |	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ограничение КАК Ограничение,
		   |	ЛОЖЬ КАК гкс_Удален,
		   |	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Иерархия КАК Иерархия
		   |ПОМЕСТИТЬ ОграниченияФМ
		   |ИЗ
		   |	ТекФМ КАК ТекФМ
		   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ОграниченияНаХарактеристикиОборудования КАК торо_ТиповыеОРОграниченияНаХарактеристикиОборудования
		   |		ПО ТекФМ.ФМТОР = торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ссылка
		   |
		   |ОБЪЕДИНИТЬ ВСЕ
		   |
		   |ВЫБРАТЬ
		   |	торо_ОграниченияНаХарактеристикиОборудования.Ограничение,
		   |	торо_ОграниченияНаХарактеристикиОборудования.гкс_Удален,
		   |	торо_ОграниченияНаХарактеристикиОборудования.Иерархия
		   |ИЗ
		   |	ТекФМ КАК ТекФМ
		   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОграниченияНаХарактеристикиОборудования КАК торо_ОграниченияНаХарактеристикиОборудования
		   |		ПО ТекФМ.ФМ = торо_ОграниченияНаХарактеристикиОборудования.ФункциональноеМесто
		   |			И (торо_ОграниченияНаХарактеристикиОборудования.Иерархия В (&Иерархии))
		   |;
		   |
		   |////////////////////////////////////////////////////////////////////////////////
		   |ВЫБРАТЬ
		   |	ОграниченияФМ.Ограничение КАК Ограничение,
		   |	МАКСИМУМ(ОграниченияФМ.гкс_Удален) КАК гкс_Удален,
		   |	ОграниченияФМ.Иерархия КАК Иерархия
		   |ПОМЕСТИТЬ БезУдаленных
		   |ИЗ
		   |	ОграниченияФМ КАК ОграниченияФМ
		   |
		   |СГРУППИРОВАТЬ ПО
		   |	ОграниченияФМ.Ограничение,
		   |	ОграниченияФМ.Иерархия
		   |;
		   |
		   |////////////////////////////////////////////////////////////////////////////////
		   |ВЫБРАТЬ РАЗЛИЧНЫЕ
		   |	БезУдаленных.Ограничение КАК Ограничение,
		   |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Характеристика КАК Характеристика,
		   |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.ВидСравнения КАК ВидСравнения,
		   |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Значение КАК Значение
		   |ИЗ
		   |	БезУдаленных КАК БезУдаленных
		   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграничений КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений
		   |		ПО БезУдаленных.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Ссылка
		   |ГДЕ
		   |	БезУдаленных.гкс_Удален = ЛОЖЬ
		   |
		   |ОБЪЕДИНИТЬ ВСЕ
		   |
		   |ВЫБРАТЬ РАЗЛИЧНЫЕ
		   |	БезУдаленных.Ограничение,
		   |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Характеристика,
		   |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.ВидСравнения,
		   |	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Значение
		   |ИЗ
		   |	БезУдаленных КАК БезУдаленных
		   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграниченийПоказатели КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели
		   |		ПО БезУдаленных.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Ссылка
		   |ГДЕ
		   |	БезУдаленных.гкс_Удален = ЛОЖЬ";
	
	ТемпМассив = Новый Массив();
	ТемпМассив.Добавить(ТекСтруктураИерархии);
	ТемпМассив.Добавить(Справочники.торо_СтруктурыОР.ПустаяСсылка());
	Запрос.УстановитьПараметр("Иерархии",ТемпМассив);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Если ЭтоФМ = Ложь Тогда 
		Запрос.УстановитьПараметр("Иерархия",ТекСтруктураИерархии);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
			НС = Ограничения.Добавить();
			НС.Ограничение = Выборка.Ограничение;
			НС.дс_Текст = Строка(Выборка.Характеристика)+" "+Выборка.ВидСравнения+" "+Выборка.Значение;
	КонецЦикла;

КонецПроцедуры
// Таблицы текущих характеристик
&НаСервере
Процедура ОбновитьХарактеристика(Ссылка)
	ИзмеряемыеПоказатели.Очистить();
	ПаспортныеХарактеристики.Очистить();
	Если ЗначениеЗаполнено(Ссылка) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	торо_ОбъектыРемонта.Ссылка КАК ОР,
	|	торо_ОбъектыРемонта.ТиповойОР КАК ТОР
	|ПОМЕСТИТЬ ВсеОР
	|ИЗ
	|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
	|ГДЕ
	|	торо_ОбъектыРемонта.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЧ.Ограничение КАК Ограничение
	|ПОМЕСТИТЬ Ограничения
	|ИЗ
	|	&ТЧ КАК ТЧ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.Показатель КАК Показатель,
	|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.Значение КАК Значение,
	|	торо_ЗначенияКонтролируемыхПоказателейСрезПоследних.ДатаКонтроля КАК ДатаКонтроля
	|ПОМЕСТИТЬ ПоказателиОР
	|ИЗ
	|	РегистрСведений.торо_ЗначенияКонтролируемыхПоказателей.СрезПоследних(, ОбъектРемонта = &Ссылка) КАК торо_ЗначенияКонтролируемыхПоказателейСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоказателиОР.ОбъектРемонта КАК ОбъектРемонта,
	|	ПоказателиОР.Показатель КАК Показатель,
	|	МАКСИМУМ(ПоказателиОР.ДатаКонтроля) КАК ДатаКонтроля
	|ПОМЕСТИТЬ ПоказателиОРМаксимум
	|ИЗ
	|	ПоказателиОР КАК ПоказателиОР
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоказателиОР.ОбъектРемонта,
	|	ПоказателиОР.Показатель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПоказателиОР.Показатель КАК Показатель,
	|	ПоказателиОР.Значение КАК Значение
	|ПОМЕСТИТЬ ПоказателиОРСрез
	|ИЗ
	|	ПоказателиОР КАК ПоказателиОР
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоказателиОРМаксимум КАК ПоказателиОРМаксимум
	|		ПО ПоказателиОР.ОбъектРемонта = ПоказателиОРМаксимум.ОбъектРемонта
	|			И ПоказателиОР.Показатель = ПоказателиОРМаксимум.Показатель
	|			И ПоказателиОР.ДатаКонтроля = ПоказателиОРМаксимум.ДатаКонтроля
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	торо_ТиповыеОРДополнительныеРеквизиты.Свойство КАК Свойство,
	|	торо_ТиповыеОРДополнительныеРеквизиты.Значение КАК Значение
	|ПОМЕСТИТЬ РеквизитыТОР
	|ИЗ
	|	ВсеОР КАК ВсеОР
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ДополнительныеРеквизиты КАК торо_ТиповыеОРДополнительныеРеквизиты
	|		ПО ВсеОР.ТОР = торо_ТиповыеОРДополнительныеРеквизиты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Характеристика КАК Характеристика,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.ВидСравнения КАК ВидСравнения,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Значение КАК Значение
	|ПОМЕСТИТЬ ОграниченияХаракетристики1
	|ИЗ
	|	Ограничения КАК Ограничения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграничений КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений
	|		ПО Ограничения.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОграниченияРеквизиты.ВидСравнения КАК ВидСравнения,
	|	ОграниченияРеквизиты.Значение КАК Значение,
	|	ЕСТЬNULL(торо_ГруппыХарактеристикОборудованияСписокХарактеристик.Характеристика, ОграниченияРеквизиты.Характеристика) КАК Характеристика
	|ПОМЕСТИТЬ ОграниченияХаракетристики
	|ИЗ
	|	ОграниченияХаракетристики1 КАК ОграниченияРеквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.торо_ГруппыХарактеристикОборудования.СписокХарактеристик КАК торо_ГруппыХарактеристикОборудованияСписокХарактеристик
	|		ПО ОграниченияРеквизиты.Характеристика = торо_ГруппыХарактеристикОборудованияСписокХарактеристик.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Характеристика КАК Характеристика,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.ВидСравнения КАК ВидСравнения,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Значение КАК Значение
	|ПОМЕСТИТЬ ОграниченияПоказатели
	|ИЗ
	|	Ограничения КАК Ограничения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграниченийПоказатели КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели
	|		ПО Ограничения.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоказателиОРСрез.Показатель КАК Свойство,
	|	ПоказателиОРСрез.Значение КАК Факт,
	|	ОграниченияПоказатели.ВидСравнения КАК ВидСравнения,
	|	ОграниченияПоказатели.Значение КАК План
	|ИЗ
	|	ПоказателиОРСрез КАК ПоказателиОРСрез
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОграниченияПоказатели КАК ОграниченияПоказатели
	|		ПО ПоказателиОРСрез.Показатель = ОграниченияПоказатели.Характеристика
	|ИТОГИ
	|	МАКСИМУМ(Факт)
	|ПО
	|	Свойство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеквизитыТОР.Свойство КАК Свойство,
	|	РеквизитыТОР.Значение КАК Факт,
	|	ОграниченияХаракетристики.ВидСравнения КАК ВидСравнения,
	|	ОграниченияХаракетристики.Значение КАК План
	|ИЗ
	|	РеквизитыТОР КАК РеквизитыТОР
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОграниченияХаракетристики КАК ОграниченияХаракетристики
	|		ПО РеквизитыТОР.Свойство = ОграниченияХаракетристики.Характеристика
	|ИТОГИ
	|	МАКСИМУМ(Факт)
	|ПО
	|	Свойство";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ТЧ", Ограничения.Выгрузить());
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[9].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		НС = ИзмеряемыеПоказатели.Добавить();
		НС.Характеристика = Выборка.Свойство;
		НС.Значение = Выборка.Факт;
		НеПодходит = Ложь;
		Выборка1 = Выборка.выбрать();
		ПроверитьХарактеристику(НеПодходит,Выборка1);
		НС.Подходит = Не НеПодходит;
	КонецЦикла;

	Выборка = РезультатЗапроса[10].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		НС = ПаспортныеХарактеристики.Добавить();
		НС.Характеристика = Выборка.Свойство;
		НС.Значение = Выборка.Факт;
		НеПодходит = Ложь;
		Выборка1 = Выборка.выбрать();
		ПроверитьХарактеристику(НеПодходит,Выборка1);
		НС.Подходит = Не НеПодходит;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ПроверитьХарактеристику(НеПодходит,Выборка1)
	Пока Выборка1.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка1.Свойство)=Ложь Тогда 
			Продолжить;
		КонецЕсли;
		ТипФакта = ТипЗнч(Выборка1.Факт);
		ТипПлана = ТипЗнч(Выборка1.План);
		Если Не ТипФакта = ТипПлана Тогда 
			Продолжить;
		КонецЕсли;
		Если Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.Равно Тогда 
			Если Не Выборка1.План = Выборка1.Факт Тогда 
				НеПодходит = Истина;
				Прервать;
			КонецЕсли;
		ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.НеРавно Тогда 
			Если Выборка1.План = Выборка1.Факт Тогда 
				НеПодходит = Истина;
				Прервать;
			КонецЕсли;
		ИначеЕсли ТипФакта = Тип("Число") ИЛИ ТипФакта = Тип("Дата") Тогда 
			Если Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.Больше Тогда 
				Если Выборка1.План >= Выборка1.Факт Тогда 
					НеПодходит = Истина;
					Прервать;
				КонецЕсли;
			ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.БольшеИлиРавно Тогда 
				Если Выборка1.План > Выборка1.Факт Тогда 
					НеПодходит = Истина;
					Прервать;
				КонецЕсли;
			ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.Меньше Тогда 
				Если Выборка1.План <= Выборка1.Факт Тогда 
					НеПодходит = Истина;
					Прервать;
				КонецЕсли;
			ИначеЕсли Выборка1.ВидСравнения = Перечисления.торо_ВидыСравнения.МеньшеИлиРавно Тогда 
				Если Выборка1.План < Выборка1.Факт Тогда 
					НеПодходит = Истина;
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
