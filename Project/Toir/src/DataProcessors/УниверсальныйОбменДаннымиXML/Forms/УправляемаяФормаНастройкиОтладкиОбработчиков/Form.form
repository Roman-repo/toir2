              <key>ru</key>
              <value>Вызывать алгоритмы как процедуры</value>
            </presentation>
            <presentation>
              <key>es</key>
              <value>Llamar los algoritmos como los procedimientos</value>
            </presentation>
            <presentation>
              <key>en</key>
              <value>Call Algorithms as Procedures</value>
            </presentation>
