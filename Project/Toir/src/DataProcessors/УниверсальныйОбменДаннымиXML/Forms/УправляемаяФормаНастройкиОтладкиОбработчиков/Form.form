              <value>1</value>
            </value>
          </choiceList>
          <choiceList>
            <presentation>
              <key>ru</key>
              <value>Подставлять код алгоритмов по месту вызова</value>
            </presentation>
            <presentation>
              <key>es</key>
              <value>Poner el código de los algoritmos del lugar de la llamada</value>
            </presentation>
            <presentation>
              <key>en</key>
              <value>Substitute the code of the algorithms at the place of the call</value>
            </presentation>
            <value xsi:type="core:NumberValue">
              <value>2</value>
            </value>
          </choiceList>
