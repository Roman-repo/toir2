  <attributes>
    <name>ЛентыНовостей</name>
    <title>
      <key>ru</key>
      <value>Ленты новостей</value>
    </title>
    <title>
      <key>es</key>
      <value>Las cintas de las novedades</value>
    </title>
    <title>
      <key>en</key>
      <value>News feeds</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЛентыНовостей.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЛентыНовостей.ДатаЗагрузкиПоследнихНовостей</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЛентыНовостей.ЛокальнаяЛентаНовостей</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЛентыНовостей.Протокол</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЛентыНовостей.ЧастотаОбновления</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Спр.Ссылка,
	Спр.ВерсияДанных,
	Спр.ПометкаУдаления,
	//Спр.Предопределенный,
	Спр.Код,
	Спр.Наименование,
	Спр.ОбязательныйКанал,
	Спр.Протокол,
	Спр.Сайт,
	Спр.ИмяФайла,
	Спр.ВариантЛогинаПароля,
	Спр.Логин,
	Спр.Пароль,
	Спр.ЗагруженоССервера,
	Спр.ВидимостьПоУмолчанию,
	Спр.ЧастотаОбновления,
	Спр.Комментарий,
	Спр.ПропускатьЗагрузкуБинарныхДанных,
	Спр.ЛокальнаяЛентаНовостей,
	//Спр.ДоступныеКатегорииНовостей.(
	//	Ссылка,
	//	НомерСтроки,
	//	КатегорияНовостей,
	//	РазрешеноНастраиватьПользователям,
	//	ОтборНастраиваетсяНаСервере
	//),
	//Спр.ИсключенияВидимости.(
	//	Ссылка,
	//	НомерСтроки,
	//	Пользователь
	//),
	Рег.ДатаЗагрузкиПоследнихНовостей,
	ВЫБОР
		КОГДА (Спр.Протокол &lt;> &quot;file&quot;) И (Спр.ЛокальнаяЛентаНовостей = ЛОЖЬ) Тогда
			&amp;Надпись_ОтключеноОбновлениеЧерезИнтернет // надпись будет отключаться с помощью условного оформления
		Иначе
			&quot;&quot;
	КОНЕЦ КАК ОбновлениеОтключено,
	ВЫБОР
		КОГДА (Спр.ЛокальнаяЛентаНовостей = ИСТИНА) Тогда
			&amp;Надпись_СоздаютсяНапрямуюВСправочнике // надпись будет отключаться с помощью условного оформления
		КОГДА (Спр.Протокол = &quot;file&quot;) Тогда
			&amp;Надпись_ЗагружаютсяИзФайла
		Иначе // http, https
			&amp;Надпись_ЗагружаютсяЧерезИнтернетПоПротоколу
	КОНЕЦ КАК ИсточникНовостей
ИЗ
	Справочник.ЛентыНовостей КАК Спр
	ЛЕВОЕ СОЕДИНЕНИЕ
	РегистрСведений.ДатыЗагрузкиПоследнихНовостей КАК Рег
	ПО
		Рег.ЛентаНовостей = Спр.Ссылка
ГДЕ
	Спр.ПометкаУдаления = ЛОЖЬ
</queryText>
      <mainTable>Catalog.ЛентыНовостей</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
