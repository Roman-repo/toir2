    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Рег.Список                 КАК Список,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(Рег.Список) = ТИП(ПланВидовХарактеристик.КатегорииНовостей) Тогда
			ВЫРАЗИТЬ(&amp;Надпись_СписокЗначенийКлассификатора КАК СТРОКА(30))
		Иначе
			&quot;&quot;
	КОНЕЦ                      КАК ТипСписка,
	Рег.ТекущаяВерсияНаКлиенте КАК ТекущаяВерсияНаКлиенте,
	Рег.ТекущаяВерсияНаСервере КАК ТекущаяВерсияНаСервере,
	ВЫБОР
		КОГДА (Рег.ТекущаяВерсияНаКлиенте &lt; Рег.ТекущаяВерсияНаСервере) И (Рег.ТекущаяВерсияНаСервере > &amp;ДатаОтсутствующихДанных) ТОГДА
			&amp;Надпись_ТребуетсяОбновление
		КОГДА (Рег.ТекущаяВерсияНаКлиенте &lt; Рег.ТекущаяВерсияНаСервере) И (Рег.ТекущаяВерсияНаСервере &lt;= &amp;ДатаОтсутствующихДанных) ТОГДА
			&amp;Надпись_ДанныеОтсутствуют
		КОГДА Рег.ТекущаяВерсияНаКлиенте >= Рег.ТекущаяВерсияНаСервере ТОГДА
			&amp;Надпись_ДанныеАктуальны
	КОНЕЦ                      КАК ТребуетсяОбновление
ИЗ
	РегистрСведений.ДатыОбновленияСтандартныхСписковНовостей КАК Рег
</queryText>
      <mainTable>InformationRegister.ДатыОбновленияСтандартныхСписковНовостей</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
