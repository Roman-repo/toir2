#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ДатаАктуальности") Тогда
		Объект.ДатаАктуальности = Параметры.ДатаАктуальности;
	Иначе
		Объект.ДатаАктуальности = ТекущаяДата();
	КонецЕсли; 
	                                           
	Если Параметры.Свойство("Владелец") Тогда
		Владелец = Параметры.Владелец;
	КонецЕсли;
	
	Если Параметры.Свойство("ДоступностьКнопкиЗаполнить") Тогда
		Элементы.ЗакрываемыеРемонтыЗаполнитьПлановыеРемонты.Доступность = Параметры.ДоступностьКнопкиЗаполнить;
	КонецЕсли;
	
	Если Параметры.Свойство("ЗакрываемыеРемонты") Тогда
		
		Для каждого Стр Из Параметры.ЗакрываемыеРемонты Цикл
			
			НС = Объект.ЗакрываемыеРемонты.Добавить();
			ЗаполнитьЗначенияСвойств(НС, Стр);
			
		КонецЦикла;
		
	Иначе
		
		Если Параметры.Свойство("ОтборРемонтов") Тогда
			ЗаполнитьПлановыеРемонтыНаСервере(Параметры.ОтборРемонтов.ID);
			ЗаполнитьАварийныеРемонтыНаСервере(Параметры.ОтборРемонтов.ID);
			
			Элементы.АварийныеРемонты.ОтборСтрок = Новый ФиксированнаяСтруктура("ПодходитПодОтбор", Истина);
			Элементы.ЗакрываемыеРемонты.ОтборСтрок = Новый ФиксированнаяСтруктура("ПодходитПодОтбор", Истина);
		Иначе
			ЗаполнитьПлановыеРемонтыНаСервере();
			ЗаполнитьАварийныеРемонтыНаСервере();
		КонецЕсли;
		
	КонецЕсли;
	
	ФОИспользоватьППР = ПолучитьФункциональнуюОпцию("торо_ИспользоватьППР");
	ФОИспользоватьВД = ПолучитьФункциональнуюОпцию("торо_УчетВыявленныхДефектовОборудования");
	
	ПричинаЗакрытияЗаявок = Константы.торо_ПричинаЗакрытияЗаявок.Получить();
	
	Элементы.ГруппаЗакрываемыеРемонты.Видимость = ФОИспользоватьППР;
	Элементы.ГруппаАварийныеРемонты.Видимость = ФОИспользоватьВД;
	
КонецПроцедуры  
 
#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗакрываемыеРемонты
&НаКлиенте
Процедура ЗакрываемыеРемонтыПередНачаломИзменения(Элемент, Отказ)
	Если Элементы.ЗакрываемыеРемонты.ТекущийЭлемент.Имя <> "ЗакрываемыеРемонтыОбрабатывать" Тогда
		Если Не Элементы.ЗакрываемыеРемонты.ТекущиеДанные.Обрабатывать Тогда 
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗакрываемыеРемонтыОтмененПриИзменении(Элемент)
	ТекСтрока = Элементы.ЗакрываемыеРемонты.ТекущиеДанные;
	Если ТекСтрока.Отменен И ТекСтрока.Перенесен Тогда
		ТекСтрока.Перенесен = Ложь;
	КонецЕсли;
	ЗакрытиеЗаявки(ТекСтрока);
КонецПроцедуры

&НаКлиенте
Процедура ЗакрываемыеРемонтыПеренесенПриИзменении(Элемент)
	ТекСтрока = Элементы.ЗакрываемыеРемонты.ТекущиеДанные;
	Если ТекСтрока.Перенесен И ТекСтрока.Отменен Тогда
		ТекСтрока.Отменен = Ложь;
	КонецЕсли;
	ЗакрытиеЗаявки(ТекСтрока);
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыАварийныеРемонты
&НаКлиенте
Процедура АварийныеРемонтыПередНачаломИзменения(Элемент, Отказ)
	Если Элементы.АварийныеРемонты.ТекущийЭлемент.Имя <> "АварийныеРемонтыОбрабатывать" Тогда
		Если Не Элементы.АварийныеРемонты.ТекущиеДанные.Обрабатывать Тогда
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура АварийныеРемонтыОтмененПриИзменении(Элемент)
	ТекСтрока = Элементы.АварийныеРемонты.ТекущиеДанные;
	ЗакрытиеЗаявки(ТекСтрока);
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура ВыполнитьОбработку(Команда)
	
	отказ = ВыполнитьОбработкуНаСервере();
		
	ПричиныНеЗаполнены = Ложь;
	Для Каждого Строка Из ОбрабатываемыеСтроки Цикл
		Если ((Строка.Отменен ИЛИ Строка.Перенесен) И НЕ ЗначениеЗаполнено(Строка.ПричинаЗакрытия))
			ИЛИ (Строка.ЗакрытьЗаявку И НЕ ЗначениеЗаполнено(Строка.ПричинаЗакрытияЗаявки)) Тогда
			Если ЗначениеЗаполнено(Владелец) Тогда
				ПоказатьПредупреждение(Неопределено,НСтр("es='No para todas las reparaciones cerradas (los Presupuestos de la reparación (¡las Demandas por la reparación) es indicada la Causa del cierre! ¡El tratamiento no es cumplido!';ru='Не для всех закрываемых ремонтов (Смет ремонта(Заявок на ремонт) указана Причина закрытия! Обработка не выполнена!';en='Not for all repairs to be closed (Repair estimates (Repair requests), the reason for closing is indicated! Processing failed!'"));
			Иначе
				ТекстСообщения = НСтр("es='No para todas las reparaciones cerradas (los Presupuestos de la reparación (¡las Demandas por la reparación) es indicada la Causa del cierre! ¡El tratamiento no es cumplido!';ru='Не для всех закрываемых ремонтов (Смет ремонта(Заявок на ремонт) указана Причина закрытия! Обработка не выполнена!';en='Not for all repairs to be closed (Repair estimates (Repair requests), the reason for closing is indicated! Processing failed!'");
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
			
			ПричиныНеЗаполнены = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если отказ или ПричиныНеЗаполнены Тогда
		Возврат;
	КонецЕсли;
	
	МассивНезаполненныхСтрок = ОбрабатываемыеСтроки.НайтиСтроки(Новый Структура("Обрабатывать, Отменен, Перенесен, ЗакрытьЗаявку", Истина, Ложь, Ложь, Ложь));
	Если МассивНезаполненныхСтрок.Количество()>0 Тогда
		Ответ = Неопределено;

		ПоказатьВопрос(Новый ОписаниеОповещения("ВыполнитьОбработкуЗавершение", ЭтотОбъект, Новый Структура("МассивНезаполненныхСтрок", МассивНезаполненныхСтрок)), НСтр("es='No para todas las líneas tratadas es indicado el tipo del tratamiento de la reparación (es anulado o llevado) o la demanda. ¿Da lo mismo cumplir el tratamiento?';ru='Не для всех обрабатываемых строк указан вид обработки ремонта (отменен или перенесен) или заявки. Все равно выполнить обработку?';en='Not all processed lines indicate the type of repair processing (canceled or rescheduled) or application. Do the processing anyway?'"), РежимДиалогаВопрос.ДаНет);
        Возврат;
	КонецЕсли;
	
	// Выполняем создание нового документа торо_ЗакрытиеЗаявокИРемонтов.
	ВыполнитьОбработкуФрагмент(МассивНезаполненныхСтрок);
	
	Оповестить("ЗакрытиеЗаявокИРемонтов", Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПлановыеРемонты(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ДатаАктуальности) Тогда
		ТекстСообщения = НСтр("es='¡Es imposible rellenar la parte tabular, porque no es rellenada la fecha de la actualidad!';ru='Невозможно заполнить табличную часть, т.к. не заполнена дата актуальности!';en='Unable to fill in the table part, the date of relevance is not filled!'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ЗаполнитьПлановыеРемонтыНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАварийныеРемонты(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ДатаАктуальности) Тогда
		ТекстСообщения = НСтр("es='¡Es imposible rellenar la parte tabular, porque no es rellenada la fecha de la actualidad!';ru='Невозможно заполнить табличную часть, т.к. не заполнена дата актуальности!';en='Unable to fill in the table part, the date of relevance is not filled!'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ЗаполнитьАварийныеРемонтыНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсеПлановые(Команда)
	Для каждого Стр Из Объект.ЗакрываемыеРемонты Цикл
	
		Стр.Обрабатывать = Истина;
	
	КонецЦикла; 
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсеПлановые(Команда)
	Для каждого Стр Из Объект.ЗакрываемыеРемонты Цикл
	
		Стр.Обрабатывать = Ложь;
	
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсеАварийные(Команда)
	Для каждого Стр Из Объект.АварийныеРемонты Цикл
	
		Стр.Обрабатывать = Истина;
	
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсеАварийные(Команда)
	Для каждого Стр Из Объект.АварийныеРемонты Цикл
	
		Стр.Обрабатывать = Ложь;
	
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Процедура ЗаполнитьАварийныеРемонтыНаСервере(ОтборРемонтов = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	РемонтыЗаявок.Регистратор КАК Регистратор
	               |ПОМЕСТИТЬ РемонтыСАктамиНарядами
	               |ИЗ
	               |	РегистрСведений.торо_ЗаявкиПоРемонтам КАК РемонтыЗаявок
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НарядыПоРемонтам КАК торо_НарядыПоРемонтам
	               |		ПО РемонтыЗаявок.IDРемонта = торо_НарядыПоРемонтам.IDРемонта
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктыПоРемонтам КАК торо_АктыПоРемонтам
	               |		ПО РемонтыЗаявок.IDРемонта = торо_АктыПоРемонтам.IDРемонта
	               |ГДЕ
	               |	НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
	               |				И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	торо_ЗаявкиПоРемонтам.IDРемонта КАК ID,
	               |	РемонтыСАктамиНарядами.Регистратор КАК Регистратор
	               |ПОМЕСТИТЬ РемонтыЗаявокСАктамиНарядами
	               |ИЗ
	               |	РемонтыСАктамиНарядами КАК РемонтыСАктамиНарядами
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК торо_ЗаявкиПоРемонтам
	               |		ПО РемонтыСАктамиНарядами.Регистратор = торо_ЗаявкиПоРемонтам.Регистратор
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	ID
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |"+"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                  |	торо_ВыявленныеДефекты.ID КАК ID,
	                  |	торо_ВыявленныеДефекты.Регистратор КАК Регистратор,
	                  |	торо_ВыявленныеДефекты.Период КАК Период,
	                  |	торо_ВыявленныеДефекты.ОтказавшийЭлемент КАК ОбъектРемонта
	                  |ПОМЕСТИТЬ РемонтыПлановыеИДефекты
	                  |ИЗ
	                  |	РегистрСведений.торо_ВыявленныеДефекты КАК торо_ВыявленныеДефекты
	                  |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеРемонты.СрезПоследних КАК торо_ОтмененныеРемонты
	                  |		ПО торо_ВыявленныеДефекты.ID = торо_ОтмененныеРемонты.ID
	                  |			И (торо_ОтмененныеРемонты.Отменен)
	                  |ГДЕ
	                  |	торо_ОтмененныеРемонты.ID ЕСТЬ NULL
	                  |
	                  |ОБЪЕДИНИТЬ ВСЕ
	                  |
	                  |ВЫБРАТЬ 
	                  |	ДокВО.ID,
	                  |	ДокВО.Регистратор,
	                  |	ДокВО.Период,
	                  |	ДокВО.ОбъектРемонта
	                  |ИЗ
	                  |	РегистрСведений.торо_ВнешниеОснованияДляРабот.СрезПоследних(, Регистратор ССЫЛКА Документ.торо_ВнешнееОснованиеДляРабот) КАК ДокВО
	                  |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеРемонты.СрезПоследних КАК торо_ОтмененныеРемонты
	                  |		ПО ДокВО.ID = торо_ОтмененныеРемонты.ID
	                  |			И (торо_ОтмененныеРемонты.Отменен)
	                  |ГДЕ
	                  |	торо_ОтмененныеРемонты.ID ЕСТЬ NULL
	                  |
	                  |ИНДЕКСИРОВАТЬ ПО
	                  |	ID"+"
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	РемонтыПлановыеИДефекты.ID КАК ID,
	               |	РемонтыПлановыеИДефекты.Регистратор КАК Регистратор,
	               |	РемонтыПлановыеИДефекты.Период КАК Период,
	               |	РемонтыПлановыеИДефекты.ОбъектРемонта КАК ОбъектРемонта
	               |ПОМЕСТИТЬ РемонтыПлановыеСПодчиненными
	               |ИЗ
	               |	РемонтыПлановыеИДефекты КАК РемонтыПлановыеИДефекты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НарядыПоРемонтам КАК торо_НарядыПоРемонтам
	               |		ПО РемонтыПлановыеИДефекты.ID = торо_НарядыПоРемонтам.IDРемонта
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктыПоРемонтам КАК торо_АктыПоРемонтам
	               |		ПО РемонтыПлановыеИДефекты.ID = торо_АктыПоРемонтам.IDРемонта
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РемонтыЗаявокСАктамиНарядами КАК РемонтыЗаявокСАктамиНарядами
	               |		ПО РемонтыПлановыеИДефекты.ID = РемонтыЗаявокСАктамиНарядами.ID
	               |ГДЕ
	               |	торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
	               |	И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL
	               |	И РемонтыЗаявокСАктамиНарядами.ID ЕСТЬ NULL
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	РемонтыПлановыеСПодчиненными.ID КАК ID,
	               |	РемонтыПлановыеСПодчиненными.ОбъектРемонта КАК ОбъектРемонта,
	               |	Константы.торо_ВидРемонтаПриВводеНаОснованииВыявленныхДефектов КАК ВидРемонта,
	               |	ВЫБОР
	               |		КОГДА НЕ Заявки.Регистратор ЕСТЬ NULL
	               |				И торо_ОтмененныеЗаявки.Заявка ЕСТЬ NULL
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК ЕстьЗаявка,
	               |	РемонтыПлановыеСПодчиненными.Регистратор КАК Регистратор,
	               |	Константы.торо_ОтменятьЗакрытиеЗаявок КАК Отменен,
	               |	Константы.торо_ПричинаЗакрытияРемонтов КАК ПричинаЗакрытия,
				   |	Константы.торо_ПричинаЗакрытияЗаявок КАК ПричинаЗакрытияЗаявки,
	               |	РемонтыПлановыеСПодчиненными.Регистратор КАК ДокументОснование,
	               |	РемонтыПлановыеСПодчиненными.Период КАК ДатаОбнаружения,
	               |	Заявки.Регистратор КАК Заявка
	               |ПОМЕСТИТЬ ПодготовленныеДанные
	               |ИЗ
	               |	РемонтыПлановыеСПодчиненными КАК РемонтыПлановыеСПодчиненными
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК Заявки
	               |		ПО РемонтыПлановыеСПодчиненными.ID = Заявки.IDРемонта
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки
	               |		ПО (Заявки.Регистратор = торо_ОтмененныеЗаявки.Заявка)
	               |			И РемонтыПлановыеСПодчиненными.ID = торо_ОтмененныеЗаявки.ИДРемонта,
	               |	Константы КАК Константы
	               |ГДЕ
	               |	РемонтыПлановыеСПодчиненными.Период <= &ДатаАктуальности
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Регистратор
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |"+"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                  |	торо_ВыявленныеДефекты.Ссылка КАК Ссылка
	                  |ПОМЕСТИТЬ ВТ_РазрешенныеДокументы
	                  |ИЗ
	                  |	Документ.торо_ВыявленныеДефекты КАК торо_ВыявленныеДефекты
	                  |ГДЕ
	                  |	торо_ВыявленныеДефекты.Ссылка В
	                  |			(ВЫБРАТЬ
	                  |				ПодготовленныеДанные.Регистратор КАК Регистратор
	                  |			ИЗ
	                  |				ПодготовленныеДанные КАК ПодготовленныеДанные)
	                  |
	                  |ОБЪЕДИНИТЬ ВСЕ
	                  |
	                  |ВЫБРАТЬ
	                  |	торо_ЗаявкаНаРемонт.Ссылка
	                  |ИЗ
	                  |	Документ.торо_ЗаявкаНаРемонт КАК торо_ЗаявкаНаРемонт
	                  |ГДЕ
	                  |	торо_ЗаявкаНаРемонт.Ссылка В
	                  |			(ВЫБРАТЬ
	                  |				ПодготовленныеДанные.Регистратор КАК Регистратор
	                  |			ИЗ
	                  |				ПодготовленныеДанные КАК ПодготовленныеДанные)
	                  |
	                  |ОБЪЕДИНИТЬ ВСЕ
	                  |
	                  |ВЫБРАТЬ
	                  |	ДокВО.Ссылка
	                  |ИЗ
	                  |	Документ.торо_ВнешнееОснованиеДляРабот КАК ДокВО
	                  |ГДЕ
	                  |	ДокВО.Ссылка В
	                  |			(ВЫБРАТЬ
	                  |				ПодготовленныеДанные.Регистратор КАК Регистратор
	                  |			ИЗ
	                  |				ПодготовленныеДанные КАК ПодготовленныеДанные)
	                  |
	                  |ОБЪЕДИНИТЬ ВСЕ
	                  |
	                  |ВЫБРАТЬ
	                  |	торо_ПланГрафикРемонта.Ссылка
	                  |ИЗ
	                  |	Документ.торо_ПланГрафикРемонта КАК торо_ПланГрафикРемонта
	                  |ГДЕ
	                  |	торо_ПланГрафикРемонта.Ссылка В
	                  |			(ВЫБРАТЬ
	                  |				ПодготовленныеДанные.Регистратор КАК Регистратор
	                  |			ИЗ
	                  |				ПодготовленныеДанные КАК ПодготовленныеДанные)
	                  |
	                  |ИНДЕКСИРОВАТЬ ПО
	                  |	Ссылка"+"
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ПодготовленныеДанные.ID КАК ID,
	               |	ПодготовленныеДанные.ОбъектРемонта КАК ОбъектРемонта,
	               |	ПодготовленныеДанные.ВидРемонта КАК ВидРемонта,
	               |	ПодготовленныеДанные.ЕстьЗаявка КАК ЕстьЗаявка,
	               |	ПодготовленныеДанные.Регистратор КАК Регистратор,
	               |	ПодготовленныеДанные.Отменен КАК Отменен,
	               |	ПодготовленныеДанные.ПричинаЗакрытия КАК ПричинаЗакрытия,
				   |	ПодготовленныеДанные.ПричинаЗакрытияЗаявки КАК ПричинаЗакрытияЗаявки,
	               |	ПодготовленныеДанные.ДокументОснование КАК ДокументОснование,
	               |	ПодготовленныеДанные.ДатаОбнаружения КАК ДатаОбнаружения,
	               |	ВЫБОР
	               |		КОГДА ПодготовленныеДанные.ЕстьЗаявка
	               |			ТОГДА ПодготовленныеДанные.Заявка
	               |		ИНАЧЕ &ПустаяСсылкаНаЗаявку
	               |	КОНЕЦ КАК Заявка
	               |ПОМЕСТИТЬ ДанныеСДублямиРемонтов
	               |ИЗ
	               |	ПодготовленныеДанные КАК ПодготовленныеДанные
	               |ГДЕ
	               |	ПодготовленныеДанные.Регистратор В
	               |			(ВЫБРАТЬ
	               |				ВТ_РазрешенныеДокументы.Ссылка КАК Ссылка
	               |			ИЗ
	               |				ВТ_РазрешенныеДокументы КАК ВТ_РазрешенныеДокументы)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	торо_СкользящийПланРаботСрезПоследних.ID_Ремонта КАК ID_Ремонта
	               |ПОМЕСТИТЬ вт_РемонтыИзОбщегоПлана
	               |ИЗ
	               |	РегистрСведений.торо_СкользящийПланРабот.СрезПоследних(
	               |			,
	               |			ID_Ремонта В
	               |				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |					ДанныеСДублямиРемонтов.ID КАК ID
	               |				ИЗ
	               |					ДанныеСДублямиРемонтов КАК ДанныеСДублямиРемонтов)) КАК торо_СкользящийПланРаботСрезПоследних
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	ID_Ремонта
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.ID КАК ID
	               |ПОМЕСТИТЬ ДублиРемонтов
	               |ИЗ
	               |	ДанныеСДублямиРемонтов КАК ВТ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ.ID
	               |
	               |ИМЕЮЩИЕ
	               |	КОЛИЧЕСТВО(ВТ.ID) > 1
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.ID КАК ID,
	               |	ВТ.ОбъектРемонта КАК ОбъектРемонта,
				   |	&&ОтборРемонтов КАК ПодходитПодОтбор,
	               |	ВТ.ВидРемонта КАК ВидРемонта,
	               |	ВТ.ЕстьЗаявка КАК ЕстьЗаявка,
	               |	ВТ.Регистратор КАК Регистратор,
	               |	ВТ.Отменен КАК Отменен,
	               |	ВТ.ПричинаЗакрытия КАК ПричинаЗакрытия,
				   |	ВТ.ПричинаЗакрытияЗаявки КАК ПричинаЗакрытияЗаявки,
	               |	ВТ.ДокументОснование КАК ДокументОснование,
	               |	ВТ.ДатаОбнаружения КАК ДатаОбнаружения,
	               |	ВТ.Заявка КАК Заявка,
	               |	ВЫБОР
	               |		КОГДА вт_РемонтыИзОбщегоПлана.ID_Ремонта ЕСТЬ NULL
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК РемонтВключенВОбщийПлан
	               |ИЗ
	               |	ДанныеСДублямиРемонтов КАК ВТ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ДублиРемонтов КАК ДублиРемонтов
	               |		ПО ВТ.ID = ДублиРемонтов.ID
	               |		ЛЕВОЕ СОЕДИНЕНИЕ вт_РемонтыИзОбщегоПлана КАК вт_РемонтыИзОбщегоПлана
	               |		ПО ВТ.ID = вт_РемонтыИзОбщегоПлана.ID_Ремонта
	               |ГДЕ
	               |	(ВТ.ЕстьЗаявка
	               |			ИЛИ ДублиРемонтов.ID ЕСТЬ NULL)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаОбнаружения";
				   
	Запрос.УстановитьПараметр("ДатаАктуальности", КонецДня(Объект.ДатаАктуальности));
	Запрос.УстановитьПараметр("ПустаяСсылкаНаЗаявку", Документы.торо_ЗаявкаНаРемонт.ПустаяСсылка());
	
	Если Не ОтборРемонтов = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&&ОтборРемонтов", "ВЫБОР 
																   |		КОГДА ВТ.ID В (&ОтборРемонтов)
																   |			ТОГДА ИСТИНА
																   |        ИНАЧЕ ЛОЖЬ
																   |	КОНЕЦ");
		Запрос.УстановитьПараметр("ОтборРемонтов", ОтборРемонтов);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&&ОтборРемонтов", "ИСТИНА");
	КонецЕсли;
	
	Результат = Запрос.Выполнить();
	
	Объект.АварийныеРемонты.Очистить();
	Объект.АварийныеРемонты.Загрузить(Результат.Выгрузить());
	
КонецПроцедуры

&НаСервере
