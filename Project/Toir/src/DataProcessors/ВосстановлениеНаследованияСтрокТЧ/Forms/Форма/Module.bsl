#Область ИнтерфейсныеПроцедуры

&НаКлиенте
Процедура УстановитьФлажокДляПодчиненных(Строка, Значение)
	
	Строка.Выбрано = Значение;
	ВложенныеСтроки = Строка.ПолучитьЭлементы();
	Для Каждого ВложеннаяСтрока Из ВложенныеСтроки Цикл
		УстановитьФлажокДляПодчиненных(ВложеннаяСтрока, Значение);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФлажокДляРодителей(Строка, Значение)
	
	СтрокаРодитель = Строка.ПолучитьРодителя();
	Если СтрокаРодитель = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НужноУстановитьЗначениеРодителя = Истина;
	Если Значение = Ложь Тогда
		ЭлементыРодителя = СтрокаРодитель.ПолучитьЭлементы();
		Для Каждого СтрокаВложенная ИЗ ЭлементыРодителя Цикл
			Если НЕ СтрокаВложенная.Выбрано = Значение Тогда
				НужноУстановитьЗначениеРодителя = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если НужноУстановитьЗначениеРодителя Тогда 
		Если НЕ СтрокаРодитель.Выбрано = Значение Тогда
			СтрокаРодитель.Выбрано = Значение;
			УстановитьФлажокДляРодителей(СтрокаРодитель, Значение);
		КонецЕсли;
	КонецЕсли;
		
	
КонецПроцедуры

&НаСервере
Процедура ОбъектыДляВосстановленияПриАктивизацииСтрокиНаСервере()
	
	ИДСтроки = Элементы.ОбъектыДляВосстановления.ТекущаяСтрока;
	Если ИДСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекСтрока = ОбъектыДляВосстановления.НайтиПоИдентификатору(ИДСтроки);
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекРодитель = ТекСтрока.РодительТекущий;
	
	Если ТипЗнч(ТекСтрока.Объект) = Тип("СправочникСсылка.Классы") Тогда
		ТекСписокРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(ТекСтрока.Объект);
		ТаблицаАтрибутов = Справочники.Классы.ПолучитьТаблицуАтрибутов(ТекСписокРодителей);
		ЗначенияАтрибутовКласса.Загрузить(ТаблицаАтрибутов);
		
	ИначеЕсли ТипЗнч(ТекСтрока.Объект) = Тип("СправочникСсылка.НоменклатураКласса") Тогда
		ТаблицаАтрибутов = Справочники.НоменклатураКласса.ПолучитьТаблицуАтрибутов(ТекСтрока.Объект);
		ЗначенияАтрибутовКласса.Загрузить(ТаблицаАтрибутов);
		
	Иначе 
		Возврат;
	КонецЕсли;
	
КонецПроцедуры // } Гкс-[TOIR-1/00000090] Однодворцев И. от 18.06.2019.

#КонецОбласти

#Область ПоискОбъектовДляВосстановления

&НаСервере
Процедура НайтиОбъектыДляВосстановленияНаСервере()
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	
	// 1. Все объекты, у которых есть строки таб.частей.
	Запрос.Текст = ТектЗапросаВсеСтрокиТЧ();
	Результаты = Запрос.ВыполнитьПакет();
	
	МассивОбъектов = Результаты[2].Выгрузить().ВыгрузитьКолонку("Объект");
	
	// 2. Получение строк ТЧ, для которых нужно установить нового родителя.
	Справочники.Классы.ПолучитьОбъектыВосстановленияНаследованияТЧ(МассивОбъектов, МенеджерВТ);
	
	Запрос.Текст = ТекстЗапросаВыборОбъектовДляВосстановления();
	Результаты = Запрос.ВыполнитьПакет();
	
	// 3. Поиск недостающих строк для построения иерархии (если на этапе 2 найдены строки вложенных таб.частей).
	Запрос.Текст = ТектЗапросаОбходСтрокВложенныхТабЧастей();
	
	ВыборкаСтрокиДляПоискаКорневогоОбъекта = Результаты[Результаты.ВГраница()].Выбрать();
	Пока ВыборкаСтрокиДляПоискаКорневогоОбъекта.Следующий() И ВыборкаСтрокиДляПоискаКорневогоОбъекта.Количество > 0 Цикл
		Результаты = Запрос.ВыполнитьПакет();
		ВыборкаСтрокиДляПоискаКорневогоОбъекта = Результаты[2].Выбрать();
	КонецЦикла;
	
	// 4. Таблица классов-родителей для построения иерархии объектов-владельцев таб.частей.
	Запрос.Текст = ТектЗапросаТаблицаРодителей();
	
	ТаблицаРодителей = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.Прямой);
	ОбработатьТаблицуРодителей(ТаблицаРодителей);
	
	// 5. Таблица иерархии классов с отбором по первому уровню ветвления 
	//    (отброс уровней иерархии, в которых только один вложенный элемент).
	Запрос.УстановитьПараметр("ТаблицаРодителей", ТаблицаРодителей);
	Запрос.Текст = ТектЗапросаДанныеДляПостроенияДерева();
	
	Результат = Запрос.Выполнить().Выбрать();
	
	СоответствиеЭлементовДерева = Новый Соответствие;
	СформироватьДеревоКлассов(Результат, СоответствиеЭлементовДерева);
	
	// 6. Таблица номенклатуры для добавления в дерево классов.
	Запрос.Текст = ТектЗапросаНоменклатураДляДобавленияВДерево();
	
	Результат = Запрос.Выполнить().Выбрать();
	ДобавитьВДеревоЭлементыВыборки(Результат, СоответствиеЭлементовДерева);
	
	// 7. Добавление таб.частей и строк в дерево.
	Запрос.Текст = ТектЗапросаВыборСтрокТЧДляДобавления();
	ВыборкаВТСтрокиДляДобавления = Запрос.Выполнить().Выбрать();
	
	Запрос.Текст = ТектЗапросаВыборПодстрокДляДобавления();
	
	СтрокиТЧ = Новый Массив;
	
	Пока ВыборкаВТСтрокиДляДобавления.Следующий() И ВыборкаВТСтрокиДляДобавления.Количество > 0 Цикл
		
		Результаты = Запрос.ВыполнитьПакет();
		ВыборкаСтрокиДляДобавления = Результаты[0].Выбрать();
		ДобавитьВДеревоСтрокиТЧ(ВыборкаСтрокиДляДобавления, СоответствиеЭлементовДерева, СтрокиТЧ);
		
		ВыборкаВТСтрокиДляДобавления = Результаты[3].Выбрать();
	КонецЦикла;
	
	// 8. Отметка строк, у которых нужно поменять родителя.
	ВыполнитьПоискСтрокДляВосстановления(СтрокиТЧ, СоответствиеЭлементовДерева);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ТектЗапросаВсеСтрокиТЧ()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СпрНоменклатураКласса.Ссылка КАК Объект
		|ПОМЕСТИТЬ ВТ_НоменклатураСХвостами
		|ИЗ
		|	Справочник.НоменклатураКласса КАК СпрНоменклатураКласса
		|ГДЕ
		|	НЕ СпрНоменклатураКласса.ЭтоГруппа
		|	И СпрНоменклатураКласса.Класс.КлассТабличнаяЧасть
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СпрКлассы.Ссылка КАК Объект
		|ПОМЕСТИТЬ ВТ_КлассыСХвостами
		|ИЗ
		|	Справочник.Классы КАК СпрКлассы
		|ГДЕ
		|	СпрКлассы.КлассТабличнаяЧасть
		|	И СпрКлассы.Родитель.КлассТабличнаяЧасть
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МножественныеЗначенияАтрибутов.Класс КАК Объект
		|ИЗ
		|	РегистрСведений.МножественныеЗначенияАтрибутов КАК МножественныеЗначенияАтрибутов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НоменклатураКласса КАК СпрНоменклатураКласса
		|		ПО МножественныеЗначенияАтрибутов.Класс = СпрНоменклатураКласса.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Классы КАК СпрКлассы
		|		ПО МножественныеЗначенияАтрибутов.Класс = СпрКлассы.Ссылка
		|ГДЕ
		|	МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса В
		|			(ВЫБРАТЬ
		|				ВТ_НоменклатураСХвостами.Объект
		|			ИЗ
		|				ВТ_НоменклатураСХвостами КАК ВТ_НоменклатураСХвостами
		|		
		|			ОБЪЕДИНИТЬ ВСЕ
		|		
		|			ВЫБРАТЬ
		|				ВТ_КлассыСХвостами.Объект
		|			ИЗ
		|				ВТ_КлассыСХвостами КАК ВТ_КлассыСХвостами)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_НоменклатураСХвостами
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КлассыСХвостами";
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервереБезКонтекста
Функция ТекстЗапросаВыборОбъектовДляВосстановления()
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВТ_НовыеРодители.Класс КАК Объект,
		|	ЕСТЬNULL(СпрКлассы.КлассТабличнаяЧасть, СпрНоменклатураКласса.Класс.КлассТабличнаяЧасть) КАК СтрокаВложеннойТЧ,
		|	ВЫБОР
		|		КОГДА НЕ СпрКлассы.Ссылка ЕСТЬ NULL
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ОбъектЭтоКласс,
		|	ВТ_НовыеРодители.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_НовыеРодители.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	ВТ_НовыеРодители.Порядок КАК Порядок,
		|	ИСТИНА КАК ЕстьСтрокиДляВосстановления,
		|	1 КАК ВидОшибки,
		|	""Ошибка наследования"" КАК ПредставлениеОшибки
		|ПОМЕСТИТЬ ВТ_СтрокиСХвостами
		|ИЗ
		|	ВТ_НовыеРодители КАК ВТ_НовыеРодители
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НоменклатураКласса КАК СпрНоменклатураКласса
		|		ПО ВТ_НовыеРодители.Класс = СпрНоменклатураКласса.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Классы КАК СпрКлассы
		|		ПО ВТ_НовыеРодители.Класс = СпрКлассы.Ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ДанныеДляПоискаВИерархии.КлассПоИерархии,
		|	СпрКлассы.КлассТабличнаяЧасть,
		|	ИСТИНА,
		|	ВТ_ДанныеДляПоискаВИерархии.АтрибутКласса,
		|	ВТ_СтрокиДляОбработки.ЗначениеАтрибутаКласса,
		|	ВТ_СтрокиДляОбработки.Порядок,
		|	ЛОЖЬ,
		|	0,
		|	""""
		|ИЗ
		|	ВТ_НовыеРодители КАК ВТ_НовыеРодители
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДанныеДляПоискаВИерархии КАК ВТ_ДанныеДляПоискаВИерархии
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СтрокиДляОбработки КАК ВТ_СтрокиДляОбработки
		|			ПО ВТ_ДанныеДляПоискаВИерархии.КлассПоИерархии = ВТ_СтрокиДляОбработки.Класс
		|				И ВТ_ДанныеДляПоискаВИерархии.АтрибутКласса = ВТ_СтрокиДляОбработки.АтрибутКласса
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Классы КАК СпрКлассы
		|			ПО ВТ_ДанныеДляПоискаВИерархии.КлассПоИерархии = СпрКлассы.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НовыеРодители КАК ВТ_НайденныеРодители
		|			ПО ВТ_ДанныеДляПоискаВИерархии.КлассПоИерархии = ВТ_НайденныеРодители.ЗначениеАтрибутаКласса
		|		ПО ВТ_НовыеРодители.Класс = ВТ_ДанныеДляПоискаВИерархии.Класс
		|			И ВТ_НовыеРодители.АтрибутКласса = ВТ_ДанныеДляПоискаВИерархии.АтрибутКласса
		|			И ВТ_НовыеРодители.ЗначениеАтрибутаКласса = ВТ_ДанныеДляПоискаВИерархии.ЗначениеАтрибутаКласса
		|ГДЕ 
		|	(НЕ СпрКлассы.КлассТабличнаяЧасть ИЛИ НЕ ВТ_НайденныеРодители.ЗначениеАтрибутаКласса ЕСТЬ NULL)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_СтрокиСХвостами.Объект
		|ПОМЕСТИТЬ ВТ_СтрокиДляПоискаКорневогоОбъекта
		|ИЗ
		|	ВТ_СтрокиСХвостами КАК ВТ_СтрокиСХвостами
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтрокиСХвостами КАК ВТ_НайденныеРодители
		|		ПО ВТ_СтрокиСХвостами.Объект = ВТ_НайденныеРодители.ЗначениеАтрибутаКласса
		|ГДЕ
		|	ВТ_СтрокиСХвостами.СтрокаВложеннойТЧ
		|	И ВТ_НайденныеРодители.Объект ЕСТЬ NULL";
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервереБезКонтекста
Функция ТектЗапросаОбходСтрокВложенныхТабЧастей()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	МножественныеЗначенияАтрибутов.Класс КАК Объект,
