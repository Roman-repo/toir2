Функция ТектЗапросаДанныеДляПостроенияДерева()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ТаблицаРодителей.КлассДляЧтения,
		|	ТаблицаРодителей.Класс,
		|	ТаблицаРодителей.Уровень
		|ПОМЕСТИТЬ ВТ_ТаблицаРодителей
		|ИЗ
		|	&ТаблицаРодителей КАК ТаблицаРодителей
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ТаблицаРодителей.Класс) КАК Класс,
		|	ВТ_ТаблицаРодителей.Уровень
		|ПОМЕСТИТЬ ВТ_Ветвления
		|ИЗ
		|	ВТ_ТаблицаРодителей КАК ВТ_ТаблицаРодителей
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ТаблицаРодителей.Уровень
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ТаблицаРодителей.Класс) > 1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МИНИМУМ(ВТ_Ветвления.Уровень) КАК Уровень
		|ПОМЕСТИТЬ ВТ_МинУровень
		|ИЗ
		|	ВТ_Ветвления КАК ВТ_Ветвления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ТаблицаРодителей.Уровень КАК Уровень,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_МинУровень.Уровень, 0) < ВТ_ТаблицаРодителей.Уровень
		|			ТОГДА Классы.Родитель
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Классы.ПустаяСсылка)
		|	КОНЕЦ КАК Родитель,
		|	ВТ_ТаблицаРодителей.Класс,
		|	Классы.Код
		|ИЗ
		|	ВТ_ТаблицаРодителей КАК ВТ_ТаблицаРодителей
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МинУровень КАК ВТ_МинУровень
		|		ПО (ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Классы КАК Классы
		|		ПО ВТ_ТаблицаРодителей.Класс = Классы.Ссылка
		|ГДЕ
		|	ВТ_ТаблицаРодителей.Уровень >= ЕСТЬNULL(ВТ_МинУровень.Уровень, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Уровень";
	
	Возврат ТекстЗапроса;
	
