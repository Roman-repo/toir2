		|	ВТ_СтрокиДляДобавленияНовые КАК ВТ_СтрокиДляДобавленияНовые
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_СтрокиДляДобавленияНовые";
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ОбработатьТаблицуРодителей(ТаблицаРодителей)
	
	ТаблицаРодителей.Колонки.Добавить("Уровень", Новый ОписаниеТипов("Число"));
	
	ТекКлассДляЧтения = Неопределено;
	Для Каждого СтрокаТЗ ИЗ ТаблицаРодителей Цикл
		Если НЕ СтрокаТЗ.КлассДляЧтения = ТекКлассДляЧтения Тогда
			М = 0;
			ТекКлассДляЧтения = СтрокаТЗ.КлассДляЧтения;
			ПредКласс = Неопределено;
		КонецЕсли;
		Если НЕ ПредКласс = СтрокаТЗ.Класс Тогда // Не заполняем уровень у дублирующихся строк.
			СтрокаТЗ.Уровень = М;
			Если М > 0 Тогда
				ПредКласс = СтрокаТЗ.Класс;
			КонецЕсли;
			М = М + 1;
		КонецЕсли;
	КонецЦикла;
	
	НайденоУдалить = ТаблицаРодителей.НайтиСтроки(Новый Структура("Уровень", 0));
	Для Каждого СтрокаТЗ ИЗ НайденоУдалить Цикл
		ТаблицаРодителей.Удалить(СтрокаТЗ);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьДеревоКлассов(ВыборкаКлассов, СоответствиеЭлементовДерева)
	
	ЭлементыКорневые = ОбъектыДляВосстановления.ПолучитьЭлементы();
	ЭлементыКорневые.Очистить();
	
	Пока ВыборкаКлассов.Следующий() Цикл
		Если НЕ ЗначениеЗаполнено(ВыборкаКлассов.Родитель) Тогда
			КоллекцияЭлементов = ЭлементыКорневые;
		Иначе
			СтруктураСтроки = СоответствиеЭлементовДерева[ВыборкаКлассов.Родитель];
			Если СтруктураСтроки = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			КоллекцияЭлементов = СтруктураСтроки.СтрокаДерева.ПолучитьЭлементы();
		КонецЕсли;
		
		СтрокаДерева = КоллекцияЭлементов.Добавить();
		СтрокаДерева.Объект = ВыборкаКлассов.Класс;
		СтрокаДерева.Код    = ВыборкаКлассов.Код;
		СтрокаДерева.ИндексКартинки = 1;
		//СтрокаДерева.Выбрано = Истина;
		
		СоответствиеЭлементовДерева.Вставить(ВыборкаКлассов.Класс, Новый Структура("СтрокаДерева", СтрокаДерева));
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьВДеревоЭлементыВыборки(ВыборкаЭлементов, СоответствиеЭлементовДерева)
	
	Пока ВыборкаЭлементов.Следующий() Цикл
		
		СтруктураСтроки = СоответствиеЭлементовДерева[ВыборкаЭлементов.Родитель];
		Если СтруктураСтроки = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		КоллекцияЭлементов = СтруктураСтроки.СтрокаДерева.ПолучитьЭлементы();
		
		СтрокаДерева = КоллекцияЭлементов.Добавить();
		СтрокаДерева.Объект = ВыборкаЭлементов.Объект;
		СтрокаДерева.Код    = ВыборкаЭлементов.Код;
		СтрокаДерева.ИндексКартинки = 1;
		//СтрокаДерева.Выбрано = Истина;
		
		СоответствиеЭлементовДерева.Вставить(ВыборкаЭлементов.Объект, Новый Структура("СтрокаДерева", СтрокаДерева));
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьВДеревоСтрокиТЧ(ВыборкаСтрокиДляДобавления, СоответствиеЭлементовДерева, СтрокиТЧ)
	
	Пока ВыборкаСтрокиДляДобавления.Следующий() Цикл
		
		СтруктураСтроки = СоответствиеЭлементовДерева[ВыборкаСтрокиДляДобавления.Объект];
		Если СтруктураСтроки = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТабЧасти = Неопределено;
		Если НЕ СтруктураСтроки.Свойство("ТабЧасти", ТабЧасти) Тогда
			ТабЧасти = Новый Соответствие;
			СтруктураСтроки.Вставить("ТабЧасти", ТабЧасти);
		КонецЕсли;
		
		СтрокаТабЧасти = ТабЧасти[ВыборкаСтрокиДляДобавления.АтрибутКласса];
		Если СтрокаТабЧасти = Неопределено Тогда
			КоллекцияЭлементов = СтруктураСтроки.СтрокаДерева.ПолучитьЭлементы();
			СтрокаТабЧасти = КоллекцияЭлементов.Вставить(ТабЧасти.Количество());
			СтрокаТабЧасти.Объект  = ВыборкаСтрокиДляДобавления.АтрибутКласса;
			//СтрокаТабЧасти.Выбрано = Истина;
			
			ТабЧасти.Вставить(ВыборкаСтрокиДляДобавления.АтрибутКласса, СтрокаТабЧасти);
		КонецЕсли;
		
		КоллекцияЭлементов = СтрокаТабЧасти.ПолучитьЭлементы();
		СтрокаДерева = КоллекцияЭлементов.Добавить();
		СтрокаДерева.Объект          = ВыборкаСтрокиДляДобавления.ЗначениеАтрибутаКласса;
		СтрокаДерева.Код             = ВыборкаСтрокиДляДобавления.Код;
		СтрокаДерева.РодительТекущий = ВыборкаСтрокиДляДобавления.Родитель;
		СтрокаДерева.ИндексКартинки = 2;
		СтрокаДерева.ЕстьСтрокиДляВосстановления = ВыборкаСтрокиДляДобавления.ЕстьСтрокиДляВосстановления;
		СтрокаДерева.ВидОшибки                   = ВыборкаСтрокиДляДобавления.ВидОшибки;
		СтрокаДерева.ПредставлениеОшибки         = ВыборкаСтрокиДляДобавления.ПредставлениеОшибки;
		
		СоответствиеЭлементовДерева.Вставить(ВыборкаСтрокиДляДобавления.ЗначениеАтрибутаКласса, 
			Новый Структура("СтрокаДерева", СтрокаДерева));
		СтрокиТЧ.Добавить(ВыборкаСтрокиДляДобавления.ЗначениеАтрибутаКласса);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ВыполнитьПоискСтрокДляВосстановления(СтрокиТЧ, СоответствиеЭлементовДерева)
	
	Для Каждого СтрокаТЧ ИЗ СтрокиТЧ Цикл
		СтруктураСтроки = СоответствиеЭлементовДерева[СтрокаТЧ];
		Если СтруктураСтроки = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТабЧасти = СтруктураСтроки.СтрокаДерева.ПолучитьРодителя();
		СтрокаОбъекта  = СтрокаТабЧасти.ПолучитьРодителя();
		
		// Ищем в таб.частях-родителях строку, в которой определена наследуемая строка.
		
		СтэкРодителей = Новый Массив;
		НайденРодительСтроки = НайтиРодителяСтроки(СтруктураСтроки, СтрокаОбъекта, СтрокаТабЧасти, 
			СоответствиеЭлементовДерева, СтэкРодителей);
		
		// Проходим по иерархии наследования, чтобы проследить, цела ли цепочка наследования?
		
		Если НайденРодительСтроки Тогда
			СтруктураСтроки.СтрокаДерева.ИндексКартинки = 3;
			ПроверитьИерархиюНаследованияСтроки(СтруктураСтроки, СтрокаТабЧасти, СтэкРодителей);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиРодителяСтроки(СтруктураСтроки, СтрокаОбъекта, СтрокаТабЧасти, СоответствиеЭлементовДерева, СтэкРодителей)
	
	СтруктураСтрокиРодителяОбъекта = ПолучитьСтруктуруРодителя(СтрокаОбъекта, СоответствиеЭлементовДерева);
	НайденРодительСтроки = Ложь;
	
	Пока НЕ НайденРодительСтроки И НЕ СтруктураСтрокиРодителяОбъекта = Неопределено Цикл
		СтэкРодителей.Добавить(СтруктураСтрокиРодителяОбъекта);
		ТабЧасти = Неопределено;
		Если СтруктураСтрокиРодителяОбъекта.Свойство("ТабЧасти", ТабЧасти) Тогда
			СтрокаТабЧастиРодителя = ТабЧасти[СтрокаТабЧасти.Объект];
			Если НЕ СтрокаТабЧастиРодителя = Неопределено Тогда
				ЭлементыТабЧасти = СтрокаТабЧастиРодителя.ПолучитьЭлементы();
				Для Каждого СтрокаТЧРодителя ИЗ ЭлементыТабЧасти Цикл
					Если СтрокаТЧРодителя.Объект = СтруктураСтроки.СтрокаДерева.РодительТекущий Тогда
						НайденРодительСтроки = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ НайденРодительСтроки Тогда
			СтруктураСтрокиРодителяОбъекта = ПолучитьСтруктуруРодителя(
				СтруктураСтрокиРодителяОбъекта.СтрокаДерева, СоответствиеЭлементовДерева);
		КонецЕсли;
	КонецЦикла;
	
	Возврат НайденРодительСтроки;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСтруктуруРодителя(СтрокаОбъекта, СоответствиеЭлементовДерева)
	
	Если СтрокаОбъекта.ИндексКартинки >= 2 Тогда
		СтруктураСтрокиРодителяОбъекта = СоответствиеЭлементовДерева[СтрокаОбъекта.РодительТекущий];
	Иначе
		СтрокаРодителяОбъекта = СтрокаОбъекта.ПолучитьРодителя();
		Если НЕ СтрокаРодителяОбъекта = Неопределено Тогда 
			СтруктураСтрокиРодителяОбъекта = СоответствиеЭлементовДерева[СтрокаРодителяОбъекта.Объект];
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтруктураСтрокиРодителяОбъекта;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ПроверитьИерархиюНаследованияСтроки(СтруктураСтроки, СтрокаТабЧасти, СтэкРодителей)
	
	РодительДляЗамены = СтруктураСтроки.СтрокаДерева.РодительТекущий;
	
	КолВо = СтэкРодителей.Количество();
	Для Н = 1 По КолВо-1 Цикл
		
		СтруктураСтрокиРодителяОбъекта = СтэкРодителей[КолВо-Н-1];
		ТабЧасти = Неопределено;
		Если СтруктураСтрокиРодителяОбъекта.Свойство("ТабЧасти", ТабЧасти) Тогда
			СтрокаТабЧастиРодителя = ТабЧасти[СтрокаТабЧасти.Объект];
			Если НЕ СтрокаТабЧастиРодителя = Неопределено Тогда
				ЭлементыТабЧасти = СтрокаТабЧастиРодителя.ПолучитьЭлементы();
				Для Каждого СтрокаТЧРодителя ИЗ ЭлементыТабЧасти Цикл
					Если СтрокаТЧРодителя.РодительТекущий = РодительДляЗамены Тогда
						РодительДляЗамены = СтрокаТЧРодителя.Объект;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ РодительДляЗамены = СтруктураСтроки.СтрокаДерева.РодительТекущий Тогда
		СтруктураСтроки.СтрокаДерева.ЕстьСтрокиДляВосстановления = Истина;
		СтруктураСтроки.СтрокаДерева.РодительУстановить = РодительДляЗамены;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ПоискДублейСтрок

&НаСервере
Процедура НайтиСтрокиДублиНаСервере()

	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	
	// 1. Все объекты, у которых есть строки таб.частей.
	Запрос.Текст = ТектЗапросаВсеСтрокиТЧ();
	Результаты = Запрос.ВыполнитьПакет();
	
	МассивОбъектов = Результаты[2].Выгрузить().ВыгрузитьКолонку("Объект");
	
	// 2. Получение строк-дублей.
	Справочники.Классы.ПолучитьДублиСтрок(МассивОбъектов, МенеджерВТ);
	
	Запрос.Текст = ТекстЗапросаВыборДублейСтрок();
	Результаты = Запрос.ВыполнитьПакет();
	
	// 3. Поиск недостающих строк для построения иерархии (если на этапе 2 найдены строки вложенных таб.частей).
	Запрос.Текст = ТектЗапросаОбходСтрокВложенныхТабЧастей();
	
	ВыборкаСтрокиДляПоискаКорневогоОбъекта = Результаты[Результаты.ВГраница()].Выбрать();
	Пока ВыборкаСтрокиДляПоискаКорневогоОбъекта.Следующий() И ВыборкаСтрокиДляПоискаКорневогоОбъекта.Количество > 0 Цикл
		Результаты = Запрос.ВыполнитьПакет();
		ВыборкаСтрокиДляПоискаКорневогоОбъекта = Результаты[2].Выбрать();
	КонецЦикла;
	
	// 4. Таблица классов-родителей для построения иерархии объектов-владельцев таб.частей.
	Запрос.Текст = ТектЗапросаТаблицаРодителей();
	
	ТаблицаРодителей = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.Прямой);
	ОбработатьТаблицуРодителей(ТаблицаРодителей);
	
	// 5. Таблица иерархии классов с отбором по первому уровню ветвления 
	//    (отброс уровней иерархии, в которых только один вложенный элемент).
	Запрос.УстановитьПараметр("ТаблицаРодителей", ТаблицаРодителей);
	Запрос.Текст = ТектЗапросаДанныеДляПостроенияДерева();
	
	Результат = Запрос.Выполнить().Выбрать();
	
	СоответствиеЭлементовДерева = Новый Соответствие;
	СформироватьДеревоКлассов(Результат, СоответствиеЭлементовДерева);
	
	// 6. Таблица номенклатуры для добавления в дерево классов.
	Запрос.Текст = ТектЗапросаНоменклатураДляДобавленияВДерево();
	
	Результат = Запрос.Выполнить().Выбрать();
	ДобавитьВДеревоЭлементыВыборки(Результат, СоответствиеЭлементовДерева);
	
	// 7. Добавление таб.частей и строк в дерево.
	Запрос.Текст = ТектЗапросаВыборСтрокТЧДляДобавления();
	ВыборкаВТСтрокиДляДобавления = Запрос.Выполнить().Выбрать();
	
	Запрос.Текст = ТектЗапросаВыборПодстрокДляДобавления();
	
	СтрокиТЧ = Новый Массив;
	
	Пока ВыборкаВТСтрокиДляДобавления.Следующий() И ВыборкаВТСтрокиДляДобавления.Количество > 0 Цикл
		
		Результаты = Запрос.ВыполнитьПакет();
		ВыборкаСтрокиДляДобавления = Результаты[0].Выбрать();
		ДобавитьВДеревоСтрокиТЧ(ВыборкаСтрокиДляДобавления, СоответствиеЭлементовДерева, СтрокиТЧ);
		
		ВыборкаВТСтрокиДляДобавления = Результаты[3].Выбрать();
	КонецЦикла;
	
КонецПроцедуры // } Гкс-[TOIR-1/00000090] Однодворцев И. от 18.06.2019.

&НаСервереБезКонтекста
Функция ТекстЗапросаВыборДублейСтрок()
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВТ_ДублиСтрок.Класс КАК Объект,
		|	ЕСТЬNULL(СпрКлассы.КлассТабличнаяЧасть, СпрНоменклатураКласса.Класс.КлассТабличнаяЧасть) КАК СтрокаВложеннойТЧ,
		|	ВЫБОР
		|		КОГДА НЕ СпрКлассы.Ссылка ЕСТЬ NULL
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ОбъектЭтоКласс,
		|	ВТ_ДублиСтрок.АтрибутКласса КАК АтрибутКласса,
		|	ВТ_ДублиСтрок.ЗначениеАтрибутаКласса КАК ЗначениеАтрибутаКласса,
		|	ВТ_ДублиСтрок.Порядок КАК Порядок,
		|	ИСТИНА КАК ЕстьСтрокиДляВосстановления,
		|	2 КАК ВидОшибки,
		|	""Дублирующаяся строка"" КАК ПредставлениеОшибки
		|ПОМЕСТИТЬ ВТ_СтрокиСХвостами
		|ИЗ
		|	ВТ_ДублиСтрок КАК ВТ_ДублиСтрок
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НоменклатураКласса КАК СпрНоменклатураКласса
		|		ПО ВТ_ДублиСтрок.Класс = СпрНоменклатураКласса.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Классы КАК СпрКлассы
		|		ПО ВТ_ДублиСтрок.Класс = СпрКлассы.Ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ДанныеДляПоискаВИерархии.КлассПоИерархии,
