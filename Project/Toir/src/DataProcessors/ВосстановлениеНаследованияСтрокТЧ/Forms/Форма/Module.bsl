#Область ВосстановлениеНаследованияСтрокТЧ

&НаСервере
Процедура ВосстановитьНаследованиеСтрокТЧНаСервере()
	
	ДеревоПоиска = РеквизитФормыВЗначение("ОбъектыДляВосстановления");
	
	СтруктураПоиска = Новый Структура("Выбрано, ЕстьСтрокиДляВосстановления, ВидОшибки", Истина, Истина, 1);
	НайденоСтрокиДляВосстановления = ДеревоПоиска.Строки.НайтиСтроки(СтруктураПоиска, Истина);
	
	ТипНоменклатура = Тип("СправочникСсылка.НоменклатураКласса");
	ТипКласс = Тип("СправочникСсылка.Классы");
	
	МассивОбъектовДляПоискаВложенных = Новый Массив;
	Отказ = Ложь;
	
	Для Каждого СтрокаНайдено Из НайденоСтрокиДляВосстановления Цикл
		
		ТипОбъекта = ТипЗнч(СтрокаНайдено.Объект);
		Если НЕ ТипОбъекта = ТипНоменклатура И НЕ ТипОбъекта = ТипКласс Тогда
			Продолжить;
		КонецЕсли;
		
		СпрОбъект = СтрокаНайдено.Объект.ПолучитьОбъект();
		Если ТипОбъекта = ТипНоменклатура Тогда
			СпрОбъект.Класс = СтрокаНайдено.РодительУстановить;
		ИначеЕсли ТипОбъекта = ТипКласс Тогда
			СпрОбъект.Родитель = СтрокаНайдено.РодительУстановить;
		КонецЕсли;
		
		Попытка
			СпрОбъект.Записать();
			МассивОбъектовДляПоискаВложенных.Добавить(СтрокаНайдено.Объект);
		Исключение
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
					НСтр("ru='Ошибка при записи элемента %1: 
					|%2.'"), СтрокаНайдено.Объект, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
			Прервать;
		КонецПопытки;
		
		СтрокаНайдено.Выбрано = Ложь;
		СтрокаНайдено.ЕстьСтрокиДляВосстановления = Ложь;
		СтрокаНайдено.РодительТекущий = СтрокаНайдено.РодительУстановить;
		СтрокаНайдено.РодительУстановить = Справочники.Классы.ПустаяСсылка();
		
	КонецЦикла;
	
	Если НЕ Отказ Тогда
		Справочники.Классы.ВосстановитьНаследованиеТабЧастей(МассивОбъектовДляПоискаВложенных);
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(ДеревоПоиска, "ОбъектыДляВосстановления");
	
КонецПроцедуры

&НаСервере
Процедура УдалитьДублиСтрокНаСервере()
	
	
	ДеревоПоиска = РеквизитФормыВЗначение("ОбъектыДляВосстановления");
	
	СтруктураПоиска = Новый Структура("Выбрано, ЕстьСтрокиДляВосстановления, ВидОшибки", Истина, Истина, 2);
	НайденоСтрокиДляУдаления = ДеревоПоиска.Строки.НайтиСтроки(СтруктураПоиска, Истина);
	
	ТипНоменклатура = Тип("СправочникСсылка.НоменклатураКласса");
	ТипКласс = Тип("СправочникСсылка.Классы");
	
	СтрокиПропустить = Новый Массив;
	СтрокиУдалить = Новый Массив;
	
	Для Каждого СтрокаНайдено Из НайденоСтрокиДляУдаления Цикл
		Если НЕ СтрокиПропустить.Найти(СтрокаНайдено) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТипОбъекта = ТипЗнч(СтрокаНайдено.Объект);
		Если НЕ ТипОбъекта = ТипНоменклатура И НЕ ТипОбъекта = ТипКласс Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТабЧасти = СтрокаНайдено.Родитель;
		СтрокаОбъекта = СтрокаТабЧасти.Родитель;
		
		Запись = РегистрыСведений.МножественныеЗначенияАтрибутов.СоздатьМенеджерЗаписи();
		Запись.Класс                  = СтрокаОбъекта.Объект;
		Запись.АтрибутКласса          = СтрокаТабЧасти.Объект;
		Запись.ЗначениеАтрибутаКласса = СтрокаНайдено.Объект;
		
		Попытка
			Запись.Удалить();
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				УправлениеНСИФункцииКлиентСерверПереопределяемый.ПодставитьПараметрыВСтроку(
					НСтр("ru='Ошибка при удалении элемента %1: 
					|%2.'"), СтрокаНайдено.Объект, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
			Прервать;
		КонецПопытки;
		
		ВложенныеСтроки = СтрокаНайдено.Строки.НайтиСтроки(СтруктураПоиска);
		Для Каждого ВложеннаяСтрока ИЗ ВложенныеСтроки Цикл
			СтрокиПропустить.Добавить(ВложеннаяСтрока);
		КонецЦикла;
		
		СтрокиУдалить.Добавить(СтрокаНайдено);
		
	КонецЦикла;
	
	Для Каждого СтрокаУдалить ИЗ СтрокиУдалить Цикл
		СтрокаРодитель = СтрокаУдалить.Родитель;
		СтрокаРодитель.Строки.Удалить(СтрокаУдалить);
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ДеревоПоиска, "ОбъектыДляВосстановления");
	
КонецПроцедуры // } Гкс-[TOIR-1/00000090] Однодворцев И. от 18.06.2019.

&НаСервере
Процедура ВывестиПодчиненныеОбъектыНаСервере()
	
	ИДСтроки = Элементы.ОбъектыДляВосстановления.ТекущаяСтрока;
	Если ИДСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекСтрока = ОбъектыДляВосстановления.НайтиПоИдентификатору(ИДСтроки);
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипНоменклатура = Тип("СправочникСсылка.НоменклатураКласса");
	ТипКласс = Тип("СправочникСсылка.Классы");
	
	ТипОбъекта = ТипЗнч(ТекСтрока.Объект);
	Если НЕ ТипОбъекта = ТипНоменклатура И НЕ ТипОбъекта = ТипКласс Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеОбъектовИСтрок = Новый Соответствие;
	
	КоллекцияЭлементов = ТекСтрока.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ Из КоллекцияЭлементов Цикл
		СоответствиеОбъектовИСтрок.Вставить(СтрокаТЧ.Объект, СтрокаТЧ);
		КоллекцияВложенных = СтрокаТЧ.ПолучитьЭлементы();
		Для Каждого СтрокаВложенная ИЗ КоллекцияВложенных Цикл 
			СоответствиеОбъектовИСтрок.Вставить(СтрокаВложенная.Объект, СтрокаВложенная);
		КонецЦикла;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаПодчиненныеОбъекты();
	
	Запрос.УстановитьПараметр("Класс", ТекСтрока.Объект);
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		СтрокаДерева = СоответствиеОбъектовИСтрок[Результат.ЗначениеАтрибутаКласса];
		Если НЕ СтрокаДерева = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТЧ = СоответствиеОбъектовИСтрок[Результат.АтрибутКласса];
		Если СтрокаТЧ = Неопределено Тогда
			СтрокаТЧ = КоллекцияЭлементов.Добавить();
			СтрокаТЧ.Объект = Результат.АтрибутКласса;
			СоответствиеОбъектовИСтрок.Вставить(Результат.АтрибутКласса, СтрокаТЧ);
		КонецЕсли;
		
		КоллекцияВложенных = СтрокаТЧ.ПолучитьЭлементы();
		
		СтрокаДерева = КоллекцияВложенных.Добавить();
		СтрокаДерева.Объект          = Результат.ЗначениеАтрибутаКласса;
		СтрокаДерева.Код             = Результат.Код;
		СтрокаДерева.РодительТекущий = Результат.Родитель;
		СтрокаДерева.ИндексКартинки  = 2;
		
		СтрокаДерева.ЕстьСтрокиДляВосстановления = Ложь;
		СтрокаДерева.ВидОшибки                   = 0;
		
	КонецЦикла;
	
КонецПроцедуры // } Гкс-[TOIR-1/00000090] Однодворцев И. от 18.06.2019.

&НаСервереБезКонтекста
Функция ТекстЗапросаПодчиненныеОбъекты()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	МножественныеЗначенияАтрибутов.АтрибутКласса КАК АтрибутКласса,
		|	МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса,
		|	МножественныеЗначенияАтрибутов.Порядок КАК Порядок,
		|	ЕСТЬNULL(СпрКлассы.Код, СпрНоменклатураКласса.Код) КАК Код,
		|	ЕСТЬNULL(СпрКлассы.Родитель, СпрНоменклатураКласса.Класс) КАК Родитель
		|ИЗ
		|	РегистрСведений.МножественныеЗначенияАтрибутов КАК МножественныеЗначенияАтрибутов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Классы КАК СпрКлассы
		|		ПО МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса = СпрКлассы.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НоменклатураКласса КАК СпрНоменклатураКласса
		|		ПО МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса = СпрНоменклатураКласса.Ссылка
		|ГДЕ
		|	МножественныеЗначенияАтрибутов.Класс = &Класс
		|	И МножественныеЗначенияАтрибутов.ТабличныйАтрибут
		|
		|УПОРЯДОЧИТЬ ПО
		|	АтрибутКласса,
		|	Порядок
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	Возврат ТекстЗапроса;
	
КонецФункции // } Гкс-[TOIR-1/00000090] Однодворцев И. от 18.06.2019.

