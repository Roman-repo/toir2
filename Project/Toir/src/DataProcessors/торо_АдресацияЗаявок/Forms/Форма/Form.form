  </attributes>
  <attributes>
    <name>Ремонты</name>
    <title>
      <key>ru</key>
      <value>Ремонты</value>
    </title>
    <title>
      <key>es</key>
      <value>Las reparaciones</value>
    </title>
    <title>
      <key>en</key>
      <value>Repairs</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ID_Ремонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ВведенаЗаявка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ВидРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Документ</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Заявка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Исполнитель</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ОбъектРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.СтатусРемонта</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.ТипДокумента</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.УточнениеИсполнителя</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Ремонты.Хозспособ</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	торо_ПланГрафикППР.ID КАК ID_Ремонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ,
	&quot;торо_ПланГрафикРемонта&quot; КАК ТипДокумента,
	торо_ПланГрафикППР.ОбъектРемонтныхРабот КАК ОбъектРемонта,
	торо_ПланГрафикППР.ВидРемонтныхРабот КАК ВидРемонта,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала КАК ДатаНачала,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания КАК ДатаОкончания,
	ВЫБОР
		КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
				И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
			ТОГДА торо_ЗаявкаНаРемонт.Исполнитель
		ИНАЧЕ торо_ПланГрафикППР.Исполнитель
	КОНЕЦ КАК Исполнитель,
	ЕСТЬNULL(торо_ЗаявкаНаРемонт.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО) КАК УточнениеИсполнителя,
	ВЫБОР
		КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ВведенаЗаявка,
	торо_ЗаявкаНаРемонт.Регистратор КАК Заявка,
	&quot;&quot; КАК Описание,
	ЕСТЬNULL(торо_СтатусыРемонтовВЗаявкахСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.Зарегистрирован)) КАК СтатусРемонта,
	ВЫБОР
		КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
				И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
			ТОГДА торо_ЗаявкаНаРемонт.Исполнитель
		ИНАЧЕ торо_ПланГрафикППР.Исполнитель
	КОНЕЦ ССЫЛКА Справочник.СтруктураПредприятия КАК Хозспособ,
	ВЫРАЗИТЬ(торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ.торо_ПланГрафикРемонта).Организация КАК РегистраторОрганизация,
	торо_ЗаявкаНаРемонт.Регистратор.Организация КАК РегистраторОрганизация1
ИЗ
	РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних КАК торо_ПланГрафикППР
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК торо_ЗаявкаНаРемонт
		ПО торо_ПланГрафикППР.ID = торо_ЗаявкаНаРемонт.IDРемонта
			И (НЕ торо_ЗаявкаНаРемонт.Регистратор В
					(ВЫБРАТЬ
						торо_ОтмененныеЗаявки.Заявка
					ИЗ
						РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки))
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		ПО торо_ПланГрафикППР.ОбъектРемонтныхРабот = торо_ОбъектыРемонта.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыРемонтовВЗаявках.СрезПоследних КАК торо_СтатусыРемонтовВЗаявкахСрезПоследних
		ПО торо_ПланГрафикППР.ID = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ИДРемонта
			И (торо_ЗаявкаНаРемонт.Регистратор = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ЗаявкаНаРемонт)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		ПО торо_ПланГрафикППР.ID = торо_АктуальныеПлановыеДатыРемонтов.IDРемонта
ГДЕ
	ВЫБОР
			КОГДА &amp;ФОИспользоватьППР
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И НЕ торо_ПланГрафикППР.Отменен
	И НЕ торо_ПланГрафикППР.Замещен
	И НЕ ВЫРАЗИТЬ(торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ.торо_ПланГрафикРемонта).Организация ЕСТЬ NULL
	И ВЫБОР
			КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
				ТОГДА ИСТИНА
			ИНАЧЕ НЕ торо_ЗаявкаНаРемонт.Регистратор.Организация ЕСТЬ NULL
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
					И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
					И ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.Исполнитель) = ТИП(Справочник.СтруктураПредприятия)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель.Источник ЕСТЬ NULL
			КОГДА (торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
					ИЛИ торо_ЗаявкаНаРемонт.Исполнитель = НЕОПРЕДЕЛЕНО)
					И ТИПЗНАЧЕНИЯ(торо_ПланГрафикППР.Исполнитель) = ТИП(Справочник.СтруктураПредприятия)
				ТОГДА НЕ торо_ПланГрафикППР.Исполнитель.Источник ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.УточнениеИсполнителя) = ТИП(Справочник.ДоговорыКонтрагентов)
					И торо_ЗаявкаНаРемонт.УточнениеИсполнителя &lt;> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.УточнениеИсполнителя.Организация ЕСТЬ NULL
			КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.УточнениеИсполнителя) = ТИП(Справочник.торо_РемонтныеБригады)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.УточнениеИсполнителя.Подразделение ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	торо_ВыявленныеДефекты.ID,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки,
	&quot;торо_ВыявленныеДефекты&quot;,
	торо_ВыявленныеДефекты.ОтказавшийЭлемент,
	&amp;торо_ВидРемонтаВД,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания,
	ВЫБОР
		КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
				И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
			ТОГДА торо_ЗаявкаНаРемонт.Исполнитель
		ИНАЧЕ торо_ВыявленныеДефекты.ПодразделениеИсполнитель
	КОНЕЦ,
	ЕСТЬNULL(торо_ЗаявкаНаРемонт.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО),
	ВЫБОР
		КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ,
	торо_ЗаявкаНаРемонт.Регистратор,
	торо_ВыявленныеДефекты.ДефектОписание,
	ЕСТЬNULL(торо_СтатусыРемонтовВЗаявкахСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.Зарегистрирован)),
	ВЫБОР
		КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
				И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
			ТОГДА торо_ЗаявкаНаРемонт.Исполнитель
		ИНАЧЕ торо_ВыявленныеДефекты.ПодразделениеИсполнитель
	КОНЕЦ ССЫЛКА Справочник.СтруктураПредприятия,
	ВЫРАЗИТЬ(торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ.торо_ВыявленныеДефекты).Организация,
	торо_ЗаявкаНаРемонт.Регистратор.Организация
ИЗ
	РегистрСведений.торо_ВыявленныеДефекты КАК торо_ВыявленныеДефекты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеРемонты.СрезПоследних КАК торо_ОтмененныеРемонтыСрезПоследних
		ПО торо_ВыявленныеДефекты.ID = торо_ОтмененныеРемонтыСрезПоследних.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК торо_ЗаявкаНаРемонт
		ПО торо_ВыявленныеДефекты.ID = торо_ЗаявкаНаРемонт.IDРемонта
			И (НЕ торо_ЗаявкаНаРемонт.Регистратор В
					(ВЫБРАТЬ
						торо_ОтмененныеЗаявки.Заявка
					ИЗ
						РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки))
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		ПО торо_ВыявленныеДефекты.ОтказавшийЭлемент = торо_ОбъектыРемонта.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыРемонтовВЗаявках.СрезПоследних КАК торо_СтатусыРемонтовВЗаявкахСрезПоследних
		ПО торо_ВыявленныеДефекты.ID = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ИДРемонта
			И (торо_ЗаявкаНаРемонт.Регистратор = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ЗаявкаНаРемонт)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		ПО торо_ВыявленныеДефекты.ID = торо_АктуальныеПлановыеДатыРемонтов.IDРемонта
ГДЕ
	ВЫБОР
			КОГДА &amp;ФОИспользоватьДефекты
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И торо_ОтмененныеРемонтыСрезПоследних.Регистратор ЕСТЬ NULL
	И НЕ ВЫРАЗИТЬ(торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ.торо_ВыявленныеДефекты).Организация ЕСТЬ NULL
	И ВЫБОР
			КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
				ТОГДА ИСТИНА
			ИНАЧЕ НЕ торо_ЗаявкаНаРемонт.Регистратор.Организация ЕСТЬ NULL
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
					И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
					И ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.Исполнитель) = ТИП(Справочник.СтруктураПредприятия)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель.Источник ЕСТЬ NULL
			КОГДА (торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
					ИЛИ торо_ЗаявкаНаРемонт.Исполнитель = НЕОПРЕДЕЛЕНО)
					И торо_ВыявленныеДефекты.ПодразделениеИсполнитель &lt;> ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
				ТОГДА НЕ торо_ВыявленныеДефекты.ПодразделениеИсполнитель.Источник ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.УточнениеИсполнителя) = ТИП(Справочник.ДоговорыКонтрагентов)
					И торо_ЗаявкаНаРемонт.УточнениеИсполнителя &lt;> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.УточнениеИсполнителя.Организация ЕСТЬ NULL
			КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.УточнениеИсполнителя) = ТИП(Справочник.торо_РемонтныеБригады)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.УточнениеИсполнителя.Подразделение ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	торо_ПредписанияСрезПоследних.ID,
	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки,
	&quot;торо_ВнешнееОснованиеДляРабот&quot;,
	торо_ПредписанияСрезПоследних.ОбъектРемонта,
	&amp;торо_ВидРемонтаВО,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала,
	торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания,
	ВЫБОР
		КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
				И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
			ТОГДА торо_ЗаявкаНаРемонт.Исполнитель
		ИНАЧЕ торо_Предписание.Исполнитель
	КОНЕЦ,
	ЕСТЬNULL(торо_ЗаявкаНаРемонт.УточнениеИсполнителя, НЕОПРЕДЕЛЕНО),
	ВЫБОР
		КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ,
	торо_ЗаявкаНаРемонт.Регистратор,
	ВЫРАЗИТЬ(торо_ПредписанияСрезПоследних.Описание КАК СТРОКА(500)),
	ЕСТЬNULL(торо_СтатусыРемонтовВЗаявкахСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.Зарегистрирован)),
	ВЫБОР
		КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
				И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
			ТОГДА торо_ЗаявкаНаРемонт.Исполнитель
		ИНАЧЕ торо_Предписание.Исполнитель
	КОНЕЦ ССЫЛКА Справочник.СтруктураПредприятия,
	ВЫРАЗИТЬ(торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ.торо_ВнешнееОснованиеДляРабот).Организация,
	торо_ЗаявкаНаРемонт.Регистратор.Организация
ИЗ
	РегистрСведений.торо_ВнешниеОснованияДляРабот.СрезПоследних(, ) КАК торо_ПредписанияСрезПоследних
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВнешнееОснованиеДляРабот.ОбследованноеОборудование КАК торо_Предписание
		ПО торо_ПредписанияСрезПоследних.ID = торо_Предписание.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеРемонты.СрезПоследних КАК торо_ОтмененныеРемонтыСрезПоследних
		ПО торо_ПредписанияСрезПоследних.ID = торо_ОтмененныеРемонтыСрезПоследних.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК торо_ЗаявкаНаРемонт
		ПО торо_ПредписанияСрезПоследних.ID = торо_ЗаявкаНаРемонт.IDРемонта
			И (НЕ торо_ЗаявкаНаРемонт.Регистратор В
					(ВЫБРАТЬ
						торо_ОтмененныеЗаявки.Заявка
					ИЗ
						РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки))
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		ПО торо_ПредписанияСрезПоследних.ОбъектРемонта = торо_ОбъектыРемонта.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыРемонтовВЗаявках.СрезПоследних КАК торо_СтатусыРемонтовВЗаявкахСрезПоследних
		ПО торо_ПредписанияСрезПоследних.ID = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ИДРемонта
			И (торо_ЗаявкаНаРемонт.Регистратор = торо_СтатусыРемонтовВЗаявкахСрезПоследних.ЗаявкаНаРемонт)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		ПО торо_ПредписанияСрезПоследних.ID = торо_АктуальныеПлановыеДатыРемонтов.IDРемонта
ГДЕ
	ВЫБОР
			КОГДА &amp;ФОИспользоватьВнешниеОснования
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	И торо_ОтмененныеРемонтыСрезПоследних.Регистратор ЕСТЬ NULL
	И НЕ ВЫРАЗИТЬ(торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК Документ.торо_ВнешнееОснованиеДляРабот).Организация ЕСТЬ NULL
	И ВЫБОР
			КОГДА торо_ЗаявкаНаРемонт.Регистратор ЕСТЬ NULL
				ТОГДА ИСТИНА
			ИНАЧЕ НЕ торо_ЗаявкаНаРемонт.Регистратор.Организация ЕСТЬ NULL
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
					И торо_ЗаявкаНаРемонт.Исполнитель &lt;> НЕОПРЕДЕЛЕНО
					И ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.Исполнитель) = ТИП(Справочник.СтруктураПредприятия)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.Исполнитель.Источник ЕСТЬ NULL
			КОГДА (торо_ЗаявкаНаРемонт.Исполнитель ЕСТЬ NULL
					ИЛИ торо_ЗаявкаНаРемонт.Исполнитель = НЕОПРЕДЕЛЕНО)
					И торо_Предписание.Исполнитель &lt;> ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
				ТОГДА НЕ торо_Предписание.Исполнитель.Источник ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.УточнениеИсполнителя) = ТИП(Справочник.ДоговорыКонтрагентов)
					И торо_ЗаявкаНаРемонт.УточнениеИсполнителя &lt;> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.УточнениеИсполнителя.Организация ЕСТЬ NULL
			КОГДА ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонт.УточнениеИсполнителя) = ТИП(Справочник.торо_РемонтныеБригады)
				ТОГДА НЕ торо_ЗаявкаНаРемонт.УточнениеИсполнителя.Подразделение ЕСТЬ NULL
			ИНАЧЕ ИСТИНА
		КОНЕЦ</queryText>
