    </toolTip>
    <toolTip>
      <key>es</key>
      <value>La información adicional sobre la persona de contacto. Es accesible para el cambio por el socio al autoservicio.</value>
    </toolTip>
    <toolTip>
      <key>en</key>
      <value>Additional contact information. Available for change by self-service partner.</value>
    </toolTip>
