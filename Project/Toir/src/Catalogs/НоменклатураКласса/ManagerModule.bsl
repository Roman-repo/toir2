
#Область ПрограммныйИнтерфейс

Функция ПолучитьРодителяПоКлассу(Класс) Экспорт
	
	ТаблицаРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(Класс);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаРодителей", ТаблицаРодителей);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаРодителей.Класс,
		|	ТаблицаРодителей.Уровень
		|ПОМЕСТИТЬ ВТ_ТаблицаРодителей
		|ИЗ
		|	&ТаблицаРодителей КАК ТаблицаРодителей
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТ_ТаблицаРодителей.Уровень) КАК Уровень
		|ПОМЕСТИТЬ ВТ_МаксУровень
		|ИЗ
		|	Справочник.Классы КАК Классы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ТаблицаРодителей КАК ВТ_ТаблицаРодителей
		|		ПО Классы.Ссылка = ВТ_ТаблицаРодителей.Класс
		|ГДЕ
		|	Классы.ОтображатьВИерархииТО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	НоменклатураКласса.Ссылка,
		|	НоменклатураКласса.ПометкаУдаления КАК ПометкаУдаления,
		|	НоменклатураКласса.Класс.ПометкаУдаления КАК ПометкаУдаленияВладельца
		|ИЗ
		|	Справочник.НоменклатураКласса КАК НоменклатураКласса
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ТаблицаРодителей КАК ВТ_ТаблицаРодителей
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксУровень КАК ВТ_МаксУровень
		|			ПО ВТ_ТаблицаРодителей.Уровень = ВТ_МаксУровень.Уровень
		|		ПО НоменклатураКласса.Класс = ВТ_ТаблицаРодителей.Класс
		|ГДЕ
		|	НоменклатураКласса.ЭтоГруппа
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПометкаУдаления УБЫВ";
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Родитель = Результат.Ссылка;
	Иначе
		Родитель = Справочники.НоменклатураКласса.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Родитель;
	
КонецФункции

Функция ПрочитатьДанныеДляЧтенияНоменклатуры(МассивНоменклатуры) Экспорт
	
	// Получаем классы номенклатуры.
	СоответствиеКлассов = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначениеРеквизитаОбъектов(
		МассивНоменклатуры, "Класс");
	
	// Соответствие номенклатуры - позволяет по классу определить номенклатуру класса.
	СоответствиеНоменклатуры = Новый Соответствие; 
	МассивКлассов = Новый Массив; // Массив классов нужен для чтения шаблонов табличных атрибутов.
	Для Каждого КлючИЗначение ИЗ СоответствиеКлассов Цикл
		МассивНоменклатурыПоКлассам = СоответствиеНоменклатуры[КлючИЗначение.Значение];
		Если МассивНоменклатурыПоКлассам = Неопределено Тогда
			МассивНоменклатурыПоКлассам = Новый Массив;
			СоответствиеНоменклатуры.Вставить(КлючИЗначение.Значение, МассивНоменклатурыПоКлассам);
			МассивКлассов.Добавить(КлючИЗначение.Значение);
		КонецЕсли;
		МассивНоменклатурыПоКлассам.Добавить(КлючИЗначение.Ключ);
	КонецЦикла;
	
	Возврат Новый Структура("СоответствиеКлассов, СоответствиеНоменклатуры, МассивКлассов", 
		СоответствиеКлассов, СоответствиеНоменклатуры, МассивКлассов);
	
КонецФункции

Функция ПолучитьТаблицуАтрибутов(Знач Номенклатура, ДанныеДляЧтения = Неопределено, МенеджерВТ=Неопределено, ЧитатьВложенныеАтрибуты=Истина) Экспорт
	
	Если НЕ ТипЗнч(Номенклатура) = Тип("Массив") Тогда
		НовыйМассив = Новый Массив;
		НовыйМассив.Добавить(Номенклатура);
		Номенклатура = НовыйМассив;
	КонецЕсли;
	
	Если ДанныеДляЧтения = Неопределено Тогда
		ДанныеДляЧтения = ПрочитатьДанныеДляЧтенияНоменклатуры(Номенклатура);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	
	Если МенеджерВТ = Неопределено Тогда
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	КонецЕсли;
	
	СписокРодителей  = Справочники.Классы.ПолучитьТаблицуРодителей(ДанныеДляЧтения.МассивКлассов);
	Справочники.Классы.ПолучитьТаблицуАтрибутов(СписокРодителей, Запрос.МенеджерВременныхТаблиц); // ВТ_ТаблицаАтрибутов
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.Текст = ТекстЗапросаЗначенияАтрибутовНоменклатуры(); // ВТ_НоменклатураКласса, ВТ_АтрибутыНоменклатуры, ВТ_ВложенныеАтрибутыКласса
	Запрос.Выполнить();
	
	Если ЧитатьВложенныеАтрибуты Тогда
		Запрос.Текст = ТекстЗапросаВложенныеАтрибуты();
		Результаты = Запрос.ВыполнитьПакет();
		
		МассивКлассовЧтенияВложенныхАтрибутов      = Результаты[0].Выгрузить().ВыгрузитьКолонку("ЗначениеАтрибутаКласса");
		МассивНоменклатурыЧтенияВложенныхАтрибутов = Результаты[1].Выгрузить().ВыгрузитьКолонку("ЗначениеАтрибутаКласса");
		
		ВыборкаВложенныхРеквизитовПоТипам          = Результаты[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ТаблицаВложенныхРеквизитов = Новый ТаблицаЗначений;
		ТаблицаВложенныхРеквизитов.Колонки.Добавить("Номенклатура", 
			Новый ОписаниеТипов("СправочникСсылка.НоменклатураКласса"));
		ТаблицаВложенныхРеквизитов.Колонки.Добавить("КлассДляЧтения", 
			Новый ОписаниеТипов("СправочникСсылка.Классы, СправочникСсылка.НоменклатураКласса"));
		ТаблицаВложенныхРеквизитов.Колонки.Добавить("ВложенныйАтрибутКлассаСсылка",
			Новый ОписаниеТипов("СправочникСсылка.ВложенныеАтрибутыКласса"));
		ТаблицаВложенныхРеквизитов.Колонки.Добавить("ТипЗначения", Новый ОписаниеТипов("Строка"));
		ТаблицаВложенныхРеквизитов.Колонки.Добавить("ИсточникВложенногоАтрибутаКласса", 
			Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.АтрибутыКласса"));
		ТаблицаВложенныхРеквизитов.Колонки.Добавить("ЗначениеАтрибутаВложенногоКлассаНТ");
		
		МассивТипов = Новый Массив;
		КвалификаторСтрока = Неопределено;
		
		Пока ВыборкаВложенныхРеквизитовПоТипам.Следующий() Цикл
			ВыборкаВложеныхРеквизитовПоОбъектам = ВыборкаВложенныхРеквизитовПоТипам.Выбрать();
			СоответствиеРеквизитовДляЧтения = Новый Соответствие;
			
			ОбходСоЗначениемИсточником = (ТипЗнч(ВыборкаВложенныхРеквизитовПоТипам.ТипЗначенияИсточника) = Тип("Тип"));
			Если ОбходСоЗначениемИсточником Тогда
				МетаданныеСпр = Метаданные.НайтиПоТипу(ВыборкаВложенныхРеквизитовПоТипам.ТипЗначенияИсточника);
				МассивОбъектовДляЧтения = Новый Массив;
				СписокРеквизитов = "";
				
				Пока ВыборкаВложеныхРеквизитовПоОбъектам.Следующий() Цикл
					Если МассивОбъектовДляЧтения.Найти(
							ВыборкаВложеныхРеквизитовПоОбъектам.ЗначениеИсточникаАтрибутаКласса) = Неопределено Тогда
						МассивОбъектовДляЧтения.Добавить(ВыборкаВложеныхРеквизитовПоОбъектам.ЗначениеИсточникаАтрибутаКласса);
					КонецЕсли;
					Если СоответствиеРеквизитовДляЧтения[
							ВыборкаВложеныхРеквизитовПоОбъектам.АтрибутВложенногоКласса] = Неопределено Тогда
						МетаданныеРеквизита = Перечисления.РеквизитыКлассаНоменклатуры.ПолучитьМетаданныеРеквизита(МетаданныеСпр, 
							ВыборкаВложеныхРеквизитовПоОбъектам.АтрибутВложенногоКласса);
						СоответствиеРеквизитовДляЧтения.Вставить(
							ВыборкаВложеныхРеквизитовПоОбъектам.АтрибутВложенногоКласса, МетаданныеРеквизита);
						СписокРеквизитов = СписокРеквизитов + ?(ПустаяСтрока(СписокРеквизитов), "", ",") + МетаданныеРеквизита.Имя;
					КонецЕсли;
				КонецЦикла;
				
				ЗначенияРеквизитов = УправлениеНСИФункцииВызовСервераПереопределяемый.ЗначенияРеквизитовОбъектов(
					МассивОбъектовДляЧтения, СписокРеквизитов);
				ВыборкаВложеныхРеквизитовПоОбъектам.Сбросить();
				Пока ВыборкаВложеныхРеквизитовПоОбъектам.Следующий() Цикл
					СтрокаВложенныхРеквизитов = ТаблицаВложенныхРеквизитов.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаВложенныхРеквизитов, ВыборкаВложеныхРеквизитовПоОбъектам);
					
					МетаданныеРеквизита = СоответствиеРеквизитовДляЧтения[ВыборкаВложеныхРеквизитовПоОбъектам.АтрибутВложенногоКласса];
					СтруктураЗначений = ЗначенияРеквизитов[ВыборкаВложеныхРеквизитовПоОбъектам.ЗначениеИсточникаАтрибутаКласса];
					
					СтрокаВложенныхРеквизитов.ЗначениеАтрибутаВложенногоКлассаНТ = СтруктураЗначений[МетаданныеРеквизита.Имя];
					СтрокаВложенныхРеквизитов.ТипЗначения = ЗначениеВСтрокуВнутр(МетаданныеРеквизита.Тип);
					
					ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивТипов, МетаданныеРеквизита.Тип.Типы(), Истина);
					Если КвалификаторСтрока = Неопределено 
							ИЛИ КвалификаторСтрока.Длина < МетаданныеРеквизита.Тип.КвалификаторыСтроки.Длина Тогда
						КвалификаторСтрока = МетаданныеРеквизита.Тип.КвалификаторыСтроки;
					КонецЕсли;
				КонецЦикла;
			Иначе
				Пока ВыборкаВложеныхРеквизитовПоОбъектам.Следующий() Цикл
					МетаданныеРеквизита = СоответствиеРеквизитовДляЧтения[
							ВыборкаВложеныхРеквизитовПоОбъектам.ВложенныйАтрибутКлассаСсылка];
					Если МетаданныеРеквизита = Неопределено Тогда
						МетаданныеСпр = Метаданные.НайтиПоТипу(ВыборкаВложеныхРеквизитовПоОбъектам.ТипИсточника.Типы()[0]);
						МетаданныеРеквизита = Перечисления.РеквизитыКлассаНоменклатуры.ПолучитьМетаданныеРеквизита(МетаданныеСпр,
							ВыборкаВложеныхРеквизитовПоОбъектам.АтрибутВложенногоКласса);
						СоответствиеРеквизитовДляЧтения.Вставить(
							ВыборкаВложеныхРеквизитовПоОбъектам.ВложенныйАтрибутКлассаСсылка, МетаданныеРеквизита);
					КонецЕсли;
					
					Если МетаданныеРеквизита = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					СтрокаВложенныхРеквизитов = ТаблицаВложенныхРеквизитов.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаВложенныхРеквизитов, ВыборкаВложеныхРеквизитовПоОбъектам);
					СтрокаВложенныхРеквизитов.ЗначениеАтрибутаВложенногоКлассаНТ = 
						ВыборкаВложеныхРеквизитовПоОбъектам.ЗначениеАтрибутаКласса;
					СтрокаВложенныхРеквизитов.ТипЗначения = ЗначениеВСтрокуВнутр(МетаданныеРеквизита.Тип);
					
					ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивТипов, МетаданныеРеквизита.Тип.Типы(), Истина);
					Если КвалификаторСтрока = Неопределено 
							ИЛИ КвалификаторСтрока.Длина < МетаданныеРеквизита.Тип.КвалификаторыСтроки.Длина Тогда
						КвалификаторСтрока = МетаданныеРеквизита.Тип.КвалификаторыСтроки;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
		Если МассивТипов.Количество() = 0 Тогда
			МассивТипов.Добавить(Тип("Число"));
		КонецЕсли;
		МассивТипов.Добавить(Тип("Неопределено"));
		
		ТаблицаВложенныхРеквизитов.Колонки.Добавить("ЗначениеАтрибутаВложенногоКласса", Новый ОписаниеТипов(МассивТипов,, КвалификаторСтрока));
		ЗначенияВыгрузка = ТаблицаВложенныхРеквизитов.ВыгрузитьКолонку("ЗначениеАтрибутаВложенногоКлассаНТ");
		ТаблицаВложенныхРеквизитов.ЗагрузитьКолонку(ЗначенияВыгрузка, "ЗначениеАтрибутаВложенногоКласса");
		ТаблицаВложенныхРеквизитов.Колонки.Удалить("ЗначениеАтрибутаВложенногоКлассаНТ");
		
		Запрос.УстановитьПараметр("ТаблицаВложенныхРеквизитов", ТаблицаВложенныхРеквизитов);
		
		Если МассивКлассовЧтенияВложенныхАтрибутов.Количество() > 0 Тогда
			ТаблицаРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(МассивКлассовЧтенияВложенныхАтрибутов);
			ТаблицаВложенныхАтрибутов = ПолучитьТаблицуАтрибутов(ТаблицаРодителей, , Ложь);
		КонецЕсли;
		
		Если МассивНоменклатурыЧтенияВложенныхАтрибутов.Количество() > 0 Тогда
			
			ТаблицаВложенныхАтрибутовНоменклатуры = Справочники.НоменклатураКласса.ПолучитьТаблицуАтрибутов(
				МассивНоменклатурыЧтенияВложенныхАтрибутов,,, Ложь);
			Если ТаблицаВложенныхАтрибутов = Неопределено Тогда
				ТаблицаВложенныхАтрибутов = ТаблицаВложенныхАтрибутовНоменклатуры;
			Иначе
				ТипКолонки = Новый ОписаниеТипов(
					ТаблицаВложенныхАтрибутов.Колонки.Объект.ТипЗначения, "СправочникСсылка.НоменклатураКласса");
				ТаблицаВложенныхАтрибутов.Колонки.Объект.Имя = "ОбъектУдалить";
				ТаблицаВложенныхАтрибутов.Колонки.Добавить("Объект", ТипКолонки);
				ЗначенияКолонки = ТаблицаВложенныхАтрибутов.ВыгрузитьКолонку("ОбъектУдалить");
				ТаблицаВложенныхАтрибутов.ЗагрузитьКолонку(ЗначенияКолонки, "Объект");
				
				Для Каждого СтрокаЗначений ИЗ ТаблицаВложенныхАтрибутовНоменклатуры Цикл
					НоваяСтрока = ТаблицаВложенныхАтрибутов.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЗначений);
				КонецЦикла;
			КонецЕсли;
			
		КонецЕсли;
		
		Запрос.УстановитьПараметр("ТаблицаАтрибутовВложенных", ТаблицаВложенныхАтрибутов);
		
	КонецЕсли;
	
	Если ЧитатьВложенныеАтрибуты И НЕ ТаблицаВложенныхАтрибутов = Неопределено Тогда
		Запрос.Текст = ТекстЗапросаЗначенияВложенныхАтрибутов(); // ВТ_ЗначенияВложенныхАтрибутов
	Иначе
		Запрос.Текст = ТекстЗапросаПустаяТаблицаЗначенияВложенныхАтрибутов(); // ВТ_ЗначенияВложенныхАтрибутов
	КонецЕсли;
	
	Если ЧитатьВложенныеАтрибуты И НЕ ТаблицаВложенныхРеквизитов = Неопределено Тогда
		Запрос.Текст = Запрос.Текст + УправлениеНСИФункцииВызовСервераПереопределяемый.ТекстРазделителяЗапросовПакета()
			+ ТекстЗапросаЗначенияВложенныхРеквизитов(); // ВТ_ЗначенияВложенныхРеквизитов
	Иначе
		Запрос.Текст = Запрос.Текст + УправлениеНСИФункцииВызовСервераПереопределяемый.ТекстРазделителяЗапросовПакета()
			+ ТекстЗапросаПустаяТаблицаЗначенияВложенныхРеквизитов(); // ВТ_ЗначенияВложенныхРеквизитов
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + УправлениеНСИФункцииВызовСервераПереопределяемый.ТекстРазделителяЗапросовПакета()
		+ ТекстЗапросаАтрибутыНоменклатуры();
	
	Результат = Запрос.Выполнить();
	Если МенеджерВТ = Неопределено Тогда
		ТаблицаАтрибутов = Результат.Выгрузить();
		Запрос.МенеджерВременныхТаблиц.Закрыть();
	КонецЕсли;
	
	Возврат ТаблицаАтрибутов;
	
КонецФункции

Функция ПолучитьСтрокиТабличныхАтрибутов(Номенклатура, АтрибутыКласса, ДанныеДляЧтения=Неопределено) Экспорт
	
	Если НЕ ТипЗнч(Номенклатура) = Тип("Массив") Тогда
		МассивНоменклатуры = Новый Массив;
		МассивНоменклатуры.Добавить(Номенклатура);
	Иначе
		МассивНоменклатуры = Номенклатура;
	КонецЕсли;
	
	Если ДанныеДляЧтения = Неопределено Тогда
		ДанныеДляЧтения = ПрочитатьДанныеДляЧтенияНоменклатуры(МассивНоменклатуры);
	КонецЕсли;
	
	// Чтение строк шаблонов (классов) табличных атрибутов. 
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	СписокРодителей = Справочники.Классы.ПолучитьТаблицуРодителей(ДанныеДляЧтения.МассивКлассов);
	Справочники.Классы.ПолучитьТаблицуАтрибутов(СписокРодителей, МенеджерВТ);
	ТаблицаСтрокАтрибутовКласса = Справочники.Классы.ПолучитьСтрокиТабличныхАтрибутов(СписокРодителей, АтрибутыКласса);
	
	// Чтение строк номенклатуры табличных атрибутов.
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.УстановитьПараметр("ТаблицаСтрокАтрибутовКласса", ТаблицаСтрокАтрибутовКласса);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.Текст = ТекстЗапросаСтрокиТабличныхАтрибутов();
	ТаблицаАтрибутовНоменклатуры = Запрос.Выполнить().Выгрузить();
	
	Возврат ТаблицаАтрибутовНоменклатуры;
	
КонецФункции	

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

