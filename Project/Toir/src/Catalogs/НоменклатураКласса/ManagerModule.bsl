Функция ТекстЗапросаСтрокиТабличныхАтрибутов()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ТаблицаСтрокАтрибутовКласса.КлассДляЧтения,
		|	ТаблицаСтрокАтрибутовКласса.АтрибутКласса,
		|	ТаблицаСтрокАтрибутовКласса.ЗначениеАтрибутаКласса,
		|	ТаблицаСтрокАтрибутовКласса.Порядок,
		|	ТаблицаСтрокАтрибутовКласса.СтатусНаследования,
		|	ТаблицаСтрокАтрибутовКласса.Уровень,
		|	ТаблицаСтрокАтрибутовКласса.УровеньТекКласса + 1 КАК УровеньТекКласса,
		|	ТаблицаСтрокАтрибутовКласса.ИсточникЗначений
		|ПОМЕСТИТЬ ВТ_ТаблицаСтрокАтрибутовКласса
		|ИЗ
		|	&ТаблицаСтрокАтрибутовКласса КАК ТаблицаСтрокАтрибутовКласса
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МножественныеЗначенияАтрибутов.Класс КАК Объект,
		|	ВЫРАЗИТЬ(МножественныеЗначенияАтрибутов.Класс КАК Справочник.НоменклатураКласса).Класс КАК КлассОбъекта,
		|	МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса,
		|	ВЫРАЗИТЬ(МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса КАК Справочник.НоменклатураКласса).Класс КАК КлассЗначения,
		|	МножественныеЗначенияАтрибутов.Порядок,
		|	МножественныеЗначенияАтрибутов.АтрибутКласса
		|ПОМЕСТИТЬ ВТ_МножественныеЗначенияАтрибутов
		|ИЗ
		|	РегистрСведений.МножественныеЗначенияАтрибутов КАК МножественныеЗначенияАтрибутов
		|ГДЕ
		|	МножественныеЗначенияАтрибутов.Класс В(&Номенклатура)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(МножественныеЗначенияАтрибутов.Объект, ЕСТЬNULL(МножественныеЗначенияАтрибутовПоНаследуемымСтрокам.Объект, ВТ_ТаблицаСтрокАтрибутовКласса.КлассДляЧтения)) КАК Объект,
		|	ВТ_ТаблицаСтрокАтрибутовКласса.АтрибутКласса КАК АтрибутКласса,
		|	ЕСТЬNULL(МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса, ЕСТЬNULL(МножественныеЗначенияАтрибутовПоНаследуемымСтрокам.ЗначениеАтрибутаКласса, НЕОПРЕДЕЛЕНО)) КАК ЗначениеАтрибутаКласса,
		|	ВЫБОР 
		|		КОГДА НЕ ЕСТЬNULL(ВТ_ТаблицаАтрибутов.ДобавлениеСтрокТабЧастиВНоменклатуреКласса, ЛОЖЬ) 
		|			ТОГДА ВТ_ТаблицаСтрокАтрибутовКласса.Порядок
		|		КОГДА НЕ МножественныеЗначенияАтрибутов.Порядок ЕСТЬ NULL
		|			ТОГДА МножественныеЗначенияАтрибутов.Порядок
		|		КОГДА НЕ МножественныеЗначенияАтрибутовПоНаследуемымСтрокам.Порядок ЕСТЬ NULL
		|			ТОГДА МножественныеЗначенияАтрибутовПоНаследуемымСтрокам.Порядок
		|		ИНАЧЕ ВТ_ТаблицаСтрокАтрибутовКласса.Порядок 
		|	КОНЕЦ КАК Порядок,
		|	ВЫБОР
		|		КОГДА ВТ_ТаблицаСтрокАтрибутовКласса.ЗначениеАтрибутаКласса = ЗНАЧЕНИЕ(Справочник.Классы.ПустаяСсылка)
		|			ТОГДА ВТ_ТаблицаСтрокАтрибутовКласса.ИсточникЗначений
		|		ИНАЧЕ ВТ_ТаблицаСтрокАтрибутовКласса.ЗначениеАтрибутаКласса
		|	КОНЕЦ КАК ИсточникЗначений,
		|	3 КАК СтатусНаследования,
		|	ВЫБОР 
		|		КОГДА НЕ МножественныеЗначенияАтрибутов.ЗначениеАтрибутаКласса ЕСТЬ NULL ИЛИ НЕ МножественныеЗначенияАтрибутовПоНаследуемымСтрокам.ЗначениеАтрибутаКласса ЕСТЬ NULL 
		|			ТОГДА ВТ_ТаблицаСтрокАтрибутовКласса.УровеньТекКласса
		|		ИНАЧЕ ВТ_ТаблицаСтрокАтрибутовКласса.Уровень
		|	КОНЕЦ КАК Уровень,
		|	ВТ_ТаблицаСтрокАтрибутовКласса.УровеньТекКласса,
		|	ВЫБОР
		|		КОГДА НЕ МножественныеЗначенияАтрибутов.Объект ЕСТЬ NULL
		|			ТОГДА ИСТИНА
		|		КОГДА НЕ МножественныеЗначенияАтрибутовПоНаследуемымСтрокам.Объект ЕСТЬ NULL
		|			ТОГДА ИСТИНА
