  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ЕстьПроблемы</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.Ссылка,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.ПометкаУдаления,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.Код,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.Порядок,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.СсылкаНаОбъект,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.Событие,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.ДатаВремяОбработки,
	ВЫБОР
		КОГДА Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.ПометкаУдаления
			ТОГДА ЗНАЧЕНИЕ(Перечисление.гкс_СостоянияОчередиОтложенногоФормирования.Пропущено)
		КОГДА ЕСТЬNULL(КоличествоПроблемПоОбъектам.КоличествоПроблем, 0) > 0
			ТОГДА ЗНАЧЕНИЕ(Перечисление.гкс_СостоянияОчередиОтложенногоФормирования.ЕстьПроблемы)
		ИНАЧЕ ВЫБОР
				КОГДА Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.ДатаВремяОбработки = ДАТАВРЕМЯ(1, 1, 1)
					ТОГДА ЗНАЧЕНИЕ(Перечисление.гкс_СостоянияОчередиОтложенногоФормирования.ОжидаетФормирования)
				ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.гкс_СостоянияОчередиОтложенногоФормирования.Сформировано)
			КОНЕЦ
	КОНЕЦ КАК Состояние,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.ДатаПостановкиВОчередь,
	Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.ДатаПринятияВОбработку
ИЗ
	Справочник.гкс_ОчередьОтложенногоФормированияИсходящихСообщений КАК Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			гкс_ПроблемыОбменаДаннымиСрезПоследних.ПроблемныйОбъект КАК ПроблемныйОбъект,
			КОЛИЧЕСТВО(гкс_ПроблемыОбменаДаннымиСрезПоследних.ТипПроблемы) КАК КоличествоПроблем
		ИЗ
			РегистрСведений.гкс_ПроблемыОбменаДанными.СрезПоследних КАК гкс_ПроблемыОбменаДаннымиСрезПоследних
		
		СГРУППИРОВАТЬ ПО
			гкс_ПроблемыОбменаДаннымиСрезПоследних.ПроблемныйОбъект) КАК КоличествоПроблемПоОбъектам
		ПО Справочникгкс_ОчередьОтложенногоФормированияИсходящихСообщений.Ссылка = КоличествоПроблемПоОбъектам.ПроблемныйОбъект</queryText>
      <mainTable>Catalog.гкс_ОчередьОтложенногоФормированияИсходящихСообщений</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <commandInterface>
