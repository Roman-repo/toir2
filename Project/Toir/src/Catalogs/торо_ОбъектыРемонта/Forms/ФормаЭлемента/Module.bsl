&НаКлиенте
Процедура Перерасчитать(Команда)
	
	ТаблицаРемонтовВизуализация.Очистить();
	Декорация1 = "";
	
	СписокВидовРемонтов = ЗаполнитьВидыРемонтаНаСервере();
	Если СписокВидовРемонтов.Количество() = 0 Тогда
		ТекстСообщения = НСтр("es='Es imposible contar la estructura del ciclo de reparación, puesto que no son rellenadas las reparaciones normativas';ru='Невозможно рассчитать структуру ремонтного цикла, так как не заполнены нормативные ремонты';en='Unale to calculate the structure of the repair cycle, since regulatory repairs are not completed'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
		
	СписокВидовРемонтов.ЗаполнитьПометки(Истина);
	СписокВидовРемонтов.ПоказатьОтметкуЭлементов(Новый ОписаниеОповещения("ПерерасчитатьЗавершение",ЭтотОбъект), НСтр("es='Escojan los tipos de los trabajos de reparación';ru='Выберите виды ремонтных работ';en='Choose types of repair work'"));
	
КонецПроцедуры

