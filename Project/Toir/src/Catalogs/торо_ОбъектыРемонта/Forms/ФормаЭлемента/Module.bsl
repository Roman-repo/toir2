			Элементы.ВыявленныеДефектыВвестиДефект.Доступность     = Истина;
			Элементы.ГарантииОбъектаРемонта.Доступность            = Истина;
			Элементы.ТабМаксимальныхЗначенийНаработки.КоманднаяПанель.Доступность = Истина;
			Если ПолучитьФункциональнуюОпцию("ИспользоватьДополнительныеРеквизитыИСведения") Тогда
				Элементы.Свойства_ЗначенияДополнительныхРеквизитов.Доступность = Истина;			
			КонецЕсли;			
		КонецЕсли;
		
	Иначе
		Элементы.АдресКартинки.Высота = 7;
