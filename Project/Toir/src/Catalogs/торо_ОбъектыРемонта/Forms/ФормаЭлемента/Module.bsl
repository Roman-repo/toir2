			Элементы.СписокОбъектовРемонта.Доступность 			   = Ложь;
			Элементы.ВидыРемонтаОсновногоСвязанного.Доступность    = Ложь;
			Элементы.ВыявленныеДефектыВвестиДефект.Доступность     = Ложь;
			Элементы.ГарантииОбъектаРемонта.Доступность            = Ложь;
			Элементы.ТабМаксимальныхЗначенийНаработки.КоманднаяПанель.Доступность = Ложь;
			Если ПолучитьФункциональнуюОпцию("ИспользоватьДополнительныеРеквизитыИСведения") Тогда
				Элементы.Свойства_ЗначенияДополнительныхРеквизитов.Доступность = Ложь;			
			КонецЕсли; 
			
		Иначе
			ЭтаФорма.ТолькоПросмотр                                = Ложь;
			Элементы.ЗначенияКонтролируемыхПоказателей.Доступность = Истина;
			Элементы.ТабВыработкиОбъектаРемонта.Доступность        = Истина;
			Элементы.КомПанельГрафика.Доступность                  = Истина;
			
			Элементы.СписокИзмеряемыхПоказателей.Доступность 	   = Истина;
			Элементы.ПараметрыОповещенияПоСостояниямОР.Доступность = Истина;
			Элементы.СписокПараметровНаработки.Доступность 		   = Истина;
			Элементы.ТабЗапчастейОбъектовРемонта.Доступность 	   = Истина;
			Элементы.ТаблицаОценокРМ.Доступность 				   = Истина;
			Элементы.ВидыРемонтаЭтогоОбъекта.Доступность 		   = Истина;
