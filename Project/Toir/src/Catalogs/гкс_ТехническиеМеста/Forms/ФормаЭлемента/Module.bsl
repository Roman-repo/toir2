#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("ТолькоПросмотр") И Параметры.ТолькоПросмотр = Истина Тогда 
		Элементы.ФормаКоманднаяПанель.Доступность = Ложь;
		Элементы.ФормаКоманднаяПанель.Видимость = Ложь;
		Элементы.МестоПлощадка.ТолькоПросмотр = Истина;
		Элементы.ЗаводПодразделение.ТолькоПросмотр = Истина;
		Элементы.Участок.ТолькоПросмотр = Истина;
		Элементы.Эстакада.ТолькоПросмотр = Истина;
		Элементы.Секция.ТолькоПросмотр = Истина;
		Элементы.Здание.ТолькоПросмотр = Истина;
		Элементы.Этаж.ТолькоПросмотр = Истина;
		Элементы.Отметка.ТолькоПросмотр = Истина;
		Элементы.МестоПлощадка.КнопкаОткрытия = Ложь;
		Элементы.ЗаводПодразделение.КнопкаОткрытия = Ложь;
		Элементы.Участок.КнопкаОткрытия = Ложь;
		Элементы.Здание.КнопкаОткрытия = Ложь;
	КонецЕсли;
	дс_ПриСозданииНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура МестоПлощадкаПриИзменении(Элемент)
	ИзменитьНаименование();
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьНаименование()
	Объект.НаименованиеПолное = "";
	Если ЗначениеЗаполнено(Объект.МестоПлощадка) Тогда 
		Объект.НаименованиеПолное = Объект.МестоПлощадка;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ЗаводПодразделение) Тогда 
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", " + Объект.ЗаводПодразделение;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Участок) Тогда 
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", " + Объект.Участок;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Эстакада) Тогда 
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", эстакада " + Объект.Эстакада;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Секция) Тогда 
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", опора " + Объект.Секция;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Здание) Тогда 
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", здание " + Объект.Здание;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Этаж) Тогда 
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", этаж " + Объект.Этаж;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Отметка) Тогда 
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", отметка "
		+ Формат(Объект.Отметка, "ЧДЦ=3");
	Иначе
		Объект.НаименованиеПолное = ?(ЗначениеЗаполнено(Объект.НаименованиеПолное),Объект.НаименованиеПолное,"") + ", отметка 0,000";
	КонецЕсли;	
КонецПроцедуры

