    </type>
    <toolTip>
      <key>ru</key>
      <value>Объект, которому соответствует внешний пользователь, например, контрагент</value>
    </toolTip>
    <toolTip>
      <key>es</key>
      <value>El objeto, a que corresponde el usuario exterior, por ejemplo, el contratante</value>
    </toolTip>
    <toolTip>
      <key>en</key>
      <value>The object to which the external user corresponds, for example, the counterparty</value>
    </toolTip>
    <minValue xsi:type="core:UndefinedValue"/>
    <maxValue xsi:type="core:UndefinedValue"/>
    <fillChecking>ShowError</fillChecking>
