  <attributes uuid="d431d1e2-13dc-495c-9de1-b5ec872eceed">
    <name>УстановитьРолиНепосредственно</name>
    <synonym>
      <key>ru</key>
      <value>Установить роли непосредственно</value>
    </synonym>
    <synonym>
      <key>es</key>
      <value>Establecer el papel directamente</value>
    </synonym>
    <synonym>
      <key>en</key>
      <value>Set roles directly</value>
    </synonym>
    <comment>Используется, если не встроена подсистема &quot;Управление доступом&quot;</comment>
    <type>
      <types>Boolean</types>
    </type>
    <toolTip>
      <key>ru</key>
      <value>Установить роли непосредственно без использования ролей, заданных в группах внешних пользователей</value>
    </toolTip>
    <toolTip>
      <key>es</key>
      <value>Establecer el papel directamente sin uso de los papeles dados en los grupos de los usuarios exteriores</value>
    </toolTip>
    <toolTip>
      <key>en</key>
      <value>Set roles directly without using the roles defined in external user groups</value>
    </toolTip>
    <minValue xsi:type="core:UndefinedValue"/>
    <maxValue xsi:type="core:UndefinedValue"/>
    <fillValue xsi:type="core:UndefinedValue"/>
    <fullTextSearch>Use</fullTextSearch>
    <dataHistory>Use</dataHistory>
