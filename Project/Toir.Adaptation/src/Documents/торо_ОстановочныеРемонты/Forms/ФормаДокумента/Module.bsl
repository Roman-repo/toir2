// Гкс+[TOIR20-188] Селимов
&НаКлиенте
Процедура ПоказатьТаблицуТрудовыхРесурсов(Команда)

	ВидимостьТаблицыТР = Элементы["гкс_ДостпупностьТрудовыхРесурсов"].Видимость;
	
	Элементы["гкс_ДостпупностьТрудовыхРесурсов"].Видимость = Не ВидимостьТаблицыТР;
	Элементы["КомандаПоказатьТаблицуТрудовыхРесурсов"].Пометка = Не ВидимостьТаблицыТР;
	
	Если ВидимостьТаблицыТР = Ложь Тогда
		УдалитьУсловноеОформлениеПоКвалификации();		
	КонецЕсли; 
	
КонецПроцедуры  

// Гкс+[TOIR20-190] Селимов
&НаКлиенте
Процедура УдалитьСвязанныеРемонтыНеВходящиеВПериодОстановочного(Команда)
	
	ДатаНачалаРемонта = Объект.ДатаНачалаРемонта;	
	ДатаОкончанияРемонта = Объект.ДатаОкончанияРемонта;	
	
	СтрокиКУдалению = Новый Массив;
	Для каждого ТекущаяСтрока Из Объект.СвязанныеРемонты Цикл
		Если ТекущаяСтрока.ДатаНачалаРемонта < ДатаНачалаРемонта
			ИЛИ ТекущаяСтрока.ДатаОкончанияРемонта > ДатаОкончанияРемонта Тогда
			СтрокиКУдалению.Добавить(ТекущаяСтрока);
		КонецЕсли; 		
	КонецЦикла; 
	
	Для каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
		Объект.СвязанныеРемонты.Удалить(СтрокаКУдалению);		
	КонецЦикла; 
	
КонецПроцедуры 

// Гкс+[TOIR20-190] Селимов
&НаКлиенте
Процедура ПеренестиВПериодОстановочногоРемонта(Команда)
	
	СтрокиКУдалению = Новый Массив;
	ПродолжительностьОстановочного = Объект.ДатаОкончанияРемонта - Объект.ДатаНачалаРемонта;
	Для каждого ТекущаяСтрока Из Объект.СвязанныеРемонты Цикл
		ПродолжительностьСвязанного = ТекущаяСтрока.ДатаОкончанияРемонта - ТекущаяСтрока.ДатаНачалаРемонта;
		Если ПродолжительностьСвязанного > ПродолжительностьОстановочного Тогда
			СтрокиКУдалению.Добавить(ТекущаяСтрока);
		Иначе
			ТекущаяСтрока.ДатаНачалаРемонта = Объект.ДатаНачалаРемонта;
			ТекущаяСтрока.ДатаОкончанияРемонта = ТекущаяСтрока.ДатаНачалаРемонта + ПродолжительностьСвязанного;
		КонецЕсли; 				
	КонецЦикла; 
	
	Для каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
		Объект.СвязанныеРемонты.Удалить(СтрокаКУдалению);		
	КонецЦикла; 
	
КонецПроцедуры 
 
