// Гкс+[TOIR20-190] Селимов 
&НаКлиенте
Процедура ПриИзмененииДатРемонта(ИзмененаДатаНачала, ИзмененаДатаОкончания)
	
	ИсходныеДаты = ПолучитьДатыИзДокумета(Объект.Ссылка);
	
	Если ИсходныеДаты <> Неопределено Тогда
		Сдвиг = 0;
		Если ИзмененаДатаНачала Тогда
			Сдвиг = Объект.ДатаНачалаРемонта - ИсходныеДаты.ДатаНачалаРемонта;
			Объект.ДатаОкончанияРемонта = ИсходныеДаты.ДатаОкончанияРемонта + Сдвиг; 
		КонецЕсли;		
		// гкс+ [2021] Куст 
		Если Объект.гкс_Сводный = Ложь Тогда // гкс- [2021]  
			Если ИзмененаДатаОкончания Тогда
				Сдвиг = Объект.ДатаОкончанияРемонта - ИсходныеДаты.ДатаОкончанияРемонта;
				Объект.ДатаНачалаРемонта = ИсходныеДаты.ДатаНачалаРемонта + Сдвиг; 
			КонецЕсли;		
		// гкс+ [2021] Куст 
		КонецЕсли; // гкс- [2021] 
		ИзменитьДатыВСвязанныхРемонты(Сдвиг);
		
	КонецЕсли; 
	
КонецПроцедуры // } Гкс-[TOIR20-190] 

// Гкс+[TOIR20-190] Селимов 
&НаКлиенте
Процедура ИзменитьДатыВСвязанныхРемонты(Сдвиг)
	// гкс+ [2021] Куст 
	Если Сдвиг = 0 Тогда 
		Возврат;
	КонецЕсли; // гкс- [2021] 
	
	Для каждого ТекущаяСтрока Из Объект.СвязанныеРемонты Цикл
		ТекущаяСтрока.ДатаНачалаРемонта    = ТекущаяСтрока.ДатаНачалаРемонта + Сдвиг;
		ТекущаяСтрока.ДатаОкончанияРемонта = ТекущаяСтрока.ДатаОкончанияРемонта + Сдвиг;
		ТекущаяСтрока.Изменен = Истина;
	КонецЦикла; 		

КонецПроцедуры 

