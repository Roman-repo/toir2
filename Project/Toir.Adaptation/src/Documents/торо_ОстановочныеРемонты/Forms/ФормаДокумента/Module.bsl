// Гкс+[TOIR20-188] Селимов 
&НаКлиенте
Процедура КолонкаДоступноПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы["ТаблицаТрудозатрат"].ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("Дата", Объект.Дата);		
		ПараметрыЗаполнения.Вставить("ВидОперации",
			ПредопределенноеЗначение("Перечисление.гкс_ВидыОперацииВводДанныхПоТрудовымРесурсам.Корректировка"));			
		ПараметрыЗаполнения.Вставить("Организация", Объект.Организация);
		ПараметрыЗаполнения.Вставить("Подразделение", Объект.Подразделение);
		ПараметрыЗаполнения.Вставить("Квалификация", ТекущиеДанные.Квалификация);
		ПараметрыЗаполнения.Вставить("ПериодПланирования", НачалоДня(ЭтаФорма["ТрудовыеРесурсы_ПериодС"]));
		// гкс+ [2021] Куст 
		СекундВМинуте = 60;
		КорректировочноеЗначение = (ТекущиеДанные.Доступно * СекундВМинуте) - ТекущиеДанные.ДоступноИсходное; // гкс- [2021]
		Если КорректировочноеЗначение > 0 Тогда
			ПараметрыЗаполнения.Вставить("ВидДвижения", ПредопределенноеЗначение("Перечисление.гкс_ВидДвижения.Приход"));
			ПараметрыЗаполнения.Вставить("Доступно", КорректировочноеЗначение); 
		Иначе
			ПараметрыЗаполнения.Вставить("ВидДвижения", ПредопределенноеЗначение("Перечисление.гкс_ВидДвижения.Расход"));			
			ПараметрыЗаполнения.Вставить("Доступно", - КорректировочноеЗначение); 
		КонецЕсли; 
		
		СоздатьДокументКорректирвкиТрудовыхРесурсов(ПараметрыЗаполнения);			
		
	КонецЕсли;   
	
КонецПроцедуры // } Гкс- [TOIR20-188] 

&НаСервереБезКонтекста
Процедура СоздатьДокументКорректирвкиТрудовыхРесурсов(ТекущиеДанные)
	
	КорректировкаТР = Документы.гкс_ВводДанныхПоТрудовымРесурсам.СоздатьДокумент();
	КорректировкаТР.Заполнить(ТекущиеДанные);
	КорректировкаТР.Записать(РежимЗаписиДокумента.Проведение);
		
КонецПроцедуры // } Гкс- [TOIR20-188]       

&НаКлиенте
Процедура ТаблицаТрудовыеРесурсыПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		ИДРемонтов = Новый Массив;
		Для каждого ТекущаяСтрока Из Объект.СвязанныеРемонты Цикл
			ИДРемонтов.Добавить(ТекущаяСтрока.ID);		
		КонецЦикла; 
		РесурсовДостаточно = ТекущиеДанные.Доступно > ТекущиеДанные.Требуется;
		// гкс+ [2021] Куст 
		Если ЭтотОбъект["гкс_ОтборПоРемонтам"] = Ложь Тогда 
			ВыделитьСвязанныеРемонтыПоКвалификации(ТекущиеДанные.Квалификация, ИДРемонтов, РесурсовДостаточно);
		КонецЕсли; // гкс- [2021] Куст 
	КонецЕсли;    	 	
КонецПроцедуры  
// Гкс-[TOIR20-189]                                             

&НаКлиенте
&ИзменениеИКонтроль("СвязанныеРемонтыПередУдалением")
Процедура гкс_СвязанныеРемонтыПередУдалением(Элемент, Отказ)

	Отказ = Истина;

	ЭтоКорректировка = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.торо_ВидыОперацийДокументаОстановочныйРемонт.Корректировка");

	Для Каждого ВыдСтрока Из Элемент.ВыделенныеСтроки Цикл

		ДанныеСтроки = Элемент.ДанныеСтроки(ВыдСтрока);

		Если НЕ ЗначениеЗаполнено(ДанныеСтроки.ID) 
			ИЛИ ДанныеСтроки.Добавлен Тогда
			Объект.СвязанныеРемонты.Удалить(ДанныеСтроки);
			#Вставка
			// Гкс+[TOIR20-189] Селимов 
			УдалитьДанныеИзТаблицыТрудовыхРесурсов(ДанныеСтроки.ID, ДанныеСтроки.ДокументИсточник);
			#КонецВставки
			Продолжить;
		КонецЕсли;

		НайденныеСтроки = МассивДоступныхДляКорректировкиСтрок.НайтиСтроки(Новый Структура("ID", ДанныеСтроки.ID));

		Если НайденныеСтроки.Количество() > 0 
			И НайденныеСтроки[0].ДоступенДляРедактирования 
			И Не ЭтоКорректировка Тогда

			Объект.СвязанныеРемонты.Удалить(ДанныеСтроки);
			#Вставка
			// Гкс+[TOIR20-189] Селимов 
			УдалитьДанныеИзТаблицыТрудовыхРесурсов(ДанныеСтроки.ID, ДанныеСтроки.ДокументИсточник); 
			#КонецВставки 

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

