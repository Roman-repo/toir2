
#Область ОбработчикиСобытийФормы

&НаСервере
&ИзменениеИКонтроль("ПриСозданииНаСервере")
Процедура гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("Основание") Тогда
		#Удаление
		торо_ЗаполнениеДокументов.ПроверитьВозможностьВводаНаОсновании(Параметры.Основание, Отказ);
		#КонецУдаления
		#Вставка
		// гкс+ [Релиз16] Деснол
		торо_ЗаполнениеДокументов.гкс_ПроверитьВозможностьВводаНаОснованииСтарый(Параметры.Основание, Отказ);
		// гкс- [Релиз16]
		#КонецВставки
		Если Отказ Тогда
			Возврат;
		КонецЕсли; 
	КонецЕсли;
	#Вставка
	// гкс+ [2021] Куст
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда
		Объект.гкс_Сводный = Истина;
	КонецЕсли;
	// гкс+ [03.23] Деснол 13.03.2023
	Если Не РольДоступна("гкс_РедактированиеЗаявкиНаРемонт") Тогда 
		Элементы.Дата.ТолькоПросмотр = Истина;
	КонецЕсли;
	// гкс- [03.23] Деснол 13.03.2023
	#КонецВставки

	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	Если Параметры.Свойство("ID") Тогда

		Строки = Объект.СвязанныеРемонты.НайтиСтроки(Новый Структура("ID", Параметры.ID));
		Если Строки.Количество() Тогда
			Элементы.СвязанныеРемонты.ТекущаяСтрока = Строки[0].ПолучитьИдентификатор();
		ИначеЕсли Параметры.ID = Объект.IDОсновногоРемонта Тогда
			ЭтаФорма.ТекущийЭлемент = Элементы.ДокументОснование;
		КонецЕсли;

	КонецЕсли;

	Если ЗначениеЗаполнено(Объект.КорректируемыйДокумент) И ТипЗнч(Объект.КорректируемыйДокумент) = Тип("ДокументСсылка.торо_ОстановочныеРемонты") Тогда
		Объект.ДокументОснование = Объект.КорректируемыйДокумент.ДокументОснование;
	КонецЕсли; 

	//торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(РеквизитФормыВЗначение("Объект"), ЭтаФорма, Строка(Объект.ВидОперации));
	торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(Объект, ЭтаФорма, Строка(Объект.ВидОперации));
	торо_СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка, Новый Структура("УстановитьСвойствоЭлементовФормыОтПрав", Истина));

	// Согласование++
	ВидДокумента = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ОстановочныеРемонты;
	торо_РаботаССогласованиями.ПриСозданииНаСервере(ЭтаФорма, ВидДокумента);
	// Согласование --

	УстановитьУсловноеОформление();

	ОбновитьДоступностьДляРедактирования();

	УправлениеВидимостью(ЭтотОбъект);

	ДиаграммаРемонтов.ОтображатьЗаголовок = Ложь;
	ДиаграммаРемонтов.ОтображатьЛегенду   = Ложь;

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПроставитьПризнакЗависимыйПодчиненный();
	КонецЕсли; 
	#Вставка
	// Гкс+[TOIR20-188] Селимов 
	ДобавитьЭлементыФормы();   
	// гкс+ [Часовые пояса] Куст 
	гкс_ЧасовыеПоясаВызовСервера.ДобавитьНовыеЭлементы(ЭтаФорма, Элементы.ШапкаДатаНомер,
		Новый Структура("гкс_РеквизитыДаты", "Дата,ДатаНачалаРемонта,ДатаОкончанияРемонта," 
		+ "СвязанныеРемонты.ДатаНачалаРемонта,СвязанныеРемонты.ДатаОкончанияРемонта" +
		",СвязанныеРемонты.ДатаНачалаРемонтаСтарая,СвязанныеРемонты.ДатаОкончанияРемонтаСтарая"));
	#КонецВставки 

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПриОткрытии")
Процедура гкс_ПриОткрытии(Отказ)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	УстановитьВидимостьДоступность();

	Если Не ЗначениеЗаполнено(Объект.Ссылка) И Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.торо_ВидыОперацийДокументаОстановочныйРемонт.ОстановочныйРемонт") И ЗначениеЗаполнено(Объект.ДокументОснование) И Объект.IDОсновногоРемонта = "" Тогда
		ПодключитьОбработчикОжидания("ОткрытьФормуДляПодбораОстановочногоРемонта", 0.1, Истина);
	КонецЕсли;
    #Вставка
	гкс_ПриОткрытииНаСервере();
	// Гкс+[TOIR20-188] Селимов 
	Этаформа["ТрудовыеРесурсы_ПериодС"] = Объект.ДатаНачалаРемонта;
	Этаформа["ТрудовыеРесурсы_ПериодПо"] = Объект.ДатаОкончанияРемонта;
	ЗаполнитьТрудовыеРесурсы(); 
	#КонецВставки

КонецПроцедуры

// гкс+ [2021] Куст
&НаСервере
Процедура гкс_ПриОткрытииНаСервере()
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтаФорма, 
		"Дата,ДатаНачалаРемонта,ДатаОкончанияРемонта," 
		+ "СвязанныеРемонты.ДатаНачалаРемонта,СвязанныеРемонты.ДатаОкончанияРемонта" +
		",СвязанныеРемонты.ДатаНачалаРемонтаСтарая,СвязанныеРемонты.ДатаОкончанияРемонтаСтарая" ,,);
КонецПроцедуры

// гкс+ [2021] Куст
&НаКлиенте
Процедура гкс_ПередЗаписьюПосле(Отказ, ПараметрыЗаписи)
	Если Объект.гкс_Сводный Тогда
		Если ЗначениеЗаполнено(Объект.ДокументОснование) И Объект.СвязанныеРемонты.Количество() Тогда
			Объект.ДокументОснование = Объект.СвязанныеРемонты[0].ДокументИсточник;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// гкс+ [2021] Куст
&НаСервере
&ИзменениеИКонтроль("ПередЗаписьюНаСервере")
Процедура гкс_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	// Согласование++
	торо_РаботаССогласованиями.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	// Согласование--

	#Вставка
	гкс_ИзменитьИсполнителейВОснованиях(Отказ);
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПСервера(ЭтаФорма,, ТекущийОбъект);
	#КонецВставки
КонецПроцедуры

// гкс+ [2021] Куст
&НаСервере
&ИзменениеИКонтроль("ПриЗаписиНаСервере")
Процедура гкс_ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	// Согласование++
	торо_РаботаССогласованиями.ПриЗаписиНаСервере(ЭтаФорма, ТекущийОбъект);
