// Гкс+[TOIR20-189] Селимов 
Функция ПолучитьПлановыеТрудозатраты(ИДРемонтов, ДокументыИсточники = Неопределено)
	
	// гкс+ [2021] Куст
	СекундВМинуте = 60;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	// гкс+ [Релиз16] Деснол
	"ВЫБРАТЬ
	|	ПлановыеТрудозатраты.Квалификация КАК Квалификация,
	|	СУММА(ВЫБОР
		|			КОГДА ПлановыеТрудозатраты.Количество = 0
		|				ТОГДА 1
		|			ИНАЧЕ ПлановыеТрудозатраты.Количество
		|		КОНЕЦ * ВЫБОР
		|			КОГДА ПлановыеТрудозатраты.ВремяРаботы = 0
		|				ТОГДА 1
		|			ИНАЧЕ ПлановыеТрудозатраты.ВремяРаботы
		|	КОНЕЦ / " + СекундВМинуте + ") КАК Требуется
	|ИЗ
	|	РегистрНакопления.торо_ПлановыеТрудовыеЗатратыРемонтныхРабот КАК ПлановыеТрудозатраты
	|ГДЕ
	|	ПлановыеТрудозатраты.РемонтыОборудования_ID В(&РемонтыОборудования_ID)
	|	И ПлановыеТрудозатраты.Регистратор В(&ДокументыИсточники)
	|
		|СГРУППИРОВАТЬ ПО
		|	ПлановыеТрудозатраты.Квалификация
	|";
	// гкс- [Релиз16]
	
	Запрос.УстановитьПараметр("РемонтыОборудования_ID", ИДРемонтов);
	
	Если ДокументыИсточники = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПлановыеТрудозатраты.Регистратор В(&ДокументыИсточники)", "Истина");
	Иначе
		Запрос.УстановитьПараметр("ДокументыИсточники", ДокументыИсточники);
	КонецЕсли; 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	ТребуемыеТрудовыеЗатраты = Новый Массив;
	Пока Выборка.Следующий() Цикл
		ТребуемыеТрудовыеЗатраты.Добавить(Новый Структура("Квалификация, Требуется", 
															Выборка.Квалификация, Выборка.Требуется));
	КонецЦикла; 
	
	Возврат ТребуемыеТрудовыеЗатраты;

КонецФункции 

&НаКлиенте
&ИзменениеИКонтроль("СвязанныеРемонтыДобавитьСтроку")
Процедура гкс_СвязанныеРемонтыДобавитьСтроку(ВыбранноеЗначение)

	Если Объект.СвязанныеРемонты.НайтиСтроки(Новый Структура("ID",ВыбранноеЗначение.СтрокаРемонтовОборудования.ID)).Количество() = 0 
		И ВыбранноеЗначение.СтрокаРемонтовОборудования.ID <> Объект.IDОсновногоРемонта Тогда

		ДатаНачалаВыбранного = ВыбранноеЗначение.СтрокаРемонтовОборудования.ДатаНачала;
		ДатаОкончанияВыбранного = ВыбранноеЗначение.СтрокаРемонтовОборудования.ДатаОкончания;

		НС                           = Объект.СвязанныеРемонты.Добавить();
		НС.ID                        = ВыбранноеЗначение.СтрокаРемонтовОборудования.ID;
		НС.ОбъектРемонта             = ВыбранноеЗначение.СтрокаРемонтовОборудования.ОбъектРемонта;
		НС.ВидРемонта                = ВыбранноеЗначение.СтрокаРемонтовОборудования.ВидРемонтныхРабот;
		НС.ДатаНачалаРемонта         = ДатаНачалаВыбранного;
		НС.ДатаОкончанияРемонта      = ДатаОкончанияВыбранного;
		НС.ДатаНачалаРемонтаСтарая   = ДатаНачалаВыбранного;
		НС.ДатаОкончанияРемонтаСтарая= ДатаОкончанияВыбранного;
		НС.ДокументИсточник          = ВыбранноеЗначение.ДокументОснование;
		НС.Добавлен                  = Истина;
		НС.Зависимый                 = ВыбранноеЗначение.СтрокаРемонтовОборудования.Зависимый;
		НС.Подчиненный               = ВыбранноеЗначение.СтрокаРемонтовОборудования.Подчиненный;
		НС.Исполнитель               = ВыбранноеЗначение.СтрокаРемонтовОборудования.Исполнитель;
		НС.СпособВыполнения          = ВыбранноеЗначение.СтрокаРемонтовОборудования.СпособВыполнения;
		НС.КритичностьДефекта        = ВыбранноеЗначение.СтрокаРемонтовОборудования.КритичностьДефекта;
		#Вставка
		НС.гкс_ОписаниеРемонта        = ВыбранноеЗначение.СтрокаРемонтовОборудования.ОписаниеРемонта;
		НС.гкс_Статус        = ВыбранноеЗначение.СтрокаРемонтовОборудования.Статус;
		#КонецВставки

		НС.Добавлен                  = Истина;

		Если Объект.ДатаНачалаРемонта > ДатаНачалаВыбранного Или Объект.ДатаОкончанияРемонта < ДатаОкончанияВыбранного Тогда
			ТекстСообщения = НСтр("es='¡La reparación escogida sale por las fronteras del intervalo de la reparación básica!';ru='Выбранный ремонт выходит за границы интервала основного ремонта!';en='The selected repair is outside the basic repair interval!'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;

		ОбновитьДоступностьДляРедактирования();
		Модифицированность = Истина;
		#Вставка
		// гкс+ [2021] Куст 
		ЗаполнитьТрудовыеРесурсы();
		#КонецВставки

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура гкс_СвязанныеРемонтыПриОкончанииРедактированияВместо(Элемент, НоваяСтрока, ОтменаРедактирования)
	// Гкс+[TOIR20-189] Селимов 
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НоваяСтрока И ЗначениеЗаполнено(Элемент.ТекущиеДанные.ID) Тогда
		ОтразитьТребуемыеРесурсыВТаблицеТрудозатрат(Элемент.ТекущиеДанные.ID, Элемент.ТекущиеДанные.ДокументИсточник);		
	КонецЕсли; 	 
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("СвязанныеРемонтыДатаНачалаРемонтаПриИзменении")
Процедура гкс_СвязанныеРемонтыДатаНачалаРемонтаПриИзменении(Элемент)
	ПроставитьПризнакИзмененВТекущейСтроке();
	#Вставка
	// Гкс+[TOIR20-190] Селимов 
	ТекущиеДанные = Элементы.СвязанныеРемонты.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекущиеДанные.ID) Тогда
		Продолжительность = ПолучитьПродолжительностьСвязанногоРемонтаИзДокумета(Объект.Ссылка, ТекущиеДанные.ID);
		ТекущиеДанные.ДатаОкончанияРемонта = ТекущиеДанные.ДатаНачалаРемонта + Продолжительность; 
	КонецЕсли; 
	#КонецВставки
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("СвязанныеРемонтыДатаОкончанияРемонтаПриИзменении")
Процедура гкс_СвязанныеРемонтыДатаОкончанияРемонтаПриИзменении(Элемент)
	ПроставитьПризнакИзмененВТекущейСтроке();
	#Вставка
	// Гкс+[TOIR20-190] Селимов 
	ТекущиеДанные = Элементы.СвязанныеРемонты.ТекущиеДанные;
	Продолжительность = ПолучитьПродолжительностьСвязанногоРемонтаИзДокумета(Объект.Ссылка, ТекущиеДанные.ID);
	ТекущиеДанные.ДатаНачалаРемонта = ТекущиеДанные.ДатаОкончанияРемонта - Продолжительность; 
	#КонецВставки
КонецПроцедуры

