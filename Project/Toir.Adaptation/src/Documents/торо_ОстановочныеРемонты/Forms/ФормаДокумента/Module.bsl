&НаСервере
Процедура ВыделитьСвязанныеРемонтыПоКвалификации(Квалификация, ИДРемонтов, РесурсовДостаточно)
	
	ИДРемонтовПоКвалификации = ПолучитьИДРемонтовПоКвалификации(Квалификация, ИДРемонтов);
	
	ПоследнийЭлементУО = УсловноеОформление.Элементы.Получить(УсловноеОформление.Элементы.Количество() - 1);
	Если ПоследнийЭлементУО.ИдентификаторПользовательскойНастройки = "ПоКвалификации" Тогда
		УсловноеОформление.Элементы.Удалить(ПоследнийЭлементУО);			
	КонецЕсли; 
	
	НовыйЭлементУО = УсловноеОформление.Элементы.Добавить();
	НовыйЭлементУО.ИдентификаторПользовательскойНастройки = "ПоКвалификации";    
	
	ОтборУО = НовыйЭлементУО.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборУО.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.СвязанныеРемонты.ID");
	ОтборУО.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	ОтборУО.ПравоеЗначение = ИДРемонтовПоКвалификации;
	    
	ОформляемоеПоле = НовыйЭлементУО.Поля.Элементы.Добавить();
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("СвязанныеРемонты");
	
	Если РесурсовДостаточно Тогда
		Цвет = WebЦвета.СветлоЗеленый;
	Иначе
		Цвет = WebЦвета.СветлоРозовый;
	КонецЕсли; 
	НовыйЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветФона", Цвет);
	
КонецПроцедуры   

// Гкс+[TOIR20-189] Селимов 
&НаСервереБезКонтекста
Функция ПолучитьИДРемонтовПоКвалификации(Квалификация, ИДРемонтов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПлановыеТрудозатраты.РемонтыОборудования_ID КАК ИД
	|ИЗ
	|	РегистрНакопления.торо_ПлановыеТрудовыеЗатратыРемонтныхРабот.Обороты(
	|			,
	|			,
	|			,
	|			РемонтыОборудования_ID В (&ИДРемонтов)
	|				И Квалификация = &Квалификация) КАК ПлановыеТрудозатраты
	|
	|СГРУППИРОВАТЬ ПО
	|	ПлановыеТрудозатраты.РемонтыОборудования_ID";
	
	Запрос.УстановитьПараметр("ИДРемонтов", ИДРемонтов);
	Запрос.УстановитьПараметр("Квалификация", Квалификация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	ИДРемонтовПоКвалификации = Новый СписокЗначений;
	Пока Выборка.Следующий() Цикл
		ИДРемонтовПоКвалификации.Добавить(Выборка.ИД);
	КонецЦикла; 
	
	Возврат ИДРемонтовПоКвалификации;
	
