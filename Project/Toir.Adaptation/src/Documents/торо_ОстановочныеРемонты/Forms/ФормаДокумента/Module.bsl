&НаСервере
Функция ДанныеТрудовыхРесурсов(ПериодПланированияС, ПериодПланированияПо, Квалификация = Неопределено)
	// гкс+ [2021] Куст 13.05.2021
	СекундВМинуте = 60;	// гкс- [2021]
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	гкс_ТрудовыеРесурсыОстатки.Квалификация КАК Квалификация,
		|	ВЫБОР
		|		КОГДА гкс_ТрудовыеРесурсыОстатки.ДоступноОстаток - гкс_ТрудовыеРесурсыОстатки.ЗапланированоОстаток < 0
		|			ТОГДА 0
		|		ИНАЧЕ гкс_ТрудовыеРесурсыОстатки.ДоступноОстаток - гкс_ТрудовыеРесурсыОстатки.ЗапланированоОстаток
		// гкс+ [2021] Куст 
		// теперь в минутах
		|	/ " + СекундВМинуте + "
		// гкс- [2021] Куст 
		|	КОНЕЦ КАК Доступно,
		|	0 КАК Требуется,
		|	0 КАК ДоступноИсходное
		|ИЗ
		|	РегистрНакопления.гкс_ТрудовыеРесурсы.Остатки(
		|			,
		|			ПериодПланирования МЕЖДУ &ПериодС И &ПериодПо
		|				И Квалификация = &Квалификация
		|				И Организация = &Организация
		|				И Подразделение = &Подразделение) КАК гкс_ТрудовыеРесурсыОстатки";
	
	Если Квалификация = Неопределено Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Квалификация = &Квалификация", "Истина");
	Иначе
		Запрос.УстановитьПараметр("Квалификация", Объект.Квалификация);		
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Организация = &Организация", "Истина");
	Иначе
		Запрос.УстановитьПараметр("Организация", Объект.Организация);		
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(Объект.Подразделение) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Подразделение = &Подразделение", "Истина");
	Иначе
		Запрос.УстановитьПараметр("Подразделение", Объект.Подразделение);		
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("ПериодС", ПериодПланированияС);
	Запрос.УстановитьПараметр("ПериодПо", ПериодПланированияПо);
	Запрос.Текст = ТекстЗапроса;
	РезультатЗапроса = Запрос.Выполнить();

	Возврат РезультатЗапроса;
	
КонецФункции 

