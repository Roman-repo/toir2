&НаКлиенте
Функция гкс_НайденоВСтрокеТЧ(СтрокаТЧ)
	СтрокаСтроки = Строка(СтрокаТЧ.ДокументИсточник) + Строка(СтрокаТЧ.ОбъектРемонта) + Строка(СтрокаТЧ.ВидРемонта)
	+ Строка(СтрокаТЧ.Исполнитель) + Строка(СтрокаТЧ.СпособВыполнения) + Строка(СтрокаТЧ.гкс_ОписаниеРемонта) + Строка(СтрокаТЧ.гкс_Статус);
	
	Если СтрНайти(СтрокаСтроки, ЭтотОбъект["гкс_СтрокаПоиска"]) > 0 Тогда 
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции // гкс- [] Деснол 16.09.2022

// гкс+ [] Деснол 16.09.2022
&НаКлиенте
Процедура гкс_НайтиСтрокуДалее(Команда)
	ТекДанные = Элементы.СвязанныеРемонты.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		НачальныйНомер = 0;
	Иначе
		НачальныйНомер = ТекДанные.НомерСтроки;
	КонецЕсли;
	НайденныйИд = Неопределено;
	Для Каждого СтрокаТЧ из Объект.СвязанныеРемонты Цикл
		Если СтрокаТЧ.НомерСтроки <= НачальныйНомер Тогда 
			Продолжить;
		КонецЕсли;
		Если гкс_НайденоВСтрокеТЧ(СтрокаТЧ) Тогда
			НайденныйИд = СтрокаТЧ.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если НайденныйИд = Неопределено Тогда 
		Для Каждого СтрокаТЧ из Объект.СвязанныеРемонты Цикл
			Если СтрокаТЧ.НомерСтроки > НачальныйНомер Тогда 
				Прервать;
			КонецЕсли;
			Если гкс_НайденоВСтрокеТЧ(СтрокаТЧ) Тогда
				НайденныйИд = СтрокаТЧ.ПолучитьИдентификатор();
				Прервать;
			КонецЕсли;                                                
		КонецЦикла;
	КонецЕсли;
	
	Если НайденныйИд = Неопределено Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "поиск не дал результатов";
		Сообщение.Сообщить();
	Иначе
		Элементы.СвязанныеРемонты.ТекущаяСтрока = НайденныйИд;
	КонецЕсли;
КонецПроцедуры // гкс- [] Деснол 16.09.2022

// Гкс+[TOIR20-188] Селимов 
&НаКлиенте
Процедура ЗаполнитьТрудовыеРесурсы()
	
	ЗаполнитьТрудовыеРесурсыНаСервере();
	
	// гкс+ [2021] Куст
	ДокументыИсточники = Новый Массив;
	ИДРемонтов = Новый Массив;
	Если ЭтотОбъект["гкс_ОтборПоРемонтам"] Тогда 
		ТекДанные = Элементы.СвязанныеРемонты.ТекущиеДанные;
		РемонтПодходит = Истина;
		Если ЭтотОбъект["гкс_ТолькоХозспособ"] И ЗначениеЗаполнено(ТекДанные.Исполнитель) Тогда
			РемонтПодходит = гкс_ЭтоСобственныйИсполнитель(ТекДанные.Исполнитель);
		КонецЕсли;
		Если РемонтПодходит Тогда 
			Если Не ТекДанные = Неопределено Тогда 
				ДокументыИсточники.Добавить(ТекДанные.ДокументИсточник);
				ИДРемонтов.Добавить(ТекДанные.ID);
			КонецЕсли;
		КонецЕсли;
	Иначе
		ОтразитьТрудовыеРесурсыНаСервере(ИДРемонтов, ДокументыИсточники);
	КонецЕсли;
	ОтразитьТребуемыеРесурсыВТаблицеТрудозатрат(ИДРемонтов, ДокументыИсточники);
	МассивУдаления = Новый массив();
	Для Каждого СтрокаТаблицы Из ЭтотОбъект["ТаблицаТрудозатрат"] Цикл
		Если СтрокаТаблицы.Требуется <= 0 Тогда 
			МассивУдаления.Добавить(СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаМассива Из МассивУдаления Цикл
		ЭтотОбъект["ТаблицаТрудозатрат"].Удалить(СтрокаМассива);
	КонецЦикла; // гкс- [2021] 
	
КонецПроцедуры	 

