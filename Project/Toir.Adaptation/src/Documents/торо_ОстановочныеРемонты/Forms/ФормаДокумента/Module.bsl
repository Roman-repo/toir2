// гкс+ [2021] Куст 
&НаКлиенте
&ИзменениеИКонтроль("СвязанныеРемонтыВыбор")
Процедура гкс_СвязанныеРемонтыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	#Вставка
	Если Поле.Имя = "СвязанныеРемонтыИсполнитель" Тогда 
		ДанныеСтроки = Элемент.ДанныеСтроки(ВыбраннаяСтрока);
		МассивТипов = Новый Массив();
		МассивТипов.Добавить(Тип("СправочникСсылка.Контрагенты"));
		МассивТипов.Добавить(Тип("СправочникСсылка.СтруктураПредприятия"));
		ТипИсполнитель = Новый ОписаниеТипов(МассивТипов);
		ОписаниеОп = Новый ОписаниеОповещения("гкс_ПослеВыбораИсполнителя", ЭтотОбъект);
		ПоказатьВводЗначения(ОписаниеОп, ДанныеСтроки.Исполнитель,, ТипИсполнитель);
		Возврат;
	КонецЕсли;
	#КонецВставки

	Если Поле.Имя <> "СвязанныеРемонтыОтвязать" И Поле.Имя <> "СвязанныеРемонтыДатаНачалаРемонта" И Поле.Имя <> "СвязанныеРемонтыДатаОкончанияРемонта" Тогда
		ДанныеСтроки = Элемент.ДанныеСтроки(ВыбраннаяСтрока);
		ОткрытьДокументСРемонтом(ДанныеСтроки.ДокументИсточник, ДанныеСтроки.ID);
	КонецЕсли;

КонецПроцедуры

// гкс+ [2021] Куст 
&НаКлиенте
Процедура гкс_ПослеВыбораИсполнителя(Результат, ДопПараметры)Экспорт
	Если Не Результат = Неопределено Тогда 
		ТекДанные = Элементы.СвязанныеРемонты.ТекущиеДанные;
		Если Не ТекДанные = Неопределено Тогда 
			ТекДанные.Исполнитель = Результат;
			ТекДанные["гкс_ИзмененИсполнитель"] = Истина;
			ТекДанные.СпособВыполнения = гкс_ПолучитьСпособВыполненияИсполнителя(Результат);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

