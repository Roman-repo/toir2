// Гкс+[TOIR20-188] Селимов 
&НаСервере
Процедура ДобавитьЭлементыФормы()
	
	// РЕКВИЗИТЫ
	ТипЧисло = Новый ОписаниеТипов("Число");
	ТипДата = Новый ОписаниеТипов("Дата");
	
	Реквизиты = Новый Массив;

	Реквизиты.Добавить(Новый РеквизитФормы("ТаблицаТрудозатрат", Новый ОписаниеТипов("ТаблицаЗначений")));
	Реквизиты.Добавить(Новый РеквизитФормы("Квалификация", 
		Новый ОписаниеТипов("СправочникСсылка.торо_КвалификацииРемонтногоПерсонала"), "ТаблицаТрудозатрат"));
	Реквизиты.Добавить(Новый РеквизитФормы("Доступно", ТипЧисло, "ТаблицаТрудозатрат"));
	Реквизиты.Добавить(Новый РеквизитФормы("ДоступноИсходное", ТипЧисло, "ТаблицаТрудозатрат"));
	Реквизиты.Добавить(Новый РеквизитФормы("Требуется", ТипЧисло, "ТаблицаТрудозатрат"));
	
	Реквизиты.Добавить(Новый РеквизитФормы("ТрудовыеРесурсы_ПериодС", ТипДата, , , Истина)); 
	Реквизиты.Добавить(Новый РеквизитФормы("ТрудовыеРесурсы_ПериодПо", ТипДата, , , Истина)); 
	// гкс+ [2021] Куст 
	Реквизиты.Добавить(Новый РеквизитФормы("гкс_ТолькоХозспособ", Новый ОписаниеТипов("Булево"))); 
	Реквизиты.Добавить(Новый РеквизитФормы("гкс_ОтборПоРемонтам", Новый ОписаниеТипов("Булево"))); 
	Реквизиты.Добавить(
		Новый РеквизитФормы("гкс_ИзмененИсполнитель", Новый ОписаниеТипов("Булево"),"Объект.СвязанныеРемонты")); 
	// гкс- [2021] Куст 
	
	ИзменитьРеквизиты(Реквизиты);
	
	// ЭЛЕМЕНТЫ	
	// гкс_ДостпупностьТрудовыхРесурсов
	НовыйЭлемент = Элементы.Добавить("гкс_ДостпупностьТрудовыхРесурсов",
						Тип("ГруппаФормы"), Элементы["СтраницаСвязанныеРемонты"]);
	НовыйЭлемент.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НовыйЭлемент.ОтображатьЗаголовок = Ложь;  	
	Элементы["гкс_ДостпупностьТрудовыхРесурсов"].Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	// гкс_ДостпупностьТрудовыхРесурсовПериод
	НовыйЭлемент = Элементы.Добавить("гкс_ДостпупностьТрудовыхРесурсовПериод", 
						Тип("ГруппаФормы"), Элементы["гкс_ДостпупностьТрудовыхРесурсов"]);
	НовыйЭлемент.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НовыйЭлемент.ОтображатьЗаголовок = Ложь;  	
	Элементы["гкс_ДостпупностьТрудовыхРесурсовПериод"].Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	
	#Область ТаблицаТрудовыеРесурсы
	Элементы.СтраницаСвязанныеРемонты.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	
	ТаблицаТрудовыеРесурсы = Элементы.Добавить("ТаблицаТрудозатрат", 
											   Тип("ТаблицаФормы"), 
											   Элементы["гкс_ДостпупностьТрудовыхРесурсов"]);
	ТаблицаТрудовыеРесурсы.ПутьКДанным = "ТаблицаТрудозатрат";

	ТаблицаТрудовыеРесурсы.ИзменятьСоставСтрок = Ложь;
	ТаблицаТрудовыеРесурсы.ИзменятьПорядокСтрок = Ложь;
	ТаблицаТрудовыеРесурсы.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	ТаблицаТрудовыеРесурсы.УстановитьДействие("ПриАктивизацииСтроки", "ТаблицаТрудовыеРесурсыПриАктивизацииСтроки");
	
	НовыйЭлемент = Элементы.Добавить("КолонкаКвалификация", Тип("ПолеФормы"), ТаблицаТрудовыеРесурсы);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеНадписи;
	НовыйЭлемент.ПутьКДанным = "ТаблицаТрудозатрат.Квалификация";
	НовыйЭлемент.Заголовок = "Квалификация";

	НовыйЭлемент = Элементы.Добавить("КолонкаДоступно", Тип("ПолеФормы"), ТаблицаТрудовыеРесурсы);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным = "ТаблицаТрудозатрат.Доступно";
	// гкс+ [2021] Куст 
	НовыйЭлемент.Заголовок = "Доступно, мин";// гкс- [2021] 
	НовыйЭлемент.УстановитьДействие("ПриИзменении", "КолонкаДоступноПриИзменении");
	
	НовыйЭлемент = Элементы.Добавить("КолонкаДоступноИсходное", Тип("ПолеФормы"), ТаблицаТрудовыеРесурсы);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеНадписи;
	НовыйЭлемент.ПутьКДанным = "ТаблицаТрудозатрат.ДоступноИсходное";
	Элементы["КолонкаДоступноИсходное"].Видимость = Ложь;
	
	НовыйЭлемент = Элементы.Добавить("КолонкаТребуется", Тип("ПолеФормы"), ТаблицаТрудовыеРесурсы);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеНадписи;
	НовыйЭлемент.ПутьКДанным = "ТаблицаТрудозатрат.Требуется";
	// гкс+ [2021] Куст 
