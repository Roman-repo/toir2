&НаКлиенте
Функция ОтразитьТребуемыеРесурсыВТаблицеТрудозатрат(ИДРемонтов, 
													ДокументыИсточники, 
													ОбъектРемонта = "", 
													СообщитьОНехваткеРесурса = Ложь)
	КвалификацииСНедостаточнымРесурсов = "";
	ПлановыеТрудозатраты = ПолучитьПлановыеТрудозатраты(ИДРемонтов, ДокументыИсточники);	
	Для каждого ТекущаяСтрока Из ПлановыеТрудозатраты Цикл
		ПараметрыПоиска = Новый Структура("Квалификация", ТекущаяСтрока.Квалификация);
		ПоискСтрок = ЭтаФорма["ТаблицаТрудозатрат"].НайтиСтроки(ПараметрыПоиска);
		Если ПоискСтрок.Количество() > 0 Тогда
			ПоискСтрок[0].Требуется = ПоискСтрок[0].Требуется + ТекущаяСтрока.Требуется;
			Доступно = ПоискСтрок[0].Доступно;
		Иначе
			НоваяСтрока = ЭтаФорма["ТаблицаТрудозатрат"].Добавить();
			НоваяСтрока.Квалификация = ТекущаяСтрока.Квалификация;
			НоваяСтрока.Требуется = ТекущаяСтрока.Требуется;
			Доступно = 0;
		КонецЕсли; 
		Если СообщитьОНехваткеРесурса И 
			Доступно < ТекущаяСтрока.Требуется Тогда
			КвалификацииСНедостаточнымРесурсов = КвалификацииСНедостаточнымРесурсов 
												+ ТекущаяСтрока.Квалификация 
												+ ", доступно:" + Доступно 
												+ ", требуется:" + ТекущаяСтрока.Требуется + ";" + Символы.ПС;
		КонецЕсли; 			
	КонецЦикла;
	
	Если СообщитьОНехваткеРесурса И Не КвалификацииСНедостаточнымРесурсов = "" Тогда
		ТекстСообшения = нСтр("ru='Для выполнения ремонта недостаточно трудовых ресурсов: %1, %2'", "ru");
		ТекстСообшения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообшения,
															ОбъектРемонта,
															КвалификацииСНедостаточнымРесурсов);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообшения);
	КонецЕсли; 
	
КонецФункции 

