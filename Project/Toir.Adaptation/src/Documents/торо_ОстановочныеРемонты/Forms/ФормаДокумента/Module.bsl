&НаКлиенте
&ИзменениеИКонтроль("ДатаНачалаРемонтаПриИзменении")
Процедура гкс_ДатаНачалаРемонтаПриИзменении(Элемент)

	#Вставка
	// Гкс+[TOIR20-190] Селимов 
	ПриИзмененииДатРемонта(Истина, Ложь); 
	// Гкс+[TOIR20-188] Селимов 
	Этаформа["ТрудовыеРесурсы_ПериодС"] = Объект.ДатаНачалаРемонта;
	Этаформа["ТрудовыеРесурсы_ПериодПо"] = Объект.ДатаОкончанияРемонта;
	ЗаполнитьТрудовыеРесурсы(); 
	#КонецВставки 
	Если Объект.ДатаНачалаРемонта > Объект.ДатаОкончанияРемонта Тогда
		ТекстСообщения = НСтр("es='¡La fecha del comienzo de la reparación es más grande que la fecha de la terminación!';ru='Дата начала ремонта больше даты окончания!';en='Repair start date is greater than the end date!'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;

КонецПроцедуры

