// гкс+ [2021] Куст 
&НаСервере
Процедура гкс_ИзменитьИсполнителейВОснованиях(Отказ)
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	ТипЗаявка = Тип("ДокументСсылка.торо_ЗаявкаНаРемонт");
	ТипППР = Тип("ДокументСсылка.торо_ПланГрафикРемонта");
	ТипКонтрагент = Тип("СправочникСсылка.Контрагенты");
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЧ.Исполнитель КАК Исполнитель,
	               |	ТЧ.ДокументИсточник КАК ДокументИсточник,
	               |	ТЧ.ID КАК ИД
	               |ПОМЕСТИТЬ Исходные
	               |ИЗ
	               |	&ТЧ1 КАК ТЧ
	               |ГДЕ
	               |	ТЧ.гкс_ИзмененИсполнитель
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Исходные.ДокументИсточник КАК ДокументИсточник,
	               |	Исходные.Исполнитель КАК Исполнитель,
	               |	Исходные.ИД КАК ИД
	               |ИЗ
	               |	Исходные КАК Исходные
	               |ИТОГИ ПО
	               |	ДокументИсточник";
	Запрос.УстановитьПараметр("ТЧ1", Объект.СвязанныеРемонты.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДокумент = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	НачатьТранзакцию();
	Попытка
		Пока ВыборкаДокумент.Следующий() Цикл
			Если ТипЗнч(ВыборкаДокумент.ДокументИсточник) = ТипЗаявка Тогда 
				ДокОбъект = ВыборкаДокумент.ДокументИсточник.ПолучитьОбъект();
				НаборЗаписей = РегистрыСведений.торо_ЗаявкиПоРемонтам.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаДокумент.ДокументИсточник);
				НаборЗаписей.Прочитать();
				ЕстьИзменения = Ложь;
				Выборка = ВыборкаДокумент.Выбрать();
				Пока Выборка.Следующий() Цикл
					СтарыйИсполнитель = Неопределено;
					Для Каждого СтрокаТаблицы Из ДокОбъект.ИсполнителиПоРемонтам Цикл
						Если СтрокаТаблицы.РемонтыОборудования_ID = Выборка.ИД Тогда 
							Если Не СтрокаТаблицы.Исполнитель = Выборка.Исполнитель Тогда 
								СтарыйИсполнитель = СтрокаТаблицы.Исполнитель;
								СтрокаТаблицы.Исполнитель = Выборка.Исполнитель;
								ЕстьИзменения = Истина;
							КонецЕсли;
							Прервать;
						КонецЕсли;
					КонецЦикла;
					//
					Если ЗначениеЗаполнено(СтарыйИсполнитель) Тогда 
						Для Каждого СтрокаТаблицы Из ДокОбъект.РемонтныеРаботы Цикл
							Если СтрокаТаблицы.РемонтыОборудования_ID = Выборка.ИД Тогда 
								Если СтрокаТаблицы.Исполнитель = СтарыйИсполнитель Тогда 
									СтрокаТаблицы.Исполнитель = Выборка.Исполнитель;
								КонецЕсли;
								Прервать;
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;
					//
					Для Каждого СтрокаНабора Из НаборЗаписей Цикл
						Если СтрокаНабора.IDРемонта = Выборка.ИД Тогда 
							СтрокаНабора.Исполнитель = Выборка.Исполнитель;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
				Если ЕстьИзменения Тогда 
					ДокОбъект.БезусловнаяЗапись = Истина;
					ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
					//
					НаборЗаписей.Записать();
				КонецЕсли;
			ИначеЕсли ТипЗнч(ВыборкаДокумент.ДокументИсточник) = ТипППР Тогда 
				ДокОбъект = ВыборкаДокумент.ДокументИсточник.ПолучитьОбъект();
				НаборЗаписей = РегистрыСведений.торо_ПлановыеРемонтныеРаботы.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаДокумент.ДокументИсточник);
				НаборЗаписей.Прочитать();
				ЕстьИзменения = Ложь;
				Выборка = ВыборкаДокумент.Выбрать();
				Пока Выборка.Следующий() Цикл
					ЭтоКонтрагент = ТипКонтрагент = ТипЗнч(Выборка.Исполнитель);
					Для Каждого СтрокаТаблицы Из ДокОбъект.ПланРемонтов Цикл
						Если СтрокаТаблицы.ID = Выборка.ИД Тогда 
							Если Не СтрокаТаблицы.Исполнитель = Выборка.Исполнитель Тогда 
								СтрокаТаблицы.Исполнитель = Выборка.Исполнитель;
								ЕстьИзменения = Истина;
								Если ЭтоКонтрагент Тогда 
									СтрокаТаблицы.СпособВыполнения = Перечисления.СпособыСтроительства.Подрядный;
								Иначе
									СтрокаТаблицы.СпособВыполнения = Перечисления.СпособыСтроительства.Хозспособ;
								КонецЕсли;
							КонецЕсли;
							Прервать;
						КонецЕсли;
						//
						Для Каждого СтрокаНабора Из НаборЗаписей Цикл
							Если СтрокаНабора.ID = Выборка.ИД Тогда 
								СтрокаНабора.Исполнитель = Выборка.Исполнитель;
								Прервать;
								Если ЭтоКонтрагент Тогда 
									СтрокаНабора.СпособВыполнения = Перечисления.СпособыСтроительства.Подрядный;
								Иначе
									СтрокаНабора.СпособВыполнения = Перечисления.СпособыСтроительства.Хозспособ;
								КонецЕсли;
							КонецЕсли;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
				Если ЕстьИзменения Тогда 
					ДокОбъект.БезусловнаяЗапись = Истина;
					ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
				//
					НаборЗаписей.Записать();
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрокаРемонта Из Объект.СвязанныеРемонты Цикл
			СтрокаРемонта["гкс_ИзмененИсполнитель"] = Ложь;
		КонецЦикла;
	Исключение
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = ОписаниеОшибки();
		Сообщение.Сообщить();
		Отказ = Истина;
		ОтменитьТранзакцию();
		Возврат;
	КонецПопытки;
	Если Отказ Тогда 
		ОтменитьТранзакцию();
		Возврат;
	КонецЕсли;
	ЗафиксироватьТранзакцию();
КонецПроцедуры

// гкс+ [2021] Куст 
&НаКлиенте
Процедура гкс_СвязанныеРемонтыИсполнительПриИзмененииПосле(Элемент)
	ТекДанные = Элементы.СвязанныеРемонты.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекДанные["гкс_ИзмененИсполнитель"] = Истина;
	КонецЕсли;
