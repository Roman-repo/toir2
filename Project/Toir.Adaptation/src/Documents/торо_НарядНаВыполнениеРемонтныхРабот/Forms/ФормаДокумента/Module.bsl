&НаСервереБезКонтекста
Функция ПолучитьТекстМероприятия(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Спр.Описание КАК Описание
		|ИЗ
		|	Справочник.гкс_МероприятияПоОбеспечениюБезопасности КАК Спр
		|ГДЕ
		|	Спр.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Описание;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

