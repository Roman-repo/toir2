&НаСервере
Процедура МодифицироватьИсполнителей()
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТруТЧ.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	ТруТЧ.ID КАК ID,
		|	ТруТЧ.Сотрудник КАК Сотрудник,
		|	ТруТЧ.Квалификация КАК Квалификация,
		|	ТруТЧ.гкс_СотрудникКонтрагента КАК гкс_СотрудникКонтрагента,
		|	ВЫБОР
		|		КОГДА ТруТЧ.гкс_Количество < 1
		|			ТОГДА 1
		|		ИНАЧЕ ТруТЧ.гкс_Количество
		|	КОНЕЦ КАК гкс_Количество,
		|	ТруТЧ.гкс_ВремяРаботы КАК гкс_ВремяРаботы
		|ПОМЕСТИТЬ ИсхТру
		|ИЗ
		|	&ТЧ1 КАК ТруТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РемТЧ.ДатаНачала КАК ДатаНачала,
		|	РемТЧ.ДатаОкончания КАК ДатаОкончания,
		|	РемТЧ.ID КАК ID
		|ПОМЕСТИТЬ ИсхРем
		|ИЗ
		|	&ТЧ2 КАК РемТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсхТру.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	ИсхТру.ID КАК ID,
		|	ИсхТру.Сотрудник КАК Сотрудник,
		|	ИсхТру.Квалификация КАК Квалификация,
		|	ИсхТру.гкс_Количество КАК гкс_Количество,
		|	ИсхТру.гкс_СотрудникКонтрагента КАК гкс_СотрудникКонтрагента,
		|	ИсхТру.гкс_ВремяРаботы КАК гкс_ВремяРаботы,
		|	ИсхРем.ДатаНачала КАК ДатаНачала,
		|	ИсхРем.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	ИсхТру КАК ИсхТру
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсхРем КАК ИсхРем
		|		ПО ИсхТру.РемонтыОборудования_ID = ИсхРем.ID
		|ИТОГИ ПО
		|	РемонтыОборудования_ID
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсхТру.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	ИсхТру.ID КАК ID,
		|	ИсхТру.Квалификация КАК Квалификация,
		|	ИсхТру.гкс_СотрудникКонтрагента КАК гкс_СотрудникКонтрагента,
		|	СУММА(ИсхТру.гкс_Количество) КАК гкс_Количество,
		|	МАКСИМУМ(ИсхТру.гкс_ВремяРаботы) КАК гкс_ВремяРаботы,
		|	ИсхРем.ДатаНачала КАК ДатаНачала,
		|	ИсхРем.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	ИсхТру КАК ИсхТру
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсхРем КАК ИсхРем
		|		ПО ИсхТру.РемонтыОборудования_ID = ИсхРем.ID
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсхТру.РемонтыОборудования_ID,
		|	ИсхТру.ID,
		|	ИсхТру.гкс_СотрудникКонтрагента,
		|	ИсхТру.Квалификация,
		|	ИсхРем.ДатаНачала,
		|	ИсхРем.ДатаОкончания
		|ИТОГИ ПО
		|	РемонтыОборудования_ID";
	
	Запрос.УстановитьПараметр("ТЧ1", Объект.Исполнители.Выгрузить());
	Запрос.УстановитьПараметр("ТЧ2", Объект.РемонтыОборудования.Выгрузить());
	
	ПакетОдин = 2;
	ПакетДва = ПакетОдин + 1;
	РезультатЗапроса = Запрос.ВыполнитьПакет();		
	Выборка1 = РезультатЗапроса[ПакетОдин].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Выборка2 = РезультатЗапроса[ПакетДва].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Объект.Исполнители.Очистить();
	Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
		ТипИсполнителей = 1;
		Для Каждого СтрИсп Из Объект.ИсполнителиПоРемонтам Цикл
			Если СтрИсп.РемонтыОборудования_ID = СтрокаТаблицы.ID Тогда
				Если ТипЗнч(Объект.ИсполнителиПоРемонтам[0].Исполнитель) = Тип("СправочникСсылка.Контрагенты") Тогда 
					ТипИсполнителей = 2;
				КонецЕсли;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ТипИсполнителей = 1 Тогда 
			Выборка1.Сбросить();
			Если Выборка1.НайтиСледующий(Новый Структура("РемонтыОборудования_ID",СтрокаТаблицы.ID)) Тогда 
				Выборка = Выборка1.Выбрать();
				Пока Выборка.Следующий() Цикл
					НужноКолво = Макс(1, Выборка.гкс_Количество);
					Сч = 0;
					Пока Сч < НужноКолво Цикл
						НоваяСтрока = Объект.Исполнители.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
						НоваяСтрока.гкс_Количество = 1;
						НоваяСтрока.гкс_ВремяРаботыТекст = Расш_гкс_СформироватьПродолжительность(НоваяСтрока.гкс_ВремяРаботы);
						Сч = Сч + 1;
					КонецЦикла;
				КонецЦикла;
			КонецЕсли;
		Иначе
			Если Выборка2.НайтиСледующий(Новый Структура("РемонтыОборудования_ID",СтрокаТаблицы.ID)) Тогда 
				Выборка = Выборка2.Выбрать();
				Пока Выборка.Следующий() Цикл
					НоваяСтрока = Объект.Исполнители.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
					НоваяСтрока.гкс_ВремяРаботыТекст = Расш_гкс_СформироватьПродолжительность(НоваяСтрока.гкс_ВремяРаботы);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	//
	ОбновитьОтображениеИсполнителей();
КонецПроцедуры

&НаКлиенте 
Процедура ЗадатьВопросПередИзменениемИсполнителяПослеВопроса(Результат, ДопПараметры)Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда 
		Если ДопПараметры.Свойство("Удаление") Тогда 
			Отказ = ложь;
			ИсполнителиПоРемонтамПередУдалением(Элементы.ИсполнителиПоРемонтам, Отказ);
			Если НЕ Отказ Тогда 
				Объект.ИсполнителиПоРемонтам.Удалить(0);
			КонецЕсли;
		КонецЕсли;
		МодифицироватьИсполнителей();
	Иначе
		Если ДопПараметры.Свойство("Удаление") = Ложь Тогда 
			Объект.ИсполнителиПоРемонтам[0].Исполнитель = ЭтотОбъект["гкс_ИсполнительДо"];
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_ИсполнителиПоРемонтамПередНачаломИзмененияПосле(Элемент, Отказ)
	Если Объект.ИсполнителиПоРемонтам.Количество() Тогда 
		ЭтотОбъект["гкс_ИсполнительДо"] = Объект.ИсполнителиПоРемонтам[0].Исполнитель;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_ИсполнителиПоРемонтамПередУдалениемПеред(Элемент, Отказ)
	ТекДанные = Элементы.ИсполнителиПоРемонтам.ТекущиеДанные;
	Если Не ТекДанные = Неопределено И ТекДанные.Исполнитель = Объект.ИсполнителиПоРемонтам[0].Исполнитель Тогда 
		ТекТип = ТипЗнч(Объект.ИсполнителиПоРемонтам[0].Исполнитель);
		Если Объект.ИсполнителиПоРемонтам.Количество() > 1 Тогда 
			Если ТекТип = ТипЗнч(Объект.ИсполнителиПоРемонтам[1].Исполнитель) Тогда 
				Возврат;
			КонецЕсли;
		ИначеЕсли ТекТип = Тип("СправочникСсылка.СтруктураПредприятия") Тогда 
			Возврат
		КонецЕсли;
		Если ТекТип = Тип("СправочникСсылка.СтруктураПредприятия") Тогда 
			Отказ = Истина;
			СтруктураОпОп = Новый Структура("Удаление", Истина);
			ЗадатьВопросПередИзменениемИсполнителя(СтруктураОпОп);
		Иначе
			ИсполнителиПоРемонтамПередУдалением(Элементы.ИсполнителиПоРемонтам, Отказ);
			Если НЕ Отказ Тогда 
				Объект.ИсполнителиПоРемонтам.Удалить(0);
			КонецЕсли;
			МодифицироватьИсполнителей();
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_ИсполнителиПоРемонтамИсполнительПриИзмененииПосле(Элемент)
	ТекДанные = Элементы.ИсполнителиПоРемонтам.ТекущиеДанные;
	Если Не ТекДанные = Неопределено И ЗначениеЗаполнено(ТекДанные.Исполнитель) И ТекДанные.Исполнитель = Объект.ИсполнителиПоРемонтам[0].Исполнитель Тогда 
		ТекТип = ТипЗнч(Объект.ИсполнителиПоРемонтам[0].Исполнитель);
		Если ТекТип = ТипЗнч(ЭтотОбъект["гкс_ИсполнительДо"]) Тогда 
			Возврат
		КонецЕсли;
		Если ТекТип = Тип("СправочникСсылка.Контрагенты") Тогда 
			СтруктураОпОп = Новый Структура();
			ЗадатьВопросПередИзменениемИсполнителя(СтруктураОпОп);
		Иначе
			МодифицироватьИсполнителей();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботОбработкаВыбора")
Процедура гкс_ДеревоРемонтныхРаботОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	ТекСтрокаДерева = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

	Если ТекСтрокаДерева = Неопределено Тогда
		СтрокаРодитель = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID", "", "", "");
		ИДВыбраннойСтроки = "";
	Иначе
		СтрокаРодитель = ТекСтрокаДерева;
		ИДВыбраннойСтроки = ТекСтрокаДерева.ID;
	КонецЕсли;


	ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;

	Если ТекРемонт <> Неопределено Тогда
		РемонтыОборудования_ID = ТекРемонт.ID;
	Иначе
		РемонтыОборудования_ID = "";
	КонецЕсли;

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") И ВыбранноеЗначение.Количество()>0 И ТипЗнч(ВыбранноеЗначение[0]) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда
		#Вставка
		// гкс+ [Подбор ТехКарт] Куст 14.10.2020
		Массивпроверки = Новый Массив();
		Массивпроверки.Добавить(ВыбранноеЗначение[0]);
		Если ПроверитьТКНаСервере(Массивпроверки).Количество() Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru='Запрещено выбирать шаблоны техкарт';
			|en='It is forbidden to choose patterns standard maintenance plans'");
			Сообщение.Сообщить();
			СтандартнаяОбработка = Ложь;
			Возврат;
		КонецЕсли;
		// гкс- [Подбор ТехКарт] Куст 14.10.2020
		#КонецВставки
		ТекущийРемонт = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		Пока ТекущийРемонт <> Неопределено И ТипЗнч(ТекущийРемонт.РемонтнаяРабота) <> Тип("Строка") Цикл
			Если ТекущийРемонт.РемонтнаяРабота = ВыбранноеЗначение[0] Тогда
				ШаблонСообщения = НСтр("es='El significado escogido ""%1"" no puede ser incluido en la composición.';ru='Выбранное значение ""%1"" не может быть включено в состав самого себя.';en='The selected value ""%1"" cannot be included in itself.'");
				ТекстСообщения = СтрШаблон(ШаблонСообщения, ВыбранноеЗначение[0]);
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				Возврат;
			КонецЕсли; 
			ТекущийРемонт = ТекущийРемонт.ПолучитьРодителя();	
		КонецЦикла; 
	КонецЕсли;

	Если  ТекРемонт <> Неопределено Тогда
		ТекущиеДанные = Новый Структура("ТекущийРемонт_ID, СтрокаРодитель_ID, СтрокаРодительРемонтыОборудования_ID, СтрокаРодительРодитель_ID, ДатаНачалаРемонта", РемонтыОборудования_ID, СтрокаРодитель.ID, СтрокаРодитель.РемонтыОборудования_ID, СтрокаРодитель.Родитель_ID, ТекРемонт.ДатаНачала);
	Иначе
		ТекущиеДанные = Новый Структура("ТекущийРемонт_ID, СтрокаРодитель_ID, СтрокаРодительРемонтыОборудования_ID, СтрокаРодительРодитель_ID, ДатаНачалаРемонта", РемонтыОборудования_ID, СтрокаРодитель.ID, СтрокаРодитель.РемонтыОборудования_ID, СтрокаРодитель.Родитель_ID, Дата(1,1,1,0,0,0));
	КонецЕсли; 

	СтруктураПараметры = Новый Структура;

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда
		МассивСтруктурВозврата = ДеревоРемонтныхРаботОбработкаВыбораНаСервереДляМассива(ВыбранноеЗначение, ТекущиеДанные, СтруктураПараметры);
		Если ФОИспользоватьОстановочные Тогда
			ОбновитьОстановочные();
		КонецЕсли;
	Иначе
		СтруктураВозврата = ДеревоРемонтныхРаботОбработкаВыбораНаСервере(ВыбранноеЗначение, ТекущиеДанные, СтруктураПараметры);
		МассивСтруктурВозврата = Новый Массив;
		МассивСтруктурВозврата.Добавить(СтруктураВозврата);
		Если ФОИспользоватьОстановочные Тогда
			ОбновитьОстановочные();
		КонецЕсли; 
	КонецЕсли;

	Для Каждого ЭлементМассива Из МассивСтруктурВозврата Цикл
		Если ТипЗнч(ЭлементМассива) = Тип("Строка") Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(ЭлементМассива);
		КонецЕсли;
	КонецЦикла;	

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		Массивстрок = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ВыбранноеЗначение.СтрокаРемонтовОборудования.ID));
		Если МассивСтрок.Количество() Тогда
			Идентиф = МассивСтрок[0].ПолучитьИдентификатор();
			Элементы.РемонтыОборудования.ТекущаяСтрока = Идентиф;
		КонецЕсли;
	КонецЕсли;
	ОбновитьЗависимыеЛоты();
	Модифицированность = Истина;

	Если Элементы.РемонтыОборудования.ТекущаяСтрока = Неопределено Тогда
		Если Объект.РемонтыОборудования.Количество() > 0 Тогда
			Элементы.РемонтыОборудования.ТекущаяСтрока = Объект.РемонтыОборудования[0].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;

	РемонтыОборудованияПриАктивизацииСтроки(Элементы.РемонтыОборудования); 

КонецПроцедуры

