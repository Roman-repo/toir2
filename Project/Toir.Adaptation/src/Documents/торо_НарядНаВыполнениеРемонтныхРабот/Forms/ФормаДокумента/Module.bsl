&НаСервере
Процедура гкс_ДобавитьГруппуКомандПечатиБАТ()
	// гкс+ [Релиз16] Деснол
	Попытка
		ГруппаПечать = Элементы.ПодменюПечатьОбычное;
	Исключение
		ГруппаПечать = Элементы.ФормаПечать;
	КонецПопытки;
	НоваяГруппа = Элементы.Добавить("гкс_БАТПечать", Тип("ГруппаФормы"), ГруппаПечать);
	НоваяГруппа.Вид = ВидГруппыФормы.Подменю;
	НоваяГруппа.Заголовок = "БАТ";
	//
	Для Каждого ЭлементСписка ИЗ ГруппаПечать.ПодчиненныеЭлементы Цикл
	// гкс- [Релиз16]
		Если Не СтрНайти(ЭлементСписка.Имя, "БАТ") = 0 Тогда 
			Элементы.Переместить(ЭлементСписка, НоваяГруппа);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

