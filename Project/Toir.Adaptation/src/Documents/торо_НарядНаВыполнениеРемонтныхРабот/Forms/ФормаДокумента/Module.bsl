&НаСервере
&ИзменениеИКонтроль("ОтредактироватьУсловноеОформление")
Процедура Расш_гкс_ОтредактироватьУсловноеОформление(ИдСтроки, ИДРемонта)

	ЭлементОформления1 = Неопределено;
	ЭлементОформления2 = Неопределено;
	Для каждого ТекУо из УсловноеОформление.Элементы Цикл
		Если ТекУо.Представление = "ВидимостьИсполнителей1" Тогда
			ЭлементОформления1 = ТекУо;
			#Вставка
			НовоеПолеЭлементаУсловногоОформления = ЭлементОформления1.Поля.Элементы.Добавить(); 
			НовоеПолеЭлементаУсловногоОформления.Поле = Новый ПолеКомпоновкиДанных("Исполнителигкс_ВремяРаботыТекст");
			НовоеПолеЭлементаУсловногоОформления.Использование = Истина;
			НовоеПолеЭлементаУсловногоОформления = ЭлементОформления1.Поля.Элементы.Добавить(); 
			НовоеПолеЭлементаУсловногоОформления.Поле = Новый ПолеКомпоновкиДанных("гкс_СотрудникКонтрагента");
			НовоеПолеЭлементаУсловногоОформления.Использование = Истина;
			#КонецВставки
		КонецЕсли;

		Если ТекУо.Представление = "ВидимостьИсполнителей2" Тогда
			ЭлементОформления2 = ТекУо;
			#Вставка
			НовоеПолеЭлементаУсловногоОформления = ЭлементОформления2.Поля.Элементы.Добавить();
			НовоеПолеЭлементаУсловногоОформления.Поле = Новый ПолеКомпоновкиДанных("Исполнителигкс_ВремяРаботыТекст");
			НовоеПолеЭлементаУсловногоОформления.Использование = Истина;
			НовоеПолеЭлементаУсловногоОформления = ЭлементОформления2.Поля.Элементы.Добавить(); 
			НовоеПолеЭлементаУсловногоОформления.Поле = Новый ПолеКомпоновкиДанных("гкс_СотрудникКонтрагента");
			НовоеПолеЭлементаУсловногоОформления.Использование = Истина;
			#КонецВставки
		КонецЕсли;

	КонецЦикла;

	ТекСтрокаДереваРемонтов = ДеревоРемонтныхРабот.НайтиПоИдентификатору(ИдСтроки);

	масСтрок = Новый Массив;
	торо_РаботаССогласованиямиКлиентСервер.ЗаполнитьМассивИзДерева(масСтрок, ТекСтрокаДереваРемонтов.ПолучитьЭлементы());

	сзИД = Новый СписокЗначений;
	Для каждого текСтрока из масСтрок Цикл
		сзИД.Добавить(текСтрока.ID);
	КонецЦикла;
	сзИД.Добавить(ТекСтрокаДереваРемонтов.ID);

	Если ЭлементОформления1 <> Неопределено Тогда
		ЭлементОформления1.Использование = Истина;
		ЭлементОформления1.Отбор.Элементы[0].ПравоеЗначение = сзИД;
	КонецЕсли;

	Если ЭлементОформления2 <> Неопределено Тогда
		ЭлементОформления2.Использование = ЗначениеЗаполнено(ИДРемонта);
		ЭлементОформления2.Отбор.Элементы[0].ПравоеЗначение = ИДРемонта;
	КонецЕсли;

	Если ЗначениеЗаполнено(ТекСтрокаДереваРемонтов.ID) И ЗначениеЗаполнено(ИДРемонта) Тогда 
		МассивСтрок = Объект.Исполнители.НайтиСтроки(Новый Структура("ID, РемонтыОборудования_ID", ТекСтрокаДереваРемонтов.ID, ИДРемонта));
		Если МассивСтрок.Количество() > 0 Тогда 
			Элементы.Исполнители.ТекущаяСтрока = МассивСтрок[0].ПолучитьИдентификатор();
		КонецЕсли; 
	ИначеЕсли ЗначениеЗаполнено(ИДРемонта) Тогда  
		МассивСтрок = Объект.Исполнители.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИДРемонта));
		Если МассивСтрок.Количество() > 0 Тогда 
			Элементы.Исполнители.ТекущаяСтрока = МассивСтрок[0].ПолучитьИдентификатор();
		КонецЕсли; 
	КонецЕсли;
	#Вставка
	// гкс+ [КатегорияРиска] Куст 19.10.2020
	гкс_ОбщегоНазначенияСервер.ДобавитьУОКатегорииРиска(ЭтаФорма);
	// гкс- [КатегорияРиска] Куст 19.10.2020
	// гкс+ [Релиз 1] Куст 22.04.2021
	гкс_ОбщегоНазначенияСервер.гкс_ДобавитьУсловноеОформлениеДереваРР(ЭтаФорма);
	// гкс- [Релиз 1] Куст 22.04.2021
	#КонецВставки

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("УстановкаИсполнителей")
Процедура Расш_гкс_УстановкаИсполнителей(ВыбранноеЗначение)
