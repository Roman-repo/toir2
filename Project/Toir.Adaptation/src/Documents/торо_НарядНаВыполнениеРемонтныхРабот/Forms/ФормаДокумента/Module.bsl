&НаСервере
Процедура гкс_УдалитьИсполнителейНаСервере(Результат)
	Для Каждого СтрокаРемонта Из Результат Цикл
		МассУдаления = Новый Массив();
		Для Каждого СтрокаТЧ Из Объект.ИсполнителиПоРемонтам Цикл
			Если СтрокаТЧ.РемонтыОборудования_ID = СтрокаРемонта.ИД_Ремонта
				И Не СтрокаТЧ.Исполнитель = СтрокаРемонта.Исполнитель Тогда
				МассУдаления.Добавить(СтрокаТЧ);
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрУдаления Из МассУдаления Цикл
			Объект.ИсполнителиПоРемонтам.Удалить(СтрУдаления);
		КонецЦикла;
		//
		ИДУдаления = Новый Массив();
		МассУдаления = Новый Массив();
		Для Каждого СтрокаТЧ Из Объект.РемонтныеРаботы Цикл
			Если СтрокаТЧ.РемонтыОборудования_ID = СтрокаРемонта.ИД_Ремонта
				И Не СтрокаТЧ.Исполнитель = СтрокаРемонта.Исполнитель
				И ЗначениеЗаполнено(СтрокаТЧ.Исполнитель)
				И ТипЗнч(СтрокаТЧ.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации")
				Тогда
				МассУдаления.Добавить(СтрокаТЧ);
				ИДУдаления.Добавить(СтрокаТЧ.ID);
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрокаТЧ Из Объект.РемонтныеРаботы Цикл
			Если СтрокаТЧ.РемонтыОборудования_ID = СтрокаРемонта.ИД_Ремонта
				И Не СтрокаТЧ.Исполнитель = СтрокаРемонта.Исполнитель
				И ТипЗнч(СтрокаТЧ.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт")
				Тогда
				НеУдаляем = Ложь;
				Для Каждого СтрокаТО Из Объект.РемонтныеРаботы Цикл
					Если СтрокаТО.Родитель_ID = СтрокаТЧ.ID 
						И СтрокаТО.РемонтыОборудования_ID = СтрокаРемонта.ИД_Ремонта
						И МассУдаления.Найти(СтрокаТО) = Неопределено Тогда 
						НеУдаляем = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Если Не НеУдаляем Тогда 
					МассУдаления.Добавить(СтрокаТЧ);
					ИДУдаления.Добавить(СтрокаТЧ.ID);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрУдаления Из МассУдаления Цикл
			Объект.РемонтныеРаботы.Удалить(СтрУдаления);
		КонецЦикла;
		//
		МассУдаления = Новый Массив();
		Для Каждого СтрокаТЧ Из Объект.Исполнители Цикл
			Если СтрокаТЧ.РемонтыОборудования_ID = СтрокаРемонта.ИД_Ремонта
				И Не ИДУдаления.Найти(СтрокаТЧ.ID) = Неопределено Тогда
				МассУдаления.Добавить(СтрокаТЧ);
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрУдаления Из МассУдаления Цикл
			Объект.Исполнители.Удалить(СтрУдаления);
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура гкс_УдалитьИспользованныеТО()
	ИДРемонта = Новый Массив();
	Для Каждого СтрокаТаблицы ИЗ Объект.РемонтыОборудования Цикл
		ИДРемонта.Добавить(СтрокаТаблицы.ID);
	КонецЦикла;
	//
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_НарядНаВыполнениеРемонтныхРаботРемонтныеРаботы.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	торо_НарядНаВыполнениеРемонтныхРаботРемонтныеРаботы.ID КАК ID,
		|	торо_НарядНаВыполнениеРемонтныхРаботРемонтныеРаботы.Родитель_ID КАК Родитель_ID,
		|	торо_НарядНаВыполнениеРемонтныхРаботРемонтныеРаботы.РемонтнаяРабота КАК РемонтнаяРабота
		|ИЗ
		|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтныеРаботы КАК торо_НарядНаВыполнениеРемонтныхРаботРемонтныеРаботы
		|ГДЕ
		|	торо_НарядНаВыполнениеРемонтныхРаботРемонтныеРаботы.РемонтыОборудования_ID В (&ИДРемонта)
		|	И торо_НарядНаВыполнениеРемонтныхРаботРемонтныеРаботы.Ссылка.Проведен = Истина
		|ИТОГИ ПО
		|	РемонтыОборудования_ID";
	
	Запрос.УстановитьПараметр("ИДРемонта", ИДРемонта);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаРемонт = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаРемонт.Следующий() Цикл
		ИДУдаления = Новый Массив();
		МассУдаления = Новый Массив();
		Выборка = ВыборкаРемонт.Выбрать();
		Для Каждого СтрокаТаблицы Из Объект.РемонтныеРаботы Цикл
			Если СтрокаТаблицы.РемонтыОборудования_ID = ВыборкаРемонт.РемонтыОборудования_ID 
				И ТипЗнч(СтрокаТаблицы.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации")
				Тогда 
				Выборка.Сбросить();
				Если Выборка.НайтиСледующий(Новый Структура("Родитель_ID,ID,РемонтнаяРабота", 
					СтрокаТаблицы.Родитель_ID, СтрокаТаблицы.ID, СтрокаТаблицы.РемонтнаяРабота)) Тогда 
					МассУдаления.Добавить(СтрокаТаблицы);
					ИДУдаления.Добавить(СтрокаТаблицы.ID);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрокаТЧ Из Объект.РемонтныеРаботы Цикл
			Если СтрокаТЧ.РемонтыОборудования_ID = ВыборкаРемонт.РемонтыОборудования_ID
				И ТипЗнч(СтрокаТЧ.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт")
				Тогда
				НеУдаляем = Ложь;
				Для Каждого СтрокаТО Из Объект.РемонтныеРаботы Цикл
					Если СтрокаТО.Родитель_ID = СтрокаТЧ.ID 
						И СтрокаТО.РемонтыОборудования_ID = ВыборкаРемонт.РемонтыОборудования_ID
						И МассУдаления.Найти(СтрокаТО) = Неопределено Тогда 
						НеУдаляем = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Если Не НеУдаляем Тогда 
					МассУдаления.Добавить(СтрокаТЧ);
					ИДУдаления.Добавить(СтрокаТЧ.ID);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого СтрУдаления Из МассУдаления Цикл
			Объект.РемонтныеРаботы.Удалить(СтрУдаления);
		КонецЦикла;
		//
		МассУдаления = Новый Массив();
		Для Каждого СтрокаТЧ Из Объект.Исполнители Цикл
			Если СтрокаТЧ.РемонтыОборудования_ID = ВыборкаРемонт.РемонтыОборудования_ID
				И Не ИДУдаления.Найти(СтрокаТЧ.ID) = Неопределено Тогда
				МассУдаления.Добавить(СтрокаТЧ);
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрУдаления Из МассУдаления Цикл
			Объект.Исполнители.Удалить(СтрУдаления);
		КонецЦикла;
	КонецЦикла;
	
