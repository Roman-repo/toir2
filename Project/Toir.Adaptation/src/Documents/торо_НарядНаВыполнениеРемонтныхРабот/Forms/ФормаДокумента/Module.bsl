&НаКлиенте
Процедура гкс_ВыбратьИсполнителя()
	МассРемонты = Новый Массив();
	МассИсполнители = Новый Массив();
	Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
		ВременныйМассив = Новый Массив();
		Для Каждого СтрокаИсполнитель Из Объект.ИсполнителиПоРемонтам Цикл
			Если СтрокаИсполнитель.РемонтыОборудования_ID = СтрокаТаблицы.ID Тогда
				ВременныйМассив.Добавить(Новый Структура("ИД_Ремонта,Исполнитель",
				СтрокаИсполнитель.РемонтыОборудования_ID, СтрокаИсполнитель.Исполнитель));
			КонецЕсли;
		КонецЦикла;
		Если ВременныйМассив.Количество() > 1 Тогда
			Для Каждого СтрокаМассива Из ВременныйМассив Цикл
				МассИсполнители.Добавить(СтрокаМассива);
			КонецЦикла;
			МассРемонты.Добавить(Новый Структура("ИД_Ремонта,ОР,ВР",
			СтрокаТаблицы.ID, СтрокаТаблицы.ОбъектРемонта, СтрокаТаблицы.ВидРемонтныхРабот));
		КонецЕсли;
	КонецЦикла;
	Если МассРемонты.Количество() Тогда 
		ОписаниеОповещенияПослеВыбора = Новый ОписаниеОповещения("гкс_ПослеВыбораИсполнителяОбработать",
			ЭтотОбъект, МассРемонты);
		ОткрытьФорму("Документ.торо_НарядНаВыполнениеРемонтныхРабот.Форма.гкс_ФормаВыбораИсполнителя",
			Новый Структура("Ремонты,Исполнители", МассРемонты, МассИсполнители), ЭтотОбъект, , , , 
			ОписаниеОповещенияПослеВыбора,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура  гкс_ПослеВыбораИсполнителяОбработать(Результат, ДопПараметры)Экспорт
	Если Результат = Неопределено Тогда 
		МассивТЧ = Новый Массив();
		МассивТЧ.Добавить("РемонтныеРаботы");
		МассивТЧ.Добавить("ИсполнителиПоРемонтам");
		МассивТЧ.Добавить("Исполнители");
		Для Каждого СтрокаРемонта Из ДопПараметры Цикл
			Для Каждого ИмяТЧ Из МассивТЧ Цикл
				МассУдаления = Новый Массив();
				Для Каждого СтрокаТЧ Из Объект[ИмяТЧ] Цикл
					Если СтрокаТЧ.РемонтыОборудования_ID = СтрокаРемонта.ИД_Ремонта Тогда
						МассУдаления.Добавить(СтрокаТЧ);
					КонецЕсли;
				КонецЦикла;
				Для Каждого СтрУдаления Из МассУдаления Цикл
					Объект[ИмяТЧ].Удалить(СтрУдаления);
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		МассУдаления = Новый Массив();
		Для Каждого СтрокаТЧ Из Объект.РемонтыОборудования Цикл
			Если СтрокаТЧ.ID = СтрокаРемонта.ИД_Ремонта Тогда
				МассУдаления.Добавить(СтрокаТЧ);
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрУдаления Из МассУдаления Цикл
			Объект.РемонтыОборудования.Удалить(СтрУдаления);
		КонецЦикла;
	Иначе
		гкс_УдалитьИсполнителейНаСервере(Результат);
	КонецЕсли;
	РемонтыОборудованияПриАктивизацииСтроки(Неопределено);
	гкс_ИсполнителиПоРемонтамИсполнительПриИзмененииПосле(Неопределено);
КонецПроцедуры
