&НаКлиенте
Процедура дс_ОтправитьНаСогласование(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Параметры1 = Новый Структура("дс_Выполнить", Истина);
		Параметры2 = Новый Структура();
		
		гкс_ОбщегоНазначенияСервер.ОтправитьНаСогласованиеНаСервере(Параметры1, Параметры2);
		Если Параметры1.дс_Выполнить Тогда 
			Параметры2.Вставить("Форма", ЭтаФорма);
			торо_РаботаССогласованиямиКлиент.ВыбратьСтатусЗавершение(Параметры1, Параметры2);
			дс_ИзменитьВидимостьКнопкиОтправкиНаСогласование();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДобавитьТехКарту")
Процедура Расш_гкс_ДобавитьТехКарту(Команда)

	ТекущиеДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("es='¡Indiquen la disposición de la reparación!';ru='Укажите расположение ремонта!';en='Specify  the location of the repair!'"), 10); 
		Возврат;
	КонецЕсли;

	Если ТипЗнч(ТекущиеДанные.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("es='¡La reparación no es posible incluir en la composición de la operación tecnológica!';ru='Ремонт нельзя включать в состав технологической операции!';en='Repair can not be included in the technological operation!'"), 10); 
		Возврат;
	КонецЕсли;

	#Удаление
	ФормаВыбора = ПолучитьФорму("Справочник.торо_ИдентификаторыТехКарт.ФормаВыбора", Новый Структура("ОтборПоСтатусам, МножественныйВыбор", ПредопределенноеЗначение("Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Действует"), Истина), Элементы.ДеревоРемонтныхРабот);
	#КонецУдаления
	#Вставка
	ПараметрыФормы = Новый Структура("ОтборПоСтатусам, МножественныйВыбор",
		ПредопределенноеЗначение("Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Действует"), Истина);
	ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;
	Если Не ТекРемонт = Неопределено Тогда 
		ПараметрыФормы.Вставить("ОтборПоТОРИзОР", ТекРемонт.ОбъектРемонта);
	КонецЕсли;
	ФормаВыбора = ПолучитьФорму("Справочник.торо_ИдентификаторыТехКарт.ФормаВыбора", ПараметрыФормы,
		Элементы.ДеревоРемонтныхРабот);
	#КонецВставки
	ФормаВыбора.Открыть();

КонецПроцедуры

&НаКлиенте
Процедура гкс_УстановитьПКоэф(Команда)
	ТекДанные = Элементы.РемонтыОборудования.ТекущиеДанные;
	Если не ТекДанные = Неопределено Тогда 
		МассивПередачи = Новый Массив();
		Для Каждого СтрокаТаблицы Из Объект.РемонтныеРаботы Цикл
			Если ТекДанные.ID = СтрокаТаблицы.РемонтыОборудования_ID Тогда 
				МассивПередачи.Добавить(Новый Структура("ИД,гкс_ПовКоэф,РемонтнаяРабота"
					, СтрокаТаблицы.ID, СтрокаТаблицы.гкс_ПовКоэф, СтрокаТаблицы.РемонтнаяРабота));
			КонецЕсли;
		КонецЦикла;
		ОписаниеОп = Новый ОписаниеОповещения("гкс_УстановитьПКоэфОбработкаВыбора",
			ЭтотОбъект, Новый Структура("ИдРемонта", ТекДанные.ID) );
			ОткрытьФорму("Справочник.гкс_ПКоэффициентыРабот.Форма.ПодборПКоэфВСписок", Новый Структура("Строки", МассивПередачи), ЭтотОбъект,,,, 
				ОписаниеОп, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

// гкс+ [12.22] Деснол 12.12.2022
&НаКлиенте
Процедура ЗаполнитьДатыРаботПоРемонту(Команда)
	ТекДанныеРемонта = Элементы.РемонтыОборудования.ТекущиеДанные;
	
	Если Не ТекДанныеРемонта = Неопределено Тогда
		ИмяПоляДляОтбора = "РемонтыОборудования_ID";
		
		Если Элементы.СтраницыИсполнителей.ТекущаяСтраница = Элементы.СтраницаПодрядчики Тогда
			ИмяТЧ = "ИсполнителиПоРемонтам";
			ИмяТЧДляПользователя = "Исполнители по ремонтам";
		Иначе
		    ИмяТЧ = "Исполнители";
			ИмяТЧДляПользователя = "Трудовые затраты";
		КонецЕсли; 

		ДополнительныеПараметры = Новый Структура("ИмяТЧ, ИмяПоляДляОтбора, ИмяТЧДляПользователя", ИмяТЧ, ИмяПоляДляОтбора, ИмяТЧДляПользователя) ;
		Если ЕстьЗаполненныеДатыУИсполнителейРемонта(ИмяТЧ, ИмяПоляДляОтбора, ТекДанныеРемонта.ID) Тогда
		    ПоказатьВопрос(Новый ОписаниеОповещения("ЗаполнитьДатыРаботПоРемонтуЗавершение", ЭтотОбъект, ДополнительныеПараметры), НСтр("es='Las fechas son rellenadas ya. ¿Перезаполнить de ellos?';ru='Даты уже заполнены. Перезаполнить их?';en='Dates are already filled. Refill them?'"), РежимДиалогаВопрос.ДаНет);
		Иначе
		    ЗаполнитьДатыРаботПоРемонтуЗавершение(КодВозвратаДиалога.Да, ДополнительныеПараметры);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры // гкс- [12.22] Деснол 12.12.2022

