#Область ОбработчикиСобытийФормы
&НаСервере
&ИзменениеИКонтроль("ПриСозданииНаСервере")
Процедура гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("Основание") 
		И ТипЗнч(Параметры.Основание) <> Тип("Структура") 
		И ТипЗнч(Параметры.Основание) <> Тип("Соответствие") Тогда
		торо_ЗаполнениеДокументов.ПроверитьВозможностьВводаНаОсновании(Параметры.Основание, Отказ);
		Если Отказ Тогда
			Возврат;
		КонецЕсли; 
	КонецЕсли;

	Если Параметры.Свойство("Основание") И Параметры.Свойство("ВыделенныеСтроки") Тогда
		ДокОснованиеППР = Параметры.Основание;
		МассивIDИзППР.ЗагрузитьЗначения(Параметры.ВыделенныеСтроки);
	КонецЕсли;

	Если Параметры.Свойство("ID") Тогда

		Строки = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", Параметры.ID));
		Если Строки.Количество() Тогда
			Элементы.РемонтыОборудования.ТекущаяСтрока = Строки[0].ПолучитьИдентификатор();
		КонецЕсли;

	КонецЕсли;

	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства

	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

	УстановитьУсловноеОформление();

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	// ФункциональныеОпции
	ФОИспользоватьГарантии      = ПолучитьФункциональнуюОпцию("торо_ИспользоватьГарантии");
	ФОЗапретитьРемонтГарантийногоОборудованияХозспособом = ПолучитьФункциональнуюОпцию("торо_ЗапретитьРемонтГарантийногоОборудованияХозспособом");
	ФОИспользоватьОстановочные	= ПолучитьФункциональнуюОпцию("торо_ИспользоватьОстановочныеРемонты");

	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда

		Если ФОИспользоватьГарантии Тогда
			Для каждого ТекСтрока из Объект.РемонтыОборудования Цикл
				ТекСтрока.ГарантийныйРемонт = торо_ГарантийноеОбслуживание.ПолучитьЗначениеФлагаГарантийныйРемонтДляОбъектаРемонта(
				ТекСтрока.ОбъектРемонта, ТекСтрока.ДатаНачала, ТекСтрока.ДатаОкончания);
			КонецЦикла;
		КонецЕсли;		
	КонецЕсли;

	ЗаполнитьДеревоРемонтныхРаботНаСервере();

	// Заголовок формы++
	торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(Объект, ЭтаФорма, "");
	// Заголовок формы--

	// Согласование++
	ВидДокумента = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_НарядНаВыполнениеРемонтныхРабот;
	торо_РаботаССогласованиями.ПриСозданииНаСервере(ЭтаФорма, ВидДокумента);
	// Согласование --

	Для Каждого СтрокаРемонта Из Объект.РемонтыОборудования Цикл
		Если СтрокаРемонта.ДокументИсточник <> Неопределено Тогда
			СтрокаРемонта.ТипДокументаОснования = СтрокаРемонта.ДокументИсточник.Метаданные().Имя;
		КонецЕсли;	
	КонецЦикла;

	ПравоРедактирование = ПравоДоступа("Редактирование", Метаданные.Документы.торо_НарядНаВыполнениеРемонтныхРабот);

	Если ФОИспользоватьОстановочные Тогда
		ОбновитьОстановочные();
	КонецЕсли;
	ОбновитьЗависимыеЛоты();
	ОбновитьДоступностьДляРедактирования();

	// Ограничение ввода на основании
	торо_СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка, Новый Структура("ОграничитьВводНаОсновании, УстановитьСвойствоЭлементовФормыОтПрав",Истина, Истина));

	УправлениеВидимостью(ЭтотОбъект);

	ПараметрыВыбораМассив = Новый Массив;
	ПараметрыВыбораМассив.Добавить(Новый ПараметрВыбора("ДополнительныеПараметры.ОтображениеСписком", Истина));
	Элементы.ДеревоРемонтныхРаботИсполнитель.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбораМассив);

	// >> [Деснол] [Ушаков А.Д.] [03.10.2019]
	дс_ЛокализоватьУсловноеОформление();
	// << [Деснол] [Ушаков А.Д.] [03.10.2019] 
	#Вставка
	// гкс+ [Релиз16] Деснол
	торо_ЗаполнениеДокументов.гкс_ПроверитьВозможностьВводаОтСтатуса(Объект, Отказ);
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	// гкс- [Релиз16]
	
	// гкс+ [Часовые пояса] Куст
	гкс_ЧасовыеПоясаВызовСервера.ДобавитьНовыеЭлементы(ЭтаФорма, Элементы.ДатаИНомер,
		Новый Структура("гкс_РеквизитыДаты", 
		"Дата,РемонтыОборудования.ДатаНачала,РемонтыОборудования.ДатаОкончания"
		+ ",Исполнители.ДатаНачала,Исполнители.ДатаОкончания"
		+ ",ИсполнителиПоРемонтам.ДатаНачала,ИсполнителиПоРемонтам.ДатаОкончания"
		));	// гкс- [Часовые пояса]
	
	ДобавитьНовыеЭлементы();
	Для каждого Строка Из Объект.Исполнители Цикл
		Строка.гкс_ВремяРаботыТекст = Расш_гкс_СформироватьПродолжительность(Строка.гкс_ВремяРаботы);
	КонецЦикла;
	// гкс+ [КатегорияРиска] Куст
	гкс_ОбщегоНазначенияСервер.ДобавитьКатегориюРискаВТЧ(
		ЭтаФорма, "РемонтыОборудования", "РемонтыОборудованияВидРемонтныхРабот");

	// гкс+ [Релиз 1] Куст 
	Элементы.СпособСогласования.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
	Если Не ЗначениеЗаполнено(Объект.Ссылка) И Объект.ДокументыОснования.Количество() Тогда 
		МассивСмет = Новый Массив();
		Для Каждого СТ Из Объект.ДокументыОснования Цикл
			Если ТипЗнч(СТ.ДокументОснование) = Тип("ДокументСсылка.торо_ЗаявкаНаРемонт") Тогда 
				МассивСмет.Добавить(СТ.ДокументОснование);
			КонецЕсли;
		КонецЦикла;
		Если МассивСмет.Количество() Тогда 
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	Док.Ссылка КАК Ссылка
				|ИЗ
				|	Документ.торо_ЗаявкаНаРемонт КАК Док
				|ГДЕ
				|	Док.гкс_РаботаПовышеннойОпасности = ""Да""
				|	И Док.Ссылка В(&МассивСмет)";
			
			Запрос.УстановитьПараметр("МассивСмет", МассивСмет);
			
			РезультатЗапроса = Запрос.Выполнить();
	 		Объект.гкс_ОформитьНарядДопуск = Не РезультатЗапроса.Пустой();
		КонецЕсли;
	КонецЕсли;
	гкс_ОбновитьНомерНарядДопуска();
	гкс_ДобавитьГруппуКомандПечатиБАТ(); 
	// гкс+ [Релиз17] Деснол
	Если Параметры.Ключ.Пустая() Тогда 
		гкс_УдалитьИспользованныеТО();
	КонецЕсли;
	// гкс- [Релиз17]
	#КонецВставки
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПриЧтенииНаСервереПосле(ТекущийОбъект)
	// гкс+ [Часовые пояса] Куст 14.04.2020
	СтруктураПроверки = Новый Структура("гкс_СдвигЧП", Неопределено);
	ЗаполнитьЗначенияСвойств(СтруктураПроверки, ЭтотОбъект);
	Если Не СтруктураПроверки.гкс_СдвигЧП = Неопределено Тогда 
		гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтаФорма,, Объект);
	КонецЕсли;
	// гкс- [Часовые пояса] Куст 14.04.2020
	// гкс+ [Категории риска] Куст 22.10.2020
	гкс_ОбщегоНазначенияСервер.ДобавитьУОКатегорииРиска(ЭтаФорма);
	// гкс- [Категории риска] Куст 22.10.2020
	// гкс+ [Релиз 1] Куст 31.03.2021
	гкс_ОбновитьНомерНарядДопуска();
	// гкс- [Релиз 1] Куст 31.03.2021
КонецПроцедуры

&НаСервере
Процедура ПриОткрытииНаСервере(ДатаКлиента)
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда 
		Объект.Дата = ТекущаяДата();
	КонецЕсли;
	// гкс+ [Часовые пояса] Куст 14.04.2020
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтаФорма,,,);
	// Заголовок формы++
	торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(Объект, ЭтаФорма, "");
	// Заголовок формы--
	// гкс- [Часовые пояса] Куст 14.04.2020
КонецПроцедуры

&НаКлиенте
Процедура гкс_ПриОткрытииПосле(Отказ)
	ПриОткрытииНаСервере(ТекущаяДата());
	Для каждого Строка Из Объект.Исполнители Цикл
		Строка.гкс_ВремяРаботыТекст = Расш_гкс_СформироватьПродолжительность(Строка.гкс_ВремяРаботы);
	КонецЦикла;
	// гкс+ [Релиз16] Деснол
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда 
		гкс_ВыбратьИсполнителя();
	КонецЕсли;
	// гкс- [Релиз16]
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПередЗаписьюНаСервереПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// гкс+ [разработка 2021] Куст 09.07.2021
	Для Каждого СтрокаТаблицы ИЗ ТекущийОбъект.РемонтныеРаботы Цикл
		Если ТипЗнч(СтрокаТаблицы.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда 
			СтрокаТаблицы.гкс_ПовКоэф = Неопределено;
		ИначеЕсли ЗначениеЗаполнено(СтрокаТаблицы.гкс_ПовКоэф) = Ложь Тогда 
			СтрокаТаблицы.гкс_ПовКоэф = Справочники.гкс_ПКоэффициентыРабот.ПоУмолчанию;
		КонецЕсли;
	КонецЦикла;
	// гкс- [разработка 2021] Куст 09.07.2021
	// гкс+ [Часовые пояса] Куст 14.04.2020
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПСервера(ЭтаФорма,, ТекущийОбъект);
	// гкс- [Часовые пояса] Куст 14.04.2020
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПередЗаписью")
Процедура гкс_ПередЗаписью(Отказ, ПараметрыЗаписи)

	#Вставка
	// гкс+ [Перед записью] Куст 27.10.2020
	МассивСтруктур = новый Массив();
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Организация", НСтр("ru='Организация';en='Organization'")));
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Подразделение", НСтр("ru='Подразделение';en='Subdivision'")));
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Ответственный", НСтр("ru='Ответственный';en='Responsible'")));
	Для Каждого СтрокаМассива Из МассивСтруктур Цикл
		Если Не ЗначениеЗаполнено(Объект[СтрокаМассива.Имя]) Тогда 
			Сообщение = Новый СообщениеПользователю();
			ШаблонСообщения = НСтр("ru='Поле ""%1"" не заполнено';en='Field %1 is empty'");
			Сообщение.Текст = СтрШаблон(ШаблонСообщения, СтрокаМассива.Текст);
			Сообщение.Поле = "Объект." + СтрокаМассива.Имя;
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла;
	//
	Отображать = Истина;
	Если Объект.ИсполнителиПоРемонтам.Количество() Тогда 
		Если ТипЗнч(Объект.ИсполнителиПоРемонтам[0].Исполнитель) = Тип("СправочникСсылка.Контрагенты") Тогда 
			Отображать = Ложь;
		КонецЕсли;
	КонецЕсли;
	Если Объект.Исполнители.Количество() = 0 Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='В документе не указан исполнитель ремонтных работ';
			|en='The document does not specify the contractor for the repair work'");
		Сообщение.Сообщить();
		Отказ = Истина;
	Иначе
		МассивСтруктур = новый Массив();
		Если Отображать Тогда 
			МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Сотрудник",
			НСтр("ru='Сотрудник';en='Employee'")));
		Иначе
			МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "гкс_Количество",
			НСтр("ru='Количество';en='Count'")));
		КонецЕсли;
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Квалификация", 
			НСтр("ru='Квалификация';en='Qualification'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаНачала",
			НСтр("ru='Дата начала';en='Start date'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаОкончания", 
			НСтр("ru='Дата окончания';en='End date'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст,Имя2", "гкс_ВремяРаботы", 
			НСтр("ru='Время работы';en='Working hours'"), "гкс_ВремяРаботыТекст"));
		Для Каждого СтрокаМассива Из МассивСтруктур Цикл
			НомерПП = 0;
			Для Каждого СтрокаТаблицы Из Объект.Исполнители Цикл
				Если Не ЗначениеЗаполнено(СтрокаТаблицы[СтрокаМассива.Имя]) Тогда 
					Сообщение = Новый СообщениеПользователю();
					ШаблонСообщения = НСтр("ru='Поле ""%1"" не заполнено';en='Field %1 is empty'");
					Сообщение.Текст = СтрШаблон(ШаблонСообщения, СтрокаМассива.Текст);
					Сообщение.Поле = "Объект.Исполнители[" + НомерПП + "]." 
					+ ?(СтрокаМассива.Свойство("Имя2"), СтрокаМассива.Имя2, СтрокаМассива.Имя);
					Сообщение.Сообщить();
					Отказ = Истина;
				КонецЕсли;
				НомерПП = НомерПП + 1;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	//
	Если Объект.ИсполнителиПоРемонтам.Количество() = 0 Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='В документе не указан исполнитель ремонта';
			|en='The document does not specify the repair contractor'");
		Сообщение.Сообщить();
		Отказ = Истина;
	Иначе
		МассивСтруктур = новый Массив();
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Исполнитель", 
			НСтр("ru='Исполнитель';en='Executor'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаНачала",
			НСтр("ru='Дата начала';en='Start date'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаОкончания", 
			НСтр("ru='Дата окончания';en='End date'")));
		Для Каждого СтрокаМассива Из МассивСтруктур Цикл
			НомерПП = 0;
			Для Каждого СтрокаТаблицы Из Объект.ИсполнителиПоРемонтам Цикл
				Если Не ЗначениеЗаполнено(СтрокаТаблицы[СтрокаМассива.Имя]) Тогда 
					Сообщение = Новый СообщениеПользователю();
					ШаблонСообщения = НСтр("ru='Поле ""%1"" не заполнено';en='Field %1 is empty'");
					Сообщение.Текст = СтрШаблон(ШаблонСообщения, СтрокаМассива.Текст);
					Сообщение.Поле = "Объект.ИсполнителиПоРемонтам[" + НомерПП + "]." + СтрокаМассива.Имя;
					Сообщение.Сообщить();
					Отказ = Истина;
				КонецЕсли;
				НомерПП = НомерПП + 1;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	//
	Если Объект.РемонтыОборудования.Количество() = 0 Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='В документе не указан ОР';en='The document does not specify an OR'");
		Сообщение.Сообщить();
		Отказ = Истина;
	Иначе
		МассивСтруктур = новый Массив();
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ОбъектРемонта",
			НСтр("ru='Объект ремонта';en='Object of repair'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ВидРемонтныхРабот", 
			НСтр("ru='Вид ремонтных работ';en='Type of repair work'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаНачала",
			НСтр("ru='Дата начала';en='Start date'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаОкончания",
			НСтр("ru='Дата окончания';en='End date'")));
		Для Каждого СтрокаМассива Из МассивСтруктур Цикл
			НомерПП = 0;
			Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
				Если Не ЗначениеЗаполнено(СтрокаТаблицы[СтрокаМассива.Имя]) Тогда 
					Сообщение = Новый СообщениеПользователю();
					ШаблонСообщения = НСтр("ru='Поле ""%1"" не заполнено';en='Field %1 is empty'");
					Сообщение.Текст = СтрШаблон(ШаблонСообщения, СтрокаМассива.Текст);
					Сообщение.Поле = "Объект.РемонтыОборудования[" + НомерПП + "]." + СтрокаМассива.Имя;
					Сообщение.Сообщить();
					Отказ = Истина;
				КонецЕсли;
				НомерПП = НомерПП + 1;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	//
	Если Объект.РемонтныеРаботы.Количество() = 0 Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='В документе не указана ремонтная работа';en='The document does not specify repairs'");
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	// гкс- [Перед записью] Куст 27.10.2020
	#КонецВставки
КонецПроцедуры

