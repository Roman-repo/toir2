		Если ТипЗнч(СТ.Исполнитель) = Тип("СправочникСсылка.Контрагенты") Тогда 
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

&НаСервере
&ИзменениеИКонтроль("ПередЗаписьюНаСервере")
Процедура Расш_гкс_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	// Согласование++
	торо_РаботаССогласованиями.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	// Согласование--

	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
		И ФОИспользоватьГарантии Тогда
		торо_ГарантийноеОбслуживание.СформироватьПредупрежденияОРекламационныхАктах(Объект, "РемонтыОборудования");
	КонецЕсли;

	#Вставка
	Если СредиИсполнителейЕстьКонтрагент() = Ложь Тогда 
	#КонецВставки
	Если торо_ОбщегоНазначения.ПроверитьВремяРаботыСотрудников(Объект, "Исполнители") Тогда 
		Отказ = Истина;
	КонецЕсли; 
	#Вставка
	КонецЕсли;
	// гкс+ [Релиз 1] Куст 31.03.2021
	Если ЭтотОбъект["гкс_НарядДопускНомерИзменен"] Тогда 
		Если ЗначениеЗаполнено(Объект.Дата) Тогда 
			ТекГод = НачалоГода(Объект.Дата);
		Иначе
			ТекГод = НачалоГода(ТекущаяДата());
		КонецЕсли;
		Запрос = Новый Запрос();
		Запрос.Текст = "Выбрать ТЧ.Документ КАК Документ ИЗ РегистрСведений.гкс_НомераНарядДопусков КАК ТЧ 
		|	Где ТЧ.Номер = &Номер И Не ТЧ.Документ = &Ссылка
		|	И ТЧ.Подразделение = &Подр И ТЧ.Год = &Год";
		Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
		Запрос.УстановитьПараметр("Подр", Объект.Подразделение);
		Запрос.УстановитьПараметр("Год", ТекГод);
		Запрос.УстановитьПараметр("Номер", ЭтотОбъект["гкс_НарядДопускНомер"]);
		РезультатЗапроса = Запрос.Выполнить();	
		Если не РезультатЗапроса.Пустой() Тогда 
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	// гкс- [Релиз 1] Куст 31.03.2021
	#КонецВставки

КонецПроцедуры

&НаКлиенте
Процедура гкс_ОрганизацияПриИзмененииПосле(Элемент)
	// гкс+ [2021] Куст
	Если ЗначениеЗаполнено(Объект.СпособСогласования) Тогда 
		Возврат;
	КонецЕсли; // гкс- [2021] 
	Если ЭтотОбъект["мИспользоватьСогласованиеДокументов"] И Элементы["СпособСогласования"].ТолькоПросмотр
		И Не СтатусДокументаРегистр = ЭтаФорма["гкс_СтатусЧерновик"] Тогда 
		Возврат;
	КонецЕсли;
	//
	Если Объект.РемонтыОборудования.Количество() > 0 Тогда 
		Способ = гкс_ПолучитьСпособСогласования(Объект.Организация, Объект.РемонтыОборудования[0].ОбъектРемонта);
		Если Не Объект.СпособСогласования = Способ И Не Способ = Неопределено Тогда 
			Объект.СпособСогласования = Способ;
			СпособСогласованияПриИзменении(Неопределено);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

