&НаСервереБезКонтекста
Функция ПроверитьТКНаСервере(МассивТК)
	МассивВозврата = Новый Массив();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Проверяемые.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ИдентификаторыТехКарт КАК Проверяемые
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК торо_ИдентификаторыТехКарт
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК Родитель1
		|			ПО торо_ИдентификаторыТехКарт.Родитель = Родитель1.Ссылка
		|		ПО Проверяемые.Родитель = торо_ИдентификаторыТехКарт.Ссылка
		|ГДЕ
		|	Проверяемые.Ссылка В(&Родитель)
		|	И Родитель1.Родитель = ЗНАЧЕНИЕ(Справочник.торо_ИдентификаторыТехКарт.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Родитель", МассивТК);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			МассивВозврата.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЕсли;
	
	Возврат МассивВозврата;
КонецФункции


