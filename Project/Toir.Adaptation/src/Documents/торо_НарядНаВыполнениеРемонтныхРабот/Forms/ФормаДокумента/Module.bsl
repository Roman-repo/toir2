&НаКлиентеНаСервереБезКонтекста
Функция Расш_гкс_СформироватьПродолжительность(ПродолжительностьВСекундах)
	
	Если ПродолжительностьВСекундах = 0 Тогда
		
		Возврат "Ввести продолжительность";
		
	Иначе
		
		Часы    = Цел(ПродолжительностьВСекундах / 3600);
		Минуты  = Цел((ПродолжительностьВСекундах - 3600 * Часы) / 60);
		Секунды = ПродолжительностьВСекундах - 3600 * Часы - Минуты * 60;
		
		Возврат "" + Часы + " ч. " + Минуты + " мин. " + Секунды + " с.";
		
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура Расш_гкс_ПослеЗаписиНаСервереПосле(ТекущийОбъект, ПараметрыЗаписи)
	Для каждого Строка Из Объект.Исполнители Цикл
		Строка.гкс_ВремяРаботыТекст = Расш_гкс_СформироватьПродолжительность(Строка.гкс_ВремяРаботы);
	КонецЦикла;
	// гкс+ [Категории риска] Куст 22.10.2020
	гкс_ОбщегоНазначенияСервер.ДобавитьУОКатегорииРиска(ЭтаФорма);
	// гкс- [Категории риска] Куст 22.10.2020
	// гкс+ [Релиз 1] Куст 31.03.2021
	Если ЗначениеЗаполнено(ТекущийОбъект.Ссылка) Тогда 
		Если ЭтотОбъект["гкс_НарядДопускНомерИзменен"] Тогда 
			ТекГод = НачалоГода(ТекущийОбъект.Дата);
			НаборЗаписей = РегистрыСведений.гкс_НомераНарядДопусков.СоздатьнаборЗаписей();
			НаборЗаписей.Отбор.Документ.Установить(ТекущийОбъект.Ссылка);
			НоваяСтрока = НаборЗаписей.Добавить();
			НоваяСтрока.Номер = ЭтотОбъект["гкс_НарядДопускНомер"];
			НоваяСтрока.НомерТекст = Формат(НоваяСтрока.Номер, "ЧГ=0");
			Пока СтрДлина(НоваяСтрока.НомерТекст) < 11 Цикл
				НоваяСтрока.НомерТекст = "0" + НоваяСтрока.НомерТекст;
			КонецЦикла;
			НоваяСтрока.Год = ТекГод;
			НоваяСтрока.Подразделение = ТекущийОбъект.Подразделение;
			НоваяСтрока.Документ = ТекущийОбъект.Ссылка;
			НаборЗаписей.Записать();
			ЭтотОбъект["гкс_НарядДопускНомерИзменен"] = Ложь;
		Иначе
			гкс_ОбновитьНомерНарядДопуска();
		КонецЕсли;
	КонецЕсли;
	// гкс- [Релиз 1] Куст 31.03.2021
КонецПроцедуры

