&НаСервере
Процедура гкс_ОбновитьНомерНарядДопуска()
	ТемпСтрукт = Новый Структура("гкс_НарядДопускНомер", Неопределено);
	ЗаполнитьЗначенияСвойств(ТемпСтрукт, ЭтотОбъект);
	Если ЗначениеЗаполнено(Объект.Ссылка) И Не ТемпСтрукт.гкс_НарядДопускНомер = Неопределено Тогда 
		НЗ = РегистрыСведений.гкс_НомераНарядДопусков.СоздатьнаборЗаписей();
		НЗ.Отбор.Документ.Установить(Объект.Ссылка);
		НЗ.Прочитать();
		Если НЗ.Количество() Тогда 
			ЭтотОбъект["гкс_НарядДопускНомер"] = НЗ[0].Номер;
		Иначе
			ЭтотОбъект["гкс_НарядДопускНомер"] = 0;
		КонецЕсли;
	КонецЕсли;
