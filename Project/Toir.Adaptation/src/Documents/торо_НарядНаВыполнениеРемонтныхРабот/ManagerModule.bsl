	|	Внутреннее соединение Документ.торо_НарядНаВыполнениеРемонтныхРабот.гкс_МПОБДо КАК ТЧ
	|	ПО ТЧ.Ссылка = ВсеДокументы.Ссылка
	|
	|Объединить все
	|
	|Выбрать 
	|ТЧ.Ссылка, ТЧ.НомерСтроки, 2 ,
	|	ТЧ.Мероприятие
	|
	|	ИЗ	
	|	ВсеДокументы КАК ВсеДокументы
	|	Внутреннее соединение Документ.торо_НарядНаВыполнениеРемонтныхРабот.гкс_МПОБВоВремя КАК ТЧ
	|	ПО ТЧ.Ссылка = ВсеДокументы.Ссылка
	|
	|Упорядочить по Приоритет, ТЧ.НомерСтроки	
	|Итоги ПО Ссылка
	|;
	|Выбрать Различные ТЧ.Сотрудник
	|Поместить РазличныеСотрудники
	|ИЗ ВсеОтветственныеДокументы КАК ТЧ
	|;
	|Выбрать
	|ТЧ.Сотрудник, Максимум(Рег.ТекущаяДолжность) КАК Должность
	|
	|ИЗ РазличныеСотрудники КАК ТЧ
	|	Внутреннее соединение РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК Рег
	|	По Рег.Сотрудник = ТЧ.Сотрудник
	|Сгруппировать по ТЧ.Сотрудник
	|
	|
	|
	|";
	#КонецОбласти
	
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов); 
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТЧ.ID В(&ID)", "");
	КонецЕсли;
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	СекундВЧасе = 3600;
	СдвигСекунд = СдвигЧП * СекундВЧасе;
	
	ПервыйПакет = 4;
	ВторойПакет = ПервыйПакет + 1;
	ТретийПакет = ВторойПакет + 1;
	РемРаботыПакет = ТретийПакет + 1;
	МероприятияПакет = РемРаботыПакет + 1;
	ЧислоПакетовРавноеДвум = 2;
	ДолжностиПакет = МероприятияПакет + ЧислоПакетовРавноеДвум;
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ВыборкаДокументов = РезультатЗапроса[ПервыйПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ВыборкаИсполнители = РезультатЗапроса[ВторойПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаКонтрагенты = РезультатЗапроса[ТретийПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаРР = РезультатЗапроса[РемРаботыПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМероприятия = РезультатЗапроса[МероприятияПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаДолжности = РезультатЗапроса[ДолжностиПакет].Выбрать();
	
	ЭтоПервый = Истина;
	
	Пока ВыборкаДокументов.Следующий() Цикл
		
		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл
			
			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;
			СтрПоиска = Новый Структура("Ссылка,ИД", ВыборкаДокументов.Ссылка, ВыборкаРемонтов.ИД);
			СтрПоискаОбщая = Новый Структура("Ссылка", ВыборкаДокументов.Ссылка);
			
			ОбластьШапка1 = Макет.ПолучитьОбласть("Шапка1");
			ОбластьШапка2 = Макет.ПолучитьОбласть("Шапка2");
			ОбластьШапка3 = Макет.ПолучитьОбласть("Шапка3");
			ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
			ОбластьСтрокаТЧ1 = Макет.ПолучитьОбласть("СтрокаТЧ1");
			ОбластьСтрокаТЧ2 = Макет.ПолучитьОбласть("СтрокаТЧ2");
			ОбластьСтрокаТЧ3 = Макет.ПолучитьОбласть("СтрокаТЧ3");
			ФИОНарядВыдал = ПреобразоватьФИО(ВыборкаРемонтов.НарядВыдал);
			ФИОРуководительРабот = ПреобразоватьФИО(ВыборкаРемонтов.РуководительРабот);
			ОбластьПодвал.Параметры.НарядВыдал = ФИОНарядВыдал;
			ОбластьПодвал.Параметры.РуководительРабот = ФИОРуководительРабот;
			ОбластьШапка1.Параметры.ОсобыеУсловия = ВыборкаРемонтов.ОсобыеУсловия;
			
			ВыборкаДолжности.Сбросить();
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.НарядВыдал) Тогда 
				ОбластьПодвал.Параметры.НарядВыдалД = Строка(ВыборкаДолжности.Должность);
			Иначе
				ОбластьПодвал.Параметры.НарядВыдалД = "";
			КонецЕсли;
			ВыборкаДолжности.Сбросить();
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.РуководительРабот) Тогда 
				ОбластьШапка1.Параметры.РуководительРабот = Строка(ВыборкаДолжности.Должность) + ", " + ФИОРуководительРабот;
				ОбластьПодвал.Параметры.РуководительРаботД = Строка(ВыборкаДолжности.Должность);
			Иначе
				ОбластьШапка1.Параметры.РуководительРабот = ФИОРуководительРабот;
				ОбластьПодвал.Параметры.РуководительРаботД = "";
			КонецЕсли;
			//
			ВыборкаКонтрагенты.Сбросить();
			ЭтоКонтрагент = Ложь;
			Если ВыборкаКонтрагенты.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Выборка.Следующий();
						ЭтоКонтрагент = ТипЗнч(Выборка.Контрагент) = Тип("СправочникСсылка.Контрагенты");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			МассивТекста = Новый Массив();
			Если ЗначениеЗаполнено(ВыборкаРемонтов.ТехМесто) Тогда 
				МассивТекста.Добавить(Строка(ВыборкаРемонтов.ТехМесто));
			КонецЕсли;
			Если ЗначениеЗаполнено(ВыборкаРемонтов.Комментарий) Тогда 
				МассивТекста.Добавить(Строка(ВыборкаРемонтов.Комментарий));
			КонецЕсли;
			Если ЗначениеЗаполнено(ВыборкаРемонтов.ТехНомер) Тогда 
				МассивТекста.Добавить(Строка(ВыборкаРемонтов.ТехНомер));
			КонецЕсли;
			ОбластьШапка1.Параметры.МестоПроведения = СтрСоединить(МассивТекста, ", ");
			//
			МассивСтрок1 = Новый Массив();
			МассивСтрок2 = Новый Массив();
			ВыборкаМероприятия.Сбросить();
			Если ВыборкаМероприятия.НайтиСледующий(СтрПоискаОбщая) Тогда 
				Выборка = ВыборкаМероприятия.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если Выборка.Приоритет = 1 Тогда 
						МассивСтрок1.Добавить(Выборка.Мероприятие);
					Иначе
						МассивСтрок2.Добавить(Выборка.Мероприятие);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			ТекДатаНачала = ВыборкаРемонтов.ДатаНачала + СдвигСекунд;
			ТекДатаОкончания = ВыборкаРемонтов.ДатаОкончания + СдвигСекунд;
			ДатаНачалаТекст = Формат(ТекДатаНачала, "ДФ=""ЧЧ:мм дд.ММ.гггг """);
			ОбластьШапка2.Параметры.ЧасДН = Формат(ТекДатаНачала, "ДФ=""ЧЧ""");
			ОбластьШапка2.Параметры.МинДН = Формат(ТекДатаНачала, "ДФ=""мм""");
			ОбластьШапка2.Параметры.ГодДН = Формат(ТекДатаНачала, "ДФ=""гггг""");
			ОбластьШапка2.Параметры.ЧасДО = Формат(ТекДатаОкончания, "ДФ=""ЧЧ""");
			ОбластьШапка2.Параметры.МинДО = Формат(ТекДатаОкончания, "ДФ=""мм""");
			ОбластьШапка2.Параметры.ГодДО = Формат(ТекДатаОкончания, "ДФ=""гггг""");
			ОбластьШапка2.Параметры.ДатаДН = Формат(ТекДатаНачала, "ДФ=""дд ММММ""");
			ОбластьШапка2.Параметры.ДатаДО = Формат(ТекДатаОкончания, "ДФ=""дд ММММ""");
			//
			ТабДок.Вывести(ОбластьШапка1);
			НомерПП = 1;
			Для Каждого СтрокаМассива ИЗ МассивСтрок1 Цикл
				ОбластьСтрокатЧ1.Параметры.Текст = СтрокаМассива;
				ОбластьСтрокатЧ1.Параметры.ДатаНачала = ДатаНачалаТекст;
				ТабДок.Вывести(ОбластьСтрокатЧ1);
				НомерПП = НомерПП + 1;
			КонецЦикла;
			ТабДок.Вывести(ОбластьШапка2);
			Для Каждого СтрокаМассива ИЗ МассивСтрок2 Цикл
				ОбластьСтрокатЧ2.Параметры.Текст = СтрокаМассива;
				ОбластьСтрокатЧ2.Параметры.РуководительРабот = ФИОРуководительРабот;
				ТабДок.Вывести(ОбластьСтрокатЧ2);
			КонецЦикла;
			ТабДок.Вывести(ОбластьШапка3);
			
			ВыборкаИсполнители.Сбросить();
			Если ВыборкаИсполнители.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							Если ЭтоКонтрагент Тогда 
								ОбластьСтрокаТЧ3.Параметры.Сотрудник = Выборка.гкс_СотрудникКонтрагента;
							Иначе
								ОбластьСтрокаТЧ3.Параметры.Сотрудник = Выборка.Сотрудник;
							КонецЕсли;
							ОбластьСтрокаТЧ3.Параметры.Квалификация = Выборка.Квалификация;
							
							ТабДок.Вывести(ОбластьСтрокаТЧ3);
						КонецЦикла;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			ТабДок.Вывести(ОбластьПодвал);
		КонецЦикла;
	КонецЦикла;
	
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.ТолькоПросмотр = Истина;
	ТабДок.АвтоМасштаб = Истина;
	Возврат ТабДок;
КонецФункции

