// гкс+ [Релиз 1] Куст 01.02.2021
Функция МесяцРодПадеж(Дата)
	Номер = Месяц(Дата);
	Если Номер = 1 Тогда 
		Возврат "Января";
	ИначеЕсли Номер = 2 Тогда 
		Возврат "Февраля";
	ИначеЕсли Номер = 3 Тогда 
		Возврат "Марта";
	ИначеЕсли Номер = 4 Тогда 
		Возврат "Апреля";
	ИначеЕсли Номер = 5 Тогда 
		Возврат "Мая";
	ИначеЕсли Номер = 6 Тогда 
		Возврат "Июля";
	ИначеЕсли Номер = 7 Тогда 
		Возврат "Июня";
	ИначеЕсли Номер = 8 Тогда 
		Возврат "Августа";
	ИначеЕсли Номер = 9 Тогда 
		Возврат "Сентября";
	ИначеЕсли Номер = 10 Тогда 
		Возврат "Октября";
	ИначеЕсли Номер = 11 Тогда 
		Возврат "Ноября";
	ИначеЕсли Номер = 12 Тогда 
		Возврат "Декабря";
	КонецЕсли;
КонецФункции

