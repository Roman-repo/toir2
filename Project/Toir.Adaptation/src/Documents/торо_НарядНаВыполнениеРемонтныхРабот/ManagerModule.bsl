#Область СлужебныеПроцедурыИФункции

&ИзменениеИКонтроль("ПечатьНарядДопускДляРаботыВЭлектроустановках")
Функция Расш_гкс_ПечатьНарядДопускДляРаботыВЭлектроустановках(МассивОбъектов, ПараметрыПечати)

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "торо_НарядНаВыполнениеРемонтныхРабот";
	#Вставка
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	#КонецВставки

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_НарядДопускДляРаботыВЭлектроустановках");

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка КАК Ссылка,
	#Удаление
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Номер КАК Номер,
	#КонецУдаления
	#Вставка
	|	ЕстьNull(ННД.НомерТекст, торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Номер) КАК Номер,
	#КонецВставки
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Дата КАК Дата,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Организация КАК Организация,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Ответственный КАК Ответственный,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID КАК ID,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаНачала КАК ДатаНачала,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаОкончания КАК ДатаОкончания,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОпаснаяРабота КАК ОпаснаяРабота,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.МестоПроведенияРабот КАК МестоПроведенияРабот
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтыОборудования КАК торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования
	#Вставка
	|		левое соединение РегистрСведений.гкс_НомераНарядДопусков КАК ННД
	|		ПО ННД.Документ = торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка
	#КонецВставки
	|ГДЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка В(&Ссылка)
	|	И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(Ответственный)
	|ПО
	|	Ссылка";

	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;

	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ЭтоПервый = Истина;

	Пока ВыборкаДокументов.Следующий() Цикл

		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл

			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;

			Шапка = Макет.ПолучитьОбласть("ШапкаДокумента");
			Шапка.Параметры.Организация = ВыборкаДокументов.Организация;
			Шапка.Параметры.ПодразделениеОрганизации = ВыборкаДокументов.Подразделение;
			#Вставка
			Шапка.Параметры.Дата = Формат(ВыборкаДокументов.Дата + (СдвигЧП * 3600), "ДФ=dd.MM.yyyy");
			#КонецВставки
			#Удаление
			Шапка.Параметры.Дата = Формат(ВыборкаДокументов.Дата,"ДФ=dd.MM.yyyy");
			#КонецУдаления
			Шапка.Параметры.Номер = ВыборкаДокументов.Номер;
			ТабДок.Вывести(Шапка);

			#Удаление
			ТЗ = ВыборкаДокументов.Ссылка.Исполнители.Выгрузить(, "Сотрудник, Квалификация");
			ТЗ.Свернуть("Сотрудник, Квалификация");
			#КонецУдаления
			#Вставка
			ТЗ = ВыборкаДокументов.Ссылка.Исполнители.Выгрузить(, "Сотрудник, Квалификация, гкс_СотрудникКонтрагента");
			ТЗ.Свернуть("Сотрудник, Квалификация, гкс_СотрудникКонтрагента");
			#КонецВставки

			ПервыйЧленБригады = Макет.ПолучитьОбласть("ПервыйЧленБригады");
			ЧленБригады       = Макет.ПолучитьОбласть("ЧленБригады");

			ЭтоПервыйСотрудник = Истина;

			Для Каждого Стр Из ТЗ Цикл

				Если ЭтоПервыйСотрудник Тогда 
					#Удаление
					ПервыйЧленБригады.Параметры.СоставБригады = Стр.Сотрудник.Наименование + " (" + Стр.Квалификация + ")";
					#КонецУдаления
					#Вставка
					ПервыйЧленБригады.Параметры.СоставБригады = ?(ЗначениеЗаполнено(Стр.Сотрудник),
					Стр.Сотрудник.Наименование, Стр.гкс_СотрудникКонтрагента)
					+ " (" + Стр.Квалификация + ")";
					#КонецВставки

					ЭтоПервыйСотрудник = Ложь;
					ТабДок.Вывести(ПервыйЧленБригады);
				Иначе 

					#Удаление
					ЧленБригады.Параметры.СоставБригады = Стр.Сотрудник.Наименование + " (" + Стр.Квалификация + ")";
					#КонецУдаления
					#Вставка
					ЧленБригады.Параметры.СоставБригады = ?(ЗначениеЗаполнено(Стр.Сотрудник),
					Стр.Сотрудник.Наименование, Стр.гкс_СотрудникКонтрагента) 
					+ " (" + Стр.Квалификация + ")";
					#КонецВставки
					ТабДок.Вывести(ЧленБригады);
				КонецЕсли;

			КонецЦикла;

			ПерваяРемонтнаяРабота = Макет.ПолучитьОбласть("ПерваяРемонтнаяРабота");
			РемонтнаяРабота       = Макет.ПолучитьОбласть("РемонтнаяРабота");

			Отбор = Новый Структура;
			Отбор.Вставить("РемонтыОборудования_ID", ВыборкаРемонтов.ID);
			СтрокиТекущегоОтбора = ВыборкаДокументов.Ссылка.РемонтныеРаботы.НайтиСтроки(Отбор);		

			ПерваяРабота = Истина;
			Для Каждого СтрокаОтбора Из СтрокиТекущегоОтбора Цикл
				Если ТипЗнч(СтрокаОтбора.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
					Если СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати = "" Тогда
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.Наименование;
					Иначе
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати;
					КонецЕсли;
					#Вставка
					НаименованиеРаботы = НаименованиеРаботы + " " + СтрокаОтбора.гкс_Примечание;
					#КонецВставки

					Если ПерваяРабота Тогда 
						ПерваяРемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ПерваяРабота = Ложь;
						ТабДок.Вывести(ПерваяРемонтнаяРабота);
					Иначе
						РемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ТабДок.Вывести(РемонтнаяРабота);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;	

			Часть0 = Макет.ПолучитьОбласть("Часть0");
			#Вставка
			ДатаНачала = ВыборкаРемонтов.ДатаНачала + (СдвигЧП * 3600);
			ДатаОкончания = ВыборкаРемонтов.ДатаОкончания + (СдвигЧП * 3600);
			#КонецВставки
			#Удаление
			ДатаНачала = ВыборкаРемонтов.ДатаНачала;
			ДатаОкончания = ВыборкаРемонтов.ДатаОкончания;
			#КонецУдаления
			Часть0.Параметры.ВремяНачало	=  Формат(ДатаНачала,"ДЛФ=T");
			Часть0.Параметры.ДатаНачало     =  Формат(ДатаНачала,"ДФ=dd.MM.yyyy");
			Часть0.Параметры.ВремяОкончание =  Формат(ДатаОкончания ,"ДЛФ=T");
			Часть0.Параметры.ДатаОкончание  =  Формат(ДатаОкончания,"ДФ=dd.MM.yyyy");
			ТабДок.Вывести(Часть0);

			Часть1 = Макет.ПолучитьОбласть("Часть1");
			ТабДок.Вывести(Часть1);

			Часть2 = Макет.ПолучитьОбласть("Часть2");
			ТабДок.Вывести(Часть2);

			Часть3 = Макет.ПолучитьОбласть("Часть3");
			ТабДок.Вывести(Часть3);

		КонецЦикла;
	КонецЦикла;

	ТабДок.ТолькоПросмотр = Истина;
	Возврат ТабДок;

КонецФункции

&ИзменениеИКонтроль("ПечатьНарядНаВыполнениеОгневыхРабот")
Функция Расш_гкс_ПечатьНарядНаВыполнениеОгневыхРабот(МассивОбъектов, ПараметрыПечати)

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "торо_НарядНаВыполнениеРемонтныхРабот";
	#Вставка
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	#КонецВставки

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_НарядНаВыполнениеОгневыхРабот");

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка КАК Ссылка,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Номер КАК Номер,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Дата КАК Дата,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Организация КАК Организация,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Ответственный КАК Ответственный,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID КАК ID,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаНачала КАК ДатаНачала,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаОкончания КАК ДатаОкончания,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОпаснаяРабота КАК ОпаснаяРабота,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.МестоПроведенияРабот КАК МестоПроведенияРабот
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтыОборудования КАК торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования
	|ГДЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка В(&Ссылка)
	|	И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(Ответственный)
	|ПО
	|	Ссылка";

	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;

	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ЭтоПервый = Истина;

	Пока ВыборкаДокументов.Следующий() Цикл

		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл

			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;

			Шапка = Макет.ПолучитьОбласть("ШапкаДокумента");
			Шапка.Параметры.Организация = ВыборкаДокументов.Организация;
			Шапка.Параметры.ПодразделениеОрганизации = ВыборкаДокументов.Подразделение;
			ТабДок.Вывести(Шапка);

			ПерваяРемонтнаяРабота = Макет.ПолучитьОбласть("ПерваяРемонтнаяРабота");
			РемонтнаяРабота       = Макет.ПолучитьОбласть("РемонтнаяРабота");

			Отбор = Новый Структура;
			Отбор.Вставить("РемонтыОборудования_ID", ВыборкаРемонтов.ID);
			СтрокиТекущегоОтбора = ВыборкаДокументов.Ссылка.РемонтныеРаботы.НайтиСтроки(Отбор);

			ПерваяРабота = Истина;
			Для Каждого СтрокаОтбора Из СтрокиТекущегоОтбора Цикл
				Если ТипЗнч(СтрокаОтбора.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
					Если СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати = "" Тогда
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.Наименование;
					Иначе
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати;
					КонецЕсли; 

					Если ПерваяРабота Тогда 
						ПерваяРемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ПерваяРабота = Ложь;
						ТабДок.Вывести(ПерваяРемонтнаяРабота);
					Иначе
						РемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ТабДок.Вывести(РемонтнаяРабота);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;	

			ШапкаТаблицыИсполнители = Макет.ПолучитьОбласть("ШапкаТаблицыИсполнители");
			ТабДок.Вывести(ШапкаТаблицыИсполнители);       	

			СтрокаТаблицыИсполнители = Макет.ПолучитьОбласть("СтрокаТаблицыИсполнители");

			#Удаление
			ТЗ = ВыборкаДокументов.Ссылка.Исполнители.Выгрузить(, "Сотрудник,Квалификация");
			ТЗ.Свернуть("Сотрудник,Квалификация");
			#КонецУдаления
			#Вставка
			ТЗ = ВыборкаДокументов.Ссылка.Исполнители.Выгрузить(, "Сотрудник,Квалификация,гкс_СотрудникКонтрагента");
			ТЗ.Свернуть("Сотрудник,Квалификация,гкс_СотрудникКонтрагента");
			#КонецВставки
			ПП = 0;

			Для Каждого Стр Из ТЗ Цикл
				ПП = ПП+1;
				СтрокаТаблицыИсполнители.Параметры.Заполнить(Стр);
				СтрокаТаблицыИсполнители.Параметры.ПП = ПП;
				#Вставка
				Если ЗначениеЗаполнено(Стр.Сотрудник) = Ложь Тогда 
					СтрокаТаблицыИсполнители.Параметры.Сотрудник = Стр.гкс_СотрудникКонтрагента;
				КонецЕсли;
				#КонецВставки
				ТабДок.Вывести(СтрокаТаблицыИсполнители);
			КонецЦикла;

			Пункт5_10 = Макет.ПолучитьОбласть("Пункт5_10");
			#Вставка
			ДатаНачала = ВыборкаРемонтов.ДатаНачала + (СдвигЧП * 3600);
			ДатаОкончания = ВыборкаРемонтов.ДатаОкончания + (СдвигЧП * 3600);
			#КонецВставки
			#Удаление
			ДатаНачала = ВыборкаРемонтов.ДатаНачала;
			ДатаОкончания = ВыборкаРемонтов.ДатаОкончания;
			#КонецУдаления

			Пункт5_10.Параметры.ВремяНачало	 =	Формат(ДатаНачала,"ДФ=чч:мм");
			Пункт5_10.Параметры.ДатаНачало     =  Формат(ДатаНачала,"ДФ=dd.MM.yyyy");
			Пункт5_10.Параметры.ВремяОкончание =  Формат(ДатаОкончания ,"ДФ=чч:мм");
			Пункт5_10.Параметры.ДатаОкончание  =  Формат(ДатаОкончания,"ДФ=dd.MM.yyyy");

			ТабДок.Вывести(Пункт5_10);
			Пункт11_12 = Макет.ПолучитьОбласть("Пункт11_12");
			ТабДок.Вывести(Пункт11_12);

		КонецЦикла;
	КонецЦикла;

	ТабДок.ТолькоПросмотр = Истина;
	Возврат ТабДок;	

КонецФункции

&ИзменениеИКонтроль("ПечатьНарядДопускНаПроизводствоРаботНаВысоте")
Функция Расш_гкс_ПечатьНарядДопускНаПроизводствоРаботНаВысоте(МассивОбъектов, ПараметрыПечати)

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "торо_НарядНаВыполнениеРемонтныхРабот";
	#Вставка
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	#КонецВставки

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_НарядДопускНаПроизводствоРаботНаВысоте");

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка КАК Ссылка,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Номер КАК Номер,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Дата КАК Дата,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Организация КАК Организация,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Ответственный КАК Ответственный,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID КАК ID,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаНачала КАК ДатаНачала,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаОкончания КАК ДатаОкончания,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОпаснаяРабота КАК ОпаснаяРабота,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.МестоПроведенияРабот КАК МестоПроведенияРабот
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтыОборудования КАК торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования
	|ГДЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка В(&Ссылка)
	|	И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(Ответственный)
	|ПО
	|	Ссылка";

	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;

	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ЭтоПервый = Истина;

	Пока ВыборкаДокументов.Следующий() Цикл

		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл

			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;

			Шапка = Макет.ПолучитьОбласть("Шапка");

			Шапка.Параметры.Номер = ВыборкаДокументов.Номер;
			#Вставка
			Шапка.Параметры.Дата = ВыборкаДокументов.Дата + (СдвигЧП * 3600);
			#КонецВставки
			#Удаление
			Шапка.Параметры.Дата = ВыборкаДокументов.Дата;
			#КонецУдаления
			Шапка.Параметры.Организация = ВыборкаДокументов.Организация;
			Шапка.Параметры.Подразделение = ВыборкаДокументов.Подразделение;

			СписокТО = "";

			Для Каждого РемРаб Из ВыборкаДокументов.Ссылка.РемонтныеРаботы Цикл
				Если РемРаб.РемонтыОборудования_ID = ВыборкаРемонтов.ID
					И ТипЗнч(РемРаб.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда

					Если РемРаб.РемонтнаяРабота.НаименованиеДляПечати = "" Тогда
						НаименованиеРаботы = РемРаб.РемонтнаяРабота.Наименование;
					Иначе
						НаименованиеРаботы = РемРаб.РемонтнаяРабота.НаименованиеДляПечати;
					КонецЕсли;

					СписокТО = СписокТО + НаименованиеРаботы + ", ";
				КонецЕсли;
			КонецЦикла;

			Шапка.Параметры.ТехОперации = Лев(СписокТО, СтрДлина(СписокТО) - 2);

			ТабДок.Вывести(Шапка);	

			ТабСотрудники = Макет.ПолучитьОбласть("СтрокаЗаполнения");

			МассивИсполнителей = Новый Массив;

			Для Каждого Сотрудник Из ВыборкаДокументов.Ссылка.Исполнители Цикл
				Если Сотрудник.РемонтыОборудования_ID = ВыборкаРемонтов.ID
					И МассивИсполнителей.Найти(Сотрудник.Сотрудник) = Неопределено Тогда
					МассивИсполнителей.Добавить(Сотрудник.Сотрудник);
				КонецЕсли;
			КонецЦикла;

			Для Каждого Сотрудник Из МассивИсполнителей Цикл
				ТабСотрудники.Параметры.ФИО = Сотрудник;
				ТабДок.Вывести(ТабСотрудники);
			КонецЦикла;

			ТабЧасть0 = Макет.ПолучитьОбласть("Часть0");

			СписокРабот = "";

			Для Каждого РемРаб Из ВыборкаДокументов.Ссылка.РемонтныеРаботы Цикл
				Если РемРаб.РемонтыОборудования_ID = ВыборкаРемонтов.ID
					И ТипЗнч(РемРаб.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
					СписокРабот = СписокРабот + РемРаб.РемонтнаяРабота.СодержаниеРабот + ", ";
				КонецЕсли;
			КонецЦикла;

			ТабЧасть0.Параметры.СодержаниеРаботТО = Лев(СписокРабот, СтрДлина(СписокРабот) - 2);

			#Вставка
			ДатаНач = ВыборкаРемонтов.ДатаНачала + (СдвигЧП * 3600);
			ДатаКон = ВыборкаРемонтов.ДатаОкончания + (СдвигЧП * 3600);
			#КонецВставки
			#Удаление
			ДатаНач = ВыборкаРемонтов.ДатаНачала;
			ДатаКон = ВыборкаРемонтов.ДатаОкончания;
			#КонецУдаления

			ТабЧасть0.Параметры.НачЧас		= Строка(Час(ДатаНач));
			ТабЧасть0.Параметры.НачМин		= Строка(Минута(ДатаНач));
			ТабЧасть0.Параметры.НачДень		= Строка(День(ДатаНач));
			// >> [Деснол] [Ушаков А.Д.] [26.09.2019] 
			ТабЧасть0.Параметры.НачМесяц	= НазваниеМесяцаСтрокой_РодительныйПадеж(ДатаНач);
			//ТабЧасть0.Параметры.НачМесяц	= НазваниеМесяцаСтрокойПадежное(Месяц(ДатаНач), "Род");
			// << [Деснол] [Ушаков А.Д.] [26.09.2019] 
			ТабЧасть0.Параметры.НачГод		= Строка(Год(ДатаНач));

			ТабЧасть0.Параметры.КонЧас		= Строка(Час(ДатаКон));
			ТабЧасть0.Параметры.КонМин		= Строка(Минута(ДатаКон));
			ТабЧасть0.Параметры.КонДень		= Строка(День(ДатаКон));
			// >> [Деснол] [Ушаков А.Д.] [26.09.2019] 
			ТабЧасть0.Параметры.КонМесяц	= НазваниеМесяцаСтрокой_РодительныйПадеж(ДатаКон);
			//ТабЧасть0.Параметры.КонМесяц	= НазваниеМесяцаСтрокойПадежное(Месяц(ДатаКон), "Род");
			// << [Деснол] [Ушаков А.Д.] [26.09.2019] 
			ТабЧасть0.Параметры.КонГод		= Строка(Год(ДатаКон));

			ТабДок.Вывести(ТабЧасть0);

			Для Сч = 1 По 11 Цикл
				ТабЧасть = Макет.ПолучитьОбласть("Часть" + Сч);
				ТабДок.Вывести(ТабЧасть);
			КонецЦикла;

		КонецЦикла;
	КонецЦикла;

	ТабДок.ТолькоПросмотр = Истина;

	Возврат ТабДок;

КонецФункции

&ИзменениеИКонтроль("ПечатьНарядДопускНаПроведениеГазоопасныхРабот")
Функция Расш_гкс_ПечатьНарядДопускНаПроведениеГазоопасныхРабот(МассивОбъектов, ПараметрыПечати)

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "торо_НарядНаВыполнениеРемонтныхРабот";
	#Вставка
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	#КонецВставки

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_НарядДопускНаПроведениеГазоопасныхРабот");

	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботИсполнители.Сотрудник КАК Сотрудник,
	|	торо_НарядНаВыполнениеРемонтныхРаботИсполнители.Квалификация КАК Квалификация,
	|	МИНИМУМ(торо_НарядНаВыполнениеРемонтныхРаботИсполнители.ДатаНачала) КАК ДатаНачала,
	|	МАКСИМУМ(торо_НарядНаВыполнениеРемонтныхРаботИсполнители.ДатаОкончания) КАК ДатаОкончания,
	|	торо_НарядНаВыполнениеРемонтныхРаботИсполнители.РемонтыОборудования_ID КАК РемонтыОборудования_ID
	|ПОМЕСТИТЬ Исполнители
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.Исполнители КАК торо_НарядНаВыполнениеРемонтныхРаботИсполнители
	|ГДЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботИсполнители.Ссылка В(&Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	торо_НарядНаВыполнениеРемонтныхРаботИсполнители.Сотрудник,
	|	торо_НарядНаВыполнениеРемонтныхРаботИсполнители.Квалификация,
	|	торо_НарядНаВыполнениеРемонтныхРаботИсполнители.РемонтыОборудования_ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка КАК Ссылка,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Номер КАК Номер,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Дата КАК Дата,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Организация КАК Организация,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Ответственный КАК Ответственный,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID КАК ID,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОпаснаяРабота КАК ОпаснаяРабота,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.МестоПроведенияРабот КАК МестоПроведенияРабот,
	|	Исполнители.Сотрудник КАК Сотрудник,
	|	Исполнители.Квалификация КАК Квалификация,
	|	Исполнители.ДатаНачала КАК ДатаНачала,
	|	Исполнители.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтыОборудования КАК торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования
	|		ЛЕВОЕ СОЕДИНЕНИЕ Исполнители КАК Исполнители
	|		ПО торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID = Исполнители.РемонтыОборудования_ID
	|ГДЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка В(&Ссылка)
	|	И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(Ответственный)
	|ПО
	|	Ссылка,
	|	ID";

	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;

	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ЭтоПервый = Истина;

	Пока ВыборкаДокументов.Следующий() Цикл

		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ID");
		Пока ВыборкаРемонтов.Следующий() Цикл

			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;

			Шапка = Макет.ПолучитьОбласть("ШапкаДокумента");
			Шапка.Параметры.Номер = ВыборкаДокументов.Номер;
			#Вставка
			Шапка.Параметры.Дата = Формат(ВыборкаДокументов.Дата + (СдвигЧП * 3600),"ДФ=dd.MM.yyyy");
			#КонецВставки
			#Удаление
			Шапка.Параметры.Дата = Формат(ВыборкаДокументов.Дата,"ДФ=dd.MM.yyyy");
			#КонецУдаления
			ТабДок.Вывести(Шапка);

			ПерваяРемонтнаяРабота = Макет.ПолучитьОбласть("ПерваяРемонтнаяРабота");
			РемонтнаяРабота       = Макет.ПолучитьОбласть("РемонтнаяРабота");

			Отбор = Новый Структура;
			Отбор.Вставить("РемонтыОборудования_ID", ВыборкаРемонтов.ID);
			СтрокиТекущегоОтбора = ВыборкаДокументов.Ссылка.РемонтныеРаботы.НайтиСтроки(Отбор);

			ПерваяРабота = Истина;
			Для Каждого СтрокаОтбора Из СтрокиТекущегоОтбора Цикл
				Если ТипЗнч(СтрокаОтбора.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
					Если СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати = "" Тогда
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.Наименование;
					Иначе
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати;
					КонецЕсли;

					Если ПерваяРабота Тогда 
						ПерваяРемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ПерваяРабота = Ложь;
						ТабДок.Вывести(ПерваяРемонтнаяРабота);
					Иначе
						РемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ТабДок.Вывести(РемонтнаяРабота);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;

			Пункт4_10 = Макет.ПолучитьОбласть("Пункт4_10");
			ТабДок.Вывести(Пункт4_10);
			ШапкаТаблицыИсполнители = Макет.ПолучитьОбласть("ШапкаТаблицыИсполнители");
			ТабДок.Вывести(ШапкаТаблицыИсполнители);

			ПП = 0;
			ВыборкаРемонта = ВыборкаРемонтов.Выбрать(ОбходРезультатаЗапроса.Прямой); 
			Пока ВыборкаРемонта.Следующий() Цикл 

				СтрокаТаблицыИсполнители = Макет.ПолучитьОбласть("СтрокаТаблицыИсполнители");
				ПП = ПП+1;
				СтрокаТаблицыИсполнители.Параметры.Заполнить(ВыборкаРемонта);
				СтрокаТаблицыИсполнители.Параметры.ПП = ПП;
				#Вставка
				Шапка.Параметры.Дата = Формат(ВыборкаДокументов.Дата + (СдвигЧП * 3600),"ДФ=dd.MM.yyyy");
				СтрокаТаблицыИсполнители.Параметры.ДатаНачала = 
					СтрокаТаблицыИсполнители.Параметры.ДатаНачала  + (СдвигЧП * 3600);
				СтрокаТаблицыИсполнители.Параметры.ДатаОкончания = 
					СтрокаТаблицыИсполнители.Параметры.ДатаОкончания  + (СдвигЧП * 3600);
				#КонецВставки
				//Если ВыборкаРемонта.ДатаНачала <> Дата (1,1,1) Тогда 
				//	СтрокаТаблицыИсполнители.Параметры.ДатаВремя = Строка(ВыборкаРемонта.ДатаНачала);
				//КонецЕсли;
				ТабДок.Вывести(СтрокаТаблицыИсполнители);
			КонецЦикла;

			Пункт12_16 = Макет.ПолучитьОбласть("Пункт12_16");
			ТабДок.Вывести(Пункт12_16);

		КонецЦикла;
	КонецЦикла;

	ТабДок.ТолькоПросмотр = Истина;
	Возврат ТабДок;

КонецФункции

&ИзменениеИКонтроль("ПечатьНарядНаПроизводствоРаботПовышеннойОпасности")
Функция Расш_гкс_ПечатьНарядНаПроизводствоРаботПовышеннойОпасности(МассивОбъектов, ПараметрыПечати)

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "торо_НарядНаВыполнениеРемонтныхРабот";
	#Вставка
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	#КонецВставки

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_НарядНаПроизводствоРаботПовышеннойОпасности");

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка КАК Ссылка,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Номер КАК Номер,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Дата КАК Дата,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Организация КАК Организация,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Ответственный КАК Ответственный,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID КАК ID,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаНачала КАК ДатаНачала,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаОкончания КАК ДатаОкончания,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОпаснаяРабота КАК ОпаснаяРабота,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.МестоПроведенияРабот КАК МестоПроведенияРабот
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтыОборудования КАК торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования
	|ГДЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка В(&Ссылка)
	|	И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(Ответственный)
	|ПО
	|	Ссылка";

	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;

	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ЭтоПервый = Истина;

	Пока ВыборкаДокументов.Следующий() Цикл

		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл

			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;

			Шапка = Макет.ПолучитьОбласть("ШапкаДокумента");
			Шапка.Параметры.Организация = ВыборкаДокументов.Организация;
			Шапка.Параметры.ПодразделениеОрганизации = ВыборкаДокументов.Подразделение;

			#Вставка
			Шапка.Параметры.Дата = Формат(ВыборкаДокументов.Дата + (СдвигЧП * 3600),"ДФ=dd.MM.yyyy");
			#КонецВставки
			#Удаление
			Шапка.Параметры.Дата = Формат(ВыборкаДокументов.Дата,"ДФ=dd.MM.yyyy");
			#КонецУдаления
			Шапка.Параметры.Номер = ВыборкаДокументов.Номер;
			ТабДок.Вывести(Шапка);

			ПерваяРемонтнаяРабота = Макет.ПолучитьОбласть("ПерваяРемонтнаяРабота");
			РемонтнаяРабота       = Макет.ПолучитьОбласть("РемонтнаяРабота");

			Отбор = Новый Структура;
			Отбор.Вставить("РемонтыОборудования_ID", ВыборкаРемонтов.ID);
			СтрокиТекущегоОтбора = ВыборкаДокументов.Ссылка.РемонтныеРаботы.НайтиСтроки(Отбор);

			ПерваяРабота = Истина;
			Для Каждого СтрокаОтбора Из СтрокиТекущегоОтбора Цикл
				Если ТипЗнч(СтрокаОтбора.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
					Если СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати = "" Тогда
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.Наименование;
					Иначе
						НаименованиеРаботы = СтрокаОтбора.РемонтнаяРабота.НаименованиеДляПечати;
					КонецЕсли;

					Если ПерваяРабота Тогда 
						ПерваяРемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ПерваяРабота = Ложь;
						ТабДок.Вывести(ПерваяРемонтнаяРабота);
					Иначе
						РемонтнаяРабота.Параметры.РемонтнаяРабота = НаименованиеРаботы;
						ТабДок.Вывести(РемонтнаяРабота);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;	

			Пункт3_4 = Макет.ПолучитьОбласть("Пункт3_4");

			#Вставка
			ДатаНачала = ВыборкаРемонтов.ДатаНачала + (СдвигЧП * 3600);
			ДатаОкончания = ВыборкаРемонтов.ДатаОкончания + (СдвигЧП * 3600);
			#КонецВставки
			#Удаление
			ДатаНачала = ВыборкаРемонтов.ДатаНачала;
			ДатаОкончания = ВыборкаРемонтов.ДатаОкончания;
			#КонецУдаления

			Пункт3_4.Параметры.ЧасНачало	 =	Формат(ДатаНачала,"ДФ=HH");
			Пункт3_4.Параметры.МинутаНачало     =  Формат(ДатаНачала,"ДФ=мм");
			Пункт3_4.Параметры.ДатаНачало     =  Формат(ДатаНачала,"ДФ=dd.MM.yyyy");

			Пункт3_4.Параметры.ЧасОкончание	 =	Формат(ДатаОкончания,"ДФ=HH");
			Пункт3_4.Параметры.МинутаОкончание     =  Формат(ДатаОкончания,"ДФ=мм");
			Пункт3_4.Параметры.ДатаОкончание    =  Формат(ДатаОкончания,"ДФ=dd.MM.yyyy");

			ТабДок.Вывести(Пункт3_4);


			Пункт5_6 = Макет.ПолучитьОбласть("Пункт5_6");

			ТабДок.Вывести(Пункт5_6);

			СтрокаТаблицыИсполнители = Макет.ПолучитьОбласть("СтрокаТаблицыИсполнители");

			ТЗ = ВыборкаДокументов.Ссылка.Исполнители.Выгрузить(, "Сотрудник,Квалификация");
			ТЗ.Свернуть("Сотрудник,Квалификация");
			ПП = 0;

			Для Каждого Стр Из ТЗ Цикл
				ПП = ПП+1;
				СтрокаТаблицыИсполнители.Параметры.Заполнить(Стр);
				СтрокаТаблицыИсполнители.Параметры.ПП = ПП;
				ТабДок.Вывести(СтрокаТаблицыИсполнители);
			КонецЦикла;

			Пункт7_11 = Макет.ПолучитьОбласть("Пункт7_11");
			ТабДок.Вывести(Пункт7_11);

		КонецЦикла;
	КонецЦикла;

	ТабДок.ТолькоПросмотр = Истина;
	Возврат ТабДок;

КонецФункции

// гкс+ [7729] Тарасов 28.09.2020
Функция ПечатьЗаказНаРаботу(МассивОбъектов, ПараметрыПечати)
	
	Макет  = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_ЗаявкаНаРемонт.ПФ_MXL_дс_ЗаказНаРаботу");
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Шапка 		= Макет.ПолучитьОбласть("Шапка");
	ШапкаРР 	= Макет.ПолучитьОбласть("ШапкаРР");
	ШапкаРР2 	= Макет.ПолучитьОбласть("ШапкаРР2");
	СтрокаРР 	= Макет.ПолучитьОбласть("СтрокаРР");
	ПодвалРР 	= Макет.ПолучитьОбласть("ПодвалРР");
	Подвал 		= Макет.ПолучитьОбласть("Подвал");
	// гкс+ [Печатка] Куст 27.10.2020
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования.ДокументОснование КАК ДокументОснование
		|	,торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ДокументыЗаявкаНаРемонт
		|ИЗ
		|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.ДокументыОснования КАК торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования
		|ГДЕ
		|	торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования.Ссылка В(&МассивОбъектов)
		|	И ТИПЗНАЧЕНИЯ(торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования.ДокументОснование) = ТИП(Документ.торо_ЗаявкаНаРемонт)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗаявкаНаРемонтРемонтыОборудования.Ссылка КАК Документ,
		|	ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Организация КАК Организация,
		|	ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта.Организация КАК ОрганизацияПолучатель,
		|	ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Номер КАК Номер,
		|	ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
		|	ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
		|	ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта.ТехНомер КАК ТехНомерОР,
		|	ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта.ИнвентарныйНомер КАК ИнвентарныйНомерОР,
		|	ВЫРАЗИТЬ(ЗаявкаНаРемонтРемонтыОборудования.ОписаниеРемонта КАК СТРОКА(1000)) КАК ОписаниеРемонта,
		|	ЗаявкаНаРемонтРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
		|	ЗаявкаНаРемонтРемонтыОборудования.ID КАК ID
		|	,ВТ_ДокументыЗаявкаНаРемонт.Ссылка КАК Наряд
		|ПОМЕСТИТЬ ВТ_РемонтыОборудования
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК ЗаявкаНаРемонтРемонтыОборудования
		|	Внутреннее соединение ВТ_ДокументыЗаявкаНаРемонт КАК ВТ_ДокументыЗаявкаНаРемонт
		|	ПО ВТ_ДокументыЗаявкаНаРемонт.ДокументОснование = ЗаявкаНаРемонтРемонтыОборудования.Ссылка
		|ГДЕ ЗаявкаНаРемонтРемонтыОборудования.ID В(&ID)
		|	 " + " ; " ;
	ТекИерархия = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
	Если ТекИерархия.ИзменяетсяДокументами Тогда 
		Запрос.Текст = Запрос.Текст + "
		|	ВЫБРАТЬ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии КАК ОР,
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии КАК Родитель
		|Поместить ТекИерархия
		|ИЗ
		|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(,
		|СтруктураИерархии = &СтруктураИерархии) КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних
		|ГДЕ
		|торо_РасположениеОРВСтруктуреИерархииСрезПоследних.Удален = ЛОЖЬ	" + " ; " ;
	Иначе
		Запрос.Текст = Запрос.Текст + "
		|	ВЫБРАТЬ
		|	Рег.ОбъектИерархии КАК ОР,
		|	Рег.РодительИерархии КАК Родитель
		|Поместить ТекИерархия
		|ИЗ
		|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК Рег
		|ГДЕ Рег.СтруктураИерархии = &СтруктураИерархии
		|	" + " ; " ;
	КонецЕсли;
	Запрос.Текст = Запрос.Текст 
+ "ВЫБРАТЬ
  |	Выбор когда ТЧ.ОР.ЭтоАктив Тогда ТЧ.ОР иначе ТЧ.Родитель конец КАК Родитель,
  |	ТЧ.ОР.ЭтоАктив ИЛИ (ТЧ.Родитель.ЭтоАктив
  |		И ТЧ.ОР.ИнвентарныйНомер = ТЧ.Родитель.ИнвентарныйНомер) КАК ЭтоАктив,
  |	ТЧ.ОР.ИнвентарныйНомер КАК ИН,
  |	ТЧ.ОР КАК ОР
  |ПОМЕСТИТЬ Уровень1
  |ИЗ
  |	ТекИерархия КАК ТЧ
