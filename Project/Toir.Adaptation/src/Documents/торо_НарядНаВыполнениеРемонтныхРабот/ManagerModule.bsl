	|	NULL КАК РуководительРабот,
	|	NULL КАК ИсполнительРабот
	|ПОМЕСТИТЬ ОтветственныеБезГруппировки
	|ИЗ
	|	ВсеОтветственныеДокументы КАК ВсеОтветственныеДокументы
	|ГДЕ
	|	ВсеОтветственныеДокументы.ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.торо_ОтветственныеЛица.Допускающий)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВсеОтветственныеДокументы.Ссылка,
	|	NULL,
	|	ВсеОтветственныеДокументы.Сотрудник,
	|	NULL
	|ИЗ
	|	ВсеОтветственныеДокументы КАК ВсеОтветственныеДокументы
	|ГДЕ
	|	ВсеОтветственныеДокументы.ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.торо_ОтветственныеЛица.РуководительРабот)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВсеОтветственныеДокументы.Ссылка,
	|	NULL,
	|	NULL,
	|	ВсеОтветственныеДокументы.Сотрудник
	|ИЗ
	|	ВсеОтветственныеДокументы КАК ВсеОтветственныеДокументы
	|ГДЕ
	|	ВсеОтветственныеДокументы.ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.торо_ОтветственныеЛица.ИсполнительРабот)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтветственныеБезГруппировки.Ссылка КАК Ссылка,
	|	МАКСИМУМ(ОтветственныеБезГруппировки.Допускающий) КАК Допускающий,
	|	МАКСИМУМ(ОтветственныеБезГруппировки.РуководительРабот) КАК РуководительРабот,
	|	МАКСИМУМ(ОтветственныеБезГруппировки.ИсполнительРабот) КАК ИсполнительРабот
	|ПОМЕСТИТЬ ОтвДокументов
	|ИЗ
	|	ОтветственныеБезГруппировки КАК ОтветственныеБезГруппировки
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтветственныеБезГруппировки.Ссылка
