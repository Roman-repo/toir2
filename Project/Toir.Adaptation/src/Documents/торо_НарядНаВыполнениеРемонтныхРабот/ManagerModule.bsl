	тчМатЗатраты.Свернуть("Наименование, Характеристика, ЕдИзм, КодНСИ", "Количество");
	тчИнструменты.Свернуть("Наименование, ЕдИзм, КодНСИ", "Количество");
	// гкс- [10.22] Деснол 11.10.2022
	#КонецВставки

