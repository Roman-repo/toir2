	|	ВсеОтветственныеДокументы.Ссылка КАК Ссылка,
	|	ВсеОтветственныеДокументы.Сотрудник КАК Допускающий,
	|	NULL КАК РуководительРабот,
	|	NULL КАК ИсполнительРабот,
	|	NULL КАК ОтветственныйЗаПодготовку
	|ПОМЕСТИТЬ ОтветственныеБезГруппировки
	|ИЗ
	|	ВсеОтветственныеДокументы КАК ВсеОтветственныеДокументы
	|ГДЕ
	|	ВсеОтветственныеДокументы.ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.торо_ОтветственныеЛица.Допускающий)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВсеОтветственныеДокументы.Ссылка,
	|	NULL,
	|	ВсеОтветственныеДокументы.Сотрудник,
	|	NULL
	|	,NULL
	|ИЗ
	|	ВсеОтветственныеДокументы КАК ВсеОтветственныеДокументы
	|ГДЕ
	|	ВсеОтветственныеДокументы.ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.торо_ОтветственныеЛица.РуководительРабот)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВсеОтветственныеДокументы.Ссылка,
	|	NULL,
	|	NULL,
	|	ВсеОтветственныеДокументы.Сотрудник
	|	,NULL
	|ИЗ
	|	ВсеОтветственныеДокументы КАК ВсеОтветственныеДокументы
	|ГДЕ
	|	ВсеОтветственныеДокументы.ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.торо_ОтветственныеЛица.ИсполнительРабот)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВсеОтветственныеДокументы.Ссылка,
	|	NULL,
	|	NULL,
	|	NULL,
	|	ВсеОтветственныеДокументы.Сотрудник
	|ИЗ
	|	ВсеОтветственныеДокументы КАК ВсеОтветственныеДокументы
	|ГДЕ
	|	ВсеОтветственныеДокументы.ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.торо_ОтветственныеЛица.ОтветственныйЗаПодготовкуОбъекта)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтветственныеБезГруппировки.Ссылка КАК Ссылка,
	|	МАКСИМУМ(ОтветственныеБезГруппировки.Допускающий) КАК Допускающий,
	|	МАКСИМУМ(ОтветственныеБезГруппировки.РуководительРабот) КАК РуководительРабот,
	|	МАКСИМУМ(ОтветственныеБезГруппировки.ИсполнительРабот) КАК ИсполнительРабот,
	|	МАКСИМУМ(ОтветственныеБезГруппировки.ОтветственныйЗаПодготовку) КАК ОтветственныйЗаПодготовку
	|ПОМЕСТИТЬ ОтвДокументов
	|ИЗ
	|	ОтветственныеБезГруппировки КАК ОтветственныеБезГруппировки
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтветственныеБезГруппировки.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеДокументы.Ссылка КАК Ссылка,
	|	ЕстьNull(ННД.НомерТекст, ВсеДокументы.Номер) КАК Номер,
	|	ВсеДокументы.Ссылка.гкс_РежимРаботы КАК РежимРаботы,
	|	ВсеДокументы.Ссылка.гкс_ОсобыеУсловия КАК ОсобыеУсловия,
	|	ВсеДокументы.Дата КАК Дата,
	|	ВсеДокументы.Организация КАК Организация,
	|	ВсеДокументы.Подразделение КАК Подразделение,
	|	ВсеДокументы.Ответственный КАК Ответственный,
	|	ВсеДокументы.ID КАК ИД,
	|	ВсеДокументы.ОбъектРемонта КАК ОР,
	|	ВсеДокументы.ОбъектРемонта.Подразделение КАК ПодразделениеВладелец,
	|	ВсеДокументы.ВидРемонтныхРабот КАК ВР,
	|	ВсеДокументы.ДатаНачала КАК ДатаНачала,
	|	ВсеДокументы.ДатаОкончания КАК ДатаОкончания,
	|	ВсеДокументы.ОпаснаяРабота КАК ОпаснаяРабота,
	|	ВсеДокументы.МестоПроведенияРабот КАК МестоПроведенияРабот,
	|	ОтвДокументов.Допускающий КАК Допускающий,
	|	ОтвДокументов.РуководительРабот КАК РуководительРабот,
	|	ОтвДокументов.ИсполнительРабот КАК ИсполнительРабот,
	|	ОтвДокументов.ОтветственныйЗаПодготовку КАК ОтветственныйЗаПодготовку
	
	|ИЗ
	|	ВсеДокументы КАК ВсеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОтвДокументов КАК ОтвДокументов
	|		ПО ВсеДокументы.Ссылка = ОтвДокументов.Ссылка
	|		левое соединение РегистрСведений.гкс_НомераНарядДопусков КАК ННД
	|		ПО ННД.Документ = ВсеДокументы.Ссылка
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(Ответственный)
	|ПО
	|	Ссылка
	|;
	|Выбрать Различные
	|ТЧ.Сотрудник КАК Сотрудник,
	|ТЧ.Ссылка КАК Ссылка, ТЧ.РемонтыОборудования_ID КАК ИД, ТЧ.Квалификация КАК Квалификация
	// гкс+ [разработка 2021] Куст 08.07.2021
	|	, ТЧ.гкс_СотрудникКонтрагента КАК гкс_СотрудникКонтрагента
	// гкс- [разработка 2021] Куст 08.07.2021
	|ИЗ
	|	ВсеДокументы КАК ВсеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_НарядНаВыполнениеРемонтныхРабот.Исполнители КАК ТЧ
	|		ПО ВсеДокументы.Ссылка = ТЧ.Ссылка
	|Итоги ПО Ссылка, ИД
	|;
	|Выбрать Различные
	|ТЧ.Ссылка КАК Ссылка, ТЧ.НомерСтроки КАК НомерСтроки,
	|	ТЧ.Исполнитель КАК Контрагент, ТЧ.РемонтыОборудования_ID КАК ИД
	|
	|	ИЗ	
	|	ВсеДокументы КАК ВсеДокументы
	|	Внутреннее соединение Документ.торо_НарядНаВыполнениеРемонтныхРабот.ИсполнителиПоРемонтам КАК ТЧ
	|	ПО ТЧ.Ссылка = ВсеДокументы.Ссылка
	|Упорядочить по ТЧ.НомерСтроки	
	|Итоги ПО Ссылка, ИД
	|;
	| Выбрать Различные 
	|ТЧ.Ссылка КАК Ссылка, ТЧ.РемонтыОборудования_ID КАК ИД, ТЧ.РемонтнаяРабота КАК РР, ТЧ.НомерСтроки КАК НомерСтроки
	|
	|	ИЗ	
	|	ВсеДокументы КАК ВсеДокументы
	|	Внутреннее соединение Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтныеРаботы КАК ТЧ
	|	ПО ТЧ.Ссылка = ВсеДокументы.Ссылка
	|Упорядочить По ТЧ.НомерСтроки
	|Итоги ПО Ссылка, ИД
	|;  
	|Выбрать 
	|ТЧ.Ссылка КАК Ссылка, ТЧ.НомерСтроки КАК НомерСтроки, 1 КАК Приоритет,
	|	ТЧ.Мероприятие КАК Мероприятие
	|
	|	ИЗ	
	|	ВсеДокументы КАК ВсеДокументы
	|	Внутреннее соединение Документ.торо_НарядНаВыполнениеРемонтныхРабот.гкс_МПОБДо КАК ТЧ
	|	ПО ТЧ.Ссылка = ВсеДокументы.Ссылка
	|
	|Объединить все
	|
	|Выбрать 
	|ТЧ.Ссылка, ТЧ.НомерСтроки, 2 ,
	|	ТЧ.Мероприятие
	|
	|	ИЗ	
	|	ВсеДокументы КАК ВсеДокументы
	|	Внутреннее соединение Документ.торо_НарядНаВыполнениеРемонтныхРабот.гкс_МПОБВоВремя КАК ТЧ
	|	ПО ТЧ.Ссылка = ВсеДокументы.Ссылка
	|
	|Упорядочить по Приоритет, ТЧ.НомерСтроки	
	|Итоги ПО Ссылка
	|;
	|Выбрать Различные ТЧ.Сотрудник
	|Поместить РазличныеСотрудники
	|ИЗ ВсеОтветственныеДокументы КАК ТЧ
	|;
	|Выбрать
	|ТЧ.Сотрудник, Максимум(Рег.ТекущаяДолжность) КАК Должность
	|
	|ИЗ РазличныеСотрудники КАК ТЧ
	|	Внутреннее соединение РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК Рег
	|	По Рег.Сотрудник = ТЧ.Сотрудник
	|Сгруппировать по ТЧ.Сотрудник
	|
	|
	|
	|";
	
	
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов); 
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТЧ.ID В(&ID)", "");
	КонецЕсли;
	
	ПервыйПакет = 4;
	ВторойПакет = ПервыйПакет + 1;
	ТретийПакет = ВторойПакет + 1;
	РемРаботыПакет = ТретийПакет + 1;
	МероприятияПакет = РемРаботыПакет + 1;
	ДолжностиПакет = МероприятияПакет + 2;
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ВыборкаДокументов = РезультатЗапроса[ПервыйПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ВыборкаИсполнители = РезультатЗапроса[ВторойПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаКонтрагенты = РезультатЗапроса[ТретийПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаРР = РезультатЗапроса[РемРаботыПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМероприятия = РезультатЗапроса[МероприятияПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаДолжности = РезультатЗапроса[ДолжностиПакет].Выбрать();
	
	ЭтоПервый = Истина;
	
	Пока ВыборкаДокументов.Следующий() Цикл
		
		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл
			
			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;
			СтрПоиска = Новый Структура("Ссылка,ИД", ВыборкаДокументов.Ссылка, ВыборкаРемонтов.ИД);
			СтрПоискаОбщая = Новый Структура("Ссылка", ВыборкаДокументов.Ссылка);
			
			Шапка = Макет.ПолучитьОбласть("Шапка");
			Шапка.Параметры.Номер = ВыборкаДокументов.Номер;
			Шапка.Параметры.Подразделение = ВыборкаРемонтов.ПодразделениеВладелец;
			Шапка.Параметры.Организация = ВыборкаРемонтов.Организация;
			Шапка.Параметры.ОР = ВыборкаРемонтов.ОР;
			
			ВыборкаДолжности.Сбросить();
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.ОтветственныйЗаПодготовку) Тогда 
				Шапка.Параметры.ОтветственныйЗаПодготовку = Строка(ВыборкаДолжности.Должность) + " " + ВыборкаРемонтов.ОтветственныйЗаПодготовку;
			Иначе
				Шапка.Параметры.ОтветственныйЗаПодготовку = ВыборкаРемонтов.ОтветственныйЗаПодготовку;
			КонецЕсли;
			ВыборкаДолжности.Сбросить();
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.РуководительРабот) Тогда 
				Шапка.Параметры.РуководительРабот = Строка(ВыборкаДолжности.Должность) + " " + ВыборкаРемонтов.РуководительРабот;
			Иначе
				Шапка.Параметры.РуководительРабот = ВыборкаРемонтов.РуководительРабот;
			КонецЕсли;
			
			//
			ВыборкаКонтрагенты.Сбросить();
			ЭтоКонтрагент = Ложь;
			Если ВыборкаКонтрагенты.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Выборка.Следующий();
						ЭтоКонтрагент = ТипЗнч(Выборка.Контрагент) = Тип("СправочникСсылка.Контрагенты");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			//
			ВыборкаРР.Сбросить();
			Если ВыборкаРР.НайтиСледующий(СтрПоискаОбщая) Тогда 
				МассивТК = Новый Массив();
				ВыборкаР = ВыборкаРР.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							Если ТипЗнч(Выборка.РР) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда 
								МассивТК.Добавить(Выборка.РР);
							КонецЕсли;
						КонецЦикла;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Шапка.Параметры.ТК = СтрСоединить(МассивТК, ", ");
			КонецЕсли;
			
			Шапка.Параметры.Мероприятия1 = "";
			//
			ВыборкаМероприятия.Сбросить();
			МассивСтрок2 = Новый Массив();
			Если ВыборкаМероприятия.НайтиСледующий(СтрПоискаОбщая) Тогда 
				МассивСтрок1 = Новый Массив();
				Выборка = ВыборкаМероприятия.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если Выборка.Приоритет = 1 Тогда 
						МассивСтрок1.Добавить(Выборка.Мероприятие);
					Иначе
						МассивСтрок2.Добавить(Выборка.Мероприятие);
					КонецЕсли;
				КонецЦикла;
				Шапка.Параметры.Мероприятия1 = СтрСоединить(МассивСтрок1, "" + Символы.ПС);
			КонецЕсли;
			Шапка.Параметры.ДатаНачала = Формат(ВыборкаРемонтов.ДатаНачала, "ДФ=""ЧЧ 'ч.' мм 'мин.' дд ММММ гггг 'г.'""");
			Шапка.Параметры.ДатаОкончания = Формат(ВыборкаРемонтов.ДатаОкончания, "ДФ=""ЧЧ 'ч.' мм 'мин.' дд ММММ гггг 'г.'""");
			//
			ТабДок.Вывести(Шапка);
			
			СтрокаТЧ1 = Макет.ПолучитьОбласть("СтрокаТЧ1");
			СтрокаТЧ2 = Макет.ПолучитьОбласть("СтрокаТЧ2");
			НомерПП = 1;
			Для Каждого СтрокаМассива Из МассивСтрок2 Цикл
				СтрокаТЧ1.Параметры.НомерПП = НомерПП;
				СтрокаТЧ1.Параметры.Мероприятие = СтрокаМассива;
				ТабДок.Вывести(СтрокаТЧ1);
				НомерПП = НомерПП + 1;
			КонецЦикла;
			
			Шапка2 = Макет.ПолучитьОбласть("Шапка2");
			ТабДок.Вывести(Шапка2);
			ВыборкаИсполнители.Сбросить();
			Если ВыборкаИсполнители.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						НомерПП = 1;
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							// гкс+ [разработка 2021] Куст 08.07.2021
							Если ЭтоКонтрагент Тогда 
								СтрокаТЧ2.Параметры.НомерПП = НомерПП;
								СтрокаТЧ2.Параметры.Сотрудник = Выборка.гкс_СотрудникКонтрагента;
							Иначе
							// гкс- [разработка 2021] Куст 08.07.2021
								СтрокаТЧ2.Параметры.НомерПП = НомерПП;
								СтрокаТЧ2.Параметры.Сотрудник = Выборка.Сотрудник;
							КонецЕсли;
							ТабДок.Вывести(СтрокаТЧ2);
							НомерПП = НомерПП + 1;
						КонецЦикла;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Подвал = Макет.ПолучитьОбласть("Подвал");
			ТабДок.Вывести(Подвал);
		КонецЦикла;
	КонецЦикла;
	
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.ТолькоПросмотр = Истина;
	Возврат ТабДок;
	
КонецФункции
