Функция гкс_ПечатьНарядНаОгневыеРаботы(МассивОбъектов, ПараметрыПечати)
	
	ТабДок = Новый ТабличныйДокумент;
	// гкс+ [разработка 2021] Куст 07.05.2021
	ТабДок.АвтоМасштаб = Истина;
	// гкс- [разработка 2021] Куст 07.05.2021
	ТабДок.ИмяПараметровПечати = "торо_НарядНаВыполнениеРемонтныхРабот";
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_гкс_НарядНаОгневыеРаботы");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Док.Ссылка КАК Ссылка,
	|	Док.Ссылка.Номер КАК Номер,
	|	Док.Ссылка.Дата КАК Дата,
	|	Док.Ссылка.Организация КАК Организация,
	|	Док.Ссылка.Подразделение КАК Подразделение,
	|	Док.Ссылка.Ответственный КАК Ответственный,
	|	Док.ID КАК ID,
	|	Док.ОбъектРемонта КАК ОбъектРемонта,
	|	Док.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	Док.ДатаНачала КАК ДатаНачала,
	|	Док.ДатаОкончания КАК ДатаОкончания,
	|	Док.ОпаснаяРабота КАК ОпаснаяРабота,
	|	Док.МестоПроведенияРабот КАК МестоПроведенияРабот
	|ПОМЕСТИТЬ ВсеДокументы
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтыОборудования КАК Док
	|ГДЕ
	|	Док.Ссылка В(&Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВсеДокументы.Ссылка КАК Ссылка,
	|	Ответственные.ОтветственноеЛицо КАК ОтветственноеЛицо,
	|	МАКСИМУМ(Ответственные.Сотрудник) КАК Сотрудник
	|ПОМЕСТИТЬ ВсеОтветственныеДокументы
	|ИЗ
	|	ВсеДокументы КАК ВсеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_НарядНаВыполнениеРемонтныхРабот.Ответственные КАК Ответственные
	|		ПО (Ответственные.Ссылка = ВсеДокументы.Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВсеДокументы.Ссылка,
	|	Ответственные.ОтветственноеЛицо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеОтветственныеДокументы.Ссылка КАК Ссылка,
	|	ВсеОтветственныеДокументы.Сотрудник КАК Допускающий,
