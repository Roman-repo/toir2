				ПроверитьИВывести(ТабДок, обСотрудник);

			КонецЦикла;

			Если ПерваяСтрока Тогда
				ТабДок.Вывести(обШапка);
			КонецЕсли;

			ВывестиРемонты(Макет, ТабДок, тчРемРаботы, ВыборкаРемонтов, ИмяПФ);

			#Вставка
			// гкс+ [10.22] Деснол 11.10.2022
			гкс_Подвал = Макет.ПолучитьОбласть("гкс_Подвал");
			ТабДок.Вывести(гкс_Подвал);
			// гкс- [10.22] Деснол 11.10.2022
			#КонецВставки
			обОтветственный = Макет.ПолучитьОбласть("Ответственный");
			обОтветственный.Параметры.Сотрудник = ВыборкаДокументов.Ответственный;
			обОтветственный.Параметры.Дата = Формат(ТекущаяДата(),"ДФ='''""''dd''""'' MMMM yyyy ""г.""'");
			ПроверитьИВывести(ТабДок, обОтветственный);
			
			ПерваяСтрока = Истина;
			обИсполнительСЗаголовоком = Макет.ПолучитьОбласть("ИсполнительСЗаголовоком");

			тчСотрудникиИКвалификация.Сбросить();
			Пока тчСотрудникиИКвалификация.Следующий() Цикл
				Если ПерваяСтрока Тогда
					ПерваяСтрока = Ложь;
					обИсполнительСЗаголовоком.Параметры.Сотрудник = тчСотрудникиИКвалификация.Сотрудник;
					обИсполнительСЗаголовоком.Параметры.Дата = Формат(ТекущаяДата(),"ДФ='''""''dd''""'' MMMM yyyy ""г.""'");
					ПроверитьИВывести(ТабДок, обИсполнительСЗаголовоком);
					Продолжить;
				КонецЕсли;

				обИсполнитель = Макет.ПолучитьОбласть("Исполнитель");
				обИсполнитель.Параметры.Сотрудник = тчСотрудникиИКвалификация.Сотрудник;
				обИсполнитель.Параметры.дата = Формат(ТекущаяДата(),"ДФ='''""''dd''""'' MMMM yyyy ""г.""'");
				ПроверитьИВывести(ТабДок, обИсполнитель);
			КонецЦикла;

			Если ПерваяСтрока Тогда
				ПроверитьИВывести(ТабДок, обИсполнительСЗаголовоком);
			КонецЕсли;

		КонецЦикла;
	КонецЦикла;

	Возврат ТабДок;

КонецФункции

&ИзменениеИКонтроль("ВывестиРекурсивно")
Процедура Расш_гкс_ВывестиРекурсивно(Макет, ТЧ, Мас, ТабДок, ИмяОбластиВМакете, НомерРодителя)

	НомерСтроки = 1;
	Для каждого текСтрока из Мас Цикл
		НомерСтрокой = НомерРодителя + Строка(НомерСтроки);

		обСтрокаТЧСостав = Макет.ПолучитьОбласть(ИмяОбластиВМакете);
		обСтрокаТЧСостав.Параметры.Ном = НомерСтрокой;
		#Удаление
		обСтрокаТЧСостав.Параметры.Наименование = текСтрока.РемонтнаяРаботаДляПечати;
		#КонецУдаления
		#Вставка
		обСтрокаТЧСостав.Параметры.Наименование = текСтрока.РемонтнаяРаботаДляПечати + " " 
			+ текСтрока.гкс_Примечание;
		// гкс+ [разработка 2021] Куст 05.05.2021
		обСтрокаТЧСостав.Параметры.Исполнитель = текСтрока.Исполнитель;
		// гкс- [разработка 2021] Куст 05.05.2021
		#КонецВставки
		обСтрокаТЧСостав.Параметры.СодержаниеРабот = текСтрока.СодержаниеРабот;
		обСтрокаТЧСостав.Параметры.Количество = текСтрока.Количество;
		#Удаление
		обСтрокаТЧСостав.Параметры.ЕдИзм = текСтрока.ЕдИзм;
		#КонецУдаления
		ПроверитьИВывести(ТабДок, обСтрокаТЧСостав);

		подСтроки = тч.НайтиСтроки(Новый структура("Родитель_ID", текСтрока.ID));
		ВывестиРекурсивно(Макет, тч, подСтроки, ТабДок, ИмяОбластиВМакете, НомерСтрокой + ".");
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;

КонецПроцедуры

&ИзменениеИКонтроль("НарядНаРаботы_ОднимДокументом")
Функция Расш_гкс_НарядНаРаботы_ОднимДокументом(МассивОбъектов, ПараметрыПечати)

	ТабДок = Новый ТабличныйДокумент;
	#Вставка
	// гкс+ [разработка 2021] Куст 07.05.2021
	ТабДок.АвтоМасштаб = Истина;
	// гкс- [разработка 2021] Куст 07.05.2021
	#КонецВставки
	ТабДок.ИмяПараметровПечати = "торо_НарядНаВыполнениеРемонтныхРабот";
	ТабДок.ТолькоПросмотр = Истина;

	#Удаление
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_НарядНаРаботы_ОднимДокументом");
	#КонецУдаления
	#Вставка
	// гкс+ [10.22] Деснол 11.10.2022
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_НарядНаВыполнениеРемонтныхРабот.ПФ_MXL_гкс_НарядНаРаботы_ОднимДокументом");
	// гкс- [10.22] Деснол 11.10.2022
	#КонецВставки

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка КАК Ссылка,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Номер КАК Номер,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Дата КАК Дата,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Организация КАК Организация,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка.Ответственный КАК Ответственный,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID КАК ID,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта.Наименование КАК Наименование,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта.АдресМестонахождения КАК АдресМестонахождения,
	#Вставка
	// гкс+ [10.22] Деснол 11.10.2022
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОбъектРемонта.ТехНомер КАК ТехНомер,
	// гкс- [10.22] Деснол 11.10.2022
	#КонецВставки
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаНачала КАК ДатаНачала,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДатаОкончания КАК ДатаОкончания,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ОпаснаяРабота КАК ОпаснаяРабота,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.МестоПроведенияРабот КАК МестоПроведенияРабот,
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ДокументИсточник КАК ДокументИсточник
	|ИЗ
	|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтыОборудования КАК торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования
	|ГДЕ
	|	торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.Ссылка В(&Ссылка)
	|	И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(Ответственный)
	|ПО
	|	Ссылка";

	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И торо_НарядНаВыполнениеРемонтныхРаботРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;

	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");

	Пока ВыборкаДокументов.Следующий() Цикл

		обШапка = Макет.ПолучитьОбласть("Шапка");

		обШапка.Параметры.Организация = ВыборкаДокументов.Организация;
		обШапка.Параметры.Подразделение = ВыборкаДокументов.Подразделение;

		обШапка.Параметры.ДатаОткрытия = Формат(ВыборкаДокументов.Дата,"ДФ=dd.MM.yyyy");
		обШапка.Параметры.Номер = ВыборкаДокументов.Номер;

		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Исполнители.Сотрудник КАК Сотрудник,
		|	Исполнители.Квалификация КАК Квалификация
		|ИЗ
		|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.Исполнители КАК Исполнители
		|ГДЕ
		|	Исполнители.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	Исполнители.Сотрудник,
		|	Исполнители.Квалификация";

		Запрос.УстановитьПараметр("Ссылка", ВыборкаДокументов.Ссылка);
		Результат = Запрос.Выполнить();
		тчСотрудникиИКвалификация = Результат.Выбрать();

		ПерваяСтрока = Истина;
		Пока тчСотрудникиИКвалификация.Следующий() Цикл
			Если ПерваяСтрока Тогда
				ПерваяСтрока = Ложь;
				обШапка.Параметры.СотрудникИКвалификация = Строка(тчСотрудникиИКвалификация.Сотрудник) + " (" + тчСотрудникиИКвалификация.Квалификация + ")";
				обШапка.Параметры.Сотрудник = тчСотрудникиИКвалификация.Сотрудник;
				ТабДок.Вывести(обШапка);
				Продолжить;
			КонецЕсли;

			обСотрудник = Макет.ПолучитьОбласть("Сотрудник");
			обСотрудник.Параметры.СотрудникИКвалификация = Строка(тчСотрудникиИКвалификация.Сотрудник) + " (" + тчСотрудникиИКвалификация.Квалификация + ")";
			обСотрудник.Параметры.Сотрудник = тчСотрудникиИКвалификация.Сотрудник;

			ПроверитьИВывести(ТабДок, обСотрудник);

		КонецЦикла;

		Если ПерваяСтрока Тогда
			ТабДок.Вывести(обШапка);
		КонецЕсли;

		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл

			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ВЫБОР
			|		КОГДА тчРемонтныеРаботы.РемонтнаяРабота ССЫЛКА Справочник.торо_ТехнологическиеОперации
			|			ТОГДА ВЫБОР
			|					КОГДА тчРемонтныеРаботы.РемонтнаяРабота.НаименованиеДляПечати = """"
			|						ТОГДА тчРемонтныеРаботы.РемонтнаяРабота.Наименование
			|					ИНАЧЕ тчРемонтныеРаботы.РемонтнаяРабота.НаименованиеДляПечати
			|				  КОНЕЦ
			|		ИНАЧЕ тчРемонтныеРаботы.РемонтнаяРабота.Наименование
			|	КОНЕЦ КАК РемонтнаяРаботаДляПечати,
			|	тчРемонтныеРаботы.РемонтнаяРабота КАК РемонтнаяРабота,
			|	ЕСТЬNULL(тчРемонтныеРаботы.РемонтнаяРабота.СодержаниеРабот, """") КАК СодержаниеРабот,
			|	тчРемонтныеРаботы.Родитель_ID КАК Родитель_ID,
			#Вставка
			|	тчРемонтныеРаботы.гкс_Примечание КАК гкс_Примечание,
			|	Выразить("""" КАК Строка(500)) КАК Исполнитель,
			#КонецВставки
			|	тчРемонтныеРаботы.ID КАК ID,
			|	торо_ТехнологическиеОперации.БазоваяЕдиницаИзмерения КАК ЕдИзм,
			|	тчРемонтныеРаботы.Количество КАК Количество
			|ИЗ
			|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.РемонтныеРаботы КАК тчРемонтныеРаботы
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТехнологическиеОперации КАК торо_ТехнологическиеОперации
			|		ПО тчРемонтныеРаботы.РемонтнаяРабота = торо_ТехнологическиеОперации.Ссылка
			|ГДЕ
			|	тчРемонтныеРаботы.Ссылка = &Ссылка
			|	И тчРемонтныеРаботы.РемонтыОборудования_ID = &ID
			|
			|УПОРЯДОЧИТЬ ПО
			|	Родитель_ID";				   
			#Вставка
			Запрос.Текст = Запрос.Текст + " ; "
			+ "Выбрать Различные
			|ДокТЧ.Сотрудник КАК Сотрудник,
			|ДокТЧ.ID КАК ID
			|ИЗ
			|	Документ.торо_НарядНаВыполнениеРемонтныхРабот.Исполнители КАК ДокТЧ
			|ГДЕ
			|	ДокТЧ.Ссылка = &Ссылка
			|	И ДокТЧ.РемонтыОборудования_ID = &ID
			|Итоги по ID";
			#КонецВставки

			Запрос.УстановитьПараметр("Ссылка", ВыборкаДокументов.Ссылка);
			Запрос.УстановитьПараметр("Дата", ВыборкаДокументов.Дата);
			Запрос.УстановитьПараметр("ID", ВыборкаРемонтов.ID);
			#Удаление
			Результат = Запрос.Выполнить();

			тчРемРаботы = Результат.Выгрузить();
			#КонецУдаления
			#Вставка
			Результат = Запрос.ВыполнитьПакет();
			ПакетТЧ = 0;
			тчРемРаботы = Результат[ПакетТЧ].Выгрузить();
			ПакетИсп = 1;
			ВыборкаИдИсп = Результат[ПакетИсп].выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Для Каждого СтрокаТаблицы Из тчРемРаботы Цикл
				ВыборкаИдИсп.Сбросить();
				Если ВыборкаИдИсп.НайтиСледующий(Новый Структура("ID", СтрокаТаблицы.ID)) Тогда 
					ВыборкаИсп = ВыборкаИдИсп.Выбрать();
					СтрокаИсполнителей = "";
					Пока ВыборкаИсп.Следующий() Цикл
						СтрокаИсполнителей = ?(ЗначениеЗаполнено(СтрокаИсполнителей), СтрокаИсполнителей + ",
							|", "") + ПреобразоватьФИО(ВыборкаИсп.Сотрудник);
					КонецЦикла;
					СтрокаТаблицы.Исполнитель = СтрокаИсполнителей;
				КонецЕсли;
			КонецЦикла;
			#КонецВставки

			ВывестиРемонты(Макет, ТабДок, тчРемРаботы, ВыборкаРемонтов, "НарядНаРаботы_ОднимДокументом");

		КонецЦикла;

		#Вставка
		// гкс+ [10.22] Деснол 11.10.2022
		гкс_Подвал = Макет.ПолучитьОбласть("гкс_Подвал");
		ТабДок.Вывести(гкс_Подвал);
		// гкс- [10.22] Деснол 11.10.2022
		#КонецВставки
		обОтветственный = Макет.ПолучитьОбласть("Ответственный");
		обОтветственный.Параметры.Сотрудник = ВыборкаДокументов.Ответственный;
		обОтветственный.Параметры.Дата = Формат(ТекущаяДата(),"ДФ='''""''dd''""'' MMMM yyyy ""г.""'");
		ПроверитьИВывести(ТабДок, обОтветственный);

		ПерваяСтрока = Истина;
		обИсполнительСЗаголовоком = Макет.ПолучитьОбласть("ИсполнительСЗаголовоком");

		тчСотрудникиИКвалификация.Сбросить();
		Пока тчСотрудникиИКвалификация.Следующий() Цикл
			Если ПерваяСтрока Тогда
				ПерваяСтрока = Ложь;
				обИсполнительСЗаголовоком.Параметры.Сотрудник = тчСотрудникиИКвалификация.Сотрудник;
				обИсполнительСЗаголовоком.Параметры.Дата = Формат(ТекущаяДата(),"ДФ='''""''dd''""'' MMMM yyyy ""г.""'");
				ПроверитьИВывести(ТабДок, обИсполнительСЗаголовоком);
				Продолжить;
			КонецЕсли;

			обИсполнитель = Макет.ПолучитьОбласть("Исполнитель");
			обИсполнитель.Параметры.Сотрудник = тчСотрудникиИКвалификация.Сотрудник;
			обИсполнитель.Параметры.дата = Формат(ТекущаяДата(),"ДФ='''""''dd''""'' MMMM yyyy ""г.""'");
			ПроверитьИВывести(ТабДок, обИсполнитель);
		КонецЦикла;

		Если ПерваяСтрока Тогда
			ПроверитьИВывести(ТабДок, обИсполнительСЗаголовоком);
		КонецЕсли;

		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();

	КонецЦикла;

	Возврат ТабДок;

КонецФункции
// гкс- [Релиз 1] Куст 01.02.2021

// гкс+ [разработка 2021] Куст 05.05.2021
&ИзменениеИКонтроль("ВывестиРемонты")
Процедура гкс_ВывестиРемонты(Макет, ТабДок, тчРемРаботы, ВыборкаРемонтов, ИмяПФ)

	НайС = тчРемРаботы.НайтиСтроки(Новый Структура("Родитель_ID", ""));
	Дерево = Новый ДеревоЗначений;
	Дерево.Колонки.Добавить("РемонтнаяРабота");
	Дерево.Колонки.Добавить("РемонтыОборудования_ID");
	Дерево.Колонки.Добавить("ID");
	Дерево.Колонки.Добавить("Количество");

	НужноПолучитьНормыЗапчастей = Истина;

	// Затраты из сметы
	СтруктураЗатратИзСметы = Новый Структура("РемонтныеРаботыИзСметы, СтруктураТаблиц", Новый Массив, Новый Структура);
	Если ТипЗнч(ВыборкаРемонтов.ДокументИсточник) = Тип("ДокументСсылка.торо_ЗаявкаНаРемонт") Тогда
		СтруктураЗатратИзСметы = ПолучитьНормыЗатратИзСметы(тчРемРаботы, ВыборкаРемонтов, ВыборкаРемонтов.ДокументИсточник);
		НужноПолучитьНормыЗапчастей = Ложь;
	КонецЕсли;

	РемонтныеРаботыИзСметы = СтруктураЗатратИзСметы.РемонтныеРаботыИзСметы;

	Для каждого текСтрока Из НайС Цикл
		Если Не РемонтныеРаботыИзСметы.Найти(текСтрока.ID) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		нс = Дерево.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(нс, текСтрока);
		СобратьДерево(нс, тчРемРаботы, РемонтныеРаботыИзСметы);
	КонецЦикла;

	// Затраты из нормативов
	стрЗатрат = торо_Ремонты.ПолучитьНормыЗатратИзВетвиДереваОпераций(Дерево,,, ВыборкаРемонтов.ДатаНачала, ВыборкаРемонтов.ДатаОкончания);

	тчМатЗатраты = Новый ТаблицаЗначений;
	тчМатЗатраты.Колонки.Добавить("Наименование");
	#Вставка
	// гкс+ [10.22] Деснол 11.10.2022
	тчМатЗатраты.Колонки.Добавить("КодНСИ");
	// гкс- [10.22] Деснол 11.10.2022
	#КонецВставки
	тчМатЗатраты.Колонки.Добавить("Характеристика");
	тчМатЗатраты.Колонки.Добавить("ЕдИзм");
	тчМатЗатраты.Колонки.Добавить("Количество");

	тчИнструменты = Новый ТаблицаЗначений;
	тчИнструменты.Колонки.Добавить("Наименование");
	#Вставка
	// гкс+ [10.22] Деснол 11.10.2022
	тчИнструменты.Колонки.Добавить("КодНСИ");
	// гкс- [10.22] Деснол 11.10.2022
	#КонецВставки
	тчИнструменты.Колонки.Добавить("ЕдИзм");
	тчИнструменты.Колонки.Добавить("Количество");

	Для каждого текСтрока Из СтрЗатрат Цикл
		МатЗатраты = текСтрока.СтруктураТаблиц.МатериальныеЗатраты;
		Инструменты = текСтрока.СтруктураТаблиц.ИнструментыИТехника;

		Для каждого текСтрокаТЧ Из МатЗатраты Цикл
			нс = тчМатЗатраты.Добавить();
			нс.Наименование = текСтрокаТЧ.Номенклатура;
			#Вставка
			// гкс+ [10.22] Деснол 11.10.2022
			ТемпСтрукт = Новый Структура("КодНСИ", текСтрокаТЧ.Номенклатура.Код);
			ЗаполнитьЗначенияСвойств(нс, ТемпСтрукт);
			// гкс- [10.22] Деснол 11.10.2022
			#КонецВставки
			нс.Характеристика = текСтрокаТЧ.Характеристика; 
