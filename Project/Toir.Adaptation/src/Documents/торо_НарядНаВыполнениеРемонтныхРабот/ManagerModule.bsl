	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов); 
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТЧ.ID В(&ID)", "");
	КонецЕсли;
	
	ПервыйПакет = 4;
	ВторойПакет = ПервыйПакет + 1;
	ТретийПакет = ВторойПакет + 1;
	РемРаботыПакет = ТретийПакет + 1;
	МероприятияПакет = РемРаботыПакет + 1;
	ДолжностиПакет = МероприятияПакет + 2;
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ВыборкаДокументов = РезультатЗапроса[ПервыйПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ВыборкаИсполнители = РезультатЗапроса[ВторойПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаКонтрагенты = РезультатЗапроса[ТретийПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаРР = РезультатЗапроса[РемРаботыПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМероприятия = РезультатЗапроса[МероприятияПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаДолжности = РезультатЗапроса[ДолжностиПакет].Выбрать();
	
	ЭтоПервый = Истина;
	
	Пока ВыборкаДокументов.Следующий() Цикл
		
		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл
			
			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;
			СтрПоиска = Новый Структура("Ссылка,ИД", ВыборкаДокументов.Ссылка, ВыборкаРемонтов.ИД);
			СтрПоискаОбщая = Новый Структура("Ссылка", ВыборкаДокументов.Ссылка);
			
			Шапка = Макет.ПолучитьОбласть("Шапка");
			Шапка.Параметры.Номер = ВыборкаДокументов.Номер;
			//Шапка.Параметры.День = День(ВыборкаДокументов.Дата);
			//Шапка.Параметры.Месяц = Формат(ВыборкаДокументов.Дата, "ДФ=ММММ");
			//Шапка.Параметры.Год = Формат(ВыборкаДокументов.Дата, "ДФ=гггг");
			//Шапка.Параметры.Ответственный = ВыборкаРемонтов.Ответственный;
			Шапка.Параметры.Организация = ВыборкаРемонтов.Организация;
			Шапка.Параметры.Подразделение = ВыборкаРемонтов.Подразделение;
			Шапка.Параметры.ПодразделениеВладелец = ВыборкаРемонтов.ПодразделениеВладелец;
			
			ВыборкаДолжности.Сбросить();
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.ОтветственныйЗаПодготовку) Тогда 
				Шапка.Параметры.Ответственный = Строка(ВыборкаДолжности.Должность) + " " + ВыборкаРемонтов.ОтветственныйЗаПодготовку;
			Иначе
				Шапка.Параметры.Ответственный = ВыборкаРемонтов.ОтветственныйЗаПодготовку;
			КонецЕсли;
			//
			ВыборкаКонтрагенты.Сбросить();
			ЭтоКонтрагент = Ложь;
			Если ВыборкаКонтрагенты.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Выборка.Следующий();
						ЭтоКонтрагент = ТипЗнч(Выборка.Контрагент) = Тип("СправочникСсылка.Контрагенты");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Шапка.Параметры.ОР = ВыборкаРемонтов.ОР;
			//
			ВыборкаРР.Сбросить();
			Если ВыборкаРР.НайтиСледующий(СтрПоискаОбщая) Тогда 
				МассивТК = Новый Массив();
				ВыборкаР = ВыборкаРР.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							Если ТипЗнч(Выборка.РР) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда 
								МассивТК.Добавить(Выборка.РР);
							КонецЕсли;
						КонецЦикла;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Шапка.Параметры.СписокТК = СтрСоединить(МассивТК, ", ");
			КонецЕсли;
			
			Шапка.Параметры.Мероприятия1 = "";
			Шапка.Параметры.Мероприятия2 = "";
			//
			ВыборкаМероприятия.Сбросить();
			Если ВыборкаМероприятия.НайтиСледующий(СтрПоискаОбщая) Тогда 
				МассивСтрок1 = Новый Массив();
				МассивСтрок2 = Новый Массив();
				Выборка = ВыборкаМероприятия.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если Выборка.Приоритет = 1 Тогда 
						МассивСтрок1.Добавить(Выборка.Мероприятие);
					Иначе
						МассивСтрок2.Добавить(Выборка.Мероприятие);
					КонецЕсли;
				КонецЦикла;
				Шапка.Параметры.Мероприятия1 = СтрСоединить(МассивСтрок1, "" + Символы.ПС);
				Шапка.Параметры.Мероприятия2 = СтрСоединить(МассивСтрок2, "" + Символы.ПС);
			КонецЕсли;
			Шапка.Параметры.ДатаНачала = Формат(ВыборкаРемонтов.ДатаНачала, "ДФ=""ЧЧ 'ч.' мм 'мин.' дд ММММ гггг 'г.'""");
			Шапка.Параметры.ДатаОкончания = Формат(ВыборкаРемонтов.ДатаОкончания, "ДФ=""ЧЧ 'ч.' мм 'мин.' дд ММММ гггг 'г.'""");
			ВыборкаДолжности.Сбросить();
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.Допускающий) Тогда 
				Шапка.Параметры.Допускающий = Строка(ВыборкаДолжности.Должность) + " " + ВыборкаРемонтов.Допускающий;
			Иначе
				Шапка.Параметры.Допускающий = ВыборкаРемонтов.Допускающий;
			КонецЕсли;
			//
			ТабДок.Вывести(Шапка);
			
			ШапкаТЧ1 = Макет.ПолучитьОбласть("ШапкаТЧ1");
			ТабДок.Вывести(ШапкаТЧ1);
			СтрокаТЧ1 = Макет.ПолучитьОбласть("СтрокаТЧ1");
			
			ВыборкаИсполнители.Сбросить();
			Если ВыборкаИсполнители.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						НомерПП = 1;
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							// гкс+ [разработка 2021] Куст 08.07.2021
							Если ЭтоКонтрагент Тогда 
								СтрокаТЧ1.Параметры.НомерПП = НомерПП;
								СтрокаТЧ1.Параметры.Сотрудник = Выборка.гкс_СотрудникКонтрагента;
								СтрокаТЧ1.Параметры.Квалификация = Выборка.Квалификация;
							Иначе
							// гкс- [разработка 2021] Куст 08.07.2021
								СтрокаТЧ1.Параметры.НомерПП = НомерПП;
								СтрокаТЧ1.Параметры.Сотрудник = Выборка.Сотрудник;
								СтрокаТЧ1.Параметры.Квалификация = Выборка.Квалификация;
							КонецЕсли;
							ТабДок.Вывести(СтрокаТЧ1);
							НомерПП = НомерПП + 1;
						КонецЦикла;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			ШапкаТЧ2 = Макет.ПолучитьОбласть("ШапкаТЧ2");
			ТабДок.Вывести(ШапкаТЧ2);
			СтрокаТЧ2 = Макет.ПолучитьОбласть("СтрокаТЧ2");
			ТабДок.Вывести(СтрокаТЧ2);
			ТабДок.Вывести(СтрокаТЧ2);
			ШапкаТЧ3 = Макет.ПолучитьОбласть("ШапкаТЧ3");
			ТабДок.Вывести(ШапкаТЧ3);
			СтрокаТЧ3 = Макет.ПолучитьОбласть("СтрокаТЧ3");
			ТабДок.Вывести(СтрокаТЧ3);
			Подвал = Макет.ПолучитьОбласть("Подвал");
			
			ТабДок.Вывести(Подвал);
		КонецЦикла;
	КонецЦикла;
	
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.ТолькоПросмотр = Истина;
	// гкс+ [разработка 2021] Куст 07.05.2021
	ТабДок.АвтоМасштаб = Истина;
	// гкс- [разработка 2021] Куст 07.05.2021
	Возврат ТабДок;
	
КонецФункции
