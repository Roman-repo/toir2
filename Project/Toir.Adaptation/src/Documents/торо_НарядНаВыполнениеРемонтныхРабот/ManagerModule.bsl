	КонецЕсли;
	ПроверитьИВывести(ТабДок, обШапкаТЧМатериалы);

	номерПП = 1;
	Для каждого текСтрока из тчМатЗатраты Цикл
		#Вставка
		// гкс+ [10.22] Деснол 11.10.2022
		ЗаполнитьЗначенияСвойств(обСтрокаТЧМатериалы.Параметры, текСтрока);
		// гкс- [10.22] Деснол 11.10.2022
		#КонецВставки
		обСтрокаТЧМатериалы.Параметры.Ном = НомерПП;
