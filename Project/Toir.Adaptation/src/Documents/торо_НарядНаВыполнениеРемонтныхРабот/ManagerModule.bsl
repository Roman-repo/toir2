	Запрос.УстановитьПараметр("СтруктураИерархии", ТекИерархия);
// гкс- [Печатка] Куст 27.10.2020
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, 
		"ГДЕ ЗаявкаНаРемонтРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;
	
	ЭтоПервый = Истина;
	ИндексВыборкиСДокументами 			= 8;
	ИндексВыборкиСРемонтнымиРаботами 	= ИндексВыборкиСДокументами + 2;
	ИндексВыборкиСТрудовымиЗатратами 	= ИндексВыборкиСРемонтнымиРаботами + 1;
	ИндексВыборкиСИсполнителями 		= ИндексВыборкиСТрудовымиЗатратами + 1;
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаДокументов 		 = РезультатыЗапроса[ИндексВыборкиСДокументами].Выбрать();
	ВыборкаРемонтныеРаботы	 = РезультатыЗапроса[ИндексВыборкиСРемонтнымиРаботами].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаТрудовыеЗатраты	 = РезультатыЗапроса[ИндексВыборкиСТрудовымиЗатратами].Выбрать();
	ВыборкаИсполнители		 = РезультатыЗапроса[ИндексВыборкиСИсполнителями].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокументов.Следующий() Цикл
		Если НЕ ЭтоПервый Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ЭтоПервый = Ложь;
		
		// Заполняем Шапку табличного документа
		ЗаполнитьЗначенияСвойств(Шапка.Параметры, ВыборкаДокументов);
		// гкс+ [] Деснол 17.08.2022
		ЗаполнитьЗначенияСвойств(Шапка.Параметры, Новый Структура("ОрганизацияПолучательПредставление", "ЗАО ""Содружество-Соя"""));
		// гкс- [] Деснол 17.08.2022
		// гкс+ [03.23] Деснол 17.03.2023
		Шапка.Параметры.Получатель = "Содружество-Соя ЗАО";
		Если СтрНайти(Шапка.Параметры.ОрганизацияПредставление, "КУРСКАГРОТЕРМИНАЛ") > 0 Тогда 
			Шапка.Параметры.Получатель = Шапка.Параметры.ОрганизацияПредставление;
		КонецЕсли;
		// гкс- [03.23] Деснол 17.03.2023
		ТабличныйДокумент.Вывести(Шапка);
		
		СтруктураПоискаID = Новый Структура("ID", ВыборкаДокументов.ID);
		СтруктураПоискаIDДокумент = Новый Структура("ID, Документ", ВыборкаДокументов.ID, ВыборкаДокументов.Наряд);
		ИсполнительПодразделение = Истина;
		// Заполняем испольнителя по работе табличного документа
		Если ВыборкаИсполнители.НайтиСледующий(СтруктураПоискаID) Тогда 
			
			ВыборкаИсполнителиДокумент = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаИсполнителиДокумент.НайтиСледующий(СтруктураПоискаIDДокумент) Тогда
				Выборка = ВыборкаИсполнителиДокумент.Выбрать();
				Если Выборка.Следующий() Тогда
					ЗаполнитьЗначенияСвойств(Подвал.Параметры, Выборка);
					Если ЗначениеЗаполнено(Выборка.ИсполнительПоРемонту) И 
						ТипЗнч(Выборка.ИсполнительПоРемонту) = Тип("СправочникСсылка.Контрагенты") Тогда 
						ИсполнительПодразделение = Ложь;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		ВыборкаИсполнители.Сбросить();
		Если ИсполнительПодразделение Тогда
			СтруктураПоискаIDДокумент = Новый Структура("ID, Документ", ВыборкаДокументов.ID, ВыборкаДокументов.Документ);
			ТабличныйДокумент.Вывести(ШапкаРР);
			
			// Заполняем строки ремонтных работ табличного документа
			ОбщаяВремяРаботМин = 0;
			Если ВыборкаРемонтныеРаботы.НайтиСледующий(СтруктураПоискаID) Тогда
				
				ВыборкаРемонтныеРаботамыДокумент = ВыборкаРемонтныеРаботы.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Если ВыборкаРемонтныеРаботамыДокумент.НайтиСледующий(СтруктураПоискаIDДокумент) Тогда
					Выборка = ВыборкаРемонтныеРаботамыДокумент.Выбрать();
					Пока Выборка.Следующий() Цикл
						
						ЗаполнитьЗначенияСвойств(СтрокаРР.Параметры, Выборка);
						СтрокаРР.Параметры.РемонтнаяРаботаПредставление = ""+СтрокаРР.Параметры.РемонтнаяРаботаПредставление+" "+Выборка.Примечание; 
						
						КоличествоЧеловек 	= 0;
						ВремяРаботыМин 		= 0;
						СтруктураПоиска = Новый Структура("Документ, ID, РемонтнаяРабота_ID", Выборка.Документ, Выборка.ID, Выборка.РемонтнаяРабота_ID);
						Пока ВыборкаТрудовыеЗатраты.НайтиСледующий(СтруктураПоиска) Цикл
							КоличествоЧеловек = КоличествоЧеловек + ВыборкаТрудовыеЗатраты.КоличествоЧеловек;	
							ВремяРаботыМин	  = ВремяРаботыМин + ВыборкаТрудовыеЗатраты.ВремяРаботыМин;
							
							ОбщаяВремяРаботМин = ОбщаяВремяРаботМин + ВыборкаТрудовыеЗатраты.ВремяРаботыМин*ВыборкаТрудовыеЗатраты.КоличествоЧеловек;
						КонецЦикла;
						ВыборкаТрудовыеЗатраты.Сбросить();
						СтрокаРР.Параметры.КоличествоЧеловек = КоличествоЧеловек;	
						СтрокаРР.Параметры.ВремяРаботыМин	= ВремяРаботыМин;
							
						ТабличныйДокумент.Вывести(СтрокаРР);
						
					КонецЦикла;
				КонецЕсли;
				
			КонецЕсли;
			ВыборкаРемонтныеРаботы.Сбросить();
			
			// Заполняем подвал ремонтных работ табличного документа
			Если ОбщаяВремяРаботМин = Цел(ОбщаяВремяРаботМин) Тогда 
				ОбщаяВремяРаботМин = Строка(ОбщаяВремяРаботМин);
			КонецЕсли;
			ПодвалРР.Параметры.ОбщаяВремяРаботМин = ОбщаяВремяРаботМин;
			ТабличныйДокумент.Вывести(ПодвалРР);
		Иначе
			ТабличныйДокумент.Вывести(ШапкаРР2);
		КонецЕсли;
		
		
		
		ТабличныйДокумент.Вывести(Подвал);
	КонецЦикла;	
	
	// Зададим параметры макета
	ТабличныйДокумент.АвтоМасштаб	= Истина;
	ТабличныйДокумент.ПолеСверху  = 0;
	ТабличныйДокумент.ПолеСлева   = 0;
	ТабличныйДокумент.ПолеСнизу   = 0;
	ТабличныйДокумент.ПолеСправа  = 0;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // гкс- [7729] Тарасов 28.09.2020

