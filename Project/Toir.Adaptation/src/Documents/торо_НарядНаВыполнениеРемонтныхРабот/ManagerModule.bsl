	ВыборкаКонтрагенты = РезультатЗапроса[ТретийПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаРР = РезультатЗапроса[РемРаботыПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМатЗат = РезультатЗапроса[МатЗатПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИнструменты = РезультатЗапроса[ИнструментыПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаСИЗ = РезультатЗапроса[СИЗПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМБ = РезультатЗапроса[МБПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМероприятия = РезультатЗапроса[МероприятияПакет].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаДолжности = РезультатЗапроса[ДолжностиПакет].Выбрать();
	
	ЭтоПервый = Истина;
	
	Пока ВыборкаДокументов.Следующий() Цикл
		
		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаРемонтов.Следующий() Цикл
			
			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;
			СтрПоиска = Новый Структура("Ссылка,ИД", ВыборкаДокументов.Ссылка, ВыборкаРемонтов.ИД);
			СтрПоискаОбщая = Новый Структура("Ссылка", ВыборкаДокументов.Ссылка);
			
			Шапка = Макет.ПолучитьОбласть("Шапка");
			Шапка.Параметры.Номер = ВыборкаДокументов.Номер;
			Шапка.Параметры.День = День(ВыборкаДокументов.Дата);
			Шапка.Параметры.Месяц = Формат(ВыборкаДокументов.Дата, "ДФ=ММММ");
			Шапка.Параметры.Год = Формат(ВыборкаДокументов.Дата, "ДФ=гггг");
			Шапка.Параметры.Ответственный = ВыборкаРемонтов.Ответственный;
			Шапка.Параметры.Организация = ВыборкаРемонтов.Организация;
			Шапка.Параметры.Подразделение = ВыборкаРемонтов.Подразделение;
	Попытка
	    // Подключаем внешнюю компоненту
	    ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаСклоненияФИО", "NameDecl",ТипВнешнейКомпоненты.Native ) ;
	    Объект = Новый("AddIn.NameDecl.CNameDecl");
	Исключение
	    // Не удалось выполнить операции с внешней компонентой
	    Сообщить("Не удалось подключить внешнюю компоненту по причине: " + ОписаниеОшибки()); 
	КонецПопытки;
	Если ЗначениеЗаполнено(ВыборкаРемонтов.ИсполнительРабот) Тогда 
		// Получаем результат склонения
		// гкс+ [разработка 2021] Куст 08.07.2021
		Попытка
			РезультатСклонения = Объект.Просклонять(Строка(ВыборкаРемонтов.ИсполнительРабот), 3);
		Исключение
			РезультатСклонения = Строка(ВыборкаРемонтов.ИсполнительРабот);
		КонецПопытки;
		// гкс- [разработка 2021] Куст 08.07.2021
	Иначе
		РезультатСклонения = "";
	КонецЕсли;
			ВыборкаДолжности.Сбросить();
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.ИсполнительРабот) Тогда 
				Шапка.Параметры.ОтветственныйИсполнитель = Строка(ВыборкаДолжности.Должность) + " " + РезультатСклонения;
			Иначе
				Шапка.Параметры.ОтветственныйИсполнитель = РезультатСклонения;
			КонецЕсли;
			Шапка.Параметры.БригадаКолво = "   ";
			//
			ВыборкаКонтрагенты.Сбросить();
			ЭтоКонтрагент = Ложь;
			Если ВыборкаКонтрагенты.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Выборка.Следующий();
						ЭтоКонтрагент = ТипЗнч(Выборка.Контрагент) = Тип("СправочникСсылка.Контрагенты");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Если Не ЭтоКонтрагент Тогда 
				ВыборкаИсполнители.Сбросить();
				Если ВыборкаИсполнители.НайтиСледующий(СтрПоискаОбщая) Тогда 
					ВыборкаР = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаР.Следующий() Цикл
						Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
							Колво = 0;
							Выборка = ВыборкаР.Выбрать();
							Пока Выборка.Следующий() Цикл
								Колво = Колво + 1;
							КонецЦикла;
							Шапка.Параметры.БригадаКолво = Колво;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			Шапка.Параметры.СписокОР = ВыборкаРемонтов.ОР;
			//
			ВыборкаРР.Сбросить();
			Если ВыборкаРР.НайтиСледующий(СтрПоискаОбщая) Тогда 
				МассивТК = Новый Массив();
				ВыборкаР = ВыборкаРР.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							Если ТипЗнч(Выборка.РР) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда 
								МассивТК.Добавить(Выборка.РР);
							КонецЕсли;
						КонецЦикла;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Шапка.Параметры.СписокОР = Строка(Шапка.Параметры.СписокОР) + " (" + СтрСоединить(МассивТК,", ") + ")";
			КонецЕсли;
			Шапка.Параметры.СписокМатериалы = "";
			//
			ВыборкаМатЗат.Сбросить();
			Если ВыборкаМатЗат.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаМатЗат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						МассивСтрок = Новый Массив();
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							МассивСтрок.Добавить(Выборка.Номенклатура);
						КонецЦикла;
						Шапка.Параметры.СписокМатериалы = СтрСоединить(МассивСтрок, ", ");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Шапка.Параметры.СписокИнструменты = "";
			//
			ВыборкаИнструменты.Сбросить();
			Если ВыборкаИнструменты.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаИнструменты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						МассивСтрок = Новый Массив();
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							МассивСтрок.Добавить(Выборка.Инструмент);
						КонецЦикла;
						Шапка.Параметры.СписокИнструменты = СтрСоединить(МассивСтрок, ", ");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Шапка.Параметры.СписокСИЗ = "";
			//
			ВыборкаСИЗ.Сбросить();
			Если ВыборкаСИЗ.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаСИЗ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						МассивСтрок = Новый Массив();
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							МассивСтрок.Добавить(Выборка.Номенклатура);
						КонецЦикла;
						Шапка.Параметры.СписокСИЗ = СтрСоединить(МассивСтрок, ", ");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Шапка.Параметры.Мероприятия = "";
			//
			ВыборкаМероприятия.Сбросить();
			Если ВыборкаМероприятия.НайтиСледующий(СтрПоискаОбщая) Тогда 
				МассивСтрок = Новый Массив();
				Выборка = ВыборкаМероприятия.Выбрать();
				Пока Выборка.Следующий() Цикл
					МассивСтрок.Добавить(Выборка.Мероприятие);
				КонецЦикла;
				Шапка.Параметры.Мероприятия = СтрСоединить(МассивСтрок, "" + Символы.ПС);
			КонецЕсли;
			Шапка.Параметры.ОсобыеУсловия = ВыборкаРемонтов.ОсобыеУсловия;
			Шапка.Параметры.ДатаНачала = Формат(ВыборкаРемонтов.ДатаНачала, "ДФ=""ЧЧ 'ч.' мм 'мин.' дд ММММ гггг 'г.'""");
			Шапка.Параметры.ДатаОкончания = Формат(ВыборкаРемонтов.ДатаОкончания, "ДФ=""ЧЧ 'ч.' мм 'мин.' дд ММММ гггг 'г.'""");
			Шапка.Параметры.РежимРаботы = ВыборкаРемонтов.РежимРаботы;
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.РуководительРабот) Тогда 
				Шапка.Параметры.РуководительРабот = Строка(ВыборкаДолжности.Должность) + " " + ВыборкаРемонтов.РуководительРабот;
			Иначе
				Шапка.Параметры.РуководительРабот = ВыборкаРемонтов.РуководительРабот;
			КонецЕсли;
			Если ВыборкаДолжности.НайтиСледующий(ВыборкаРемонтов.Допускающий) Тогда 
				Шапка.Параметры.Допускающий = Строка(ВыборкаДолжности.Должность) + " " + ВыборкаРемонтов.Допускающий;
			Иначе
				Шапка.Параметры.Допускающий = ВыборкаРемонтов.Допускающий;
			КонецЕсли;
			Шапка.Параметры.МерыБезопасности = "";
			//
			ВыборкаМБ.Сбросить();
			Если ВыборкаМБ.НайтиСледующий(СтрПоискаОбщая) Тогда 
				ВыборкаР = ВыборкаМБ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаР.Следующий() Цикл
					Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
						МассивСтрок = Новый Массив();
						Выборка = ВыборкаР.Выбрать();
						Пока Выборка.Следующий() Цикл
							МассивСтрок.Добавить(Выборка.МераБезопасности);
						КонецЦикла;
						Шапка.Параметры.МерыБезопасности = СтрСоединить(МассивСтрок, ", ");
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			ТабДок.Вывести(Шапка);
			
			СтрокаТЧ = Макет.ПолучитьОбласть("СтрокаТЧ");
			// гкс+ [разработка 2021] Куст 08.07.2021
			Если ЭтоКонтрагент Тогда 
				ВыборкаИсполнители.Сбросить();
				Если ВыборкаИсполнители.НайтиСледующий(СтрПоискаОбщая) Тогда 
					ВыборкаР = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаР.Следующий() Цикл
						Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
							НомерПП = 1;
							Выборка = ВыборкаР.Выбрать();
							Пока Выборка.Следующий() Цикл
								СтрокаТЧ.Параметры.НомерПП = НомерПП;
								СтрокаТЧ.Параметры.Сотрудник = Выборка.гкс_СотрудникКонтрагента;
								СтрокаТЧ.Параметры.Квалификация = Выборка.Квалификация;
								ТабДок.Вывести(СтрокаТЧ);
								НомерПП = НомерПП + 1;
							КонецЦикла;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			Иначе
			// гкс- [разработка 2021] Куст 08.07.2021
				ВыборкаИсполнители.Сбросить();
				Если ВыборкаИсполнители.НайтиСледующий(СтрПоискаОбщая) Тогда 
					ВыборкаР = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаР.Следующий() Цикл
						Если ВыборкаР.ИД = ВыборкаРемонтов.ИД Тогда 
							НомерПП = 1;
							Выборка = ВыборкаР.Выбрать();
							Пока Выборка.Следующий() Цикл
								СтрокаТЧ.Параметры.НомерПП = НомерПП;
								СтрокаТЧ.Параметры.Сотрудник = Выборка.Сотрудник;
								СтрокаТЧ.Параметры.Квалификация = Выборка.Квалификация;
								ТабДок.Вывести(СтрокаТЧ);
								НомерПП = НомерПП + 1;
							КонецЦикла;
							Шапка.Параметры.БригадаКолво = Колво;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			
			
			Подвал = Макет.ПолучитьОбласть("Подвал");
			Подвал.Параметры.Допускающий = Шапка.Параметры.Допускающий;
			ТабДок.Вывести(Подвал);
		КонецЦикла;
	КонецЦикла;
	
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.ТолькоПросмотр = Истина;
	Возврат ТабДок;
	
КонецФункции
