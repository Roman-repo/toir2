&НаСервере
Процедура гкс_ДобавитьВДеревоРеквизитыИзППР(РемонтыНовые)
	Запрос = Новый Запрос();
	Запрос.Текст = "
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Плановые.Исполнитель КАК Исполнитель,
	               |	Плановые.СпособВыполнения КАК СпособВыполнения,
	               |	Плановые.ID КАК ИД
	               |ИЗ
	               |	РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних(, ID В (&ИД)) КАК Плановые";
	Запрос.УстановитьПараметр("ИД", РемонтыНовые);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			НайдСтр = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", Выборка.ИД));
			Для Каждого СтрокаТЧ Из НайдСтр Цикл
				СтрокаТЧ.гкс_СпособВыполнения = Выборка.СпособВыполнения;
				СтрокаТЧ.Исполнитель = Выборка.Исполнитель;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры // гкс- [03.23] Деснол 13.03.2023

// гкс+ [03.23] Деснол 13.03.2023
&НаСервере
Процедура гкс_ОбновитьТехкартыРемонтаНаСервере(ИД_Ремонта, ТекущиеДанные)
	СтруктураДоОбновления = Новый Структура();
	МассивТО = Новый Массив();
	ВыбранноеЗначение = Новый Массив();
	СоотИТК = Новый Соответствие();
	НайдСтр = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID,Родитель_ID", ИД_Ремонта, ""));
	Для Каждого СТ Из НайдСтр Цикл
		Если ТипЗнч(СТ.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда 
			ВыбранноеЗначение.Добавить(СТ.РемонтнаяРабота);
			СоотИТК.Вставить(СТ.ID, СТ.РемонтнаяРабота);
		КонецЕсли;
	КонецЦикла;
	СоотТО = Новый Соответствие();
	НайдСтр = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СТ Из НайдСтр Цикл
		СтруктСтроки = Новый Структура("Операция,Родитель", СТ.РемонтнаяРабота, Неопределено);
		СтруктСтроки.Вставить("гкс_СпособВыполнения", СТ.гкс_СпособВыполнения);
		СтруктСтроки.Вставить("Исполнитель", СТ.Исполнитель);
		Если ЗначениеЗаполнено(СТ.Родитель_ID) Тогда 
			СтруктСтроки.Родитель = СоотИТК.Получить(СТ.Родитель_ID);
		КонецЕсли;
		МассивТО.Добавить(СтруктСтроки);
		СоотТО.Вставить(СТ.ID, СтруктСтроки);
	КонецЦикла;
	МассивМЗ = Новый Массив();
	НайдСтр = Объект.МатериальныеЗатраты.НайтиСтроки(Новый Структура("РемонтыОборудования_ID,гкс_Давальческие", ИД_Ремонта, Истина));
	Для Каждого СТ Из НайдСтр Цикл
		СтруктСтроки = Новый Структура("ЕдиницаИзмерения,Количество,Номенклатура,ХарактеристикаНоменклатуры,Качество,КоличествоЕдиниц");
		ЗаполнитьЗначенияСвойств(СтруктСтроки, СТ);
		СтрТО = СоотТО.Получить(СТ.ID);
		Если Не СтрТО = Неопределено Тогда 
			СтруктСтроки.Вставить("Операция", СтрТО.Операция);
			СтруктСтроки.Вставить("Родитель", СтрТО.Родитель);
			МассивМЗ.Добавить(СтруктСтроки);
		КонецЕсли;
	КонецЦикла;
	// Удаление
	НайдСтр = Объект.МатериальныеЗатраты.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.МатериальныеЗатраты.Удалить(СМ);
	КонецЦикла;
	НайдСтр = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.РемонтныеРаботы.Удалить(СМ);
	КонецЦикла;
	НайдСтр = Объект.ТрудовыеЗатраты.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.ТрудовыеЗатраты.Удалить(СМ);
	КонецЦикла;
	НайдСтр = Объект.Инструменты.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.Инструменты.Удалить(СМ);
	КонецЦикла;
	НайдСтр = Объект.ЗапчастиРемонта.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.ЗапчастиРемонта.Удалить(СМ);
	КонецЦикла;
	НайдСтр = Объект.МерыБезопасности.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.МерыБезопасности.Удалить(СМ);
	КонецЦикла;
	НайдСтр = Объект.ИсполнителиПоРемонтам.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.ИсполнителиПоРемонтам.Удалить(СМ);
	КонецЦикла;
	НайдСтр = Объект.гкс_СИЗ.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СМ Из НайдСтр Цикл
		Объект.гкс_СИЗ.Удалить(СМ);
	КонецЦикла;
	// Перевыбор
	ДеревоРемонтныхРаботОбработкаВыбораСервер(ВыбранноеЗначение, ТекущиеДанные);
	// Восстановление
	СоотИТК = Новый Соответствие();
	НайдСтр = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID,Родитель_ID", ИД_Ремонта, ""));
	Для Каждого СТ Из НайдСтр Цикл
		Если ТипЗнч(СТ.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда 
			ВыбранноеЗначение.Добавить(СТ.РемонтнаяРабота);
			СоотИТК.Вставить(СТ.ID, СТ.РемонтнаяРабота);
		КонецЕсли;
	КонецЦикла;
	МассивНовыхТО = Новый Массив();
	НайдСтр = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИД_Ремонта));
	Для Каждого СТ Из НайдСтр Цикл
		ТекРодитель = СоотИТК.Получить(СТ.Родитель_ID);
		Для Каждого СМ Из МассивТО Цикл
			Если СМ.Операция = СТ.РемонтнаяРабота И СМ.Родитель = ТекРодитель Тогда 
				ЗаполнитьЗначенияСвойств(СТ, СМ);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		СтруктСтроки = Новый Структура("Операция,Родитель,ИД", СТ.РемонтнаяРабота, ТекРодитель, СТ.ID);
		МассивНовыхТО.Добавить(СтруктСтроки);
	КонецЦикла;
	Для Каждого СМ Из МассивМЗ Цикл
		Для Каждого НоваяТО Из МассивНовыхТО Цикл
			Если НоваяТО.Операция = СМ.Операция И НоваяТО.Родитель = СМ.Родитель Тогда 
				НайдСтр = Объект.МатериальныеЗатраты.НайтиСтроки(Новый Структура("РемонтыОборудования_ID,ID,Номенклатура", ИД_Ремонта, НоваяТО.ИД, СМ.Номенклатура));
				Если НайдСтр.Количество() Тогда 
					Для Каждого СТ Из НайдСтр Цикл
						СТ.гкс_Давальческие = Истина;
					КонецЦикла;
				Иначе
					НоваяСтрокаМЗ = Объект.МатериальныеЗатраты.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаМЗ, СМ);
					НоваяСтрокаМЗ.ID = НоваяТО.ИД;
					НоваяСтрокаМЗ.РемонтыОборудования_ID = ИД_Ремонта;
					НоваяСтрокаМЗ.гкс_Давальческие = Истина;
				КонецЕсли;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры // гкс- [03.23] Деснол 13.03.2023

// гкс+ [03.23] Деснол 14.03.2023
&НаКлиенте
Процедура гкс_ОбновитьТехкартыРемонтаПослеВопроса(Результат, ДопПараметры) Экспорт
	Если Не Результат = КодВозвратаДиалога.Да Тогда 
		Возврат;
	КонецЕсли;
	ТекДанные = Элементы.РемонтыОборудования.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекСтрокаДерева = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		
		
		СтрокаРодитель = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID", "", "", "");
		ИДВыбраннойСтроки = "";
		
	
		ТекущиеДанные = Новый Структура("ТекущийРемонт_ID, СтрокаРодитель_ID, СтрокаРодительРемонтыОборудования_ID, СтрокаРодительРодитель_ID, ДатаНачалаРемонта"
		, ТекДанные.ID
		, СтрокаРодитель.ID
		, СтрокаРодитель.РемонтыОборудования_ID
		, СтрокаРодитель.Родитель_ID
		, ТекДанные.ДатаНачала);
		
		
		гкс_ОбновитьТехкартыРемонтаНаСервере(ТекДанные.ID, ТекущиеДанные);
		
		РемонтыОборудованияПриАктивизацииСтроки(Элементы.РемонтыОборудования);
		ВыделитьСтрокуДереваРемонтныхРабот(ИДВыбраннойСтроки);
			
		Модифицированность = Истина;
			
		КонецЕсли;
КонецПроцедуры // гкс- [03.23] Деснол 14.03.2023

