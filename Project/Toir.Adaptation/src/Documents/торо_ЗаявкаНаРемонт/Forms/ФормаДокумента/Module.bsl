	//заполнение ТЧ МатериальныеЗатраты
	ОтборТовара	= Новый Структура("Номенклатура");
	Для Каждого ТекСтрока Из Объект.МатериальныеЗатраты Цикл		
		ОтборТовара.Номенклатура	= ТекСтрока.Номенклатура;
		НайденныеСтроки	= ТаблицаДанных.НайтиСтроки(ОтборТовара);
		Если НайденныеСтроки.Количество() > 0 Тогда
			ЗаполнитьЗначенияСвойств(ТекСтрока, НайденныеСтроки[0]);
		КонецЕсли;	
	КонецЦикла;
	
	//Зозуля 497+
	Если ТаблицаДанных.Количество() > 0 Тогда 
		ТаблицаДанных.Сортировать("гкс_ДатаПоставки УБЫВ");            
		НаибольшаяДатаПоставки = ТаблицаДанных[0].гкс_ДатаПоставки;
		НаименованиеНоменклатуры = ТаблицаДанных[0].Наименование;
		Для Каждого ТекСтрока Из Объект.РемонтыОборудования Цикл			
			Если ТекСтрока.ДатаНачала < НаибольшаяДатаПоставки Тогда 
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = СтрШаблон("В строке %1: Дата начала ремонта меньше даты поставки номенклатуры %2", 
					ТекСтрока.НомерСтроки, НаименованиеНоменклатуры);
				Сообщение.Поле = "Объект.РемонтыОборудования["+(ТекСтрока.НомерСтроки-1)+"].ДатаНачала"; 
				Сообщение.Сообщить();
			КонецЕсли;
		КонецЦикла;
		
	// Гкс+[TOIR20-532] Вялых Д.А. от 10.02.2025. Добавлено:{
	УстановитьИспользованиеУОДляДанныхЕРП(Истина); 
