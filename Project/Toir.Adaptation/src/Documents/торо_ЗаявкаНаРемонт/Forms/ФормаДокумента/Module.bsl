&НаСервере
Процедура ОбновитьЦеныНоменклатуры(ОтборНоменклатура = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТЧ.Номенклатура КАК Номенклатура,
		|	ТЧ.РемонтыОборудования_ID КАК ИД_Ремонта
		|ПОМЕСТИТЬ Исходные
		|ИЗ
		|	&ТЧ КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Организации.гкс_ВидЦены КАК ВидЦены,
		|	Организации.гкс_ВидЦены.ВалютаЦены КАК Валюта
		|ПОМЕСТИТЬ ОргВидЦены
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	Организации.Ссылка = &Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
		|ИЗ
		|	ОргВидЦены КАК ОргВидЦены
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|				&Дата,
		|				Номенклатура В
		|					(ВЫБРАТЬ
		|						ТЧ.Номенклатура
		|					ИЗ
		|						Исходные КАК ТЧ)) КАК ЦеныНоменклатурыСрезПоследних
		|		ПО ОргВидЦены.ВидЦены = ЦеныНоменклатурыСрезПоследних.ВидЦены
		|			И ОргВидЦены.Валюта = ЦеныНоменклатурыСрезПоследних.Валюта";
	
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ТЧ", Объект.МатериальныеЗатраты.Выгрузить());
	Если Не ОтборНоменклатура = Неопределено Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТЧ КАК ТЧ","&ТЧ КАК ТЧ Где ТЧ.Номенклатура = &Номенклатура");
		Запрос.УстановитьПараметр("Номенклатура", ОтборНоменклатура);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	СоотНомЦена = Новый Соответствие();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СоотНомЦена.Вставить(Выборка.Номенклатура, Выборка.Цена);
	КонецЦикла;
	
	Если ОтборНоменклатура = Неопределено Тогда 
		Для Каждого СтрокаМатЗатрат Из Объект.МатериальныеЗатраты Цикл
			СтрокаМатЗатрат.гкс_Цена = СоотНомЦена.Получить(СтрокаМатЗатрат.Номенклатура);
		КонецЦикла;
	Иначе
		Для Каждого СтрокаМатЗатрат Из Объект.МатериальныеЗатраты Цикл
			Если СтрокаМатЗатрат.Номенклатура = ОтборНоменклатура Тогда 
				СтрокаМатЗатрат.гкс_Цена = СоотНомЦена.Получить(СтрокаМатЗатрат.Номенклатура);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// гкс+ [] Деснол 12.09.2022
&НаКлиенте
Процедура гкс_ПроецироватьПослеВопроса(Результат, ДопПараметры) Экспорт
	Если Не Результат = Неопределено Тогда 
		Если Результат = "ВР" Тогда 
			СтрокаИсточник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ДопПараметры.Источник))[0];
			Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
				СтрокаПриемник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДРемонта))[0];
				СтрокаПриемник.ВидРемонтныхРабот = СтрокаИсточник.ВидРемонтныхРабот;
			КонецЦикла;
		ИначеЕсли Результат = "Даты" Тогда 
			СтрокаИсточник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ДопПараметры.Источник))[0];
			Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
				СтрокаПриемник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДРемонта))[0];
				СтрокаПриемник.ДатаНачала = СтрокаИсточник.ДатаНачала;
				СтрокаПриемник.ДатаОкончания = СтрокаИсточник.ДатаОкончания;
			КонецЦикла;
		ИначеЕсли Результат = "Операции" Тогда 
			МассивТЧ = Новый Массив();
			МассивТЧ.Добавить("РемонтныеРаботы");
			МассивТЧ.Добавить("МатериальныеЗатраты");
			МассивТЧ.Добавить("ТрудовыеЗатраты");
			МассивТЧ.Добавить("Инструменты");
			МассивТЧ.Добавить("ЗапчастиРемонта");
			МассивТЧ.Добавить("гкс_СИЗ");
			Для Каждого ИмяТЧ Из МассивТЧ Цикл
				Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
					СтрокиРемонта = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИДРемонта));
					Для Каждого СтрокаТаблицы Из СтрокиРемонта Цикл
						Объект[ИмяТЧ].Удалить(Объект[ИмяТЧ].Индекс(СтрокаТаблицы));
