&НаСервере
Функция СозданНаОснованииВнешнегоОснованияДляРабот()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ИСТИНА КАК Поле1
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.ДокументыОснования КАК ДокОснования
		|ГДЕ
		|	ДокОснования.Ссылка = &Ссылка
		|	И ДокОснования.ДокументОснование ССЫЛКА Документ.торо_ВнешнееОснованиеДляРабот";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
