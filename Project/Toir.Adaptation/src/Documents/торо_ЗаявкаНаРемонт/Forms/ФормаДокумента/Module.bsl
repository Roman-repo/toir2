	КонецЕсли;
	Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
		Если СтрокаТаблицы.гкс_Выбран И Не ТекДанные.ID = СтрокаТаблицы.ID Тогда 
			МассивИД.Добавить(СтрокаТаблицы.ID);
		КонецЕсли;
	КонецЦикла;
	Если МассивИД.Количество() > 0 Тогда 
		ПараметрыПослеВыбора = Новый Структура("МассивИД,Источник", МассивИД, ТекДанные.ID);
		ТекОписаниеОповещения = Новый ОписаниеОповещения("гкс_ПроецироватьПослеВопроса", ЭтотОбъект, ПараметрыПослеВыбора);
