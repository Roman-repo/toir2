&НаСервереБезКонтекста
Функция гкс_ВалютаОрганизации(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Организации.гкс_ВидЦены.ВалютаЦены КАК Валюта
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	Организации.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = ложь Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Валюта;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

&НаКлиенте
Процедура гкс_УстановитьПКоэфОбработкаВыбора(Результат, ДопПараметры)Экспорт
	Если Не Результат = Неопределено Тогда 
		Для Каждого СтрокаМассива Из Результат Цикл
			Для Каждого СтрокаТаблицы Из Объект.РемонтныеРаботы Цикл
				Если ДопПараметры.ИдРемонта = СтрокаТаблицы.РемонтыОборудования_ID
					И СтрокаМассива.ИД = СтрокаТаблицы.ID Тогда 
					СтрокаТаблицы.гкс_ПовКоэф = СтрокаМассива.гкс_ПовКоэф;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;

		РемонтыОборудованияПриАктивизацииСтроки(Элементы.РемонтыОборудования);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_РемонтныеРаботыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "Деревогкс_ПовКоэф" Тогда 
		ТекДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		Если Не ТекДанные = Неопределено 
		И гкс_ЭтоТО(ТекДанные.РемонтнаяРабота) Тогда 
		ОписаниеОп = Новый ОписаниеОповещения("УстановитьВыбраннымПослеВыбора", ЭтотОбъект);
		ОткрытьФорму("Справочник.гкс_ПКоэффициентыРабот.ФормаВыбора",, ЭтотОбъект,,,, 
				ОписаниеОп, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция гкс_ЭтоТО(Ссылка)
	Возврат ТипЗнч(Ссылка) = Тип("СправочникСсылка.торо_ТехнологическиеОперации");
КонецФункции

&НаКлиенте
Процедура УстановитьВыбраннымПослеВыбора(Результат, ДопПараметры)Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда 
		ТекДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		Если Не ТекДанные = Неопределено Тогда 
			НайдСтроки = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("ID,РемонтыОборудования_ID"
				, ТекДанные.ID, ТекДанные.РемонтыОборудования_ID));
			Если НайдСтроки.Количество() Тогда 
				Модифицированность = Истина;
				ТекДанные.гкс_ПовКоэф = Результат;
				Для Каждого СТрокаМассива Из НайдСтроки Цикл
					СТрокаМассива.гкс_ПовКоэф = Результат;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

