	Элементы.ДеревоРемонтныхРаботДобавитьТехОперацию.Видимость = Ложь;
	Элементы.ДеревоРемонтныхРаботДобавитьТехОперацию.Доступность = Ложь;
	Элементы.ДеревоРемонтныхРаботПодборОпераций.Видимость = Ложь;
	Элементы.ДеревоРемонтныхРаботПодборОпераций.Доступность = Ложь; 
	// гкс+ [Релиз19] Деснол
	Если Не (РольДоступна("ПолныеПрава") 
		Или РольДоступна("гкс_РедактированиеЗаявкиНаРемонт")
		Или РольДоступна("Администрирование")
		// Гкс-[TOIR20-303] Пономарёв С.О. от 20.01.2022. Добавлено:{
		Или РольДоступна("гкс_КлючевойПользователь") 
		// } Гкс-[TOIR20-303] Пономарёв С.О. от 20.01.2022.
		) Тогда
	// гкс- [Релиз19]
		Элементы.Ответственный.ТолькоПросмотр = Истина;
	КонецЕсли;    	
		
	Если РольДоступна("гкс_ИзменениеПроведеннойЗаявки") Тогда 
		ОткрытьДоступностьПолейДляРоли();
	КонецЕсли;

КонецПроцедуры                                             

&НаСервере
Процедура ДобавитьЭлементыСимптомДефекта()
	
	Если Объект.РемонтыОборудования.Количество() > 0 Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТЧ.ID КАК ИД
			|ПОМЕСТИТЬ Исходные
			|ИЗ
			|	&ТЧ КАК ТЧ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	торо_ВыявленныеДефектыСписокДефектов.гкс_СимптомДефекта КАК Симптом,
			|	Исходные.ИД КАК ИД
			|ИЗ
			|	Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Исходные КАК Исходные
			|		ПО торо_ВыявленныеДефектыСписокДефектов.ID = Исходные.ИД";
		Запрос.УстановитьПараметр("ТЧ",Объект.РемонтыОборудования.Выгрузить(,"ID"));
		РезультатЗапроса = Запрос.Выполнить();	
		Если РезультатЗапроса.Пустой() = Ложь Тогда 
			Выборка = РезультатЗапроса.Выбрать();	
			
			НовыйЭлемент = Элементы.Добавить("РемонтыОборудованиягкс_СимптомДефекта", Тип("ПолеФормы"),
				Элементы.РемонтыОборудования);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Объект.РемонтыОборудования.гкс_СимптомДефекта";
			НовыйЭлемент.ТолькоПросмотр = Истина;
			НовыйЭлемент.Заголовок = НСтр("ru='Симптом дефекта';en='Симптом дефекта'");
			Элементы.Переместить(Элементы["РемонтыОборудованиягкс_СимптомДефекта"], 
				Элементы.РемонтыОборудования, Элементы.РемонтыОборудованияОписаниеРемонта);
			
			Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
				Если Выборка.НайтиСледующий(Новый Структура("ИД", СтрокаТаблицы.ID)) Тогда 
					СтрокаТаблицы.гкс_СимптомДефекта = Выборка.Симптом;
				КонецЕсли;
				Выборка.Сбросить();
			КонецЦикла;
		КонецЕсли;
	КонецЕсли; 	
		
КонецПроцедуры                                  

