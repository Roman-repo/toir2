						НоваяСтрока = Объект[ИмяТЧ].Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
						НоваяСтрока.РемонтыОборудования_ID = ИДРемонта;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла; 
			// гкс+ [12.22] Деснол 13.12.2022
		ИначеЕсли Результат = "Критичность" Тогда 
			СтрокаИсточник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ДопПараметры.Источник))[0];
			Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
				СтрокаПриемник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДРемонта))[0];
				СтрокаПриемник.КритичностьДефекта = СтрокаИсточник.КритичностьДефекта;
			КонецЦикла;
		ИначеЕсли Результат = "Межремонтный" Тогда 
			СтрокаИсточник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ДопПараметры.Источник))[0];
			Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
				СтрокаПриемник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДРемонта))[0];
				СтрокаПриемник.гкс_МежремонтныйПериод = СтрокаИсточник.гкс_МежремонтныйПериод;
			КонецЦикла;
		ИначеЕсли Результат = "Исполнители" Тогда 
			МассивТЧ = Новый Массив();
			МассивТЧ.Добавить("ИсполнителиПоРемонтам");
			Для Каждого ИмяТЧ Из МассивТЧ Цикл
				Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
					СтрокиРемонта = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИДРемонта));
					Для Каждого СтрокаТаблицы Из СтрокиРемонта Цикл
						Объект[ИмяТЧ].Удалить(Объект[ИмяТЧ].Индекс(СтрокаТаблицы));
					КонецЦикла;
				КонецЦикла;
				СтрокиИсточника = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ДопПараметры.Источник));
				Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
					Для Каждого СтрокаИсточника Из СтрокиИсточника Цикл
						НоваяСтрока = Объект[ИмяТЧ].Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
						НоваяСтрока.РемонтыОборудования_ID = ИДРемонта;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			// гкс- [12.22] Деснол 13.12.2022
		// Гкс+[TOIR20-464] Зозуля А.В. от 14.11.2024. Добавлено:{
		ИначеЕсли Результат = "Описание" Тогда 
			СтрокаИсточник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ДопПараметры.Источник))[0];
			Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
				СтрокаПриемник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДРемонта))[0];
				СтрокаПриемник.ОписаниеРемонта = СтрокаИсточник.ОписаниеРемонта;
			КонецЦикла;
		// } Гкс-[TOIR20-464] Зозуля А.В. от 14.11.2024.
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры // гкс- [] Деснол 12.09.2022

&НаСервере
Процедура ОбновитьПлановуюСтоимостьРемонтаНаСервере()
	ОбновитьЦеныНоменклатуры();
	СуммаДавальческие = 0;
	ОбщаяСумма = 0;
	Для Каждого СтрокаТаблицы Из Объект.МатериальныеЗатраты Цикл
		КоэфРемонтнойРаботы = 1;
		СуммаСтроки = СтрокаТаблицы.гкс_Цена * СтрокаТаблицы.Количество * КоэфРемонтнойРаботы;
		ОбщаяСумма = ОбщаяСумма + СуммаСтроки;
		// гкс+ [Релиз17] Деснол
		Если СтрокаТаблицы.гкс_Давальческие Тогда 
			СуммаДавальческие = СуммаДавальческие + СуммаСтроки;
		КонецЕсли;
		// гкс- [Релиз17]
	КонецЦикла;
	

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.ВремяРаботы КАК ВремяРаботы,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.Количество КАК Количество,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.Квалификация КАК Квалификация,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.ID КАК ИД
		|ПОМЕСТИТЬ ВнешняяТаблицаИсполнителейРемонтныхРабот
		|ИЗ
		|	&ВнешняяТаблицаИсполнителейРемонтныхРабот0 КАК ВнешняяТаблицаИсполнителейРемонтныхРабот0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнешняяТаблицаКоэффициентовРемонтныхРабот0.ID КАК ИД,
		|	ВЫРАЗИТЬ(ВнешняяТаблицаКоэффициентовРемонтныхРабот0.гкс_ПовКоэф КАК Справочник.гкс_ПКоэффициентыРабот) КАК гкс_ПовКоэф
		|ПОМЕСТИТЬ ВнешняяТаблицаКоэффициентовРемонтныхРабот
		|ИЗ
		|	&ВнешняяТаблицаКоэффициентовРемонтныхРабот0 КАК ВнешняяТаблицаКоэффициентовРемонтныхРабот0
		|ГДЕ
		|	НЕ ВнешняяТаблицаКоэффициентовРемонтныхРабот0.гкс_ПовКоэф = ЗНАЧЕНИЕ(Справочник.гкс_ПКоэффициентыРабот.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот.ВремяРаботы * 
		|	ЕСТЬNULL(ВнешняяТаблицаКоэффициентовРемонтныхРабот.гкс_ПовКоэф.Коэффициент, 1) КАК ВремяРаботы,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот.Количество КАК Количество,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот.Квалификация КАК Квалификация,
		|	ВнешняяТаблицаКоэффициентовРемонтныхРабот.ИД КАК ИД
		|ПОМЕСТИТЬ Исходные
		|ИЗ
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот КАК ВнешняяТаблицаИсполнителейРемонтныхРабот
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВнешняяТаблицаКоэффициентовРемонтныхРабот КАК ВнешняяТаблицаКоэффициентовРемонтныхРабот
		|		ПО ВнешняяТаблицаИсполнителейРемонтныхРабот.ИД = ВнешняяТаблицаКоэффициентовРемонтныхРабот.ИД
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Организации.гкс_ВидЦены КАК ВидЦены,
		|	Организации.гкс_ВидЦены.ВалютаЦены КАК Валюта
		|ПОМЕСТИТЬ ОргВидЦены
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	Организации.Ссылка = &Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_СтоимостьЧасаКвалификацииСрезПоследних.Квалификация КАК Квалификация,
		|	торо_СтоимостьЧасаКвалификацииСрезПоследних.Стоимость КАК Стоимость
		|ПОМЕСТИТЬ ИзРегистра
		|ИЗ
		|	РегистрСведений.торо_СтоимостьЧасаКвалификации.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Квалификация В
		|					(ВЫБРАТЬ
		|						ТЧ.Квалификация
		|					ИЗ
		|						Исходные КАК ТЧ)) КАК торо_СтоимостьЧасаКвалификацииСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОргВидЦены КАК ОргВидЦены
		|		ПО (ОргВидЦены.Валюта = торо_СтоимостьЧасаКвалификацииСрезПоследних.Валюта)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИзРегистра.Стоимость * Исходные.Количество * (Исходные.ВремяРаботы / 3600) КАК Стоимость
		|ИЗ
		|	Исходные КАК Исходные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИзРегистра КАК ИзРегистра
		|		ПО Исходные.Квалификация = ИзРегистра.Квалификация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КурсыВалютСрезПоследних.Кратность КАК Кратность,
		|	КурсыВалютСрезПоследних.Курс КАК Курс
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(, Валюта = &ВалютаВывода) КАК КурсыВалютСрезПоследних";

	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ВалютаВывода", Объект.гкс_Валюта);
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("ВнешняяТаблицаИсполнителейРемонтныхРабот0", Объект.ТрудовыеЗатраты.Выгрузить());
	Запрос.УстановитьПараметр("ВнешняяТаблицаКоэффициентовРемонтныхРабот0", Объект.РемонтныеРаботы.Выгрузить());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ПакетПервый = 5;
	ПакетВторой = ПакетПервый + 1;
	Выборка = РезультатЗапроса[ПакетПервый].Выбрать();
	Пока Выборка.Следующий() Цикл
		ОбщаяСумма = ОбщаяСумма + Выборка.Стоимость;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[ПакетВторой].Выбрать();
	// Теперь на курс не смотрим
	Если Выборка.Следующий() И Не Выборка.Курс = 0 И Ложь Тогда 
		Объект.гкс_ПлановаяСтоимостьРемонта = (ОбщаяСумма / Выборка.Курс) * Выборка.Кратность;
		ВывестиПлановуюСтоимость(Объект.гкс_Валюта);
	Иначе
		Объект.гкс_ПлановаяСтоимостьРемонта = ОбщаяСумма;
		// гкс+ [Релиз17] Деснол
		Объект.гкс_ПлановаяСтоимостьБезДавальческихМатериалов = ОбщаяСумма - СуммаДавальческие;
		// гкс- [Релиз17]
		ВывестиПлановуюСтоимость(Объект.гкс_Валюта);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиПлановуюСтоимость(Валюта = Неопределено)
	Если Валюта = Неопределено Тогда 
		Валюта = Константы.торо_ВалютаРегламентированногоУчета.Получить();
	КонецЕсли;
	ЭтотОбъект["гкс_ПлановаяСтоимостьТекст"] = Строка(Объект.гкс_ПлановаяСтоимостьРемонта) + " " + Валюта.Наименование;
	ЭтотОбъект["гкс_ПлановаяСтоимостьБезДавальческихМатериаловТекст"] = Строка(Объект.гкс_ПлановаяСтоимостьБезДавальческихМатериалов) + " " + Валюта.Наименование;
КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("УстановитьУсловноеОформление")
Процедура гкс_УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();

	// Чтобы не отображалась единица измерения в Материальных затратах, когда заполнена Упаковка.
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.МатериальныеЗатратыНоменклатураЕдиницаИзмерения.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.МатериальныеЗатраты.ЕдиницаИзмерения");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
	Элемент.Оформление.УстановитьЗначениеПараметра("Отображать", Ложь);
	Элемент.Использование = Истина;

	// Чтобы не отображалась единица измерения в Запчастях ремонта, когда заполнена Упаковка.
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ЗапчастиРемонтаНоменклатураЕдиницаИзмерения.Имя);

