// Гкс+[TOIR20-490] Зозуля А.В. от 22.01.2024. Добавлено:{
&НаСервере
Процедура гкс_ОбновитьОстаткиНаСервере()
	
	Если Объект.МатериальныеЗатраты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;	
	
	СписокНоменклатуры	= Новый СписокЗначений;
	Для Каждого ТекСтрока Из Объект.МатериальныеЗатраты Цикл
		СписокНоменклатуры.Добавить(ТекСтрока.Номенклатура);
	КонецЦикла;
	
	// Гкс+[TOIR20-510] Зозуля А.В. от 29.01.2025. Изменено:{
	//ТаблицаДанных = гкс_ИнтеграцияERP2.ПолучитьДанныеПоНоменклатуре(Объект.Ссылка, СписокНоменклатуры); 
	ТаблицаДанных = гкс_ИнтеграцияERP2.ПолучитьДанныеПоНоменклатуре(Объект.Ссылка, Объект.Организация, СписокНоменклатуры);
