#Область ОбработчикиСобытийЭлементовТаблицыФормы_РемонтыОборудования

&НаКлиенте
&ИзменениеИКонтроль("РемонтыОборудованияПриАктивизацииСтроки")
Процедура гкс_РемонтыОборудованияПриАктивизацииСтроки(Элемент)

	ТекущиеДанные = Элементы.РемонтыОборудования.ТекущиеДанные;

	Если Не ТекущиеДанные = Неопределено Тогда
		Структура = Новый Структура();
		Структура.Вставить(	"ИмяТЧ"                    , "РемонтныеРаботы");
		Структура.Вставить(	"Текущий_ID"               , ТекущиеДанные.ID);
		Структура.Вставить(	"Наименование_Ремонты"     , "РемонтыОборудования_ID");
		Структура.Вставить(	"Наименование_ПолеРодитель", "Родитель_ID");
		Структура.Вставить(	"Наименование_ПолеЭлемент" , "ID");

		торо_ЗаполнениеДокументовКлиент.ЗаполнитьДеревоРемонтов(Структура, ДеревоРемонтныхРабот, Объект);

		ЗаполнитьЕдиницыИзмерения(ДеревоРемонтныхРабот); 

		УстановитьОтборыСвязанныхТаблицРемонты(Элементы.РемонтыОборудования.ТекущиеДанные.ID);
		ВыделитьСтрокуДереваРемонтныхРабот(Неопределено);
		Элементы.ДеревоРемонтныхРабот.Развернуть(ДеревоРемонтныхРабот.ПолучитьЭлементы()[0].ПолучитьИдентификатор(),Истина);

		УстановитьВидимостьКнопокДляТекРемонта(ТекущиеДанные);
		УстановитьДоступностьДляРедактированияПоТекРемонту(ТекущиеДанные.БлокироватьДляИзменения, ТекущиеДанные.ОбъектРемонта);

		Найденный = МассивIDЛотов.НайтиПоЗначению(ТекущиеДанные.ID);
		Если Найденный <> Неопределено Тогда
			Элементы.ИсполнителиПоРемонтамЗаполнитьИзЛотов.Доступность = Истина;
		Иначе
			Элементы.ИсполнителиПоРемонтамЗаполнитьИзЛотов.Доступность = Ложь;
		КонецЕсли;

		Если ФильтрПоИсполнителямАктивирован Тогда
			ДеревоРРЗаполнитьПолеДляФильтраНаКлиенте(ДеревоРемонтныхРабот, Истина);
		КонецЕсли; 
	КонецЕсли;

	УстановитьПараметрыВыбораНоменклатуры();
	#Вставка
	ОбновитьЗаливкуЗаголовка();
	#КонецВставки

КонецПроцедуры

&НаКлиенте
Процедура гкс_РемонтыОборудованияПриОкончанииРедактированияПосле(Элемент, НоваяСтрока, ОтменаРедактирования)
	гкс_ПодразделениеПриИзмененииПосле(Неопределено);
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("РемонтыОборудованияОбработкаВыбора")
Процедура гкс_РемонтыОборудованияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	Если ТипЗнч (ВыбранноеЗначение) = Тип ("Число") Тогда 

		НормаВремени = ВыбранноеЗначение;

		МассивРемонтов = Новый Массив;		
		Для каждого ТекСтрока Из Элементы.РемонтыОборудования.ВыделенныеСтроки Цикл 
			МассивРемонтов.Добавить(Объект.РемонтыОборудования.НайтиПоИдентификатору(ТекСтрока));
		КонецЦикла; 

		Для каждого ТекРемонт Из МассивРемонтов Цикл 
			ТекРемонт.ДатаОкончания = ТекРемонт.ДатаНачала + НормаВремени;
		КонецЦикла;

		Модифицированность = Истина;

	Иначе

		РемонтУжеДобавлен = Ложь;
		ЭтоРемонтнаяРабота = Ложь;
		МассивИДДобавленныхРемонтов = Новый Массив;
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") И ВыбранноеЗначение.Количество() > 0 Тогда 
			Для каждого ЭлементМассива Из ВыбранноеЗначение Цикл
				Если ТипЗнч(ЭлементМассива) = Тип("Структура") И ЭлементМассива.Свойство("СтрокаРемонтовОборудования") Тогда 
					НайденныеРемонты = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ЭлементМассива.СтрокаРемонтовОборудования.ID));
					Если НайденныеРемонты.Количество() > 0 Тогда
						РемонтУжеДобавлен = Истина;
						МассивИДДобавленныхРемонтов.Добавить(ЭлементМассива.СтрокаРемонтовОборудования.ID);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;

			Если РемонтУжеДобавлен Тогда 
				Вопрос = НСтр("es='Algunos de las reparaciones escogidas son añadidos ya. Los trabajos de reparación vinculados serán limpiados y añadidos de nuevo. ¿Continuar?';ru='Некоторые из выбранных ремонтов уже добавлены. Связанные ремонтные работы будут очищены и добавлены заново. Продолжить?';en='Some of the selected repairs have already been added. Associated repairs will be cleaned and re-added. Continue?'");
			КонецЕсли;
		КонецЕсли;

		Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") И ВыбранноеЗначение.Свойство("СтрокаРемонтовОборудования") 
			И ВыбранноеЗначение.Количество() > 0 Тогда
			ЭтоРемонтнаяРабота = ВыбранноеЗначение.ЭтоРемонтнаяРабота;
			НайденныеРемонты = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ВыбранноеЗначение.СтрокаРемонтовОборудования.ID));
			Если НайденныеРемонты.Количество() > 0 Тогда
				РемонтУжеДобавлен = Истина;
				МассивИДДобавленныхРемонтов.Добавить(ВыбранноеЗначение.СтрокаРемонтовОборудования.ID);
			КонецЕсли;

			Если РемонтУжеДобавлен Тогда 
				Вопрос = НСтр("es='Esta reparación es añadida ya. Los trabajos de reparación vinculados serán limpiados y añadidos de nuevo. ¿Continuar?';ru='Этот ремонт уже добавлен. Связанные ремонтные работы будут очищены и добавлены заново. Продолжить?';en='This repair has already been added. Associated repairs will be cleaned and re-added. Continue?'");
			КонецЕсли;
		КонецЕсли;

		// ФО торо_НазначениеНаРемонтСУчетомРисков.
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") И ВыбранноеЗначение.Свойство("КрайняяДопустимаяДатаЗавершенияРемонта") Тогда
			ТекущиеДанные = Элементы.РемонтыОборудования.ТекущиеДанные;
			Если Не ТекущиеДанные = Неопределено Тогда
				ЗаполнитьЗначенияСвойств(ТекущиеДанные, ВыбранноеЗначение);
				ТекущиеДанные.ДатаНачала     = ВыбранноеЗначение.ДатаНачалаРемонта;

				ТекущиеДанные.ДатаОкончания  = ВыбранноеЗначение.ДатаОкончанияРемонта;

				МассивСтрок = Объект.РезультатыПодбораИзМатрицыОценкиРисков.НайтиСтроки(Новый Структура("РемонтыОборудования_ID",ТекущиеДанные.ID));

				Для каждого Строка Из МассивСтрок Цикл
					Объект.РезультатыПодбораИзМатрицыОценкиРисков.Удалить(Строка);
				КонецЦикла; 

				Если ВыбранноеЗначение.Свойство("РезультатыПодбораИзМатрицыОценкиРисков") Тогда
					Для каждого Строка Из ВыбранноеЗначение.РезультатыПодбораИзМатрицыОценкиРисков Цикл
						ЗаполнитьЗначенияСвойств(Объект.РезультатыПодбораИзМатрицыОценкиРисков.Добавить(), Строка);
					КонецЦикла; 
				КонецЕсли; 

				Модифицированность = Истина;

			КонецЕсли;
		Иначе

			Если РемонтУжеДобавлен И НЕ ЭтоРемонтнаяРабота Тогда
				СтруктураПараметров = Новый Структура;
				СтруктураПараметров.Вставить("ВыбранноеЗначение", ВыбранноеЗначение);
				СтруктураПараметров.Вставить("МассивИДДобавленныхРемонтов", МассивИДДобавленныхРемонтов);
				ПоказатьВопрос(Новый ОписаниеОповещения("РемонтыОборудованияОбработкаВыбораПослеВопроса", ЭтотОбъект, СтруктураПараметров),
				Вопрос, РежимДиалогаВопрос.ДаНет);
			Иначе
				ОбработкаВыбораЗавершение(ВыбранноеЗначение);
			КонецЕсли;

		КонецЕсли; 


	КонецЕсли;
	#Вставка
