&НаСервере
&ИзменениеИКонтроль("ЗаполнитьДеревоРемонтныхРаботНаСервере")
Процедура гкс_ЗаполнитьДеревоРемонтныхРаботНаСервере(РемонтыОборудования_ID)

	ДеревоСФормы = РеквизитФормыВЗначение("ДеревоРемонтныхРабот");

	ДеревоСФормы.Строки.Очистить();

	КорневаяСтрока = ДеревоСФормы.Строки.Добавить();
	#Удаление
	КорневаяСтрока.РемонтнаяРабота = "Ремонтные работы";	
	#КонецУдаления
	#Вставка
	КорневаяСтрока.РемонтнаяРабота = дс_ПолучитьПредставлениеКорневойРемонтнойРаботы();
	#КонецВставки
	КорневаяСтрока.Картинка = 4;

	Если Не РемонтыОборудования_ID = Неопределено Тогда
		ТЗРемонтныеРаботы = Объект.РемонтныеРаботы.Выгрузить(Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", РемонтыОборудования_ID)));
	Иначе
		ТЗРемонтныеРаботы = Неопределено;
	КонецЕсли;                                                       

	СоздатьВетвьДереваПоТЧ(КорневаяСтрока, ТЗРемонтныеРаботы);

	ЗначениеВРеквизитФормы(ДеревоСФормы, "ДеревоРемонтныхРабот");

КонецПроцедуры

&НаСервере
Процедура ОбновитьСимптомДефекта()
	Если Объект.РемонтыОборудования.Количество() > 0 Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТЧ.ID КАК ИД
			|ПОМЕСТИТЬ Исходные
			|ИЗ
			|	&ТЧ КАК ТЧ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	торо_ВыявленныеДефектыСписокДефектов.гкс_СимптомДефекта КАК Симптом,
			|	Исходные.ИД КАК ИД
			|ИЗ
			|	Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Исходные КАК Исходные
			|		ПО торо_ВыявленныеДефектыСписокДефектов.ID = Исходные.ИД";
		Запрос.УстановитьПараметр("ТЧ",Объект.РемонтыОборудования.Выгрузить(,"ID"));
		РезультатЗапроса = Запрос.Выполнить();	
		Если РезультатЗапроса.Пустой() = Ложь Тогда 
			Выборка = РезультатЗапроса.Выбрать();				
			Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
				Если Выборка.НайтиСледующий(Новый Структура("ИД", СтрокаТаблицы.ID)) Тогда 
					СтрокаТаблицы.гкс_СимптомДефекта = Выборка.Симптом;
				КонецЕсли;
				Выборка.Сбросить();
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

