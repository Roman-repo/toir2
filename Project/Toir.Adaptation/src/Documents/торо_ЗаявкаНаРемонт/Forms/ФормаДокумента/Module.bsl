&НаКлиенте
Процедура ПроверитьЗаполнениеРемонтовОборудования(МассивСтруктур, Отказ)
	
	Если Объект.РемонтыОборудования.Количество() = 0 Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='В документе не указан ОР';en='The document does not specify an OR'");
		Сообщение.Сообщить();
		Отказ = Истина;
	Иначе
		МассивСтруктур = новый Массив();
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ОбъектРемонта",
			НСтр("ru='Объект ремонта';en='Object of repair'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ВидРемонтныхРабот", 
			НСтр("ru='Вид ремонтных работ';en='Type of repair work'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаНачала",
			НСтр("ru='Дата начала';en='Start date'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаОкончания",
			НСтр("ru='Дата окончания';en='End date'")));
		Для Каждого СтрокаМассива Из МассивСтруктур Цикл
			НомерПП = 0;
			Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
				Если Не ЗначениеЗаполнено(СтрокаТаблицы[СтрокаМассива.Имя]) Тогда 
					Сообщение = Новый СообщениеПользователю();
					ШаблонСообщения = НСтр("ru='Поле ""%1"" не заполнено';en='Field %1 is empty'");
					Сообщение.Текст = СтрШаблон(ШаблонСообщения, СтрокаМассива.Текст);
					Сообщение.Поле = "Объект.РемонтыОборудования[" + НомерПП + "]." + СтрокаМассива.Имя;
					Сообщение.Сообщить();
					Отказ = Истина;
				КонецЕсли;
				НомерПП = НомерПП + 1;
			КонецЦикла;
		КонецЦикла;
		НомерПП = 0;
		Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
			Если СтрокаТаблицы.ДатаНачала > СтрокаТаблицы.ДатаОкончания Тогда 
				Сообщение = Новый СообщениеПользователю();
				ШаблонСообщения = НСтр("ru='Дата окончания должна быть больше даты начала';en='The end date must be greater than the start date'");
				Сообщение.Текст = ШаблонСообщения;
				Сообщение.Поле = "Объект.РемонтыОборудования[" + НомерПП + "].ДатаОкончания";
				Сообщение.Сообщить();
				Отказ = Истина;
			КонецЕсли;
			НомерПП = НомерПП + 1;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры   

