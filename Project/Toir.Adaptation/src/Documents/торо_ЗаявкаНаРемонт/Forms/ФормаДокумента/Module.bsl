&НаСервере
&ИзменениеИКонтроль("ОбработкаПроверкиЗаполненияНаСервере")
Процедура гкс_ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства

	#Вставка
	// Гкс+[TOIR20-158] Селимов
	ВнешнееОснованиеДляРабот = СозданНаОснованииВнешнегоОснованияДляРабот(); // } Гкс-[TOIR20-158] 
	#КонецВставки
	Для Каждого Строка Из Объект.РемонтыОборудования Цикл
		Если Строка.ДатаНачала > Строка.ДатаОкончания Тогда
			ШаблонСообщения = НСтр("es='En la línea el número %1 listas de las reparaciones de la maquinaria la fecha del comienzo del período de los trabajos de reparación es más grande que la fecha de la terminación (%2 - %3).';ru='В строке номер %1 списка ремонтов оборудования дата начала периода ремонтных работ больше даты окончания (%2 - %3).';en='In line number%1 of the equipment repair list, the start date of the repair period is greater than the end date (%2 -%3).'");
			ТекстСообщения = СтрШаблон(ШаблонСообщения,	Строка.НомерСтроки,Строка.ДатаНачала,Строка.ДатаОкончания);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,,Отказ);
		КонецЕсли;

		Если ФОНазначениеНаРемонтСУчетомРисков
			И ЗначениеЗаполнено(Строка.КрайняяДопустимаяДатаЗавершенияРемонта)
			И Строка.ДатаОкончания > Строка.КрайняяДопустимаяДатаЗавершенияРемонта Тогда
			ШаблонСообщения = НСтр("es='En la línea el número %1 listas de las reparaciones de la maquinaria la fecha de la terminación del período de los trabajos de reparación más de fecha extrema admisible заверешния de la reparación (%2 - %3).';ru='В строке номер %1 списка ремонтов оборудования дата окончания периода ремонтных работ больше крайней допустимой даты заверешния ремонта (%2 - %3).';en='In line number%1 of the list of equipment repairs, the end date of the repair period is greater than the extreme permissible date of completion of repairs (%2 -%3).'");
			ТекстСообщения = СтрШаблон(ШаблонСообщения,	Строка.НомерСтроки,Строка.ДатаОкончания,Строка.КрайняяДопустимаяДатаЗавершенияРемонта);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,,Отказ);
		КонецЕсли; 
		#Вставка
		// гкс+ [02.23] Деснол 06.02.2023
		//// Гкс+[TOIR20-158] Селимов
		//Если ВнешнееОснованиеДляРабот И Не ЗначениеЗаполнено(Строка.КритичностьДефекта) Тогда
		//	ШаблонСообщения = НСтр("es='%1';ru='Не указана критичность дефекта в строке %1';en='Defect criticality not filled in line%1'");
		//	ТекстСообщения = СтрШаблон(ШаблонСообщения,	Строка.НомерСтроки);
		//	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "Объект.РемонтыОборудования["+ Строка(Строка.НомерСтроки - 1) +"].КритичностьДефекта",,Отказ);			
		//КонецЕсли; // } Гкс-[TOIR20-158] 
		// гкс- [02.23] Деснол 06.02.2023
		#КонецВставки
	КонецЦикла;

	Если ФОИспользоватьГарантии И ФОЗапретитьРемонтГарантийногоОборудованияХозспособом Тогда
		торо_ГарантийноеОбслуживание.ПроверитьНаличиеКонтрагентов(Объект, "ИсполнителиПоРемонтам","Исполнитель", Отказ);
	КонецЕсли; 

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура гкс_ОрганизацияПриИзмененииПосле(Элемент)
	гкс_ПодразделениеПриИзмененииПосле(Неопределено);
	Объект.гкс_Валюта = гкс_ВалютаОрганизации(Объект.Организация);
КонецПроцедуры

&НаКлиенте
Процедура гкс_ПодразделениеПриИзмененииПосле(Элемент)
	Если ЗначениеЗаполнено(Объект.СпособСогласования) Тогда 
		Возврат;
	КонецЕсли;
	Если ЭтотОбъект["мИспользоватьСогласованиеДокументов"] И Элементы["СпособСогласования"].ТолькоПросмотр
		И Не СтатусДокументаРегистр = ЭтотОбъект["гкс_СтатусЧерновик"] Тогда 
		Возврат;
	КонецЕсли;
	Если Объект.РемонтыОборудования.Количество() > 0 Тогда 
		Способ = гкс_ПолучитьСпособСогласования(Объект.Организация, Объект.РемонтыОборудования[0].ОбъектРемонта);
		Если Не Объект.СпособСогласования = Способ И Не Способ = Неопределено Тогда 
			Объект.СпособСогласования = Способ;
			СпособСогласованияПриИзменении(Неопределено);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте 
&ИзменениеИКонтроль("СпособСогласованияПриИзменении")
Процедура гкс_СпособСогласованияПриИзменении(Элемент)

	Если фПослеОчистки = Ложь Тогда
		ОбновитьДеревоСогласующих(Истина);
		#Удаление
		торо_РаботаССогласованиямиКлиентСервер.ДобавитьСтрокуВИсториюСтатусов(ЭтаФорма, СтатусДокументаРегистр,, Истина);
		#КонецУдаления
		#Вставка
		торо_РаботаССогласованиямиКлиентСервер.ДобавитьСтрокуВИсториюСтатусов(ЭтотОбъект, СтатусДокументаРегистр,,);
		#КонецВставки
	Иначе
		фПослеОчистки = Ложь;
	КонецЕсли;

	УправлениеВидимостьюСогласование(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("СпособСогласованияНачалоВыбора")
Процедура гкс_СпособСогласованияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	Если СогласующиеРегистр.Количество() > 0 Тогда

		СтандартнаяОбработка = Ложь;

		ПоказатьВопрос(Новый ОписаниеОповещения("СпособСогласованияНачалоВыбораЗавершение", ЭтаФорма, Новый Структура("Элемент",Элемент)),
		НСтр("es='¡Los datos de los estatus establecidos del documento serán limpiados! ¿Continuar?';ru='Данные по установленным статусам документа будут очищены! Продолжить?';en='Data on the established statuses of the document will be cleared! Continue?'"),
		РежимДиалогаВопрос.ДаНет, 60);		

		Возврат;

	КонецЕсли;
	#Вставка
	СтандартнаяОбработка = Ложь;
	ДопПараметры = Новый Структура("Отбор", Новый Структура("ПометкаУдаления", Ложь));
	ОткрытьФорму("Справочник.торо_СпособыСогласованияДокументов.ФормаВыбора",ДопПараметры,
	Элемент, , , , , РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	#КонецВставки

КонецПроцедуры

&НаКлиенте
Процедура гкс_СпособВыполненияДеревоПриИзменении(Элемент)
	ТекСтрока = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
	
	ID = ТекСтрока.ID;
	МассивСтрТЧ = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("ID", ID));
	
	Если МассивСтрТЧ.Количество() Тогда
		СтрТЧ = МассивСтрТЧ[0];
		СтрТЧ.гкс_СпособВыполнения = ТекСтрока.гкс_СпособВыполнения;
	Иначе
		ТекСтрока.гкс_СпособВыполнения = Неопределено;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("СпособСогласованияНачалоВыбораЗавершение")
Процедура гкс_СпособСогласованияНачалоВыбораЗавершение(РезультатВопроса, ДополнительныеПараметры)

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		СогласующиеРегистр.Очистить();
		Если мХранитьИсториюСогласованияВДокументах Тогда
			Объект.Согласующие.Очистить();
		КонецЕсли;
		#Вставка
		// гкс+ [Релиз 1] Куст 22.03.2021
		ДопПараметры = Новый Структура("Отбор", Новый Структура("ПометкаУдаления", Ложь));
		ОткрытьФорму("Справочник.торо_СпособыСогласованияДокументов.ФормаВыбора",ДопПараметры,
		ДополнительныеПараметры.Элемент,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		// гкс- [Релиз 1] Куст 22.03.2021
		#КонецВставки
		#Удаление
		ОткрытьФорму("Справочник.торо_СпособыСогласованияДокументов.ФормаВыбора",,ДополнительныеПараметры.Элемент,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		#КонецУдаления
		Возврат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботПриАктивизацииСтроки")
Процедура гкс_ДеревоРемонтныхРаботПриАктивизацииСтроки(Элемент)

	ТекДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

	Если НЕ ТекДанные = Неопределено Тогда

		УстановитьОтборСтрокПоЗатратам();

		#Удаление
		Если ТекДанные.РемонтнаяРабота = "Ремонтные работы" Тогда
		#КонецУдаления
		#Вставка
		Если ТекДанные.РемонтнаяРабота = дс_ПолучитьПредставлениеКорневойРемонтнойРаботы() Тогда
		#КонецВставки
			Элементы.ДеревоРемонтныхРаботКоличество.ТолькоПросмотр = Истина;			
		Иначе
			Элементы.ДеревоРемонтныхРаботКоличество.ТолькоПросмотр = Ложь;
		КонецЕсли; 

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботПередУдалением")
Процедура гкс_ДеревоРемонтныхРаботПередУдалением(Элемент, Отказ)

	ТекСтрокаДРР = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные; 

	СтруктураСвязанныхТЧ = Новый Структура();
	СтруктураСвязанныхТЧ.Вставить("МатериальныеЗатраты");
	СтруктураСвязанныхТЧ.Вставить("Инструменты");
	СтруктураСвязанныхТЧ.Вставить("ТрудовыеЗатраты");
	СтруктураСвязанныхТЧ.Вставить("РемонтныеРаботы");
	СтруктураСвязанныхТЧ.Вставить("МерыБезопасности");
	#Удаление
	Если НЕ ЗначениеЗаполнено(ТекСтрокаДРР.Родитель_ID) И ТекСтрокаДРР.РемонтнаяРабота = "Ремонтные работы" Тогда
	#КонецУдаления
	#Вставка
	Если НЕ ЗначениеЗаполнено(ТекСтрокаДРР.Родитель_ID) И ТекСтрокаДРР.РемонтнаяРабота = дс_ПолучитьПредставлениеКорневойРемонтнойРаботы() Тогда
	#КонецВставки

		ТекСтрокаДРР.ПолучитьЭлементы().Очистить();

		Для Каждого КлючИЗначение Из СтруктураСвязанныхТЧ Цикл

			ТабличнаяЧасть = Объект[КлючИЗначение.Ключ];

			ПараметрыПоиска = Новый Структура;
			ПараметрыПоиска.Вставить("РемонтыОборудования_ID", Элементы.РемонтыОборудования.ТекущиеДанные.ID);

			СтрокиКУдалению = ТабличнаяЧасть.НайтиСтроки(ПараметрыПоиска);

			Для Каждого Строка Из СтрокиКУдалению Цикл

				ТабличнаяЧасть.Удалить(Строка);

			КонецЦикла;		    

		КонецЦикла;

		Модифицированность = Истина;

		Отказ = Истина;

	Иначе

		ВыделенныеСтроки = Элементы.ДеревоРемонтныхРабот.ВыделенныеСтроки;
		МассивСтрокДляУдаления = Новый Массив;

		Для каждого Стр Из ВыделенныеСтроки Цикл 
			Строка = ДеревоРемонтныхРабот.НайтиПоИдентификатору(Стр);
			#Удаление
			Если Строка <> Неопределено И Строка.РемонтнаяРабота <> "Ремонтные работы" Тогда 
			#КонецУдаления
			#Вставка
			Если Строка <> Неопределено И Строка.РемонтнаяРабота <> дс_ПолучитьПредставлениеКорневойРемонтнойРаботы() Тогда
			#КонецВставки
				МассивСтрокДляУдаления.Добавить(Строка);
			КонецЕсли;
		КонецЦикла;		

		Для каждого Элемент Из МассивСтрокДляУдаления Цикл
			СтруктурыДляПередачи = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID, РемонтнаяРабота",
			Элемент.ID, Элемент.РемонтыОборудования_ID, Элемент.Родитель_ID, Элемент.РемонтнаяРабота);
			УдалитьДанныеТЧПоIDСтрокиДереваНаСервере(СтруктурыДляПередачи, СтруктураСвязанныхТЧ);

			СтрокаРодителя = Элемент.ПолучитьРодителя();
			Если СтрокаРодителя <> Неопределено Тогда 
				СтрокаРодителя.ПолучитьЭлементы().Удалить(Элемент); 
			КонецЕсли; 
		КонецЦикла;


		Модифицированность = Истина;
		Отказ = Истина;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормы_ДеревоРемонтныхРабот

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботОбработкаВыбора")
Процедура гкс_ДеревоРемонтныхРаботОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	ТекСтрокаДерева = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

	Если ТекСтрокаДерева = Неопределено Тогда
		СтрокаРодитель = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID", "", "", "");
		ИДВыбраннойСтроки = "";
	Иначе
		СтрокаРодитель = ТекСтрокаДерева;
		ИДВыбраннойСтроки = ТекСтрокаДерева.ID;
	КонецЕсли;

	ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;

	Если ТекРемонт <> Неопределено Тогда
		РемонтыОборудования_ID = ТекРемонт.ID;
		ДатаНачалаРемонта      = ТекРемонт.ДатаНачала;
	Иначе
		РемонтыОборудования_ID = "";
		ДатаНачалаРемонта      = Неопределено;       
	КонецЕсли;

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") И ВыбранноеЗначение.Количество()>0 И ТипЗнч(ВыбранноеЗначение[0]) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда
		#Вставка
		Массивпроверки = Новый Массив();
		Массивпроверки.Добавить(ВыбранноеЗначение[0]);
		Если ПроверитьТКНаСервере(Массивпроверки).Количество() Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru='Запрещено выбирать шаблоны техкарт';
			|en='It is forbidden to choose patterns standard maintenance plans'");
			Сообщение.Сообщить();
			СтандартнаяОбработка = Ложь;
			Возврат;
		КонецЕсли;
		#КонецВставки
		ТекущийРемонт = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		Пока ТекущийРемонт <> Неопределено И ТипЗнч(ТекущийРемонт.РемонтнаяРабота) <> Тип("Строка") Цикл
			Если ТекущийРемонт.РемонтнаяРабота = ВыбранноеЗначение[0] Тогда
				ШаблонСообщения = НСтр("es='El significado escogido ""%1"" no puede ser incluido en la composición.';ru='Выбранное значение ""%1"" не может быть включено в состав самого себя.';en='The selected value ""%1"" cannot be included in itself.'");
				ТекстСообщения = СтрШаблон(ШаблонСообщения, ВыбранноеЗначение[0]);
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				Возврат;
			КонецЕсли; 
			ТекущийРемонт = ТекущийРемонт.ПолучитьРодителя();	
		КонецЦикла;
	КонецЕсли;

	ТекущиеДанные = Новый Структура("ТекущийРемонт_ID, СтрокаРодитель_ID, СтрокаРодительРемонтыОборудования_ID, СтрокаРодительРодитель_ID, ДатаНачалаРемонта"
	, РемонтыОборудования_ID
	, СтрокаРодитель.ID
	, СтрокаРодитель.РемонтыОборудования_ID
	, СтрокаРодитель.Родитель_ID
	, ДатаНачалаРемонта);

	ДеревоРемонтныхРаботОбработкаВыбораСервер(ВыбранноеЗначение, ТекущиеДанные);

	РемонтыОборудованияПриАктивизацииСтроки(Элементы.РемонтыОборудования);
	ВыделитьСтрокуДереваРемонтныхРабот(ИДВыбраннойСтроки);

	Модифицированность = Истина;

КонецПроцедуры

// гкс+ [Релиз16] Деснол
&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботИсполнительПриИзменении")
Процедура гкс_ДеревоРемонтныхРаботИсполнительПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		ТекущиеДанные.ДоговорБригада = Неопределено;
		УстановитьПараметрыВыбораДоговораБригады_ДляРемонтныхРабот(ТекущиеДанные.Исполнитель, ТекущиеДанные.РемонтыОборудования_ID);
		#Вставка
		Если ЗначениеЗаполнено(ТекущиеДанные.Исполнитель) Тогда 
			Ветвь = ТекущиеДанные.ПолучитьЭлементы();
			Для Каждого СтрокаДерева Из Ветвь Цикл
				СтрокаДерева.Исполнитель = ТекущиеДанные.Исполнитель;
				Ветвь2 = СтрокаДерева.ПолучитьЭлементы();
				Для Каждого СтрокаДерева2 Из Ветвь2 Цикл
					СтрокаДерева2.Исполнитель = ТекущиеДанные.Исполнитель;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
		#КонецВставки
	КонецЕсли;

	Если ФильтрПоИсполнителямАктивирован Тогда
		ДеревоРРЗаполнитьПолеДляФильтраПриИзмененииИсполнителяНаКлиенте();
	КонецЕсли;

КонецПроцедуры // гкс- [Релиз16]

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормы_МатериальныеЗатраты

&НаКлиенте
&ИзменениеИКонтроль("МатериальныеЗатратыПередОкончаниемРедактирования")
Процедура гкс_МатериальныеЗатратыПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)

	Если НоваяСтрока И Не ОтменаРедактирования Тогда 
		ТекСтрокаДереваРемонтныхРабот = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		Элемент.ТекущиеДанные.ID = ТекСтрокаДереваРемонтныхРабот.ID;
		Элемент.ТекущиеДанные.РемонтыОборудования_ID = ТекСтрокаДереваРемонтныхРабот.РемонтыОборудования_ID;
		Элемент.ТекущиеДанные.Качество = ПредопределенноеЗначение("Перечисление.ГрадацииКачества.Новый");
	КонецЕсли;

	Если НЕ ОтменаРедактирования Тогда
		#Вставка
		Если Объект.МатериальныеЗатраты.НайтиСтроки(Новый Структура("ID,РемонтыОборудования_ID,Номенклатура,ХарактеристикаНоменклатуры,гкс_Давальческие",Элемент.ТекущиеДанные.ID,Элемент.ТекущиеДанные.РемонтыОборудования_ID,Элемент.ТекущиеДанные.Номенклатура,Элемент.ТекущиеДанные.ХарактеристикаНоменклатуры,Элемент.ТекущиеДанные.гкс_Давальческие)).Количество() > 1 Тогда
		#КонецВставки
		ТекстСообщения = НСтр("es='La nomenclatura dada es añadida ya.';ru='Данная номенклатура уже добавлена.';en='This item has already been added.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,,,,Отказ);
		#Вставка
		КонецЕсли;
		#КонецВставки
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("МатериальныеЗатратыНоменклатураПриИзменении")
Процедура гкс_МатериальныеЗатратыНоменклатураПриИзменении(Элемент)

	ТекущаяСтрока = Элементы.МатериальныеЗатраты.ТекущиеДанные;

	ТекущаяСтрока.ХарактеристикиИспользуются = торо_НоменклатураСервер.ПолучитьХарактеристикиИспользуются(ТекущаяСтрока.Номенклатура);

	Если Не ТекущаяСтрока.ХарактеристикиИспользуются Тогда
		ТекущаяСтрока.ХарактеристикаНоменклатуры = Неопределено;
	КонецЕсли;
	#Вставка
	ТекущаяСтрока = Элементы.МатериальныеЗатраты.ТекущиеДанные;
	ОбновитьЦеныНоменклатуры(ТекущаяСтрока.Номенклатура);
	#КонецВставки

КонецПроцедуры

#КонецОбласти

