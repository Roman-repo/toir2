#Область ОбработчикиСобытийФормы

&НаСервере
&ИзменениеИКонтроль("ПриСозданииНаСервере")
Процедура гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("Основание") И ТипЗнч(Параметры.Основание) <> Тип("Соответствие") Тогда
		торо_ЗаполнениеДокументов.ПроверитьВозможностьВводаНаОсновании(Параметры.Основание, Отказ);
		Если Отказ Тогда
			Возврат;
		КонецЕсли; 
	КонецЕсли;

	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ГруппаГлобальные;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтаФорма, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды	

	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

	Если Параметры.Свойство("Основание") И Параметры.Свойство("ВыделенныеСтроки") Тогда
		ДокОснованиеППР = Параметры.Основание;
		МассивIDИзППР.ЗагрузитьЗначения(Параметры.ВыделенныеСтроки);
	КонецЕсли;

	Если ЭтаФорма.Параметры.Свойство("ДекомпиляцияЭлементов") Тогда
		ВнешниеОбработки.Создать(ЭтаФорма.Параметры.ДекомпиляцияЭлементов.ИмяПодключеннойОбработки,Ложь).ОпределитьВнутренниеСвойстваЭлементов(ЭтаФорма);
	КонецЕсли;

	Если Параметры.Свойство("ФильтрПоИсполнителю") Тогда
		Если ТипЗнч(Параметры.ФильтрПоИсполнителю) = Тип("СписокЗначений") Тогда
			МассивИсполнителейДляФильтра = Параметры.ФильтрПоИсполнителю;
		КонецЕсли;
	Иначе
		МассивИсполнителейДляФильтра = Неопределено;
	КонецЕсли; 

	Если Параметры.Свойство("АктивироватьСтроку") Тогда
		ТекСтрокаИзВнеID = Параметры.ТекСтрокаИзОбработкиID;		
	КонецЕсли;

	// Функциональные опции.
	ФОУчетЗапчастей                                      = ПолучитьФункциональнуюОпцию("торо_УчетЗапчастей");
	ФОИспользоватьГарантии                               = ПолучитьФункциональнуюОпцию("торо_ИспользоватьГарантии");
	ФОЗапретитьРемонтГарантийногоОборудованияХозспособом = ПолучитьФункциональнуюОпцию("торо_ЗапретитьРемонтГарантийногоОборудованияХозспособом");
	ФОИспользоватьАналоги                                = ПолучитьФункциональнуюОпцию("торо_ИспользоватьАналогиНоменклатурыДляРемонтов");
	ФОИспользоватьОстановочные                           = ПолучитьФункциональнуюОпцию("торо_ИспользоватьОстановочныеРемонты");
	ФОНазначениеНаРемонтСУчетомРисков                    = ПолучитьФункциональнуюОпцию("торо_НазначениеНаРемонтСУчетомРисков");
	ФОИспользоватьСкользящееПланирование                 = ПолучитьФункциональнуюОпцию("торо_ИспользоватьСкользящееПланирование");

	ПравоИнтерактивнаяПометкаУдаленияЗаказовНаВнутреннееПотребление = ПравоДоступа("ИнтерактивнаяПометкаУдаления", Метаданные.Документы.ЗаказНаВнутреннееПотребление);
	ПравоИнтерактивноеДобавлениеЗаказовНаВнутреннееПотребление = ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Документы.ЗаказНаВнутреннееПотребление);
	ПравоРедактирование = ПравоДоступа("Редактирование", Метаданные.Документы.торо_ЗаявкаНаРемонт);

	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда

		ОбновитьДобавленныеКолонкиТаблиц();

	КонецЕсли;

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	ЭтоПервыйДокументВЦепочке = ЭтоПервыйДокументВЦепочке();
	ЭтоПоследнийДокументВЦепочке = ЭтоПоследнийДокументВЦепочке(); 

	// Заголовок формы++
	торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(Объект, ЭтаФорма, "");
	// Заголовок формы--

	// Согласование++
	ВидДокумента = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ЗаявкаНаРемонт;
	торо_РаботаССогласованиями.ПриСозданииНаСервере(ЭтаФорма, ВидДокумента);
	УправлениеВидимостьюСогласование(ЭтотОбъект);
	// Согласование --

	// Ограничение ввода на основании
	торо_СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка, Новый Структура("ОграничитьВводНаОсновании, УстановитьСвойствоЭлементовФормыОтПрав",Истина, Истина));

	Элементы.ГруппаЗапчасти.Видимость = ФОУчетЗапчастей;  
	Элементы.АктульныеДатыРемонта.Видимость = ФОИспользоватьОстановочные;
	Элементы.РемонтыОборудованияВернутьРемонтВРаботу.Видимость = Ложь;

	УстановитьУсловноеОформление();
	ОбновитьДоступностьДляРедактирования();

	ОбновитьДокументыЗаказНаВнПотреблениеСервер();
	ОбновитьЗависимыеЛоты();

	#Вставка       	
		// гкс+ [Релиз16] Деснол
	торо_ЗаполнениеДокументов.гкс_ПроверитьВозможностьВводаОтСтатуса(Объект, Отказ);
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	// гкс- [Релиз16]	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		гкс_ПроверитьДубльРемонта(Отказ);
	КонецЕсли;
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;   
	
	гкс_ДобавитьИзменитьРеквизитыФормы();
	гкс_ДобавитьИзменитьКомандыФормы();
	гкс_ИнициализироватьРеквизитыФормы();
	гкс_ДобавитьИзменитьЭлементыФормы();
	гкс_ИнициализироватьЭлементыФормы();
	гкс_УстановитьВидимостьДоступностьЭлементовФормы();  	
	#КонецВставки
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПриОткрытии")
Процедура гкс_ПриОткрытии(Отказ)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И Объект.РемонтыОборудования.Количество() = 0 И Объект.ДокументыОснования.Количество() > 0 Тогда

		Если МассивIDИзППР.Количество() = 0 Тогда
			ПодключитьОбработчикОжидания("ПодборРемонтовОбработчикОжидания",0.5,Истина);
		Иначе
			ВыбранноеЗначение = ЗаполнитьДанныеНаОснованииППРВыделенныеСтроки();
			РемонтыОборудованияОбработкаВыбора(Элементы.РемонтыОборудования, ВыбранноеЗначение, Ложь);
		КонецЕсли;

	КонецЕсли; 	

	Если ТекСтрокаИзВнеID<>"" Тогда
		ВыделитьСтрокуРемонтовОборудования(ТекСтрокаИзВнеID);
	КонецЕсли;	

	// Имена элементов формы типа ТаблицаФормы, в которых необходимо обрабатывать события изменения строк.
	Массив = Новый Массив;
	Массив.Добавить("ДокументыОснования");
	Массив.Добавить("ДеревоРемонтныхРабот");
	торо_СобытияФормКлиент.ЗаполнитьСтруктуруДанныхДоРедактирования(СтруктураДанныхДоРедактирования,Массив);

	Если МассивИсполнителейДляФильтра.Количество() > 0 Тогда
		ВыборИсполнителейДляФильтраЗавершение(Неопределено, Неопределено);
		ФильтрПоИсполнителямАктивирован = Истина;
	Иначе
		ФильтрПоИсполнителямАктивирован = Ложь;
	КонецЕсли;
	#Вставка
	ПриОткрытииНаСервере(ТекущаяДата());
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда 
		гкс_ПодразделениеПриИзмененииПосле(Неопределено);
	КонецЕсли;
	// гкс+ [] Деснол 12.09.2022
	ЭтотОбъект["гкс_ВыборРемонтов"] = Истина;
	гкс_РежимПроецирования(Неопределено);
	// гкс- [] Деснол 12.09.2022
	#КонецВставки

КонецПроцедуры

&НаКлиенте
Процедура гкс_ПриОткрытииПосле(Отказ)

	гкс_ЗавершитьЗамерОткрытияФормы(ЭтотОбъект.гкс_ВремяНачалаЗамера);
	
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ОбработкаВыбора")
Процедура гкс_ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура")
		И ВыбранноеЗначение.Свойство("ВыполняемаяОперация")
		И ВыбранноеЗначение.ВыполняемаяОперация = "ВыборАналогаНоменклатурыДляРемонта" Тогда

		ЗаменитьМатериалыНаАналоги(ВыбранноеЗначение.АдресВХранилище);
		ТекДанныеРемРаб = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		МассивID = Новый Массив;
		ЗаполнитьМассивID(МассивID,ТекДанныеРемРаб);
		ОтметитьНаличиеАналогов(МассивID);
		Модифицированность = Истина;

	ИначеЕсли ИсточникВыбора.Имяформы = "Обработка.торо_ПодборНоменклатуры.Форма.Форма" Тогда

		ТекДанныеРемРаб = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		ТекДанныеРемонты = Элементы.РемонтыОборудования.ТекущиеДанные;

		Если ТекДанныеРемРаб = Неопределено ИЛИ ТекДанныеРемонты = Неопределено Тогда 
			Возврат;
		КонецЕсли;

		Если Элементы.ПанельЗатрат.ТекущаяСтраница = Элементы.ПанельЗатрат.ПодчиненныеЭлементы.ГруппаМатериальныеЗатраты Тогда
			ИмяТЧ = "МатериальныеЗатраты";
			ИмяРеквизита = "Номенклатура";
		ИначеЕсли Элементы.ПанельЗатрат.ТекущаяСтраница = Элементы.ПанельЗатрат.ПодчиненныеЭлементы.ГруппаИнструменты Тогда
			ИмяТЧ = "Инструменты";
			ИмяРеквизита = "Инструмент";
		Иначе
			ИмяТЧ = "ЗапчастиРемонта";
			ИмяРеквизита = "Номенклатура";
		КонецЕсли;

		СтруктураСтрокиОпераций = Новый Структура("РемонтыОборудования_ID, ID, Количество", ТекДанныеРемонты.ID, ТекДанныеРемРаб.ID, ТекДанныеРемРаб.Количество);
		ДобавитьНоменклатуруИзПодбора(ВыбранноеЗначение, СтруктураСтрокиОпераций, ИмяТЧ, ИмяРеквизита);
		ОтметитьНаличиеАналогов(ТекДанныеРемРаб.ID);
		Модифицированность = Истина;
		#Вставка
		ОбновитьЦеныНоменклатуры();
		#КонецВставки

	КонецЕсли;

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ПриЧтенииНаСервере")
Процедура гкс_ПриЧтенииНаСервере(ТекущийОбъект)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	ФОИспользоватьГарантии                               = ПолучитьФункциональнуюОпцию("торо_ИспользоватьГарантии");
	ФОИспользоватьАналоги                                = ПолучитьФункциональнуюОпцию("торо_ИспользоватьАналогиНоменклатурыДляРемонтов");
	ФОИспользоватьОстановочные                           = ПолучитьФункциональнуюОпцию("торо_ИспользоватьОстановочныеРемонты");
	ФОИспользоватьСкользящееПланирование                 = ПолучитьФункциональнуюОпцию("торо_ИспользоватьСкользящееПланирование");

	ОбновитьДобавленныеКолонкиТаблиц();
	#Вставка
	СтруктураПроверки = Новый Структура("гкс_СдвигЧП", Неопределено);
	ЗаполнитьЗначенияСвойств(СтруктураПроверки, ЭтотОбъект);
	Если Не СтруктураПроверки.гкс_СдвигЧП = Неопределено Тогда 
		гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтотОбъект,
		"Дата,РемонтыОборудования.ДатаНачала,РемонтыОборудования.ДатаОкончания," +
		"РемонтыОборудования.КрайняяДопустимаяДатаЗавершенияРемонта", Объект);
		ОбновитьСимптомДефекта();
		ОбновитьЦеныНоменклатуры();
	КонецЕсли;
	гкс_ОбщегоНазначенияСервер.ДобавитьУОКатегорииРиска(ЭтотОбъект);
	Если РольДоступна("гкс_ИзменениеПроведеннойЗаявки") Тогда 
		ОткрытьДоступностьПолейДляРоли();
	КонецЕсли;
	#КонецВставки

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ПередЗаписьюНаСервере")
Процедура гкс_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	// Согласование++
	торо_РаботаССогласованиями.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	// Согласование--

	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
		И ФОИспользоватьГарантии Тогда
		торо_ГарантийноеОбслуживание.СформироватьПредупрежденияОРекламационныхАктах(Объект, "РемонтыОборудования");
	КонецЕсли; 
	#Вставка
	Для Каждого СтрокаТаблицы ИЗ ТекущийОбъект.РемонтныеРаботы Цикл
		Если ТипЗнч(СтрокаТаблицы.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда 
			СтрокаТаблицы.гкс_ПовКоэф = Неопределено;
		ИначеЕсли ЗначениеЗаполнено(СтрокаТаблицы.гкс_ПовКоэф) = Ложь Тогда 
			СтрокаТаблицы.гкс_ПовКоэф = Справочники.гкс_ПКоэффициентыРабот.ПоУмолчанию;
		КонецЕсли;
	КонецЦикла;
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПСервера(ЭтотОбъект,, ТекущийОбъект);
	#КонецВставки

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ПриЗаписиНаСервере")
Процедура гкс_ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	// Согласование++
	торо_РаботаССогласованиями.ПриЗаписиНаСервере(ЭтаФорма, ТекущийОбъект);
	// Согласование--
	#Вставка
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтотОбъект,
		"Дата,РемонтыОборудования.ДатаНачала,РемонтыОборудования.ДатаОкончания," +
		"РемонтыОборудования.КрайняяДопустимаяДатаЗавершенияРемонта", ТекущийОбъект);
	#КонецВставки

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ПослеЗаписиНаСервере")
Процедура гкс_ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)

	// Заголовок формы++
	торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(Объект, ЭтаФорма, "");
	// Заголовок формы--

	ОбновитьДобавленныеКолонкиТаблиц();
	ОбновитьЗависимыеЛоты();
	#Вставка
	Если Объект.РемонтыОборудования.Количество() > 0 Тогда 
		СтруктураПроверки = Новый Структура("гкс_СимптомДефекта",Неопределено);
		ЗаполнитьЗначенияСвойств(СтруктураПроверки,Объект.РемонтыОборудования[0]);
		Если Не СтруктураПроверки["гкс_СимптомДефекта"] = Неопределено Тогда 
			ОбновитьСимптомДефекта();
			ОбновитьЦеныНоменклатуры();
		КонецЕсли;
	КонецЕсли;
	гкс_ОбщегоНазначенияСервер.ДобавитьУОКатегорииРиска(ЭтотОбъект);
	Если РольДоступна("гкс_ИзменениеПроведеннойЗаявки") Тогда 
		ОткрытьДоступностьПолейДляРоли();
	КонецЕсли;
	// Гкс+[TOIR20-532] Вялых Д.А. от 10.02.2025. Добавлено:{
	УстановитьИспользованиеУОДляДанныхЕРП(Ложь); 
	// } Гкс-[TOIR20-532] Вялых Д.А. от 10.02.2025.
	#КонецВставки

КонецПроцедуры   

&НаКлиенте
&ИзменениеИКонтроль("ПередЗаписью")
Процедура гкс_ПередЗаписью(Отказ, ПараметрыЗаписи)
	#Вставка
	МассивСтруктур = Новый Массив();
	
	РеквизитыДляПроверки(МассивСтруктур);
	ПроверитьЗаполнениеРеквизитовШапки(МассивСтруктур, Отказ);
	ПроверитьЗаполнениеРемонтовОборудования(МассивСтруктур, Отказ);
	ПроверитьЗаполнениеМатериальныхЗатрат(МассивСтруктур, Отказ);
	ПроверитьЗаполнениеТрудовыхЗатрат(МассивСтруктур, Отказ);
	ПроверитьЗаполнениеРемонтныхРабот(МассивСтруктур, Отказ);
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	#КонецВставки

