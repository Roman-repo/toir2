Функция ПроверитьИзменениеДляПФ()
	Если Не Ссылка.РемонтныеРаботы.Количество() = РемонтныеРаботы.Количество() Тогда 
		Возврат Истина;
	Иначе
		Для Сч = 0 По РемонтныеРаботы.Количество() - 1 Цикл
			Строка1 = РемонтныеРаботы[Сч];
			Строка2 = Ссылка.РемонтныеРаботы[Сч];
			Если Не (Строка1.РемонтнаяРабота = Строка2.РемонтнаяРабота
				И Строка1.Количество = Строка2.Количество) Тогда 
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если Не Ссылка.МатериальныеЗатраты.Количество() = МатериальныеЗатраты.Количество() Тогда 
		Возврат Истина;
	Иначе
		Для Сч = 0 По МатериальныеЗатраты.Количество() - 1 Цикл
			Строка1 = МатериальныеЗатраты[Сч];
			Строка2 = Ссылка.МатериальныеЗатраты[Сч];
			Если Не (Строка1.Номенклатура = Строка2.Номенклатура
				И Строка1.Количество = Строка2.Количество
				И Строка1.гкс_Давальческие = Строка2.гкс_Давальческие) Тогда 
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если Не Ссылка.Инструменты.Количество() = Инструменты.Количество() Тогда 
		Возврат Истина;
	Иначе
		Для Сч = 0 По Инструменты.Количество() - 1 Цикл
			Строка1 = Инструменты[Сч];
			Строка2 = Ссылка.Инструменты[Сч];
			Если Не (Строка1.Инструмент = Строка2.Инструмент
				И Строка1.Количество = Строка2.Количество) Тогда 
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если Не Ссылка.ИсполнителиПоРемонтам.Количество() = ИсполнителиПоРемонтам.Количество() Тогда 
		Возврат Истина;
	Иначе
		Для Сч = 0 По ИсполнителиПоРемонтам.Количество() - 1 Цикл
			Строка1 = ИсполнителиПоРемонтам[Сч];
			Строка2 = Ссылка.ИсполнителиПоРемонтам[Сч];
			Если Не (Строка1.Исполнитель = Строка2.Исполнитель
				И Строка1.УточнениеИсполнителя = Строка2.УточнениеИсполнителя) Тогда 
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если Не Ссылка.ТрудовыеЗатраты.Количество() = ТрудовыеЗатраты.Количество() Тогда 
		Возврат Истина;
	Иначе
		Для Сч = 0 По ТрудовыеЗатраты.Количество() - 1 Цикл
			Строка1 = ТрудовыеЗатраты[Сч];
			Строка2 = Ссылка.ТрудовыеЗатраты[Сч];
			Если Не (Строка1.Квалификация = Строка2.Квалификация
				И Строка1.Количество = Строка2.Количество
				И Строка1.ВремяРаботы = Строка2.ВремяРаботы) Тогда 
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Ложь;
КонецФункции // гкс- [06.23] Деснол 16.06.2023

