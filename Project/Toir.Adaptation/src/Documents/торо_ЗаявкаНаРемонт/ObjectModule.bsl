&После("ПриЗаписи")
Процедура гкс_ПриЗаписи(Отказ)
	// гкс+ [10.23] Деснол 28.02.2024
	Если ОбменДанными.Загрузка Тогда 
		Возврат;
	КонецЕсли;
	// гкс- [10.23] Деснол 28.02.2024
	// гкс+ [06.23] Деснол 16.06.2023
	Если ДополнительныеСвойства.Свойство("ЕстьИзмененийРеквизитовТЗ") 
		И ДополнительныеСвойства.ЕстьИзмененийРеквизитовТЗ Тогда 
		ВыбранныйСтатус = Неопределено;
		НаборЗаписей = РегистрыСведений.торо_ТекущиеСтатусыСогласованияДокументов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.СогласуемыйДокумент.Установить(Ссылка);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() Тогда 
			ВыбранныйСтатус = НаборЗаписей[0].СтатусДокумента;
		КонецЕсли;
		Если Не ВыбранныйСтатус = Неопределено Тогда 
			НужноДобавитьПФвДО = Ложь;
			Настройка = Справочники.гкс_ПроизвольныеНастройкиИнтеграций.СтатусыЗаявокКВыгрузке;
			МассивСвойств = Справочники.гкс_ПроизвольныеНастройкиИнтеграций.ПолучитьСвойства(Настройка, "Свойства");
			Для каждого Свойство Из МассивСвойств Цикл
				Если Свойство.Значение = ВыбранныйСтатус Тогда 
					НужноДобавитьПФвДО = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если НужноДобавитьПФвДО Тогда 
				Попытка
					Документы.торо_ЗаявкаНаРемонт.гкс_ДобавитьПФТехЗаданияВДО(Ссылка);
				Исключение
					ОписаниеОшибки = ОписаниеОшибки();
					ЗаписьЖурналаРегистрации(НСтр("es='La excepción';ru='Исключение';en='An exception'"), УровеньЖурналаРегистрации.Предупреждение,, ОписаниеОшибки);
					Сообщение = Новый СообщениеПользователю();
					Сообщение.Текст = ОписаниеОшибки;
					Сообщение.Сообщить();
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	// гкс- [06.23] Деснол 16.06.2023
	// гкс+ [10.23] Деснол 28.02.2024
	Если гкс_РаботыТСПожаротушения = "Да" И Не Отказ И Проведен И Не БезусловнаяЗапись = Истина Тогда 
		// При проведении отправлять уведомление. когда останавливать неизвестно
		СобытиеСсылка = Константы.гкс_СобытиеПроведенияСметыПожаротушения.Получить();
		Если ЗначениеЗаполнено(СобытиеСсылка) Тогда 
			МассивСвойств = Новый Массив();
			МассивСвойств.Добавить(Новый Структура("Ключ,Значение", "НавСсылка", ПолучитьНавигационнуюСсылку(Ссылка)));
			торо_РаботаСУведомлениями.гкс_ЗаписатьУведомленияСрокаСогласования(Ссылка, СобытиеСсылка, Новый Массив(), , МассивСвойств);
		КонецЕсли;
	КонецЕсли;
