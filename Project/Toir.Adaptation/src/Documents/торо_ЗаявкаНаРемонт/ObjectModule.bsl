Процедура гкс_ПроверитьДубльРемонта(Отказ)
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЧ.ID КАК ID
	               |ПОМЕСТИТЬ Исходные
	               |ИЗ
	               |	&ТЧ1 КАК ТЧ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Рег.Регистратор КАК Ссылка
	               |ИЗ
	               |	РегистрСведений.торо_ЗаявкиПоРемонтам.СрезПоследних(
	               |			,
	               |			IDРемонта В
	               |					(ВЫБРАТЬ
	               |						ТЧ.ID
	               |					ИЗ
	               |						Исходные КАК ТЧ)
	               |				И НЕ Регистратор = &Ссылка
	               |				И Регистратор ССЫЛКА Документ.торо_ЗаявкаНаРемонт) КАК Рег";
	Запрос.УстановитьПараметр("ТЧ1", РемонтыОборудования.Выгрузить());
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Отказ = Истина;
		МассивСсылок = Новый Массив();
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			МассивСсылок.Добавить(Строка(Выборка.Ссылка));
		КонецЦикла;
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='По ремонту уже есть проведенные заявки: ';en='there are already orders for repairs'")
			+ СтрСоединить(МассивСсылок, ", ");
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры
