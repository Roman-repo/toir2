		ОтборИсполнитель = ПараметрыПечати.ОтборИсполнитель;
		ЕстьОтборИсполнитель = Истина;
	Иначе
		ОтборИсполнитель = Новый Массив();
		ЕстьОтборИсполнитель = Ложь;
	КонецЕсли;
	// гкс- [Релиз18]
	
	Запрос = Новый Запрос;
	#Область РемонтыПечатки
	// гкс+ [Печатки] Куст 14.10.2020
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗаявкаНаРемонтРемонтыОборудования.Ссылка КАК Документ,
