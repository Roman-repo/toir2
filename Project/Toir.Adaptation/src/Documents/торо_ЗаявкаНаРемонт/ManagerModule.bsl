#Область ОбработчикиСобытий

 // Гкс+[TOIR20-677] Оселедько В.С. от 01.08.2025. Добавлено:{
&Перед("ОбработкаПолученияФормы")
Процедура гкс_ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		ВремяНачала = ОценкаПроизводительности.НачатьЗамерВремени();
		Параметры.Вставить("ВремяНачалаОткрытияФормы", ВремяНачала);
		СтандартнаяОбработка = Ложь;
		ВыбраннаяФорма = Метаданные.Документы.торо_ЗаявкаНаРемонт.Формы.ФормаДокумента.Имя;		
		
	ИначеЕсли ВидФормы = "ФормаСписка" Тогда	
		
		ВремяНачала = ОценкаПроизводительности.НачатьЗамерВремени();
		Параметры.Вставить("ВремяНачалаОткрытияФормы", ВремяНачала);
		СтандартнаяОбработка = Ложь;
		ВыбраннаяФорма = Метаданные.Документы.торо_ЗаявкаНаРемонт.Формы.ФормаСписка.Имя;
		
	КонецЕсли;
			
КонецПроцедуры // Гкс+[TOIR20-677]

#КонецОбласти

