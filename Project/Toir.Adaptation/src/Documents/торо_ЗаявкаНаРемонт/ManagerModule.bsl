		|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Подразделение КАК Подразделение,
		|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Номер КАК Номер,
		|	торо_ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта.ТехНомер КАК ТехНомер
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК торо_ЗаявкаНаРемонтРемонтыОборудования
		|ГДЕ
		|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка В(&Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ЗаявкаНаРемонтРемонтныеРаботы.Ссылка КАК Ссылка,
		|	торо_ЗаявкаНаРемонтРемонтныеРаботы.РемонтнаяРабота КАК РемонтнаяРабота,
		|	торо_ЗаявкаНаРемонтРемонтныеРаботы.ID КАК ИД,
		|	торо_ЗаявкаНаРемонтРемонтныеРаботы.Родитель_ID КАК Родитель_ИД,
		|	торо_ЗаявкаНаРемонтРемонтныеРаботы.РемонтыОборудования_ID КАК ИД_Ремонта,
		|	торо_ЗаявкаНаРемонтРемонтныеРаботы.гкс_Примечание КАК Примечание
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.РемонтныеРаботы КАК торо_ЗаявкаНаРемонтРемонтныеРаботы
		|ГДЕ
		|	торо_ЗаявкаНаРемонтРемонтныеРаботы.Ссылка В(&Ссылка)
		|ИТОГИ ПО
		|	Ссылка,
		|	ИД_Ремонта
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ЗаявкаНаРемонтИсполнителиПоРемонтам.Ссылка КАК Ссылка,
		|	торо_ЗаявкаНаРемонтИсполнителиПоРемонтам.Исполнитель КАК Исполнитель,
		|	торо_ЗаявкаНаРемонтИсполнителиПоРемонтам.РемонтыОборудования_ID КАК ИД_Ремонта
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.ИсполнителиПоРемонтам КАК торо_ЗаявкаНаРемонтИсполнителиПоРемонтам
		|ГДЕ
		|	торо_ЗаявкаНаРемонтИсполнителиПоРемонтам.Ссылка В(&Ссылка)
		|ИТОГИ ПО
		|	Ссылка,
		|	ИД_Ремонта";
	
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	НомерПакетаДокументов = 0;
	НомерПакетаТО = 1;
	НомерПакетаИсполнители = 2;
	
	ВыборкаДок = РезультатЗапроса[НомерПакетаДокументов].Выбрать();
	ВыборкаТО = РезультатЗапроса[НомерПакетаТО].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИсполнители = РезультатЗапроса[НомерПакетаИсполнители].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыводитьРазделитель = Ложь;
	Пока ВыборкаДок.Следующий() Цикл
		Если ВыводитьРазделитель Тогда 
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ВыводитьРазделитель = Истина;
		//
		Шапка.Параметры.Номер = ВыборкаДок.Номер;
		Шапка.Параметры.ТехНомер = ВыборкаДок.ТехНомер;
		Шапка.Параметры.ОР = ВыборкаДок.ОР;
		Шапка.Параметры.Организация = ВыборкаДок.Организация;
		Шапка.Параметры.Подразделение = ВыборкаДок.Подразделение;
		СтруктураПоискаДок = Новый Структура("Ссылка", ВыборкаДок.Ссылка);
		СтруктураПоискаИД = Новый Структура("ИД_Ремонта", ВыборкаДок.ИД);
		#Область ОбходТехКарт
		МассивТекстаТК = Новый Массив();
		ВыборкаТО.Сбросить();
		Если ВыборкаТО.НайтиСледующий(СтруктураПоискаДок) Тогда 
			ВыборкаТОИД = ВыборкаТО.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаТОИД.НайтиСледующий(СтруктураПоискаДок) Тогда 
				МассивТК = Новый Массив();
				МассивТО = Новый Массив();
				Выборка = ВыборкаТОИД.Выбрать();
				Пока Выборка.Следующий() Цикл
					ИмяТО = Строка(Выборка.РемонтнаяРабота);
					Если ЗначениеЗаполнено(Выборка.Примечание) Тогда 
						ИмяТО = ИмяТО + " " + Выборка.Примечание;
					КонецЕсли;
					Если ТипЗнч(Выборка.РемонтнаяРабота) = ТипИТК Тогда 
						Если Не ЗначениеЗаполнено(Выборка.Родитель_ИД) Тогда 
							СтруктураТК = Новый Структура("ИД,Имя,Строки", Выборка.ИД, ИмяТО, Новый Массив());
							МассивТК.Добавить(СтруктураТК);
						КонецЕсли;
					Иначе
						Если ЗначениеЗаполнено(Выборка.Родитель_ИД) Тогда 
							ТКНайдена = Ложь;
							Для Каждого СтрокаМассива Из МассивТК Цикл
								Если СтрокаМассива.ИД = Выборка.Родитель_ИД Тогда 
									СтрокаМассива.Строки.Добавить(ИмяТО);
									ТКНайдена = Истина;
									Прервать;
								КонецЕсли;
							КонецЦикла;
							Если Не ТКНайдена Тогда 
								МассивТО.Добавить(Новый Структура("ИД,Имя", Выборка.Родитель_ИД, ИмяТО));
							КонецЕсли;
						Иначе
							СтруктураТК = Новый Структура("ИД,Имя,Строки", Выборка.ИД, ИмяТО, Новый Массив());
							МассивТК.Добавить(СтруктураТК);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				Для Каждого СтрокаМассива Из МассивТО Цикл
					Для Каждого СтрокаТК Из МассивТК Цикл
						Если СтрокаТК.ИД = СтрокаМассива.ИД Тогда 
							СтрокаТК.Строки.Добавить(СтрокаМассива.Имя);
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
				Для Каждого СтрокаТК ИЗ МассивТК Цикл
					МассивТекстаТК.Добавить(СтрокаТК.Имя);
					Для Каждого СтрокаМассива Из СтрокаТК.Строки Цикл
						МассивТекстаТК.Добавить(СтрокаМассива);
					КонецЦикла;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		#КонецОбласти
		Шапка.Параметры.ТКиТО = СтрСоединить(МассивТекстаТК, ", ");
		ТабДокумент.Вывести(Шапка);
		ТабДокумент.Вывести(СтрокаТЧ);
		#Область ОбходИсполнителей
		МассивТекстаИсполнителей = Новый Массив();
		ВыборкаИсполнители.Сбросить();
		Если ВыборкаИсполнители.НайтиСледующий(СтруктураПоискаДок) Тогда 
			ВыборкаИспИД = ВыборкаИсполнители.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Если ВыборкаИспИД.НайтиСледующий(СтруктураПоискаДок) Тогда 
				Выборка = ВыборкаИспИД.Выбрать();
				Пока Выборка.Следующий() Цикл
					МассивТекстаИсполнителей.Добавить(Выборка.Исполнитель);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;		
		#КонецОбласти
		Подвал.Параметры.Исполнители = СтрСоединить(МассивТекстаИсполнителей, ", ");
		ТабДокумент.Вывести(Подвал);
	КонецЦикла;
	
	ТабДокумент.АвтоМасштаб	= Истина;
	ТабДокумент.ПолеСверху  = 0;
	ТабДокумент.ПолеСлева   = 0;
	ТабДокумент.ПолеСнизу   = 0;
	ТабДокумент.ПолеСправа  = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ТабДокумент.ТолькоПросмотр = Истина;
	
	Возврат ТабДокумент;
КонецФункции // гкс- [Релиз18]


