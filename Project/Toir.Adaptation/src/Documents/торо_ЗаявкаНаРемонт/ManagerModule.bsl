Функция гкс_ПечатьОбъемРабот(МассивОбъектов, ПараметрыПечати, НовыйСиноним)
	
	Макет  = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_ЗаявкаНаРемонт.ПФ_MXL_дс_НарядЗадание");
	ТабДокумент = Новый ТабличныйДокумент;
	Шапка = Макет.ПолучитьОбласть("Шапка2");
	СтрокаРР = Макет.ПолучитьОбласть("СтрокаРР");
	ПодвалРР = Макет.ПолучитьОбласть("ПодвалРР");
	СтрокаМЗ = Макет.ПолучитьОбласть("СтрокаМЗ");
	ШапкаИнструменты = Макет.ПолучитьОбласть("ШапкаИнструменты");
	СтрокаИнструменты = Макет.ПолучитьОбласть("СтрокаИнструменты");
	Подвал = Макет.ПолучитьОбласть("Подвал2");
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	
	ЗапросДокументов = Новый Запрос;
	ЗапросДокументов.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта КАК ОР,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.ID КАК ИД,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка КАК Док,
	|	Максимум(АктРемонты.Ссылка) КАК Акт,
	|	МАКСИМУМ(НЕ торо_ЗаявкаНаРемонтПрисоединенныеФайлы.Ссылка ЕСТЬ NULL) КАК ЕстьФайлы
	|ПОМЕСТИТЬ Ремонты
	|ИЗ
	|	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК торо_ЗаявкаНаРемонтРемонтыОборудования
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ЗаявкаНаРемонтПрисоединенныеФайлы КАК торо_ЗаявкаНаРемонтПрисоединенныеФайлы
	|		ПО торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка = торо_ЗаявкаНаРемонтПрисоединенныеФайлы.ВладелецФайла
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК АктРемонты
	|		ПО торо_ЗаявкаНаРемонтРемонтыОборудования.ID = АктРемонты.ID
	|ГДЕ
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка В(&Ссылка)
	|	И торо_ЗаявкаНаРемонтРемонтыОборудования.ID В(&ID)
	|
	|СГРУППИРОВАТЬ ПО
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.ID,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(торо_ЗаявкаНаРемонтДокументыОснования.ДокументОснование.Ответственный) КАК ОтветственныйДО,
	|	МАКСИМУМ(торо_ЗаявкаНаРемонтДокументыОснования.ДокументОснование.Дата) КАК ДатаДО,
	|	Ремонты.Док КАК Док
	|ПОМЕСТИТЬ ДокументыОснования
	|ИЗ
	|	Ремонты КАК Ремонты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ДокументыОснования КАК торо_ЗаявкаНаРемонтДокументыОснования
	|		ПО Ремонты.Док = торо_ЗаявкаНаРемонтДокументыОснования.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Ремонты.Док
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Ремонты.ОР КАК ОР,
	|	Ремонты.ОР.ИнвентарныйНомер КАК ИнвНомер,
	|	Ремонты.ОР.ТехНомер КАК ТехНомер,
	|	Ремонты.ОР.Организация КАК Организация,
	|	Ремонты.ОР.Направление КАК Специализация,
	|	РемонтыЗаявки.ОписаниеРемонта КАК НаправлениеНаУстранение,
	|	РемонтыЗаявки.Ссылка.Номер КАК НарядЗаданиеНомер,
	|	РемонтыЗаявки.Ссылка.Комментарий КАК КомментЗаявка,
	|	РемонтыЗаявки.Ссылка.Дата КАК Дата,
	|	РемонтыЗаявки.Ссылка.Ответственный КАК Ответственный,
	|	Ремонты.ИД КАК ИД,
	|	Ремонты.Док КАК Док,
	|	Ремонты.Док.гкс_НуженОстанов КАК Флаг1,
	|	Ремонты.Док.гкс_НуженПодготовка КАК Флаг2,
	|	Ремонты.Док.гкс_РаботаПовышеннойОпасности КАК Флаг3,
	|	Ремонты.Док.гкс_НуженИспытание КАК Флаг4,
	|	ЕСТЬNULL(торо_ВнешнееОснованиеДляРаботОбследованноеОборудование.Ссылка.Описание,
	|	ЕСТЬNULL(торо_ВнешнееОснованиеДляРаботОбследованноеОборудование.Описание,
	|	ЕСТЬNULL(торо_ВыявленныеДефектыСписокДефектов.ДефектОписание, РемонтыЗаявки.гкс_ИмяТехКартыРемонта))) 
	|	КАК ДефектОписание,
	|	Ремонты.ЕстьФайлы КАК ЕстьФайлы,
	|	ЕСТЬNULL(ИзМатрицы.КатегорияРиска, Ремонты.ОР.гкс_КатегорияРиска) КАК Приоритет,
	|	Ремонты.Акт.Комментарий КАК Комментарий,
	|	Ремонты.ОР.ТиповойОР КАК ТОР,
	|	ДокументыОснования.ОтветственныйДО КАК ОтветственныйДО,
	|	ДокументыОснования.ДатаДО КАК ДатаДО,
	|	РемонтыЗаявки.ВидРемонтныхРабот КАК ВидРабот,
	|	РемонтыЗаявки.ДатаНачала КАК ДатаНачала,
	|	РемонтыЗаявки.ДатаОкончания КАК ДатаОкончания,
	|	гкс_ТехническиеМеста.Отметка КАК Отметка,
	|	гкс_ТехническиеМеста.Участок КАК Участок,
	|	гкс_ТехническиеМеста.ЗаводПодразделение КАК Завод,
	|	гкс_ТехническиеМеста.МестоПлощадка КАК Место
	|ИЗ
	|	Ремонты КАК Ремонты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК РемонтыЗаявки
	|		ПО Ремонты.Док = РемонтыЗаявки.Ссылка
	|			И Ремонты.ИД = РемонтыЗаявки.ID
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты.РезультатыПодбораИзМатрицыОценкиРисков КАК ИзМатрицы
	|			ПО торо_ВыявленныеДефектыСписокДефектов.Ссылка = ИзМатрицы.Ссылка
	|				И торо_ВыявленныеДефектыСписокДефектов.ID = ИзМатрицы.ID_Ремонта
	|				И (ИзМатрицы.РезультатВыбора = ИСТИНА)
	|		ПО Ремонты.ИД = торо_ВыявленныеДефектыСписокДефектов.ID
	|			И (торо_ВыявленныеДефектыСписокДефектов.Ссылка.ПометкаУдаления = ЛОЖЬ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ВнешнееОснованиеДляРабот.ОбследованноеОборудование 
	|	КАК торо_ВнешнееОснованиеДляРаботОбследованноеОборудование
	|		ПО Ремонты.ИД = торо_ВнешнееОснованиеДляРаботОбследованноеОборудование.ID
	|			И (торо_ВнешнееОснованиеДляРаботОбследованноеОборудование.Ссылка.ПометкаУдаления = ЛОЖЬ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДокументыОснования КАК ДокументыОснования
	|		ПО Ремонты.Док = ДокументыОснования.Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.гкс_ТехническиеМеста КАК гкс_ТехническиеМеста
	|			ПО (гкс_ТекущиеФМОР.ОР = гкс_ТекущиеФМОР.ФМ
	|						И гкс_ТекущиеФМОР.ТМ = гкс_ТехническиеМеста.Ссылка
	|					ИЛИ НЕ гкс_ТекущиеФМОР.ОР = гкс_ТекущиеФМОР.ФМ
	|						И гкс_ТекущиеФМОР.ТМФМ = гкс_ТехническиеМеста.Ссылка)
	|		ПО Ремонты.ОР = гкс_ТекущиеФМОР.ОР
	|;
