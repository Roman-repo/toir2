			Пока Выборка.Следующий() Цикл
				СтрокаРР.Параметры.РР = Строка(Выборка.РР) + " " + Выборка.гкс_Примечание;
				СтрокаРР.Параметры.КолвоРР = Выборка.КолвоРР;
				НуженВывод = Истина;
				ВыборкаТЗ = Выборка.Выбрать();
				Пока ВыборкаТЗ.Следующий() Цикл
					СтрокаРР.Параметры.Квалификация = ВыборкаТЗ.Квалификация;
					СтрокаРР.Параметры.Колво = ВыборкаТЗ.Количество;
					План = ВыборкаТЗ.ВремяРаботы / 60;
					Итог1 = Итог1 + (План * ВыборкаТЗ.Количество);
					Если План = Цел(План) Тогда 
						План = Строка(План);
					КонецЕсли;
					СтрокаРР.Параметры.План = План;
					ТабДокумент.Вывести(СтрокаРР);
					НуженВывод = Ложь;
					СтрокаРР.Параметры.КолвоРР = "";
					СтрокаРР.Параметры.Квалификация = "";
					СтрокаРР.Параметры.Колво = "";
					СтрокаРР.Параметры.План = "";
					СтрокаРР.Параметры.РР = "";
				КонецЦикла;
				Если НуженВывод Тогда 
					ТабДокумент.Вывести(СтрокаРР);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		ВыборкаИДРР.Сбросить();
		
		Итог2 = (ВыборкаДокументов.ДатаОкончания - ВыборкаДокументов.ДатаНачала) / 60;
		
		Если Итог1 = Цел(Итог1) Тогда 
			Итог1 = Строка(Итог1);
		КонецЕсли;
		Если Итог2 = Цел(Итог2) Тогда 
			Итог2 = Строка(Итог2);
		КонецЕсли;
		ПодвалРР.Параметры.Итог1 = Итог1;
		// гкс+ [02.23] Деснол 06.02.2023
		//ПодвалРР.Параметры.Итог2 = Итог2;
		// гкс- [02.23] Деснол 06.02.2023
		ТабДокумент.Вывести(ПодвалРР);
		
		// Гкс+[TOIR20-504] Вялых Д.А. от 15.01.2025. Добавлено:{
		Если ЭтоНоваяВерсияМакета Тогда
			ТабДокумент.Вывести(ШапкаИП);
			Пока ВыборкаИзмеряемыеПоказатели.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтрокаИП.Параметры, ВыборкаИзмеряемыеПоказатели);
				ТабДокумент.Вывести(СтрокаИП);
			КонецЦикла;
			ТабДокумент.Вывести(ШапкаМЗ);
		КонецЕсли;
		// } Гкс-[TOIR20-504] Вялых Д.А. от 15.01.2025.
		
		Если ВыборкаМЗ.НайтиСледующий(Новый Структура("ИД", ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаМЗ.Выбрать();
			Пока Выборка.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтрокаМЗ.Параметры, Выборка);
				ТабДокумент.Вывести(СтрокаМЗ);
			КонецЦикла;
		КонецЕсли;
		ВыборкаМЗ.Сбросить();
		
		ТабДокумент.Вывести(ШапкаИнструменты);
		Если ВыборкаИн.НайтиСледующий(Новый Структура("ИД", ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаИн.Выбрать();
			Пока Выборка.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтрокаИнструменты.Параметры, Выборка);
				ТабДокумент.Вывести(СтрокаИнструменты);
			КонецЦикла;
		КонецЕсли;
		ВыборкаИн.Сбросить(); 
		
		// Гкс+[TOIR20-504] Вялых Д.А. от 15.01.2025. Добавлено:{ 
		Если ЭтоНоваяВерсияМакета Тогда
			ТабДокумент.Вывести(Подвал_ч1);
			ТабДокумент.Вывести(ШапкаРаботПО);
			Пока ВыборкаМерыБезопасности.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтрокаРаботПО.Параметры, ВыборкаМерыБезопасности);
				ТабДокумент.Вывести(СтрокаРаботПО);
			КонецЦикла;
			ТабДокумент.Вывести(ШапкаИспытания);
			Пока ВыборкаИспытанияОборудования.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтрокаИспытания.Параметры, ВыборкаИспытанияОборудования);
				ТабДокумент.Вывести(СтрокаИспытания);
			КонецЦикла;
			ТабДокумент.Вывести(ПодвалПрименяемая);
		КонецЕсли;
		// } Гкс-[TOIR20-504] Вялых Д.А. от 15.01.2025.
		
		Если ВыборкаИспол.НайтиСледующий(Новый Структура("ИД", ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаИспол.Выбрать();
			Если Выборка.Следующий() Тогда 
				Подвал.Параметры.Исполнитель = Выборка.Исполнитель;
				Если ТипЗнч(Выборка.Исполнитель) = Тип("СправочникСсылка.Контрагенты") Тогда 
					Подвал.Параметры.Договор = Выборка.УточнениеИсполнителя;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		ВыборкаИспол.Сбросить();
		
		ТемпТекст = "";
		Если ВыборкаРРАкта.НайтиСледующий(Новый Структура("ИД",ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаРРАкта.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выборка.Следующий() Цикл
				ТемпТекст = ТемпТекст + ?(ЗначениеЗаполнено(ТемпТекст),", ","") 
				+ Выборка.РР + " " + Выборка.гкс_Примечание + "/ " +(Выборка.ВремяРаботы/60)+" мин.";
			КонецЦикла;
		КонецЕсли;
		Подвал.Параметры.СписокТО = ТемпТекст;
		ВыборкаРРАкта.Сбросить();
		
		ТемпТекст = "";
		Если ВыборкаМЗАкта.НайтиСледующий(Новый Структура("ИД",ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаМЗАкта.Выбрать();
			Пока Выборка.Следующий() Цикл
				ТемпТекст = ТемпТекст + ?(ЗначениеЗаполнено(ТемпТекст),", ","") 
				+ Выборка.Номенклатура + "/ " +Выборка.Колво +" "+Выборка.ЕдИзм+".";
			КонецЦикла;
		КонецЕсли;
		Подвал.Параметры.МатЗатраты = ТемпТекст;
		ВыборкаМЗАкта.Сбросить();
		
		// Гкс+[TOIR20-347] Лебедев Н.А. от 22.02.2023. Удалено:{
		//Подвал.Параметры.СмФайлы = ВыборкаДокументов.КомментЗаявка;
		// } Гкс-[TOIR20-347] Лебедев Н.А. от 22.02.2023.	
		// Гкс+[TOIR20-351] Лебедев Н.А. от 15.03.2023. Удалено:{
		//Если ВыборкаДокументов.ЕстьФайлы Тогда 
		//	Подвал.Параметры.СмФайлы = Подвал.Параметры.СмФайлы + Символы.ПС
		//	+  "См. вложенные файлы";
		//КонецЕсли;
		// } Гкс-[TOIR20-351] Лебедев Н.А. от 15.03.2023.
		
		ТабДокумент.Вывести(Подвал);
	КонецЦикла;
	
	// Зададим параметры макета
	ТабДокумент.АвтоМасштаб	= Истина;
	ТабДокумент.ПолеСверху  = 0;
	ТабДокумент.ПолеСлева   = 0;
	ТабДокумент.ПолеСнизу   = 0;
	ТабДокумент.ПолеСправа  = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ТабДокумент.ТолькоПросмотр = Истина;
	
	Возврат ТабДокумент;
	
	
КонецФункции

Функция ПреобразоватьФИО(Сотрудник)
	МассивИмени = СтрРазделить(Строка(Сотрудник)," ",Ложь);
	Если МассивИмени.Количество() > 2 Тогда 
		Возврат МассивИмени[0] +" "+ Лев(МассивИмени[1],1) +". "+ Лев(МассивИмени[2],1)+".";
	КонецЕсли;
	Возврат Сотрудник;
КонецФункции
