Процедура гкс_ДобавитьПФТехЗаданияВДО(ВнешнийОбъект, НеОбновлять = Ложь) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Док.Номер КАК Номер
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт КАК Док
		|ГДЕ
		|	Док.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ВнешнийОбъект);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();	
	Выборка.Следующий();
	Имя = "Техническое задание " + Выборка.Номер;
	Файлы = ИнтеграцияС1СДокументооборотВызовСервера.ФайлыПоОбъектуПотребителю(
		ВнешнийОбъект.УникальныйИдентификатор(), Строка(ВнешнийОбъект), ВнешнийОбъект.Метаданные().ПолноеИмя());
	Идентификатор = "";
	Для каждого СведенияОФайле Из Файлы.files Цикл
		Если СведенияОФайле.name = Имя Тогда
			Идентификатор = СведенияОФайле.objectId.id;
			Если НеОбновлять Тогда 
				Возврат;
			КонецЕсли;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	//
	УникальныйИдентификаторФормы = Неопределено;
	//
	ПолныйПуть = ПолучитьИмяВременногоФайла("pdf");
	ДопПараметры = Новый Структура();
	ДопПараметры.Вставить("Идентификатор", Идентификатор);
	ДопПараметры.Вставить("Имя", Имя);
	ДопПараметры.Вставить("Расширение", "pdf");
	ДопПараметры.Вставить("УникальныйИдентификаторФормы", УникальныйИдентификаторФормы);
	ДопПараметры.Вставить("ОписаниеОповещения", Неопределено);
	ДопПараметры.Вставить("ОсвободитьФайл", Ложь);
	ДопПараметры.Вставить("ОбновитьСведенияОРедактировании", Ложь);	
	//
	ТабДок = документы.торо_ЗаявкаНаРемонт.гкс_ПолучитьПФТехЗадание(ВнешнийОбъект);
	ТабДок.Записать(ПолныйПуть, ТипФайлаТабличногоДокумента.PDF);
	ДвоичныйФайл = Новый ДвоичныеДанные(ПолныйПуть);
	АдресВХ = ПоместитьВоВременноеХранилище(ДвоичныйФайл, УникальныйИдентификаторФормы);
	ДопПараметры.Вставить("АдресВХ", АдресВХ);
	ДопПараметры.Вставить("Размер", 100);
	ДопПараметры.Вставить("ВремяИзменения", ТекущаяДата());
	ДопПараметры.Вставить("ВремяИзмененияУниверсальное", ТекущаяДата());
	//	
	Если Идентификатор = "" Тогда 
		СоздатьНовыйДО(ВнешнийОбъект, ДопПараметры);
		//
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Печатная форма добавлена в файлы ДО";
		Сообщение.Сообщить();
	Иначе
		СведенияОРедактировании = ИнтеграцияС1СДокументооборотВызовСервера.
			ПолучитьСведенияОРедактированииФайла(ДопПараметры.Идентификатор, "DMFile");
		ДопПараметры.Вставить("СведенияОРедактировании", СведенияОРедактировании);
		ОбновитьПФНаСервереПосле(АдресВХ, ПолныйПуть, ДопПараметры);
		//
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Печатная форма обновлена в списке файлов ДО";
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

Процедура ОбновитьПФНаСервереПосле(Адрес, ПолныйПуть, Параметры)
	Параметры.Вставить("АдресВременногоХранилищаФайла", Адрес);
	СтруктураИмени = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПолныйПуть, Ложь);
	
	Параметры.Вставить("Расширение", СтруктураИмени.Расширение);
	
	Файл = Новый Файл(ПолныйПуть);
	Параметры.Вставить("Размер", Файл.Размер());
	Параметры.Вставить("ДатаМодификации", Файл.ПолучитьВремяИзменения());
	Параметры.Вставить("ДатаМодификацииУниверсальная", Файл.ПолучитьУниверсальноеВремяИзменения());
	
	Параметры.Вставить("Текст", "");
	
	// Удалим параметры, которые передавать на сервер нельзя и не нужно.
	ОписаниеОповещения = Параметры.ОписаниеОповещения;
	Параметры.Удалить("ОписаниеОповещения");
	
	Если ИнтеграцияС1СДокументооборотВызовСервера.
		ОбновитьФайлДвоичнымиДаннымиВременногоХранилища(Параметры) Тогда
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьНовыйДО(ВнешнийОбъект, ПараметрыСоздания)
	Прокси = ИнтеграцияС1СДокументооборотПовтИсп.ПолучитьПрокси();
	
	Запрос = ИнтеграцияС1СДокументооборот.СоздатьОбъект(Прокси, "DMAddLinkedFileRequest");
	
	Запрос.rootFolderID = ПолучитьИдентификаторКорневойПапкиФайлов1СДокументооборот();
	
	Запрос.file = ИнтеграцияС1СДокументооборот.СоздатьОбъект(Прокси, "DMFile");
	
	Запрос.file.externalObject = ИнтеграцияС1СДокументооборот.СоздатьОбъект(Прокси, "ExternalObject");
	Запрос.file.externalObject.name = Строка(ВнешнийОбъект);
	Запрос.file.externalObject.id = Строка(ВнешнийОбъект.УникальныйИдентификатор());
	Запрос.file.externalObject.type = ВнешнийОбъект.Метаданные().ПолноеИмя();
	
	Запрос.file.objectId = ИнтеграцияС1СДокументооборот.СоздатьObjectID(Прокси, "", "DMFile");
	Запрос.file.binaryData = ПолучитьИзВременногоХранилища(ПараметрыСоздания.АдресВХ);
	Запрос.file.extension = ПараметрыСоздания.Расширение;
	Запрос.file.modificationDate = ПараметрыСоздания.ВремяИзменения;
	Запрос.file.modificationDateUniversal = ПараметрыСоздания.ВремяИзмененияУниверсальное;
	Запрос.file.name = ПараметрыСоздания.Имя;
	Запрос.file.size = ПараметрыСоздания.Размер;
	
	МаксРазмерФайла = ИнтеграцияС1СДокументооборотВызовСервера.МаксимальныйРазмерПередаваемогоФайла();
	Если ПараметрыСоздания.Размер > МаксРазмерФайла Тогда
		РазмерВМб = ПараметрыСоздания.Размер / (1024 * 1024);
		РазмерВМбМакс = МаксРазмерФайла / (1024 * 1024);
		ВызватьИсключение
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("es='La dimensión del fichero ""%1"" (%2 Mb) supera máximamente admisible (%3 Mb).';ru='Размер файла ""%1"" (%2 Мб) превышает максимально допустимый (%3 Мб).';en='File size ""%1"" (%2 Mb) exceeds the maximum allowed (%3 Mb).'"),
			ПараметрыСоздания.Имя, 
			РаботаСФайламиСлужебныйКлиентСервер.ПолучитьСтрокуСРазмеромФайла(РазмерВМб),
			РаботаСФайламиСлужебныйКлиентСервер.ПолучитьСтрокуСРазмеромФайла(РазмерВМбМакс));
	КонецЕсли;
		
	Ответ = Прокси.execute(Запрос);
	ИнтеграцияС1СДокументооборот.ПроверитьВозвратВебСервиса(Прокси, Ответ);
	
	//Ответ.file.objectId.id;
КонецПроцедуры

Функция ПолучитьИдентификаторКорневойПапкиФайлов1СДокументооборот() 
	
	УстановитьПривилегированныйРежим(Истина);
	ИдентификаторКорневойПапкиФайлов1СДокументооборот = 
		Константы.ИдентификаторКорневойПапкиФайлов1СДокументооборот.Получить();
	Возврат ИдентификаторКорневойПапкиФайлов1СДокументооборот;
	
КонецФункции

#КонецОбласти