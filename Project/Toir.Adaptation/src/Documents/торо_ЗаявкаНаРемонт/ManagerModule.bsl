	|	СУММА(торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Количество) КАК Колво,
	|	ЕСТЬNULL(УпаковкиНоменклатуры.Наименование, 
	|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура.ЕдиницаИзмерения) КАК ЕдИзм
	|ИЗ
	|	Ремонты КАК Ремонты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтныеРаботы 
	|	КАК торо_АктОВыполненииЭтапаРаботРемонтныеРаботы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.МатериальныеЗатраты 
	|	КАК торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
	|				ПО торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ЕдиницаИзмерения = УпаковкиНоменклатуры.Ссылка
	|			ПО торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Ссылка = 
	|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Ссылка
	|				И торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтыОборудования_ID = 
	|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.РемонтыОборудования_ID
	|				И торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.ID = торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ID
	|		ПО Ремонты.Акт = торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.Ссылка
	|			И Ремонты.ИД = торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.РемонтыОборудования_ID
	|			И (торо_АктОВыполненииЭтапаРаботРемонтныеРаботы.НоваяОперация = ИСТИНА)
	|
	|СГРУППИРОВАТЬ ПО
	|	Ремонты.ИД,
	|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура,
	|	ЕСТЬNULL(УпаковкиНоменклатуры.Наименование, 
	|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура.ЕдиницаИзмерения)
	|ИТОГИ ПО
	|	ИД";	
	ЗапросДокументов.УстановитьПараметр("Ссылка", МассивОбъектов);
	ЗапросДокументов.УстановитьПараметр("СтатусСогласован", 
	Справочники.торо_СтатусыСогласованияДокументовРемонтныхРабот.Согласован);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		ЗапросДокументов.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		ЗапросДокументов.Текст = СтрЗаменить(ЗапросДокументов.Текст, 
		"И торо_ЗаявкаНаРемонтРемонтыОборудования.ID В(&ID)", "");
	КонецЕсли;
	
	ЭтоПервый = Истина;
	ИндексВыборкиСДокументами = 2;
	ИндексВыборкиСРемонтнымиРаботами = 4;
	ИндексВыборкиСМатериальнымиЗатратами = 5;
	ИндексВыборкиСИнструментами = 6;
	ИндексВыборкиСИсполнителями = 7;
	ИндексВыборкиССогласующими = 8;
	ИндексВыборкиСАктуальнымиПериодами = 9;
	ИндексВыборкиСРемонтнымиРаботамиАкта = 10;
	ИндексВыборкиСМатериальнымиЗатратамиАкта = 11;
	
	РезультатЗапроса = ЗапросДокументов.ВыполнитьПакет();
	ВыборкаДокументов = РезультатЗапроса[ИндексВыборкиСДокументами].Выбрать();
	ВыборкаИДРР = РезультатЗапроса[ИндексВыборкиСРемонтнымиРаботами].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМЗ = РезультатЗапроса[ИндексВыборкиСМатериальнымиЗатратами].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИн = РезультатЗапроса[ИндексВыборкиСИнструментами].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИспол = РезультатЗапроса[ИндексВыборкиСИсполнителями].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаСогл = РезультатЗапроса[ИндексВыборкиССогласующими].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаАктуальные = 
	РезультатЗапроса[ИндексВыборкиСАктуальнымиПериодами].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаРРАкта = 
	РезультатЗапроса[ИндексВыборкиСРемонтнымиРаботамиАкта].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаМЗАкта = 
	РезультатЗапроса[ИндексВыборкиСМатериальнымиЗатратамиАкта].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокументов.Следующий() Цикл
		Если НЕ ЭтоПервый Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ЭтоПервый = Ложь;
		//
		ЗаполнитьЗначенияСвойств(Шапка.Параметры,ВыборкаДокументов);
		Шапка.Параметры.Номер = ВыборкаДокументов.НарядЗаданиеНомер;
		НовыйСиноним = " Объем работ по заявке " + ВыборкаДокументов.НарядЗаданиеНомер;
		ТабДокумент.Вывести(Шапка);
		//
		Итог1 = 0; Итог2 = 0;
		Если ВыборкаИДРР.НайтиСледующий(Новый Структура("ИД",ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаИДРР.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выборка.Следующий() Цикл
				СтрокаРР.Параметры.РР = Строка(Выборка.РР) + " " + Выборка.гкс_Примечание;
				СтрокаРР.Параметры.КолвоРР = Выборка.КолвоРР;
				НуженВывод = Истина;
				ВыборкаТЗ = Выборка.Выбрать();
				Пока ВыборкаТЗ.Следующий() Цикл
					СтрокаРР.Параметры.Квалификация = ВыборкаТЗ.Квалификация;
					СтрокаРР.Параметры.Колво = ВыборкаТЗ.Количество;
					План = ВыборкаТЗ.ВремяРаботы / 60;
					Итог1 = Итог1 + (План * ВыборкаТЗ.Количество);
					Если План = Цел(План) Тогда 
						План = Строка(План);
					КонецЕсли;
					СтрокаРР.Параметры.План = План;
					ТабДокумент.Вывести(СтрокаРР);
					НуженВывод = Ложь;
					СтрокаРР.Параметры.КолвоРР = "";
					СтрокаРР.Параметры.Квалификация = "";
					СтрокаРР.Параметры.Колво = "";
					СтрокаРР.Параметры.План = "";
					СтрокаРР.Параметры.РР = "";
				КонецЦикла;
				Если НуженВывод Тогда 
					ТабДокумент.Вывести(СтрокаРР);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		ВыборкаИДРР.Сбросить();
		
		Итог2 = (ВыборкаДокументов.ДатаОкончания - ВыборкаДокументов.ДатаНачала) / 60;
		
		Если Итог1 = Цел(Итог1) Тогда 
			Итог1 = Строка(Итог1);
		КонецЕсли;
		Если Итог2 = Цел(Итог2) Тогда 
			Итог2 = Строка(Итог2);
		КонецЕсли;
		ПодвалРР.Параметры.Итог1 = Итог1;
		// гкс+ [02.23] Деснол 06.02.2023
		//ПодвалРР.Параметры.Итог2 = Итог2;
		// гкс- [02.23] Деснол 06.02.2023
		ТабДокумент.Вывести(ПодвалРР);
		
		Если ВыборкаМЗ.НайтиСледующий(Новый Структура("ИД",ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаМЗ.Выбрать();
			Пока Выборка.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтрокаМЗ.Параметры,Выборка);
				ТабДокумент.Вывести(СтрокаМЗ);
			КонецЦикла;
		КонецЕсли;
		ВыборкаМЗ.Сбросить();
		
		ТабДокумент.Вывести(ШапкаИнструменты);
		Если ВыборкаИн.НайтиСледующий(Новый Структура("ИД",ВыборкаДокументов.ИД)) Тогда 
			Выборка = ВыборкаИн.Выбрать();
			Пока Выборка.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(СтрокаИнструменты.Параметры,Выборка);
				ТабДокумент.Вывести(СтрокаИнструменты);
			КонецЦикла;
		КонецЕсли;
		ВыборкаИн.Сбросить();
		
		// Гкс+[TOIR20-347] Лебедев Н.А. от 22.02.2023. Удалено:{
		//Подвал.Параметры.СмФайлы = ВыборкаДокументов.КомментЗаявка;
		// } Гкс-[TOIR20-347] Лебедев Н.А. от 22.02.2023.
		// Гкс+[TOIR20-351] Лебедев Н.А. от 15.03.2023. Удалено:{
		//Если ВыборкаДокументов.ЕстьФайлы Тогда 
		//	Подвал.Параметры.СмФайлы = Подвал.Параметры.СмФайлы + Символы.ПС
		//	+  "См. вложенные файлы";
		//КонецЕсли;
		// } Гкс-[TOIR20-351] Лебедев Н.А. от 15.03.2023.
		
		ТабДокумент.Вывести(Подвал);
	КонецЦикла;
	
	// Зададим параметры макета
	ТабДокумент.АвтоМасштаб	= Истина;
	ТабДокумент.ПолеСверху  = 0;
	ТабДокумент.ПолеСлева   = 0;
	ТабДокумент.ПолеСнизу   = 0;
	ТабДокумент.ПолеСправа  = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ТабДокумент.ТолькоПросмотр = Истина;
	
	Возврат ТабДокумент;
	
	
КонецФункции

// гкс+ [7729] Тарасов 28.09.2020
Функция ПечатьЗаказНаРаботу(МассивОбъектов, ПараметрыПечати)
	
