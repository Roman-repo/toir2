// гкс+ [11.22] Деснол 24.11.2022
Функция дс_ПечатьДефектныйАкт(МассивОбъектов, ПараметрыПечати)

	Макет  = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_ВыявленныеДефекты.ПФ_MXL_дс_ДефектныйАкт");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапкаСтрока1 = Макет.ПолучитьОбласть("ШапкаСтрока1");
	ОбластьШапкаСтрока2 = Макет.ПолучитьОбласть("ШапкаСтрока2");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	ОбластьПодвалСтрока1 = Макет.ПолучитьОбласть("ПодвалСтрока1");
	ОбластьПодвалСтрока2 = Макет.ПолучитьОбласть("ПодвалСтрока2");
	ТабДокумент = Новый ТабличныйДокумент;

	ЗапросДокументов = Новый Запрос;
	ЗапросДокументов.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ВыявленныеДефектыСписокДефектов.Ссылка КАК Ссылка,
	|	торо_ВыявленныеДефектыСписокДефектов.НомерСтроки КАК НомерСтроки,
	|	торо_ВыявленныеДефектыСписокДефектов.ДефектОписание КАК ДефектОписание,
	|	торо_ВыявленныеДефектыСписокДефектов.ОтказавшийЭлемент КАК ОР,
	|	торо_ВыявленныеДефектыСписокДефектов.ID КАК ID,
	|	торо_ВыявленныеДефектыСписокДефектов.Ссылка.Комиссия КАК Комиссия,
	|	торо_Комиссии.гкс_НомерПриказа КАК гкс_НомерПриказа,
	|	торо_Комиссии.гкс_ДатаПриказа КАК гкс_ДатаПриказа
	|ИЗ
	|	Документ.торо_ВыявленныеДефекты.СписокДефектов КАК торо_ВыявленныеДефектыСписокДефектов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_Комиссии КАК торо_Комиссии
	|		ПО торо_ВыявленныеДефектыСписокДефектов.Ссылка.Комиссия = торо_Комиссии.Ссылка
	|ГДЕ
	|	торо_ВыявленныеДефектыСписокДефектов.Ссылка В(&Ссылка)
	|	И торо_ВыявленныеДефектыСписокДефектов.ID В(&ID)
	|ИТОГИ
	|	МАКСИМУМ(Комиссия)
	|ПО
	|	Ссылка";
	// гкс+ [01.23] Деснол 18.01.2023
	ЗапросДокументов.Текст = ЗапросДокументов.Текст + " ; "
	+ "ВЫБРАТЬ
          |	Дефект.Ссылка КАК Ссылка,
          |	ЕСТЬNULL(КадроваяИсторияСотрудниковСрезПоследних.Сотрудник, Подразделения.ТекущийРуководитель) КАК Сотрудник,
          |	КадроваяИсторияСотрудниковСрезПоследних.Должность КАК Должность,
          |	КадроваяИсторияСотрудниковСрезПоследних.Период КАК Период
          |ИЗ
          |	Документ.торо_ВыявленныеДефекты КАК Дефект
          |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК Подразделения
          |			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних(&Дата, ) КАК КадроваяИсторияСотрудниковСрезПоследних
          |			ПО Подразделения.ТекущийРуководитель = КадроваяИсторияСотрудниковСрезПоследних.Сотрудник.ФизическоеЛицо
          |		ПО (Подразделения.Ссылка = Дефект.Подразделение)
          |ГДЕ
          |	Дефект.Ссылка В(&Ссылка)
          |
          |УПОРЯДОЧИТЬ ПО
          |	Период УБЫВ
          |ИТОГИ ПО
          |	Ссылка";
	// гкс- [01.23] Деснол 18.01.2023
	
	ЗапросДокументов.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		ЗапросДокументов.УстановитьПараметр("ID", ПараметрыПечати.МассивID);
	Иначе
		ЗапросДокументов.Текст = СтрЗаменить(ЗапросДокументов.Текст, "И торо_ВыявленныеДефектыСписокДефектов.ID В(&ID)", "");
	КонецЕсли;
	
	ЭтоПервый = Истина;
	// гкс+ [01.23] Деснол 18.01.2023
	ЗапросДокументов.УстановитьПараметр("Дата", Дата(3999, 1, 1));
	РезультатЗапроса = ЗапросДокументов.ВыполнитьПакет();
	ВыборкаДокументов = РезультатЗапроса[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	ВыборкаСотрудникПодразделения = РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	// гкс- [01.23] Деснол 18.01.2023
	Пока ВыборкаДокументов.Следующий() Цикл
		
		Дефект = ВыборкаДокументов.Ссылка;
		#Область ПоискКомиссии
		СтруктураОтбора = Новый Структура("Комиссия,Дата", ВыборкаДокументов.Комиссия, Дата(3999, 1, 1));
		
		ВыборкаКомиссия = ПолучитьКомиссию(СтруктураОтбора);
		МассивСтруктурКомиссии = Новый Массив();
		
		Если ВыборкаКомиссия.Следующий() Тогда
			
			СтруктураКомиссии = Новый Структура();
			СтруктураКомиссии.Вставить("ФИО", ПреобразоватьФИО(ВыборкаКомиссия.ПредседательКомиссии));
			СтруктураКомиссии.Вставить("Должность", ВыборкаКомиссия.ДолжностьПредседателя);
			МассивСтруктурКомиссии.Добавить(СтруктураКомиссии);
			
			ВыборкаЧленыКомиссии = ВыборкаКомиссия.Выбрать(ОбходРезультатаЗапроса.Прямой);
			Пока ВыборкаЧленыКомиссии.Следующий() Цикл
				СтруктураКомиссии = Новый Структура();
				СтруктураКомиссии.Вставить("ФИО", ПреобразоватьФИО(ВыборкаЧленыКомиссии.ЧленКомиссии));
				СтруктураКомиссии.Вставить("Должность", ВыборкаЧленыКомиссии.Должность);
				МассивСтруктурКомиссии.Добавить(СтруктураКомиссии);
			КонецЦикла;
			
		КонецЕсли;
		// гкс+ [01.23] Деснол 18.01.2023
		СтруктураЗаявителя = Новый Структура();
		ВыборкаСотрудникПодразделения.Сбросить();
		Если ВыборкаСотрудникПодразделения.НайтиСледующий(Новый Структура("Ссылка", ВыборкаДокументов.Ссылка)) Тогда 
			ВыборкаДолжность = ВыборкаСотрудникПодразделения.Выбрать();
			ВыборкаДолжность.Следующий();
			СтруктураЗаявителя.Вставить("ФИО", ПреобразоватьФИО(ВыборкаДолжность.Сотрудник));
			СтруктураЗаявителя.Вставить("Должность", ВыборкаДолжность.Должность);
		КонецЕсли;
		// гкс- [01.23] Деснол 18.01.2023
		#КонецОбласти
		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		
		Пока ВыборкаРемонтов.Следующий() Цикл
			Если НЕ ЭтоПервый Тогда
				ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;
			
			ОР = ВыборкаРемонтов.ОР;
			
			ОбластьШапка.Параметры.Номер 		= Дефект.Номер;
			ОбластьШапка.Параметры.НомерКомиссии 		= ВыборкаРемонтов.гкс_НомерПриказа;
			ОбластьШапка.Параметры.ДатаКомиссии 		= ВыборкаРемонтов.гкс_ДатаПриказа;
			ОбластьШапка.Параметры.Должность 		= "";
			ОбластьШапка.Параметры.ФИО 		= "";
			Если МассивСтруктурКомиссии.Количество() Тогда 
				ОбластьШапка.Параметры.Должность = МассивСтруктурКомиссии[0].Должность;
				ОбластьШапка.Параметры.ФИО = МассивСтруктурКомиссии[0].ФИО;
			КонецЕсли;

			ТабДокумент.Вывести(ОбластьШапка);
			Если МассивСтруктурКомиссии.Количество() > 1 Тогда 
				ОбластьШапкаСтрока1.Параметры.Должность = МассивСтруктурКомиссии[1].Должность;
				ОбластьШапкаСтрока1.Параметры.ФИО = МассивСтруктурКомиссии[1].ФИО;
				ТабДокумент.Вывести(ОбластьШапкаСтрока1);
			КонецЕсли;
						
			НомерПП = 2;
			Пока НомерПП < МассивСтруктурКомиссии.Количество() Цикл
				ОбластьШапкаСтрока2.Параметры.Должность = МассивСтруктурКомиссии[НомерПП].Должность;
				ОбластьШапкаСтрока2.Параметры.ФИО = МассивСтруктурКомиссии[НомерПП].ФИО;
				ТабДокумент.Вывести(ОбластьШапкаСтрока2);
				НомерПП = НомерПП + 1;
			КонецЦикла;
			// гкс+ [01.23] Деснол 18.01.2023
			Если СтруктураЗаявителя.Свойство("ФИО") Тогда 
				ОбластьШапкаСтрока2.Параметры.Должность = СтруктураЗаявителя.Должность;
				ОбластьШапкаСтрока2.Параметры.ФИО = СтруктураЗаявителя.ФИО;
				ТабДокумент.Вывести(ОбластьШапкаСтрока2);
			КонецЕсли;
			// гкс- [01.23] Деснол 18.01.2023
			
			ОбластьПодвал.Параметры.ОР = торо_ЗаполнениеДокументов.ПолучитьПредоставленияОРДляПечати(ОР);
			ОбластьПодвал.Параметры.ОписаниеДефекта = ВыборкаРемонтов.ДефектОписание;
			
			Если МассивСтруктурКомиссии.Количество() Тогда 
				ОбластьПодвал.Параметры.Должность = МассивСтруктурКомиссии[0].Должность;
				ОбластьПодвал.Параметры.ФИО = МассивСтруктурКомиссии[0].ФИО;
			КонецЕсли;

			ТабДокумент.Вывести(ОбластьПодвал);
			Если МассивСтруктурКомиссии.Количество() > 1 Тогда 
				ОбластьПодвалСтрока1.Параметры.Должность = МассивСтруктурКомиссии[1].Должность;
				ОбластьПодвалСтрока1.Параметры.ФИО = МассивСтруктурКомиссии[1].ФИО;
				ТабДокумент.Вывести(ОбластьПодвалСтрока1);
			КонецЕсли;
			
			НомерПП = 2;
			Пока НомерПП < МассивСтруктурКомиссии.Количество() Цикл
				ОбластьПодвалСтрока2.Параметры.Должность = МассивСтруктурКомиссии[НомерПП].Должность;
				ОбластьПодвалСтрока2.Параметры.ФИО = МассивСтруктурКомиссии[НомерПП].ФИО;
				ТабДокумент.Вывести(ОбластьПодвалСтрока2);
				НомерПП = НомерПП + 1;
			КонецЦикла;
			// гкс+ [01.23] Деснол 18.01.2023
			Если СтруктураЗаявителя.Свойство("ФИО") Тогда 
				ОбластьПодвалСтрока2.Параметры.Должность = СтруктураЗаявителя.Должность;
				ОбластьПодвалСтрока2.Параметры.ФИО = СтруктураЗаявителя.ФИО;
				ТабДокумент.Вывести(ОбластьПодвалСтрока2);
			КонецЕсли;
			// гкс- [01.23] Деснол 18.01.2023
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Зададим параметры макета
	ТабДокумент.АвтоМасштаб	= Истина;
	ТабДокумент.ПолеСверху  = 0;
	ТабДокумент.ПолеСлева   = 0;
	ТабДокумент.ПолеСнизу   = 0;
	ТабДокумент.ПолеСправа  = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ТабДокумент.ТолькоПросмотр = Истина;
	
	Возврат ТабДокумент;
	

КонецФункции // гкс- [11.22] Деснол 24.11.2022

// гкс+ [11.22] Деснол 24.11.2022
Функция ПреобразоватьФИО(Сотрудник)
	ИндексПервойЧастиИмени = 0;
	ИндексВторойЧастиИмени = 1;
	ИндексТретейЧастиИмени = 2;
	МассивИмени = СтрРазделить(Строка(Сотрудник), " ", Ложь);
	Если МассивИмени.Количество() > 2 Тогда 
		Возврат МассивИмени[ИндексПервойЧастиИмени] 
		+ " " + Лев(МассивИмени[ИндексВторойЧастиИмени], 1) 
		+ ". " + Лев(МассивИмени[ИндексТретейЧастиИмени], 1) + ".";
	КонецЕсли;
	Возврат Сотрудник;
КонецФункции // гкс- [11.22] Деснол 24.11.2022

#КонецОбласти