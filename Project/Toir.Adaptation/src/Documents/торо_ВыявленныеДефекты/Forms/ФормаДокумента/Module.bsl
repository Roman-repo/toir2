&НаСервереБезКонтекста
Функция ЭтоФМ(Ссылка, ИскатьФМ = Истина)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОбъектыРемонта.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.Ссылка = &Ссылка
		|	И торо_ОбъектыРемонта.ТипОбъекта = ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто)
		|	И торо_ОбъектыРемонта.ЭтоГруппа = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);          
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Возврат Истина;
	КонецЕсли;
	Если ИскатьФМ = Истина Тогда 
		ТекущееФункциональноеМесто = гкс_ПроверкаФункциональныхМест.НайтиФМ(Ссылка);
		Если ЗначениеЗаполнено(ТекущееФункциональноеМесто) И Не ТекущееФункциональноеМесто = Ссылка Тогда 
			Ссылка = ТекущееФункциональноеМесто;
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("ОбъектРемонтаПриИзменении")
Процедура гкс_ОбъектРемонтаПриИзменении(Элемент)
	#Вставка
	Если Не ЭтоФМ(Объект.ОбъектРемонта) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = Строка(Объект.ОбъектРемонта) 
			+ НСтр("ru=' является объектом ремонта. Выберите функциональное место'");
		Сообщение.Сообщить();
		Объект.ОбъектРемонта = Неопределено;
		Возврат;
	КонецЕсли;
	#КонецВставки
	ОчиститьСписокДефектов();
	ОбъектыРемонта.Очистить();

	нс = ОбъектыРемонта.Добавить();
	нс.ОбъектРемонта = Объект.ОбъектРемонта;

	ТекущийОР = Объект.ОбъектРемонта;

	#Удаление 
    Объект.ПодразделениеИсполнитель = ПолучитьПодразделениеДляОР(Объект.ОбъектРемонта);
	#КонецУдаления 

	Элементы.СписокДефектов.ОтборСтрок = Неопределено;
	Элементы.СписокДефектов.ОтборСтрок = Новый ФиксированнаяСтруктура("ОбъектРемонта", Объект.ОбъектРемонта);
	Элементы.СписокДефектов.Доступность = ЗначениеЗаполнено(Объект.ОбъектРемонта);

КонецПроцедуры

