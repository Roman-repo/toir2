&НаСервереБезКонтекста
Функция гкс_ЕвоНуженПоВлиянию(Влияние)
	Возврат Не Влияние = Перечисления.гкс_Влияние.БезВлияния;
КонецФункции

&НаКлиенте
Процедура гкс_ОткрытьЕВО(ДопПараметры = Неопределено)
	Если Модифицированность Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Перед проведением, необходимо записать изменения";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	ОпОп = Новый ОписаниеОповещения("гкс_ПриЗакрытииЕВО", ЭтотОбъект);
	Если ЗначениеЗаполнено(ЭтотОбъект["СсылкаЕвоБланк"]) Тогда 
		СтруктураСоздания = Новый Структура("Ключ", ЭтотОбъект["СсылкаЕвоБланк"]);
	Иначе
		СтруктураСоздания = Новый Структура("ДокументОснование", Объект.Ссылка);
		СтруктураСоздания.Вставить("ДатаОбнаружения", Объект.ДатаОбнаружения);
		Если Объект.СписокДефектов.Количество() Тогда 
			СтруктураСоздания.Вставить("КорневаяПричина", Объект.СписокДефектов[0].гкс_КорневаяПричина);
			СтруктураСоздания.Вставить("ВидДефекта", Объект.СписокДефектов[0].ВидДефекта);
			СтруктураСоздания.Вставить("ДефектОписание", Объект.СписокДефектов[0].ДефектОписание);
		КонецЕсли;
	КонецЕсли;
	СтруктураСоздания.Вставить("Организация", Объект.Организация);
	СтруктураСоздания.Вставить("Подразделение", Объект.Подразделение);
	ОткрытьФорму("Документ.гкс_ЕВОБланк.ФормаОбъекта", СтруктураСоздания,,,,, ОпОп);
КонецПроцедуры

&НаКлиенте
Процедура гкс_ПриЗакрытииЕВО(Результат, ДопПараметры) Экспорт
	Если Результат = Неопределено Тогда 
		Прочитать();
		// найти актуальный ЕВО
		СтрОтвет = гкс_НайтиАктуальныйЕВО(Объект.Ссылка);
		ЭтотОбъект["СсылкаЕвоБланк"] = СтрОтвет.Ссылка;
		ЭтотОбъект["ПроведенЕвоБланк"] = СтрОтвет.Проведен;
		Если Объект.Дата > Дата(2023,11,1) Тогда
			Элементы.ГруппаСогласование.Доступность = ЭтотОбъект["ПроведенЕвоБланк"] ИЛИ Объект.Проведен 
				ИЛИ Не гкс_ЕвоНуженПоВлиянию(Объект.гкс_Влияние);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_ВлияниеПриИзменении(Элемент)
	Если Объект.Дата > Дата(2023,11,1) Тогда
		Элементы.ГруппаСогласование.Доступность = ЭтотОбъект["ПроведенЕвоБланк"] ИЛИ Объект.Проведен ИЛИ Не гкс_ЕвоНуженПоВлиянию(Объект.гкс_Влияние);
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция гкс_НайтиАктуальныйЕВО(СсылкаВД)
	Ответ = Новый Структура("Ссылка,Проведен", Неопределено, Ложь);
	Если Не ЗначениеЗаполнено(СсылкаВД) Тогда 
		Возврат Ответ;
	КонецЕсли;
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ЕВОБланк.Проведен КАК Проведен,
		|	гкс_ЕВОБланк.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.гкс_ЕВОБланк КАК гкс_ЕВОБланк
		|ГДЕ
		|	гкс_ЕВОБланк.ДокументОснование = &СсылкаВД
		|	И гкс_ЕВОБланк.ПометкаУдаления = Ложь";
	
	Запрос.УстановитьПараметр("СсылкаВД", СсылкаВД);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат Ответ;
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Ответ.Ссылка = Выборка.Ссылка;
		Ответ.Проведен = Выборка.Проведен;
		Возврат Ответ;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура гкс_ОткрытьЕВО_ЧерезСекунду() Экспорт
	гкс_ОткрытьЕВО();
КонецПроцедуры

