#Область ОбработчикиСобытийФормы

&НаКлиенте
&После("ПриОткрытии")
Процедура гкс_ПриОткрытии(Отказ)
	ПриОткрытииНаСервере(ТекущаяДата());
	// гкс+ [07.23] Деснол 18.07.2023
	// Гкс+[TOIR20-570/TOIR20-576] Зозуля А.В. от 14.04.2025. Удалено:{
	//Если Объект.СписокДефектов.Количество() Тогда
	//ТекущиеДанные = Объект.СписокДефектов[0];
	//Объект.гкс_СрочностьВоздействия = ПолучитьСрочностьВоздействия(ТекущиеДанные.ОтказавшийЭлемент, ТекущиеДанные.КритичностьДефекта);	
	//КонецЕсли;
	// } Гкс-[TOIR20-570/TOIR20-576] Зозуля А.В. от 14.04.2025.
	// гкс- [07.23] Деснол 18.07.2023
	Если ЗначениеЗаполнено(Объект.Ссылка) И Не ЭтотОбъект["ПроведенЕвоБланк"]
		И гкс_ЕвоНуженПоВлиянию(Объект.гкс_Влияние) Тогда 		
		ПодключитьОбработчикОжидания("гкс_ОткрытьЕВО_ЧерезСекунду", 1, Истина);
	КонецЕсли; 
	// Гкс+[TOIR20-454] Зозуля А.В. от 09.10.2024. Добавлено:{
	гкс_ДефектОформленПоТАГПриИзменении(Неопределено);
	// } Гкс-[TOIR20-454] Зозуля А.В. от 09.10.2024.
	
	ЭтотОбъект["гкс_ПодразделениеИсполнительЗаполненПользователем"] =
		ЗначениеЗаполнено(Объект.ПодразделениеИсполнитель);
		
КонецПроцедуры

&НаСервере
Процедура ПриОткрытииНаСервере(ДатаКлиента)
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда 
		Объект.Дата = ТекущаяДата();
	КонецЕсли;
	// гкс+ [Часовые пояса] Куст 
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтаФорма,,,);
	// Заголовок формы
	торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(Объект, ЭтаФорма, "");
КонецПроцедуры

&НаСервере
&После("ПередЗаписьюНаСервере")
Процедура гкс_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// гкс+ [Часовые пояса] Куст
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПСервера(ЭтаФорма,, ТекущийОбъект);
КонецПроцедуры

&НаСервере
&После("ПриЗаписиНаСервере")
Процедура гкс_ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// гкс+ [Часовые пояса] Куст 
	гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтаФорма,, ТекущийОбъект);
КонецПроцедуры

&НаСервере
Процедура гкс_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	// гкс+ [Релиз 1] Куст
	ДобавитьНовыеЭлементы();
	
	// гкс+ [Часовые пояса] Куст
	гкс_ЧасовыеПоясаВызовСервера.ДобавитьНовыеЭлементы(ЭтаФорма, Элементы.ГруппаДатаОбнаружения,
		Новый Структура("гкс_РеквизитыДаты", 
		"Дата,ДатаОбнаружения,СписокДефектов.ДатаНачалаРемонта"));
		
	// гкс+ [Релиз 1] Куст 
	Элементы.СпособСогласования.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
КонецПроцедуры

&НаСервере
Процедура гкс_ПриЧтенииНаСервереПосле(ТекущийОбъект)
	// гкс+ [Часовые пояса] Куст
	СтруктураПроверки = Новый Структура("гкс_СдвигЧП", Неопределено);
	ЗаполнитьЗначенияСвойств(СтруктураПроверки, ЭтотОбъект);
	Если Не СтруктураПроверки.гкс_СдвигЧП = Неопределено Тогда 
		гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтаФорма,, Объект);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПередЗаписью")
Процедура гкс_ПередЗаписью(Отказ, ПараметрыЗаписи)
	#Вставка
	МассивСтруктур = новый Массив();
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДатаОбнаружения", НСтр("ru='Дата обнаружения';en='Detection date'")));
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Организация", НСтр("ru='Организация';en='Organization'")));
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "Подразделение", НСтр("ru='Подразделение';en='Subdivision'")));
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ОбъектРемонта", НСтр("ru='ФМ';en='FP'")));
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "гкс_Влияние", НСтр("ru='Влияние';en='Impact'")));
	МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДефектВыявленВПроцессе",
		НСтр("ru='Дефект выявлен в процессе';en='Defect detected in the process'")));
	// Гкс+[TOIR20-454] Зозуля А.В. от 09.10.2024. Добавлено:{
	Если Объект.гкс_ДефектОформленПоТАГ И Не ЗначениеЗаполнено(Объект.гкс_НомерТАГ) Тогда
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "гкс_НомерТАГ", НСтр("ru='Номер ТАГ';en='TAG number'")));		
	КонецЕсли;	
	// } Гкс-[TOIR20-454] Зозуля А.В. от 09.10.2024.	
		
	Для Каждого СтрокаМассива Из МассивСтруктур Цикл
		Если Не ЗначениеЗаполнено(Объект[СтрокаМассива.Имя]) Тогда 
			Сообщение = Новый СообщениеПользователю();
			ШаблонСообщения = НСтр("ru='Поле ""%1"" не заполнено';en='Field %1 is empty'");
			Сообщение.Текст = СтрШаблон(ШаблонСообщения, СтрокаМассива.Текст);
			Сообщение.Поле = "Объект." + СтрокаМассива.Имя;
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла;
	Если Объект.СписокДефектов.Количество() = 0 Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='В документе не указан отказавший элемент';en='The document does not specify an failed item'");
		Сообщение.Сообщить();
		Отказ = Истина;
	Иначе
		МассивСтруктур = новый Массив();
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ОтказавшийЭлемент",
			НСтр("ru='Отказавший элемент';en='Failed item'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "КритичностьДефекта",
			НСтр("ru='Критичность дефекта';en='Defect criticality'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "гкс_СимптомДефекта",
			НСтр("ru='Симптом дефекта';en='Symptom defect'")));
		МассивСтруктур.Добавить(Новый Структура("Имя,Текст", "ДефектОписание",
			НСтр("ru='Дефект описание';en='Defect description'")));
		Для Каждого СтрокаМассива Из МассивСтруктур Цикл
			НомерПП = 0;
			Для Каждого СтрокаТаблицы Из Объект.СписокДефектов Цикл
				Если Не ЗначениеЗаполнено(СтрокаТаблицы[СтрокаМассива.Имя]) Тогда 
					Сообщение = Новый СообщениеПользователю();
					ШаблонСообщения = НСтр("ru='Поле ""%1"" не заполнено';en='Field %1 is empty'");
					Сообщение.Текст = СтрШаблон(ШаблонСообщения, СтрокаМассива.Текст);
					Сообщение.Поле = "Объект.СписокДефектов[" + НомерПП + "]." + СтрокаМассива.Имя;
					Сообщение.Сообщить();
					Отказ = Истина;
				КонецЕсли;
				НомерПП = НомерПП + 1;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	#КонецВставки

	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
		И ФОИспользоватьГарантии Тогда
		торо_ГарантийноеОбслуживание.СформироватьПредупрежденияОРекламационныхАктах(Объект, "СписокДефектов");
	КонецЕсли; 
	#Вставка
	#Область ЕвоБланк
	Если 
		// гкс+ [10.23] Деснол 13.06.2024
		ЭтотОбъект["ПроведенЕвоБланк"] = Ложь И
		// записывают документ до проведения и не создают эвобланк. эту лазейку нужно закрыть
		ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И
		// гкс- [10.23] Деснол 13.06.2024
		гкс_ЕвоНуженПоВлиянию(Объект.гкс_Влияние) Тогда
		Если ЗначениеЗаполнено(ЭтотОбъект["СсылкаЕвоБланк"]) Тогда 
			// проверить проведенность
			СтруктураБланк = гкс_НайтиАктуальныйЕВО(Объект.Ссылка);
			ЭтотОбъект["СсылкаЕвоБланк"] = СтруктураБланк.Ссылка;
			ЭтотОбъект["ПроведенЕвоБланк"] = СтруктураБланк.Проведен;
			Если Не ЭтотОбъект["ПроведенЕвоБланк"] Тогда 
				Отказ = Истина;
				гкс_ОткрытьЕВО();
			КонецЕсли;
		Иначе
			Отказ = Истина;
			// Создать
			гкс_ОткрытьЕВО();
		КонецЕсли;
	КонецЕсли;
	#КонецОбласти
	#КонецВставки
КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ОбработкаПроверкиЗаполненияНаСервере")
Процедура гкс_ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства

	#Вставка
	// Гкс+[TOIR20-158] Селимов
	ВнешнееОснованиеДляРабот = СозданНаОснованииВнешнегоОснованияДляРабот();  
	#КонецВставки 
	Индекс = 0;
	ШаблонСообщения = НСтр("es='%1';ru='Не заполнен объект ремонта в строке %1';en='Repair object not filled in line%1'");
	Для каждого Строка из ОбъектыРемонта Цикл
		Если НЕ ЗначениеЗаполнено(Строка.ОбъектРемонта) Тогда
			ТекстСообщения = СтрШаблон(ШаблонСообщения, Индекс+1);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,"ОбъектыРемонта["+Индекс+"].ОбъектРемонта",,Отказ);
		КонецЕсли;
		Индекс = Индекс+1;
	КонецЦикла;
	#Вставка
	// Гкс+[TOIR20-158] Селимов		 
	Индекс = 0;
	ШаблонСообщения = НСтр("es='%1';ru='Не указана критичность дефекта в строке %1';en='Defect criticality not filled in line%1'");
	Если ВнешнееОснованиеДляРабот Тогда 
		Для каждого Строка Из Объект.СписокДефектов Цикл
			Если Не ЗначениеЗаполнено(Строка.КритичностьДефекта) Тогда
				ТекстСообщения = СтрШаблон(ШаблонСообщения, Индекс+1);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ,
													"Объект.СписокДефектов[" + Индекс + "].КритичностьДефекта", , 
													Отказ);
			КонецЕсли; 			
			Индекс = Индекс+1;
		КонецЦикла; 		
	КонецЕсли; // Гкс-[TOIR20-158]
	#КонецВставки 

КонецПроцедуры 
#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
&ИзменениеИКонтроль("СпособСогласованияПриИзменении")
Процедура гкс_СпособСогласованияПриИзменении(Элемент)
	Если фПослеОчистки = Ложь Тогда
		ОбновитьДеревоСогласующих(Истина);
		#Удаление
		торо_РаботаССогласованиямиКлиентСервер.ДобавитьСтрокуВИсториюСтатусов(ЭтаФорма, СтатусДокументаРегистр,, Истина);
		#КонецУдаления
		#Вставка
		торо_РаботаССогласованиямиКлиентСервер.ДобавитьСтрокуВИсториюСтатусов(ЭтаФорма, СтатусДокументаРегистр,,);
		#КонецВставки
	Иначе
		фПослеОчистки = Ложь;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы
// гкс+ [Релиз16] Деснол
&НаКлиенте
Процедура ОткрытьЗакрытиеЗаявокИРемонтов(Команда)
	Если Объект.Проведен = Ложь Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Необходимо провести документ';en='you need to post a document'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	ВыбранныеРемонты = Новый Массив;
	Для каждого Ремонт Из Объект.СписокДефектов Цикл
		ВыбранныеРемонты.Добавить(Ремонт.ID);
	КонецЦикла; 
	
	Отбор = Новый Структура;
	Отбор.Вставить("ID", ВыбранныеРемонты);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ОтборРемонтов", Отбор);
	ПараметрыФормы.Вставить("ТекущаяСтраница", "ГруппаАварийныеРемонты");
	
	ОткрытьФорму("Обработка.торо_ЗакрытиеЗаявокИРемонтов.Форма.Форма", ПараметрыФормы,,,,,,);
	
КонецПроцедуры
// гкс- [Релиз16]

// гкс+ [02.23] Деснол 07.02.2023
&НаКлиенте
Процедура гкс_ОткрытьПамятку1(Команда)
	ОткрытьФорму("Документ.торо_ВыявленныеДефекты.Форма.ПамяткаКритичность",,,,,,, РежимОткрытияОкнаФормы.Независимый);
КонецПроцедуры // гкс- [02.23] Деснол 07.02.2023

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьНовыеЭлементы()
	МассивРеквизитов = Новый Массив();
	МассивРеквизитов.Добавить(Новый РеквизитФормы("гкс_СтатусЧерновик",
		Новый ОписаниеТипов("СправочникСсылка.торо_СтатусыСогласованияДокументовРемонтныхРабот")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("гкс_ПодразделениеИсполнительЗаполненПользователем",
		Новый ОписаниеТипов("Булево")));	
	
	ИзменитьРеквизиты(МассивРеквизитов);
	// гкс+ [03.23] Деснол 13.03.2023
	Если Не РольДоступна("гкс_РедактированиеЗаявкиНаРемонт") Тогда 
		Элементы.Дата.ТолькоПросмотр = Истина;
	КонецЕсли;
	// гкс- [03.23] Деснол 13.03.2023
	ЭтаФорма["гкс_СтатусЧерновик"] = справочники.торо_СтатусыСогласованияДокументовРемонтныхРабот.Черновик;

	Элементы.ОбъектРемонта.Заголовок = НСтр("ru='ФМ';en='FP'");
	Элементы.ОбъектРемонта.АвтоОтметкаНезаполненного = Истина;
	Элементы.СписокДефектовСоздатьТиповойДефект.Доступность = Ложь;
	Элементы.СписокДефектовСоздатьТиповойДефект.Видимость = Ложь;
	Элементы.СписокДефектовТиповойДефект.Видимость = Ложь;
	Элементы.СписокДефектовВидДефекта.ТолькоПросмотр = Истина;
	Элементы.СписокДефектовДефектПричина.Видимость = Ложь;
	Элементы.СписокДефектовВидДефекта.АвтоОтметкаНезаполненного = Ложь;

	НЭлем = Элементы.Добавить("дс_ГруппаСимптом",Тип("ГруппаФормы"), Элементы.СписокДефектов);
	НЭлем.Вид = ВидГруппыФормы.ГруппаКолонок;
	НЭлем.Группировка = ГруппировкаКолонок.Вертикальная;
	Элементы.Переместить(Элементы["дс_ГруппаСимптом"],
		Элементы.СписокДефектов, Элементы.СписокДефектовТиповойДефект);

	НЭлем = Элементы.Добавить("СписокДефектовгкс_СимптомДефекта",Тип("ПолеФормы"), Элементы["дс_ГруппаСимптом"]);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Объект.СписокДефектов.гкс_СимптомДефекта";
	// Гкс+[TOIR20-466] Зозуля А.В. от 07.11.2024. Добавлено:{
	НЭлем.АвтоОтметкаНезаполненного = Истина;
	// } Гкс-[TOIR20-466] Зозуля А.В. от 07.11.2024.
	
	НЭлем = Элементы.Добавить("гкс_Влияние",Тип("ПолеФормы"), Элементы.ГруппаЛевая);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Объект.гкс_Влияние";
	НЭлем.АвтоМаксимальнаяШирина = Ложь;
