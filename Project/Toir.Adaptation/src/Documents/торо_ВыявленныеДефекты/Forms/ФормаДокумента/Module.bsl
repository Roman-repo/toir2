&НаКлиенте
Процедура гкс_Подключаемый_ФайлыФиксацииВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

#Если ВебКлиент Тогда
	ВызватьИсключение НСтр("ru='Просмотр файлов недоступно при работе в веб-клиенте.'");
#Иначе
	
	Попытка
		ТекущиеДанные = Элемент.ТекущиеДанные;
		НаименованиеФайла = ТекущиеДанные.НаименованиеФайла;
		АдресХраненияФайлов = гкс_АдресХраненияФайловФиксации() ;
		ВебСсылка = СтрШаблон("%1%2", АдресХраненияФайлов, ТекущиеДанные.ИдентификаторФайла);

		Если Поле.ГиперссылкаЯчейки И ЗначениеЗаполнено(ВебСсылка) Тогда
			СтандартнаяОбработка = Ложь; 
			СимволыРасширенияФайла = 4;
			РасширениеФайла = Прав(НаименованиеФайла, СимволыРасширенияФайла);  			
			
			ПараметрыПолучения = ПолучениеФайловИзИнтернетаКлиентСервер.ПараметрыПолученияФайла();
			ПараметрыПолучения.ПутьДляСохранения = ПолучитьИмяВременногоФайла(РасширениеФайла);
			Таймаут = 30;
			ПараметрыПолучения.Таймаут = Таймаут;

			Результат = ПолучениеФайловИзИнтернетаКлиент.СкачатьФайлНаКлиенте(ВебСсылка, ПараметрыПолучения);
			ЗапуститьПриложение(Результат.Путь);						
		КонецЕсли;
		
	Исключение
		ТекстСообщения = СтрШаблон(НСтр("ru ='Ошибка при переходе по веб-ссылке: %1'"),
			ОписаниеОшибки());
		гкс_ЗаписатьОшибкуВЖурналРегистрации(ТекстСообщения);
		
		ТекстСообщения = СтрШаблон(НСтр("ru ='Ошибка перехода по ссылке: %1'"), ОписаниеОшибки());
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				
	КонецПопытки;

#КонецЕсли	
	
КонецПроцедуры

