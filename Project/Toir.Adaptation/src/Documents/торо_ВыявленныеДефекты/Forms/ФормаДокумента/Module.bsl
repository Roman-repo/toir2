Процедура гкс_СписокДефектовОтказавшийЭлементПриИзмененииВместо()
	
	гкс_СписокДефектовОтказавшийЭлементПриИзмененииНаСервере();

КонецПроцедуры

&НаСервере
Процедура гкс_СписокДефектовОтказавшийЭлементПриИзмененииНаСервере() 
	
	ИдентификаторСтроки = Элементы.СписокДефектов.ТекущаяСтрока;
	ТекДанные = Объект.СписокДефектов.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	Если ЭтоФМ(ТекДанные.ОтказавшийЭлемент,Ложь) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Отказавшим элементом не должно быть функциональое место!'");
		Сообщение.Сообщить();
		ТекДанные.ОтказавшийЭлемент = Неопределено;
		Возврат;
	КонецЕсли;
	Если Не ТекДанные.ОтказавшийЭлемент = ПредопределенноеЗначение("Справочник.торо_ОбъектыРемонта.ПустаяСсылка") Тогда
		ТекДанные.ТиповойДефект = ПредопределенноеЗначение("Справочник.торо_ТиповыеДефектыОборудования.ПустаяСсылка");
		ТекДанные.НаправлениеОтказавшийЭлемент = 
			торо_ОбщегоНазначенияВызовСервера.ЗначениеРеквизитаОбъекта(ТекДанные.ОтказавшийЭлемент, "Направление");
	КонецЕсли;
	
	// Гкс+[TOIR20-570/TOIR20-576] Зозуля А.В. от 14.04.2025. Добавлено:{
	Если ЗначениеЗаполнено(ТекДанные.КритичностьДефекта) Тогда
		СтруктураОтвета = гкс_МаксимальнаяСрочностьВоздействияИКачественнаяОценка(Объект.СписокДефектов);
		Объект.гкс_СрочностьВоздействия = СтруктураОтвета.СрочностьВоздействия;
		Объект.гкс_КачественнаяОценка = СтруктураОтвета.КачественнаяОценка;
	КонецЕсли;	
	// } Гкс-[TOIR20-570/TOIR20-576] Зозуля А.В. от 14.04.2025.
	
	Если ЭтотОбъект["гкс_ПодразделениеИсполнительЗаполненПользователем"] Тогда	
		ТекДанные.ПодразделениеИсполнитель = Объект.ПодразделениеИсполнитель;		
	Иначе						
		МассивОтказавшихЭлементов = Новый Массив;
		Для Каждого Строка Из Объект.СписокДефектов Цикл
			МассивОтказавшихЭлементов.Добавить(Строка.ОтказавшийЭлемент);	
		КонецЦикла;	
			
		ПодразделенияИсполнителиОтказавшихЭлементов = 
			ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивОтказавшихЭлементов, "ПодразделениеИсполнитель");
		Для Каждого Строка Из Объект.СписокДефектов Цикл
			ЭлементСоответствия = ПодразделенияИсполнителиОтказавшихЭлементов.Получить(Строка.ОтказавшийЭлемент); 
			Строка.ПодразделениеИсполнитель = ЭлементСоответствия.ПодразделениеИсполнитель;	
		КонецЦикла;
		
		ТаблицаПодразделений = Объект.СписокДефектов.Выгрузить(,"ПодразделениеИсполнитель");;
		ТаблицаПодразделений.Свернуть("ПодразделениеИсполнитель");
		Если ТаблицаПодразделений.Количество() = 1 Тогда
			Объект.ПодразделениеИсполнитель = ТаблицаПодразделений[0].ПодразделениеИсполнитель;
		Иначе
			Объект.ПодразделениеИсполнитель = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
&После("ПодразделениеИсполнительПриИзменении")
Процедура гкс_ПодразделениеИсполнительПриИзменении(Элемент)
	ЭтотОбъект["гкс_ПодразделениеИсполнительЗаполненПользователем"] = 
		ЗначениеЗаполнено(Объект.ПодразделениеИсполнитель);
	ПодразделениеПриИзменении(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ПодразделениеПриИзменении(Элемент)
	Если ЭтотОбъект["мИспользоватьСогласованиеДокументов"] И Элементы["СпособСогласования"].ТолькоПросмотр
		И Не СтатусДокументаРегистр = ЭтаФорма["гкс_СтатусЧерновик"] Тогда 
		Возврат;
	КонецЕсли;
	//
	Если Объект.СписокДефектов.Количество() > 0 Тогда 
		// гкс+ [2021] Куст
		Способ = гкс_ПолучитьСпособСогласования(Объект.Организация, Объект.СписокДефектов[0].ОтказавшийЭлемент,
			Объект.ПодразделениеИсполнитель, Объект.Ссылка);// гкс- [2021]		
		Если ЗначениеЗаполнено(Способ) И Не Объект.СпособСогласования = Способ Тогда 
			Объект.СпособСогласования = Способ;
			СпособСогласованияПриИзменении(Неопределено);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция гкс_ПолучитьСпособСогласования(Орг, ОР, ПодрИсп, ОбъектСсылка = Неопределено)
	// гкс+ [2021] Куст
	Если торо_РаботаССогласованиями.гкс_ПоДокументуЕстьИстория(ОбъектСсылка) Тогда 
		Возврат Неопределено;
	КонецЕсли; // гкс- [2021]
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОбъектыРемонта.Подразделение КАК Подразделение
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ОР);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат торо_РаботаССогласованиями.гкс_ПолучитьСпособСогласованияПоУмолчанию(
		Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ВыявленныеДефекты,
		Орг, Выборка.Подразделение, ПодрИсп);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

