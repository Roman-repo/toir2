    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДокументОснование</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Заявка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ИД</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ОР</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВЫРАЗИТЬ(Заявки.Регистратор КАК Документ.торо_ЗаявкаНаРемонт) КАК Заявка,
	Заявки.IDРемонта КАК ИД,
	ЕСТЬNULL(Даты.ДатаНачала, Заявки.ДатаНачалаРемонтныхРабот) КАК ДатаНачала,
	ЕСТЬNULL(Даты.ДатаОкончания, Заявки.ДатаОкончанияРемонтныхРабот) КАК ДатаОкончания
ПОМЕСТИТЬ ВТ_ВсеЗаявки
ИЗ
	РегистрСведений.торо_ЗаявкиПоРемонтам КАК Заявки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеРемонтныеРаботы.СрезПоследних КАК Завершенные
		ПО Заявки.IDРемонта = Завершенные.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК Даты
		ПО Заявки.IDРемонта = Даты.IDРемонта
ГДЕ
	Завершенные.ID ЕСТЬ NULL
	И Заявки.Регистратор ССЫЛКА Документ.торо_ЗаявкаНаРемонт

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВЫРАЗИТЬ(Заявки.Регистратор КАК Документ.торо_ОстановочныеРемонты),
	Заявки.IDРемонта,
	ЕСТЬNULL(Даты.ДатаНачала, Заявки.ДатаНачалаРемонтныхРабот),
	ЕСТЬNULL(Даты.ДатаОкончания, Заявки.ДатаОкончанияРемонтныхРабот)
ИЗ
	РегистрСведений.торо_ЗаявкиПоРемонтам КАК Заявки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеРемонтныеРаботы.СрезПоследних КАК Завершенные
		ПО Заявки.IDРемонта = Завершенные.ID
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК Даты
		ПО Заявки.IDРемонта = Даты.IDРемонта
ГДЕ
	Завершенные.ID ЕСТЬ NULL
	И Заявки.Регистратор ССЫЛКА Документ.торо_ОстановочныеРемонты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ВсеЗаявки.Заявка КАК Заявка,
	ВТ_ВсеЗаявки.ИД КАК ИД,
	ВТ_ВсеЗаявки.ДатаНачала КАК ДатаНачала,
	ВТ_ВсеЗаявки.ДатаОкончания КАК ДатаОкончания,
	Дефекты.Регистратор КАК ДокументОснование,
	Дефекты.ОбъектРемонта КАК ОР,
	торо_Ремонты.ВидРемонта КАК ВР
ИЗ
	ВТ_ВсеЗаявки КАК ВТ_ВсеЗаявки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВыявленныеДефекты.СрезПоследних КАК Дефекты
		ПО ВТ_ВсеЗаявки.ИД = Дефекты.ID
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_Ремонты
		ПО ВТ_ВсеЗаявки.ИД = торо_Ремонты.ID

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВТ_ВсеЗаявки.Заявка,
	ВТ_ВсеЗаявки.ИД,
	ВТ_ВсеЗаявки.ДатаНачала,
	ВТ_ВсеЗаявки.ДатаОкончания,
	ППР.Регистратор,
	ППР.ОбъектРемонтныхРабот,
	ППР.ВидРемонтныхРабот
ИЗ
	ВТ_ВсеЗаявки КАК ВТ_ВсеЗаявки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних(, Регистратор ССЫЛКА Документ.торо_ПланГрафикРемонта) КАК ППР
		ПО ВТ_ВсеЗаявки.ИД = ППР.ID

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВТ_ВсеЗаявки.Заявка,
	ВТ_ВсеЗаявки.ИД,
	ВТ_ВсеЗаявки.ДатаНачала,
	ВТ_ВсеЗаявки.ДатаОкончания,
	Внешнее.Регистратор,
	Внешнее.ОбъектРемонта,
	торо_Ремонты.ВидРемонта
ИЗ
	ВТ_ВсеЗаявки КАК ВТ_ВсеЗаявки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВнешниеОснованияДляРабот.СрезПоследних(, Регистратор ССЫЛКА Документ.торо_ВнешнееОснованиеДляРабот) КАК Внешнее
		ПО ВТ_ВсеЗаявки.ИД = Внешнее.ID
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_Ремонты
		ПО ВТ_ВсеЗаявки.ИД = торо_Ремонты.ID</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
