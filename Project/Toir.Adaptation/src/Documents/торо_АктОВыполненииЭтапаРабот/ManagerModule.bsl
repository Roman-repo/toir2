	|	ДокументАктОВыполненииЭтапаРабот.Комиссия КАК Комиссия
	// гкс+ [Комиссия] Куст 
	|	,ДокументАктОВыполненииЭтапаРабот.Комиссия.гкс_ДатаПриказа КАК ДатаПриказа,
	|	ДокументАктОВыполненииЭтапаРабот.Комиссия.гкс_НомерПриказа КАК НомерПриказа
	// гкс- [Комиссия] Куст 
	|ПОМЕСТИТЬ ВТ_ДанныеДокумента
	|ИЗ
	|	Документ.торо_АктОВыполненииЭтапаРабот КАК ДокументАктОВыполненииЭтапаРабот
	|ГДЕ
	|	ДокументАктОВыполненииЭтапаРабот.Ссылка В(&Ссылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	// гкс+ [8181] Тарасов 
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ДанныеДокумента.Ссылка КАК Ссылка,
	|	РемонтныеРаботыТЧ.НомерСтроки КАК НомерСтроки,
	|	РемонтныеРаботыТЧ.РемонтнаяРабота КАК РемонтнаяРабота,
	|	ПРЕДСТАВЛЕНИЕ(РемонтныеРаботыТЧ.РемонтнаяРабота) КАК РемонтнаяРаботаПредставление
	|ИЗ
	|	ВТ_ДанныеДокумента КАК ВТ_ДанныеДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтныеРаботы КАК РемонтныеРаботыТЧ
	|		ПО (ВТ_ДанныеДокумента.Ссылка = РемонтныеРаботыТЧ.Ссылка)
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(РемонтныеРаботыТЧ.РемонтнаяРабота) = ТИП(Справочник.торо_ИдентификаторыТехКарт)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	НомерСтроки
	// гкс- [8181] Тарасов
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка,
	|	Док.Организация КАК Организация,
	// гкс+ [Комиссия] Куст 
	|	Док.ДатаПриказа КАК ДатаПриказа,
	|	Док.НомерПриказа КАК НомерПриказа,
	// гкс- [Комиссия] Куст 
	|	РемТЧ.ОбъектРемонта КАК ОР,
	|	КомТЧ.ЧленКомиссии КАК Комиссия,
	|	КомТЧ.Ссылка.Председатель КАК Председатель,
	// гкс+ [2021] Куст 
	|	ЕСТЬNULL(РегВД.ДефектОписание, ЕСТЬNULL(РегВО.Описание, """")) КАК Описание,
	// гкс- [2021] Куст 	
	|	Док.Номер КАК Номер,
	|	Док.Дата КАК Дата
	|ИЗ
	|	ВТ_ДанныеДокумента КАК Док
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК РемТЧ
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВыявленныеДефекты КАК РегВД
	|			ПО (РегВД.ID = РемТЧ.ID)
	// гкс+ [2021] Куст 
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВнешниеОснованияДляРабот.СрезПоследних() КАК РегВО
	|			ПО (РегВО.ID = РемТЧ.ID)
	// гкс- [2021] Куст 
	|		ПО (РемТЧ.Ссылка = Док.Ссылка)
