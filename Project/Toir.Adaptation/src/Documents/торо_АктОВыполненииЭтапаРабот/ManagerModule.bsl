&Вместо("ПечатьАктВыполненныхРемонтныхРабот")
Функция Расш_гкс_ПечатьАктВыполненныхРемонтныхРабот(МассивОбъектов, ПараметрыПечати)
	
	ТабДок = Новый ТабличныйДокумент;
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_АктОВыполненииЭтапаРабот.ПФ_MXL_дс_АктВыполненныхРемонтныхРабот");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РемонтыТЧ.Ссылка КАК Документ,
	|	ДокАкт.Номер КАК Номер,
	|	ДокАкт.Дата КАК Дата,
	|	ДокАкт.Организация КАК Организация,
	|	ДокАкт.Подразделение КАК Подразделение,
	|	РемонтыТЧ.ОбъектРемонта КАК ОбъектРемонта,
	|	РемонтыТЧ.ОбъектРемонта.ИнвентарныйНомер КАК ИнвНомер,
	|	РемонтыТЧ.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	РемонтыТЧ.ДокументИсточник КАК ДокументИсточник,
	|	РемонтыТЧ.ДатаНачала КАК ДатаНачала,
	|	РемонтыТЧ.ДатаОкончания КАК ДатаОкончания,
	|	РемонтыТЧ.ID КАК ID,
	|	ИсполнителиТЧ.Исполнитель КАК Контрагент,
	|	ИсполнителиТЧ.УточнениеИсполнителя КАК Договор
	|ПОМЕСТИТЬ ПервыйПакет
	|ИЗ
	|	Документ.торо_АктОВыполненииЭтапаРабот КАК ДокАкт
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК РемонтыТЧ
	|		ПО ДокАкт.Ссылка = РемонтыТЧ.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.ИсполнителиПоРемонтам КАК ИсполнителиТЧ
	|		ПО (ИсполнителиТЧ.Ссылка = ДокАкт.Ссылка)
	|			И (ИсполнителиТЧ.НомерСтроки = 1)
	|ГДЕ
	|	ДокАкт.Ссылка В(&Ссылка)
	|	И РемонтыТЧ.ID В(&МассивID)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РегЗаявки.IDРемонта КАК ИД,
	|	МАКСИМУМ(РегЗаявки.Регистратор) КАК Регистратор
	|ПОМЕСТИТЬ ЗаявкиРемонтов
	|ИЗ
	|	РегистрСведений.торо_ЗаявкиПоРемонтам.СрезПоследних(
	|			,
	|			IDРемонта В
	|					(ВЫБРАТЬ
	|						ТЧ.ID
	|					ИЗ
	|						ПервыйПакет КАК ТЧ)
	|				И Регистратор ССЫЛКА Документ.торо_ЗаявкаНаРемонт) КАК РегЗаявки
	|
	|СГРУППИРОВАТЬ ПО
	|	РегЗаявки.IDРемонта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДокАкт.Документ КАК Документ,
	|	ДокАкт.Номер КАК Номер,
	|	ДокАкт.Дата КАК Дата,
	|	ДокАкт.Организация КАК Организация,
	|	ДокАкт.Подразделение КАК Подразделение,
	|	ДокАкт.ОбъектРемонта КАК ОбъектРемонта,
	|	ДокАкт.ИнвНомер КАК ИнвНомер,
	|	ДокАкт.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	ДокАкт.ДокументИсточник КАК ДокументИсточник,
	|	ДокАкт.ДатаНачала КАК ДатаНачала,
	|	ДокАкт.ДатаОкончания КАК ДатаОкончания,
	|	ДокАкт.ID КАК ID,
	|	ДокАкт.Контрагент КАК Контрагент,
	|	ДокАкт.Договор КАК Договор,
	|	ЕстьNull(РегЗаявки.Регистратор.Дата, """") КАК ЗаявкаДата,
	|	ЕстьNull(РегЗаявки.Регистратор.Номер,"""") КАК ЗаявкаНомер
	|ИЗ
	|	ПервыйПакет КАК ДокАкт
	|		Левое СОЕДИНЕНИЕ ЗаявкиРемонтов КАК РегЗаявки
	|		ПО ДокАкт.ID = РегЗаявки.ИД
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(Организация),
	|	МАКСИМУМ(Подразделение),
	|	МИНИМУМ(ДатаНачала),
	|	МАКСИМУМ(ДатаОкончания)
	|ПО
	|	Документ";
	
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Если ПараметрыПечати.Свойство("МассивID") Тогда
		Запрос.УстановитьПараметр("МассивID", ПараметрыПечати.МассивID);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И РемонтыТЧ.ID В(&МассивID)", "");
	КонецЕсли;
	
	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Документ");
	ЭтоПервый = Истина;
	
	Пока ВыборкаДокументов.Следующий() Цикл
		Документ = ВыборкаДокументов.Документ;
		ДатаНачала = ВыборкаДокументов.ДатаНачала;
		ВыборкаРемонтов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.Прямой);
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА торо_АктРемонтныеРаботы.РемонтнаяРабота ССЫЛКА Справочник.торо_ТехнологическиеОперации
		|			ТОГДА ВЫБОР
		|					КОГДА торо_АктРемонтныеРаботы.РемонтнаяРабота.НаименованиеДляПечати = """"
		|						ТОГДА ТехнологическиеОперации.Наименование
		|					ИНАЧЕ торо_АктРемонтныеРаботы.РемонтнаяРабота.НаименованиеДляПечати
		|				  КОНЕЦ
		|		ИНАЧЕ торо_ВерсииТехКартСрезПоследних.ТехКарта.Наименование
		|	КОНЕЦ КАК Работа,
		|	торо_АктРемонтныеРаботы.ID КАК ID,
		|	торо_АктРемонтныеРаботы.Родитель_ID КАК Родитель_ID,
		|	торо_АктРемонтныеРаботы.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	ВЫБОР
		|		КОГДА торо_АктРемонтныеРаботы.РемонтнаяРабота ССЫЛКА Справочник.торо_ТехнологическиеОперации
		|			ТОГДА ТехнологическиеОперации.Комментарий
		|		ИНАЧЕ торо_ВерсииТехКартСрезПоследних.ТехКарта.Комментарий
		|	КОНЕЦ КАК Комментарий,
		|	ТехнологическиеОперации.БазоваяЕдиницаИзмерения КАК ЕдИзм,
		|	торо_АктРемонтныеРаботы.гкс_Примечание КАК Примечание,
		|	торо_АктРемонтныеРаботы.Количество КАК Количество
		|ИЗ
		|	Документ.торо_АктОВыполненииЭтапаРабот.РемонтныеРаботы КАК торо_АктРемонтныеРаботы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТехнологическиеОперации КАК ТехнологическиеОперации
		|		ПО торо_АктРемонтныеРаботы.РемонтнаяРабота = ТехнологическиеОперации.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт.СрезПоследних(&ДатаНачала, ) КАК торо_ВерсииТехКартСрезПоследних
		|		ПО торо_АктРемонтныеРаботы.РемонтнаяРабота = торо_ВерсииТехКартСрезПоследних.ИдентификаторТехКарты
		|ГДЕ
		|	торо_АктРемонтныеРаботы.Ссылка = &Акт";
		
		Запрос.УстановитьПараметр("Акт", Документ);	
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
		тзСписокРаботИсх = Запрос.Выполнить().Выгрузить();
		
		Пока ВыборкаРемонтов.Следующий() Цикл
			РемонтОборудования  = ВыборкаРемонтов;
			ОбщийИтог = 0;
			
			Если НЕ ЭтоПервый Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЭтоПервый = Ложь;
			
			// Шапка
			Область = Макет.ПолучитьОбласть("Шапка");
			Область.Параметры.НомерДокумента = ВыборкаДокументов.Номер;
			Область.Параметры.Дата	= Формат(ВыборкаДокументов.Дата,"ДЛФ=Д");
			Область.Параметры.ДатаНач = Формат(РемонтОборудования.ДатаНачала,"ДЛФ=Д");
			Область.Параметры.ДатаКонец = Формат(РемонтОборудования.ДатаОкончания,"ДЛФ=Д");
						
			ТабДок.Вывести(Область);
			
			// Заголовок
			Область = Макет.ПолучитьОбласть("Заголовок");
			ТекстИсполнитель = Строка(ВыборкаРемонтов.Контрагент);
			Если ТипЗнч(ВыборкаРемонтов.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда 
				ТекстИсполнитель = ТекстИсполнитель + " (" + ВыборкаДокументов.Договор + ")";
			Иначе
				// ТекстИсполнитель = ТекстИсполнитель + " (" + ? + ")"; // тут нужна организация
			КонецЕсли;
			Область.Параметры.ПодразделениеИсполнитель = ТекстИсполнитель;
			Область.Параметры.ПодразделениеЗаказчик = Строка(ВыборкаРемонтов.Подразделение) + " (" + ВыборкаДокументов.Организация + ")";
			
			Если ТипЗнч(Документ) = Тип("ДокументСсылка.торо_АктОВыполненииРегламентногоМероприятия") Тогда
				ТекстОР = 
				торо_ЗаполнениеДокументов.ПолучитьПредоставленияОРДляПечати(РемонтОборудования.ОбъектРемонта);
			Иначе
				ТекстОР = 
				торо_ЗаполнениеДокументов.ПолучитьПредоставленияОРДляПечати(РемонтОборудования.ОбъектРемонта);
			КонецЕсли;
			Область.Параметры.ОбъектРемонта = Строка(ТекстОР);
			Область.Параметры.ИнвНомер = ВыборкаРемонтов.ИнвНомер;
			Если ЗначениеЗаполнено(ВыборкаРемонтов.ЗаявкаНомер) Тогда 
				Область.Параметры.ЗаголовокЗаявка = "Заявка на ремонт:";
				Область.Параметры.ТекстЗаявка = Строка(ВыборкаРемонтов.ЗаявкаНомер) + " от " + ВыборкаРемонтов.ЗаявкаДата;
			КонецЕсли;
			
			ТабДок.Вывести(Область);
			
			// ВыполненныеРаботыШапка
			Область = Макет.ПолучитьОбласть("ВыполненныеРаботыШапка");
			ТабДок.Вывести(Область);
			
			// ВыполненныеРаботы
			Область = Макет.ПолучитьОбласть("ВыполненныеРаботы");
			
			// Накладываем отбор по РемонтуОборудования. Если делать это в запросе - теряется последовательность ремонтов.
			ПараметрыОтбора = Новый Структура("РемонтыОборудования_ID",РемонтОборудования.ID);
			тзСписокРабот = тзСписокРаботИсх.Скопировать(ПараметрыОтбора);	
			Ном = "1";
			МассивID = Новый Массив;
			МассивСтрок = тзСписокРабот.НайтиСтроки(Новый Структура("Родитель_ID",""));
			
			// Определяем используются ли комментарии или нет
			ВывестиРаботы(МассивСтрок,тзСписокРабот,Область,ТабДок,МассивID,Ном,Истина,Истина);
			
			
			// МатериалыШапка
			ИспользоватьХарактеристики = Константы.торо_ИспользоватьХарактеристикиНоменклатуры.Получить();
			ИспользоватьСерии = Константы.ИспользоватьСерииНоменклатуры.Получить();
			
			Если ИспользоватьХарактеристики Тогда  
				ОбластьШапка = Макет.ПолучитьОбласть("МатериалыФОШапка");
				Область      = Макет.ПолучитьОбласть("МатериалыФО");
			Иначе 
				ОбластьШапка = Макет.ПолучитьОбласть("МатериалыШапка");
				Область      = Макет.ПолучитьОбласть("Материалы");
			КонецЕсли;
			ТабДок.Вывести(ОбластьШапка);
			
			// Материалы
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	СУММА(МатериальныеЗатраты.Количество) КАК Количество,
			|	СУММА(МатериальныеЗатраты.Сумма) КАК Сумма,
			|	МатериальныеЗатраты.Номенклатура КАК Номенклатура,
			|	МатериальныеЗатраты.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
			|	МатериальныеЗатраты.гкс_Давальческие КАК гкс_Давальческие,
			|	МатериальныеЗатраты.ЕдиницаИзмерения КАК ЕдиницаИзмерения
			|ПОМЕСТИТЬ МатЗатраты_Упаковки
			|ИЗ
			|	Документ.торо_АктОВыполненииЭтапаРабот.МатериальныеЗатраты КАК МатериальныеЗатраты
			|ГДЕ
			|	МатериальныеЗатраты.Ссылка = &Ссылка
			|	И МатериальныеЗатраты.РемонтыОборудования_ID = &ID
			|
			|СГРУППИРОВАТЬ ПО
			|	МатериальныеЗатраты.Номенклатура,
			|	МатериальныеЗатраты.гкс_Давальческие,
			|	МатериальныеЗатраты.ХарактеристикаНоменклатуры,
			|	МатериальныеЗатраты.ЕдиницаИзмерения
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	ЕдиницаИзмерения
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	МатериальныеЗатраты.Количество * ЕСТЬNULL(спрУпаковки.Коэффициент, 1) КАК Количество,
			|	МатериальныеЗатраты.Сумма КАК Сумма,
			|	МатериальныеЗатраты.Номенклатура КАК Номенклатура,
			|	МатериальныеЗатраты.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
			|	МатериальныеЗатраты.гкс_Давальческие КАК гкс_Давальческие,
			|	спрНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
			|ПОМЕСТИТЬ МатЗатраты
			|ИЗ
			|	МатЗатраты_Упаковки КАК МатериальныеЗатраты
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиНоменклатуры КАК спрУпаковки
			|		ПО МатериальныеЗатраты.ЕдиницаИзмерения = спрУпаковки.Ссылка
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК спрНоменклатура
			|		ПО МатериальныеЗатраты.Номенклатура = спрНоменклатура.Ссылка
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	Номенклатура,
			|	ХарактеристикаНоменклатуры,
			|	ЕдиницаИзмерения
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ЦеныНоменклатурыСрезПоследних.ВидЦены КАК ВидЦены,
			|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
			|	ЦеныНоменклатурыСрезПоследних.Валюта КАК Валюта,
			|	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
			|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика
			|ПОМЕСТИТЬ ЦеныНоменклатурыСрезПоследних
			|ИЗ
			|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
			|			&Дата,
			|			ВидЦены = &ТипЦены
			|				И Валюта = &Валюта
			|				И (Номенклатура, Характеристика, ЕдиницаИзмерения) В
			|					(ВЫБРАТЬ
			|						Таб.Номенклатура,
			|						Таб.ХарактеристикаНоменклатуры,
			|						Таб.ЕдиницаИзмерения
			|					ИЗ
			|						МатЗатраты КАК Таб)) КАК ЦеныНоменклатурыСрезПоследних
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	Номенклатура,
			|	Характеристика,
			|	ЕдиницаИзмерения
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Количество КАК Количество,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Сумма КАК Сумма,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.гкс_Давальческие КАК гкс_Давальческие,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура КАК Номенклатура,
			|	торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
			|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.ВидЦены, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)) КАК ТипЦены,
			|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) КАК Цена,
			|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Валюта, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) КАК Валюта
			|ИЗ
			|	МатЗатраты КАК торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты
			|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныНоменклатурыСрезПоследних КАК ЦеныНоменклатурыСрезПоследних
			|		ПО торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
			|			И торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ХарактеристикаНоменклатуры = ЦеныНоменклатурыСрезПоследних.Характеристика
			|			И торо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ЕдиницаИзмерения = ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения";
			
			//Запрос.УстановитьПараметр("МатериальныеЗатраты",Документ.МатериальныеЗатраты.Выгрузить(Новый Структура("РемонтыОборудования_ID",РемонтОборудования.ID)));
			Запрос.УстановитьПараметр("Ссылка", Документ);
			Запрос.УстановитьПараметр("Дата", ДатаНачала);
			Запрос.УстановитьПараметр("ТипЦены",Константы.торо_ТипЦеныДляРасчетаСебестоимостиРемонта.Получить());
			Запрос.УстановитьПараметр("Валюта",Константы.ВалютаУправленческогоУчета.Получить());
			Запрос.УстановитьПараметр("ID", РемонтОборудования.ID);
			
			Результат = Запрос.Выполнить();
			Выборка = Результат.Выбрать();
			
			счетчик = 1;
			Итого=0;
			Пока Выборка.Следующий() Цикл
				
				Область.Параметры.Материал   = Выборка.Номенклатура;
				Если ИспользоватьХарактеристики Тогда  
					Область.Параметры.Характеристика = Строка(Выборка.ХарактеристикаНоменклатуры);
				КонецЕсли;
				Область.Параметры.Ед 		 = Выборка.Номенклатура.ЕдиницаИзмерения;
				Область.Параметры.Код 		 = Выборка.Номенклатура.Код;
				Область.Параметры.Количество = Выборка.Количество;
				Область.Параметры.Давальческие = ?(Выборка.гкс_Давальческие, "Да", "");
 
				Область.Параметры.Номер      = счетчик;
				счетчик = счетчик + 1;
				ТабДок.Вывести(Область);		
				
			КонецЦикла;
			
			//Исполнители			
			
			Область = Макет.ПолучитьОбласть("Собственные");
			Область1 = Макет.ПолучитьОбласть("Собственные1");
			Запрос = Новый Запрос;
			Запрос.Текст = "
			|выбрать ТЧ.Исполнитель Ссылка Справочник.Контрагенты КАК ЭтоКонтрагент, ТЧ.Ссылка КАК Ссылка
			|Поместить ВТ_Контрагент
			|ИЗ
			|	Документ.торо_АктОВыполненииЭтапаРабот.ИсполнителиПоРемонтам КАК ТЧ
			|ГДЕ
			|	ТЧ.Ссылка = &Ссылка И ТЧ.НомерСТроки = 1

			| ; ВЫБРАТЬ
			|	ТЧ.Квалификация КАК Квалификация,
			|	СУММА(ТЧ.ВремяРаботы * выбор когда ТЧ.гкс_Количество = 0 тогда 1 иначе ТЧ.гкс_Количество конец) КАК ВремяРаботы,
			|	СУММА(ТЧ.СуммаКНачислению) КАК СуммаКНачислению,
			|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТЧ.ID) КАК ID,
			|	ТЧ.Сотрудник КАК Сотрудник, Максимум(ЕстьNull(ВТ.ЭтоКонтрагент, Ложь)) КАК ЭтоКонтрагент
			|ИЗ
			|	Документ.торо_АктОВыполненииЭтапаРабот.ТрудовыеЗатраты КАК ТЧ
			|	Левое соединение ВТ_Контрагент КАК ВТ ПО ВТ.Ссылка = ТЧ.Ссылка
			|ГДЕ
			|	ТЧ.Ссылка = &Ссылка
			|	И ТЧ.РемонтыОборудования_ID = &ID
			|
			|СГРУППИРОВАТЬ ПО
			|	ТЧ.Квалификация,
			|	ТЧ.Сотрудник";
			
			
			Запрос.УстановитьПараметр("Ссылка", Документ);
			Запрос.УстановитьПараметр("ID", РемонтОборудования.ID);
			
			Результат = Запрос.Выполнить();
			Выборка = Результат.Выбрать();
			
			счетчик = 1;
			Итого = 0;
			Пока Выборка.Следующий() Цикл
				Если счетчик = 1 Тогда 
					Если ЗначениеЗаполнено(Выборка.Сотрудник) И Выборка.ЭтоКонтрагент = Ложь Тогда 
						ОбластьШапка1 = Макет.ПолучитьОбласть("СобственныеШапка");
						ТабДок.Вывести(ОбластьШапка1);
					Иначе
						ОбластьШапка1 = Макет.ПолучитьОбласть("СобственныеШапка1");
						ТабДок.Вывести(ОбластьШапка1);
					КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Выборка.Сотрудник) И Выборка.ЭтоКонтрагент = Ложь Тогда 
					текОбласть = Область;
					ТекОбласть.Параметры.ФИО = Выборка.Сотрудник;
				Иначе
					текОбласть = Область1;
				КонецЕсли;
				ТекОбласть.Параметры.Квалификация = Выборка.Квалификация;
				ТекОбласть.Параметры.ВремяРаботы  = торо_ОбщегоНазначенияКлиентСервер.СформироватьЗаголовокПоПродолжительности(Выборка.ВремяРаботы);
				ТекОбласть.Параметры.Номер        = счетчик;
				
				счетчик = счетчик + 1;
				ТабДок.Вывести(ТекОбласть);		
				Итого = Итого + Выборка.ВремяРаботы;
				
			КонецЦикла;
			
			Область = Макет.ПолучитьОбласть("ИтогоСобственные");
			Если ЗначениеЗаполнено(Итого) Тогда 
				Область.Параметры.Итого = торо_ОбщегоНазначенияКлиентСервер.СформироватьЗаголовокПоПродолжительности(Итого);
			Иначе
				Область.Параметры.Итого = "";
			КонецЕсли;
			ТабДок.Вывести(Область);	
				
			// Подрядчики
			Область = Макет.ПолучитьОбласть("ПодрядчикШапка");
			ТабДок.Вывести(Область);
			
			Область = Макет.ПолучитьОбласть("Подрядчик");
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ИсполнителиПоРемонтам.Исполнитель КАК Контрагент,
			|	ИсполнителиПоРемонтам.Сумма КАК Сумма
			|ИЗ
			|	Документ.торо_АктОВыполненииЭтапаРабот.ИсполнителиПоРемонтам КАК ИсполнителиПоРемонтам
			|ГДЕ
			|	ИсполнителиПоРемонтам.Ссылка = &Документ
			|	И ИсполнителиПоРемонтам.РемонтыОборудования_ID = &РемонтыОборудования_ID
			|	И ИсполнителиПоРемонтам.Исполнитель ССЫЛКА Справочник.Контрагенты";
			
			Запрос.УстановитьПараметр("Документ", Документ);
			Запрос.УстановитьПараметр("РемонтыОборудования_ID", РемонтОборудования.ID);
			
			Результат = Запрос.Выполнить();
			Выборка = Результат.Выбрать();
			счетчик = 1;
			Итого = 0;
			Пока Выборка.Следующий() Цикл
				
				Область.Параметры.Подрядчик   = Выборка.Контрагент;
				Область.Параметры.Номер      = счетчик;
				счетчик = счетчик + 1;
				ТабДок.Вывести(Область);
				
			КонецЦикла; 
						
			// Подвал
			Область = Макет.ПолучитьОбласть("Подвал");
			
			ТабДок.Вывести(Область);
			
		КонецЦикла;
		
	КонецЦикла;
	
	ТабДок.ТолькоПросмотр = Истина;
	Возврат ТабДок;
	
КонецФункции

&ИзменениеИКонтроль("ВывестиРаботы")
Процедура Расш_гкс_ВывестиРаботы(МассивСтрок, тзСписокРабот, СтрокаТаблицыРабот, ТабДок, МассивID, Ном, Комментарии, КолВо)
	Для каждого СписокРабот Из МассивСтрок Цикл
		СтрокаТаблицыРабот.Параметры.Номер = Ном;
		#Удаление
		СтрокаТаблицыРабот.Параметры.Работа = СписокРабот.Работа;
		#КонецУдаления
		#Вставка
		СтрокаТаблицыРабот.Параметры.Работа = Строка(СписокРабот.Работа) + " " + СписокРабот.Примечание;
		#КонецВставки
		Если КолВо = Истина Тогда
			СтрокаТаблицыРабот.Параметры.Количество=СписокРабот.Количество; 
			СтрокаТаблицыРабот.Параметры.ЕдИзм=СписокРабот.ЕдИзм; 
		КонецЕсли;	
		Если Комментарии = Истина Тогда
			СтрокаТаблицыРабот.Параметры.Комментарий = СписокРабот.Комментарий;
		КонецЕсли;
		ТабДок.Вывести(СтрокаТаблицыРабот);
		МассивID.Добавить(СписокРабот.ID);
		ВывестиРаботы(тзСписокРабот.НайтиСтроки(Новый Структура("Родитель_ID",СписокРабот.ID)),тзСписокРабот,СтрокаТаблицыРабот,ТабДок,МассивID,Ном + ".1",Комментарии,КолВо);

		КоличествоРазделителей = СтрЧислоВхождений(Ном, ".");
		ПозицияКрайнегоРазделителя = СтрНайти(Ном, ".", , , ?(КоличествоРазделителей = 0, 1, КоличествоРазделителей));
		ЦелаяЧасть = Лев(Ном, ?(ПозицияКрайнегоРазделителя = 1, СтрДлина(Ном), ПозицияКрайнегоРазделителя));
		ДробнаяЧасть = Строка(Число(Сред(Ном, ПозицияКрайнегоРазделителя + 1)) + 1);
		Ном = ЦелаяЧасть + ДробнаяЧасть;
	КонецЦикла;
КонецПроцедуры

Функция гкс_ПечатьДефектныйАкт2026(МассивОбъектов, ПараметрыПечати)

	Макет  = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_АктОВыполненииЭтапаРабот.ПФ_MXL_гкс_ДефектныйАкт2026");

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьКомиссия = Макет.ПолучитьОбласть("Комиссия");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	ОбластьПодвалСтрока = Макет.ПолучитьОбласть("ПодвалСтрока");

	Запрос = Новый Запрос;
	Запрос.Текст = гкс_ТекстЗапросаДефектныйАкт2026();		
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	НомерПакетаОсновной = 2;
	НомерПакетаТМЦ = 3;

	ВыборкаСсылка = РезультатыЗапроса[НомерПакетаОсновной].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаТМЦСсылка = РезультатыЗапроса[НомерПакетаТМЦ].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	ПервыйДокумент = Истина;
	Пока ВыборкаСсылка.Следующий() Цикл
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		НомерПП = 0;
		ВыборкаДетальныеЗаписи = ВыборкаСсылка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если НомерПП = 0 Тогда 
				ОбластьШапка.Параметры.Организация = ВыборкаДетальныеЗаписи.Организация;
				ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры, ВыборкаДетальныеЗаписи,, "Дата, ДатаПриказа");
				ОбластьШапка.Параметры.ДатаПриказа = Формат(ВыборкаДетальныеЗаписи.ДатаПриказа, "ДЛФ=Д");
				ОбластьШапка.Параметры.Дата = Формат(ВыборкаДетальныеЗаписи.Дата, "ДФ=дд.ММ.гггг");
				ТабличныйДокумент.Вывести(ОбластьШапка);
				
				ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры, ВыборкаДетальныеЗаписи,
					"ОбъектРемонта,Комментарий,НомерСметы");
			Иначе
				ОбластьКомиссия.Параметры.ЧленКомиссии = ВыборкаДетальныеЗаписи.ЧленКомиссии;
				ТабличныйДокумент.Вывести(ОбластьКомиссия);
			КонецЕсли;
			НомерПП = НомерПП + 1;
		КонецЦикла;
		
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		ВыборкаТМЦСсылка.Сбросить();
		Если ВыборкаТМЦСсылка.НайтиСледующий(Новый Структура("Ссылка", ВыборкаСсылка.Ссылка)) Тогда 
			
			ВыборкаДетальныеЗаписиТМЦ = ВыборкаТМЦСсылка.Выбрать();
			Пока ВыборкаДетальныеЗаписиТМЦ.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(ОбластьПодвалСтрока.Параметры, ВыборкаДетальныеЗаписиТМЦ);
				Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписиТМЦ.ЕдиницаИзмерения) Тогда 
					ОбластьПодвалСтрока.Параметры.ЕдиницаИзмерения = ВыборкаДетальныеЗаписиТМЦ.ЕдиницаИзмерения;
				Иначе
					ОбластьПодвалСтрока.Параметры.ЕдиницаИзмерения = 
						ВыборкаДетальныеЗаписиТМЦ.НоменклатураЕдиницаИзмерения;
				КонецЕсли;
				
				ТабличныйДокумент.Вывести(ОбластьПодвалСтрока);
			КонецЦикла;   
			
		КонецЕсли;
	КонецЦикла;
	
	// Зададим параметры макета
	ТабличныйДокумент .АвтоМасштаб	= Истина;
	ТабличныйДокумент .ПолеСверху  = 0;
	ТабличныйДокумент .ПолеСлева   = 0;
	ТабличныйДокумент .ПолеСнизу   = 0;
	ТабличныйДокумент .ПолеСправа  = 0;
	ТабличныйДокумент .ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	
	Возврат ТабличныйДокумент ;

КонецФункции 

Функция гкс_ТекстЗапросаДефектныйАкт2026()
	
	Возврат
	"ВЫБРАТЬ
	|	ДокументАктОВыполненииЭтапаРабот.Ссылка КАК Ссылка,
	|	ДокументАктОВыполненииЭтапаРабот.Организация КАК Организация,
	|	ДокументАктОВыполненииЭтапаРабот.Номер КАК Номер,
	|	ДокументАктОВыполненииЭтапаРабот.Дата КАК Дата,
	|	ДокументАктОВыполненииЭтапаРабот.Комментарий КАК Комментарий,
	|	ДокументАктОВыполненииЭтапаРабот.Комиссия КАК Комиссия
	|ПОМЕСТИТЬ ВТДанныеДокумента
	|ИЗ
	|	Документ.торо_АктОВыполненииЭтапаРабот КАК ДокументАктОВыполненииЭтапаРабот
	|ГДЕ
	|	ДокументАктОВыполненииЭтапаРабот.Ссылка В(&Ссылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктОВыполненииЭтапаРаботДокументыОснования.Ссылка КАК АктСсылка,
	|	ЗаявкаНаРемонт.Номер КАК НомерСметы
	|ПОМЕСТИТЬ ВТСметы
	|ИЗ
	|	Документ.торо_АктОВыполненииЭтапаРабот.ДокументыОснования КАК АктОВыполненииЭтапаРаботДокументыОснования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт КАК ЗаявкаНаРемонт
	|		ПО АктОВыполненииЭтапаРаботДокументыОснования.ДокументОснование = ЗаявкаНаРемонт.Ссылка
	|ГДЕ
	|	АктОВыполненииЭтапаРаботДокументыОснования.Ссылка В(&Ссылка)
	|	И АктОВыполненииЭтапаРаботДокументыОснования.НомерСтроки = 1
	|	И ТИПЗНАЧЕНИЯ(АктОВыполненииЭтапаРаботДокументыОснования.ДокументОснование) = ТИП(Документ.торо_ЗаявкаНаРемонт)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТДанныеДокумента.Ссылка КАК Ссылка,
	|	ВТДанныеДокумента.Организация КАК Организация,
	|	ВТДанныеДокумента.Комментарий КАК Комментарий,
	|	ВТДанныеДокумента.Номер КАК Номер,
	|	ВТДанныеДокумента.Дата КАК Дата,
	|	ПРЕДСТАВЛЕНИЕ(РемонтыОборудования.ОбъектРемонта) КАК ОбъектРемонта,
	|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(СправочникКомиссии.Председатель), """") КАК Председатель,
	|	ЕСТЬNULL(СправочникКомиссии.гкс_ДатаПриказа, """") КАК ДатаПриказа,
	|	ЕСТЬNULL(СправочникКомиссии.гкс_НомерПриказа, """") КАК НомерПриказа,
	|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(КомиссииСоставКомиссии.ЧленКомиссии), """") КАК ЧленКомиссии,
	|	ЕСТЬNULL(ВТСметы.НомерСметы, """") КАК НомерСметы
	|ИЗ
	|	ВТДанныеДокумента КАК ВТДанныеДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК РемонтыОборудования
	|		ПО (РемонтыОборудования.Ссылка = ВТДанныеДокумента.Ссылка)
	|			И (РемонтыОборудования.НомерСтроки = 1)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_Комиссии КАК СправочникКомиссии
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_Комиссии.СоставКомиссии КАК КомиссииСоставКомиссии
	|			ПО СправочникКомиссии.Ссылка = КомиссииСоставКомиссии.Ссылка
	|		ПО ВТДанныеДокумента.Комиссия = СправочникКомиссии.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСметы КАК ВТСметы
	|		ПО ВТДанныеДокумента.Ссылка = ВТСметы.АктСсылка
	|ИТОГИ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктОВыполненииЭтапаРаботМатериальныеЗатраты.Ссылка КАК Ссылка,
	|	АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура КАК Номенклатура,
	|	АктОВыполненииЭтапаРаботМатериальныеЗатраты.Количество КАК Количество,
	|	ПРЕДСТАВЛЕНИЕ(АктОВыполненииЭтапаРаботМатериальныеЗатраты.ЕдиницаИзмерения) КАК ЕдиницаИзмерения,
	|	ПРЕДСТАВЛЕНИЕ(СправочникНоменклатура.ЕдиницаИзмерения) КАК НоменклатураЕдиницаИзмерения,
	|	СправочникНоменклатура.Код КАК Код
	|ИЗ
	|	Документ.торо_АктОВыполненииЭтапаРабот.МатериальныеЗатраты КАК АктОВыполненииЭтапаРаботМатериальныеЗатраты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура = СправочникНоменклатура.Ссылка
	|ГДЕ
	|	АктОВыполненииЭтапаРаботМатериальныеЗатраты.Ссылка В(&Ссылка)
	|ИТОГИ ПО
	|	Ссылка";
	
КонецФункции	

#КонецОбласти  

