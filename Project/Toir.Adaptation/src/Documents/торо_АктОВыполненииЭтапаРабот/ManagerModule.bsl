#Область ОбработчикиСобытий

&Перед("ОбработкаПолученияФормы")
Процедура гкс_ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		ВремяНачала = ОценкаПроизводительности.НачатьЗамерВремени();
		Параметры.Вставить("ВремяНачалаОткрытияФормы", ВремяНачала);
		СтандартнаяОбработка = Ложь;
		ВыбраннаяФорма = Метаданные.Документы.торо_АктОВыполненииЭтапаРабот.Формы.ФормаДокумента.Имя;		
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// гкс+ [Релиз 1] Куст 
Функция ПечатьНарядЗадание(МассивОбъектов, ПараметрыПечати, НовыйСиноним)

	Макет  = УправлениеПечатью.МакетПечатнойФормы("Документ.торо_ЗаявкаНаРемонт.ПФ_MXL_дс_НарядЗадание");
	ТабДокумент = Новый ТабличныйДокумент;
	Шапка = Макет.ПолучитьОбласть("Шапка");
	СтрокаРР = Макет.ПолучитьОбласть("СтрокаРР");
	ПодвалРР = Макет.ПолучитьОбласть("ПодвалРР");
	СтрокаМЗ = Макет.ПолучитьОбласть("СтрокаМЗ");
	ШапкаИнструменты = Макет.ПолучитьОбласть("ШапкаИнструменты");
	СтрокаИнструменты = Макет.ПолучитьОбласть("СтрокаИнструменты");
	Подвал = Макет.ПолучитьОбласть("Подвал");
	СдвигЧП = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	// гкс+ [Релиз18] Деснол
	Если ПараметрыПечати.Свойство("ОтборИсполнитель") Тогда 
		ОтборИсполнитель = ПараметрыПечати.ОтборИсполнитель;
		ЕстьОтборИсполнитель = Истина;
	Иначе
		ОтборИсполнитель = Новый Массив();
		ЕстьОтборИсполнитель = Ложь;
	КонецЕсли;
	// гкс- [Релиз18]

	ЗапросДокументов = Новый Запрос;
	ЗапросДокументов.Текст = 
	"ВЫБРАТЬ
	|	ДокОснования.Ссылка КАК Ссылка,
	|	ЕстьNull(ДокНаряд.ДокументОснование,ДокОснования.ДокументОснование) КАК ДокументОснование
	|ПОМЕСТИТЬ НужныеОснования
	|ИЗ
	|	Документ.торо_АктОВыполненииЭтапаРабот.ДокументыОснования КАК ДокОснования
	|	Левое Соединение Документ.торо_НарядНаВыполнениеРемонтныхРабот.ДокументыОснования КАК ДокНаряд
	|	ПО ДокНаряд.Ссылка = ДокОснования.ДокументОснование И ДокНаряд.ДокументОснование Ссылка Документ.торо_ЗаявкаНаРемонт
	|ГДЕ
	|	ДокОснования.Ссылка В(&Ссылка)
	|;
	| ВЫБРАТЬ
	|	ДокОснования.Ссылка КАК Акт,
	|	АктРемонты.ID КАК ИД,
	|	ДокОснования.ДокументОснование КАК Основание
	|ПОМЕСТИТЬ АктИОснование
	|ИЗ
	|	НужныеОснования КАК ДокОснования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.РемонтыОборудования КАК АктРемонты
	|		ПО (АктРемонты.Ссылка = ДокОснования.Ссылка)
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта КАК ОР,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.ID КАК ИД,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка КАК Док,
	|	АктРемонты.Акт КАК Акт,
	|	МАКСИМУМ(НЕ торо_ЗаявкаНаРемонтПрисоединенныеФайлы.Ссылка ЕСТЬ NULL) КАК ЕстьФайлы
	|ПОМЕСТИТЬ Ремонты
	|ИЗ
