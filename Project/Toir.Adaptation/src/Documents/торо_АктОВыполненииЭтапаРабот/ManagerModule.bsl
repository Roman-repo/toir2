	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_Комиссии.СоставКомиссии КАК КомТЧ
	|		ПО (КомТЧ.Ссылка = Док.Комиссия)
	|
	|ИТОГИ ПО
	|	Ссылка";
	// гкс+ [Релиз16] Деснол
	ЗапросДокументов.Текст = ЗапросДокументов.Текст + " ; "
+ "
|Выбрать
|Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Ссылка КАК Ссылка,
|Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура КАК Номенклатура,
|Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура.Код КАК Код,
|Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Количество КАК Колво,
|Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.ЕдиницаИзмерения КАК Упаковка,
|Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Номенклатура.ЕдиницаИзмерения КАК ЕдИзм
|ИЗ
|	Документ.торо_АктОВыполненииЭтапаРабот.МатериальныеЗатраты КАК Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты
|ГДЕ
|	Документторо_АктОВыполненииЭтапаРаботМатериальныеЗатраты.Ссылка В (&Ссылка)
|Итоги ПО Ссылка
|";
	НомерПакетаРемРаботы = 1;
	НомерПакетаОсновной = НомерПакетаРемРаботы + 1;
	НомерПакетаТМЦ = НомерПакетаОсновной + 1;
	// гкс- [Релиз16]
	
	ЗапросДокументов.УстановитьПараметр("Ссылка", МассивОбъектов);
	
	МассивРезультатовЗапроса = ЗапросДокументов.ВыполнитьПакет();
	
	// гкс+ [Релиз16] Деснол
	ВыборкаРемонтныеРаботы = МассивРезультатовЗапроса[НомерПакетаРемРаботы].Выбрать();
	ВыборкаТМЦДок = МассивРезультатовЗапроса[НомерПакетаТМЦ].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Выборка = МассивРезультатовЗапроса[НомерПакетаОсновной].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	// гкс- [Релиз16]
	ЭтоПервый = Истина;
	Пока Выборка.Следующий() Цикл
		Если НЕ ЭтоПервый Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ЭтоПервый = Ложь;
		//
		НомерПП = 0;
		ВыборкаК = Выборка.Выбрать();
		Пока ВыборкаК.Следующий() Цикл
			Если НомерПП = 0 Тогда 
				Шапка.Параметры.Организация = ВыборкаК.Организация;
				// гкс+ [Комиссия] Куст 
				ЗаполнитьЗначенияСвойств(Шапка.Параметры, ВыборкаК);
				Шапка.Параметры.ДатаПриказа = Формат(ВыборкаК.ДатаПриказа, "ДЛФ=Д");
				// гкс- [Комиссия] Куст 
				Шапка.Параметры.Номер = ВыборкаК.Номер;
				// гкс+ [2021] Куст 
				Шапка.Параметры.Дата = Формат(ВыборкаК.Дата, "ДФ=дд.ММ.гггг");
				// гкс- [2021] Куст 
				Шапка.Параметры.ОР = ВыборкаК.ОР;
				Шапка.Параметры.Председатель = ВыборкаК.Председатель;
				// гкс+ [05.23] Деснол 10.05.2023
				ПараметрыПодвала = Новый Структура("ОР,ОписаниеДефекта", ВыборкаК.ОР, ВыборкаК.Описание);
				ЗаполнитьЗначенияСвойств(Подвал.Параметры, ПараметрыПодвала);
				// гкс- [05.23] Деснол 10.05.2023
				Шапка.Параметры.Комиссия = ВыборкаК.Комиссия;
				ТабДокумент.Вывести(Шапка);
			Иначе
				ДопКомиссия.Параметры.Комиссия = ВыборкаК.Комиссия;
				ТабДокумент.Вывести(ДопКомиссия);
			КонецЕсли;
			НомерПП = НомерПП + 1;
		КонецЦикла;
		// гкс+ [8181] Тарасов 
		// Получаем список Тех карт через запятую
		СписокТехКарт = "";
		СтркутураПоиска = Новый Структура("Ссылка", Выборка.Ссылка);
		Пока ВыборкаРемонтныеРаботы.НайтиСледующий(СтркутураПоиска) Цикл
			СписокТехКарт = СписокТехКарт+""+ВыборкаРемонтныеРаботы.РемонтнаяРаботаПредставление+", ";
		КонецЦикла;
		ВыборкаРемонтныеРаботы.Сбросить();
		СписокТехКарт = СокрЛП(СписокТехКарт);
		СписокТехКарт = СокрЛП(Лев(СписокТехКарт, СтрДлина(СписокТехКарт) - 1));
		
		Подвал.Параметры.СписокТехКарт = СписокТехКарт;
		// гкс- [8181] Тарасов 
		
		ТабДокумент.Вывести(Подвал);
		// гкс+ [Релиз16] Деснол
		ВыборкаТМЦДок.Сбросить();
		Если ВыборкаТМЦДок.НайтиСледующий(Новый Структура("Ссылка", Выборка.Ссылка)) Тогда 
			ВыборкаТМЦ = ВыборкаТМЦДок.Выбрать();
			Пока ВыборкаТМЦ.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(ПодвалСтрока.Параметры, ВыборкаТМЦ);
				Если ЗначениеЗаполнено(ВыборкаТМЦ.Упаковка) Тогда 
					ПодвалСтрока.Параметры.ЕдИзм = ВыборкаТМЦ.Упаковка;
				Иначе
					ПодвалСтрока.Параметры.ЕдИзм = ВыборкаТМЦ.ЕдИзм;
				КонецЕсли;
				ТабДокумент.Вывести(ПодвалСтрока);
			КонецЦикла;
		КонецЕсли;
		// гкс- [Релиз16]
	КонецЦикла;
	
	// Зададим параметры макета
	ТабДокумент.АвтоМасштаб	= Истина;
	ТабДокумент.ПолеСверху  = 0;
	ТабДокумент.ПолеСлева   = 0;
	ТабДокумент.ПолеСнизу   = 0;
	ТабДокумент.ПолеСправа  = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ТабДокумент.ТолькоПросмотр = Истина;
	
	Возврат ТабДокумент;
КонецФункции // гкс- [Релиз 1] Куст 

