&НаСервере
&ИзменениеИКонтроль("ПередЗаписьюНаСервере")
Процедура гкс_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	// Согласование++
	торо_РаботаССогласованиями.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	// Согласование--

	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
		И ФОИспользоватьГарантии Тогда
		торо_ГарантийноеОбслуживание.СформироватьПредупрежденияОРекламационныхАктах(Объект, "РемонтыОборудования");
	КонецЕсли;

	#Вставка
	Если СредиИсполнителейЕстьКонтрагент() = Ложь Тогда 
	#КонецВставки
	Если торо_ОбщегоНазначения.ПроверитьВремяРаботыСотрудников(Объект, "ТрудовыеЗатраты") Тогда 
		Отказ = Истина;
	КонецЕсли;
	#Вставка
	КонецЕсли;
	
	// Гкс+[TOIR20-725] Литвин В.В. от 09.10.2025 Добавлено:{
	ДеревоСФормы = РеквизитФормыВЗначение("ДеревоРемонтныхРабот");
	ПредставлениеКорневойСтроки = дс_ПолучитьПредставлениеКорневойРемонтнойРаботы();
	СообщениеОбОтсутствииКорневойСтроки = СтрШаблон("Не найдена корневая строка ""%1"" в дереве ремонтных работ",
													ПредставлениеКорневойСтроки);
	
	Если ДеревоСФормы.Строки.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(СообщениеОбОтсутствииКорневойСтроки);
		Возврат;
	КонецЕсли;	
																											
	КорневаяСтрока = ДеревоСФормы.Строки[0];
	
	Если КорневаяСтрока.РемонтнаяРабота <> ПредставлениеКорневойСтроки Тогда
		ОбщегоНазначения.СообщитьПользователю(СообщениеОбОтсутствииКорневойСтроки);
	Иначе
		Для Каждого СтрокаТехКарта Из КорневаяСтрока.Строки Цикл
			Если Не СтрокаТехКарта.ЭтоТехКарта Тогда
				Отказ = Истина;
				Если ЗначениеЗаполнено(СтрокаТехКарта.ТехОперация) Тогда
					СообщениеОбОтсутствииТехКарты = СтрШаблон("Для операции ""%1"" отсутствует тех.карта", 
															  СтрокаТехКарта.ТехОперация);
					ОбщегоНазначения.СообщитьПользователю(СообщениеОбОтсутствииТехКарты);	
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	// Гкс-[TOIR20-725] Литвин В.В. от 09.10.2025}
	#КонецВставки

КонецПроцедуры

// гкс+ [Подбор ТехКарт] Куст 
&НаКлиенте
&ИзменениеИКонтроль("ОбработкаВыбора")
Процедура гкс_ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура")
		И ВыбранноеЗначение.Свойство("ВыполняемаяОперация")
		И ВыбранноеЗначение.ВыполняемаяОперация = "ВыборАналогаНоменклатурыДляРемонта" Тогда
		ЗаменитьМатериалыНаАналоги(ВыбранноеЗначение.АдресВХранилище);
		ТекДанныеРемРаб = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		МассивID = Новый Массив;
		ЗаполнитьМассивID(МассивID,ТекДанныеРемРаб);
		ОтметитьНаличиеАналогов(МассивID);
		Модифицированность = Истина;

	ИначеЕсли ИсточникВыбора.Имяформы = "Обработка.торо_ПодборНоменклатуры.Форма.Форма" Тогда

		ТекДанныеРемРаб = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

		Если ТекДанныеРемРаб = Неопределено Тогда 
			Возврат;
		КонецЕсли;

		ИмяТЧ = "МатериальныеЗатраты";
		ИмяРеквизита = "Номенклатура";
		СтруктураСтрокиОпераций = Новый Структура("РемонтыОборудования_ID, ID, Количество", ТекДанныеРемРаб.РемонтыОборудования_ID, ТекДанныеРемРаб.ID, ТекДанныеРемРаб.Количество);
		ДобавитьНоменклатуруИзПодбора(ВыбранноеЗначение, СтруктураСтрокиОпераций, ИмяТЧ, ИмяРеквизита);
		ОтметитьНаличиеАналогов(ТекДанныеРемРаб.ID);
		Модифицированность = Истина;

	Иначе
		#Вставка
		// гкс+ [Релиз16] Деснол
		Отказ = Ложь;
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") 
			И ВыбранноеЗначение.Свойство("СтрокаРемонтовОборудования") Тогда 
			гкс_ПроверитьЗакрытостьРемонта(Отказ, ВыбранноеЗначение.СтрокаРемонтовОборудования.ID);
		КонецЕсли;
		Если Отказ Тогда 
			Сооб = Новый СообщениеПользователю();
			Сооб.Текст =  НСтр("ru='Ремонт завершен. Создание акта запрещено.'");
			Сооб.Сообщить();
			Возврат;
		КонецЕсли;
		// гкс- [Релиз16]
		#Конецвставки

		ЕстьДокументы = Ложь;

		Если ПолучитьФОПовышеннаяОпасность() Тогда
			Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") И ВыбранноеЗначение.Свойство("ДокументОснование") Тогда
				Если ТипЗнч(ВыбранноеЗначение.ДокументОснование) <> Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") Тогда
					ЗаполнитьТабОперацийБезНаряда(ВыбранноеЗначение.ДокументОснование, ВыбранноеЗначение.СтрокаРемонтовОборудования.ID);

					Если ТабОперацийБезНаряда.Количество() > 0 Тогда
						ЕстьДокументы = Истина;
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли  ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда
				Для каждого Элемент Из ВыбранноеЗначение Цикл
					Если ТипЗнч(Элемент.ДокументОснование) <> Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") Тогда
						ЗаполнитьТабОперацийБезНаряда(Элемент.ДокументОснование);

						Если ТабОперацийБезНаряда.Количество() > 0 Тогда
							ЕстьДокументы = Истина;
							Прервать;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;

		Если Не ЕстьДокументы Тогда

			ЭтоРемонтнаяРабота = Ложь;
			РемонтУжеДобавлен = Ложь;
			МассивИДДобавленныхРемонтов = Новый Массив;
			Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") И ВыбранноеЗначение.Количество() > 0 Тогда 
				Для каждого ЭлементМассива Из ВыбранноеЗначение Цикл
					Если ТипЗнч(ЭлементМассива) = Тип("Структура") И ЭлементМассива.Свойство("СтрокаРемонтовОборудования") Тогда 
						НайденныеРемонты = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ЭлементМассива.СтрокаРемонтовОборудования.ID));
						Если НайденныеРемонты.Количество() > 0 Тогда
							РемонтУжеДобавлен = Истина;
							МассивИДДобавленныхРемонтов.Добавить(ЭлементМассива.СтрокаРемонтовОборудования.ID);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;

				Если РемонтУжеДобавлен Тогда 
					Вопрос = НСтр("es='Algunos de las reparaciones escogidas son añadidos ya. Los trabajos de reparación vinculados serán limpiados y añadidos de nuevo. ¿Continuar?';ru='Некоторые из выбранных ремонтов уже добавлены. Связанные ремонтные работы будут очищены и добавлены заново. Продолжить?';en='Some of the selected repairs have already been added. Associated repairs will be cleaned and re-added. Continue?'");
				КонецЕсли;
			КонецЕсли;

			Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") И ВыбранноеЗначение.Свойство("СтрокаРемонтовОборудования") 
				И ВыбранноеЗначение.Количество() > 0 Тогда 
				ЭтоРемонтнаяРабота = ВыбранноеЗначение.ЭтоРемонтнаяРабота;
				НайденныеРемонты = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ВыбранноеЗначение.СтрокаРемонтовОборудования.ID));
				Если НайденныеРемонты.Количество() > 0 Тогда
					РемонтУжеДобавлен = Истина;
					МассивИДДобавленныхРемонтов.Добавить(ВыбранноеЗначение.СтрокаРемонтовОборудования.ID);
				КонецЕсли;

				Если РемонтУжеДобавлен Тогда 
					Вопрос = НСтр("es='Esta reparación es añadida ya. Los trabajos de reparación vinculados serán limpiados y añadidos de nuevo. ¿Continuar?';ru='Этот ремонт уже добавлен. Связанные ремонтные работы будут очищены и добавлены заново. Продолжить?';en='This repair has already been added. Associated repairs will be cleaned and re-added. Continue?'");
				КонецЕсли;
			КонецЕсли;

			Если РемонтУжеДобавлен И НЕ ЭтоРемонтнаяРабота Тогда
				СтруктураПараметров = Новый Структура;
				СтруктураПараметров.Вставить("ВыбранноеЗначение", ВыбранноеЗначение);
				СтруктураПараметров.Вставить("МассивИДДобавленныхРемонтов", МассивИДДобавленныхРемонтов);
				ПоказатьВопрос(Новый ОписаниеОповещения("ОбработкаВыбораПослеВопроса", ЭтотОбъект, СтруктураПараметров),
				Вопрос, РежимДиалогаВопрос.ДаНет);
				Возврат;
			Иначе
				ОбработкаВыбораЗавершение(ВыбранноеЗначение);
				#Вставка
				МодифицироватьИсполнителей();
				#КонецВставки
				Возврат;
			КонецЕсли;

		Иначе

			Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") И ВыбранноеЗначение.Свойство("ДокументОснование") Тогда
				Если ТипЗнч(ВыбранноеЗначение.ДокументОснование) <> Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") Тогда
					ЗаполнитьТабОперацийБезНаряда(ВыбранноеЗначение.ДокументОснование, ВыбранноеЗначение.СтрокаРемонтовОборудования.ID);
					ОткрытьФорму("ОбщаяФорма.торо_ФормаОперацийБезНарядов", Новый Структура("ТабОперацийБезНаряда, ДокОснование", ТабОперацийБезНаряда, ВыбранноеЗначение.ДокументОснование), ИсточникВыбора,,ВариантОткрытияОкна.ОтдельноеОкно,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
				КонецЕсли;
			ИначеЕсли  ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда

				МассивДокументов = Новый Массив;

				Для каждого Элемент Из ВыбранноеЗначение Цикл
					Если ТипЗнч(Элемент.ДокументОснование) <> Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") Тогда
						Если МассивДокументов.Найти(Элемент.ДокументОснование) = Неопределено Тогда
							МассивДокументов.Добавить(Элемент.ДокументОснование);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;

				Для каждого Элемент Из МассивДокументов Цикл
					ЗаполнитьТабОперацийБезНаряда(Элемент);
					ОткрытьФорму("ОбщаяФорма.торо_ФормаОперацийБезНарядов", Новый Структура("ТабОперацийБезНаряда, ДокОснование", ТабОперацийБезНаряда, Элемент), ИсточникВыбора,,ВариантОткрытияОкна.ОтдельноеОкно,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
				КонецЦикла;

			КонецЕсли;

		КонецЕсли;
		#Вставка
		ДобавитьУОКатегорииРискаНаСервере();
		ОбновитьЗаливкуЗаголовка();
		МодифицироватьИсполнителей();
		#КонецВставки

	КонецЕсли;

	ЭтоПервыйДокументВЦепочке = ЭтоПервыйДокументВЦепочке();
	ЭтоПоследнийДокументВЦепочке = ЭтоПоследнийДокументВЦепочке();
	РемонтыОборудованияОбновитьДокументыИсточники();
	ЗаполнитьЕдиницыИзмерения(ДеревоРемонтныхРабот);
	ЗаполнитьИспользованиеХарактеристикЗапчастей();

	Для каждого Строка Из Объект.ТрудовыеЗатраты Цикл
		Строка.ВремяРаботыТекст = СформироватьПродолжительность(Строка.ВремяРаботы);
	КонецЦикла;

	Для Каждого Строка Из ДеревоРемонтныхРабот.ПолучитьЭлементы() Цикл
		РазвернутьДеревоРемонтныхРабот(Строка);
	КонецЦикла;

КонецПроцедуры
// гкс- [Подбор ТехКарт]
#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
&ИзменениеИКонтроль("СпособСогласованияНачалоВыбора")
Процедура гкс_СпособСогласованияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	Если СогласующиеРегистр.Количество() > 0 Тогда

		СтандартнаяОбработка = Ложь;

		ПоказатьВопрос(Новый ОписаниеОповещения("СпособСогласованияНачалоВыбораЗавершение", ЭтаФорма, Новый Структура("Элемент",Элемент)),
		НСтр("es='¡Los datos de los estatus establecidos del documento serán limpiados! ¿Continuar?';ru='Данные по установленным статусам документа будут очищены! Продолжить?';en='Data on the established statuses of the document will be cleared! Continue?'"),
		РежимДиалогаВопрос.ДаНет, 60);		

		Возврат;

	КонецЕсли;
	#Вставка
	// гкс+ [Релиз 1] Куст 
	СтандартнаяОбработка = Ложь;
	ДопПараметры = Новый Структура("Отбор", Новый Структура("ПометкаУдаления", Ложь));
	ОткрытьФорму("Справочник.торо_СпособыСогласованияДокументов.ФормаВыбора",ДопПараметры,
	Элемент, , , , , РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	#КонецВставки

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("СпособСогласованияНачалоВыбораЗавершение")
Процедура гкс_СпособСогласованияНачалоВыбораЗавершение(РезультатВопроса, ДополнительныеПараметры)

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		СогласующиеРегистр.Очистить();
		Если мХранитьИсториюСогласованияВДокументах Тогда
			Объект.Согласующие.Очистить();
		КонецЕсли;
		#Вставка
		// гкс+ [Релиз 1] Куст
		ДопПараметры = Новый Структура("Отбор", Новый Структура("ПометкаУдаления", Ложь));
		ОткрытьФорму("Справочник.торо_СпособыСогласованияДокументов.ФормаВыбора",ДопПараметры,
		ДополнительныеПараметры.Элемент, , , , , РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		#КонецВставки
		#Удаление
		ОткрытьФорму("Справочник.торо_СпособыСогласованияДокументов.ФормаВыбора",,ДополнительныеПараметры.Элемент,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		#КонецУдаления
		Возврат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура гкс_СпособВыполненияДеревоПриИзменении(Элемент)
	ТекСтрока = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
	
	ID = ТекСтрока.ID;
	МассивСтрТЧ = Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("ID", ID));
	
	Если МассивСтрТЧ.Количество() Тогда
		СтрТЧ = МассивСтрТЧ[0];
		СтрТЧ.гкс_СпособВыполнения = ТекСтрока.гкс_СпособВыполнения;
	Иначе
		ТекСтрока.гкс_СпособВыполнения = Неопределено;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("СпособСогласованияПриИзменении")
Процедура гкс_СпособСогласованияПриИзменении(Элемент)

	Если фПослеОчистки = Ложь Тогда
		ОбновитьДеревоСогласующих(Истина);
		#Удаление
		торо_РаботаССогласованиямиКлиентСервер.ДобавитьСтрокуВИсториюСтатусов(ЭтаФорма, СтатусДокументаРегистр,, Истина);
		#КонецУдаления
		#Вставка
		торо_РаботаССогласованиямиКлиентСервер.ДобавитьСтрокуВИсториюСтатусов(ЭтаФорма, СтатусДокументаРегистр,,);
		// гкс+ [2021] Куст
		гкс_ИзменитьВидимостьКнопкиОтправкиНаСогласование();
		#КонецВставки
	Иначе
		фПослеОчистки = Ложь;
	КонецЕсли;

	УправлениеВидимостью(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура гкс_ПодразделениеПриИзмененииПосле(Элемент)
	ПодразделениеПриИзменении(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура гкс_ОрганизацияПриИзмененииПосле(Элемент)
	ПодразделениеПриИзменении(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ПодразделениеПриИзменении(Элемент)
	// гкс+ [2021] Куст
	Если ЗначениеЗаполнено(Объект.СпособСогласования) Тогда 
		Возврат;
	КонецЕсли; // гкс- [2021] 
	Если ЭтотОбъект["мИспользоватьСогласованиеДокументов"] И Элементы["СпособСогласования"].ТолькоПросмотр
		И Не СтатусДокументаРегистр = ЭтаФорма["гкс_СтатусЧерновик"] Тогда 
		Возврат;
	КонецЕсли;
	//
	Если Объект.РемонтыОборудования.Количество() > 0 Тогда 
		Способ = гкс_ПолучитьСпособСогласования(Объект.Организация, Объект.РемонтыОборудования[0].ОбъектРемонта);
		Если Не Объект.СпособСогласования = Способ И Не Способ = Неопределено Тогда  
			Объект.СпособСогласования = Способ;
			СпособСогласованияПриИзменении(Неопределено);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовРемонтныхРабот

&НаКлиенте
&После("РемонтыОборудованияПередОкончаниемРедактирования")
Процедура гкс_РемонтыОборудованияПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	ПодразделениеПриИзменении(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура гкс_РемонтныеРаботыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле.Имя = "Деревогкс_ПовКоэф" Тогда 
		ТекДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		Если Не ТекДанные = Неопределено 
		И гкс_ЭтоТО(ТекДанные.РемонтнаяРабота) Тогда 
		ОписаниеОп = Новый ОписаниеОповещения("УстановитьВыбраннымПослеВыбора", ЭтотОбъект);
		ОткрытьФорму("Справочник.гкс_ПКоэффициентыРабот.ФормаВыбора",, ЭтотОбъект,,,, 
				ОписаниеОп, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_РемонтыОборудованияЗавершитьРемонтПриИзмененииПосле(Элемент)
	ДобавитьУОКатегорииРискаНаСервере();
	ОбновитьЗаливкуЗаголовка();
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботОбработкаВыбора")
Процедура гкс_ДеревоРемонтныхРаботОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	ТекСтрокаДерева = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

	Если ТекСтрокаДерева = Неопределено Тогда
		СтрокаРодитель = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID", "", "", "");
		ИДВыбраннойСтроки = "";
	Иначе
		СтрокаРодитель = ТекСтрокаДерева;
		ИДВыбраннойСтроки = ТекСтрокаДерева.ID;
	КонецЕсли;

	ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") И ВыбранноеЗначение.Количество() > 0 И ТипЗнч(ВыбранноеЗначение[0]) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда
		#Вставка
		// гкс+ [Подбор ТехКарт] Куст
		Массивпроверки = Новый Массив();
		Массивпроверки.Добавить(ВыбранноеЗначение[0]);
		Если ПроверитьТКНаСервере(Массивпроверки).Количество() Тогда 
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru='Запрещено выбирать шаблоны техкарт';
			|en='It is forbidden to choose patterns standard maintenance plans'");
			Сообщение.Сообщить();
			СтандартнаяОбработка = Ложь;
			Возврат;
		КонецЕсли;
		#КонецВставки
		ТекущийРемонт = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
		Пока ТекущийРемонт <> Неопределено И ТипЗнч(ТекущийРемонт.РемонтнаяРабота) <> Тип("Строка") Цикл
			Если ТекущийРемонт.РемонтнаяРабота = ВыбранноеЗначение[0] Тогда
				ШаблонСообщения = НСтр("es='El significado escogido ""%1"" no puede ser incluido en la composición.';ru='Выбранное значение ""%1"" не может быть включено в состав самого себя.';en='The selected value ""%1"" cannot be included in itself.'");
				ТекстСообщения = СтрШаблон(ШаблонСообщения, ВыбранноеЗначение[0]);
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				Возврат;
			КонецЕсли; 
			ТекущийРемонт = ТекущийРемонт.ПолучитьРодителя();	
		КонецЦикла; 	
	КонецЕсли; 

	Если ТекРемонт <> Неопределено Тогда
		РемонтыОборудования_ID = ТекРемонт.ID;
		ДатаНачалаРемонта      = ТекРемонт.ДатаНачала;
	Иначе
		РемонтыОборудования_ID = "";
		ДатаНачалаРемонта      = Неопределено;       
	КонецЕсли;

	ТекущиеДанные = Новый Структура("ТекущийРемонт_ID, СтрокаРодитель_ID, СтрокаРодительРемонтыОборудования_ID, СтрокаРодительРодитель_ID, ДатаНачалаРемонта", 
	РемонтыОборудования_ID, СтрокаРодитель.ID, СтрокаРодитель.РемонтыОборудования_ID, СтрокаРодитель.Родитель_ID, ДатаНачалаРемонта);
	СтруктураПараметры = Новый Структура;

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда
		МассивСтруктурВозврата = ДеревоРемонтныхРаботОбработкаВыбораНаСервереДляМассива(ВыбранноеЗначение, ТекущиеДанные, СтруктураПараметры);
		Если ФОИспользоватьОстановочные Тогда
			ОбновитьОстановочные();
		КонецЕсли;
	Иначе
		СтруктураВозврата = ДеревоРемонтныхРаботОбработкаВыбораНаСервере(ВыбранноеЗначение, ТекущиеДанные, СтруктураПараметры);
		МассивСтруктурВозврата = Новый Массив;
		МассивСтруктурВозврата.Добавить(СтруктураВозврата);
		Если ФОИспользоватьОстановочные Тогда
			ОбновитьОстановочные();
		КонецЕсли;
	КонецЕсли;

	Для Каждого СтруктураВозврата Из МассивСтруктурВозврата Цикл
		Если ТипЗнч(СтруктураВозврата) = Тип("Строка") Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(СтруктураВозврата);
		КонецЕсли;
	КонецЦикла;

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		Массивстрок = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ВыбранноеЗначение.СтрокаРемонтовОборудования.ID));
		Если МассивСтрок.Количество() Тогда
			Идентиф = МассивСтрок[0].ПолучитьИдентификатор();
			Элементы.РемонтыОборудования.ТекущаяСтрока = Идентиф;
		КонецЕсли;
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("Массив") И ВыбранноеЗначение.Количество() > 0 И 
		НЕ ТипЗнч(ВыбранноеЗначение[0])= Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") И
		НЕ ТипЗнч(ВыбранноеЗначение[0])= Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
		Массивстрок = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ВыбранноеЗначение[0].СтрокаРемонтовОборудования.ID));
		Если МассивСтрок.Количество() Тогда
			Идентиф = МассивСтрок[0].ПолучитьИдентификатор();
			Элементы.РемонтыОборудования.ТекущаяСтрока = Идентиф;
		КонецЕсли;		
	КонецЕсли;

	ОбновитьЗависимыеЛоты();
	РемонтыОборудованияПриАктивизацииСтроки(Элементы.РемонтыОборудования);

	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		МассивID = Новый Массив;
		Для Каждого СтрокаРР Из ВыбранноеЗначение.МассивСтрокРемонтныхРабот Цикл
			МассивID.Добавить(СтрокаРР.ID);
		КонецЦикла;
		ОтметитьНаличиеАналогов(МассивID);
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда
		ОтметитьНаличиеАналогов();
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
		Для Каждого СтрокаРР Из Объект.РемонтныеРаботы Цикл
			Если СтрокаРР.РемонтнаяРабота = ВыбранноеЗначение Тогда
				ОтметитьНаличиеАналогов(СтрокаРР.ID);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Для каждого Строка Из Объект.ТрудовыеЗатраты Цикл
		Строка.ВремяРаботыТекст = СформироватьПродолжительность(Строка.ВремяРаботы);
	КонецЦикла;

	Для каждого Строка из Объект.МатериальныеЗатраты Цикл
		Строка.ХарактеристикиИспользуются = торо_НоменклатураСервер.ПолучитьХарактеристикиИспользуются(Строка.Номенклатура);
	КонецЦикла;

	Если ЗначениеЗаполнено(ИДВыбраннойСтроки) Тогда
		Идентификатор = Неопределено;
		ОбщегоНазначенияКлиентСервер.ПолучитьИдентификаторСтрокиДереваПоЗначениюПоля("ID", Идентификатор, ДеревоРемонтныхРабот.ПолучитьЭлементы(), ИДВыбраннойСтроки, Ложь);
		Если Идентификатор <> Неопределено Тогда
			Элементы.ДеревоРемонтныхРабот.ТекущаяСтрока = Идентификатор;
		КонецЕсли;
	КонецЕсли;

	Модифицированность = Истина;

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботПередУдалением")
Процедура гкс_ДеревоРемонтныхРаботПередУдалением(Элемент, Отказ)

	ТекСтрокаДРР = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

	мСтруктураТабличныхЧастейСвязанныхСДеревомРемонтныхРабот = Новый Структура();
	мСтруктураТабличныхЧастейСвязанныхСДеревомРемонтныхРабот.Вставить("МатериальныеЗатраты");
	мСтруктураТабличныхЧастейСвязанныхСДеревомРемонтныхРабот.Вставить("СерийныеЗапчасти");
	мСтруктураТабличныхЧастейСвязанныхСДеревомРемонтныхРабот.Вставить("ТрудовыеЗатраты");
	мСтруктураТабличныхЧастейСвязанныхСДеревомРемонтныхРабот.Вставить("РемонтныеРаботы");

	СтруктураСвязанныхТЧ = Новый Структура();
	СтруктураСвязанныхТЧ.Вставить("МатериальныеЗатраты");
	СтруктураСвязанныхТЧ.Вставить("СерийныеЗапчасти");
	СтруктураСвязанныхТЧ.Вставить("ТрудовыеЗатраты");
	СтруктураСвязанныхТЧ.Вставить("РемонтныеРаботы");

	#Удаление
	Если НЕ ЗначениеЗаполнено(ТекСтрокаДРР.Родитель_ID) И ТекСтрокаДРР.РемонтнаяРабота = "Ремонтные работы" Тогда
	#КонецУдаления
	#Вставка
	Если НЕ ЗначениеЗаполнено(ТекСтрокаДРР.Родитель_ID) И ТекСтрокаДРР.РемонтнаяРабота = дс_ПолучитьПредставлениеКорневойРемонтнойРаботы() Тогда
	#КонецВставки

		ТекСтрокаДРР.ПолучитьЭлементы().Очистить();

		Для Каждого КлючИЗначение Из СтруктураСвязанныхТЧ Цикл

			ТабличнаяЧасть = Объект[КлючИЗначение.Ключ];

			ПараметрыПоиска = Новый Структура;
			ПараметрыПоиска.Вставить("РемонтыОборудования_ID", Элементы.РемонтыОборудования.ТекущиеДанные.ID);

			СтрокиКУдалению = ТабличнаяЧасть.НайтиСтроки(ПараметрыПоиска);

			Для Каждого Строка Из СтрокиКУдалению Цикл

				ТабличнаяЧасть.Удалить(Строка);

			КонецЦикла;		    

		КонецЦикла;

		Модифицированность = Истина;

		Отказ = Истина;

	Иначе

		ВыделенныеСтроки = Элементы.ДеревоРемонтныхРабот.ВыделенныеСтроки;
		МассивСтрокДляУдаления = Новый Массив;

		Для каждого Стр Из ВыделенныеСтроки Цикл 
			Строка = ДеревоРемонтныхРабот.НайтиПоИдентификатору(Стр);
			#Удаление
			Если Строка <> Неопределено И Строка.РемонтнаяРабота <> "Ремонтные работы" Тогда 
			#КонецУдаления
			#Вставка
			Если Строка <> Неопределено И Строка.РемонтнаяРабота <> дс_ПолучитьПредставлениеКорневойРемонтнойРаботы() Тогда 
			#КонецВставки
				МассивСтрокДляУдаления.Добавить(Строка);
			КонецЕсли;
		КонецЦикла;		

		Для каждого Элемент Из МассивСтрокДляУдаления Цикл

			СтруктурыДляПередачи = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID, РемонтнаяРабота",
			Элемент.ID, Элемент.РемонтыОборудования_ID, Элемент.Родитель_ID, Элемент.РемонтнаяРабота);
			УдалитьДанныеТЧПоIDСтрокиДереваНаСервере(СтруктурыДляПередачи, СтруктураСвязанныхТЧ);

			СтрокаРодителя = Элемент.ПолучитьРодителя();
			Если СтрокаРодителя <> Неопределено Тогда 
				СтрокаРодителя.ПолучитьЭлементы().Удалить(Элемент); 
			КонецЕсли;
		КонецЦикла;


		Модифицированность = Истина;
		Отказ = Истина;  

	КонецЕсли;

	ПересчитатьПроцентыВыполненияВДеревеНаСервере();
	РазвернутьДеревоРемонтныхРабот(ДеревоРемонтныхРабот.ПолучитьЭлементы()[0]);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовИсполнителейРемонтныхРабот

&НаКлиенте
Процедура гкс_ИсполнителиПоРемонтамПередНачаломИзмененияПосле1(Элемент, Отказ)
	Если Объект.ИсполнителиПоРемонтам.Количество() Тогда 
		ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;
		Если Не ТекРемонт = Неопределено Тогда 
			Для Каждого СТ Из Объект.ИсполнителиПоРемонтам Цикл
				Если СТ.РемонтыОборудования_ID = ТекРемонт.ID Тогда 
					ЭтотОбъект["гкс_ИсполнительДо"] = СТ.Исполнитель;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_ИсполнителиПоРемонтамПередУдалениемПеред1(Элемент, Отказ)
	ТекДанные = Элементы.ИсполнителиПоРемонтам.ТекущиеДанные;
	ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;
	Если ТекРемонт = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	ПервыйИсполнитель = Неопределено;
	ПерваяСтрокаТЧ = Неопределено;
	ВторойИсполнитель = Неопределено;
	Для Каждого СтрокаТаблицы Из Объект.ИсполнителиПоРемонтам Цикл
		Если СтрокаТаблицы.РемонтыОборудования_ID = ТекРемонт.ID Тогда 
			Если ПервыйИсполнитель = Неопределено Тогда 
				ПервыйИсполнитель = СтрокаТаблицы.Исполнитель;
				ПерваяСтрокаТЧ = СтрокаТаблицы;
			Иначе
				ВторойИсполнитель = СтрокаТаблицы.Исполнитель;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если Не ТекДанные = Неопределено И ТекДанные.Исполнитель = ПервыйИсполнитель Тогда 
		
		ТекТип = ТипЗнч(ПервыйИсполнитель);
		Если не ВторойИсполнитель = Неопределено Тогда 
			Если ТекТип = ТипЗнч(ВторойИсполнитель) Тогда 
				Возврат;
			КонецЕсли;
		ИначеЕсли ТекТип = Тип("СправочникСсылка.СтруктураПредприятия") Тогда 
			Возврат
		КонецЕсли;
		Если ТекТип = Тип("СправочникСсылка.СтруктураПредприятия") Тогда 
			Отказ = Истина;
			СтруктураОпОп = Новый Структура("Удаление", Истина);
			ЗадатьВопросПередИзменениемИсполнителя(СтруктураОпОп);
		Иначе
			ИсполнителиПоРемонтамПередУдалением(Элементы.ИсполнителиПоРемонтам, Отказ);
			Если НЕ Отказ Тогда 
				Объект.ИсполнителиПоРемонтам.Удалить(ПерваяСтрокаТЧ);
			КонецЕсли;
			МодифицироватьИсполнителей(ТекРемонт.ID);
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура гкс_УстановитьПКоэф(Команда)
	ТекДанные = Элементы.РемонтыОборудования.ТекущиеДанные;
	Если не ТекДанные = Неопределено Тогда 
		МассивПередачи = Новый Массив();
		Для Каждого СтрокаТаблицы Из Объект.РемонтныеРаботы Цикл
			Если ТекДанные.ID = СтрокаТаблицы.РемонтыОборудования_ID Тогда 
				МассивПередачи.Добавить(Новый Структура("ИД,гкс_ПовКоэф,РемонтнаяРабота"
					, СтрокаТаблицы.ID, СтрокаТаблицы.гкс_ПовКоэф, СтрокаТаблицы.РемонтнаяРабота));
			КонецЕсли;
		КонецЦикла;
		ОписаниеОп = Новый ОписаниеОповещения("гкс_УстановитьПКоэфОбработкаВыбора",
			ЭтотОбъект, Новый Структура("ИдРемонта", ТекДанные.ID) );
			ОткрытьФорму("Справочник.гкс_ПКоэффициентыРабот.Форма.ПодборПКоэфВСписок", Новый Структура("Строки", МассивПередачи), ЭтотОбъект,,,, 
				ОписаниеОп, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура дс_ОтправитьНаСогласование(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Параметры1 = Новый Структура("дс_Выполнить", Истина);
		Параметры2 = Новый Структура();
		
		гкс_ОбщегоНазначенияСервер.ОтправитьНаСогласованиеНаСервере(Параметры1, Параметры2);
		Если Параметры1.дс_Выполнить Тогда 
			Параметры2.Вставить("Форма", ЭтаФорма);
			торо_РаботаССогласованиямиКлиент.ВыбратьСтатусЗавершение(Параметры1, Параметры2);
			гкс_ИзменитьВидимостьКнопкиОтправкиНаСогласование();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДобавитьТехКарту")
Процедура гкс_ДобавитьТехКарту(Команда)

	ТекущиеДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("es='¡Indiquen la disposición de la reparación!';ru='Укажите расположение ремонта!';en='Specify  the location of the repair!'"), 10); 
		Возврат;
	КонецЕсли;

	Если ТипЗнч(ТекущиеДанные.РемонтнаяРабота) = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("es='¡La reparación no es posible incluir en la composición de la operación tecnológica!';ru='Ремонт нельзя включать в состав технологической операции!';en='Repair can not be included in the technological operation!'"), 10); 
