	               |	Ссылка,
	               |	НомерСтроки";
	Запрос.УстановитьПараметр("ТЧ1", Объект.ДокументыОснования.Выгрузить());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Если Не РезультатЗапроса[1].Пустой() Тогда 
		НомерРемонта = 0;
		Выборка = РезультатЗапроса[1].Выбрать();
		Пока Выборка.Следующий() Цикл
			НомерПП = 0;
			РемНайден = Ложь;
			Для Каждого СтрРем Из Объект.РемонтыОборудования Цикл
				Если СтрРем.ID = Выборка.ID Тогда 
					РемНайден = Истина;
					Прервать;
				КонецЕсли;
				НомерПП = НомерПП + 1;
			КонецЦикла;
			Если РемНайден Тогда 
				Если НомерРемонта < НомерПП Тогда 
					Объект.ДокументыОснования.Сдвинуть(НомерРемонта, НомерПП - НомерРемонта);
				ИначеЕсли НомерРемонта > НомерПП Тогда 
					Объект.ДокументыОснования.Сдвинуть(НомерРемонта, НомерРемонта - НомерПП);
				КонецЕсли;
				НомерРемонта = НомерРемонта + 1;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли Не РезультатЗапроса[2].Пустой() Тогда 
		НомерРемонта = 0;
		Выборка = РезультатЗапроса[2].Выбрать();
		Пока Выборка.Следующий() Цикл
