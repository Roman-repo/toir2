&ИзменениеИКонтроль("ЗаполнитьДеревоРемонтныхРаботНаСервере")
Процедура гкс_ЗаполнитьДеревоРемонтныхРаботНаСервере(РемонтыОборудования_ID)

	ДеревоСФормы = РеквизитФормыВЗначение("ДеревоРемонтныхРабот");

	ДеревоСФормы.Строки.Очистить();

	КорневаяСтрока = ДеревоСФормы.Строки.Добавить();
	#Удаление
	КорневаяСтрока.РемонтнаяРабота = "Ремонтные работы";	
	#КонецУдаления
	#Вставка
	КорневаяСтрока.РемонтнаяРабота = дс_ПолучитьПредставлениеКорневойРемонтнойРаботы();	
	#КонецВставки
	
	КорневаяСтрока.Картинка = 4;
	
	Если Не РемонтыОборудования_ID = Неопределено Тогда	
		ТЗРемонтныеРаботы = Объект.РемонтныеРаботы.Выгрузить(Объект.РемонтныеРаботы.НайтиСтроки(Новый Структура("РемонтыОборудования_ID", РемонтыОборудования_ID)));
	Иначе 
		#Удаление
		ТЗРемонтныеРаботы = Неопределено;	
		#КонецУдаления
		#Вставка
		ТЗРемонтныеРаботы = Объект.РемонтныеРаботы.Выгрузить();
		ТЗРемонтныеРаботы.Индексы.Добавить("Родитель_ID");
		#КонецВставки
	КонецЕсли; 

	СоздатьВетвьДереваПоТЧ(КорневаяСтрока, ТЗРемонтныеРаботы);

	СтруктураРодСтроки = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID", "", "", "");
	//торо_Ремонты.РасставитьПроцентыРодительскихСтрок(ДеревоСФормы, СтруктураРодСтроки);
	торо_ПроцентыВыполнения.ОбновитьПроцентыВыполненияВДереве(ДеревоСФормы);

	ЗначениеВРеквизитФормы(ДеревоСФормы, "ДеревоРемонтныхРабот");

КонецПроцедуры 

&НаКлиентеНаСервереБезКонтекста
&ИзменениеИКонтроль("СформироватьПродолжительность")
Функция гкс_СформироватьПродолжительность(ПродолжительностьВСекундах)

	Если ПродолжительностьВСекундах = 0 Тогда

		Возврат "Ввести продолжительность";

	Иначе

		Часы    = Цел(ПродолжительностьВСекундах / 3600);
		Минуты  = Цел((ПродолжительностьВСекундах - 3600 * Часы) / 60);
		Секунды = ПродолжительностьВСекундах - 3600 * Часы - Минуты * 60;

		#Удаление
		Возврат "" + Часы + " ч. " + Минуты + " мин. " + Секунды + " с.";
		#КонецУдаления
		#Вставка
		ПродолжительностьСтрокой = СтрШаблон(НСтр("es='%1 h. %2 min. %3 sec.';
			|ru='%1 ч. %2 мин. %3 с.';en='%1 hr.%2 min. %3 s'"), Часы, Минуты, Секунды);
		Возврат ПродолжительностьСтрокой;
		#КонецВставки

	КонецЕсли;

КонецФункции

&НаСервере
Функция гкс_ПолучитьСпособСогласования(Орг, ОР)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОбъектыРемонта.Подразделение КАК Подразделение
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ОР);
	РезультатЗапроса = Запрос.Выполнить();
	// гкс+ [2021] Куст
	Если РезультатЗапроса.Пустой() 
		ИЛИ торо_РаботаССогласованиями.гкс_ПоДокументуЕстьИстория(Объект.Ссылка) Тогда // гкс- [2021] Куст
		Возврат Неопределено;
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	ПодрИсп = Справочники.СтруктураПредприятия.ПустаяСсылка();
	Если Объект.ИсполнителиПоРемонтам.Количество() 
		И ТипЗнч(Объект.ИсполнителиПоРемонтам[0].Исполнитель) = Тип("СправочникСсылка.СтруктураПредприятия") Тогда 
		ПодрИсп = Объект.ИсполнителиПоРемонтам[0].Исполнитель;
	КонецЕсли;
	Возврат торо_РаботаССогласованиями.гкс_ПолучитьСпособСогласованияПоУмолчанию(
		Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_АктОВыполненииЭтапаРабот,
		Орг, Выборка.Подразделение, ПодрИсп);
КонецФункции

&НаКлиенте
Процедура гкс_ИсполнителиПоРемонтамИсполнительПриИзмененииПосле(Элемент)
	ПодразделениеПриИзменении(Неопределено);
	ТекДанные = Элементы.ИсполнителиПоРемонтам.ТекущиеДанные;
	ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;
	ПервыйИсполнитель = Неопределено;
	Для Каждого СтрокаТаблицы Из Объект.ИсполнителиПоРемонтам Цикл
		Если СтрокаТаблицы.РемонтыОборудования_ID = ТекРемонт.ID Тогда 
			ПервыйИсполнитель = СтрокаТаблицы.Исполнитель;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если Не ТекДанные = Неопределено И ЗначениеЗаполнено(ТекДанные.Исполнитель) И ТекДанные.Исполнитель = ПервыйИсполнитель Тогда 
		ТекТип = ТипЗнч(ПервыйИсполнитель);
		Если ТекТип = ТипЗнч(ЭтотОбъект["гкс_ИсполнительДо"]) Тогда 
			Возврат;
		КонецЕсли;
		Если ТекТип = Тип("СправочникСсылка.Контрагенты") Тогда 
			СтруктураОпОп = Новый Структура();
			ЗадатьВопросПередИзменениемИсполнителя(СтруктураОпОп);
		Иначе
			МодифицироватьИсполнителей(ТекРемонт.ID);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
