					Прервать;
				КонецЕсли;
				НомерПП = НомерПП + 1;
			КонецЦикла;
			Если РемНайден Тогда 
				Если НомерРемонта < НомерПП Тогда 
					Объект.РемонтыОборудования.Сдвинуть(НомерПП, НомерРемонта - НомерПП);
				ИначеЕсли НомерРемонта > НомерПП Тогда 
					Объект.РемонтыОборудования.Сдвинуть(НомерПП, НомерПП - НомерРемонта);
				КонецЕсли;
				НомерРемонта = НомерРемонта + 1;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли
