Процедура гкс_ЗаполнитьДеревоРемонтныхРаботЗапросомНаСервере()
	
	// Гкс+[TOIR20-725] Литвин В.В. от 09.10.2025 Добавлено:{
	Перем НоваяСтрокаТехКарта;
	// Гкс-[TOIR20-725] Литвин В.В. от 09.10.2025}
	
    // Гкс+[TOIR20-609] Вялых Д.А. от 24.07.2025. Добавлено:{
	ДеревоСФормы = РеквизитФормыВЗначение("ДеревоРемонтныхРабот");

	ДеревоСФормы.Строки.Очистить();

	КорневаяСтрока = ДеревоСФормы.Строки.Добавить();
	КорневаяСтрока.РемонтнаяРабота = дс_ПолучитьПредставлениеКорневойРемонтнойРаботы();	
	
	КорневаяСтрока.Картинка = 4;
	// Гкс+[TOIR20-725] Литвин В.В. от 09.10.2025 Добавлено:{
	СтрокиКорневойСтроки = КорневаяСтрока.Строки;
	// Гкс-[TOIR20-725] Литвин В.В. от 09.10.2025}
	
	ЗапросДанныхДляДерева = Новый Запрос;
	ЗапросДанныхДляДерева.Текст = ТекстЗапросаДанныхДляДерева();
	ЗапросДанныхДляДерева.УстановитьПараметр("Ссылка", Объект.Ссылка); 
	
	РезультатДанныеДляДерева = ЗапросДанныхДляДерева.Выполнить();
	
	ДанныеДляДерева = РезультатДанныеДляДерева.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	Пока ДанныеДляДерева.Следующий() Цикл
		
		Строка = ДанныеДляДерева.Выбрать();
		
		Пока Строка.Следующий() Цикл
			
			Если Строка.ЭтоТехКарта Тогда
				НоваяСтрокаТехКарта = СтрокиКорневойСтроки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТехКарта, Строка);
			Иначе
				// Гкс+[TOIR20-725] Литвин В.В. от 09.10.2025 Изменено:{
				//Было:
				//НоваяСтрока = НоваяСтрокаТехКарта.Строки.Добавить();
				//Стало:
				Если НоваяСтрокаТехКарта = Неопределено Тогда
					НоваяСтрока = СтрокиКорневойСтроки.Добавить();
				Иначе
					НоваяСтрока = НоваяСтрокаТехКарта.Строки.Добавить();
				КонецЕсли;
				// Гкс-[TOIR20-725] Литвин В.В. от 09.10.2025}
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;

	СтруктураРодСтроки = Новый Структура("ID, РемонтыОборудования_ID, Родитель_ID", "", "", "");
	//торо_Ремонты.РасставитьПроцентыРодительскихСтрок(ДеревоСФормы, СтруктураРодСтроки);
	торо_ПроцентыВыполнения.ОбновитьПроцентыВыполненияВДереве(ДеревоСФормы);

	ЗначениеВРеквизитФормы(ДеревоСФормы, "ДеревоРемонтныхРабот");
    // } Гкс-[TOIR20-609] Вялых Д.А. от 24.07.2025.
