&НаСервере
Процедура ОбновитьОтображениеИсполнителей(ТекИД = Неопределено)
	Отображать = Истина;
	Если не ТекИД = Неопределено Тогда 
		ПервыйИсполнитель = Неопределено;
		Для Каждого СтрокаТаблицы Из Объект.ИсполнителиПоРемонтам Цикл
			Если СтрокаТаблицы.РемонтыОборудования_ID = ТекИД Тогда 
				ПервыйИсполнитель = СтрокаТаблицы.Исполнитель;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если Не ПервыйИсполнитель = Неопределено И ТипЗнч(ПервыйИсполнитель) = Тип("СправочникСсылка.Контрагенты") Тогда 
			Отображать = Ложь;
		КонецЕсли;
	Иначе
		Если Объект.ИсполнителиПоРемонтам.Количество() Тогда 
			Если ТипЗнч(Объект.ИсполнителиПоРемонтам[0].Исполнитель) = Тип("СправочникСсылка.Контрагенты") Тогда 
				Отображать = Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Элементы.ТрудовыеЗатратыСотрудник.Видимость = Отображать;
	Элементы["Исполнителигкс_Количество"].Видимость = Не Отображать;
	// гкс+ [Релиз16] Деснол
	Если Отображать Тогда 
		Элементы["гкс_СотрудникКонтрагента"].Видимость = Ложь;
	Иначе
		ИзНаряда = Ложь;
		Для Каждого СтрокаТаблицы Из Объект.ДокументыОснования Цикл
			Если ТипЗнч(СтрокаТаблицы.ДокументОснование) = Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") Тогда 
				ИзНаряда = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Элементы["гкс_СотрудникКонтрагента"].Видимость = ИзНаряда;
	КонецЕсли;
	// гкс- [Релиз16]
	
КонецПроцедуры

&НаСервере
Процедура МодифицироватьИсполнителей(ТекИД = Неопределено)
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТруТЧ.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	ТруТЧ.ID КАК ID,
		|	ТруТЧ.КТУ КАК КТУ,
		|	ТруТЧ.Сотрудник КАК Сотрудник,
		|	ТруТЧ.СуммаКНачислению КАК СуммаКНачислению,
		|	ТруТЧ.Квалификация КАК Квалификация,
		|	ВЫБОР
		|		КОГДА ТруТЧ.гкс_Количество < 1
		|			ТОГДА 1
		|		ИНАЧЕ ТруТЧ.гкс_Количество
		|	КОНЕЦ КАК гкс_Количество,
		|	ТруТЧ.гкс_СотрудникКонтрагента КАК гкс_СотрудникКонтрагента,
		|	ТруТЧ.ВремяРаботы КАК ВремяРаботы,
		|	ТруТЧ.ДатаНачала КАК ДатаНачала,
		|	ТруТЧ.ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ ИсхТру
		|ИЗ
		|	&ТЧ1 КАК ТруТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РемТЧ.ДатаНачала КАК ДатаНачала,
		|	РемТЧ.ДатаОкончания КАК ДатаОкончания,
		|	РемТЧ.ID КАК ID
		|ПОМЕСТИТЬ ИсхРем
		|ИЗ
		|	&ТЧ2 КАК РемТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсхТру.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	ИсхТру.ID КАК ID,
		|	ИсхТру.КТУ КАК КТУ,
		|	ИсхТру.Сотрудник КАК Сотрудник,
		|	ИсхТру.СуммаКНачислению КАК СуммаКНачислению,
		|	ИсхТру.Квалификация КАК Квалификация,
		|	ИсхТру.гкс_Количество КАК гкс_Количество,
		|	ИсхТру.гкс_СотрудникКонтрагента КАК гкс_СотрудникКонтрагента,
		|	ИсхТру.ВремяРаботы КАК ВремяРаботы,
		|	ИсхРем.ДатаНачала КАК ДатаНачала,
		|	ИсхРем.ДатаОкончания КАК ДатаОкончания,
		|	ИсхТру.ДатаНачала КАК ДатаНачала1,
		|	ИсхТру.ДатаОкончания КАК ДатаОкончания1
		|ИЗ
		|	ИсхТру КАК ИсхТру
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсхРем КАК ИсхРем
		|		ПО ИсхТру.РемонтыОборудования_ID = ИсхРем.ID
		|ИТОГИ ПО
		|	РемонтыОборудования_ID
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсхТру.РемонтыОборудования_ID КАК РемонтыОборудования_ID,
		|	ИсхТру.ID КАК ID,
		|	МАКСИМУМ(ИсхТру.КТУ) КАК КТУ,
		|	ИсхТру.Квалификация КАК Квалификация,
		|	СУММА(ИсхТру.гкс_Количество) КАК гкс_Количество,
		|	МАКСИМУМ(ИсхТру.ВремяРаботы) КАК ВремяРаботы,
		|	ИсхТру.гкс_СотрудникКонтрагента КАК гкс_СотрудникКонтрагента,
		|	ИсхРем.ДатаНачала КАК ДатаНачала,
		|	ИсхРем.ДатаОкончания КАК ДатаОкончания,
		|	ИсхТру.ДатаНачала КАК ДатаНачала1,
		|	ИсхТру.ДатаОкончания КАК ДатаОкончания1
		|ИЗ
		|	ИсхТру КАК ИсхТру
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсхРем КАК ИсхРем
		|		ПО ИсхТру.РемонтыОборудования_ID = ИсхРем.ID
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсхТру.РемонтыОборудования_ID,
		|	ИсхТру.ID,
		|	ИсхТру.Квалификация,
		|	ИсхТру.гкс_СотрудникКонтрагента,
		|	ИсхРем.ДатаНачала,
		|	ИсхРем.ДатаОкончания,
		|	ИсхТру.ДатаНачала,
		|	ИсхТру.ДатаОкончания
		|ИТОГИ ПО
		|	РемонтыОборудования_ID";
	
	Запрос.УстановитьПараметр("ТЧ1", Объект.ТрудовыеЗатраты.Выгрузить());
	Запрос.УстановитьПараметр("ТЧ2", Объект.РемонтыОборудования.Выгрузить());
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();		
	Выборка1 = РезультатЗапроса[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Выборка2 = РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Объект.ТрудовыеЗатраты.Очистить();
	Для Каждого СТ Из Объект.РемонтыОборудования Цикл
		ТипИсполнителей = 1;
		Для Каждого СтрИсп Из Объект.ИсполнителиПоРемонтам Цикл
			Если СтрИсп.РемонтыОборудования_ID = СТ.ID Тогда
				Если ТипЗнч(СтрИсп.Исполнитель) = Тип("СправочникСсылка.Контрагенты") Тогда 
					ТипИсполнителей = 2;
				КонецЕсли;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ТипИсполнителей = 1 Тогда 
			Выборка1.Сбросить();
			Если Выборка1.НайтиСледующий(Новый Структура("РемонтыОборудования_ID",СТ.ID)) Тогда 
				Выборка = Выборка1.Выбрать();
				Пока Выборка.Следующий() Цикл
					НужноКолво = Макс(1, Выборка.гкс_Количество);
					Сч = 0;
					Пока Сч < НужноКолво Цикл
						НоваяСтрока = Объект.ТрудовыеЗатраты.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
						Если ЗначениеЗаполнено(Выборка.ДатаНачала1) Тогда 
							НоваяСтрока.ДатаНачала = Выборка.ДатаНачала1;
							НоваяСтрока.ДатаОкончания = Выборка.ДатаОкончания1;
						КонецЕсли;
						НоваяСтрока.гкс_Количество = 1;
						НоваяСтрока.ВремяРаботыТекст = СформироватьПродолжительность(НоваяСтрока.ВремяРаботы);
						Сч = Сч + 1;
					КонецЦикла;
				КонецЦикла;
			КонецЕсли;
		Иначе
			Если Выборка2.НайтиСледующий(Новый Структура("РемонтыОборудования_ID",СТ.ID)) Тогда 
				Выборка = Выборка2.Выбрать();
				Пока Выборка.Следующий() Цикл
					НоваяСтрока = Объект.ТрудовыеЗатраты.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
					Если ЗначениеЗаполнено(Выборка.ДатаНачала1) Тогда 
						НоваяСтрока.ДатаНачала = Выборка.ДатаНачала1;
						НоваяСтрока.ДатаОкончания = Выборка.ДатаОкончания1;
					КонецЕсли;
					НоваяСтрока.ВремяРаботыТекст = СформироватьПродолжительность(НоваяСтрока.ВремяРаботы);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	//
	ОбновитьОтображениеИсполнителей(ТекИД);
КонецПроцедуры

&НаКлиенте 
Процедура ЗадатьВопросПередИзменениемИсполнителя(СтруктураОпОп)
	ОпОп = Новый ОписаниеОповещения("ЗадатьВопросПередИзменениемИсполнителяПослеВопроса", ЭтотОбъект, СтруктураОпОп);
	ПоказатьВопрос(ОпОп, НСтр("ru='Данные о сотрудниках на закладке «По операциям» будут удалены. Продолжить?';
	|en='Employee data on the By operations tab will be deleted. Proceed?'"), РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

&НаКлиенте 
Процедура ЗадатьВопросПередИзменениемИсполнителяПослеВопроса(Результат, ДопПараметры)Экспорт
	ТекРемонт = Элементы.РемонтыОборудования.ТекущиеДанные;
	Если ТекРемонт = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	ПервыйИсполнитель = Неопределено;
	ПерваяСтрокаТЧ = Неопределено;
	ВторойИсполнитель = Неопределено;
	Для Каждого СтрокаТаблицы Из Объект.ИсполнителиПоРемонтам Цикл
		Если СтрокаТаблицы.РемонтыОборудования_ID = ТекРемонт.ID Тогда 
			ПервыйИсполнитель = СтрокаТаблицы.Исполнитель;
			ПерваяСтрокаТЧ = СтрокаТаблицы;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если Результат = КодВозвратаДиалога.Да Тогда 
		Если ДопПараметры.Свойство("Удаление") Тогда 
			Отказ = ложь;
			ИсполнителиПоРемонтамПередУдалением(Элементы.ИсполнителиПоРемонтам, Отказ);
			Если НЕ Отказ Тогда 
				Объект.ИсполнителиПоРемонтам.Удалить(ПерваяСтрокаТЧ);
			КонецЕсли;
		КонецЕсли;
		МодифицироватьИсполнителей(ТекРемонт.ID);
	Иначе
		Если ДопПараметры.Свойство("Удаление") = Ложь Тогда 
			ПерваяСтрокаТЧ.Исполнитель = ЭтотОбъект["гкс_ИсполнительДо"];
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

