&НаКлиенте
Процедура гкс_ПроецироватьПослеВопроса(Результат, ДопПараметры) Экспорт
	Если Не Результат = Неопределено Тогда 
		Если Результат = "ВР" Тогда 
			СтрокаИсточник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ДопПараметры.Источник))[0];
			Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
				СтрокаПриемник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДРемонта))[0];
				СтрокаПриемник.ВидРемонтныхРабот = СтрокаИсточник.ВидРемонтныхРабот;
			КонецЦикла;
		ИначеЕсли Результат = "Даты" Тогда 
			СтрокаИсточник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ДопПараметры.Источник))[0];
			Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
				СтрокаПриемник = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", ИДРемонта))[0];
				СтрокаПриемник.ДатаНачала = СтрокаИсточник.ДатаНачала;
				СтрокаПриемник.ДатаОкончания = СтрокаИсточник.ДатаОкончания;
			КонецЦикла;
		ИначеЕсли Результат = "Операции" Тогда 
			МассивТЧ = Новый Массив();
			МассивТЧ.Добавить("РемонтныеРаботы");
			МассивТЧ.Добавить("МатериальныеЗатраты");
			МассивТЧ.Добавить("ТрудовыеЗатраты");
			МассивТЧ.Добавить("СерийныеЗапчасти");
			МассивТЧ.Добавить("ЗакрываемыеПредписания");
			Для Каждого ИмяТЧ Из МассивТЧ Цикл
				Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
					СтрокиРемонта = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИДРемонта));
					Для Каждого СтрокаТаблицы Из СтрокиРемонта Цикл
						Объект[ИмяТЧ].Удалить(Объект[ИмяТЧ].Индекс(СтрокаТаблицы));
					КонецЦикла;
				КонецЦикла;
				СтрокиИсточника = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ДопПараметры.Источник));
				Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
					Для Каждого СтрокаИсточника Из СтрокиИсточника Цикл
						НоваяСтрока = Объект[ИмяТЧ].Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
						НоваяСтрока.РемонтыОборудования_ID = ИДРемонта;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла; 
		ИначеЕсли Результат = "Исполнители" Тогда 
			МассивТЧ = Новый Массив();
			МассивТЧ.Добавить("ИсполнителиПоРемонтам");
			Для Каждого ИмяТЧ Из МассивТЧ Цикл
				Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
					СтрокиРемонта = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ИДРемонта));
					Для Каждого СтрокаТаблицы Из СтрокиРемонта Цикл
						Объект[ИмяТЧ].Удалить(Объект[ИмяТЧ].Индекс(СтрокаТаблицы));
					КонецЦикла;
				КонецЦикла;
				СтрокиИсточника = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("РемонтыОборудования_ID", ДопПараметры.Источник));
				Для Каждого ИДРемонта Из ДопПараметры.МассивИД Цикл
					Для Каждого СтрокаИсточника Из СтрокиИсточника Цикл
						НоваяСтрока = Объект[ИмяТЧ].Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
						НоваяСтрока.РемонтыОборудования_ID = ИДРемонта;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры // гкс- [12.22] Деснол 13.12.2022

// гкс+ [Подбор ТехКарт] Куст 
&НаСервереБезКонтекста
Функция ПроверитьТКНаСервере(МассивТК)
	МассивВозврата = Новый Массив();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Проверяемые.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ИдентификаторыТехКарт КАК Проверяемые
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК торо_ИдентификаторыТехКарт
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК Родитель1
		|			ПО торо_ИдентификаторыТехКарт.Родитель = Родитель1.Ссылка
		|		ПО Проверяемые.Родитель = торо_ИдентификаторыТехКарт.Ссылка
		|ГДЕ
		|	Проверяемые.Ссылка В(&Родитель)
		|	И Родитель1.Родитель = ЗНАЧЕНИЕ(Справочник.торо_ИдентификаторыТехКарт.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Родитель", МассивТК);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			МассивВозврата.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЕсли;
	
	Возврат МассивВозврата;
КонецФункции

