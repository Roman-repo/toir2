&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтныхРаботИсполнительПриИзменении")
Процедура гкс_ДеревоРемонтныхРаботИсполнительПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ДеревоРемонтныхРабот.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		ТекущиеДанные.ДоговорБригада = Неопределено;
		УстановитьПараметрыВыбораДоговораБригады_ДляРемонтныхРабот(ТекущиеДанные.Исполнитель, ТекущиеДанные.РемонтыОборудования_ID);
		#Вставка
		Если ЗначениеЗаполнено(ТекущиеДанные.Исполнитель) Тогда 
			Ветвь = ТекущиеДанные.ПолучитьЭлементы();
			Для Каждого СтрокаДерева Из Ветвь Цикл
				СтрокаДерева.Исполнитель = ТекущиеДанные.Исполнитель;
				Ветвь2 = СтрокаДерева.ПолучитьЭлементы();
				Для Каждого СтрокаДерева2 Из Ветвь2 Цикл
					СтрокаДерева2.Исполнитель = ТекущиеДанные.Исполнитель;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
		#КонецВставки
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("УстановитьПараметрыВыбораИсполнителя_ДляРемонтныхРабот")
Процедура гкс_УстановитьПараметрыВыбораИсполнителя_ДляРемонтныхРабот(РемонтыОборудования_ID)

	СтруктураПоиска = Новый Структура("РемонтыОборудования_ID", РемонтыОборудования_ID);
	#Вставка
	// гкс+ [Релиз16] Деснол
	Если ЗначениеЗаполнено(РемонтыОборудования_ID) = Ложь Тогда 
		ТекДанные = Элементы.РемонтыОборудования.ТекущиеДанные;
		Если Не ТекДанные = Неопределено Тогда 
			СтруктураПоиска = Новый Структура("РемонтыОборудования_ID", ТекДанные.ID);
		КонецЕсли;
	КонецЕсли;
	// гкс- [Релиз16]
	#КонецВставки
	СтрокиИсполнителей = Объект.ИсполнителиПоРемонтам.НайтиСтроки(СтруктураПоиска);

	ОтборПоСсылке = Новый Массив;
	Для каждого Строка из СтрокиИсполнителей Цикл
		ОтборПоСсылке.Добавить(Строка.Исполнитель);
	КонецЦикла;

	ПараметрыВыбораМассив = Новый Массив;
	ПараметрыВыбораМассив.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(ОтборПоСсылке)));
	ПараметрыВыбораМассив.Добавить(Новый ПараметрВыбора("РежимОтображенияСписка", "Список"));
	Элементы.ДеревоРемонтныхРаботИсполнитель.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбораМассив);

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("УстановитьДоступностьДляРедактированияПоТекРемонту")
Процедура гкс_УстановитьДоступностьДляРедактированияПоТекРемонту(БлокироватьДляИзменения, ОбъектРемонта)

	ПризнакВестиУчетСерийныхЗапчастей = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектРемонта, "ВестиУчетСерийныхЗапчастей");

	Элементы.ДеревоРемонтныхРабот.ТолькоПросмотр			= БлокироватьДляИзменения Или Не ПравоРедактирование ИЛИ ЭтаФорма["СогласованиеТолькоПросмотр"];
	Элементы.МатериальныеЗатраты.ТолькоПросмотр				= БлокироватьДляИзменения Или Не ПравоРедактирование ИЛИ ЭтаФорма["СогласованиеТолькоПросмотр"];
	Элементы.ДокументыВнутреннееПотребление.ТолькоПросмотр	= БлокироватьДляИзменения Или Не ПравоРедактирование;
	Элементы.ТрудовыеЗатраты.ТолькоПросмотр					= БлокироватьДляИзменения Или Не ПравоРедактирование ИЛИ ЭтаФорма["СогласованиеТолькоПросмотр"];
	#Вставка
	НеРедактированиеИсполнителей = БлокироватьДляИзменения Или Не ПравоРедактирование ИЛИ ЭтаФорма["СогласованиеТолькоПросмотр"];
	Если НеРедактированиеИсполнителей Тогда
		//Если гкс_ПроверитьРольНаСервере("гкс_РедактированиеСтоимостиВАкте") Тогда
		Если Пользователи.РолиДоступны("гкс_РедактированиеСтоимостиВАкте") Тогда
			Элементы.ИсполнителиПоРемонтам.ТолькоПросмотр = Ложь;
			Элементы.ИсполнителиПоРемонтам.ИзменятьСоставСтрок = Ложь;
			Элементы.ИсполнителиПоРемонтам.ИзменятьПорядокСтрок = Ложь;
			Элементы.ИсполнителиПоРемонтамИсполнитель.ТолькоПросмотр = Истина;
			Элементы.ИсполнителиПоРемонтамУточнениеИсполнителя.ТолькоПросмотр = Истина;
			Элементы.ИсполнителиПоРемонтамДатаНачала.ТолькоПросмотр = Истина;
			Элементы.ИсполнителиПоРемонтамДатаОкончания.ТолькоПросмотр = Истина;
			Элементы.ИсполнителиПоРемонтамСумма.ТолькоПросмотр = Ложь;
			Элементы.СтраницаПодрядчики.ТолькоПросмотр = Ложь;
			Элементы.СтраницаИсполнителей.ТолькоПросмотр = Ложь;
			Элементы.ГруппаРемонтныеРаботы.ТолькоПросмотр = Ложь;
			Элементы.ГоризонтальнаяГруппа.ТолькоПросмотр = Ложь;
			Элементы.ГруппаРемонтныеРаботы.ТолькоПросмотр = Ложь;
		Иначе
			Элементы.ИсполнителиПоРемонтам.ТолькоПросмотр = Истина;
		КонецЕсли;
	Иначе
	#КонецВставки
	Элементы.ИсполнителиПоРемонтам.ТолькоПросмотр		= БлокироватьДляИзменения Или Не ПравоРедактирование ИЛИ ЭтаФорма["СогласованиеТолькоПросмотр"];
	#Вставка
	КонецЕсли;
	#КонецВставки
	Элементы.СерийныеЗапчасти.ТолькоПросмотр				= БлокироватьДляИзменения Или Не ПравоРедактирование ИЛИ ЭтаФорма["СогласованиеТолькоПросмотр"] 
	ИЛИ НЕ ПризнакВестиУчетСерийныхЗапчастей;

	Элементы.ДобавитьВнутреннееПотребление.Доступность				= Не БлокироватьДляИзменения И ПравоРедактирование И ПравоИнтерактивноеДобвалениеВнутреннихПотреблений И (НЕ ФОВводПотребленияНаОснованииПроведенного ИЛИ (ФОВводПотребленияНаОснованииПроведенного И Объект.Проведен));
	Элементы.СводныйДокументВнутреннееПотребление.Доступность		= Не БлокироватьДляИзменения И ПравоРедактирование И ПравоИнтерактивноеДобвалениеВнутреннихПотреблений И (НЕ ФОВводПотребленияНаОснованииПроведенного ИЛИ (ФОВводПотребленияНаОснованииПроведенного И Объект.Проведен));
	Элементы.УдалитьДокументВнутреннееПотребление.Доступность		= Не БлокироватьДляИзменения И ПравоРедактирование И ПравоИнтерактивнаяПометкаУдаленияВнутреннихПотреблений;
	Элементы.ДобавитьОприходованиеИзлишков.Доступность				= Не БлокироватьДляИзменения И ПравоРедактирование И ПравоИнтерактивноеДобвалениеОприходованияИзлишков И (НЕ ФОВводОприходованияНаОснованииПроведенного ИЛИ (ФОВводОприходованияНаОснованииПроведенного И Объект.Проведен));
	Элементы.СводныйДокументОприходованиеИзлишков.Доступность       = Не БлокироватьДляИзменения И ПравоРедактирование И ПравоИнтерактивноеДобвалениеОприходованияИзлишков И (НЕ ФОВводОприходованияНаОснованииПроведенного ИЛИ (ФОВводОприходованияНаОснованииПроведенного И Объект.Проведен));
	Элементы.УдалитьДокументОприходованиеИзлишков.Доступность		= Не БлокироватьДляИзменения И ПравоРедактирование И ПравоИнтерактивнаяПометкаУдаленияОприходованияИзлишков;
	Элементы.ДеревоРемонтныхРаботДобавитьТехКарту.Доступность		= Не БлокироватьДляИзменения И ПравоРедактирование И НЕ Элементы.ДеревоРемонтныхРабот.ТолькоПросмотр И НЕ ЭтаФорма["СогласованиеТолькоПросмотр"];
	Элементы.ДеревоРемонтныхРаботДобавитьТехОперацию.Доступность	= Не БлокироватьДляИзменения И ПравоРедактирование И НЕ Элементы.ДеревоРемонтныхРабот.ТолькоПросмотр И НЕ ЭтаФорма["СогласованиеТолькоПросмотр"];
	Элементы.Заполнить.Доступность									= Не БлокироватьДляИзменения И ПравоРедактирование И НЕ ЭтаФорма["СогласованиеТолькоПросмотр"];

	ДоступностьПодбораЗапчастей = НЕ Элементы.СерийныеЗапчасти.ТолькоПросмотр;
	Элементы.СерийныеЗапчастиЗапчастиПодборНоменклатуры.Доступность = ДоступностьПодбораЗапчастей;
	Элементы.СерийныеЗапчастиЗаполнитьЗапчастиПоНормам_ТекущийРемонт.Доступность = ДоступностьПодбораЗапчастей;
	Элементы.СерийныеЗапчастиЗаполнитьЗапчастиПоНормам_ВсеРемонты.Доступность = ДоступностьПодбораЗапчастей;
	Элементы.СерийныеЗапчастиЗаполнитьЗапчастиПоОснованию_ТекущийРемонт.Доступность = ДоступностьПодбораЗапчастей;
	Элементы.СерийныеЗапчастиЗаполнитьЗапчастиПоОснованию_ВсеРемонты.Доступность = ДоступностьПодбораЗапчастей;

КонецПроцедуры

// гкс+ [] Деснол 22.09.2022
&НаСервере
Процедура ОбновитьПлановуюСтоимостьРемонтаНаСервере(ТекущийОбъект)
	
	СуммаДавальческие = 0;
	ОбщаяСумма = 0;
	Для Каждого СтрокаТаблицы Из ТекущийОбъект.МатериальныеЗатраты Цикл
		КоэфРемонтнойРаботы = 1;
		СуммаСтроки = СтрокаТаблицы.Сумма * КоэфРемонтнойРаботы;
		ОбщаяСумма = ОбщаяСумма + СуммаСтроки;
		Если СтрокаТаблицы.гкс_Давальческие Тогда 
			СуммаДавальческие = СуммаДавальческие + СуммаСтроки;
		КонецЕсли;
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.ВремяРаботы КАК ВремяРаботы,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.гкс_Количество КАК Количество,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.Квалификация КАК Квалификация,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот0.ID КАК ИД
		|ПОМЕСТИТЬ ВнешняяТаблицаИсполнителейРемонтныхРабот
		|ИЗ
		|	&ВнешняяТаблицаИсполнителейРемонтныхРабот0 КАК ВнешняяТаблицаИсполнителейРемонтныхРабот0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнешняяТаблицаКоэффициентовРемонтныхРабот0.ID КАК ИД,
		|	ВЫРАЗИТЬ(ВнешняяТаблицаКоэффициентовРемонтныхРабот0.гкс_ПовКоэф КАК Справочник.гкс_ПКоэффициентыРабот) КАК гкс_ПовКоэф
		|ПОМЕСТИТЬ ВнешняяТаблицаКоэффициентовРемонтныхРабот
		|ИЗ
		|	&ВнешняяТаблицаКоэффициентовРемонтныхРабот0 КАК ВнешняяТаблицаКоэффициентовРемонтныхРабот0
		|ГДЕ
		|	НЕ ВнешняяТаблицаКоэффициентовРемонтныхРабот0.гкс_ПовКоэф = ЗНАЧЕНИЕ(Справочник.гкс_ПКоэффициентыРабот.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот.ВремяРаботы * 
		|	ЕСТЬNULL(ВнешняяТаблицаКоэффициентовРемонтныхРабот.гкс_ПовКоэф.Коэффициент, 1) КАК ВремяРаботы,
		|выбор когда ВнешняяТаблицаИсполнителейРемонтныхРабот.Количество = 0 Тогда 1 иначе
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот.Количество конец КАК Количество,
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот.Квалификация КАК Квалификация,
		|	ВнешняяТаблицаКоэффициентовРемонтныхРабот.ИД КАК ИД
		|ПОМЕСТИТЬ Исходные
		|ИЗ
		|	ВнешняяТаблицаИсполнителейРемонтныхРабот КАК ВнешняяТаблицаИсполнителейРемонтныхРабот
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВнешняяТаблицаКоэффициентовРемонтныхРабот КАК ВнешняяТаблицаКоэффициентовРемонтныхРабот
		|		ПО ВнешняяТаблицаИсполнителейРемонтныхРабот.ИД = ВнешняяТаблицаКоэффициентовРемонтныхРабот.ИД
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Организации.гкс_ВидЦены КАК ВидЦены,
		|	Организации.гкс_ВидЦены.ВалютаЦены КАК Валюта
		|ПОМЕСТИТЬ ОргВидЦены
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	Организации.Ссылка = &Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_СтоимостьЧасаКвалификацииСрезПоследних.Квалификация КАК Квалификация,
		|	торо_СтоимостьЧасаКвалификацииСрезПоследних.Стоимость КАК Стоимость
		|ПОМЕСТИТЬ ИзРегистра
		|ИЗ
		|	РегистрСведений.торо_СтоимостьЧасаКвалификации.СрезПоследних(
		|			&Дата,
		|			Организация = &Организация
		|				И Квалификация В
		|					(ВЫБРАТЬ
		|						ТЧ.Квалификация
		|					ИЗ
		|						Исходные КАК ТЧ)) КАК торо_СтоимостьЧасаКвалификацииСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОргВидЦены КАК ОргВидЦены
		|		ПО (ОргВидЦены.Валюта = торо_СтоимостьЧасаКвалификацииСрезПоследних.Валюта)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИзРегистра.Стоимость * Исходные.Количество * (Исходные.ВремяРаботы / 3600) КАК Стоимость
		|ИЗ
		|	Исходные КАК Исходные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИзРегистра КАК ИзРегистра
		|		ПО Исходные.Квалификация = ИзРегистра.Квалификация  ";

	Запрос.УстановитьПараметр("Организация", ТекущийОбъект.Организация);
	Запрос.УстановитьПараметр("Дата", ТекущийОбъект.Дата);
	Запрос.УстановитьПараметр("ВнешняяТаблицаИсполнителейРемонтныхРабот0", ТекущийОбъект.ТрудовыеЗатраты.Выгрузить());
	Запрос.УстановитьПараметр("ВнешняяТаблицаКоэффициентовРемонтныхРабот0", ТекущийОбъект.РемонтныеРаботы.Выгрузить());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ПакетПервый = 5;
	Выборка = РезультатЗапроса[ПакетПервый].Выбрать();
	Пока Выборка.Следующий() Цикл
		ОбщаяСумма = ОбщаяСумма + Выборка.Стоимость;
	КонецЦикла;
	
	ТекущийОбъект.гкс_СтоимостьРемонта = ОбщаяСумма;
		
КонецПроцедуры // гкс- [] Деснол 22.09.2022

