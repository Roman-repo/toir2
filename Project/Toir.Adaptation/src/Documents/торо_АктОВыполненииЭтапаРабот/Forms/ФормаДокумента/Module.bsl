&НаКлиенте
Процедура гкс_Проецировать(Команда)
	МассивИД = Новый Массив();
	ТекДанные = Элементы.РемонтыОборудования.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Выберите строку источник";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	Для Каждого СтрокаТаблицы Из Объект.РемонтыОборудования Цикл
		Если СтрокаТаблицы.гкс_Выбран И Не ТекДанные.ID = СтрокаТаблицы.ID Тогда 
			МассивИД.Добавить(СтрокаТаблицы.ID);
		КонецЕсли;
	КонецЦикла;
	Если МассивИД.Количество() > 0 Тогда 
		ПараметрыПослеВыбора = Новый Структура("МассивИД,Источник", МассивИД, ТекДанные.ID);
		ТекОписаниеОповещения = Новый ОписаниеОповещения("гкс_ПроецироватьПослеВопроса", ЭтотОбъект, ПараметрыПослеВыбора);
		СписокТекста = Новый СписокЗначений();
		СписокТекста.Добавить("ВР", "Вид ремонта");
		СписокТекста.Добавить("Даты", "Даты ремонта");
		СписокТекста.Добавить("Операции", "Список операций");
		СписокТекста.Добавить("Исполнители", "Исполнители по ремонту");
		ПоказатьВопрос(ТекОписаниеОповещения, "Выберите реквизиты для проецирования", СписокТекста);
	Иначе
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Выберите строки для проецирования";
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры // гкс- [12.22] Деснол 13.12.2022

