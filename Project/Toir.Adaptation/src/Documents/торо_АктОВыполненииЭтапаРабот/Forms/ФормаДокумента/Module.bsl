		Запрос.УстановитьПараметр("РемонтыОборудования", Объект.РемонтыОборудования.Выгрузить());
		РезультатЗапроса = Запрос.Выполнить();
		Отказ = Не РезультатЗапроса.Пустой();
	Иначе
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ
		               |	торо_ЗавершенныеРемонтныеРаботыСрезПоследних.ID КАК ID
		               |ИЗ
		               |	РегистрСведений.торо_ЗавершенныеРемонтныеРаботы.СрезПоследних(, ID = &ИД_Ремонта) КАК торо_ЗавершенныеРемонтныеРаботыСрезПоследних";
		Запрос.УстановитьПараметр("ИД_Ремонта", ИД_Ремонта);
		РезультатЗапроса = Запрос.Выполнить();
		Отказ = Не РезультатЗапроса.Пустой();
