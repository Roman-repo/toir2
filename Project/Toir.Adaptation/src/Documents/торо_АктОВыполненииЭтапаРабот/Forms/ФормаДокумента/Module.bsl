#Область ОбработчикиСобытийФормы

&НаСервере
Процедура гкс_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ВремяНачалаОткрытияФормы") Тогда
		ВремяНачалаЗамера = Параметры.ВремяНачалаОткрытияФормы;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ПриСозданииНаСервере")
Процедура гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("Основание") И ТипЗнч(Параметры.Основание) <> Тип("Соответствие") Тогда
		торо_ЗаполнениеДокументов.ПроверитьВозможностьВводаНаОсновании(Параметры.Основание,Отказ);
		Если Отказ Тогда
			Возврат;
		КонецЕсли; 
	КонецЕсли;

	Если Параметры.Свойство("Основание") И Параметры.Свойство("ВыделенныеСтроки") Тогда
		ДокОснованиеППР = Параметры.Основание;
		МассивIDИзППР.ЗагрузитьЗначения(Параметры.ВыделенныеСтроки);
	КонецЕсли;

	Если Параметры.Свойство("ID") Тогда

		Строки = Объект.РемонтыОборудования.НайтиСтроки(Новый Структура("ID", Параметры.ID));
		Если Строки.Количество() Тогда
			Элементы.РемонтыОборудования.ТекущаяСтрока = Строки[0].ПолучитьИдентификатор();
		КонецЕсли;

	КонецЕсли;
	#Вставка
	// гкс+ [Релиз16] Деснол
	Если Не ЗначениеЗаполнено(Объект.Ссылка) И Не Отказ Тогда 
		Если Объект.РемонтыОборудования.Количество() Тогда 
			гкс_ПроверитьЗакрытостьРемонта(Отказ);
		КонецЕсли;
		Если Отказ Тогда 
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Ремонт завершен. Создание акта запрещено.'"));
			Возврат;
		КонецЕсли;
	КонецЕсли;
	// гкс- [Релиз16]
	#КонецВставки

	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

	УстановитьУсловноеОформление();

	// функциональные опции
	ФОУчетЗапчастей             = ПолучитьФункциональнуюОпцию("торо_УчетЗапчастей");
	ФОУчетСостоянияОборудования = ПолучитьФункциональнуюОпцию("торо_УчетСостоянияОборудования");
	ФОИспользоватьГарантии      = ПолучитьФункциональнуюОпцию("торо_ИспользоватьГарантии");
	ФОЗапретитьРемонтГарантийногоОборудованияХозспособом = ПолучитьФункциональнуюОпцию("торо_ЗапретитьРемонтГарантийногоОборудованияХозспособом");
	ФОИспользоватьОстановочные	= ПолучитьФункциональнуюОпцию("торо_ИспользоватьОстановочныеРемонты");
	ФОНапоминатьЗафиксироватьПростой = ПолучитьФункциональнуюОпцию("торо_НапоминатьЗафиксироватьПростой");
	ФОВводПотребленияНаОснованииПроведенного = Константы.торо_ВводПотребленияНаОснованииПроведенногоАкта.Получить();
	ФОВводОприходованияНаОснованииПроведенного = Константы.торо_ВводОприходованияНаОснованииПроведенногоАкта.Получить();

	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда

		ОписаниеОшибки = "";
		Если слкМенеджерЗащиты.ПроверитьЛицензииСеанса(ОписаниеОшибки) <> Истина Тогда
			ТекстСообщения = НСтр("es='¡La licencia no es descubierta! La creación del documento es imposible.';ru='Лицензия не обнаружена! Создание документа невозможно.';en='No license found! Creating a document is not possible.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,,Отказ);
			Возврат;
		КонецЕсли;				

		СлужебныеРеквизитыЗаполнитьНаСервере();

		Если ФОИспользоватьГарантии Тогда
			Для каждого ТекСтрока из Объект.РемонтыОборудования Цикл
				ТекСтрока.ГарантийныйРемонт = торо_ГарантийноеОбслуживание.ПолучитьЗначениеФлагаГарантийныйРемонтДляОбъектаРемонта(
				ТекСтрока.ОбъектРемонта, ТекСтрока.ДатаНачала, ТекСтрока.ДатаОкончания);
			КонецЦикла;
		КонецЕсли;			

	КонецЕсли;
    #Удаление
	ЗаполнитьДеревоРемонтныхРаботНаСервере();
    #КонецУдаления 
	#Вставка
	// Гкс+[TOIR20-609] Вялых Д.А. от 24.07.2025. Добавлено:{
	гкс_ЗаполнитьДеревоРемонтныхРаботЗапросомНаСервере(); 
	// } Гкс-[TOIR20-609] Вялых Д.А. от 24.07.2025.
	#КонецВставки
	ФОИспользоватьУсложненнуюСхемуЗакрытияНарядов = ПолучитьФункциональнуюОпцию("торо_ИспользоватьУсложненнуюСхемуЗакрытияНарядов");
	Элементы.ДеревоРемонтныхРаботВыполнено.Видимость = НЕ ФОИспользоватьУсложненнуюСхемуЗакрытияНарядов;

	ОбновитьДокументыВнутреннегоПотребленияСервер();
	ОбновитьДокументыОприходованияИзлишковСервер();

	// Заголовок формы++
	торо_РаботаСДиалогами.УстановитьЗаголовокФормыДокумента(Объект, ЭтаФорма, "");
	// Заголовок формы--

	// Согласование++
	ВидДокумента = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_АктОВыполненииЭтапаРабот;
	торо_РаботаССогласованиями.ПриСозданииНаСервере(ЭтаФорма, ВидДокумента);
	// Согласование --

	ОтметитьНаличиеАналогов();

	РемонтыОборудованияОбновитьДокументыИсточники();

	ПравоРедактирование = ПравоДоступа("Редактирование", Метаданные.Документы.торо_АктОВыполненииЭтапаРабот);
	ПравоИнтерактивноеДобвалениеВнутреннихПотреблений = ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Документы.ВнутреннееПотреблениеТоваров);
	ПравоИнтерактивнаяПометкаУдаленияВнутреннихПотреблений = ПравоДоступа("ИнтерактивнаяПометкаУдаления", Метаданные.Документы.ВнутреннееПотреблениеТоваров);
	ПравоИнтерактивноеДобвалениеОприходованияИзлишков = ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Документы.ОприходованиеИзлишковТоваров);
	ПравоИнтерактивнаяПометкаУдаленияОприходованияИзлишков = ПравоДоступа("ИнтерактивнаяПометкаУдаления", Метаданные.Документы.ОприходованиеИзлишковТоваров);

	Элементы.СтраницаЗапчасти.Видимость = ФОУчетЗапчастей;

	// Ограничение ввода на основании
	торо_СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка, Новый Структура("ОграничитьВводНаОсновании, ДокументыОснования, УстановитьСвойствоЭлементовФормыОтПрав",Истина, Истина, Истина));
	// Конец ограничение ввода на основании

	ФОИспользоватьНарядДопуск = ПолучитьФункциональнуюОпцию("торо_ИспользоватьНарядДопускНаРаботыПовышеннойОпасностиОбязательно");

	Если Параметры.Свойство("Основание") и ТипЗнч(Параметры.Основание) = Тип("Соответствие") Тогда
		ВТ_ТабОперацийБезНаряда = ЭтотОбъект.ТабОперацийБезНаряда.Выгрузить();
		Для каждого Стр Из Параметры.Основание Цикл
			ДокОснованиеЗаявка = Стр.Значение;
			Если ФОИспользоватьНарядДопуск И ЗначениеЗаполнено(ДокОснованиеЗаявка) И НЕ ТипЗнч(ДокОснованиеЗаявка) = Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") Тогда
				ЗаполнитьТабОперацийБезНаряда(ДокОснованиеЗаявка, Стр.Ключ);
				Для Каждого Строка Из ТабОперацийБезНаряда Цикл
					НС= ВТ_ТабОперацийБезНаряда.Добавить();
					ЗаполнитьЗначенияСвойств(НС, Строка);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		ТабОперацийБезНаряда.Загрузить(ВТ_ТабОперацийБезНаряда);
	Иначе
		ДокОснованиеЗаявка = Параметры.Основание;
		Если ФОИспользоватьНарядДопуск И ЗначениеЗаполнено(ДокОснованиеЗаявка) И НЕ ТипЗнч(ДокОснованиеЗаявка) = Тип("ДокументСсылка.торо_НарядНаВыполнениеРемонтныхРабот") Тогда
			ЗаполнитьТабОперацийБезНаряда(ДокОснованиеЗаявка);
		КонецЕсли;
	КонецЕсли;


	Для каждого Строка Из Объект.ТрудовыеЗатраты Цикл
		Если НЕ ЗначениеЗаполнено(Строка.ВремяРаботы) Тогда
			Строка.ВремяРаботы = Строка.ДатаОкончания - Строка.ДатаНачала;
		КонецЕсли;
		Строка.ВремяРаботыТекст = СформироватьПродолжительность(Строка.ВремяРаботы);
	КонецЦикла;

	ОбновитьДоступностьДляРедактирования();

	Если ФОИспользоватьОстановочные Тогда
		ОбновитьОстановочные();
	КонецЕсли;

	ОбновитьЗависимыеЛоты();

	УправлениеВидимостью(ЭтотОбъект);

	ЭтоПервыйДокументВЦепочке = ЭтоПервыйДокументВЦепочке();
	ЭтоПоследнийДокументВЦепочке = ЭтоПоследнийДокументВЦепочке();
	#Вставка
	// гкс+ [Релиз16] Деснол
	торо_ЗаполнениеДокументов.гкс_ПроверитьВозможностьВводаОтСтатуса(Объект, Отказ);
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	// гкс- [Релиз16]
	
	// гкс+ [Часовые пояса] Куст 
	гкс_ЧасовыеПоясаВызовСервера.ДобавитьНовыеЭлементы(ЭтаФорма, Элементы.ДатаИНомер,
		Новый Структура("гкс_РеквизитыДаты", 
		"Дата,РемонтыОборудования.ДатаНачала,РемонтыОборудования.ДатаОкончания"
		+ ",ТрудовыеЗатраты.ДатаНачала,ТрудовыеЗатраты.ДатаОкончания"
		+ ",ИсполнителиПоРемонтам.ДатаНачала,ИсполнителиПоРемонтам.ДатаОкончания"));
	
	ДобавитьНовыеЭлементы();
	// гкс+ [КатегорияРиска] Куст 
	гкс_ОбщегоНазначенияСервер.ДобавитьКатегориюРискаВТЧ(ЭтаФорма, "РемонтыОборудования", "ДатыРемонта");
	
	// гкс+ [Релиз 1] Куст 
	Элементы.СпособСогласования.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
	// гкс+ [05.23] Деснол 10.05.2023
	Если Параметры.Ключ.Пустая() И Объект.РемонтыОборудования.Количество() > 1 Тогда 
		ВернутьПорядокРемонтовПоОснованию();
	КонецЕсли;
	// гкс- [05.23] Деснол 10.05.2023
	#КонецВставки

КонецПроцедуры

&НаСервере
Процедура гкс_ПриЧтенииНаСервереПосле(ТекущийОбъект)
	// гкс+ [Часовые пояса] Куст 
	СтруктураПроверки = Новый Структура("гкс_СдвигЧП", Неопределено);
	ЗаполнитьЗначенияСвойств(СтруктураПроверки, ЭтотОбъект);
	Если Не СтруктураПроверки.гкс_СдвигЧП = Неопределено Тогда 
		гкс_ЧасовыеПоясаВызовСервера.ПеревестиНаЧПКлиента(ЭтаФорма,, Объект);
	КонецЕсли;
	// гкс+ [Категории риска] Куст
	гкс_ОбщегоНазначенияСервер.ДобавитьУОКатегорииРиска(ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура гкс_ПриОткрытииПосле(Отказ) 
	
	// Гкс+[TOIR20-608] Вялых Д.А. от 21.07.2025. Добавлено и закомментировано:{
	//ПриОткрытииНаСервере(ТекущаяДата());
		
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("Метаданные", "Акт о выполнении этапа работ");
	СтруктураПараметров.Вставить("СтрокаВидаОперации", "");
	СтруктураПараметров.Вставить("Номер", Объект.Номер);
	СтруктураПараметров.Вставить("Дата", Объект.Дата); 
	СтруктураПараметров.Вставить("Проведен", Объект.Проведен); 
	СтруктураПараметров.Вставить("Ссылка", Объект.Ссылка);
	
	СтруктураДанныхЗаполненияФормы = гкс_ЗаголовокФормыДокумента(СтруктураПараметров);
	
	Если СтруктураДанныхЗаполненияФормы.Свойство("ДатаССервера") Тогда
		Объект.Дата = СтруктураДанныхЗаполненияФормы.ДатаССервера;		
	КонецЕсли;
	
	РаботаСДиалогамиКлиент.гкс_ПеревестиНаЧПКлиента(ЭтаФорма,,,);
	ЭтаФорма.Заголовок = СтруктураДанныхЗаполненияФормы.Заголовок;
	
	// } Гкс-[TOIR20-558] Вялых Д.А. от 21.07.2025.
	
	// гкс+ [12.22] Деснол 13.12.2022
	ЭтотОбъект["гкс_ВыборРемонтов"] = Истина;
	гкс_РежимПроецирования(Неопределено);
	// гкс- [12.22] Деснол 13.12.2022  
	
	ЗавершитьЗамерОткрытияФормы(ВремяНачалаЗамера);
	
КонецПроцедуры 

&НаСервереБезКонтекста
Функция гкс_ЗаголовокФормыДокумента(СтруктураПараметров)
	
	СтруктураВозврата = Новый Структура(); 
	
	Если ЗначениеЗаполнено(СтруктураПараметров.Ссылка) = Ложь Тогда 
		СтруктураВозврата.Вставить("ДатаССервера", ТекущаяДата());
	КонецЕсли;
	 	СтруктураВозврата.Вставить("Заголовок", торо_РаботаСДиалогами.гкс_ЗаголовокФормыДокумента(СтруктураПараметров));
	 
	
	Возврат СтруктураВозврата;

КонецФункции

