#Область ОбработчикиСобытийФормы

&НаСервере
&Перед("ПриСозданииНаСервере")
Процедура Расш_гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ДобавитьНовыеЭлементы();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ДобавитьНовыеЭлементы()
	НоваяГруппа = Элементы.Добавить("ГруппаФМ", Тип("ГруппаФормы"), Элементы.Теги);
	НоваяГруппа.Вид = ВидГруппыФормы.Подменю;
	НоваяГруппа.Заголовок = НСтр("en='Check FP';es='Comprobación de la fm';ru='Проверка ФМ'");
КонецПроцедуры

&НаСервере
Процедура ДобавитьКоманду1(ИмяКоманды, Группа, ПредставлениеКоманды)
	НовКнопкаМеню = Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), Группа);
	НовКнопкаМеню.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	НовКнопкаМеню.Заголовок  = "%" + ПредставлениеКоманды + "%";

	НовКоманда = ЭтаФорма.Команды.Добавить(ИмяКоманды);
	НовКоманда.Действие      = "кнДобавитьТегНажатие";
	НовКоманда.Заголовок     = "%"+ ПредставлениеКоманды +"%";

	НовКнопкаМеню.ИмяКоманды = ИмяКоманды;	
КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ДобавитьКомандыТегов")
Процедура Расш_гкс_ДобавитьКомандыТегов()
	#Вставка
	// Ссылка
	ДобавитьКоманду1("Ссылка"                           , Элементы.ГруппаДокументы,
	НСтр("ru = 'Ссылка'; en = 'Document'; es = 'Document'"));
	// Номер
	ДобавитьКоманду1("Номер"                           , Элементы.ГруппаДокументы,
	НСтр("ru = 'Номер'; en = 'Number'; es = 'El número de'"));
	// Дата
	ДобавитьКоманду1("Дата"                            , Элементы.ГруппаДокументы,
	НСтр("ru = 'Дата'; en = 'Date'; es = 'Fecha'") );
	// Ответственный
	ДобавитьКоманду1("Ответственный"                   , Элементы.ГруппаДокументы,
	НСтр("ru = 'Ответственный'; en = 'Responsible'; es = 'Responsable'") );
	ДобавитьКоманду1("НавСсылка"                           , Элементы.ГруппаДокументы,
	НСтр("ru = 'Навигационная Ссылка'; en = 'Navigation ref'; es = 'Navigation ref'"));
	// Комментарий
	ДобавитьКоманду1("Комментарий"                   , Элементы.ГруппаДокументы,
	НСтр("ru = 'Комментарий'; en = 'Review'; es = 'Comentario'"));
	// Согасование
	// Согласующий
	ДобавитьКоманду1 ("Согласующий"                    , Элементы.ГруппаСогласование,
	НСтр("ru = 'Согласующий'; en = 'Matching'; es = 'Vía'"));
	ДобавитьКоманду1 ("СтатусДокумента"                , Элементы.ГруппаСогласование,
	НСтр("ru = 'Статус документа'; en = 'The status of the document'; es = 'El estado de un documento'"));
	ДобавитьКоманду1 ("ПредыдущийСтатусДокумента"      , Элементы.ГруппаСогласование,
	НСтр("ru = 'Предыдущий статус документа'; en = 'The previous status of the document';"
	+ " es = 'El estado anterior de un documento'"));

	ДобавитьКоманду1 ("ОбъектРемонта"				  , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("ru = 'Объект ремонта'; en = 'Object of repair'; es = 'El objeto de la reparación'"));
	ДобавитьКоманду1 ("Показатель"					  , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("ru = 'Показатель'; en = 'Figure'; es = 'La tasa de'"));
	ДобавитьКоманду1 ("ЗначениеПоказателя"			  , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("ru = 'Значение показателя'; en = 'The value of the index'; es = 'El valor de la métrica'"));
	ДобавитьКоманду1 ("ЕдиницаИзмеренияПоказателя" 	  , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("ru = 'Единица измерения показателя'; en = 'Unit of measure'; es = 'Unidad de medida del indicador'"));
	ДобавитьКоманду1 ("УсловиеУведомления" 			  , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("ru = 'Условие уведомления'; en = 'The notification condition'; es = 'La condición de la notificación'"));
	ДобавитьКоманду1 ("Значение" 					  , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("en='Value';es='El significado';ru='Значение'"));
	ДобавитьКоманду1 ("ГраницаИнтервала" 			  , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("ru = 'Граница интервала'; en = 'Bound of the interval'; es = 'El límite del intervalo de'"));
	ДобавитьКоманду1 ("КритическиеЗначенияПоказателей" , Элементы.ГруппаКонтролируемыеПоказатели,
	НСтр("ru = 'Критические значения показателей'; en = 'Critical values';"
	+ " es = 'Críticos de los valores de los indicadores de'"));

	ДобавитьКоманду1 ("Адресат"                        , Элементы.ГруппаОбщие,
	НСтр("ru = 'Адресат'; en = 'The recipient'; es = 'El destino'"));
	
	ДобавитьКоманду1 ("гкс_Наименование"                        , Элементы.ГруппаОбщие,
	НСтр("ru = 'Наименование'; en = 'Name'; es = 'Name'"));

	ДобавитьКоманду1 ("ДефектныеОбъектыРемонта"        , Элементы.ГруппаВыявленныеДефекты,
	НСтр("ru = 'Дефектные объекты ремонта'; en = 'Defective repair facilities';"
	+ " es = 'Defectuosos objetos de la reparación'"));
	ДобавитьКоманду1 ("ДефектныеОбъектыРемонтаСОписаниемИПоследствиями"        ,
	Элементы.ГруппаВыявленныеДефекты, НСтр("ru = 'Дефектные объекты ремонта с описанием и последствиями';"
		+ " en = 'Defective repair facilities with a description and consequences';"
		+ " es = 'Defectuosos objetos de la reparación con la descripción y consecuencias de la'"));

	ДобавитьКоманду1 ("ФМ"                    , Элементы["ГруппаФМ"],
	НСтр("en='FP';es='Fm';ru='ФМ'"));
	ДобавитьКоманду1 ("ТекстТребований"                    , Элементы["ГруппаФМ"],
	НСтр("ru = 'Текст требований'; en = 'Text requirements'; es = 'El texto de los requisitos'"));
	#КонецВставки
	#Удаление
	// Номер
	ДобавитьКоманду("Номер"                           , Элементы.ГруппаДокументы);
	// Дата
	ДобавитьКоманду("Дата"                            , Элементы.ГруппаДокументы);
	// Ответственный
	ДобавитьКоманду("Ответственный"                   , Элементы.ГруппаДокументы);
	// Комментарий
	ДобавитьКоманду("Комментарий"                   , Элементы.ГруппаДокументы);
	// Согасование
	// Согласующий
	ДобавитьКоманду ("Согласующий"                    , Элементы.ГруппаСогласование);
	ДобавитьКоманду ("СтатусДокумента"                , Элементы.ГруппаСогласование);
	ДобавитьКоманду ("ПредыдущийСтатусДокумента"      , Элементы.ГруппаСогласование);
	
	ДобавитьКоманду ("ОбъектРемонта"				  , Элементы.ГруппаКонтролируемыеПоказатели);
	ДобавитьКоманду ("Показатель"					  , Элементы.ГруппаКонтролируемыеПоказатели);
	ДобавитьКоманду ("ЗначениеПоказателя"			  , Элементы.ГруппаКонтролируемыеПоказатели);
	ДобавитьКоманду ("ЕдиницаИзмеренияПоказателя" 	  , Элементы.ГруппаКонтролируемыеПоказатели);
	ДобавитьКоманду ("УсловиеУведомления" 			  , Элементы.ГруппаКонтролируемыеПоказатели);
	ДобавитьКоманду ("Значение" 					  , Элементы.ГруппаКонтролируемыеПоказатели);
	ДобавитьКоманду ("ГраницаИнтервала" 			  , Элементы.ГруппаКонтролируемыеПоказатели);
	ДобавитьКоманду ("КритическиеЗначенияПоказателей" , Элементы.ГруппаКонтролируемыеПоказатели);
	
	ДобавитьКоманду ("Адресат"                        , Элементы.ГруппаОбщие);
	
	ДобавитьКоманду ("ДефектныеОбъектыРемонта"        , Элементы.ГруппаВыявленныеДефекты);
	ДобавитьКоманду ("ДефектныеОбъектыРемонтаСОписаниемИПоследствиями"        , Элементы.ГруппаВыявленныеДефекты);
	#КонецУдаления
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("кнДобавитьТегНажатие")
Процедура Расш_гкс_кнДобавитьТегНажатие(Команда)

	Если ЭтаФорма.ТекущийЭлемент = Элементы.ТемаПисьма
		Или ЭтаФорма.ТекущийЭлемент = Элементы.ТелоПисьма Тогда

		#Вставка
		Если Команда.Имя = "гкс_Наименование" Тогда 
			ИмяТега = "%Наименование%";
			ЭтаФорма.ТекущийЭлемент.ВыделенныйТекст = ИмяТега;
			Возврат;
		КонецЕсли;
		#КонецВставки
		ИмяТега = "%" + Команда.Имя + "%";
		ЭтаФорма.ТекущийЭлемент.ВыделенныйТекст = ИмяТега;

	КонецЕсли;

КонецПроцедуры



#КонецОбласти