	дс_ПослеЗаписиНаСервере(ЭтаФорма, ТекущийОбъект, ПараметрыЗаписи);
	// гкс- [Релиз 1] Куст 19.03.2020
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПередЗаписью")
Процедура Расш_гкс_ПередЗаписью(Отказ, ПараметрыЗаписи)

	Если Не Отказ Тогда
		Если (МодифицированностьНормРемонтов Или МодифицированностьЗамещаемыхРемонтов Или  МодифицированностьПредшествующихРемонтов)
			И ЗначениеЗаполнено(ВРНачалоЦикла) Тогда

			Элементы.Перерасчитать.Доступность 	= Ложь;
			Элементы.Построить.Доступность 		= Ложь;
			Элементы.Настройки.Доступность 		= Ложь; 			

			ВРНачалоЦикла = Неопределено;
			ПлановыйГрафикРаботы = Неопределено;
			торо_РаботаСМнемосхемами.мнс_СоздатьЧистуюКарту(ПолеМнемосхемы);
			ОчиститьПолеТабличногоДокумента();
			Элементы.Декорация1.Заголовок		= НСтр("es='En total ';ru='Всего: ';en='Total: '");

			ТекстСообщения = НСтр("es='Los datos en вкладке <la Estructura del ciclo de reparación> eran limpiados, puesto que las normas son cambiadas.';ru='Данные на вкладке <Структура ремонтного цикла> были очищены, так как нормативы изменены.';en='The data on the <Структура ремонтного цикла> tab has been cleared because the specifications have been changed.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			#Вставка
			Если ЭтотОбъект["ФОИспользоватьФункциональныеМеста"] Тогда 
				Если ЗначениеЗаполнено(Объект.ТипОбъекта) = Ложь Тогда 
					Отказ = Истина;
					Сообщение = Новый СообщениеПользователю();
					Сообщение.Текст = НСтр("ru = 'Не указан тип объекта!'; 
						|en = 'Do not specify the type of object!'; es = 'No se especifica el tipo de objeto!'");
					Сообщение.Поле = "Объект.ТипОбъекта";
					Сообщение.Сообщить();
				КонецЕсли;
			КонецЕсли;
			#КонецВставки
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ФункциональныеМеста
// гкс+ [Релиз 1] Куст 17.03.2020
&НаСервере
Процедура ДобавитьНовыеЭлементы()
	Элементы.НормативныеРемонтыНормативныйРемонт.РедактированиеТекста = Ложь;
	Элементы.НормативныеРемонтыНормативныйРемонт.БыстрыйВыбор = Ложь;
	Элементы.НормативныеРемонтыНормативныйРемонт.КнопкаСоздания = Ложь;
	МассивРеквизитов = Новый Массив();
	
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ФОИспользоватьФункциональныеМеста", Новый ОписаниеТипов("Булево")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("МодифицированностьОграничений", Новый ОписаниеТипов("Булево")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ПредыдущийТипОбъекта",
		Новый ОписаниеТипов("ПеречислениеСсылка.торо_ТипыОбъектовRCM")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ТаблицаОграничений", Новый ОписаниеТипов("ДеревоЗначений")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Иерархия", Новый ОписаниеТипов("СправочникСсылка.торо_СтруктурыОР"),
		"ТаблицаОграничений", НСтр("ru = 'Иерархия'; en = 'Hierarchy'; es = 'La jerarquía de'")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Ограничение",
		Новый ОписаниеТипов("СправочникСсылка.торо_ОграниченияНаХарактеристикиОбрудования"),
		"ТаблицаОграничений", НСтр("en='Rrestriction';es='La limitación de la';ru='Ограничение'")));
	
	ИзменитьРеквизиты(МассивРеквизитов);
	//
	ЭтотОбъект["ФОИспользоватьФункциональныеМеста"] = Константы.торо_ИспользоватьФункциональныеМеста.Получить();
	ЭтотОбъект["ПредыдущийТипОбъекта"] = Объект.ТипОбъекта;
	//
	НЭлем = Элементы.Добавить("ГруппаРодительТип", Тип("ГруппаФормы"));
	НЭлем.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НЭлем.ОтображатьЗаголовок = Ложь;
	//
	Элементы.Переместить(Элементы["ГруппаРодительТип"], ЭтаФорма,Элементы.КодИНаименование);
	Элементы.Переместить(Элементы.Родитель, Элементы["ГруппаРодительТип"],);
	//
	НЭлем = Элементы.Добавить("ТипОбъекта", Тип("ПолеФормы"), Элементы["ГруппаРодительТип"]);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.РежимВыбораИзСписка = Истина;
	НЭлем.ПутьКДанным = "Объект.ТипОбъекта";
	НЭлем.СписокВыбора.Добавить(Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто);
	НЭлем.СписокВыбора.Добавить(Перечисления.торо_ТипыОбъектовRCM.Объект);
	НЭлем.Видимость = ЭтотОбъект["ФОИспользоватьФункциональныеМеста"];
	НЭлем.УстановитьДействие("ПриИзменении", "ТипОбъекта_ПриИзменении");
	//
	нСтран = Элементы.Добавить("Страница_Ограничения", Тип("ГруппаФормы"), Элементы["ПанельДопИнформации"]);
	нСтран.Вид = ВидГруппыФормы.Страница;
	нСтран.Заголовок = НСтр("en='Rrestriction';es='La limitación de la';ru='Ограничение'");
	//
	НЭлем = Элементы.Добавить("ГруппаКомандыОграничений", Тип("ГруппаФормы"), Элементы["Страница_Ограничения"]);
	НЭлем.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НЭлем.ОтображатьЗаголовок = Ложь;
	//
	нТабл = Элементы.Добавить("ТаблицаОграничений", Тип("ТаблицаФормы"), Элементы["Страница_Ограничения"]);
	нТабл.ПутьКДанным = "ТаблицаОграничений";
	нТабл.Отображение = ОтображениеТаблицы.Дерево;
	нТабл.КоманднаяПанель.Видимость = Ложь;
	нТабл.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	нТабл.УстановитьДействие("ПередУдалением", "ТаблицаОграничений_ПередУдалением");
	нТабл.УстановитьДействие("ПередНачаломДобавления", "ТаблицаОграничений_ПередНачаломДобавления");
	нТабл.УстановитьДействие("Выбор", "Ограничения_Выбор");
	
	НЭлем = Элементы.Добавить("Ограничения_Иерархия", Тип("ПолеФормы"), Элементы["ТаблицаОграничений"]);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "ТаблицаОграничений.Иерархия";
	НЭлем.АвтоВысотаЯчейки = Истина;
	НЭлем.ТолькоПросмотр = Истина;
	
	НЭлем = Элементы.Добавить("Ограничения_Ограничение", Тип("ПолеФормы"), Элементы["ТаблицаОграничений"]);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "ТаблицаОграничений.Ограничение";
	НЭлем.АвтоВысотаЯчейки = Истина;
	НЭлем.УстановитьДействие("ПриИзменении", "Ограничения_Ограничение_ПриИзменении");
	НЭлем.ТолькоПросмотр = Истина;
	//
	НКом = Команды.Добавить("Ограничения_ДобавитьИерархию");
	НКом.Действие = "Ограничения_ДобавитьИерархию";
	НКом.Заголовок = НСтр("ru = 'Добавить иерархию'; en = 'To add a hierarchy'; es = 'Añadir la jerarquía'");
	//
	НЭлем = Элементы.Добавить("Кнопка_Ограничения_ДобавитьИерархию", Тип("КнопкаФормы"),
		Элементы["ГруппаКомандыОграничений"]);
	НЭлем.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
	НЭлем.ИмяКоманды = "Ограничения_ДобавитьИерархию";
	//
	НКом = Команды.Добавить("Ограничения_ДобавитьОграничение");
	НКом.Действие = "Ограничения_ДобавитьОграничение";
	НКом.Заголовок = НСтр("ru = 'Добавить ограничение'; en = 'Add constraint'; es = 'Agregar la restricción'");
	//
	НЭлем = Элементы.Добавить("Кнопка_Ограничения_ДобавитьОграничение", Тип("КнопкаФормы"),
		Элементы["ГруппаКомандыОграничений"]);
	НЭлем.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
	НЭлем.ИмяКоманды = "Ограничения_ДобавитьОграничение";
	//
	НКом = Команды.Добавить("Ограничения_ДобавитьОграничениеВсем");
	НКом.Действие = "Ограничения_ДобавитьОграничениеВсем";
	НКом.Заголовок = НСтр("ru = 'Добавить ограничение для всех';
		|en = 'Add constraint for all'; es = 'Agregar una restricción para todos'");
	//
	НЭлем = Элементы.Добавить("Кнопка_Ограничения_ДобавитьОграничениеВсем", Тип("КнопкаФормы"), 
		Элементы["ГруппаКомандыОграничений"]);
	НЭлем.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
	НЭлем.ИмяКоманды = "Ограничения_ДобавитьОграничениеВсем";
	//
	Элементы.Наименование.Заголовок = НСтр("ru='Модель';en='Model'");
	//
	НЭлем = Элементы.Добавить("гкс_Модель", Тип("ПолеФормы"), Элементы.КодИНаименование);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.Заголовок = НСтр("ru='Наименование';en='Name'");
	НЭлем.ПутьКДанным = "Объект.гкс_Модель";
	НЭлем.АвтоМаксимальнаяШирина = Ложь;
	НЭлем.ТолькоПросмотр = Истина;
	Элементы.Наименование.УстановитьДействие("ПриИзменении", "МодельПриИзменении");
	Элементы.Комментарий.УстановитьДействие("ПриИзменении", "МодельПриИзменении");
	Элементы.Изготовитель.УстановитьДействие("ПриИзменении", "МодельПриИзменении");
	Элементы.Родитель.УстановитьДействие("ПриИзменении", "МодельПриИзменении");
	Элементы.Переместить(Элементы["гкс_Модель"], Элементы.КодИНаименование,Элементы.Код);
	Элементы.Переместить(Элементы.Наименование, ЭтаФорма,Элементы.НаправлениеИИзготовитель);
	//
	ТипОбъекта_ПриИзмененииНаСервере();
	
	ЗаполнитьДеревоОграничений();
	//
	Элементы.Изготовитель.Видимость = Ложь;
	НЭлем = Элементы.Добавить("гкс_Изготовитель", Тип("ПолеФормы"), Элементы.НаправлениеИИзготовитель);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.Заголовок = НСтр("ru='Изготовитель';en='Manufacturer'; es = 'el Fabricador'");
	НЭлем.ПутьКДанным = "Объект.Изготовитель";
	НЭлем.АвтоМаксимальнаяШирина = Ложь;
	
	// Гкс+[TOIR20-94] Борисов В.М. от 05.06.2020. Добавлено:{
	// добавим новую страницу Ответственный и заполним ее
	// Гкс+[TOIR20-204] Селимов от 08.12.2020. Изменено:{
	// ТолькоПросмотр = Истина;
	// }На:{
	КритичностьТолькоПросмотр = Истина;	// } Гкс-[TOIR20-204]
	Если ПравоДоступа("Редактирование", Метаданные.Справочники.гкс_Критичность) Тогда
		КритичностьТолькоПросмотр = Ложь;
	КонецЕсли;
	
	НоваяГруппа = Элементы.Добавить("гкс_Ответственный", Тип("ГруппаФормы"), Элементы.ПанельДопИнформации);
	НоваяГруппа.Заголовок = Нстр("ru='Ответственный'", ОбщегоНазначения.КодОсновногоЯзыка());
	НоваяГруппа.Вид = ВидГруппыФормы.Страница;
	
	НовыйЭлемент = Элементы.Добавить("гкс_ОтветственныйИнженер", Тип("ПолеФормы"), НоваяГруппа);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.Заголовок = Нстр("ru='Ответственный инженер'", ОбщегоНазначения.КодОсновногоЯзыка());
	НовыйЭлемент.ПутьКДанным = "Объект.гкс_ОтветственныйИнженер";
	НовыйЭлемент.ТолькоПросмотр = КритичностьТолькоПросмотр;
	
	НовыйЭлемент = Элементы.Добавить("гкс_Критичность", Тип("ПолеФормы"), НоваяГруппа);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.Заголовок = Нстр("ru='Кричичность'", ОбщегоНазначения.КодОсновногоЯзыка());
	НовыйЭлемент.ПутьКДанным = "Объект.гкс_Критичность";
	НовыйЭлемент.ТолькоПросмотр = КритичностьТолькоПросмотр;
	// } Гкс-[TOIR20-94] Борисов В.М. от 05.06.2020. 	

КонецПроцедуры

&НаКлиенте
Процедура МодельПриИзменении(Элемент)
	ИмяРодителя = Строка(Объект.Родитель);
	гкс_Модель = ИмяРодителя + " / "+Объект.Наименование+?(ЗначениеЗаполнено(Объект.Изготовитель)," / "+Объект.Изготовитель,"")+?(ЗначениеЗаполнено(Объект.Комментарий)," / "+Объект.Комментарий,"");
	Объект.гкс_Модель = гкс_Модель;
КонецПроцедуры

&НаКлиенте
Процедура ТипОбъекта_ПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Ссылка) И Не ЭтотОбъект["ПредыдущийТипОбъекта"] = Объект.ТипОбъекта И ВСоставеЕстьОР(Объект.Ссылка) Тогда 
		СтруктураОпОп = Новый Структура("ТипОбъекта,Предыдущий",Объект.ТипОбъекта,ЭтотОбъект["ПредыдущийТипОбъекта"]);
		ОпОп = Новый ОписаниеОповещения("ПослеВопросаОбОчисткеСпискаОР",ЭтотОбъект,СтруктураОпОп);
		МассивКнопок = Новый СписокЗначений();
		// >> [Деснол] [Ушаков А.Д.] [08.11.2019] 
		МассивКнопок.Добавить("Очистить", НСтр("ru = 'Очистить состав'; en = 'Clear composition'; es = 'Limpiar la composición de la'"));
		МассивКнопок.Добавить("Изменить", НСтр("ru = 'Изменить тип'; en = 'To change the type'; es = 'Cambiar el tipo de'"));
		ПоказатьВопрос(ОпОп,НСтр("en='Clean the part of the EI or change the type of all the EI in the squad?';es='Limpiar la composición de los RP o cambiar el tipo de todos los resultados previstos en la composición?';ru='Очистить состав ОР или изменить тип всех ОР в составе?'"),МассивКнопок);
		// << [Деснол] [Ушаков А.Д.] [08.11.2019] 
		Возврат;
	КонецЕсли;
	
	ТекВидимость = Не(Объект.ТипОбъекта = торо_ОбщегоНазначенияКлиентПовтИсп.ПолучитьПеречисление("торо_ТипыОбъектовRCM","ФункциональноеМесто"));
	Элементы.НаправлениеИИзготовитель.Видимость = ТекВидимость;
	Элементы.ГруппаДополнительныеРеквизиты.Видимость = ТекВидимость;
	Элементы["Страница_Ограничения"].Видимость = Не ТекВидимость;
	
	ЭтотОбъект["ПредыдущийТипОбъекта"] = Объект.ТипОбъекта;
КонецПроцедуры

&НаСервере
