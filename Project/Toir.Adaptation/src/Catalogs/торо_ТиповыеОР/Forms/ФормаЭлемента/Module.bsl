#Область ОбработчикиСобытийФормы

&НаСервере
Процедура Расш_гкс_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	// гкс+ [Релиз 1] Куст 17.03.2020
	дс_ПриСозданииНаСервере();
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда 
		Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.Объект;
	КонецЕсли;
	ДобавитьНовыеЭлементы();
	// гкс-[Релиз 1] Куст 17.03.2020
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПередЗаписьюНаСервереПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// гкс+ [Релиз 1] Куст 17.03.2020
	Если ЭтотОбъект["МодифицированностьОграничений"] Тогда 
		ЗаписатьДеревоОграничений(ТекущийОбъект);
		ЭтотОбъект["МодифицированностьОграничений"] = Ложь;
	КонецЕсли;
	дс_ПередЗаписьюНаСервере(ЭтаФорма, Отказ, ТекущийОбъект, ПараметрыЗаписи);
	// гкс- [Релиз 1] Куст 17.03.2020
КонецПроцедуры

