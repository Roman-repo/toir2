&НаКлиенте
Процедура ПослеВопросаОбОчисткеСпискаОР(Результат,ДопПараметры)Экспорт
	Если Результат = "Очистить" Тогда 
		ОчиститьОРНаСервере();
		Элементы.СписокОР.Обновить();
		ЭтотОбъект["ПредыдущийТипОбъекта"] = Объект.ТипОбъекта;
	ИначеЕсли Результат = "Изменить" Тогда 
		ИзменитьТипОР(ДопПараметры.ТипОбъекта, Объект.Ссылка);
		Элементы.СписокОР.Обновить();
		ЭтотОбъект["ПредыдущийТипОбъекта"] = Объект.ТипОбъекта;
	Иначе
		ЭтотОбъект["ПредыдущийТипОбъекта"] = ДопПараметры.Предыдущий;
		Объект.ТипОбъекта = ДопПараметры.Предыдущий;
		Возврат;
	КонецЕсли;
	
	ТипОбъекта_ПриИзменении(Истина);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ИзменитьТипОР(НовыйТип, ТОР)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОбъектыРемонта.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.ТиповойОР = &ТОР
		|	И НЕ торо_ОбъектыРемонта.ТипОбъекта = &ТипОбъекта";
	
	Запрос.УстановитьПараметр("ТипОбъекта", НовыйТип);
	Запрос.УстановитьПараметр("ТОР", ТОР);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Попытка
			ТекОб = Выборка.Ссылка.ПолучитьОбъект();
			ТекОб.ТипОбъекта = НовыйТип;
			ТекОб.Записать();
		Исключение
			Сообщение = Новый СообщениеПользователю();
			// >> [Деснол] [Ушаков А.Д.] [08.11.2019] 
			Сообщение.Текст = НСтр("ru = 'Не удалось изменить тип '; en = 'Failed to change the type '; es = 'No se puede cambiar el tipo de '")+Выборка.Ссылка+" : "+ОписаниеОшибки();
			// << [Деснол] [Ушаков А.Д.] [08.11.2019] 
			Сообщение.Сообщить();
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВСоставеЕстьОР(ТОР)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	торо_ОбъектыРемонта.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.ТиповойОР = &ТОР";
	Запрос.УстановитьПараметр("ТОР", ТОР);
	РезультатЗапроса = Запрос.Выполнить();
	Возврат Не РезультатЗапроса.Пустой();	
КонецФункции

&НаСервере
Процедура ЗаполнитьДеревоОграничений()

	Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
	Корень.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Иерархия КАК ТекИерархия,
		|	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ограничение КАК Ограничение
		|ИЗ
		|	Справочник.торо_ТиповыеОР.ОграниченияНаХарактеристикиОборудования КАК торо_ТиповыеОРОграниченияНаХарактеристикиОборудования
		|ГДЕ
		|	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ссылка = &Ссылка
		|ИТОГИ ПО
		|	ТекИерархия";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка1 = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка1.Следующий() Цикл
		НоваяСтрока = Корень.Добавить();
		НоваяСтрока.Иерархия = Выборка1.ТекИерархия;
		Ветвь = НоваяСтрока.ПолучитьЭлементы();
		
		Выборка = Выборка1.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока1 = Ветвь.Добавить();
			НоваяСтрока1.Иерархия = Выборка1.ТекИерархия;
			НоваяСтрока1.Ограничение = Выборка.Ограничение;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьДеревоОграничений(ТекущийОбъект)
	ТекущийОбъект.ОграниченияНаХарактеристикиОборудования.Очистить();
	Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
	Для Каждого СтрокаТаблицы Из Корень Цикл
		Ветвь = СтрокаТаблицы.ПолучитьЭлементы();
		Для Каждого СтрокаТаблицы1 Из Ветвь Цикл
			НоваяСтрока = ТекущийОбъект.ОграниченияНаХарактеристикиОборудования.Добавить();
			НоваяСтрока.Иерархия = СтрокаТаблицы.Иерархия;
			НоваяСтрока.Ограничение = СтрокаТаблицы1.Ограничение;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

