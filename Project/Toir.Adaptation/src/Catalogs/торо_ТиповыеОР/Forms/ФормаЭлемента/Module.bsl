&НаКлиенте
Процедура Ограничения_ПослеВыбораИерархии(Результат, ДопПараметры)Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда 
		Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
		Для Каждого СтрокаТаблицы Из Корень Цикл
			Если СтрокаТаблицы.Иерархия = Результат Тогда 
				Возврат;
			КонецЕсли;
		КонецЦикла;
		НоваяСтрока = Корень.Добавить();
		НоваяСтрока.Иерархия = Результат;
		
		ЭтотОбъект["МодифицированностьОграничений"] = Истина;
		Модифицированность = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Ограничения_ПослеВыбораОграничения(Результат, ДопПараметры)Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда 
		
		Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
		Ветвь = Неопределено;
		Если ДопПараметры.Иерархия = Неопределено Тогда 
			
			Для Каждого СТ Из Корень Цикл
				Если ЗначениеЗаполнено(СТ.Иерархия)=Ложь Тогда 
					Ветвь = СТ.ПолучитьЭлементы();
					Прервать;
				КонецЕсли;
			КонецЦикла;
		
			Если Ветвь = Неопределено Тогда 
				НоваяСтрока = Корень.Добавить();
				Ветвь = НоваяСтрока.ПолучитьЭлементы();
			КонецЕсли;
		Иначе
			Для Каждого СТ Из Корень Цикл
				Если СТ.Иерархия = ДопПараметры.Иерархия Тогда 
					Ветвь = СТ.ПолучитьЭлементы();
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если Ветвь = Неопределено Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		Для Каждого СтрокаМассива Из Ветвь Цикл
			Если СтрокаМассива.Ограничение = Результат Тогда 
				Возврат;
			КонецЕсли;					
		КонецЦикла;
		НоваяСтрока = Ветвь.Добавить();
		НоваяСтрока.Иерархия = ДопПараметры.Иерархия;
		НоваяСтрока.Ограничение = Результат;
		ЭтотОбъект["МодифицированностьОграничений"] = Истина;
		Модифицированность = Истина;
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Ограничения_Выбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекДанные = Элементы["ТаблицаОграничений"].ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если ЗначениеЗаполнено(ТекДанные.Ограничение) Тогда 
			ПоказатьЗначение(,ТекДанные.Ограничение);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
