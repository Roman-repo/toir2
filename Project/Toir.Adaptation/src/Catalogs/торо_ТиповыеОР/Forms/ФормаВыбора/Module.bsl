&НаСервере
Процедура ДобавитьНовыеЭлементы()
	НЭлем = Элементы.Добавить("дс_Ссылка", Тип("ПолеФормы"), Элементы.Список);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Список.Ссылка";
	НЭлем.Заголовок = НСтр("ru='Наименование';en='Name'");
	Элементы.Переместить(Элементы["дс_Ссылка"], Элементы.Список, Элементы.Наименование);
	Элементы.Наименование.Видимость = Ложь;
	
КонецПроцедуры
