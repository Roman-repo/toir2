&НаКлиенте
Функция ЕстьЗапрещенныеСимволы(Текст, Маска = "абвгдеёжзийклмнопрстуфхьъычцшщэюяАБВГДЕЁЖЗИЙКЛМНОПРСТУФХЬЪЫЧЦШЩЭЮЯ", НовоеЗначение)
	НовоеЗначение = "";
	ЕстьОшибка = Ложь;
	МаскаЗамены = "f,dult`;pbqrkvyjghcnea[m]sxwio'.zF<DULT~:PBQRKVYJGHCNEA{M}SXWIO"">Z";
	Для Счетчик = 1 По СтрДлина(Текст) Цикл
		ТекБуква = Сред(Текст, Счетчик, 1);
		СимволВМаске = СтрНайти(Маска, ТекБуква);
		Если СимволВМаске = 0 Тогда 
			НовоеЗначение = НовоеЗначение + ТекБуква;
		Иначе
			ЕстьОшибка = Истина;
			НовоеЗначение = НовоеЗначение + Сред(МаскаЗамены, СимволВМаске, 1);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЕстьОшибка;
КонецФункции

