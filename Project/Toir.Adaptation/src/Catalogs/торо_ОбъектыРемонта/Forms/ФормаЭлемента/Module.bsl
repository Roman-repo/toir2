&НаКлиенте
&ИзменениеИКонтроль("СписокПараметровНаработкиПередУдалением")
Процедура гкс_СписокПараметровНаработкиПередУдалением(Элемент, Отказ)

	ТекДанные = Элемент.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		#Удаление
		ДанныеНаработки = ТабВыработкиОбъектаРемонта.НайтиСтроки(Новый Структура("Показатель",ТекДанные.Показатель));
		Если ДанныеНаработки.Количество() > 0 Тогда
			ТекстСообщения = НСтр("es='No es posible quitar el índice, si por él es introducida ya la elaboración.';ru='Нельзя удалить показатель, если по нему уже введена наработка.';en='Can not delete a metric if you have already entered a run time for it.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,,,, Отказ);
			Возврат;
		КонецЕсли;
		#КонецУдаления

		НайденныеСтроки = СписокПараметровНаработки.НайтиСтроки(Новый Структура("ОбъектРемонта, Показатель", ТекДанные.ОбъектРемонта, ТекДанные.Показатель));
		Если НайденныеСтроки.Количество() = 1 Тогда
			НайденныеСтроки = ТабМаксимальныхЗначенийНаработки.НайтиСтроки(Новый Структура("ОбъектРемонта, Показатель", ТекДанные.ОбъектРемонта, ТекДанные.Показатель));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				ТабМаксимальныхЗначенийНаработки.Удалить(НайденнаяСтрока);
			КонецЦикла;
			МодифицированностьМаксЗначНаработки = Истина;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры // гкс- [Релиз20]

// гкс+ [] Деснол 24.08.2022
&НаСервере
&ИзменениеИКонтроль("УстановитьПараметрыЗапросовНаСервере")
Процедура гкс_УстановитьПараметрыЗапросовНаСервере()
	#Вставка
	ТекИерархия = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
	
	Если ТекИерархия.ИзменяетсяДокументами Тогда 
		ТекстЗапросаПодчиненных = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии КАК ОР,
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии КАК Родитель
		|ПОМЕСТИТЬ ВсяИерархия
		|ИЗ
		|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
		|			,
		|			СтруктураИерархии = &Структура) КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних"+"
		|;
		| ";
	Иначе
		ТекстЗапросаПодчиненных = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ИерархическиеСтруктурыОР.ОбъектИерархии КАК ОР
		|	торо_ИерархическиеСтруктурыОР.РодительИерархии КАК Родитель
		|ПОМЕСТИТЬ ВсяИерархия
		|ИЗ
		|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК торо_ИерархическиеСтруктурыОР
		|ГДЕ
		|	торо_ИерархическиеСтруктурыОР.СтруктураИерархии = &Структура  "+"
		|;
		| ";
	КонецЕсли;
	ТекстЗапросаПодчиненных = ТекстЗапросаПодчиненных + "Выбрать ВсяИерархия.ОР КАК ОР
	|Поместить Уровень1
	|ИЗ ВсяИерархия КАК ВсяИерархия
	|Где ВсяИерархия.Родитель = &Ссылка
	| ; 
	|Выбрать ВсяИерархия.ОР КАК ОР
	|Поместить Уровень2
	|ИЗ Уровень1 КАК Уровень1
	|	Внутреннее соединение ВсяИерархия КАК ВсяИерархия
	|	ПО ВсяИерархия.Родитель = Уровень1.ОР
	| ; 
	|Выбрать ВсяИерархия.ОР КАК ОР
	|Поместить Уровень3
	|ИЗ Уровень2 КАК Уровень1
	|	Внутреннее соединение ВсяИерархия КАК ВсяИерархия
	|	ПО ВсяИерархия.Родитель = Уровень1.ОР
	| ; 
	|Выбрать ВсяИерархия.ОР КАК ОР
	|Поместить Уровень4
	|ИЗ Уровень3 КАК Уровень1
	|	Внутреннее соединение ВсяИерархия КАК ВсяИерархия
	|	ПО ВсяИерархия.Родитель = Уровень1.ОР
	| ; 
	|Выбрать Различные
	|ВсяИерархия.ОР КАК ОР
	|ИЗ Уровень4 КАК Уровень1
	|	Внутреннее соединение ВсяИерархия КАК ВсяИерархия
	|	ПО ВсяИерархия.Родитель = Уровень1.ОР
	|
	|Объединить все
	|
	|Выбрать Различные
	|Уровень4.ОР
	|ИЗ Уровень4 КАК Уровень4
	|
	|Объединить все
	|
	|Выбрать Различные
	|Уровень3.ОР
	|ИЗ Уровень3 КАК Уровень3
	|
	|Объединить все
	|
	|Выбрать Различные
	|Уровень2.ОР
	|ИЗ Уровень2 КАК Уровень2
	|
	|Объединить все
	|
	|Выбрать Различные
	|Уровень1.ОР
	|ИЗ Уровень1 КАК Уровень1
	|";
	Запрос = Новый Запрос();
	Запрос.Текст = ТекстЗапросаПодчиненных;
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Структура", ТекИерархия);
	// гкс+ [] Деснол 10.10.2022
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		МассивОР = Новый Массив();
		Пока Выборка.Следующий() Цикл
			МассивОР.Добавить(Выборка.ОР);
		КонецЦикла;
		МассивОР.Добавить(Объект.Ссылка);
	Иначе
		МассивОР = Новый Массив();
	КонецЕсли;
	// гкс- [] Деснол 10.10.2022
	#КонецВставки

	Кнопка = Элементы.ЗаявкиНаРемонтОтображатьТолькоПроведенныеЗаявки;
	ЗаявкиНаРемонт.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	ЗаявкиНаРемонт.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);

	Кнопка = Элементы.ВыявленныеДефектыОтображатьТолькоПроведенныеДефекты;
	ВыявленныеДефекты.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);
	ВыявленныеДефекты.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);

	Кнопка = Элементы.ВыполненныеРемонтыОтображатьТолькоПроведенныеАкты;
	ВыполненныеРемонты.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	ВыполненныеРемонты.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);                             

	Кнопка = Элементы.ПредстоящиеРемонтыОтображатьТолькоПроведенныеППР;
	ПредстоящиеРемонты.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	ПредстоящиеРемонты.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);
	ПредстоящиеРемонты.Параметры.УстановитьЗначениеПараметра("ДатаНачала", ТекущаяДата());

	Кнопка = Элементы.ПредстоящиеРегМероприятияОтображатьТолькоПроведенныеРМ;
	ПредстоящиеРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	ПредстоящиеРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);
	ПредстоящиеРегМероприятия.Параметры.УстановитьЗначениеПараметра("ДатаНачала", ТекущаяДата());

	Кнопка = Элементы.НарядыОтображатьТолькоПроведенныеНаряды;
	НарядыНаВыполнениеРемонтныхРабот.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	НарядыНаВыполнениеРемонтныхРабот.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);

	Кнопка = Элементы.АктыПриемкиОтображатьТолькоПроведенныеАкты;
	АктыПриемкиОборудования.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	АктыПриемкиОборудования.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);

	Кнопка = Элементы.НарядыРМОтображатьТолькоПроведенные;
	НарядыНаРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	НарядыНаРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);

	Кнопка = Элементы.ВыполненныеРМОтображатьТолькоПроведенные;
	ВыполненныеРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОтображатьТолькоПроведенные", Кнопка.Пометка);
	ВыполненныеРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", Объект.Ссылка);

	#Вставка
	ЗаявкиНаРемонт.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	ВыявленныеДефекты.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	ВыполненныеРемонты.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);                             
	ПредстоящиеРемонты.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	ПредстоящиеРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	НарядыНаВыполнениеРемонтныхРабот.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	АктыПриемкиОборудования.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	НарядыНаРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	ВыполненныеРегМероприятия.Параметры.УстановитьЗначениеПараметра("ОбъектРемонта", МассивОР);
	#КонецВставки
КонецПроцедуры
