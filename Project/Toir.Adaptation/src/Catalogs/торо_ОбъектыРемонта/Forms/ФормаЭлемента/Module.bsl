	ТекДанные = Элементы["ТаблицаОграничений"].ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если ЗначениеЗаполнено(ТекДанные.Ограничение) Тогда 
			ПоказатьЗначение(, ТекДанные.Ограничение);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Ограничения_ДобавитьИерархию(Команда)
	СтруктураОпОп = Новый Структура("МножественныйВыбор",Ложь);
	ОписаниеОповещенияПослеДобавления = Новый ОписаниеОповещения("Ограничения_ПослеВыбораИерархии", ЭтотОбъект);
	ОткрытьФорму("Справочник.торо_СтруктурыОР.ФормаВыбора", СтруктураОпОп,,,,,
		ОписаниеОповещенияПослеДобавления, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура Ограничения_ДобавитьОграничение(Команда)
	ТекДанные = Элементы["ТаблицаОграничений"].ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		СтруктураОпОп = Новый Структура("Иерархия", ТекДанные.Иерархия);
		ОписаниеОповещенияПослеДобавления = Новый ОписаниеОповещения("Ограничения_ПослеВыбораОграничения",
			ЭтотОбъект, СтруктураОпОп);
		ОткрытьФорму("Справочник.торо_ОграниченияНаХарактеристикиОбрудования.ФормаВыбора",
			Новый Структура("МножественныйВыбор", Ложь),,,,,
			ОписаниеОповещенияПослеДобавления, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Ограничения_ДобавитьОграничениеВсем(Команда)
	
	СтруктураОпОп = Новый Структура("Иерархия",Неопределено);
	ОписаниеОповещенияПослеДобавления = Новый ОписаниеОповещения("Ограничения_ПослеВыбораОграничения",
		ЭтотОбъект, СтруктураОпОп);
	ОткрытьФорму("Справочник.торо_ОграниченияНаХарактеристикиОбрудования.ФормаВыбора",
		Новый Структура("МножественныйВыбор", Ложь),,,,,
		ОписаниеОповещенияПослеДобавления, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура Ограничения_ПослеВыбораИерархии(Результат, ДопПараметры)Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда 
		Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
		Для Каждого СтрокаКорня Из Корень Цикл
			Если СтрокаКорня.Иерархия = Результат Тогда 
				Возврат;
			КонецЕсли;
		КонецЦикла;
		НоваяСтрокаКорня = Корень.Добавить();
		НоваяСтрокаКорня.Иерархия = Результат;
		
		ЭтотОбъект["МодифицированностьОграничений"] = Истина;
		Модифицированность = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Ограничения_ПослеВыбораОграничения(Результат, ДопПараметры)Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда 
		
		Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
		Ветвь = Неопределено;
		Если ДопПараметры.Иерархия = Неопределено Тогда 
			
			Для Каждого СтрокаКорня Из Корень Цикл
				Если ЗначениеЗаполнено(СтрокаКорня.Иерархия)=Ложь Тогда 
					Ветвь = СтрокаКорня.ПолучитьЭлементы();
					Прервать;
				КонецЕсли;
			КонецЦикла;
		
			Если Ветвь = Неопределено Тогда 
				НоваяСтрокаКорня = Корень.Добавить();
				Ветвь = НоваяСтрокаКорня.ПолучитьЭлементы();
			КонецЕсли;
		Иначе
			Для Каждого СтрокаКорня Из Корень Цикл
				Если СтрокаКорня.Иерархия = ДопПараметры.Иерархия Тогда 
					Ветвь = СтрокаКорня.ПолучитьЭлементы();
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если Ветвь = Неопределено Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		Для Каждого СтрокаВетви Из Ветвь Цикл
			Если СтрокаВетви.Ограничение = Результат Тогда 
				СтрокаВетви.Собственное = Истина;
				Возврат;
			КонецЕсли;					
		КонецЦикла;
		НоваяСтрокаВетви = Ветвь.Добавить();
		НоваяСтрокаВетви.Иерархия = ДопПараметры.Иерархия;
		НоваяСтрокаВетви.Ограничение = Результат;
		НоваяСтрокаВетви.Собственное = Истина;
		ЭтотОбъект["МодифицированностьОграничений"] = Истина;
		Модифицированность = Истина;
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьОР(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда 
		Сообщить = Новый СообщениеПользователю();
		Сообщить.Текст = НСтр("ru = 'Необходимо записать объект.';
			| en = 'you Need to write the object.'; es = 'Debe escribir un objeto.'");
		Сообщить.Сообщить();
		Возврат;
	КонецЕсли;
	ПроверитьОРНаСервере(Объект.Ссылка);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПроверитьОРНаСервере(Ссылка)
	Результат = гкс_ПроверкаФункциональныхМест.ПроверитьОграниченияМассиваОР(,Ссылка);
	Если ТипЗнч(Результат) = Тип("Структура") Тогда 
		Если Результат.НеПодходят.Количество() = 0 Тогда 
			Сообщить = Новый СообщениеПользователю();
			Сообщить.Текст = НСтр("ru = 'Все объекты ремонта удовлетворяют требованиям.';
				| en = 'All repair facilities meet the requirements.';
				| es = 'Todos los objetos de la reparación satisfacen sus necesidades.'");
			Сообщить.Сообщить();
		Иначе
			Для Каждого СтрокаТаблицы ИЗ Результат.НеПодходят Цикл
				Сообщить = Новый СообщениеПользователю();
				Сообщить.Текст = НСтр("ru = 'Объект '; en = 'Object '; es = 'el Objeto '")
					+ СтрокаТаблицы.Ссылка+НСтр("en=' do not meet the requirements FP: ';
					|es=' no cumplen con los requisitos de fm: '
					|;ru=' не соответствуют требованиям ФМ: '")
					+ СтрокаТаблицы.ТекстТребований;
