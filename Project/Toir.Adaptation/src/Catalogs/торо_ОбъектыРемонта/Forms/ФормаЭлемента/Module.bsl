	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндексКартинки,
	|	торо_АктПриемкиОборудованияРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта
	|{ВЫБРАТЬ
	|	ОбъектРемонта.*}
	|ИЗ
	|	Документ.торо_АктПриемкиОборудования.РемонтыОборудования КАК торо_АктПриемкиОборудованияРемонтыОборудования
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_АктПриемкиОборудования КАК торо_АктПриемкиОборудования
	|		ПО торо_АктПриемкиОборудованияРемонтыОборудования.Ссылка = торо_АктПриемкиОборудования.Ссылка";
	Если ТекВидимость Тогда 
		АктыПриемкиОборудования.ТекстЗапроса = АктыПриемкиОборудования.ТекстЗапроса + "
		|ГДЕ
		// гкс+ [] Деснол 24.08.2022
		|	торо_АктПриемкиОборудованияРемонтыОборудования.ОбъектРемонта В (&ОбъектРемонта)";
		// гкс- [] Деснол 24.08.2022
	Иначе
		АктыПриемкиОборудования.ТекстЗапроса = АктыПриемкиОборудования.ТекстЗапроса + "
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПодчиненныеОР КАК ПодчиненныеОР
		|		ПО (ПодчиненныеОР.ОР = торо_АктПриемкиОборудованияРемонтыОборудования.ОбъектРемонта)
		|ГДЕ
		// гкс+ [] Деснол 24.08.2022
		|	торо_АктПриемкиОборудованияРемонтыОборудования.ОбъектРемонта В (&ОбъектРемонта) ИЛИ Не ПодчиненныеОР.ОР Есть Null";
		// гкс- [] Деснол 24.08.2022
	КонецЕсли;
	АктыПриемкиОборудования.ТекстЗапроса = АктыПриемкиОборудования.ТекстЗапроса + "
	
	|	И ВЫБОР
	|			КОГДА &ОтображатьТолькоПроведенные
	|				ТОГДА торо_АктПриемкиОборудования.Проведен
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|УПОРЯДОЧИТЬ ПО
	|	ОбъектРемонта";

	// гкс+ [10.22] Деснол 12.10.2022
	ПредстоящиеРегМероприятия.ТекстЗапроса = СтрЗаменить(ПредстоящиеРегМероприятия.ТекстЗапроса , "= &ОбъектРемонта", "В (&ОбъектРемонта)");
	НарядыНаРегМероприятия.ТекстЗапроса = СтрЗаменить(НарядыНаРегМероприятия.ТекстЗапроса , "= &ОбъектРемонта", "В (&ОбъектРемонта)");
	ВыполненныеРегМероприятия.ТекстЗапроса = СтрЗаменить(ВыполненныеРегМероприятия.ТекстЗапроса , "= &ОбъектРемонта", "В (&ОбъектРемонта)");
	// гкс- [10.22] Деснол 12.10.2022
КонецПроцедуры

&НаКлиенте
Процедура ГарантииОбъектаРемонта_ПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	Если Объект.ТипОбъекта = торо_ОбщегоНазначенияКлиентПовтИсп.ПолучитьПеречисление("торо_ТипыОбъектовRCM",
			"ФункциональноеМесто") Тогда 
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТиповойСостав_Добавить(Команда)
	ОписаниеОповещенияПослеВыбора = Новый ОписаниеОповещения("ТиповойСостав_ДобавитьПослеВыбора", ЭтотОбъект);
	ОткрытьФорму("Справочник.торо_ТиповыеОР.ФормаВыбора", Новый Структура("МножественныйВыбор", Ложь),,,,,
		ОписаниеОповещенияПослеВыбора, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ТиповойСостав_ДобавитьПослеВыбора(Результат,ДопПараметры)Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда 
		Если ТипЗнч(Результат) = Тип("СправочникСсылка.торо_ТиповыеОР") Тогда 
			НоваяСтрока = ЭтотОбъект["ТиповойСостав"].Добавить();
			НоваяСтрока.ТОР = Результат;
		Иначе
			Для Каждого СтрокаМассива Из Результат Цикл
				НоваяСтрока = ЭтотОбъект["ТиповойСостав"].Добавить();
				НоваяСтрока.ТОР = СтрокаМассива;
			КонецЦикла;
		КонецЕсли;
		ЭтотОбъект["МодифицированностьСостава"] = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТиповойСостав_Удалить(Команда)
	ТекДанные = Элементы["ТиповойСостав"].ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ЭтотОбъект["ТиповойСостав"].Удалить(ТекДанные);
		ЭтотОбъект["МодифицированностьСостава"] = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТиповойСостав_Проставить(Команда)
	ТиповойСостав_ПроставитьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ТиповойСостав_ПроставитьНаСервере()
	Если ЗначениеЗаполнено(Объект.Ссылка)= Ложь Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Необходимо записать объект";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	ТЧ = Новый ТаблицаЗначений();
	ТЧ.Колонки.Добавить("ТОР",Новый ОписаниеТипов("СправочникСсылка.торо_ТиповыеОР"));
	Для Каждого СтрокаТаблицы ИЗ ЭтотОбъект["ТиповойСостав"] Цикл
		НоваяСтрока = ТЧ.Добавить();
		НоваяСтрока.ТОР = СтрокаТаблицы.ТОР;
	КонецЦикла;
	
	ЭтотОбъект["ТиповойСостав"].Очистить();
	ЭтотОбъект["НераспределенныйСостав"].Очистить();
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.ТОР КАК ТОР
		|ПОМЕСТИТЬ Исходная
		|ИЗ
		|	&ТЧ КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ИерархическиеСтруктурыОР.ОбъектИерархии КАК ОбъектРемонта,
		|	торо_ИерархическиеСтруктурыОР.ОбъектИерархии.ТиповойОР КАК ТипОборудования,
		|	торо_ИерархическиеСтруктурыОР.ОбъектИерархии.ТиповойОР.Родитель КАК ТОРРодитель
		|ПОМЕСТИТЬ Оры
		|ИЗ
		|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК торо_ИерархическиеСтруктурыОР
		|ГДЕ
		|	торо_ИерархическиеСтруктурыОР.РодительИерархии = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии,
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии.ТиповойОР,
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии.ТиповойОР.Родитель
		|ИЗ
		|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних
		|ГДЕ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Исходная.ТОР КАК ТОР
		|ПОМЕСТИТЬ УникальныеТОР
		|ИЗ
		|	Исходная КАК Исходная
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	УникальныеТОР.ТОР КАК ТОР,
		|	Оры.ОбъектРемонта КАК ОР,
		|	Оры.ОбъектРемонта.ДатаВыпуска КАК ОРДатаУстановки,
		|	Оры.ОбъектРемонта.ДатаВводаВЭксплуатацию КАК ОРДатаВвода,
		|	Оры.ОбъектРемонта.ЗаводскойНомер КАК ОРЗаводской,
		|	Оры.ОбъектРемонта.ИнвентарныйНомер КАК ОРИнвентарный,
		|	ВЫБОР
		|		КОГДА УникальныеТОР.ТОР = Оры.ОбъектРемонта
		|			ТОГДА 1
		|		КОГДА Оры.ТОРРодитель = УникальныеТОР.ТОР
		|			ТОГДА 2
		|		ИНАЧЕ 3
		|	КОНЕЦ КАК Приоритет
		|ИЗ
		|	УникальныеТОР КАК УникальныеТОР
		|		ЛЕВОЕ СОЕДИНЕНИЕ Оры КАК Оры
		|		ПО УникальныеТОР.ТОР = Оры.ТипОборудования
		|			ИЛИ УникальныеТОР.ТОР = Оры.ТОРРодитель
		|
		|УПОРЯДОЧИТЬ ПО
		|	Приоритет
		|ИТОГИ ПО
		|	ТОР
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ Различные
		|	Оры.ОбъектРемонта КАК ОР,
		|	Оры.ТипОборудования КАК ТОР
		|ИЗ
		|	Оры КАК Оры
		|		ЛЕВОЕ СОЕДИНЕНИЕ УникальныеТОР КАК УникальныеТОР
		|		ПО Оры.ТипОборудования = УникальныеТОР.ТОР
		|			ИЛИ Оры.ТОРРодитель = УникальныеТОР.ТОР
		|ГДЕ
		|	УникальныеТОР.ТОР ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("ТЧ", ТЧ);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка1 = РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	РазличныеОР = Новый Массив();
	НомерПП = 1;
	Пока Выборка1.Следующий() Цикл
		ЭтоПервый = Истина;
		Выборка = Выборка1.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка.ОР) Тогда 
				Если РазличныеОР.Найти(Выборка.ОР) = Неопределено Тогда 
					РазличныеОР.Добавить(Выборка.ОР);
				Иначе
					Продолжить;
				КонецЕсли;
				НоваяСтрока = ЭтотОбъект["ТиповойСостав"].Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);				
				НоваяСтрока.НомерПП = НомерПП;
				НомерПП = НомерПП + 1;
				ЭтоПервый = Ложь;
			КонецЕсли;
		КонецЦикла;
		Если ЭтоПервый Тогда 
			НоваяСтрока = ЭтотОбъект["ТиповойСостав"].Добавить();
			НоваяСтрока.ТОР = Выборка1.ТОР;
			НоваяСтрока.НомерПП = НомерПП;
			НомерПП = НомерПП + 1;
		КонецЕсли;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[4].Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ЭтотОбъект["НераспределенныйСостав"].Добавить();
		НоваяСтрока.ТОР = Выборка.ТОР;
		НоваяСтрока.ОР = Выборка.ОР;
	КонецЦикла;
	
	ЭтотОбъект["МодифицированностьСостава"] = Истина;
КонецПроцедуры

&НаСервере
Процедура ТиповойСостав_Записать()
	Если ЗначениеЗаполнено(Объект.Ссылка)= Ложь Тогда 
		Возврат;
	КонецЕсли;
	НаборЗаписей = РегистрыСведений.торо_ТиповойСоставФункциональныхМест.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ФункциональноеМесто.Установить(Объект.Ссылка);
	НаборЗаписей.Записать();
	
	НаборЗаписей = РегистрыСведений.торо_СоставФункциональныхМест.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ФункциональноеМесто.Установить(Объект.Ссылка);
	НаборЗаписей.Записать();
		
	//
	ТЧ = Новый ТаблицаЗначений();
	ТЧ.Колонки.Добавить("ТОР",Новый ОписаниеТипов("СправочникСсылка.торо_ТиповыеОР"));
	ТЧ.Колонки.Добавить("ОР",Новый ОписаниеТипов("СправочникСсылка.торо_ОбъектыРемонта"));
	Для Каждого СтрокаТаблицы ИЗ ЭтотОбъект["ТиповойСостав"] Цикл
		НоваяСтрока = ТЧ.Добавить();
		НоваяСтрока.ТОР = СтрокаТаблицы.ТОР;
		НоваяСтрока.ОР = СтрокаТаблицы.ОР;
	КонецЦикла;
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.ТОР КАК ТОР,
		|	ТЧ.ОР КАК ОР
		|ПОМЕСТИТЬ Исходная
		|ИЗ
		|	&ТЧ КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Исходная.ТОР КАК ТОР,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Исходная.ОР) КАК Количество
		|ИЗ
		|	Исходная КАК Исходная
		|
		|СГРУППИРОВАТЬ ПО
		|	Исходная.ТОР
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Исходная.ОР КАК ОР,
		|	Исходная.ТОР КАК ТОР
		|ИЗ
		|	Исходная КАК Исходная
		|ГДЕ
		|	НЕ Исходная.ОР = ЗНАЧЕНИЕ(Справочник.торо_ОбъектыРемонта.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("ТЧ", ТЧ);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.торо_ТиповойСоставФункциональныхМест.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ФункциональноеМесто.Установить(Объект.Ссылка);
		НаборЗаписей.Отбор.ТипОборудования.Установить(Выборка.ТОР);
		НоваяСтрока = НаборЗаписей.Добавить();
		НоваяСтрока.ФункциональноеМесто = Объект.Ссылка;
		НоваяСтрока.ТипОборудования = Выборка.ТОР;
		НоваяСтрока.Количество = Выборка.Количество;
		НаборЗаписей.Записать();
	КонецЦикла;
	
	Выборка = РезультатЗапроса[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.торо_СоставФункциональныхМест.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ФункциональноеМесто.Установить(Объект.Ссылка);
		НаборЗаписей.Отбор.ТипОборудования.Установить(Выборка.ТОР);
		НаборЗаписей.Отбор.ОбъектРемонта.Установить(Выборка.ОР);
		НоваяСтрока = НаборЗаписей.Добавить();
		НоваяСтрока.ФункциональноеМесто = Объект.Ссылка;
		НоваяСтрока.ТипОборудования = Выборка.ТОР;
		НоваяСтрока.ОбъектРемонта = Выборка.ОР;
		НаборЗаписей.Записать();
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ТиповойСостав_Загрузить()
	Если ЗначениеЗаполнено(Объект.Ссылка)= Ложь Тогда 
		Возврат;
	КонецЕсли;
	ЭтотОбъект["ТиповойСостав"].Очистить();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ИерархическиеСтруктурыОР.ОбъектИерархии КАК ОбъектРемонта,
		|	торо_ИерархическиеСтруктурыОР.ОбъектИерархии.ТиповойОР КАК ТипОборудования
		|ПОМЕСТИТЬ Оры
		|ИЗ
		|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК торо_ИерархическиеСтруктурыОР
		|ГДЕ
		|	торо_ИерархическиеСтруктурыОР.РодительИерархии = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии,
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.ОбъектИерархии.ТиповойОР
		|ИЗ
		|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних КАК торо_РасположениеОРВСтруктуреИерархииСрезПоследних
		|ГДЕ
		|	торо_РасположениеОРВСтруктуреИерархииСрезПоследних.РодительИерархии = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ТиповойСоставФункциональныхМест.ТипОборудования КАК ТОР,
		|	торо_СоставФункциональныхМест.ОбъектРемонта КАК ОР,
		|	торо_СоставФункциональныхМест.ОбъектРемонта.ДатаВводаВЭксплуатацию КАК ОРДатаВвода,
		|	торо_СоставФункциональныхМест.ОбъектРемонта.ДатаВыпуска КАК ОРДатаУстановки,
		|	торо_СоставФункциональныхМест.ОбъектРемонта.ЗаводскойНомер КАК ОРЗаводской,
		|	торо_СоставФункциональныхМест.ОбъектРемонта.ИнвентарныйНомер КАК ОРИнвентарный
		|ПОМЕСТИТЬ Состав
		|ИЗ
		|	РегистрСведений.торо_ТиповойСоставФункциональныхМест КАК торо_ТиповойСоставФункциональныхМест
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СоставФункциональныхМест КАК торо_СоставФункциональныхМест
		|		ПО торо_ТиповойСоставФункциональныхМест.ФункциональноеМесто = торо_СоставФункциональныхМест.ФункциональноеМесто
		|			И торо_ТиповойСоставФункциональныхМест.ТипОборудования = торо_СоставФункциональныхМест.ТипОборудования
		|ГДЕ
		|	торо_ТиповойСоставФункциональныхМест.ФункциональноеМесто = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ Различные
		|	Состав.ТОР КАК ТОР,
		|	Состав.ОР КАК ОР,
		|	Состав.ОРДатаВвода КАК ОРДатаВвода,
		|	Состав.ОРДатаУстановки КАК ОРДатаУстановки,
		|	Состав.ОРЗаводской КАК ОРЗаводской,
		|	Состав.ОРИнвентарный КАК ОРИнвентарный
		|ИЗ
		|	Состав КАК Состав
		|ИТОГИ ПО
		|	ТОР
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ  Различные
		|	Оры.ОбъектРемонта КАК ОР,
		|	Оры.ТипОборудования КАК ТОР
		|ИЗ
		|	Оры КАК Оры
		|		ЛЕВОЕ СОЕДИНЕНИЕ Состав КАК Состав
		|		ПО Оры.ОбъектРемонта = Состав.ОР
		|ГДЕ
		|	Состав.ОР ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка1 = РезультатЗапроса[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	НомерПП = 1;
	Пока Выборка1.Следующий() Цикл
		ЭтоПервый = Истина;
		Выборка = Выборка1.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка.ОР) Тогда 
				НоваяСтрока = ЭтотОбъект["ТиповойСостав"].Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);				
				НоваяСтрока.НомерПП = НомерПП;
				НомерПП = НомерПП + 1;
				ЭтоПервый = Ложь;
			КонецЕсли;
		КонецЦикла;
		Если ЭтоПервый Тогда 
			НоваяСтрока = ЭтотОбъект["ТиповойСостав"].Добавить();
			НоваяСтрока.ТОР = Выборка1.ТОР;
			НоваяСтрока.НомерПП = НомерПП;
			НомерПП = НомерПП + 1;
		КонецЕсли;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[3].Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ЭтотОбъект["НераспределенныйСостав"].Добавить();
		НоваяСтрока.ТОР = Выборка.ТОР;
		НоваяСтрока.ОР = Выборка.ОР;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура гкс_ТегПриИзменении(Элемент)
	МодифицированностьИзмеряемыхПоказателей = Истина;
	
	ТекДанные = Элементы.СписокИзмеряемыхПоказателей.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекущийТег = ТекДанные.гкс_Тег;
		НовыйТекст = "";
		Если ЕстьЗапрещенныеСимволы(ТекущийТег, , НовыйТекст) Тогда 
			ТекДанные.гкс_Тег = НовыйТекст;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru='Для тега можно использовать только латинские символы и цифры'");
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЕсли;
	
