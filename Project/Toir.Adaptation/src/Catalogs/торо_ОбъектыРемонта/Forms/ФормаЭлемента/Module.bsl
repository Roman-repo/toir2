// гкс+ [04.23] Деснол 14.04.2023
&НаКлиенте
Процедура гкс_СоздатьТМ(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Если ЗначениеЗаполнено(ЭтотОбъект["гкс_ТМ"]) Тогда 
			Элементы["гкс_СоздатьТМКнопка"].Видимость = Ложь;
			Возврат;
		КонецЕсли;
		ОпОп = Новый ОписаниеОповещения("гкс_СоздатьТМПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(ОпОп, "Для объекта будет создано собственное техническое место. Редактироваться оно будет отдельно. Процесс необратим. Продолжить?", РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
КонецПроцедуры // гкс- [04.23] Деснол 14.04.2023

// гкс+ [04.23] Деснол 14.04.2023
&НаКлиенте
Процедура гкс_СоздатьТМПослеВопроса(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда 
		Элементы["гкс_СоздатьТМКнопка"].Видимость = Ложь;
		Элементы["гкс_ТМ"].Видимость = Истина;
		Элементы["гкс_ТМФМ"].Видимость = Ложь;
		гкс_СкопироватьТМ();
	КонецЕсли;
КонецПроцедуры // гкс- [04.23] Деснол 14.04.2023

// гкс+ [04.23] Деснол 14.04.2023
&НаСервере
Процедура гкс_СкопироватьТМ()
	Если ЗначениеЗаполнено(ЭтотОбъект["гкс_ТМФМ"]) Тогда 
		ОбъектТехническоеМесто = ЭтотОбъект["гкс_ТМФМ"].Скопировать();
		ОбъектТехническоеМесто.Наименование = Объект.Ссылка;
		ОбъектТехническоеМесто.Записать();
	Иначе
		ОбъектТехническоеМесто = Справочники.гкс_ТехническиеМеста.СоздатьЭлемент();
		ОбъектТехническоеМесто.Наименование = Объект.Ссылка;
		ОбъектТехническоеМесто.Записать();
	КонецЕсли;
	ЭтотОбъект["гкс_ТМ"] = ОбъектТехническоеМесто.Ссылка;
	
	ТекущееФункциональноеМесто = гкс_ПроверкаФункциональныхМест.НайтиФМ(Объект.Ссылка);
	НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
	НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Объект.Ссылка);
	НоваяСтрокаНабораЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
	НоваяСтрокаНабораЗаписей.ОР = Объект.Ссылка;
	НоваяСтрокаНабораЗаписей.ФМ = ТекущееФункциональноеМесто;
	НоваяСтрокаНабораЗаписей.ТМ = ОбъектТехническоеМесто.Ссылка;
	НоваяСтрокаНабораЗаписей.ТМФМ = Неопределено;
	НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
КонецПроцедуры // гкс- [04.23] Деснол 14.04.2023



