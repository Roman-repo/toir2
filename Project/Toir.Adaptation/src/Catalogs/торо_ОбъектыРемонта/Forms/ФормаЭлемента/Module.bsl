&НаКлиенте
Процедура ТаблицаОграничений_ПередУдалением(Элемент, Отказ)
	ТекДанные = Элементы["ТаблицаОграничений"].ТекущиеДанные;
	Если Не ТекДанные = Неопределено И ТекДанные.Собственное = Ложь Тогда 
		ТекДанные.гкс_Удален = Не ТекДанные.гкс_Удален;
		ЭтотОбъект["МодифицированностьОграничений"] = Истина;
		Модифицированность = Истина;
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ЭтотОбъект["МодифицированностьОграничений"] = Истина;
	Модифицированность = Истина;
КонецПроцедуры

