&НаКлиенте
Процедура ОткрытьМатрицуОценкиРисков(Команда)
	
	МассивВыбранныхЗначений = Новый Массив;
	
	Для Каждого Строка Из Объект.гкс_ВыборИзМатрицы Цикл
		СтруктураВыбранных = Новый Структура;
		СтруктураВыбранных.Вставить("ОбъектВоздействия", Строка.ОбъектВоздействия);
		СтруктураВыбранных.Вставить("КатегорияРиска"   , Строка.КатегорияРиска);
		СтруктураВыбранных.Вставить("Комментарий"   , Строка.Комментарий);
		МассивВыбранныхЗначений.Добавить(СтруктураВыбранных);
	КонецЦикла; 
	СтруктураОпОп = Новый Структура();
	ОпОп = Новый ОписаниеОповещения("ПолучитьРезультатМатрицы",ЭтотОбъект,СтруктураОпОп);
	ОткрытьФорму("Обработка.торо_МатрицаОценкиРисков.Форма.ФормаПодбора",
		Новый Структура("ДатаОбнаружения, МассивВыбранныхЗначений, КлючНазначенияИспользования,Комментарий", ТекущаяДата(),
		МассивВыбранныхЗначений, "ПодборКатегорииРискаВДефект",
		Объект.гкс_КомментарийМатрицы),,,,, ОпОп, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементыМатрицы()
	НЭлем = Элементы.Добавить("гкс_КатегорияРискаГруппа", Тип("ГруппаФормы"), Элементы.ГруппаДанныеЭксплЛевая);
	НЭлем.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НЭлем.ОтображатьЗаголовок = Ложь;
	Элементы.Переместить(Элементы["гкс_КатегорияРискаГруппа"], Элементы.ГруппаДанныеЭксплЛевая, Элементы.Приоритет);
	Элементы.Приоритет.Видимость = Ложь;
	
	НЭлем = Элементы.Добавить("гкс_КатегорияРиска", Тип("ПолеФормы"), Элементы["гкс_КатегорияРискаГруппа"]);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Объект.гкс_КатегорияРиска";
	НЭлем.АвтоМаксимальнаяШирина = Ложь;
	НЭлем.ТолькоПросмотр = Истина;
	// гкс+ [07.23] Деснол 17.07.2023
	НЭлем = Элементы.Добавить("гкс_КачественнаяОценка", Тип("ПолеФормы"), Элементы["гкс_КатегорияРискаГруппа"]);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Объект.гкс_КачественнаяОценка";
	НЭлем.АвтоМаксимальнаяШирина = Ложь;
	НЭлем.ТолькоПросмотр = Истина;
	// гкс- [07.23] Деснол 17.07.2023
	
	НКом = Команды.Добавить("гкс_ОткрытьМатрицу");
	НКом.Действие = "ОткрытьМатрицуОценкиРисков";
	НКом.Заголовок = НСтр("ru='Открыть матрицу'");
	
	НКом.Картинка = БиблиотекаКартинок.Задача;
	
	НЭлем = Элементы.Добавить("гкс_ОткрытьМатрицу", Тип("КнопкаФормы"), Элементы["гкс_КатегорияРискаГруппа"]);
	НЭлем.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	НЭлем.ИмяКоманды = "гкс_ОткрытьМатрицу";
	НЭлем.Отображение = ОтображениеКнопки.Картинка;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьРезультатМатрицы(Результат, ДопПараметры)Экспорт
	Если Не Результат = Неопределено Тогда 
		Модифицированность = Истина;
		Объект.гкс_КатегорияРиска = Результат.КатегорияРиска;
		// гкс+ [07.23] Деснол 17.07.2023
		Объект.гкс_КачественнаяОценка = Результат.КачественнаяОценка;
		// гкс- [07.23] Деснол 17.07.2023
		Объект.гкс_ВыборИзМатрицы.Очистить();
		Объект.гкс_КомментарийМатрицы = Результат.Комментарий;
		РезультатыВыбора = Новый Массив;			
		Если Результат.Свойство("РезультатыПодбораИзМатрицыОценкиРисков", РезультатыВыбора) Тогда
			Для каждого Строка Из РезультатыВыбора Цикл
				НоваяСтрока = Объект.гкс_ВыборИзМатрицы.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			КонецЦикла; 
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
