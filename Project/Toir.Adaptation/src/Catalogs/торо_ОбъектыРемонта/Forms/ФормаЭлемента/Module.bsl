
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура Расш_гкс_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	ТипОбъекта_ПриИзмененииНаСервере();
	ДобавитьНовыеЭлементыПосле();
	Если Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто Тогда
		ЗаполнитьДеревоОграничений();
		ТиповойСостав_Загрузить();
	КонецЕсли;
	// гкс+ [КатегорияРиска] Куст 19.10.2020
	ДобавитьЭлементыМатрицы();
	// гкс- [КатегорияРиска] Куст 19.10.2020
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("СоздатьФМ") И Параметры.СоздатьФМ Тогда 
		Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто;
	ИначеЕсли ЗначениеЗаполнено(Объект.ТипОбъекта) = Ложь Тогда
		Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.Объект;
	КонецЕсли;
	ДобавитьНовыеЭлементы();
	дс_ПриСозданииНаСервере();
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПередЗаписьюНаСервереПеред(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто Тогда 
		Если ЗначениеЗаполнено(Объект.ДатаВыпуска) = Ложь И ЗначениеЗаполнено(Объект.ДатаВводаВЭксплуатацию) Тогда 
			Объект.ДатаВыпуска = Объект.ДатаВводаВЭксплуатацию-1;
		КонецЕсли;
	КонецЕсли;
	Если ЭтотОбъект["ИзмененТипОбъекта"] И ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		гкс_ПроверкаФункциональныхМест.ОбновитьТекущийФМОР(Объект.Ссылка,
			Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто);
		ЭтотОбъект["ИзмененТипОбъекта"] = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПередЗаписьюНаСервереПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ЭтотОбъект["МодифицированностьОграничений"] Тогда 
		ЗаписатьДеревоОграничений();
		ЭтотОбъект["МодифицированностьОграничений"] = Ложь;
	КонецЕсли;
	Если ЭтотОбъект["МодифицированностьСостава"] Тогда 
		ТиповойСостав_Записать();
		ЭтотОбъект["МодифицированностьСостава"] = Истина;
	КонецЕсли;
	
	дс_ПередЗаписьюНаСервере(ЭтаФорма, Отказ, ТекущийОбъект, ПараметрыЗаписи);
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПриЧтенииНаСервереПосле(ТекущийОбъект)
	ВременнаяСтруктура = Новый Структура("гкс_ТМ,гкс_Кодировка", Неопределено, Неопределено);
	ЗаполнитьЗначенияСвойств(ВременнаяСтруктура, ЭтотОбъект);
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Если Не ВременнаяСтруктура.гкс_ТМ = Неопределено Тогда 
			НайтиТМ(Объект.Ссылка, ЭтотОбъект["гкс_ТМ"], ЭтотОбъект["гкс_ТМФМ"], Объект.ТипОбъекта);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Расш_гкс_ПослеЗаписиНаСервереПосле(ТекущийОбъект, ПараметрыЗаписи)
	дс_ПослеЗаписиНаСервере(ЭтаФорма, ТекущийОбъект, ПараметрыЗаписи);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_КодировкаОР.Текст КАК Текст
		|ИЗ
		|	РегистрСведений.гкс_КодировкаОР КАК гкс_КодировкаОР
		|ГДЕ
		|	гкс_КодировкаОР.ОР = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЭтотОбъект["гкс_Кодировка"] = Выборка.Текст;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Расш_гкс_ПередЗаписьюПеред5656(Отказ, ПараметрыЗаписи)
	Если ЭтотОбъект["ФОИспользоватьФункциональныеМеста"] Тогда 
		Если ЗначениеЗаполнено(Объект.ТипОбъекта) = Ложь Тогда 
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru = 'Не указан тип объекта!'; en = 'Do not specify the type of object!';"
				+" es = 'No se especifica el tipo de objeto!'");
			Сообщение.Поле = "Объект.ТипОбъекта";
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЕсли;
	Если Объект.ТипОбъекта = торо_ОбщегоНазначенияКлиентПовтИсп.ПолучитьПеречисление("торо_ТипыОбъектовRCM",
			"ФункциональноеМесто") Тогда 
		Если ЗначениеЗаполнено(Объект.ДатаВыпуска) = Ложь Тогда 
			Если ЗначениеЗаполнено(Объект.ДатаВводаВЭксплуатацию) Тогда 
				Объект.ДатаВыпуска = Объект.ДатаВводаВЭксплуатацию - 1;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если ЗначениеЗаполнено(Объект.ДатаВыпуска) = Ложь Тогда 
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru = 'Дата выпуска не заполнена'; en = 'Date of issue is not populated';"
				+" es = 'Fecha de lanzamiento no está llena'");
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// гкс+ [05.23] Деснол 10.05.2023
&НаКлиенте
&Вместо("ПередЗаписью")
Процедура гкс_ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Не ЗначениеЗаполнено(Объект.гкс_КатегорияРиска) Тогда 
		ТекстСообщения = "Категория риска не заполнена!";
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ПродолжитьВызов(Отказ, ПараметрыЗаписи);
КонецПроцедуры // гкс- [05.23] Деснол 10.05.2023

&НаСервере
&ИзменениеИКонтроль("ПриСозданииНаСервере")
Процедура Расш_гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ПравоРедактирования = ПравоДоступа("Редактирование", Объект.Ссылка.Метаданные());

	// СтандартныеПодсистемы.Свойства
	Контекст = Новый Структура();
	Контекст.Вставить("Объект",                     Объект);
	Контекст.Вставить("ИмяЭлементаДляРазмещения",   "ГруппаДополнительныеРеквизиты");
	Контекст.Вставить("ПроизвольныйОбъект",         Ложь);
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Контекст);
	// Конец СтандартныеПодсистемы.Свойства

	торо_УправлениеСвойствами.ПроставитьПризнакОбщегоСвойстваВТаблицеДопРеквизитов(ЭтаФорма, Неопределено);
	ПривязатьОбработчикИзмененияДопРеквизитов();
	УнаследоватьДопРеквизитыИзТиповогоОР();

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	// СтандартныеПодсистемы.КонтактнаяИнформация
	УправлениеКонтактнойИнформацией.ПриСозданииНаСервере(ЭтотОбъект, Объект, "КонтактнаяИнформация", ПоложениеЗаголовкаЭлементаФормы.Лево);
	// Конец СтандартныеПодсистемы.КонтактнаяИнформация

	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

	торо_СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка, Новый Структура("УстановитьСвойствоЭлементовФормыОтПрав", Истина));

	Если Параметры.Свойство("СтруктураИерархии") И ЗначениеЗаполнено(Параметры.СтруктураИерархии) Тогда
		ТекСтруктураИерархии = Параметры.СтруктураИерархии;
	Иначе
		ТекСтруктураИерархии = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОписаниеОшибки = "";
		Если слкМенеджерЗащиты.ПроверитьЛицензииСеанса(ОписаниеОшибки) <> Истина Тогда
			ТекстСообщения = НСтр("es='¡La licencia no es descubierta! La creación del objeto de la reparación es imposible.';ru='Лицензия не обнаружена! Создание объекта ремонта невозможно.';en='No license found! Creating a repair facility is not possible.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
			Возврат;
		КонецЕсли;

		РодительИерархии = ?(Параметры.Свойство("РодительИерархии"), Параметры.РодительИерархии, Справочники.торо_ОбъектыРемонта.ПустаяСсылка());
		ЭтоНовыйЭлемент = Истина;

		Модифицированность = Истина;
		ЗаполнитьПослеКопирования();
	КонецЕсли;

	Родитель = НайтиРодителяИерархии(ТекСтруктураИерархии, Объект.Ссылка);
	Если НЕ ЗначениеЗаполнено(Родитель) и ЗначениеЗаполнено(РодительИерархии) Тогда
		Родитель = РодительИерархии;
	КонецЕсли;

	ОтображатьИзображение = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("НастройкиТОиР","ОбъектыРемонта_ОтображатьИзображение", Ложь);

	ТекТиповойОР  = Объект.ТиповойОР;
	ПредТиповойОР = Объект.ТиповойОР;

	ОбновитьЗначенияНаработки = Истина;

	МодифицированностьПараметровНаработки   = Ложь;
	МодифицированностьНормРемонтов          = Ложь;
	МодифицированностьИзмеряемыхПоказателей = Ложь;
	МодифицированностьМаксЗначНаработки = Ложь;

	КоличествоПусков.Загрузить(РегистрыНакопления.торо_КоличествоПусковОР.Обороты('00010101',ТекущаяДата(),Новый Структура("ОбъектРемонта", Объект.Ссылка)));

	// ЖЦ Оборудования++
	ФОИспользоватьДокументыЖЦОборудования = ПолучитьФункциональнуюОпцию("торо_ИспользоватьДокументыПринятияИСписанияОборудования");
	Если ФОИспользоватьДокументыЖЦОборудования Тогда
		ЗаполнитьДатыЭксплуатации();
		УстановитьФлагПланированияИДоступность(Не ЗначениеЗаполнено(Объект.Ссылка));
	КонецЕсли; 
	// ЖЦ Оборудования--

	// Гарантии++
	ФОИспользоватьГарантии = ПолучитьФункциональнуюОпцию("торо_ИспользоватьГарантии");
	Если ФОИспользоватьГарантии Тогда
		#Удаление
		ТаблицаГарантий = торо_ГарантийноеОбслуживание.ПолучитьТаблицуГарантий(Объект.Ссылка);
		#КонецУдаления
		#Вставка
		Если Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто Тогда 
			ТаблицаГарантий = торо_ГарантийноеОбслуживание.ПолучитьТаблицуГарантийФМ(Объект.Ссылка);
		Иначе
			ТаблицаГарантий = торо_ГарантийноеОбслуживание.ПолучитьТаблицуГарантий(Объект.Ссылка);
		КонецЕсли;
		#КонецВставки

		Если Не ТаблицаГарантий = Неопределено  Тогда
			ГарантииОбъектаРемонта.Загрузить(ТаблицаГарантий);
		КонецЕсли; 

		Если ГарантииОбъектаРемонта.Количество() > 0 Тогда
			ЕстьГарантияДляОбъекта = Истина;
		Иначе
			ЕстьГарантияДляОбъекта = Ложь;
		КонецЕсли;

	КонецЕсли;
	// Гарантии--

	// Ремонты_по_состоянию++
	ФОИспользоватьРемонтыПоСостоянию = ПолучитьФункциональнуюОпцию("торо_ИспользоватьРемонтыПоСостоянию");
	// Ремонты_по_состоянию--

	УстановитьВидимостьДоступность(Истина);
	УстановитьПараметрыЗапросовНаСервере();

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПослеЗаписи")
Процедура Расш_гкс_ПослеЗаписи(ПараметрыЗаписи)

	// Для обновления данных в дереве ОР.
	СтруктураРеквизитов = Новый Структура("Ссылка, ПометкаУдаления, Наименование", Объект.Ссылка, Объект.ПометкаУдаления, Объект.Наименование);

	Если ЭтоНовыйЭлемент Тогда
		СтруктураРеквизитов.Вставить("ЭтоНовый", ЭтоНовыйЭлемент);						
		СтруктураРеквизитов.Вставить("СтруктураИерархии", ТекСтруктураИерархии);
		СтруктураРеквизитов.Вставить("РодительИерархии", РодительИерархии);
	КонецЕсли;
	#Вставка
	СтруктураРеквизитов.Вставить("ТипОбъекта", Объект.ТипОбъекта);
	#КонецВставки

	Оповестить("ЗаписанОбъектРемонта", СтруктураРеквизитов, ЭтаФорма);

	ЗаписатьНормативыОРПриИзмененииТиповогоОРНаСервере(Объект.ТиповойОР, Объект.Ссылка);
	УстановитьКоличествоОсновногоЗависимогоОборудования();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы
&НаСервере
Процедура ДобавитьНовыеЭлементы()
	МассивРеквизитов = Новый Массив();
	
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ФОИспользоватьФункциональныеМеста", Новый ОписаниеТипов("Булево")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ИсторияПеремещенияФМ", Новый ОписаниеТипов("ТаблицаЗначений")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ОбъектРемонта", 
		Новый ОписаниеТипов("СправочникСсылка.торо_ОбъектыРемонта"),"ИсторияПеремещенияФМ",
		НСтр("ru = 'Объект ремонта'; en = 'Object of repair'; es = 'El objeto de la reparación'")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Событие",
		Новый ОписаниеТипов("ПеречислениеСсылка.торо_СобытияОборудованияНаФМ"), "ИсторияПеремещенияФМ",
		НСтр("ru = 'Событие'; en = 'Event'; es = 'El evento'")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Период",Новый ОписаниеТипов("Дата",,,,,
		Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)), "ИсторияПеремещенияФМ",
		НСтр("ru = 'Период'; en = 'Period'; es = 'El período de'")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ТаблицаОграничений", Новый ОписаниеТипов("ДеревоЗначений")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Иерархия", Новый ОписаниеТипов("СправочникСсылка.торо_СтруктурыОР"),
		"ТаблицаОграничений", НСтр("ru = 'Иерархия'; en = 'Hierarchy'; es = 'La jerarquía de'")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Ограничение", 
		Новый ОписаниеТипов("СправочникСсылка.торо_ОграниченияНаХарактеристикиОбрудования"),
		"ТаблицаОграничений", НСтр("en='Rrestriction';es='La limitación de la';ru='Ограничение'")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Собственное", Новый ОписаниеТипов("Булево"),
		"ТаблицаОграничений", НСтр("ru = 'Собственное'; en = 'Private'; es = 'Propia'")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("гкс_Удален", Новый ОписаниеТипов("Булево"), 
		"ТаблицаОграничений", "гкс_Удален"));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("МодифицированностьОграничений", Новый ОписаниеТипов("Булево")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("МодифицированностьСостава", Новый ОписаниеТипов("Булево")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ТиповойСостав", Новый ОписаниеТипов("ТаблицаЗначений")));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ОР", 
