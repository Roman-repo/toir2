&НаСервереБезКонтекста
Функция СоздатьТМ(Ссылка)
	ОбъектТехническоеМесто = Справочники.гкс_ТехническиеМеста.СоздатьЭлемент();
	ОбъектТехническоеМесто.Наименование = Ссылка;
	ОбъектТехническоеМесто.Записать();
	
	НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
	НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Ссылка);
	НоваяСтрокаНабораЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
	НоваяСтрокаНабораЗаписей.ОР = Ссылка;
	НоваяСтрокаНабораЗаписей.ФМ = Ссылка;
	НоваяСтрокаНабораЗаписей.ТМ = ОбъектТехническоеМесто.Ссылка;
	НоваяСтрокаНабораЗаписей.ТМФМ = ОбъектТехническоеМесто.Ссылка;
	НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
	
	гкс_ПроверкаФункциональныхМест.ПроецироватьТКНаПодчиненных(Ссылка);
	//
	Возврат ОбъектТехническоеМесто.Ссылка;
КонецФункции
&НаСервереБезКонтекста
Функция НайтиФМ(Ссылка)
	ПоследняяСсылка = Ссылка;
	Иерархия = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
	Запрос = Новый Запрос;
	Пока ЗначениеЗаполнено(ПоследняяСсылка) Цикл
		Если Иерархия.ИзменяетсяДокументами = истина Тогда 
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	1 КАК Приоритет
				|ПОМЕСТИТЬ Уровень1
				|ИЗ
				|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
				|			,
				|			ОбъектИерархии = &Ссылка
				|				И СтруктураИерархии = &Иерархия) КАК РегистрОР
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	2 КАК Приоритет
				|ПОМЕСТИТЬ Уровень2
				|ИЗ
				|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
				|			,
				|			ОбъектИерархии В
				|					(ВЫБРАТЬ
				|						ТЧ.РодительИерархии
				|					ИЗ
				|						Уровень1 КАК ТЧ)
				|				И СтруктураИерархии = &Иерархия) КАК РегистрОР
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	3 КАК Приоритет
				|ПОМЕСТИТЬ Уровень3
				|ИЗ
				|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
				|			,
				|			ОбъектИерархии В
				|					(ВЫБРАТЬ
				|						ТЧ.РодительИерархии
				|					ИЗ
				|						Уровень2 КАК ТЧ)
				|				И СтруктураИерархии = &Иерархия) КАК РегистрОР";
		Иначе
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	1 КАК Приоритет
				|ПОМЕСТИТЬ Уровень1
				|ИЗ
				|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
				|ГДЕ
				|	РегистрОР.ОбъектИерархии = &Ссылка
				|	И РегистрОР.СтруктураИерархии = &Иерархия
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	2 КАК Приоритет
				|ПОМЕСТИТЬ Уровень2
				|ИЗ
				|	Уровень1 КАК Уровень1
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
				|		ПО Уровень1.РодительИерархии = РегистрОР.ОбъектИерархии
				|			И (РегистрОР.СтруктураИерархии = &Иерархия)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РегистрОР.РодительИерархии КАК РодительИерархии,
				|	РегистрОР.РодительИерархии.ТипОбъекта = &ТипФМ КАК ТипОбъекта,
				|	3 КАК Приоритет
				|ПОМЕСТИТЬ Уровень3
				|ИЗ
				|	Уровень2 КАК Уровень1
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИерархическиеСтруктурыОР КАК РегистрОР
				|		ПО Уровень1.РодительИерархии = РегистрОР.ОбъектИерархии
				|			И (РегистрОР.СтруктураИерархии = &Иерархия)";
		КонецЕсли;
		//
		Запрос.Текст = Запрос.Текст + "
		| ;  "+"ВЫБРАТЬ
		       |	Уровень1.РодительИерархии КАК РодительИерархии,
		       |	Уровень1.ТипОбъекта КАК ТипОбъекта,
		       |	Уровень1.Приоритет КАК Приоритет
		       |ПОМЕСТИТЬ ВсеРодители
		       |ИЗ
		       |	Уровень1 КАК Уровень1
		       |
		       |ОБЪЕДИНИТЬ ВСЕ
		       |
		       |ВЫБРАТЬ
		       |	Уровень2.РодительИерархии,
		       |	Уровень2.ТипОбъекта,
		       |	Уровень2.Приоритет
		       |ИЗ
		       |	Уровень2 КАК Уровень2
		       |
		       |ОБЪЕДИНИТЬ ВСЕ
		       |
		       |ВЫБРАТЬ
		       |	Уровень3.РодительИерархии,
		       |	Уровень3.ТипОбъекта,
		       |	Уровень3.Приоритет
		       |ИЗ
		       |	Уровень3 КАК Уровень3
		       |;
		       |
		       |////////////////////////////////////////////////////////////////////////////////
		       |ВЫБРАТЬ
		       |	ВсеРодители.РодительИерархии КАК РодительИерархии,
		       |	ВсеРодители.ТипОбъекта КАК ТипОбъекта,
		       |	ВсеРодители.Приоритет КАК Приоритет
		       |ИЗ
		       |	ВсеРодители КАК ВсеРодители
		       |
		       |УПОРЯДОЧИТЬ ПО
		       |	Приоритет";
		//
		Запрос.УстановитьПараметр("Иерархия", Иерархия);
		Запрос.УстановитьПараметр("Ссылка", ПоследняяСсылка);
		Запрос.УстановитьПараметр("ТипФМ", Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто);
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		ПоследняяСсылка = Неопределено;
		Пока Выборка.Следующий() Цикл
			ПоследняяСсылка = Выборка.РодительИерархии;
			Если Выборка.ТипОбъекта Тогда 
				ПоследняяСсылка = Неопределено;
				Возврат Выборка.РодительИерархии;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции
&НаСервереБезКонтекста
Процедура НайтиТМ(Ссылка, ТехническоеМесто, ТехническоеМестоФункциональногоМеста, ТипОбъекта)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	гкс_ТекущиеФМОР.ФМ КАК ФМ,
		|	гкс_ТекущиеФМОР.ТМ КАК ТМ,
		|	гкс_ТекущиеФМОР.ТМФМ КАК ТМФМ
		|ИЗ
		|	РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
		|ГДЕ
		|	гкс_ТекущиеФМОР.ОР = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		// Если записи нет совсем
		Если ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто Тогда
			НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
			НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Ссылка);
			НоваяСтрокаНабораЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
			НоваяСтрокаНабораЗаписей.ОР = Ссылка;
			НоваяСтрокаНабораЗаписей.ФМ = Ссылка;
			НоваяСтрокаНабораЗаписей.ТМ = Неопределено;
			НоваяСтрокаНабораЗаписей.ТМФМ = Неопределено;
			НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
		Иначе
			ТекущееФункциональноеМесто = гкс_ПроверкаФункциональныхМест.НайтиФМ(Ссылка);
			Если ЗначениеЗаполнено(ТекущееФункциональноеМесто) Тогда
				// Запись должна быть если есть ФМ
				Запрос = Новый Запрос;
				Запрос.Текст = 
					"ВЫБРАТЬ
					|	гкс_ТекущиеФМОР.ФМ КАК ФМ,
					|	гкс_ТекущиеФМОР.ТМ КАК ТМ,
					|	гкс_ТекущиеФМОР.ТМФМ КАК ТМФМ
					|ИЗ
					|	РегистрСведений.гкс_ТекущиеФМОР КАК гкс_ТекущиеФМОР
					|ГДЕ
					|	гкс_ТекущиеФМОР.ОР = &Ссылка";
				Запрос.УстановитьПараметр("Ссылка", ТекущееФункциональноеМесто);
				РезультатЗапроса = Запрос.Выполнить();
				Если РезультатЗапроса.Пустой() = Ложь Тогда 
					Выборка = РезультатЗапроса.Выбрать();
					Выборка.Следующий();
					//
					ТехническоеМестоФункциональногоМеста = Выборка.ТМ;
					НаборЗаписейРегистрагкс_ТекущиеФМОР = РегистрыСведений.гкс_ТекущиеФМОР.СоздатьНаборЗаписей();
					НаборЗаписейРегистрагкс_ТекущиеФМОР.Отбор.ОР.Установить(Ссылка);
					НоваяСтрокаНабораЗаписей = НаборЗаписейРегистрагкс_ТекущиеФМОР.Добавить();
					НоваяСтрокаНабораЗаписей.ОР = Ссылка;
					НоваяСтрокаНабораЗаписей.ФМ = Выборка.ФМ;
					НоваяСтрокаНабораЗаписей.ТМ = Неопределено;
					НоваяСтрокаНабораЗаписей.ТМФМ = Выборка.ТМ;
					НаборЗаписейРегистрагкс_ТекущиеФМОР.Записать();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			ТехническоеМесто = Выборка.ТМ;
			ТехническоеМестоФункциональногоМеста = Выборка.ТМФМ;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ДеревоОграничений

&НаСервере
Процедура ЗаполнитьДеревоОграничений()

	Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
	Корень.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОграниченияНаХарактеристикиОборудования.Иерархия КАК ТекИерархия,
		|	торо_ОграниченияНаХарактеристикиОборудования.Ограничение КАК Ограничение,
		|	ИСТИНА КАК Собственное,
		|	торо_ОграниченияНаХарактеристикиОборудования.гкс_Удален КАК гкс_Удален
		|ПОМЕСТИТЬ ВсеНужные
		|ИЗ
		|	РегистрСведений.торо_ОграниченияНаХарактеристикиОборудования КАК торо_ОграниченияНаХарактеристикиОборудования
		|ГДЕ
		|	торо_ОграниченияНаХарактеристикиОборудования.ФункциональноеМесто = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Иерархия,
		|	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ограничение,
		|	ЛОЖЬ,
		|	ЛОЖЬ
		|ИЗ
		|	Справочник.торо_ТиповыеОР.ОграниченияНаХарактеристикиОборудования КАК торо_ТиповыеОРОграниченияНаХарактеристикиОборудования
		|ГДЕ
		|	торо_ТиповыеОРОграниченияНаХарактеристикиОборудования.Ссылка = &ТОР
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВсеНужные.ТекИерархия КАК ТекИерархия,
		|	ВсеНужные.Ограничение КАК Ограничение,
		|	МАКСИМУМ(ВсеНужные.Собственное) КАК Собственное,
		|	МАКСИМУМ(ВсеНужные.гкс_Удален) КАК гкс_Удален
		|ИЗ
		|	ВсеНужные КАК ВсеНужные
		|
		|СГРУППИРОВАТЬ ПО
		|	ВсеНужные.ТекИерархия,
		|	ВсеНужные.Ограничение
		|ИТОГИ ПО
		|	ТекИерархия";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("ТОР", Объект.ТиповойОР);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Выборка1 = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборка1.Следующий() Цикл
			НоваяСтрока = Корень.Добавить();
			НоваяСтрока.Иерархия = Выборка1.ТекИерархия;
			Ветвь = НоваяСтрока.ПолучитьЭлементы();
			
			Выборка = Выборка1.Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока1 = Ветвь.Добавить();
				НоваяСтрока1.Иерархия = Выборка1.ТекИерархия;
				НоваяСтрока1.Ограничение = Выборка.Ограничение;
				НоваяСтрока1.Собственное = Выборка.Собственное;
				НоваяСтрока1.гкс_Удален = Выборка.гкс_Удален;
				Если НоваяСтрока1.гкс_Удален Тогда 
					НоваяСтрока1.Собственное = Ложь;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьДеревоОграничений()
	Если Объект.ТипОбъекта = Перечисления.торо_ТипыОбъектовRCM.ФункциональноеМесто Тогда 
		Корень = ЭтотОбъект["ТаблицаОграничений"].ПолучитьЭлементы();
		Для Каждого СтрокаКорня Из Корень Цикл
			Ветвь = СтрокаКорня.ПолучитьЭлементы();
			Для Каждого СтрокаВетви Из Ветвь Цикл
				Если СтрокаВетви.Собственное Или СтрокаВетви.гкс_Удален Тогда 
					НаборЗаписейРегистраторо_ОграниченияНаХарактеристикиОборудования = 
						РегистрыСведений.торо_ОграниченияНаХарактеристикиОборудования.СоздатьНаборЗаписей();
					НаборЗаписейРегистраторо_ОграниченияНаХарактеристикиОборудования.Отбор.Иерархия.Установить(СтрокаКорня.Иерархия);
					НаборЗаписейРегистраторо_ОграниченияНаХарактеристикиОборудования.Отбор.Ограничение.Установить(СтрокаВетви.Ограничение);
					НаборЗаписейРегистраторо_ОграниченияНаХарактеристикиОборудования.Отбор.ФункциональноеМесто.Установить(Объект.Ссылка);
					НоваяСтрокаНабораЗаписей = НаборЗаписейРегистраторо_ОграниченияНаХарактеристикиОборудования.Добавить();
					НоваяСтрокаНабораЗаписей.Иерархия = СтрокаКорня.Иерархия;
					НоваяСтрокаНабораЗаписей.Ограничение = СтрокаВетви.Ограничение;
					НоваяСтрокаНабораЗаписей.ФункциональноеМесто = Объект.Ссылка;
					НоваяСтрокаНабораЗаписей.гкс_Удален = СтрокаВетви.гкс_Удален;
					НаборЗаписейРегистраторо_ОграниченияНаХарактеристикиОборудования.Записать();
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ = РегистрыСведений.торо_ОбъектыДляПроверкиТребованийФМ.СоздатьНаборЗаписей();
		НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Отбор.Объект.Установить(Объект.Ссылка);
		НоваяСтрокаНабораЗаписей = НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Добавить();
		НоваяСтрокаНабораЗаписей.Объект = Объект.Ссылка;
		НоваяСтрокаНабораЗаписей.Период = ТекущаяДата();
		НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Записать();
	КонецЕсли;
КонецПроцедуры

