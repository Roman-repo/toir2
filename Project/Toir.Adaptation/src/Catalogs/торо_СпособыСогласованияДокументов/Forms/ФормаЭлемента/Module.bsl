&НаСервере
Процедура гкс_ЗагрузитьСрокиГодности(СсылкаКопирования = Неопределено)
	СсылкаОтбор = Объект.Ссылка;
	Если Не СсылкаКопирования = Неопределено Тогда 
		СсылкаОтбор = СсылкаКопирования;
	ИначеЕсли ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	ЭтотОбъект["гкс_ТЧСрокиОповещаемые"].Очистить();
	ЭтотОбъект["гкс_ТЧСроки"].Очистить();
	Запрос = Новый Запрос();
	Запрос.Текст = "выбрать
	|Рег.Статус КАК Статус,
	|Рег.Срок КАК Срок
	|ИЗ РегистрСведений.гкс_СрокиСогласования КАК Рег
	|Где Рег.Способ = &Ссылка
	|;
	|Выбрать
	|Рег.Статус КАК Статус,
	|Рег.Пользователь КАК Пользователь,
	|Рег.Адрес КАК Адрес
	|ИЗ РегистрСведений.гкс_СрокиСОповещаемые КАК Рег
	|Где Рег.Способ = &Ссылка
	|";
	Запрос.УстановитьПараметр("Ссылка", СсылкаОтбор);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Пакет1 = 0;
	Пакет2 = Пакет1 + 1;
	Выборка = РезультатЗапроса[Пакет1].Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ЭтотОбъект["гкс_ТЧСроки"].Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	КонецЦикла;
	//
	Выборка = РезультатЗапроса[Пакет2].Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ЭтотОбъект["гкс_ТЧСрокиОповещаемые"].Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	КонецЦикла;
КонецПроцедуры
