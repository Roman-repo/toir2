
&ИзменениеИКонтроль("ОбработкаПолученияПредставления")
Процедура Расш_гкс_ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	#Вставка
	Язык = торо_ОбщегоНазначенияПовтИсп.ТекущийЯзыкИБ();
	#КонецВставки
	#Удаление
	Язык = торо_Локализация.ТекущийЯзыкИБ();
	#КонецУдаления
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(торо_Переводы.Текст, гкс_ТехническиеМеста.НаименованиеПолное) КАК Текст,
	|	гкс_ТехническиеМеста.НаименованиеПолное КАК Текст2
	|ИЗ
	|	Справочник.гкс_ТехническиеМеста КАК гкс_ТехническиеМеста
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_Переводы КАК торо_Переводы
	|		ПО гкс_ТехническиеМеста.Ссылка = торо_Переводы.ID
	|			И (торо_Переводы.Язык = &Язык)
	|			И (торо_Переводы.Реквизит = ""НаименованиеПолное"")
	|ГДЕ
	|	гкс_ТехническиеМеста.Ссылка = &Ссылка";	
	Запрос.УстановитьПараметр("Ссылка", Данные.Ссылка);
	Запрос.УстановитьПараметр("Язык", Язык);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Представление = Выборка.Текст2;
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
КонецПроцедуры
