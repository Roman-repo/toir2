#Область ОбработчикиСобытийФормы

&НаСервере
&Перед("ПриСозданииНаСервере")
Процедура гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Гкс+[TOIR20-622] Оселедько В.С. от 25.07.2025. Добавлено:{
	Если Параметры.Свойство("ВремяНачалаОткрытияФормы") Тогда
		ВремяНачалаЗамера = Параметры.ВремяНачалаОткрытияФормы;	
	Иначе
		ВремяНачалаЗамера = ОценкаПроизводительности.НачатьЗамерВремени();
	КонецЕсли;
    // } Гкс-[TOIR20-622]
	ДобавитьНовыеЭлементы();
КонецПроцедуры

&НаКлиенте
&После("ПриОткрытии")
Процедура гкс_ПриОткрытии(Отказ)
	гкс_УстановитьДоступность(); 
	// Гкс+[TOIR20-622] Оселедько В.С. от 25.07.2025. Добавлено:{
	гкс_ПриОткрытииПослеНаСервере(ВремяНачалаЗамера);
	// } Гкс-[TOIR20-622]
КонецПроцедуры

// Гкс+[TOIR20-622] Оселедько В.С. от 25.07.2025. Добавлено:{
&НаСервереБезКонтекста
Процедура гкс_ПриОткрытииПослеНаСервере(ВремяНачалаЗамера)
	ЗавершитьЗамерОткрытияФормы(ВремяНачалаЗамера);	
КонецПроцедуры // } Гкс-[TOIR20-622]

