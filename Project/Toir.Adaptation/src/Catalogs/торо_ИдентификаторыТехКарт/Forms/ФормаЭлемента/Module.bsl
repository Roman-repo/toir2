Процедура гкс_ИспытанияОборудованияПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		ЗаполнитьIDРодителяИОперациюСтрокиТабличнойчасти(Элементы.гкс_ИспытанияОборудования.ТекущиеДанные);		
	Иначе
		// Запись данных до редактирования
		торо_СобытияФормКлиент.ПриНачалеРедактирования(Элемент,СтруктураДанныхДоРедактирования,Элемент.ТекущиеДанные);
	КонецЕсли;
	
	Модифицированность = Истина; 
	
КонецПроцедуры	// } Гкс-[TOIR20-503] Зозуля А.В. от 13.01.2025.

// Гкс+[TOIR20-503] Зозуля А.В. от 13.01.2025. Добавлено:{
&НаКлиенте
Процедура гкс_ИспытанияОборудованияПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	ТекДанные = Элементы.гкс_ИспытанияОборудования.ТекущиеДанные;
	Если НЕ ОтменаРедактирования Тогда
		Если НЕ ТекДанные = Неопределено Тогда
			МассивСтрок = ЭтотОбъект.гкс_ИспытанияОборудования.НайтиСтроки(Новый Структура("ID, ИспытаниеОборудования",
				ТекДанные.ID, ТекДанные.ИспытаниеОборудования));
			Если МассивСтрок.Количество() > 1 Тогда
				ТекстСообщения = НСтр("es='¡Esta prueba de equipo ya ha sido agregada!';
										|ru='Данное испытание оборудования уже добавлено!';
										|en='This equipment test has already been added!'");
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,,,, Отказ);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли Не НоваяСтрока Тогда
		// возврат старых значений
		ЗаполнитьЗначенияСвойств(ТекДанные,СтруктураДанныхДоРедактирования[Элемент.Имя]);
	КонецЕсли;
	
КонецПроцедуры	// } Гкс-[TOIR20-503] Зозуля А.В. от 13.01.2025.

