&НаКлиенте
Процедура гкс_УстановитьДоступность()
	Элементы.Наименование.ТолькоПросмотр = Истина;
	Если ЭтотОбъект["гкс_ЭтоРодитель"] = Истина Тогда 
		Элементы.ТабЧасти.Видимость = Ложь;
		Элементы.ДобавитьТехКарту.Видимость = Ложь;
		Элементы.КонтекстноеМенюДобавитьТехКарту.Видимость = Ложь;
		Элементы.ТехКартаСпособРасчетаПродолжительности.Доступность = Ложь;
		Элементы.Перерассчитать.Доступность = Ложь;
		Элементы.СписокОперацийПродолжительностьТекст.Видимость = Ложь;
		Элементы.НормаВремени.Видимость = Ложь;
		Элементы.ТехКартаСпособРасчетаПродолжительности.Видимость = Ложь;
		Элементы.Декорация1.Видимость = Ложь;
		Элементы.Перерассчитать.Видимость = Ложь;
		Элементы.ГруппаОстанова.Видимость = Ложь;
	ИначеЕсли ЭтотОбъект["гкс_ЭтоНаследник"] = Истина Тогда 
		Элементы.СписокОпераций.ИзменятьПорядокСтрок = Ложь;
		Элементы.СписокОпераций.ИзменятьСоставСтрок = Ложь;
		Элементы.СписокОперацийКоманднаяПанель.Доступность = Ложь;
		Элементы.ТехКартаСписокОперацийОперация.ТолькоПросмотр = Истина;
		Элементы.СписокОперацийКоличество.ТолькоПросмотр = Истина;
		Элементы["СписокОперацийгкс_Примечание"].ТолькоПросмотр = Истина;
		Элементы.ТехКартаСписокОперацийСпособВыполнения.ТолькоПросмотр = Истина;
		Элементы.СоздатьНовуюВерсию.Доступность = Ложь;
		Элементы.ИзменитьДату.Доступность = Ложь;
		Элементы.НормаВремени.Видимость = Истина;
		Элементы.ТехКартаСпособРасчетаПродолжительности.Видимость = Истина;
		Элементы.Декорация1.Видимость = Истина;
		Элементы.Перерассчитать.Видимость = Истина;
		
		Элементы.ДобавитьТехКарту.Видимость = Ложь;
		Элементы.КонтекстноеМенюДобавитьТехКарту.Видимость = Ложь;
		Элементы.Родитель.ТолькоПросмотр = Истина;
		Элементы["гкс_Обслуживание"].ТолькоПросмотр = Истина;
		Элементы.ТехКартаДатаПринятия.ТолькоПросмотр = Истина;
	КонецЕсли;
	Элементы["гкс_Ответственный"].Доступность = Не Объект.Статус = ЭтотОбъект["гкс_СтатусДляЗаписи"];
КонецПроцедуры

