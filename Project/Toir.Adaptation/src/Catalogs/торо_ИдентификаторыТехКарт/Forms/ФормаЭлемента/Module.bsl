// Гкс+[TOIR20-503] Зозуля А.В. от 13.01.2025. Добавлено:{
&НаКлиенте
Процедура гкс_ИспытанияОборудованияПередУдалением(Элемент, Отказ)
	
	ТекДанные = Элементы.гкс_ИспытанияОборудования.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда 
		
		Если НЕ ПроверитьВозможностьУдаления(ТекДанные) Тогда 
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		ТекДанныеОперация = Элементы.СписокОпераций.ТекущиеДанные;
		Если НЕ ТекДанныеОперация = Неопределено Тогда
			Если ТипЗнч(ТекДанныеОперация.Операция) = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда
				МассивСтрок = ЭтотОбъект["тзгкс_ИспытанияОборудования"].НайтиСтроки(Новый Структура("ID, ИспытаниеОборудования",
					ТекДанные.ID, ТекДанные.ИспытаниеОборудования));
				Для каждого Элем Из МассивСтрок Цикл
					ЭтотОбъект["тзгкс_ИспытанияОборудования"].Удалить(Элем);
				КонецЦикла;
			Иначе
				МассивСтрок = ТехКарта.гкс_ИспытанияОборудования.НайтиСтроки(Новый Структура("ID, ИспытаниеОборудования",
					ТекДанные.ID, ТекДанные.ИспытаниеОборудования));
				Для каждого Элем Из МассивСтрок Цикл
					ТехКарта.гкс_ИспытанияОборудования.Удалить(Элем);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Модифицированность = Истина;
	
КонецПроцедуры	// } Гкс-[TOIR20-503] Зозуля А.В. от 13.01.2025.

// Гкс+[TOIR20-503] Зозуля А.В. от 13.01.2025. Добавлено:{
