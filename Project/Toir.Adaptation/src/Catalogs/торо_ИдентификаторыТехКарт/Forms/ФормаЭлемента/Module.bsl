&НаСервере
&ИзменениеИКонтроль("ПередЗаписьюНаСервере")
Процедура гкс_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	Если Не УстановитьБлокировкуДанныхНаСервере(ТехКарта.Ссылка, ТехКарта.ВерсияДанных, Ложь)Тогда
		ТекстСообщения = НСтр("es='El objeto era cambiado o quitado. Vuelvan a leer los datos del objeto.';ru='Объект был изменен или удален. Перечитайте данные объекта.';en='The object has been modified or deleted. Reread the data of the object.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;

	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

	Если НЕ ЗначениеЗаполнено(ТехКарта.ДатаПринятия) Тогда
		ТекстСообщения = НСтр("es='Campo ""De aquel. La tarjeta es aceptada con"" no es rellenado';ru='Поле ""Тех. карта принята с"" не заполнено';en='Field ""Technical card accepted from"" is not filled'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;

	#Удаление
	Если НЕ ЗначениеЗаполнено(ТехКарта.НормаВремени) Тогда
	#КонецУдаления
	#Вставка
	Если ЭтотОбъект["гкс_ЭтоРодитель"] = Ложь
		И НЕ ЗначениеЗаполнено(ТехКарта.НормаВремени) Тогда 
	#КонецВставки
		ТекстСообщения = НСтр("es='Campo ""la Duración"" no es rellenado';ru='Поле ""Продолжительность"" не заполнено';en='""Duration"" field is not filled'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Объект.Статус) Тогда
		ТекстСообщения = НСтр("es='Campo ""el Estatus"" no es rellenado';ru='Поле ""Статус"" не заполнено';en='""Status"" field is not filled'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;

	Для каждого СтрокаТаблицы Из ТехКарта.МатериальныеЗатраты Цикл

		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Количество) Тогда

			ШаблонСообщения = НСтр("es='En la parte tabular ""los Gastos"" para la operación ""%1"": ¡no es rellenado el significado del requisito ""la Cantidad""!';ru='В табличной части ""Материальные затраты"" для операции ""%1"": Не заполнено значение реквизита ""Количество""!';en='In the tabular part ""Material costs"" for the operation ""%1"": The value of the attribute ""Quantity"" is not filled!'");
			ТекстСообщения = СтрШаблон(ШаблонСообщения, СокрЛП(СтрокаТаблицы.Операция.Наименование));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);

		КонецЕсли;

	КонецЦикла;

	Для каждого СтрокаТаблицы Из ТехКарта.ИнструментыИТехника Цикл

		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Количество) Тогда

			ШаблонСообщения = НСтр("es='En la parte tabular ""los Instrumentos y la técnica"" para la operación ""%1"": ¡no es rellenado el significado del requisito ""la Cantidad""!';ru='В табличной части ""Инструменты и техника"" для операции ""%1"": Не заполнено значение реквизита ""Количество""!';en='In the tabular section ""Tools and equipment"" for operation ""%1"": The value of the attribute ""Quantity"" is not filled!'");
			ТекстСообщения = СтрШаблон(ШаблонСообщения, СокрЛП(СтрокаТаблицы.Операция.Наименование));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);

		КонецЕсли;

	КонецЦикла;
    #Вставка
	// Гкс+[TOIR20-503] Зозуля А.В. от 13.01.2025. Добавлено:{
	// Гкс+[TOIR20-541] Зозуля А.В. от 18.02.2025. Изменено:{
	//Для каждого СтрокаТаблицы Из ТехКарта.ИзмеряемыеПоказатели Цикл
	Для каждого СтрокаТаблицы Из ИзмеряемыеПоказатели Цикл
	// } Гкс-[TOIR20-541] Зозуля А.В. от 18.02.2025.	

		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.гкс_ТребуемыйРезультатИзмерения) Тогда

			ШаблонСообщения = НСтр("es='En la parte tabular ""Indicadores mensurables"" para la operación ""%1"": ¡no es rellenado el significado del requisito ""Resultado de medición requerido""!';
									|ru='В табличной части ""Измеряемые показатели"" для операции ""%1"": Не заполнено значение реквизита ""Требуемый результат измерения""!';
									|en='In the tabular section ""Measurable Indicators"" for operation ""%1"": The value of the attribute ""Required measurement result"" is not filled!'");
			ТекстСообщения = СтрШаблон(ШаблонСообщения, СокрЛП(СтрокаТаблицы.Операция.Наименование));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);

		КонецЕсли;

	КонецЦикла;
	// } Гкс-[TOIR20-503] Зозуля А.В. от 13.01.2025.
	#КонецВставки
	Если Модифицированность И НЕ Отказ Тогда

		ПроверитьДругиеТехкарты = Истина;

		Если СоздаватьНовыйОбъект Тогда

			НовОбъект = Справочники.торо_ТехКарты.СоздатьЭлемент();

			ЗаполнитьЗначенияСвойств(НовОбъект, ТехКарта, , "Код");
			НовОбъект.Наименование = Объект.Наименование;

			НовОбъект.СписокОпераций.Загрузить(ТехКарта.СписокОпераций.Выгрузить());
			НовОбъект.ОказываемыеУслуги.Загрузить(ТехКарта.ОказываемыеУслуги.Выгрузить());
			НовОбъект.МатериальныеЗатраты.Загрузить(ТехКарта.МатериальныеЗатраты.Выгрузить());
			НовОбъект.ТрудовыеЗатраты.Загрузить(ТехКарта.ТрудовыеЗатраты.Выгрузить());
			НовОбъект.ИнструментыИТехника.Загрузить(ТехКарта.ИнструментыИТехника.Выгрузить());
			НовОбъект.ИзмеряемыеПоказатели.Загрузить(ТехКарта.ИзмеряемыеПоказатели.Выгрузить());
			НовОбъект.МерыБезопасности.Загрузить(ТехКарта.МерыБезопасности.Выгрузить());
			#Вставка
			// Гкс+[TOIR20-503] Зозуля А.В. от 13.01.2025. Добавлено:{
			НовОбъект.гкс_ИспытанияОборудования.Загрузить(ТехКарта.гкс_ИспытанияОборудования.Выгрузить());
			// } Гкс-[TOIR20-503] Зозуля А.В. от 13.01.2025.
			#КонецВставки

			ЗаписатьНормативыОпераций(НовОбъект);

			Если НовОбъект.ПроверитьЗаполнение() Тогда
				НовОбъект.Записать();
			Иначе
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			РаботаСФайламиСлужебный.СкопироватьПрисоединенныеФайлы(ПредВерсияТехКарты, НовОбъект.Ссылка);

			НаборЗаписей = РегистрыСведений.торо_ВерсииТехКарт.СоздатьНаборЗаписей();

			НС = НаборЗаписей.Добавить();
			НС.ИдентификаторТехКарты = торо_ОбщегоНазначения.ПолучитьСсылкуНаОбъект(ТекущийОбъект);
			НС.Период                = НовОбъект.ДатаПринятия;
			НС.ТехКарта              = НовОбъект.Ссылка;
			НаборЗаписей.Записать(Ложь);

			ТехКартаСсылка = ПолучитьТехКартуПоИдентификатору(НС.ИдентификаторТехКарты, НовОбъект.ДатаПринятия);

			ТехКартаОбъект = ТехКартаСсылка.ПолучитьОбъект();


			ЗаполнитьТаблицыЗначенийПоТабЧастям(ТехКартаОбъект.Ссылка);

			ЗначениеВРеквизитФормы(ТехКартаОбъект,"ТехКарта");

		Иначе

			ТехКартаОбъект = РеквизитФормыВЗначение("ТехКарта");
			ТехКартаОбъект.Наименование = Объект.Наименование;
			Если ТехКартаОбъект.ПроверитьЗаполнение() Тогда
				ТехКартаОбъект.Записать();
			Иначе
				Отказ = Истина;
				Возврат;
			КонецЕсли;

			Если ДатаПринятияИзменена Тогда

				МенеджерЗаписи = РегистрыСведений.торо_ВерсииТехКарт.СоздатьМенеджерЗаписи();

				МенеджерЗаписи.ИдентификаторТехКарты = торо_ОбщегоНазначения.ПолучитьСсылкуНаОбъект(ТекущийОбъект);
				МенеджерЗаписи.Период                = СтараяДатаПринятия;
				МенеджерЗаписи.ТехКарта              = ТехКартаОбъект.Ссылка;

				МенеджерЗаписи.Прочитать(); 

				МенеджерЗаписи.ТехКарта              = ТехКартаОбъект.Ссылка;
				МенеджерЗаписи.Период                = ТехКартаОбъект.ДатаПринятия;
				МенеджерЗаписи.ИдентификаторТехКарты = торо_ОбщегоНазначения.ПолучитьСсылкуНаОбъект(ТекущийОбъект);

				МенеджерЗаписи.Записать(Истина);

				СтараяДатаПринятия                   = ТехКартаОбъект.ДатаПринятия;

			КонецЕсли; 

			ЗначениеВРеквизитФормы(ТехКартаОбъект,"ТехКарта");

		КонецЕсли;
	КонецЕсли;

	#Вставка
	Если ЭтотОбъект["гкс_ЭтоРодитель"] = Ложь Тогда 
	#КонецВставки
	СообщитьОВозможномИзмененииПродолжительностиРемонта(флСписокОперацийМодифицированность, флТрудозатратыМодифицированность);
	#Вставка
	КонецЕсли;
	#КонецВставки

	Если НЕ Отказ Тогда
		флТрудозатратыМодифицированность = Ложь;
		флСписокОперацийМодифицированность = Ложь;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("СтатусОбработкаВыбора")
Процедура гкс_СтатусОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Если НЕ ЗначениеЗаполнено(ТехКарта.ДатаПринятия) И ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Действует") Тогда
		СтандартнаяОбработка = Ложь;
		ТекстСообщения = НСтр("es='Campo ""De aquel. La tarjeta es aceptada con"" no es rellenado';ru='Поле ""Тех. карта принята с"" не заполнено';en='Field ""Technical card accepted from"" is not filled'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ТехКарта.НормаВремени)  И ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Действует") Тогда
		#Вставка
		Если ЭтотОбъект["гкс_ЭтоРодитель"] = Истина Тогда 
			ТехКарта.НормаВремени = 1;
		Иначе
		#КонецВставки
		СтандартнаяОбработка = Ложь;
		ТекстСообщения = НСтр("es='Campo ""la Duración"" no es rellenado';ru='Поле ""Продолжительность"" не заполнено';en='""Duration"" field is not filled'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		#Вставка
		КонецЕсли;
		#КонецВставки
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ИзменитьПодчиненнуюВерсиюТК(ПодчиненнаяТехКарта = Неопределено, ТехКартаСсылка)
	МассивИменТаблиц = Новый Массив();
	МассивИменТаблиц.Добавить("СписокОпераций");
	МассивИменТаблиц.Добавить("МатериальныеЗатраты");
	МассивИменТаблиц.Добавить("ТрудовыеЗатраты");
	МассивИменТаблиц.Добавить("ИнструментыИТехника");
	МассивИменТаблиц.Добавить("ИзмеряемыеПоказатели");
	МассивИменТаблиц.Добавить("ОказываемыеУслуги");
	МассивИменТаблиц.Добавить("МерыБезопасности");
	НеНайденныеТО = Новый Массив();
	Если ПодчиненнаяТехКарта = Неопределено Тогда 
		ПодчиненнаяТехКарта = ТехКартаСсылка.ПолучитьОбъект();
	КонецЕсли;
	Для Каждого ТехОперацияСтарая ИЗ ПодчиненнаяТехКарта.СписокОпераций Цикл
		НеНайденныеТО.Добавить(ТехОперацияСтарая.ID);
	КонецЦикла;
	Для Каждого ТехОперация ИЗ ТехКарта.СписокОпераций Цикл
		ЭтоНовая = Истина;
		Для Каждого ТехОперацияСтарая ИЗ ПодчиненнаяТехКарта.СписокОпераций Цикл
			Если ТехОперацияСтарая.ID = ТехОперация.ID Тогда 
				НеНайденныеТО.Удалить(НеНайденныеТО.Найти(ТехОперацияСтарая.ID));
				ЗаполнитьЗначенияСвойств(ТехОперацияСтарая, ТехОперация,,"Продолжительность,НормаВремениВСекундах");
				ЭтоНовая = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ЭтоНовая Тогда 
			НоваяСтрока = ПодчиненнаяТехКарта.СписокОпераций.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТехОперация);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаМассива Из НеНайденныеТО Цикл
		Для Каждого ИмяТаблицы Из МассивИменТаблиц Цикл
			НайденныеСтроки = ПодчиненнаяТехКарта[ИмяТаблицы].НайтиСтроки(Новый Структура("ID", СтрокаМассива));
			Для Каждого СтрокаТЧ Из НайденныеСтроки Цикл
				ПодчиненнаяТехКарта[ИмяТаблицы].Удалить(СтрокаТЧ);
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	НомерСтрокиНовый = 0;
	Для Каждого ТехОперация ИЗ ТехКарта.СписокОпераций Цикл
		НомерСтрокиСтарый = 0;
		Для Каждого ТехОперацияСтарая ИЗ ПодчиненнаяТехКарта.СписокОпераций Цикл
			Если ТехОперацияСтарая.ID = ТехОперация.ID Тогда 
				Прервать;
			КонецЕсли;
			НомерСтрокиСтарый = НомерСтрокиСтарый + 1;
		КонецЦикла;
		Если НЕ НомерСтрокиНовый = НомерСтрокиСтарый Тогда 
			ПодчиненнаяТехКарта.СписокОпераций.Сдвинуть(НомерСтрокиСтарый, НомерСтрокиНовый - НомерСтрокиСтарый);
		КонецЕсли;
		НомерСтрокиНовый = НомерСтрокиНовый + 1;
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(ПодчиненнаяТехКарта, ТехКарта,, 
		"Код,ПометкаУдаления,Ссылка,НормаВремени,НормаВремениТекст,СпособРасчетаПродолжительности");
	ПодчиненнаяТехКарта.Записать();
	 	
КонецПроцедуры

