Процедура РассчитатьДатуОкончанияАктуальностиКарты()
	
	Если ЗначениеЗаполнено(ТехКарта.ДатаПринятия) 
		И ЗначениеЗаполнено(ТехКарта.гкс_ПериодДействия) Тогда
		КолВоПериодов = ?(ТехКарта.гкс_КоличествоПериодовДействия = 0, 1, ТехКарта.гкс_КоличествоПериодовДействия);
		ТехКарта.гкс_ДатаОкончанияАктуальности = 		
			торо_ОбщегоНазначенияКлиентСервер.РассчитатьДатуОкончанияПериода(ТехКарта.ДатаПринятия, 
																			 ТехКарта.гкс_ПериодДействия, 
																			 КолВоПериодов);
	Иначе
		ТехКарта.гкс_ДатаОкончанияАктуальности = Неопределено;
	КонецЕсли;                                                               	
	
