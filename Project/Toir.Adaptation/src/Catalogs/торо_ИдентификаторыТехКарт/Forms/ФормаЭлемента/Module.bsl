	Элементы.Переместить(Элементы.гкс_ГруппаИспытанияОборудования, Элементы.ТабЧасти, Элементы.ГруппаФайлы);  
		
	НЭлем	= Элементы.Вставить("гкс_ИспытанияОборудования", Тип("ТаблицаФормы"), Элементы.гкс_ГруппаИспытанияОборудования);	
	НЭлем.ПутьКДанным = "гкс_ИспытанияОборудования";
	НЭлем.Отображение = ОтображениеТаблицы.Список;
	НЭлем.УстановитьДействие("ПередНачаломДобавления", "гкс_ИспытанияОборудованияПередНачаломДобавления"); 
	НЭлем.УстановитьДействие("ПередНачаломИзменения", "гкс_ИспытанияОборудованияПередНачаломИзменения"); 
	НЭлем.УстановитьДействие("ПередУдалением", "гкс_ИспытанияОборудованияПередУдалением"); 
	НЭлем.УстановитьДействие("ПриНачалеРедактирования", "гкс_ИспытанияОборудованияПриНачалеРедактирования"); 
	НЭлем.УстановитьДействие("ПередОкончаниемРедактирования", "гкс_ИспытанияОборудованияПередОкончаниемРедактирования"); 
	НЭлем.УстановитьДействие("ПриОкончанииРедактирования", "гкс_ИспытанияОборудованияПриОкончанииРедактирования"); 

	НЭлем  = Элементы.Вставить("гкс_ИспытанияОборудованияИспытаниеОборудования",
		Тип("ПолеФормы"), Элементы.гкс_ИспытанияОборудования);	
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;      
	НЭлем.ПутьКДанным = "гкс_ИспытанияОборудования.ИспытаниеОборудования";
	// } Гкс-[TOIR20-503] Зозуля А.В. от 13.01.2025.
	
