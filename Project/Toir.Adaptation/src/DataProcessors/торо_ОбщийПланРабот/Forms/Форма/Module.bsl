&НаКлиенте
Перем ОчищаемыеСтрокиТрудовыхРесурсов; // Хранит массив строк, которые необходимо очистить при 
									   // переключении с одной строки на другую в таблице ремонтов

#Область ОбработчикиСобытийФормы

&НаСервере
&ИзменениеИКонтроль("ПриСозданииНаСервере")
Процедура гкс_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ФОИспользоватьСкользящееПланирование = ПолучитьФункциональнуюОпцию("торо_ИспользоватьСкользящееПланирование");
	ФОНазначениеНаРемонтыСУчетомРисков   = ПолучитьФункциональнуюОпцию("торо_НазначениеНаРемонтСУчетомРисков");

	Если ФОИспользоватьСкользящееПланирование Тогда
		Для каждого Элемент Из Элементы.ГруппаГлубинаПланирования.ПодчиненныеЭлементы Цикл
			Элемент.ТолькоПросмотр = Истина;
		КонецЦикла; 
		Элементы.ГруппаОтборыПоИсполнителям.Заголовок = Элементы.ГруппаОтборыПоИсполнителям.Заголовок + ", план работ";
	Иначе
		Элементы.ВидПлана.Видимость                             = Ложь;
		Элементы.ФормаСохранитьПланПодразделения.Видимость      = Ложь;
		Элементы.ГруппаПланРабот.Видимость                      = Ложь;
		Элементы.ДеревоРемонтыГруппаРедактируемыеДаты.Видимость = Ложь;
	КонецЕсли;

	Элементы.ОтобразитьНезапланированныеРемонты.Видимость = Ложь;
	Элементы.НезапланированныеРемонтыГруппа.Видимость	  = Ложь;

	Организация = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
	"НастройкиТОиР",
	"ОсновнаяОрганизация",
	Истина);

	ПоказыватьВнешниеОснования		= Истина;
	ПоказыватьДефекты               = Истина;
	ПоказыватьРемонтыППР            = Истина;
	ПоказыватьРемонтыРегламентные   = Истина;

	ДатаОтсчета = ТекущаяДата();

	ГруппироватьПоИсполнителю = 0;
	ВерхнийУровень = "4";
	НижнийУровень  = "2";

	ДиаграммаГантаПодразделения.ОтображатьЗаголовок = Ложь;
	ДиаграммаГантаПодразделения.ОтображатьЛегенду   = Ложь;
	#Вставка
	// Гкс+[TOIR20-173] Селимов от 24.11.2020. Добавлено:{
	ДобавитьЭлементыФормы();  // } Гкс-[TOIR20-173] 
	#КонецВставки 
	
КонецПроцедуры

// Гкс+[TOIR20-173] Селимов 	
&НаСервере
Процедура гкс_ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если Настройки.Получить("ТрудовыеРесурсы_ПериодС") <> Неопределено Тогда
		ЭтаФорма["ТрудовыеРесурсы_ПериодС"] = Настройки["ТрудовыеРесурсы_ПериодС"];
		Если ЭтаФорма["ТрудовыеРесурсы_ПериодС"] = Дата(1, 1, 1) Тогда
			 ЭтаФорма["ТрудовыеРесурсы_ПериодС"] = НачалоГода(ТекущаяДатаСеанса());	
		КонецЕсли; 
	КонецЕсли; 	
	Если Настройки.Получить("ТрудовыеРесурсы_ПериодПо") <> Неопределено Тогда
		ЭтаФорма["ТрудовыеРесурсы_ПериодПо"] = Настройки["ТрудовыеРесурсы_ПериодПо"]; 
		Если ЭтаФорма["ТрудовыеРесурсы_ПериодПо"] = Дата(1, 1, 1) Тогда
			 ЭтаФорма["ТрудовыеРесурсы_ПериодПо"] = КонецГода(ТекущаяДатаСеанса());	
		КонецЕсли; 
	КонецЕсли; 	
	
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПриОткрытии")
Процедура гкс_ПриОткрытии(Отказ)
	ВариантГруппировкиПриИзменении(Элементы.ВариантГруппировки);
	СформироватьЗаголовокСвернутойГруппы(Элементы.ПоказыватьВнешниеОснования);
	УстановитьЗаголовкиКолонок();
	РемонтыТаблицаИДиаграммаПриСменеСтраницы(Элементы.РемонтыТаблицаИДиаграмма,Элементы.РемонтыТаблицаИДиаграмма.ТекущаяСтраница);

	Если ФОИспользоватьСкользящееПланирование Тогда
		ВидПланаПриИзменении(Элементы.ВидПлана);
	КонецЕсли;
    #Вставка
	// Гкс+[TOIR20-173] Селимов
	ЗаполнитьТрудовыеРесурсы(); 
	// Гкс+[TOIR20-186] Селимов 
	УстановитьДоступностьКомандТаблицыРемонтов(Ложь); 
	#КонецВставки
	
КонецПроцедуры

&НаСервере
Процедура гкс_ПриСохраненииДанныхВНастройкахНаСервере(Настройки)
	
	// Гкс+[TOIR20-173] Селимов 	
	Настройки.Вставить("ТрудовыеРесурсы_ПериодС", ЭтаФорма["ТрудовыеРесурсы_ПериодС"]);
	Настройки.Вставить("ТрудовыеРесурсы_ПериодПо", ЭтаФорма["ТрудовыеРесурсы_ПериодПо"]); 

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ОбработкаВыбора")
Процедура гкс_ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.торо_ПланРаботПодразделения") Тогда
		ПланРабот = ВыбранноеЗначение;
		ОбновитьЗаголовокКнопкиПланРабот();
		СтруктураДанныхПлана = ПолучитьСтруктуруДанныхИзСохраненногоПлана(ПланРабот);
		ЗаполнитьЗначенияСвойств(ЭтаФорма, СтруктураДанныхПлана);

		ВидыРемонтов.Очистить();
		ВидыРемонтов.ЗагрузитьЗначения(СтруктураДанныхПлана.ВидыРемонтовМассив);
		ВидПланаПриИзменении(Элементы.ВидПлана);
		Элементы.ОтобразитьНезапланированныеРемонты.Видимость = Истина;
		Элементы.НезапланированныеРемонтыГруппа.Видимость	  = Истина;
	#Вставка
	// Гкс+[TOIR20-191] Селимов
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.торо_ОстановочныеРемонты") Тогда
		ЭтаФорма["гкс_ОстановочныйРемонт"] = ВыбранноеЗначение;
		ОбновитьЗаголовокКнопкиОстановочныйРемонт(); 
	#КонецВставки	
	КонецЕсли; 
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

