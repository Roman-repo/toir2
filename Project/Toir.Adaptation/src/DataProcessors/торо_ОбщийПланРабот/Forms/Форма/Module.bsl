// Гкс+[TOIR20-189] Селимов
&НаСервере
Функция ПолучитьИДРемонтовОстановочных(ОстановочныйРемонт)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОстановочныеРемонтыСвязанныеРемонты.ID КАК ID
		|ИЗ
		|	Документ.торо_ОстановочныеРемонты.СвязанныеРемонты КАК торо_ОстановочныеРемонтыСвязанныеРемонты
		|ГДЕ
		|	торо_ОстановочныеРемонтыСвязанныеРемонты.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	торо_ОстановочныеРемонтыСвязанныеРемонты.ID";
	
	Запрос.УстановитьПараметр("Ссылка", ОстановочныйРемонт);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ИДРемонтов = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ИДРемонтов.Добавить(ВыборкаДетальныеЗаписи.ID);	
	КонецЦикла;
	
	Возврат ИДРемонтов;
	
КонецФункции 

