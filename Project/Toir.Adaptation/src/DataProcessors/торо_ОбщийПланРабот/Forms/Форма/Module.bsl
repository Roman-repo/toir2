// Гкс+[TOIR20-186] Селимов 
&НаКлиенте
Процедура гкс_РемонтыТаблицаИДиаграммаПриСменеСтраницыВместо(Элемент, ТекущаяСтраница)
	
	Если ТекущаяСтраница = Элементы.ГруппаДетальныеЗаписиПоРемонтам Тогда
		ТекущиеДанные = Элементы.ДеревоРемонты.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено
			И ЗначениеЗаполнено(ТекущиеДанные.Заявка) Тогда
			УстановитьДоступностьКомандТаблицыРемонтов(Истина);
		КонецЕсли; 
	КонецЕсли; 	
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормы_ТаблицаРемонтов

// Гкс+[TOIR20-173] Селимов 	
&НаКлиенте
Процедура гкс_ДеревоРемонтыПриАктивизацииСтрокиВместо(Элемент)
	Если ОчищаемыеСтрокиТрудовыхРесурсов.Количество() > 0  Тогда
		Для каждого ОчищаемаяСтрока Из ОчищаемыеСтрокиТрудовыхРесурсов Цикл
			Если ОчищаемаяСтрока.Доступно > 0 Тогда
				ОчищаемаяСтрока.Требуется = 0;
			Иначе
				ЭтаФорма["ТаблицаТрудозатрат"].Удалить(ОчищаемаяСтрока);
			КонецЕсли; 					           			
		КонецЦикла; 		
		ОчищаемыеСтрокиТрудовыхРесурсов.Очистить();
	КонецЕсли; 
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		ИДРемонтов = Новый Массив;
		Если ТекущиеДанные.ID_Ремонта = "" Тогда
			ЭлементыДерева = ТекущиеДанные.ПолучитьЭлементы();
			Для каждого ЭлементДерева Из ЭлементыДерева Цикл
				ИДРемонтов.Добавить(ЭлементДерева.ID_Ремонта);
			КонецЦикла;
		Иначе
			ИДРемонтов.Добавить(ТекущиеДанные.ID_Ремонта);	
		КонецЕсли; 
		ТребуемыеТрудозатраты = гкс_ДеревоРемонтыПриАктивизацииСтрокиНаСервере(ИДРемонтов);	
		Для каждого ТекущаяСтрока Из ТребуемыеТрудозатраты Цикл
			ПараметрыПоиска = Новый Структура("Квалификация", ТекущаяСтрока.Квалификация);
			ПоискСтрок = ЭтаФорма["ТаблицаТрудозатрат"].НайтиСтроки(ПараметрыПоиска);
			Если ПоискСтрок.Количество() > 0 Тогда
				ПоискСтрок[0].Требуется = ТекущаяСтрока.Требуется;
				ОчищаемыеСтрокиТрудовыхРесурсов.Добавить(ПоискСтрок[0]);
			Иначе
				НоваяСтрока = ЭтаФорма["ТаблицаТрудозатрат"].Добавить();
				НоваяСтрока.Квалификация = ТекущаяСтрока.Квалификация;
				НоваяСтрока.Требуется = ТекущаяСтрока.Требуется;
				ОчищаемыеСтрокиТрудовыхРесурсов.Добавить(НоваяСтрока);
			КонецЕсли; 
		КонецЦикла; 
		
		// Гкс+[TOIR20-186] Селимов 
		ДоступностьКоманд = ЗначениеЗаполнено(ТекущиеДанные.Заявка);
		УстановитьДоступностьКомандТаблицыРемонтов(ДоступностьКоманд); 
	КонецЕсли; 
	
КонецПроцедуры  

// Гкс+[TOIR20-186] Селимов 
&НаКлиенте
Процедура УстановитьДоступностьКомандТаблицыРемонтов(ДоступностьКоманд)
	Элементы["КомандаЗакрытьЗаявку"].Доступность = ДоступностьКоманд;
	Элементы["КомандаСвязанныеДокументы"].Доступность = ДоступностьКоманд;
	Элементы["КомандаСоздатьОстановочныйРемонт"].Доступность = ДоступностьКоманд;		
КонецПроцедуры         

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтыДатаОкончанияРедактируемаяПриИзменении")
Процедура гкс_ДеревоРемонтыДатаОкончанияРедактируемаяПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ДеревоРемонты.ТекущиеДанные;
	#Вставка
	// Гкс+[TOIR20-185] Селимов 
	УстановитьИнтервалыВДиаграмме(ТекущиеДанные);    	
	#КонецВставки 
	Если Не ТекущиеДанные = Неопределено Тогда
		ПроверитьДатыРемонтовВСтроке(ТекущиеДанные);
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДеревоРемонтыДатаНачалаРедактируемаяПриИзменении")
Процедура гкс_ДеревоРемонтыДатаНачалаРедактируемаяПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ДеревоРемонты.ТекущиеДанные;
	#Вставка
	// Гкс+[TOIR20-185] Селимов
	УстановитьИнтервалыВДиаграмме(ТекущиеДанные);    	
	#КонецВставки 
	Если Не ТекущиеДанные = Неопределено Тогда
		ПроверитьДатыРемонтовВСтроке(ТекущиеДанные);
	КонецЕсли; 
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Гкс+[TOIR20-173] Селимов 
&НаКлиенте
Процедура ПоказатьТаблицуТрудовыхРесурсов(Команда)

	ВидимостьТаблицыТР = Элементы["гкс_ДостпупностьТрудовыхРесурсов"].Видимость;
	
	Элементы["гкс_ДостпупностьТрудовыхРесурсов"].Видимость = Не ВидимостьТаблицыТР;
	Элементы["КомандаПоказатьТаблицуТрудовыхРесурсов"].Пометка = Не ВидимостьТаблицыТР;
	
КонецПроцедуры  

// Гкс+[TOIR20-186] Селимов 
&НаКлиенте
Процедура ОткрытьАРМЗакрытиеЗаявок(Команда)
	
	ТекущиеДанные = Элементы.ДеревоРемонты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;		
	КонецЕсли; 
	
	ОтборРемонтов = Новый Структура("ID", ТекущиеДанные.ID_Ремонта);	
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ДоступностьКнопкиЗаполнить", Ложь);
	ПараметрыКоманды.Вставить("ОтборРемонтов", ОтборРемонтов);
	ОткрытьФорму("Обработка.торо_ЗакрытиеЗаявокИРемонтов.Форма.Форма", ПараметрыКоманды, ЭтаФорма, Новый УникальныйИдентификатор);
		
КонецПроцедуры  

// Гкс+[TOIR20-186] Селимов 
&НаКлиенте
Процедура СтруктураПодчиненности(Команда)
	
	ТекущиеДанные = Элементы.ДеревоРемонты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;		
	КонецЕсли; 
	
	ОбъектОтбора = Новый Структура("ОбъектОтбора", ТекущиеДанные.ДокументОснование);
	
	ОткрытьФорму("ОбщаяФорма.СтруктураПодчиненности", ОбъектОтбора, ЭтаФорма, Новый УникальныйИдентификатор);
	
КонецПроцедуры 

// Гкс+[TOIR20-186] Селимов 
&НаКлиенте
Процедура СоздатьОстановочныйРемонт(Команда)
	
	ТекущиеДанные = Элементы.ДеревоРемонты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;		
	КонецЕсли; 
	
	ФормаОстановочногоРемонта = ПолучитьФорму("Документ.торо_ОстановочныеРемонты.ФормаОбъекта");
	ДанныеФормы = ФормаОстановочногоРемонта.Объект; 
	ЗаполнитьОстановочныйРемонтНаСервере(ДанныеФормы, ТекущиеДанные.Заявка); // Заполняем документ на сервере
	КопироватьДанныеФормы(ДанныеФормы, ФормаОстановочногоРемонта.Объект); // Копируем наш объект в объект формы и далее открываем ее
	ФормаОстановочногоРемонта.Открыть();	
	
КонецПроцедуры   

// Гкс+[TOIR20-191] Селимов 
&НаКлиенте
Процедура ВыбратьОстановочныйРемонт(Команда)
	
	Если ЗначениеЗаполнено(ЭтаФорма["гкс_ОстановочныйРемонт"]) Тогда
		ОткрытьЗначение(ЭтаФорма["гкс_ОстановочныйРемонт"]);
	Иначе
		ОткрытьФорму("Документ.торо_ОстановочныеРемонты.ФормаВыбора",
					Новый Структура("Отбор", Новый Структура("Проведен", Истина)), ЭтаФорма);
	КонецЕсли; 

КонецПроцедуры      

// Гкс+[TOIR20-191] Селимов
&НаКлиенте
Процедура ОчиститьОстановочныйРемонт(Команда)
	
	ЭтаФорма["гкс_ОстановочныйРемонт"] = Неопределено;
	ОбновитьЗаголовокКнопкиОстановочныйРемонт();
	
КонецПроцедуры  
                                            
#КонецОбласти

#Область СлужебныеПроцедурыИФункции
// Гкс+[TOIR20-173] Селимов		
&НаСервере
Процедура ДобавитьЭлементыФормы()
	
	// РЕКВИЗИТЫ
	ТипЧисло = Новый ОписаниеТипов("Число");
	ТипДата = Новый ОписаниеТипов("Дата");
	
	Реквизиты = Новый Массив;

	Реквизиты.Добавить(Новый РеквизитФормы("ТаблицаТрудозатрат", Новый ОписаниеТипов("ТаблицаЗначений")));
	Реквизиты.Добавить(Новый РеквизитФормы("Квалификация", 
							Новый ОписаниеТипов("СправочникСсылка.торо_КвалификацииРемонтногоПерсонала"), "ТаблицаТрудозатрат"));
	Реквизиты.Добавить(Новый РеквизитФормы("Доступно", ТипЧисло, "ТаблицаТрудозатрат"));
	Реквизиты.Добавить(Новый РеквизитФормы("Требуется", ТипЧисло, "ТаблицаТрудозатрат"));
	
	// Гкс+[TOIR20-184] 
	Реквизиты.Добавить(Новый РеквизитФормы("Стоимость", ТипЧисло, "ДеревоРемонты"));// Гкс-[TOIR20-184] 

	Реквизиты.Добавить(Новый РеквизитФормы("ТрудовыеРесурсы_ПериодС", ТипДата, , , Истина)); 
