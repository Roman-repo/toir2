Функция гкс_ПОЛУЧИТЬСТРУКТУРУ_СТРОКАРЕМОНТОВОБОРУДОВАНИЯ()
	Возврат Новый Структура("ID,
	|ВидРемонтныхРабот,
	|ДатаНачала,
	|ДатаОкончания,
	|Завершен,
	|ОбъектРемонта,
	|ОбъектРемонтаВладелец,
	|ИнвНомер,
	|ТехНомер,
	|ЗаводскойНомер,
	|ОписаниеРемонта,
	|СпособВыполнения,
	|Исполнитель,
	|КритичностьДефекта, 
	|Подчиненный, 
	#Вставка
	|Статус, 
	|ОписаниеРемонта, 
	#КОнецВставки
	|Зависимый");
КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("РемонтыВыбор")
Процедура гкс_РемонтыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	ТекущиеДанные = Элементы.Ремонты.ТекущиеДанные;

	Если Не ТекущиеДанные = Неопределено Тогда
		#Вставка
		Если Поле.Имя = Элементы.РемонтыДокументРегистратор.Имя Тогда 
			ПоказатьЗначение(,ТекущиеДанные.ДокументОснование);
			Возврат;
		КонецЕсли;
		#КонецВставки
		СтрокаРемонтовОборудования = ПОЛУЧИТЬСТРУКТУРУ_СТРОКАРЕМОНТОВОБОРУДОВАНИЯ();
		ЗаполнитьЗначенияСвойств(СтрокаРемонтовОборудования, ТекущиеДанные);
		ОповеститьОВыборе(Новый Структура("СтрокаРемонтовОборудования, ДокументОснование", СтрокаРемонтовОборудования, ТекущиеДанные.ДокументОснование));
	КонецЕсли; 

КонецПроцедуры
// гкс- [разработка 2021] Куст 07.07.2021
#КонецОбласти

