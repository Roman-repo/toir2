		ТекстОтбора2.Добавить("Регистратор.Подразделение В (&Подр)");
	КонецЕсли;   
	Если ЭтотОбъект["гкс_ПодрИсп_Исп"] Тогда 
		Если ЭтотОбъект["гкс_ПодрИсп_"].Количество() Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты5", "ИСТИНА");
			ТекстОтбора2.Добавить("Исполнитель В (&ПодрИсп)");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ &ОтборРемонты4", "ГДЕ ТЧ.Исполнитель В (&ПодрИсп) ");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ &ОтборРемонты3", 
			"Внутреннее соединение РегистрСведений.торо_ЗаявкиПоРемонтам КАК Рег2
			|	ПО Рег2.Регистратор = РегистрСведенийторо_РемонтыСрезПоследних.Регистратор И Рег2.Исполнитель В (&ПодрИсп)");
		Иначе
			ТекстОтбора2.Добавить("Исполнитель В (&ПодрИсп)");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ &ОтборРемонты4", " ");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты5", "(ТЧ.Исполнитель есть NULL 
			|ИЛИ ТЧ.Исполнитель В (&ПодрИсп))");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ &ОтборРемонты3", 
			"Внутреннее соединение РегистрСведений.торо_ЗаявкиПоРемонтам КАК Рег2
			|	ПО Рег2.Регистратор = РегистрСведенийторо_РемонтыСрезПоследних.Регистратор И (Рег2.Исполнитель В (&ПодрИсп)
			|	ИЛИ Не(Рег2.Исполнитель Ссылка Справочник.Контрагенты 
			|	И Рег2.Исполнитель Ссылка Справочник.СтруктураПредприятия))");
		КонецЕсли;
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты5", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ &ОтборРемонты4", " ");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ &ОтборРемонты3", " ");
	КонецЕсли;  
	Если ЭтотОбъект["гкс_РодительОРИсп"] Тогда 
		ТекстОтбора1.Добавить("ОбъектРемонта В (&МассивОР)");
