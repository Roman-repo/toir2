		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты1", "Истина");
	КонецЕсли;
	Если ТекстОтбора2.Количество() Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты2", СтрСоединить(ТекстОтбора2, " И "));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты2", "Истина");
	КонецЕсли;
	// гкс+ [] Деснол 12.09.2022
	Если ЭтотОбъект["гкс_ОтветИсп"] Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты6", "Регистратор.Ответственный В (&Ответственный)");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты6", "Истина");
	КонецЕсли;
	// гкс- [] Деснол 12.09.2022
	// гкс+ [разработка 2021] Куст 08.07.2021
	Если ЭтотОбъект["гкс_ИспОтборНуженОстанов"] Тогда 
