	|		ПО ИтоговаяТаблицаДоОтборовПоЗависимымИДатам.ID = ВТ_Критичности2.ID
	|		И ИтоговаяТаблицаДоОтборовПоЗависимымИДатам.Регистратор = ВТ_Критичности2.Ссылка
	|		Внутреннее соединение ВТ_Статусы КАК ВТ_Статусы
	|		ПО ВТ_Статусы.Регистратор = ИтоговаяТаблицаДоОтборовПоЗависимымИДатам.Регистратор
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаНачала,
	|	ДатаОкончания";
	# КонецОбласти

	ТекстОтбора1 = Новый Массив();
	ТекстОтбора2 = Новый Массив();
	Если ЭтотОбъект["гкс_ОргИсп"] Тогда 
		ТекстОтбора1.Добавить("Регистратор.Организация В (&Орг)");
		ТекстОтбора2.Добавить("Регистратор.Организация В (&Орг)");
	КонецЕсли;
	Если ЭтотОбъект["гкс_ПодрИсп"] Тогда 
