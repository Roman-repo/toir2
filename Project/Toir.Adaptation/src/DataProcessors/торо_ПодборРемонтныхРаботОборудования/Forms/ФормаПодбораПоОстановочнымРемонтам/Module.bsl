		ТекстОтбора1.Добавить("ОбъектРемонта.Направление В (&Направление)");
		ТекстОтбора2.Добавить("ОбъектРемонтныхРабот.Направление В (&Направление)");
	КонецЕсли;
	Если ТекстОтбора1.Количество() Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборРемонты1", СтрСоединить(ТекстОтбора1, " И "));
