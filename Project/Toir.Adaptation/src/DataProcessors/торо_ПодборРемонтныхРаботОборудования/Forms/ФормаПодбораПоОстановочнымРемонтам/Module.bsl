// гкс+ [] Деснол 16.09.2022
&НаКлиенте
Процедура гкс_НайтиСтрокуДалее(Команда)
	ТекДанные = Элементы.Ремонты.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		НачальныйНомер = 0;
	Иначе
		НачальныйНомер = ТекДанные.НомерСтроки;
	КонецЕсли;
	НайденныйИд = Неопределено;
	Для Каждого СтрокаТЧ из Ремонты Цикл
		Если СтрокаТЧ.НомерСтроки <= НачальныйНомер Тогда 
			Продолжить;
		КонецЕсли;
		Если гкс_НайденоВСтрокеТЧ(СтрокаТЧ) Тогда
			НайденныйИд = СтрокаТЧ.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если НайденныйИд = Неопределено Тогда 
		Для Каждого СтрокаТЧ из Ремонты Цикл
			Если СтрокаТЧ.НомерСтроки > НачальныйНомер Тогда 
				Прервать;
			КонецЕсли;
			Если гкс_НайденоВСтрокеТЧ(СтрокаТЧ) Тогда
				НайденныйИд = СтрокаТЧ.ПолучитьИдентификатор();
				Прервать;
			КонецЕсли;                                                
		КонецЦикла;
	КонецЕсли;
	
	Если НайденныйИд = Неопределено Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "поиск не дал результатов";
		Сообщение.Сообщить();
	Иначе
		Элементы.Ремонты.ТекущаяСтрока = НайденныйИд;
	КонецЕсли;
КонецПроцедуры // гкс- [] Деснол 16.09.2022

#КонецОбласти

