#Область ОбработчикиСобытийФормы

&НаСервере
Процедура Расш_гкс_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	// гкс+ [Релиз 1] Куст 17.03.2020
	ДобавитьНовыеЭлементы();
	// гкс- [Релиз 1] Куст 17.03.2020
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
&ИзменениеИКонтроль("ЖурналДефектов")
Процедура Расш_гкс_ЖурналДефектов(Команда)
	ПараметрыОтбора = Новый Структура();
	ПараметрыОтбора.Вставить("НачПериода", НачалоГода(Дата));
	ПараметрыОтбора.Вставить("КонПериода", КонецГода(Дата));
	ПараметрыОтбора.Вставить("ПодразделениеДляДок", ПодразделениеДляДок);
	ПараметрыОтбора.Вставить("Организация", Организация);
	#Удаление
	ПараметрыОтбора.Вставить("ОР", ТекущийОР);
	#КонецУдаления
	#Вставка
	// гкс+ [8078] Тарасов 09.10.2020
	ПараметрыОтбора.Вставить("ОР", ОтказавшийЭлемент);
	ПараметрыОтбора.Вставить("гкс_ОРОтказавшийЭлемент", Истина);
	// гкс- [8078] Тарасов 09.10.2020
	#КонецВставки
	
	допПараметры = Новый Структура();
	допПараметры.Вставить("ПараметрыОтбора", ПараметрыОтбора);

	ОткрытьФорму("Документ.торо_ВыявленныеДефекты.Форма.ФормаЖурналаДефектов", допПараметры);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// гкс+ [Релиз 1] Куст 17.03.2020
&НаСервере
Процедура ДобавитьНовыеЭлементы()
	Элементы.ТиповойДефект.Видимость = Ложь;
	Элементы.ПричинаДефекта.АвтоОтметкаНезаполненного = Ложь;
	Элементы.ВидДефекта.Видимость = Ложь;
	Элементы.ПричинаДефекта.Видимость = Ложь;
	Элементы.Переместить(Элементы.УсловияВыявленияДефекта, Элементы.ДефектыЛевая);
	
	НовыеРеквизиты = Новый Массив();
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_СдвигЧП", Новый ОписаниеТипов("Число",,, 
		Новый КвалификаторыЧисла(2,0))));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_Влияние",
		Новый ОписаниеТипов("ПеречислениеСсылка.гкс_Влияние")));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_СимптомДефекта",
		Новый ОписаниеТипов("СправочникСсылка.гкс_СимптомыДефектов")));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_НаправлениеНаУстранение",
		Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(300)),, 
		НСтр("ru='Комментарий к направлению на устранение';
		|en='Comment on the direction for elimination'")));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_ОписаниеДефекта",
		Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(300)),, 
		НСтр("ru='Описание дефекта';en='Defect description';es='El defecto la descripción'"))); 
	// Гкс+[TOIR20-511] Вялых Д.А. от 23.01.2025. Добавлено:{
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_ДефектОформленПоТАГ",
		Новый ОписаниеТипов("Булево"),, 
		"Дефект выявлен по ТАГ"));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_НомерТАГ",
		Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(20)),, 
		"Номер ТАГ"));
	// } Гкс-[TOIR20-511] Вялых Д.А. от 23.01.2025.
	ИзменитьРеквизиты(НовыеРеквизиты);
	

	
	// гкс+ [Часовые пояса] Куст 14.04.2020
	ДатаСервера = ТекущаяДата();
	ДатаКлиента = ТекущаяДатаСеанса();
	Если Секунда(ДатаСервера) >= Секунда(ДатаКлиента) Тогда 
		Разница = Час(ДатаКлиента) - Час(ДатаСервера) ;
	Иначе
		Разница = Час(ДатаКлиента) - Час(ДатаСервера) + 1;
	КонецЕсли;
	ЭтаФорма["гкс_СдвигЧП"] = Разница;
	// гкс- [Часовые пояса] Куст 14.04.2020
	
	НЭлем = Элементы.Добавить("гкс_Влияние",Тип("ПолеФормы"), Элементы.ДефектыЛевая);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_Влияние";
	НЭлем.Заголовок = НСтр("ru='Влияние';en='Impact'");
	// гкс+ [Релиз 1] Куст 05.11.2020
	НЭлем.АвтоОтметкаНезаполненного = Истина;
	// гкс- [Релиз 1] Куст 05.11.2020
	
	НЭлем = Элементы.Добавить("гкс_СимптомДефекта", Тип("ПолеФормы"), Элементы.ДефектыЛевая);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_СимптомДефекта";
	НЭлем.Заголовок = НСтр("ru='Симптом дефекта';en='Symptom defect'");
	НЭлем.АвтоОтметкаНезаполненного = Истина;
	
	НЭлем = Элементы.Добавить("гкс_ОписаниеДефекта", Тип("ПолеФормы"), Элементы.ГруппаНижняя);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_ОписаниеДефекта";
	НЭлем.Ширина = 101;
	НЭлем.АвтоОтметкаНезаполненного = Истина;
	
	НЭлем = Элементы.Добавить("гкс_НаправлениеНаУстранение", Тип("ПолеФормы"), Элементы.ГруппаНижняя);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_НаправлениеНаУстранение";
	НЭлем.Ширина = 101; 
	
	Элементы.ОписаниеДефекта.Видимость = Ложь;
	
	// Гкс+[TOIR20-511] Вялых Д.А. от 23.01.2025. Добавлено:{
	НЭлем = Элементы.Вставить("гкс_НомерТАГ", Тип("ПолеФормы"), Элементы.ГруппаНижняя, Элементы.Инициатор);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_НомерТАГ"; 
	НЭлем.Маска = "99999999999999999999";
	НЭлем.Доступность = Ложь; 
	
	НЭлем = Элементы.Вставить("гкс_ДефектОформленПоТАГ", Тип("ПолеФормы"), Элементы.ГруппаНижняя, Элементы.гкс_НомерТАГ);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_ДефектОформленПоТАГ";
	НЭлем.УстановитьДействие("ПриИзменении", "Расш_гкс_ПриИзмененииДефектОформленПоТАГ");
	// } Гкс-[TOIR20-511] Вялых Д.А. от 23.01.2025.
	
	
	НКом = Команды.Добавить("гкс_ОткрытьПрисоединенныеФайлы");
	НКом.Действие = "ОткрытьПрисоединенныеФайлы";
	
	НЭлем = Элементы.Добавить("гкс_ГруппаДокНовый", Тип("ГруппаФормы"));
	НЭлем.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НЭлем.ОтображатьЗаголовок = Ложь;
	НЭлем.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	Элементы.Переместить(Элементы["гкс_ГруппаДокНовый"], Элементы.ГруппаНижняя,Элементы.НовыйДок);
	Элементы.Переместить(Элементы.НовыйДок, Элементы["гкс_ГруппаДокНовый"]);
	
	НКноп = Элементы.Добавить("гкс_ОткрытьПрисоединенныеФайлы", Тип("КнопкаФормы"), Элементы["гкс_ГруппаДокНовый"]);
	НКноп.ИмяКоманды = "гкс_ОткрытьПрисоединенныеФайлы";
	НКноп.Заголовок = НСтр("ru='Открыть присоединенные файлы';en='Open attached files'");
	НКноп.Отображение = ОтображениеКнопки.Картинка;
	НКноп.Картинка = БиблиотекаКартинок.Скрепка;
	
	Элементы.ДефектыЛевая.СквозноеВыравнивание = СквозноеВыравнивание.Использовать;
	Элементы.Дефекты.СквозноеВыравнивание = СквозноеВыравнивание.Использовать;	
	
	// гкс+ [8078] Тарасов 09.10.2020
	Элементы.КритичностьДефекта.АвтоОтметкаНезаполненного = Истина;
	// гкс- [8078] Тарасов 09.10.2020
КонецПроцедуры
// гкс- [Релиз 1] Куст 17.03.2020

