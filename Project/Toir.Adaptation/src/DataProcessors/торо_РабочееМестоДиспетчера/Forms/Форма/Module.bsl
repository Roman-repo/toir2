// гкс+ [Релиз 1] Куст 17.03.2020
&НаСервереБезКонтекста
Функция ЭтоФМ(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ОбъектыРемонта.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|ГДЕ
		|	торо_ОбъектыРемонта.Ссылка = &Ссылка
		|	И торо_ОбъектыРемонта.ТипОбъекта = ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто)
		|	И торо_ОбъектыРемонта.ЭтоГруппа = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);          
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции
// гкс- [Релиз 1] Куст 17.03.2020

// гкс+ [Релиз 1] Куст 17.03.2020
&НаСервереБезКонтекста
Функция НайтиФМИЗаполнитьДанныеОРНаСервере(Ссылка)
	
	ТекущееФункциональноеФесто = гкс_ПроверкаФункциональныхМест.НайтиФМ(Ссылка);
	Если ЗначениеЗаполнено(ТекущееФункциональноеФесто) И НЕ Ссылка = ТекущееФункциональноеФесто Тогда 
		Ссылка = ТекущееФункциональноеФесто;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	торо_ОбъектыРемонта.ИнвентарныйНомер КАК ИнвентарныйНомер,
	               |	торо_ОбъектыРемонта.ЗаводскойНомер КАК ЗаводскойНомер,
	               |	торо_ОбъектыРемонта.ТехНомер КАК ТехНомер,
	               |	торо_ОбъектыРемонта.АдресМестонахождения КАК АдресМестонахождения,
	               |	торо_ОбъектыРемонта.Наименование КАК Наименование,
	               |	торо_ОбъектыРемонта.Подразделение КАК Подразделение,
	               |	торо_ОбъектыРемонта.ПодразделениеИсполнитель КАК ПодразделениеИсполнитель,
	               |	торо_ОбъектыРемонта.Направление КАК Направление,
	               |	торо_ОбъектыРемонта.ЭтоГруппа КАК ЭтоГруппа,
	               |	торо_ОбъектыРемонта.ВнешнийОбъект КАК ВнешнийОбъект,
	               |	торо_ОбъектыРемонта.Контрагент КАК Контрагент,
				   |	торо_ОбъектыРемонта.ТипОбъекта = 
				   |	Значение(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто) КАК ЭтоФМ,
				   |	торо_ОбъектыРемонта.Ссылка
	               |ИЗ
	               |	Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
	               |ГДЕ
	               |	торо_ОбъектыРемонта.Ссылка = &Ссылка";
				   
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	стрВозврата = Новый Структура("ИнвентарныйНомер,ЗаводскойНомер,ТехНомер,АдресМестонахождения,Наименование,"
		+ "Подразделение,ПодразделениеИсполнитель,Направление,ЭтоГруппа,ВнешнийОбъект,Контрагент,ЭтоФМ,Ссылка");
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат стрВозврата;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(стрВозврата, Выборка);
	Возврат стрВозврата;
	
КонецФункции
// гкс- [Релиз 1] Куст 17.03.2020

&НаКлиенте
&ИзменениеИКонтроль("ОтказавшийЭлементОбработкаВыбора")
Процедура Расш_гкс_ОтказавшийЭлементОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	#Вставка
	Если ЭтоФМ(ВыбранноеЗначение) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Отказавшим элементом не должно быть функциональое место!'");
		Сообщение.Сообщить();
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;
	#КонецВставки
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		струк = ЗаполнитьДанныеОРНаСервере(ВыбранноеЗначение);
		Направление = струк.Направление;
	Иначе
		Направление = ПредопределенноеЗначение("Справочник.торо_НаправленияОбъектовРемонтныхРабот.ПустаяСсылка");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ЗаполнитьДанныеОРНаКлиенте")
Процедура Расш_гкс_ЗаполнитьДанныеОРНаКлиенте1(ТекущиеДанные)

	Если ТекущиеДанные <> Неопределено Тогда

		ТекущийОР = ТекущиеДанные.Ссылка;
		#Удаление
		стрВозврата = ЗаполнитьДанныеОРНаСервере(ТекущийОР);
		#КонецУдаления
		#Вставка
		стрВозврата = НайтиФМИЗаполнитьДанныеОРНаСервере(ТекущийОР);
		#КонецВставки

		ВходитВСостав = торо_РаботаСИерархией20.ПолучитьТекущегоРодителяВИерархии(ТекущийОР, ТекСтруктураИерархии);

		Если стрВозврата.Контрагент <> Неопределено И ЗначениеЗаполнено(стрВозврата.Контрагент) Тогда
			Элементы.Подразделение.Видимость = Ложь;
			Элементы.Контрагент.Видимость = Истина;
		Иначе
			Элементы.Подразделение.Видимость = Истина;
			Элементы.Контрагент.Видимость = Ложь;
		КонецЕсли;

		Подразделение = стрВозврата.Подразделение;
		Наименование = стрВозврата.Наименование;
		ОбъектРемонта = стрВозврата.Ссылка;
		Местонахождение = стрВозврата.АдресМестонахождения;
		ИнвентарныйНомер = стрВозврата.ИнвентарныйНомер;
		ЗаводскойНомер = стрВозврата.ЗаводскойНомер;
		ТехнологичейскийНомер = стрВозврата.ТехНомер;
		ПодразделениеИсполнитель = стрВозврата.ПодразделениеИсполнитель;
		Контрагент = стрВозврата.Контрагент;
		Направление = стрВозврата.Направление;

		#Удаление
		Если стрВозврата.ЭтоГруппа <> Неопределено И стрВозврата.ЭтоГруппа = Ложь Тогда
		#КонецУдаления
		#Вставка
		Если (стрВозврата.ЭтоГруппа <> Неопределено И стрВозврата.ЭтоГруппа = Ложь)
			И Не стрВозврата.ЭтоФМ = Истина Тогда
		#КонецВставки
			ОтказавшийЭлемент = ТекущиеДанные.Ссылка;
		Иначе
			ОтказавшийЭлемент = Неопределено;
		КонецЕсли;

		Дата = ТекущаяДата();
		ДатаОбнаружения = ТекущаяДата();

		#Удаление
		КонтактноеЛицо = Неопределено;
		#КонецУдаления
		ТиповойДефект = Неопределено;
		КритичностьДефекта = Неопределено;
		ОписаниеДефекта = Неопределено;
		ВидДефекта = Неопределено;
		ПричинаДефекта = Неопределено;
		УсловияВыявленияДефекта = Неопределено;
		#Вставка
		// Гкс+[TOIR20-511] Вялых Д.А. от 23.01.2025. Добавлено:{
	    ЭтотОбъект["гкс_ДефектОформленПоТАГ"] = Ложь;
		ЭтотОбъект["гкс_НомерТАГ"] = "";
		Элементы.гкс_НомерТАГ.Доступность = Ложь;
		// } Гкс-[TOIR20-511] Вялых Д.А. от 23.01.2025.	
		ЭтотОбъект["гкс_ОписаниеДефекта"] = Неопределено;
		#КонецВставки

		Статус = "";
		Номер = "";
		НовыйДок = Неопределено;
	Иначе 
		Статус = "";
		Номер = "";
		НовыйДок = Неопределено;
	КонецЕсли;

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ЗаполнитьПоТИповомуДефекту")
Процедура Расш_гкс_ЗаполнитьПоТИповомуДефекту1()

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	торо_ТиповыеДефектыОборудованияПричиныВозникновенияДефекта.Причина КАК Причина,
	|	торо_ТиповыеДефектыОборудования.ВидДефекта КАК ВидДефекта,
	|	торо_ТиповыеДефектыОборудования.КритичностьДефекта КАК КритичностьДефекта,
	|	торо_ТиповыеДефектыОборудования.ОписаниеДефекта КАК ОписаниеДефекта,
	|	торо_ТиповыеДефектыОборудования.НаправлениеНаУстранение КАК НаправлениеНаУстранение,
	|	торо_ТиповыеДефектыОборудования.ПоследствиеДефекта КАК ПоследствиеДефекта
	|ИЗ
	|	Справочник.торо_ТиповыеДефектыОборудования КАК торо_ТиповыеДефектыОборудования
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеДефектыОборудования.ПричиныВозникновенияДефекта КАК торо_ТиповыеДефектыОборудованияПричиныВозникновенияДефекта
	|		ПО (торо_ТиповыеДефектыОборудованияПричиныВозникновенияДефекта.Ссылка = торо_ТиповыеДефектыОборудования.Ссылка)
	|ГДЕ
	|	торо_ТиповыеДефектыОборудования.Ссылка = &Ссылка";

	Запрос.УстановитьПараметр("Ссылка", ТиповойДефект);

	Результат = Запрос.Выполнить();

	Если Результат.Пустой() Тогда возврат; КонецЕсли;

	Выборка = Результат.Выбрать();
	Выборка.Следующий();

	ВидДефекта = Выборка.ВидДефекта;
	ПричинаДефекта = Выборка.Причина;
	КритичностьДефекта = Выборка.КритичностьДефекта;
	ОписаниеДефекта = Выборка.ОписаниеДефекта;
	ПоследствиеДефекта = Выборка.ПоследствиеДефекта;
	НаправлениеНаУстранение = Выборка.НаправлениеНаУстранение;
	#Вставка
	ЭтотОбъект["гкс_НаправлениеНаУстранение"] = Выборка.НаправлениеНаУстранение;
	ЭтотОбъект["гкс_ОписаниеДефекта"] = Выборка.ОписаниеДефекта;
	#КонецВставки

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПроверитьЗаполнениеОбязательныхРеквизитов")
Функция Расш_гкс_ПроверитьЗаполнениеОбязательныхРеквизитов1()

	Ошибка = Ложь;

	масОшибок = Новый Массив;

	Если Не ЗначениеЗаполнено(Организация) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Организация");
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ПодразделениеДляДок) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Подразделение");
	КонецЕсли;
	Если Не ЗначениеЗаполнено(УсловияВыявленияДефекта) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Дефект выявлен в процессе");
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Дата) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Дата");
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ДатаОбнаружения) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Дата обнаружения");
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ОтказавшийЭлемент) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Отказавший элемент");
	КонецЕсли;
	#Удаление
	Если Не ЗначениеЗаполнено(ВидДефекта) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Вид дефекта");
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ПричинаДефекта) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Причина дефекта");
	КонецЕсли;
	#КонецУдаления
	#Вставка
	Если Не ЗначениеЗаполнено(ЭтотОбъект["гкс_СимптомДефекта"]) Тогда
		Ошибка = Истина;
		масОшибок.Добавить(НСтр("ru='Симптом дефекта';en='Symptom defect'"));
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЭтотОбъект["гкс_ОписаниеДефекта"]) Тогда
		Ошибка = Истина;
		масОшибок.Добавить(НСтр("ru='Описание дефекта';en='Defect description';es='El defecto la descripción'"));
	КонецЕсли;
	// Гкс+[TOIR20-511] Вялых Д.А. от 23.01.2025. Добавлено:{	
	Если ЭтотОбъект["гкс_ДефектОформленПоТАГ"] И НЕ ЗначениеЗаполнено(ЭтотОбъект["гкс_НомерТАГ"]) Тогда
		Ошибка = Истина;
		масОшибок.Добавить("Номер ТАГ");
	КонецЕсли;
	// } Гкс-[TOIR20-511] Вялых Д.А. от 23.01.2025.
	
	// гкс+ [8078] Тарасов 09.10.2020
	Если Не ЗначениеЗаполнено(КритичностьДефекта) Тогда
		Ошибка = Истина;
		масОшибок.Добавить(НСтр("ru='Критичность дефекта';en='Defect criticality'"));
	КонецЕсли;
	// гкс- [8078] Тарасов 09.10.2020
	// гкс+ [Релиз 1] Куст 05.11.2020  
	Если Не ЗначениеЗаполнено(ЭтотОбъект["гкс_Влияние"]) Тогда
		Ошибка = Истина;
		масОшибок.Добавить(НСтр("ru='Влияние';en='Impact'"));
	КонецЕсли;
	//
	Если Не ЗначениеЗаполнено(ЭтотОбъект["ОбъектРемонта"]) Тогда
		Ошибка = Истина;
		масОшибок.Добавить(НСтр("ru='ФМ';en='FP'"));
	КонецЕсли;
	// гкс- [Релиз 1] Куст 05.11.2020
	#КонецВставки

	Для каждого текСтрока из масОшибок Цикл
		#Удаление
		ШаблонСообщения = НСтр("ru = 'Поле <%1> не заполнено! Документ не будет создан.'");
		#КонецУдаления
		#Вставка
		ШаблонСообщения = НСтр("es='¡Campo <%1> no es rellenado! El documento no será creado.';
			|ru='Поле <%1> не заполнено! Документ не будет создан.';
			|en='Field <%1> is empty! The document will not be created.'");
		#КонецВставки
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ТекСтрока);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЦикла;

	Возврат Ошибка;

КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("ОбработкаВыбора")
Процедура Расш_гкс_ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ИсточникВыбора <> Неопределено Тогда
		ТиповойДефект = ВыбранноеЗначение.Дефект;
		ВидДефекта = ВыбранноеЗначение.ВидДефекта;
		КритичностьДефекта = ВыбранноеЗначение.КритичностьДефекта;
		ПричинаДефекта = ВыбранноеЗначение.ПричинаДефекта;
		ОписаниеДефекта = ВыбранноеЗначение.ДефектОписание;
		#Вставка
		ЭтотОбъект["гкс_ОписаниеДефекта"] = ВыбранноеЗначение.ДефектОписание;
		#КонецВставки
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ЗарегистрироватьДефект")
Процедура Расш_гкс_ЗарегистрироватьДефект(Команда)

	Если ПроверитьЗаполнениеОбязательныхРеквизитов() Тогда
		Возврат;
	КонецЕсли;

	Если Элементы.СтраницыГруппаЛевая.ТекущаяСтраница = Элементы.ГруппаДерево Тогда
		ТекДанные = Элементы.Дерево.ТекущиеДанные;
		Если ТипЗнч(ТекДанные.Ссылка) = Тип("СправочникСсылка.торо_СтруктурыОР") Тогда
			#Удаление
			ТекстСообщения = НСтр("ru = 'В качестве объекта ремонта нельзя выбрать вид иерархии объектов ремонта.'");
			#КонецУдаления
			#Вставка
			ТекстСообщения = НСтр("es='En calidad del objeto de la reparación no es posible escoger el tipo de la jerarquía"
				+ " de los objetos de la reparación.';ru='В качестве объекта ремонта нельзя выбрать вид иерархии объектов"
				+ " ремонта.';en='You cannot select the type of hierarchy of repair objects as a repair object.'");
			#КонецВставки
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
	Иначе
		ТекДанные = Элементы.Список.ТекущиеДанные;
	КонецЕсли; 

	Если ТекДанные.ЭтоГруппа = Истина Тогда
		#Удаление
		ТекстСообщения = НСтр("ru = 'В качестве объекта ремонта нельзя выбрать группу.'");
		#КонецУдаления
		#Вставка
		ТекстСообщения = НСтр("es='En calidad del objeto de la reparación no es posible escoger el grupo.'
			|;ru='В качестве объекта ремонта нельзя выбрать группу.';
			|en='You cannot select a group as a repair item.'");
		#КонецВставки
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;	

	Результат = СоздатьДокументВыявленныйДефект();
	Если ЗначениеЗаполнено(Результат) тогда
		Номер = Результат;
		Статус = "Зарегистрирован";

		Если ФОНапоминатьЗафиксироватьПростой И ФОУчетСостоянияОборудования Тогда
			#Удаление
			ПоказатьВопрос(Новый ОписаниеОповещения("ЗарегистрироватьДефектЗавершение", ЭтотОбъект, Неопределено), НСтр("ru = 'Зафиксировать фактический простой объектов?'"), РежимДиалогаВопрос.ДаНет);
			#КонецУдаления
			#Вставка
			ПоказатьВопрос(Новый ОписаниеОповещения("ЗарегистрироватьДефектЗавершение", ЭтотОбъект, Неопределено),
				НСтр("es='¿Fijar las horas muertas reales de los objetos?';ru='Зафиксировать фактический простой объектов?';
				|en='Lock actual downtime to objects?'"), РежимДиалогаВопрос.ДаНет);
			#КонецВставки
		КонецЕсли; 
	КонецЕсли;

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("СоздатьДокументВыявленныйДефект")
Функция Расш_гкс_СоздатьДокументВыявленныйДефект1()

	Если ЗначениеЗаполнено(Номер) и Документы.торо_ВыявленныеДефекты.НайтиПоНомеру(Номер, Дата) <> Неопределено Тогда
		#Удаление
		ТекстСообщения = НСтр("ru = 'Документ с таким номером уже существует в этом периоде! Документ не был создан.'");
		#КонецУдаления
		#Вставка
		ТекстСообщения = НСтр("es='¡El documento con tal número existe ya en este período! El documento no era creado.'
			|;ru='Документ с таким номером уже существует в этом периоде! Документ не был создан.';
			|en='A document with this number already exists in this period! The document was not created.'");
		#КонецВставки
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат Неопределено;
	КонецЕсли;

	ВидДокумента = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ВыявленныеДефекты;
	СогласованиеИспользуется = торо_РаботаССогласованиями.ПроверитьИспользованиеСогласованияДокументов(ВидДокумента);

	СтруктураЗаполнения = Новый Структура;
	#Вставка
	Если Не ЭтаФорма["гкс_СдвигЧП"] = 0 Тогда 
		СтруктураЗаполнения.Вставить("Дата", Дата - (ЭтаФорма["гкс_СдвигЧП"] * 3600));
		СтруктураЗаполнения.Вставить("ДатаОбнаружения", ДатаОбнаружения - (ЭтаФорма["гкс_СдвигЧП"] * 3600));	
	Иначе
	#КонецВставки
	СтруктураЗаполнения.Вставить("Дата", Дата);
	СтруктураЗаполнения.Вставить("ДатаОбнаружения", ДатаОбнаружения);
	#Вставка
	КонецЕсли;
	#КонецВставки
	Если ЗначениеЗаполнено(Номер) Тогда 
		СтруктураЗаполнения.Вставить("Номер", Номер);
	КонецЕсли;

	СтруктураЗаполнения.Вставить("Инициатор", Инициатор);
	СтруктураЗаполнения.Вставить("КонтактноеЛицоИнициатора", КонтактноеЛицо);
	СтруктураЗаполнения.Вставить("ДефектВыявленВПроцессе", УсловияВыявленияДефекта);
	СтруктураЗаполнения.Вставить("Организация", Организация);
	СтруктураЗаполнения.Вставить("Подразделение", ПодразделениеДляДок);
	СтруктураЗаполнения.Вставить("ОбъектРемонта", ОбъектРемонта);
	СтруктураЗаполнения.Вставить("ПодразделениеИсполнитель", ПодразделениеИсполнитель);
	#Вставка
	СтруктураЗаполнения.Вставить("гкс_Влияние", ЭтотОбъект["гкс_Влияние"]);
	// Гкс+[TOIR20-511] Вялых Д.А. от 23.01.2025. Добавлено:{
	СтруктураЗаполнения.Вставить("гкс_ДефектОформленПоТАГ", ЭтотОбъект["гкс_ДефектОформленПоТАГ"]);
	СтруктураЗаполнения.Вставить("гкс_НомерТАГ", ЭтотОбъект["гкс_НомерТАГ"]);
	// } Гкс-[TOIR20-511] Вялых Д.А. от 23.01.2025.
	#КонецВставки

	СтруктураСтрокиТЧ = Новый Структура;
	СтруктураСтрокиТЧ.Вставить("ОтказавшийЭлемент", ОтказавшийЭлемент);
	СтруктураСтрокиТЧ.Вставить("ОбъектРемонта", ОбъектРемонта);
	СтруктураСтрокиТЧ.Вставить("ТиповойДефект", ТиповойДефект);
	СтруктураСтрокиТЧ.Вставить("ВидДефекта", ВидДефекта);
	СтруктураСтрокиТЧ.Вставить("ДефектПричина", ПричинаДефекта);
	СтруктураСтрокиТЧ.Вставить("КритичностьДефекта", КритичностьДефекта);
	#Удаление
	СтруктураСтрокиТЧ.Вставить("ДефектОписание", ОписаниеДефекта);
	#КонецУдаления
	СтруктураСтрокиТЧ.Вставить("ПоследствияДефекта", ПоследствиеДефекта);
	#Удаление
	СтруктураСтрокиТЧ.Вставить("НаправлениеНаУстранение", НаправлениеНаУстранение);
	#КонецУдаления
	СтруктураСтрокиТЧ.Вставить("ПодразделениеИсполнитель", ПодразделениеИсполнитель);
	#Вставка
	СтруктураСтрокиТЧ.Вставить("ДефектОписание", ЭтотОбъект["гкс_ОписаниеДефекта"]);
	СтруктураСтрокиТЧ.Вставить("гкс_СимптомДефекта", ЭтаФорма["гкс_СимптомДефекта"]);
	СтруктураСтрокиТЧ.Вставить("НаправлениеНаУстранение", ЭтотОбъект["гкс_НаправлениеНаУстранение"]);
	#КонецВставки

	МассивСтрокТЧ = Новый Массив;
	МассивСтрокТЧ.Добавить(СтруктураСтрокиТЧ);

	СтруктураЗаполнения.Вставить("МассивСтрокТЧ", МассивСтрокТЧ);

	докОбъект = Документы.торо_ВыявленныеДефекты.СоздатьДокумент();
	докОбъект.Заполнить(СтруктураЗаполнения);
	
	#Вставка
	// Гкс+[TOIR20-511] Вялых Д.А. от 23.01.2025. Добавлено:{
	докОбъект.гкс_ДефектОформленПоТАГ = СтруктураЗаполнения.гкс_ДефектОформленПоТАГ;
	// } Гкс-[TOIR20-511] Вялых Д.А. от 23.01.2025.
	
	// Гкс+[TOIR20-577] Зозуля А.В. от 22.04.2025. Добавлено:{
	СписокДефектов = докОбъект.СписокДефектов;
	Если СписокДефектов.Количество() > 0 Тогда
		ДанныеТабличнойЧасти = Новый ТаблицаЗначений;
		ДанныеТабличнойЧасти.Колонки.Добавить("ОтказавшийЭлемент", Новый ОписаниеТипов("СправочникСсылка.торо_ОбъектыРемонта")); 
		ДанныеТабличнойЧасти.Колонки.Добавить("КритичностьДефекта", Новый ОписаниеТипов("СправочникСсылка.торо_КритичностьДефекта"));
		Для Каждого ТекСтрока Из СписокДефектов Цикл
			НоваяСтрока = ДанныеТабличнойЧасти.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		КонецЦикла;	
		
		Менеджер = Документы.торо_ВыявленныеДефекты;
		СтруктураОтвета = Менеджер.гкс_МаксимальнаяСрочностьВоздействияИКачественнаяОценка(ДанныеТабличнойЧасти);
		докОбъект.гкс_СрочностьВоздействия = СтруктураОтвета.СрочностьВоздействия;
		докОбъект.гкс_КачественнаяОценка = СтруктураОтвета.КачественнаяОценка;
	КонецЕсли;	
	// } Гкс-[TOIR20-577] Зозуля А.В. от 22.04.2025.
	#КонецВставки

	Попытка
		Если СогласованиеИспользуется Тогда
			докОбъект.Записать(РежимЗаписиДокумента.Запись);
		Иначе 
			докОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЕсли;
	Исключение
		#Удаление
		ТекстСообщения = НСтр("ru = 'При записи документа произошла ошибка: '") + ОписаниеОшибки();
		#КонецУдаления
		#Вставка
		ТекстСообщения = НСтр("es='A la anotación del documento había una falta: '
			|;ru='При записи документа произошла ошибка: ';
			|en='An error occurred while writing the document: '") + ОписаниеОшибки();
		#КонецВставки
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		возврат Неопределено;
	КонецПопытки;

	НовыйДок = докОбъект.Ссылка;
	Возврат докОбъект.Номер;	

КонецФункции

