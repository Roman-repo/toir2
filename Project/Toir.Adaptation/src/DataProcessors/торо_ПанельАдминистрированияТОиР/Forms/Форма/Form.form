              <title>
                <key>ru</key>
                <value>Опасный производственный объект</value>
              </title>
              <title>
                <key>es</key>
                <value>El objeto peligroso de producción</value>
              </title>
              <title>
                <key>en</key>
                <value>Hazardous production facility</value>
              </title>
              <visible>true</visible>
              <enabled>true</enabled>
