КонецФункции

&НаСервере
Функция гкс_ПроверитьДублиСтрок(ВидДокумент, Организация, Подразделение, ПодрИсп)
	
	тз = СпособыСогласованияПоУмолчанию.Выгрузить();
	Если ВидДокумент = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ЗаявкаНаРемонт ИЛИ
				ВидДокумент = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ВыявленныеДефекты ИЛИ
				ВидДокумент = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_АктОВыполненииЭтапаРабот ИЛИ
				ВидДокумент = Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ВнешнееОснованиеДляРабот Тогда 
		найс = тз.НайтиСтроки(Новый Структура("ВидДокумента, Организация, Подразделение, гкс_ПодразделениеИсполнитель", ВидДокумент, Организация, Подразделение, ПодрИсп));
	Иначе
		найс = тз.НайтиСтроки(Новый Структура("ВидДокумента, Организация, Подразделение", ВидДокумент, Организация, Подразделение));
	КонецЕсли;
	
	Если найс.Количество() > 1 Тогда
		ШаблонСообщения = НСтр("es='Para la organización %1 y la subdivisión %2 es indicado ya el modo de la coordinación. Escojan otra organización o la subdivisión.'
		|;ru='Для организации %1 и подразделения %2 уже указан способ согласования. Выберите другую организацию или подразделение.';
		|en='The %1 organization and %2 division already have a matching method specified. Select a different organization or organizational unit.'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, Организация, Подразделение);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("СпособыСогласованияПоУмолчаниюПередОкончаниемРедактирования")
Процедура Расш_гкс_СпособыСогласованияПоУмолчаниюПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)

	Если НоваяСтрока И Не ОтменаРедактирования Тогда
		Элемент.ТекущиеДанные.ВидДокумента = ТекущийВидДокумента;
	КонецЕсли;

	текСтрока = Элемент.ТекущиеДанные;
	Если текСтрока <> Неопределено И Не ОтменаРедактирования Тогда
		#Удаление
		Если ПроверитьДублиСтрок(текСтрока.ВидДокумента, текСтрока.Организация, текСтрока.Подразделение) Тогда
		#КонецУдаления
		#Вставка
		Если гкс_ПроверитьДублиСтрок(текСтрока.ВидДокумента, текСтрока.Организация, 
				текСтрока.Подразделение, текСтрока.гкс_ПодразделениеИсполнитель) Тогда
		#КонецВставки
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

