	// гкс- [Релиз 1] Куст 20.01.2021
	МассивРеквизитов.Добавить(Новый РеквизитФормы("торо_ПараметрыОповещенияОПроверкеОборудованияНаФМ",
	Новый ОписаниеТипов("СправочникСсылка.торо_СобытияУведомленийВДокументах")));
