#Область ОбработчикиСобытийФормы

&НаСервере
Процедура Расш_гкс_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	НЭлем = Команды.Добавить("ОткрытьНастройкуГруппФайлов");
	НЭлем.Действие = "ОткрытьНастройкуГруппФайлов";
	НЭлем.Заголовок = НСтр("ru='Группы присоединенных файлов';en='Groups of attached files'");
	
	НЭлем = Элементы.Добавить("гкс_ОткрытьНастройкуГруппФайлов", Тип("КнопкаФормы"), Элементы.СтраницаОбщие);
	НЭлем.ИмяКоманды = "ОткрытьНастройкуГруппФайлов";
	// гкс+ [Релиз19] Деснол
	Если Не (РольДоступна("ПолныеПрава")
		ИЛИ РольДоступна("гкс_РедактированиеЗаявкиНаРемонт"))
		И РольДоступна("гкс_РедактированиеИерархииФайлов") = Ложь Тогда 
	// гкс- [Релиз19]
		НЭлем.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
&Перед("ПриЗаписиНаСервере")
Процедура Расш_гкс_ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Константы.торо_ДатаНачалаФиксацииПеремещенийМеждуФМ.Установить(ЭтотОбъект["ДатаФиксацииМеремещенийФМ"]);
	Константы.гкс_РазрешитьПрисоединенныеФайлыТОИР.Установить(ЭтотОбъект["гкс_РазрешитьПрисоединенныеФайлыТОИР"]);
	Константы.гкс_СобытиеИстеченияСрокаСогласования.Установить(ЭтотОбъект["гкс_СобытиеИстеченияСрокаСогласования"]);
	Константы.гкс_СобытиеПросрочкиСрокаСогласования.Установить(ЭтотОбъект["гкс_СобытиеПросрочкиСрокаСогласования"]);
	Константы.гкс_КолвоДнейДоОкончанияСрокаСогласования.Установить(ЭтотОбъект["гкс_КолвоДнейДоОкончанияСрокаСогласования"]);
	Константы.гкс_СобытиеПросрочкиМероприятияЕвобланк.Установить(ЭтотОбъект["гкс_СобытиеПросрочкиМероприятияЕвобланк"]);
	// гкс+ [11.22] Деснол 17.11.2022
	Константы.гкс_СобытиеПереносРемонтаЗаявки.Установить(ЭтотОбъект["гкс_СобытиеПереносРемонтаЗаявки"]);
	Константы.гкс_ОтключитьМногоязычностьОР.Установить(ЭтотОбъект["гкс_ОтключитьМногоязычностьОР"]);
	// гкс- [11.22] Деснол 17.11.2022
	// гкс+ [03.23] Деснол 24.03.2023
	Константы.гкс_СкрытьСтоимостьРемонта.Установить(ЭтотОбъект["гкс_СкрытьСтоимостьРемонта"]);
	// гкс- [03.23] Деснол 24.03.2023
	Константы.торо_ПараметрыОповещенияОПроверкеОборудованияНаФМ.Установить(
		ЭтотОбъект["торо_ПараметрыОповещенияОПроверкеОборудованияНаФМ"]);
	Константы.гкс_ПараметрыОповещенияОИзмененииТехКарты.Установить(
		ЭтотОбъект["гкс_ПараметрыОповещенияОИзмененииТехКарты"]);
	// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{      
	Константы.гкс_ПериодДействияТехКартПоУмолчанию.Установить(
		ЭтотОбъект["гкс_ПериодДействияТехКартПоУмолчанию"]); 
	Константы.гкс_КоличествоПериодовДействияТехКартПоУмолчанию.Установить(
		ЭтотОбъект["гкс_КоличествоПериодовДействияТехКартПоУмолчанию"]); // } Гкс-[TOIR20-194] 			
	// Гкс+[TOIR20-171] Селимов от 17.11.2020. Добавлено:{      
	Константы.гкс_КоличествоДнейДоОкончанияАктуальностиТК.Установить(
		ЭтотОбъект["гкс_КоличествоДнейДоОкончанияАктуальностиТК"]); // } Гкс-[TOIR20-171] 			
	// гкс+ [10.23] Деснол 28.02.2024
	Константы.гкс_СобытиеПроведенияСметыПожаротушения.Установить(
		ЭтотОбъект["гкс_СобытиеПроведенияСметыПожаротушения"]); 
	// гкс- [10.23] Деснол 28.02.2024
КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОткрытьНастройкуГруппФайлов(Команда)
	ОткрытьФорму("Обработка.торо_ПанельАдминистрированияТОиР.Форма.ФормаНастройкиИерархииФайлов",,,,,,, 
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецПроцедуры

&НаСервере
