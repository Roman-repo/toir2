#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если ЗавершениеРаботы = Ложь Тогда 
		Если ЕстьИзменения Тогда 
			Отказ = Истина; СтандартнаяОбработка = Ложь;
			ОписаниеОповещения = Новый ОписаниеОповещения("СохранитьПослеВопроса", ЭтотОбъект,
				Новый Структура("ЗакрытьПослеЗаписи", Истина));
			ПоказатьВопрос(ОписаниеОповещения, НСтр("ru='Введенные данные не сохранены. Сохранить?'"), 
				РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Иерархия = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
	Если ЗначениеЗаполнено(Иерархия) Тогда 
		ИзменяетсяДокументами = Иерархия.ИзменяетсяДокументами;
	Иначе
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Иерархия не определена'");
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ПостроитьДерево();
	Элементы.ДеревоПодчиненный.ТолькоПросмотр = Истина;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИфункции

&НаКлиенте
Процедура ДеревоГлавныйПриАктивизацииСтроки(Элемент)

	ТекДанные = Элементы.ДеревоГлавный.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если Главный = ТекДанные.Ссылка Тогда 
			Возврат;
		КонецЕсли;
		Если ЕстьИзменения Тогда 
			ТекстВопроса = НСтр("ru='Сохранить изменения?'");
			ОписаниеОповещенияПослеВопроса = Новый ОписаниеОповещения("СохранитьПослеВопроса", ЭтотОбъект,Новый Структура());
			ПоказатьВопрос(ОписаниеОповещенияПослеВопроса, ТекстВопроса,
				РежимДиалогаВопрос.ДаНетОтмена);
			Возврат;
		КонецЕсли;
		Если ТекДанные.ЭтоГруппа = Ложь Тогда 
			Элементы.ДеревоПодчиненныйВыбран.Видимость = Истина;
			Элементы.ДеревоПодчиненныйВыбран1.Видимость = Истина;
			Элементы.ДеревоПодчиненныйМуляж.Видимость = Ложь;
			Элементы.ДеревоПодчиненныйМуляж1.Видимость = Ложь;
			Элементы.ДеревоПодчиненный.ТолькоПросмотр = Ложь;
			ПодключитьОбработчикОжидания("ОбновитьДеревоПодчиненных", 0.1, Истина);
		Иначе
			Элементы.ДеревоПодчиненный.ТолькоПросмотр = Истина;
			Элементы.ДеревоПодчиненныйВыбран.Видимость = Ложь;
			Элементы.ДеревоПодчиненныйВыбран1.Видимость = Ложь;
			Элементы.ДеревоПодчиненныйМуляж.Видимость = Истина;
			Элементы.ДеревоПодчиненныйМуляж1.Видимость = Истина;
		КонецЕсли;
		Главный = ТекДанные.Ссылка;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДеревоПодчиненных()
	ОбновитьДеревоПодчиненныхНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОбновитьДеревоПодчиненныхНаСервере()
	МассивВыбранных = Новый Массив();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_РемонтыОсновногоЗависимогоОборудования.СвязанныйОбъектРемонта КАК Подчиненный,
		|	МАКСИМУМ(торо_РемонтыОсновногоЗависимогоОборудования.гкс_Остановочная) КАК Выбран,
		|	МАКСИМУМ(торо_РемонтыОсновногоЗависимогоОборудования.гкс_Технологическая) КАК Выбран1
		|ИЗ
		|	РегистрСведений.торо_РемонтыОсновногоЗависимогоОборудования КАК торо_РемонтыОсновногоЗависимогоОборудования
		|ГДЕ
		|	торо_РемонтыОсновногоЗависимогоОборудования.ОсновнойОбъектРемонта = &Главный
		|
		|СГРУППИРОВАТЬ ПО
		|	торо_РемонтыОсновногоЗависимогоОборудования.СвязанныйОбъектРемонта";

	
	Запрос.УстановитьПараметр("Главный", Главный);	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	Корень = ДеревоГлавный.ПолучитьЭлементы();
	ОбновитьРекурсияНаСервере(Корень,Выборка);
КонецПроцедуры

&НаСервере
Процедура ОбновитьРекурсияНаСервере(Корень,МассивВыбранных)
	Для Каждого СтрокаКорня Из Корень Цикл
		СтрокаКорня.Выбран = Ложь;
		СтрокаКорня.Выбран1 = Ложь;
		Если СтрокаКорня.ЭтоГруппа = Ложь Тогда 
			ЕстьФМ = Истина;
			Если МассивВыбранных.НайтиСледующий(Новый Структура("Подчиненный", СтрокаКорня.Ссылка)) Тогда
				СтрокаКорня.Выбран = МассивВыбранных.Выбран ИЛИ МассивВыбранных.Выбран1 = Ложь;
				СтрокаКорня.Выбран1 = МассивВыбранных.Выбран1;
			КонецЕсли;
			МассивВыбранных.Сбросить();
		КонецЕсли;
		ОбновитьРекурсияНаСервере(СтрокаКорня.ПолучитьЭлементы(),МассивВыбранных);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПостроитьДерево()
	ДеревоГлавный.ПолучитьЭлементы().Очистить();
	//
	МассивОР = Новый Массив();
	МассивОР.Добавить(Справочники.торо_ОбъектыРемонта.ПустаяСсылка());
	МассивСтрокУровня = Новый Массив();
	МассивСтрокУровня.Добавить(ДеревоГлавный);
	АнтиЦикл = 12;
	Пока МассивОР.Количество() > 0 Цикл 
		АнтиЦикл = АнтиЦикл - 1;
		Если АнтиЦикл <= 0 Тогда 
			Прервать;
		КонецЕсли;
		Запрос = Новый Запрос;
		Если ИзменяетсяДокументами Тогда 
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	Рег.РодительИерархии КАК Родитель,
				|	Рег.ОбъектИерархии КАК Объект,
				|	Рег.ОбъектИерархии.ПометкаУдаления КАК ПометкаУдаления,
				|	Рег.ОбъектИерархии.ТехНомер КАК ТехНомер,
				|	Рег.ОбъектИерархии.ЭтоГруппа КАК ЭтоГруппа
				|ИЗ
				|	РегистрСведений.торо_РасположениеОРВСтруктуреИерархии.СрезПоследних(
				|			,
				|			СтруктураИерархии = &СтруктураИерархии
				|				И (ОбъектИерархии.ЭтоГруппа
				|					ИЛИ ОбъектИерархии.ТипОбъекта = ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто))) КАК Рег
				|ГДЕ
				|	Рег.РодительИерархии В(&РодительИерархии)
				|ИТОГИ ПО
				|	Родитель";
		Иначе
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	Рег.РодительИерархии КАК Родитель,
				|	Рег.ОбъектИерархии КАК Объект,
				|	Рег.ОбъектИерархии.ЭтоГруппа КАК ЭтоГруппа,
				|	Рег.ОбъектИерархии.ТехНомер КАК ТехНомер,
				|	Рег.ОбъектИерархии.ПометкаУдаления КАК ПометкаУдаления
				|ИЗ
				|	РегистрСведений.торо_ИерархическиеСтруктурыОР КАК Рег
				|ГДЕ
				|	Рег.СтруктураИерархии = &СтруктураИерархии
				|	И (Рег.ОбъектИерархии.ЭтоГруппа = ИСТИНА
				|			ИЛИ Рег.ОбъектИерархии.ТипОбъекта = ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто))
				|	И Рег.РодительИерархии В(&РодительИерархии)
				|ИТОГИ ПО
				|	Родитель";
		КонецЕсли;
		Запрос.УстановитьПараметр("РодительИерархии", МассивОР);
		Запрос.УстановитьПараметр("СтруктураИерархии", Иерархия);
		РезультатЗапроса = Запрос.Выполнить();	
		МассивОР.Очистить();
		Если Не РезультатЗапроса.Пустой() Тогда 
			ВыборкаРодитель = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
			ТемпМассив = Новый Массив();
			Для Каждого СтрокаУровня Из МассивСтрокУровня Цикл
				Если ВыборкаРодитель.НайтиСледующий(
					Новый Структура("Родитель",?(ТипЗнч(СтрокаУровня) = Тип("ДанныеФормыДерево"),
						Справочники.торо_ОбъектыРемонта.ПустаяСсылка(), СтрокаУровня.Ссылка))) Тогда 
					ТекЭлементы = СтрокаУровня.ПолучитьЭлементы();
					
					Выборка = ВыборкаРодитель.Выбрать();
					Пока Выборка.Следующий() Цикл
						НоваяСтрока = ТекЭлементы.Добавить();
						НоваяСтрока.Ссылка = Выборка.Объект;
						НоваяСтрока.ТехНомер = Выборка.ТехНомер;
						НоваяСтрока.ЭтоГруппа = Выборка.ЭтоГруппа;
						Если Выборка.ЭтоГруппа Тогда 
							Если Выборка.ПометкаУдаления Тогда 
								НоваяСтрока.Картинка = 6;
							Иначе
								НоваяСтрока.Картинка = 5;
							КонецЕсли;
						Иначе
							Если Выборка.ПометкаУдаления Тогда 
								НоваяСтрока.Картинка = 12;
							Иначе
								НоваяСтрока.Картинка = 11;
							КонецЕсли;
						КонецЕсли;
						ТемпМассив.Добавить(НоваяСтрока);
						МассивОР.Добавить(Выборка.Объект);
					КонецЦикла;
				КонецЕсли;
				ВыборкаРодитель.Сбросить();
			КонецЦикла;
			МассивСтрокУровня = ТемпМассив;
		КонецЕсли;
	КонецЦикла;
	ОчиститьДеревоОтПустыхГрупп(ДеревоГлавный.ПолучитьЭлементы());
КонецПроцедуры

&НаСервере
Процедура ОчиститьДеревоОтПустыхГрупп(Корень, ЕстьФМ = Ложь)
	МассивКУдалению = Новый Массив();
	Для Каждого СтрокаКорня Из Корень Цикл
		Элементы.ПоискПодчиненный.СписокВыбора.Добавить(СтрокаКорня.Ссылка);
		Элементы.ПоискГлавный.СписокВыбора.Добавить(СтрокаКорня.Ссылка);
		Если ЗначениеЗаполнено(СтрокаКорня.ТехНомер) Тогда 
			Элементы.ПоискПодчиненный.СписокВыбора.Добавить(СтрокаКорня.Ссылка,СтрокаКорня.ТехНомер);
			Элементы.ПоискГлавный.СписокВыбора.Добавить(СтрокаКорня.Ссылка,СтрокаКорня.ТехНомер);
		КонецЕсли;
		ЕстьГлубже = Ложь;
		ОчиститьДеревоОтПустыхГрупп(СтрокаКорня.ПолучитьЭлементы(), ЕстьГлубже);
		Если СтрокаКорня.ЭтоГруппа = Ложь ИЛИ ЕстьГлубже Тогда 
			ЕстьФМ = Истина;
		Иначе
			МассивКУдалению.Добавить(СтрокаКорня);
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаМассива Из МассивКУдалению Цикл
		Корень.Удалить(СтрокаМассива);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СохранитьПослеВопроса(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда 
		СохранитьСвязьНаСервере();
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда 
		Главный = Неопределено;
	Иначе
		СтруктураТекущейСтроки = Новый Структура("ОР",Главный);
		УстановитьТекущуюСтрокуНаСервере(СтруктураТекущейСтроки);
		Если СтруктураТекущейСтроки.Свойство("Идентификатор") Тогда 
			Элементы.ДеревоГлавный.ТекущаяСтрока = СтруктураТекущейСтроки.Идентификатор;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ЕстьИзменения = Ложь;
	Если ДопПараметры.Свойство("ЗакрытьПослеЗаписи") И ДопПараметры.ЗакрытьПослеЗаписи Тогда 
		Закрыть();
	Иначе
		ДеревоГлавныйПриАктивизацииСтроки(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьСвязьНаСервере()
	ТЧ = новый ТаблицаЗначений();
	ТЧ.Колонки.Добавить("Ссылка",Новый ОписаниеТипов("СправочникСсылка.торо_ОбъектыРемонта"));
	ТЧ.Колонки.Добавить("Выбран",Новый ОписаниеТипов("Булево"));
	ТЧ.Колонки.Добавить("Выбран1",Новый ОписаниеТипов("Булево"));
	Корень = ДеревоГлавный.ПолучитьЭлементы();
	СобратьРекурсияНаСервере(Корень, ТЧ);
	//
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.Ссылка КАК Ссылка,
		|	ТЧ.Выбран КАК Выбран,
		|	ТЧ.Выбран1 КАК Выбран1
		|ПОМЕСТИТЬ Исходные
		|ИЗ
		|	&ТЧ КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_РемонтыОсновногоЗависимогоОборудования.СвязанныйОбъектРемонта КАК Подчиненный
		|ПОМЕСТИТЬ ВсеПоГлавному
		|ИЗ
		|	РегистрСведений.торо_РемонтыОсновногоЗависимогоОборудования КАК торо_РемонтыОсновногоЗависимогоОборудования
		|ГДЕ
		|	торо_РемонтыОсновногоЗависимогоОборудования.ОсновнойОбъектРемонта = &Главный
		|
		|СГРУППИРОВАТЬ ПО
		|	торо_РемонтыОсновногоЗависимогоОборудования.СвязанныйОбъектРемонта
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Исходные.Ссылка КАК Ссылка,
		|	Исходные.Выбран КАК гкс_Остановочная,
		|	Исходные.Выбран1 КАК гкс_Технологическая,
		|	торо_РемонтыОсновногоЗависимогоОборудования.ОсновнойОбъектРемонта ЕСТЬ NULL КАК Свободен
		|ИЗ
		|	Исходные КАК Исходные
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_РемонтыОсновногоЗависимогоОборудования КАК торо_РемонтыОсновногоЗависимогоОборудования
		|		ПО Исходные.Ссылка = торо_РемонтыОсновногоЗависимогоОборудования.ОсновнойОбъектРемонта
		|			И (торо_РемонтыОсновногоЗависимогоОборудования.СвязанныйОбъектРемонта = &Главный)
		|ГДЕ
		|	(Исходные.Выбран = ИСТИНА
		|			ИЛИ Исходные.Выбран1 = ИСТИНА)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Исходные.Ссылка КАК Ссылка
		|ИЗ
		|	Исходные КАК Исходные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВсеПоГлавному КАК ВсеПоГлавному
		|		ПО Исходные.Ссылка = ВсеПоГлавному.Подчиненный
		|ГДЕ
		|	Исходные.Выбран = ЛОЖЬ
		|	И Исходные.Выбран1 = ЛОЖЬ";
	Запрос.УстановитьПараметр("Главный", Главный);	
	Запрос.УстановитьПараметр("ТЧ", ТЧ);	
	РезультатЗапроса = Запрос.ВыполнитьПакет();	
	ИндексОсновногоПакета = 2;
	ИндексДополнительногоПакета = 3;
	Выборка = РезультатЗапроса[ИндексОсновногоПакета].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Свободен Тогда 
			НаборЗаписей = РегистрыСведений.торо_РемонтыОсновногоЗависимогоОборудования.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.ОсновнойОбъектРемонта.Установить(Главный);
			НаборЗаписей.Отбор.СвязанныйОбъектРемонта.Установить(Выборка.Ссылка);
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() = 0 Тогда 
				НоваяСтрока = НаборЗаписей.Добавить();
				НоваяСтрока.ОсновнойОбъектРемонта = Главный;
				НоваяСтрока.СвязанныйОбъектРемонта = Выборка.Ссылка;
			КонецЕсли;
			Для Каждого НоваяСтрока ИЗ НаборЗаписей Цикл
				НоваяСтрока.гкс_Остановочная = Выборка.гкс_Остановочная;
				НоваяСтрока.гкс_Технологическая = Выборка.гкс_Технологическая;
			КонецЦикла;
			НаборЗаписей.Записать();
		Иначе
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru='Обнаружено зацикливание. Связь не сохранена:'") + " " 
				+ Строка(Главный) + " - " + Строка(Выборка.Ссылка);
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[ИндексДополнительногоПакета].Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.торо_РемонтыОсновногоЗависимогоОборудования.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ОсновнойОбъектРемонта.Установить(Главный);
		НаборЗаписей.Отбор.СвязанныйОбъектРемонта.Установить(Выборка.Ссылка);
		НаборЗаписей.Записать();
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СохранитьСвязь(Команда)
	СохранитьСвязьНаСервере();
	ЕстьИзменения = Ложь;
КонецПроцедуры

&НаСервере
Процедура СобратьРекурсияНаСервере(Корень,МассивВыбранных)
	Для Каждого СтрокаКорня Из Корень Цикл
		Если СтрокаКорня.ЭтоГруппа = Ложь Тогда 
			НоваяСтрока = МассивВыбранных.Добавить();
			НоваяСтрока.Ссылка = СтрокаКорня.Ссылка;
			НоваяСтрока.Выбран = СтрокаКорня.Выбран;
			НоваяСтрока.Выбран1 = СтрокаКорня.Выбран1;
		КонецЕсли;
		СобратьРекурсияНаСервере(СтрокаКорня.ПолучитьЭлементы(),МассивВыбранных);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПодчиненныйВыбранПриИзменении(Элемент)
	ТекДанные = Элементы.ДеревоПодчиненный.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если ТекДанные.ЭтоГруппа Тогда 
			ТекДанные.Выбран = Ложь;
			ТекДанные.ТипСвязи = Неопределено;
		ИначеЕсли ТекДанные.Ссылка = Главный Тогда 
			ТекДанные.Выбран = Ложь;
			ТекДанные.ТипСвязи = Неопределено;
		Иначе
			ЕстьИзменения = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

