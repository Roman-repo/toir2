	|			ПО (РегистрСведенийторо_ТекущиеСтатусыСогласованияДокументов.СогласуемыйДокумент = ВТОтборИД.ДокументНачалаЦепочки)
	|		ПО ВТОтборДеффектов.ID = ВТОтборИД.IDРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыДокументовВыявленныхДефектовУстановленные.СрезПоследних(&ТекДата, &ИспользоватьСтатусыДокументов) КАК торо_СтатусыДокументовВыявленныхДефектовСрезПоследних
	|		ПО ВТОтборДеффектов.Регистратор = торо_СтатусыДокументовВыявленныхДефектовСрезПоследних.ИзменяемыйДокумент
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТАктыПоРемонтамСрез КАК ВТАктыПоРемонтамСрез
	|		ПО ВТОтборДеффектов.ID = ВТАктыПоРемонтамСрез.IDРемонта
	|ГДЕ
	|	НЕ ВТОтборДеффектов.Регистратор.Организация ЕСТЬ NULL
	|	И ВЫБОР
	|			КОГДА НЕ &Завершенные
	|				ТОГДА ЗакрытыеЗаявки.ID ЕСТЬ NULL
	|						ИЛИ ЕСТЬNULL(торо_СтатусыДокументовВыявленныхДефектовСрезПоследних.СтатусДокумента, ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.ПустаяССылка)) = ЗНАЧЕНИЕ(Перечисление.торо_СтатусыДокументов.гкс_ВыполненНеобходимАктПриемки)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА НЕ &ПоВсемПодразделениям
	|				ТОГДА ВТОтборДеффектов.Подразделение В (&Исполнитель)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И торо_ОтмененныеРемонтыСрезПоследних.Регистратор ЕСТЬ NULL
	|	И ВЫБОР
	|			КОГДА &гкс_ИспользоватьСрочностьВоздействия
	|				ТОГДА ВТОтборДеффектов.Регистратор.гкс_СрочностьВоздействия = &гкс_СрочностьВоздействия
	|						ИЛИ &гкс_СрочностьВоздействия = ЗНАЧЕНИЕ(Перечисление.гкс_СрочностьВоздействия.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|{ГДЕ
	|	ВТОтборИД.ДокументНачалаЦепочки.* КАК Документ,
	|	(""Выявленные дефекты"") КАК ТипДокумента,
	|	(ЛОЖЬ) КАК Перенесенный,
	|	ВТОтборДеффектов.ОтказавшийЭлемент.* КАК ОбъектРемонта,
	|	(ЕСТЬNULL(торо_РемонтыЗаявка.ВидРемонта, &торо_ВидРемонтаВД)) КАК ВидРемонта,
	|	(ВЫБОР
	|			КОГДА ВТОтборИД.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ВТОтборДеффектов.Период
	|			ИНАЧЕ ВТОтборИД.ДатаНачала
	|		КОНЕЦ) КАК ПланируемаяДатаНачалаРемонта,
	|	ВТОтборИД.ДатаОкончания КАК ПланируемаяДатаОкончанияРемонта,
	|	(ЕСТЬNULL(торо_Заявка.Исполнитель, ВТОтборДеффектов.ПодразделениеИсполнитель)).* КАК Исполнитель,
	|	ВТОтборДеффектов.Организация.*,
	|	ВТОтборДеффектов.КритичностьДефекта.*,
	|	(ВЫБОР
	|			КОГДА НЕ ЗакрытыеЗаявки.ID ЕСТЬ NULL
	|				ТОГДА ""Устранен (выявленный дефект)""
	|			КОГДА НЕ торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
	|				ТОГДА ""Устраняется (выявленный дефект)""
	|			КОГДА НЕ торо_Заявка.IDРемонта ЕСТЬ NULL
