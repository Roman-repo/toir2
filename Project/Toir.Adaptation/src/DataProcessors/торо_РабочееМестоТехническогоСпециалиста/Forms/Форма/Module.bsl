#Область ОписаниеПеременных

&НаКлиенте
Перем СтароеЗначениеРемонтыДатаНачала;
&НаКлиенте
Перем СтароеЗначениеРемонтыДатаОкончания; 
&НаКлиенте
Перем СтароеЗначениеОрганизация;


#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура гкс_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)   
	
	ДобавитьИзменитьРеквизитыФормы(); 
	ДобавитьИзменитьЭлементыФормы(); 
	УстановитьВидимостьДоступностьЭлементовФормы();
	ДобавитьИзменитьУсловноеОформлениеЭлемнетовФормы();
	// Гкс+[TOIR20-669] Оселедько В.С. от 31.07.2025. Добавлено:{
	Если Параметры.Свойство("ВремяНачалаОткрытияФормы") Тогда
		ЭтотОбъект.гкс_ВремяНачалаЗамера = Параметры.ВремяНачалаОткрытияФормы;		
	КонецЕсли;
	// Гкс+[TOIR20-669] Оселедько В.С.
	// гкс+ [Релиз 1] Куст 17.03.2020
	дс_ЛокализоватьЗаголовкиКолонок();
	дс_ЛокализоватьСписокРемонтов();
	// гкс- [Релиз 1] Куст 17.03.2020
	// гкс+ [Часовые пояса] Куст 14.04.2020
	Сдвиг = Час(ТекущаяДатаСеанса()) - Час(ТекущаяДата());
	ТекстыЗамены = Новый Массив();
	ТекстыЗамены.Добавить(Новый Структура("До, После", "торо_АктуальныеПлановыеДатыРемонтов.ДатаОкончания",
		" ДобавитьКДате(торо_АктуальныеПлановЫеДатыРемонтов.ДатаОкончания, Час, " + Сдвиг + ")"));
	ТекстыЗамены.Добавить(Новый Структура("До, После", "ИНАЧЕ торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала",
		" Иначе ДобавитьКДате(торо_АктуальнЫеПлановыеДатыРемонтов.ДатаНачала, Час, " + Сдвиг + ")"));
	ТекстыЗамены.Добавить(Новый Структура("До, После", "торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала,",
		" ДобавитьКДате(торо_АктуальныеПлановЫеДатыРемонтов.ДатаНачала, Час, " + Сдвиг + "),"));
	ТекстыЗамены.Добавить(Новый Структура("До, После", "И торо_АктуальныеПлановыеДатыРемонтов.ДатаНачала",
		" И ДобавитьКДате(торо_АктуальныеПлановЫеДатыРемонтов.ДатаНачала, Час, " + Сдвиг + ")"));
	ТекстыЗамены.Добавить(Новый Структура("До, После", "ТОГДА торо_ВыявленныеДефекты.Период",
		" Тогда ДобавитьКДате(торо_ВыявленнЫеДефекты.Период, Час, " + Сдвиг + ")"));
	ТекстыЗамены.Добавить(Новый Структура("До, После", "торо_ПланГрафикППР.Период,",
		" ДобавитьКДате(торо_ПланГрафИкППР.Период, Час, " + Сдвиг + "),"));
	ТекстыЗамены.Добавить(Новый Структура("До, После", "торо_ВыявленныеДефекты.Период,",
		" ДобавитьКДате(торо_ВыявленныеДефектЫ.Период, Час, " + Сдвиг + "),"));
	ТекстыЗамены.Добавить(Новый Структура("До, После", "торо_ПредписанияСрезПоследних.Период КАК Период,",
		" ДобавитьКДате(торо_ПредписанияСрезПоследнИх.Период, Час, " + Сдвиг + ") КАК Период,"));
	Ремонты.ТекстЗапроса = гкс_ЧасовыеПоясаВызовСервера.ИзменитьТекстЗапросаФормыСписка(
		Ремонты.ТекстЗапроса, ТекстыЗамены);
	// гкс- [Часовые пояса] Куст 14.04.2020   
		
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПриОткрытии")
Процедура гкс_ПриОткрытии(Отказ)
	
	УстановитьПараметрыДинамическогоСписка();
	
	#Удаление
	Если НЕ ЗначениеЗаполнено(сзСтатусОР) Тогда
		сзСтатусОР.Добавить("Зарегистрирован (выявленный дефект)", "Зарегистрирован (выявленный дефект)");
		сзСтатусОР.Добавить("Запланировано устранение (выявленный дефект)", "Запланировано устранение (выявленный дефект)");
		сзСтатусОР.Добавить("Устраняется (выявленный дефект)", "Устраняется (выявленный дефект)");
		сзСтатусОР.Добавить("Устранен (выявленный дефект)", "Устранен (выявленный дефект)");

		сзСтатусОР.Добавить("Зарегистрирован (внешнее основание)", "Зарегистрирован (внешнее основание)");
		сзСтатусОР.Добавить("Запланировано устранение (внешнее основание)", "Запланировано устранение (внешнее основание)");
		сзСтатусОР.Добавить("Устраняется (внешнее основание)", "Устраняется (внешнее основание)");
		сзСтатусОР.Добавить("Устранен (внешнее основание)", "Устранен (внешнее основание)");

		сзСтатусОР.Добавить("Введен ППР (план-график ППР)", "Введен ППР (план-график ППР)");
		сзСтатусОР.Добавить("Запланировано выполнение (план-график ППР)", "Запланировано выполнение (план-график ППР)");
		сзСтатусОР.Добавить("Выполняется (план-график ППР)", "Выполняется (план-график ППР)");
		сзСтатусОР.Добавить("Выполнен (план-график ППР)", "Выполнен (план-график ППР)");
	КонецЕсли;

	ЗаполнитьСписокВыбораОтбораПоСтатусуДокумента();

	флОстановочныеПриИзменении(Элементы.флОстановочные);
	ИспользоватьОтборПоСтатусуПриИзменении(Элементы.ИспользоватьОтборПоСтатусу);
	ИспользоватьОтборПоСтатусуДокументаПриИзменении(Элементы.ИспользоватьОтборПоСтатусуДокумента);

	Элементы.ФормаОткрытьЗакрытиеЗаявокИРемонтов.Доступность = Ложь;
	#КонецУдаления
	#Вставка     
	СтароеЗначениеРемонтыДатаНачала = ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаНачала;
	СтароеЗначениеРемонтыДатаОкончания = ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаОкончания;  
	СтароеЗначениеОрганизация = Объект.Организация;
	#КонецВставки


КонецПроцедуры

#КонецОбласти                   

#Область ОбработчикиСобытийЭлементовШапкиФормы 

&НаКлиенте
&ИзменениеИКонтроль("ОрганизацияПриИзменении")
Процедура гкс_ОрганизацияПриИзменении(Элемент)
	
	#Вставка                                  
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда 
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Отбор по организации обязательно должен быть заполнен'"));
		Объект.Организация = СтароеЗначениеОрганизация;
		
		Возврат;
		
	КонецЕсли;
	
	#КонецВставки
	УстановитьПараметрыДинамическогоСпискаКлиент();
	#Вставка     
	СтароеЗначениеОрганизация = Объект.Организация;
	#КонецВставки

КонецПроцедуры

#Область ПодключаемыеОбработчики

&НаКлиенте
Процедура гкс_ПериодОтборДатРемонтаПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаНачала)
		ИЛИ ЗначениеЗаполнено(ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаОкончания) Тогда
			
		Ремонты.Параметры.УстановитьЗначениеПараметра("ДатаНачалаРемонта" , 
			ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаНачала);
		Ремонты.Параметры.УстановитьЗначениеПараметра("ДатаОкончанияРемонта" , 
			ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаОкончания);
		
	Иначе
			
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Период отбора ремонтов должен быть обязательно заполнен'"));
		
		ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаНачала = СтароеЗначениеРемонтыДатаНачала;
		ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаОкончания = СтароеЗначениеРемонтыДатаОкончания; 

		Возврат;
		
	КонецЕсли;
	
	СтароеЗначениеРемонтыДатаНачала = ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаНачала;
	СтароеЗначениеРемонтыДатаОкончания = ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаОкончания; 
	
КонецПроцедуры   

&НаКлиенте
Процедура гкс_ОтборПВПриИзменении(Элемент)
	УстановитьПараметрыДинамическогоСпискаКлиент();
КонецПроцедуры

&НаКлиенте
Процедура гкс_ОтборПВПриИзменении2(Элемент)
	Если ЭтотОбъект["гкс_ИспользоватьОтборПодразделениеВладелец"] = Истина Тогда 
		УстановитьПараметрыДинамическогоСпискаКлиент();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Подключаемыйгкс_ЗавершенныеПриИзменении(Элемент)
	
	Ремонты.Параметры.УстановитьЗначениеПараметра("Завершенные", Объект.Завершенные);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти   

#Область СлужебныеПроцедурыИФункции

#Область ЭлементыФормы   

&НаСервере
Процедура УстановитьВидимостьДоступностьЭлементовФормы()
	
	Элементы.ФормаОткрытьЗакрытиеЗаявокИРемонтов.Доступность = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьИзменитьУсловноеОформлениеЭлемнетовФормы()
	
	Элементы.Организация.ЦветФона = WebЦвета.Желтый;
	
	гкс_УстановитьУсловноеОформлениеНаПриоритетОР();
		
КонецПроцедуры

&НаСервере
Процедура ДобавитьИзменитьЭлементыФормы()

	НЭлем = Элементы.Добавить("гкс_СимптомДефекта", Тип("ПолеФормы"), Элементы.Ремонты);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Ремонты.гкс_СимптомДефекта";
	НЭлем.Заголовок = НСтр("ru='Симптом дефекта';en='Симптом дефекта'");
	
	НЭлем = Элементы.Добавить("дс_ДефектОписание", Тип("ПолеФормы"), Элементы.Ремонты);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Ремонты.ДефектОписание";
	НЭлем.Заголовок = НСтр("ru='Описание дефекта';en='A description of the defect'");
		
	НЭлем = Элементы.Добавить("гкс_СрочностьВоздействия", Тип("ПолеФормы"), Элементы.Ремонты);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Ремонты.гкс_СрочностьВоздействия";
	НЭлем.Заголовок = НСтр("ru='Срочность воздействия';
							|en='Urgency of impact';
							|es='Urgencia de impacto'");

	НЭлем = Элементы.Добавить("Ремонтыгкс_РаботыВыполнены", Тип("ПолеФормы"), Элементы.Ремонты);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Ремонты.гкс_РаботыВыполнены";
	НЭлем.Заголовок = НСтр("ru='А';
							|en='A';
							|es='A'");
	НЭлем.Подсказка = НСтр("ru='Требуется оформить акт приемки';
							|en='A equipment acceptance certificate is required';
							|es='A'");
	
	НГруп = Элементы.Добавить("гкс_ГруппаОтборПВ", Тип("ГруппаФормы"), Элементы.Группа2);
	НГруп.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НГруп.группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	НГруп.ОтображатьЗаголовок = Ложь;
	
	Элементы.Переместить(Элементы["гкс_ГруппаОтборПВ"], Элементы.Группа2, Элементы.ГруппаСтатусОР);
	
	НЭлем = Элементы.Добавить("гкс_ИспользоватьОтборПодразделениеВладелец", Тип("ПолеФормы"), Элементы["гкс_ГруппаОтборПВ"]);
	НЭлем.Вид = ВидПоляФормы.ПолеФлажка;
	НЭлем.ПутьКДанным = "гкс_ИспользоватьОтборПодразделениеВладелец";
	НЭлем.УстановитьДействие("ПриИзменении", "гкс_ОтборПВПриИзменении");
	НЭлем.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	НЭлем.Заголовок = НСтр("ru='Подразделение владелец';
	|en='Owner Subdivision'");
	
	НЭлем = Элементы.Добавить("гкс_ОтборПодразделениеВладелец", Тип("ПолеФормы"), Элементы["гкс_ГруппаОтборПВ"]);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_ОтборПодразделениеВладелец";
	НЭлем.УстановитьДействие("ПриИзменении", "гкс_ОтборПВПриИзменении2");
	НЭлем.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	
	НоваяГруппаФормы = Элементы.Добавить("гкс_ГруппаОрганизацияПодразделениеВладелец", Тип("ГруппаФормы"), Элементы.Группа2);
	НоваяГруппаФормы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НоваяГруппаФормы.группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	НоваяГруппаФормы.ОтображатьЗаголовок = Ложь;
	
	Элементы.Переместить(Элементы.Организация, НоваяГруппаФормы); 
	Элементы.Переместить(Элементы["гкс_ГруппаОтборПВ"], НоваяГруппаФормы);
	
	НоваяГруппаФормы = Элементы.Добавить("гкс_ГруппаСтатусРемонтаДокумента", Тип("ГруппаФормы"), Элементы.Группа2);
	НоваяГруппаФормы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НоваяГруппаФормы.группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	НоваяГруппаФормы.ОтображатьЗаголовок = Ложь;
	
	Элементы.Переместить(Элементы.ГруппаСтатусОР, НоваяГруппаФормы); 
	Элементы.Переместить(Элементы.ГруппаСтатусДокумента, НоваяГруппаФормы);
	
	НоваяГруппаВладелец = Элементы.Добавить("гкс_ГруппаПодразделениеСрочностьВоздействия", Тип("ГруппаФормы"), Элементы.Группа2);
	НоваяГруппаВладелец.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НоваяГруппаВладелец.группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	НоваяГруппаВладелец.ОтображатьЗаголовок = Ложь;
	
	Элементы.Переместить(Элементы.ГруппаПодразделение, НоваяГруппаВладелец); 
	Элементы.ИспользоватьОтборПоИсполнителю.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	
	НоваяГруппаФормы = Элементы.Добавить("гкс_ГруппаОтборСрочностьВоздействия", Тип("ГруппаФормы"), НоваяГруппаВладелец);
	НоваяГруппаФормы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НоваяГруппаФормы.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	НоваяГруппаФормы.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	НоваяГруппаФормы.Объединенная	= Истина;
	НоваяГруппаФормы.СквозноеВыравнивание = СквозноеВыравнивание.Использовать;
	НоваяГруппаФормы.ОтображатьЗаголовок = Ложь;
	
	НЭлем = Элементы.Добавить("гкс_ИспользоватьОтборСрочностьВоздействия", Тип("ПолеФормы"), НоваяГруппаФормы);
	НЭлем.Вид = ВидПоляФормы.ПолеФлажка;
	НЭлем.ПутьКДанным = "гкс_ИспользоватьОтборСрочностьВоздействия";
	НЭлем.УстановитьДействие("ПриИзменении", "гкс_ИспользоватьОтборСрочностьВоздействияПриИзменении");
	НЭлем.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	НЭлем.Заголовок = НСтр("ru='Срочность воздействия';
							|en='Urgency of impact';
							|es='Urgencia de impacto'");
	
	НЭлем = Элементы.Добавить("гкс_ОтборСрочностьВоздействия", Тип("ПолеФормы"), НоваяГруппаФормы);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_ОтборСрочностьВоздействия";
	НЭлем.УстановитьДействие("ПриИзменении", "гкс_ОтборСрочностьВоздействияПриИзменении");
	НЭлем.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;

