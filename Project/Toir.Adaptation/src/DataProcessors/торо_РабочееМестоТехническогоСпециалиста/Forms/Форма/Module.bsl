&НаСервере
Процедура ПодменитьЗапросИНастроитьДинамическийСписокРемонты()
	
	Ремонты.ТекстЗапроса = ТекстПодменитьЗапросИНастроитьДинамическийСписокРемонты();  
	
	ПараметрыРемонтов = Ремонты.Параметры;
	
	// Возможна просадка по производитеьности - отбор фиксированный по организации не снимать при открытии
	ПараметрыРемонтов.УстановитьЗначениеПараметра("ПоВсемОрганизациям" , Ложь);
	
	ПараметрыРемонтов.УстановитьЗначениеПараметра("гкс_ИспользоватьСрочностьВоздействия" , Ложь);
	ПараметрыРемонтов.УстановитьЗначениеПараметра("гкс_СрочностьВоздействия" , Неопределено);

	ПараметрыРемонтов.УстановитьЗначениеПараметра("ДатаНачалаРемонта" , ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаНачала);
	ПараметрыРемонтов.УстановитьЗначениеПараметра("ДатаОкончанияРемонта" , ЭтотОбъект["гкс_ПериодОтборДатРемонта"].ДатаОкончания);
	ПараметрыРемонтов.УстановитьЗначениеПараметра("гкс_ИспользоватьПодразделениеВладелец" , Ложь);
	ПараметрыРемонтов.УстановитьЗначениеПараметра("гкс_ПодразделениеВладелец" , Неопределено);
	
	УстановитьОтборыПоКолонкеСтатусОР(); 
	
	Если ФОИспользоватьСтатусыДокументов Тогда
		Элементы.ОтборПоСтатусуДокумента.Доступность = ИспользоватьОтборПоСтатусуДокумента;
		ОбщегоНазначенияКлиентСервер
		     .УстановитьЭлементОтбора(Ремонты.Отбор, 
			                          "СтатусДокумента", 
			                          ОтборПоСтатусуДокумента,
									  Неопределено,
									  Неопределено,
									  ИспользоватьОтборПоСтатусуДокумента);
	КонецЕсли;   
	
	ОтборПоОстановочномуНаСервере();
	
КонецПроцедуры 

&НаСервере
Процедура ОтборПоОстановочномуНаСервере()

	Если Ремонты.Отбор.Элементы.Количество() > ИндексОтбораПоОстановочным Тогда
		Ремонты.Отбор.Элементы.Удалить(ИндексОтбораПоОстановочным);
	КонецЕсли;

	Если Не флОстановочные Тогда
		ДокументОстановочного = Неопределено;
	КонецЕсли;
	
	Элементы.ДокументОстановочного.Доступность = флОстановочные;
	Если флОстановочные Тогда
		ЭлементОтбора = Ремонты.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("IDОсновного");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
		ЭлементОтбора.Использование = Истина;
		ИндексОтбораПоОстановочным = Ремонты.Отбор.Элементы.Индекс(ЭлементОтбора);
	КонецЕсли;
	
КонецПроцедуры

