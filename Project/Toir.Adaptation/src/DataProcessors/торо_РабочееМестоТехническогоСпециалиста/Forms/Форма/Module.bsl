	|	ТЧ.ДефектОписание КАК ДефектОписание,
	|	ТЧ.гкс_СрочностьВоздействия КАК гкс_СрочностьВоздействия,
	|	ЕСТЬNULL(ЗавершенныеАкты.гкс_РаботыВыполнены, ЛОЖЬ) КАК гкс_РаботыВыполнены
	|{ВЫБРАТЬ
	|	ID_Ремонта,
	|	Документ,
	|	ТипДокумента,
	|	ДокументПлановыхДат,
	|	ПодрПлановыхДат,
	|	Перенесенный,
	|	ОбъектРемонта,
	|	ВидРемонта,
	|	ПланируемаяДатаНачалаРемонта,
	|	ПланируемаяДатаОкончанияРемонта,
	|	Исполнитель,
	|	Организация,
	|	КритичностьДефекта,
	|	СтатусОР,
	|	Подразделение,
	|	ВведенаЗаявка,
	|	ПриоритетОР,
	|	СостояниеОР,
	|	Завершенные,
	|	ГарантийныйРемонт,
	|	СтатусДокумента,
	|	IDОсновного,
	|	Бригада,
	|	СпособВыполнения,
	|	гкс_СимптомДефекта,
	|	ДефектОписание,
	|	гкс_СрочностьВоздействия,
	|	гкс_РаботыВыполнены}
	|ИЗ
	|	ВесьРезультат КАК ТЧ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НастройкиСтатусовСогласованияДокументов КАК РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов
	|		ПО (РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов.СпособСогласования = ТЧ.Документ.СпособСогласования)
	|			И (РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов.Статус = ТЧ.СтатусСогласования)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗавершенныеАкты КАК ЗавершенныеАкты
	|		ПО (ЗавершенныеАкты.ИД = ТЧ.ID_Ремонта)
	|ГДЕ
	|	(РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов.Статус ЕСТЬ NULL
	|			ИЛИ РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов.НеИспользоватьВПодборах = ЛОЖЬ)
	|{ГДЕ
	|	ТЧ.ДокументПлановыхДат.*}";
	
	Если НЕ Объект.ИспользоватьОтборПоПодразделению Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, 
		                    "торо_ВнешниеОснованияДляРабот.Подразделение В(&Исполнитель)",
		                    "ИСТИНА");
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти

&НаСервере
Процедура гкс_УстановитьУсловноеОформлениеНаПриоритетОР()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	торо_КатегорииРиска.Ссылка КАК КатегорииРиска,
	|	торо_КатегорииРиска.Представление КАК Представление,
	|	торо_КатегорииРиска.Цвет КАК Цвет
	|ИЗ
	|	Справочник.торо_КатегорииРиска КАК торо_КатегорииРиска";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ЭлементУсловногоОформления = Ремонты.УсловноеОформление.Элементы.Добавить();
		ЭлементУсловногоОформления.Представление = ""+Выборка.Представление;
		
		ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ПриоритетОР"); 
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.ПравоеЗначение = Выборка.КатегорииРиска;
		
		ЦветФона = Выборка.Цвет.Получить();
		ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
		  
		ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
		ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ПриоритетОР");
		
	КонецЦикла;
	
КонецПроцедуры

