&НаКлиенте
&ИзменениеИКонтроль("ОбязательныеПроверкиПередВводомНаОсновании")
Функция гкс_ОбязательныеПроверкиПередВводомНаОсновании(ЭлементФормыТаблица, МассивДанныхСтрок)

	ТекДанные = ЭлементФормыТаблица.ТекущиеДанные;

	Если ТекДанные = Неопределено Тогда
		#Удаление
		ТекстСообщения = НСтр("ru = 'Выберите ремонт!'");
		#КонецУдаления
		#Вставка
		ТекстСообщения = НСтр("es='¡Escojan la reparación!';ru='Выберите ремонт!';en='Choose a repair!'");
		#КонецВставки
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат Ложь;
	КонецЕсли;

	МассивВыделенныхСтрок = ПолучитьМассивВыделенныхСтрокРемонтов(ЭлементФормыТаблица);

	ОбработатьОстановочныеРемонтыИЗакрытия(МассивВыделенныхСтрок);

	КолЗавершенных = 0;

	Для Каждого Строка Из МассивВыделенныхСтрок Цикл

		Если ЗначениеЗаполнено(Строка.Завершенные) Тогда
			Если ТипЗнч(Строка.Завершенные) = Тип("Строка")или Строка.Завершенные  Тогда
				КолЗавершенных = КолЗавершенных + 1;
			Иначе
				Структура = Новый Структура("ОбъектРемонта, ВидРемонта, ПланируемаяДатаНачалаРемонта, ID_Ремонта, Документ, ТипДокумента"
				, Строка.ОбъектРемонта
				, Строка.ВидРемонта
				, Строка.ПланируемаяДатаНачалаРемонта
				, Строка.ID_Ремонта
				, Строка.Документ
				, Строка.ТипДокумента);
				МассивДанныхСтрок.Добавить(Структура);
			КонецЕсли;
		КонецЕсли;

	КонецЦикла;

	Если КолЗавершенных > 0 Тогда
		#Удаление
		ТекстСообщения = НСтр("ru = 'В списке выбранных ремонтов есть завершенные!'");
		#КонецУдаления
		#Вставка
		ТекстСообщения = НСтр("es='¡En la lista de las reparaciones escogidas es acabado!';ru='В списке выбранных "
		+"ремонтов есть завершенные!';en='In the list of selected repairs are completed!'");
		#КонецВставки
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;

КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("ДляВсехРемонтовЕстьОснование")
Функция гкс_ДляВсехРемонтовЕстьОснование(МассивДанныхСтрок, СоответствиеРемонтовИОснований, ПредставлениеДокументаДляПользователя)

	// Проверим, по всем ли ремонтам нашлось хотя бы одно основание.
	МассивДокументовБезОснований = Новый Массив;
	Для каждого Строка Из МассивДанныхСтрок Цикл
		МассивОснований = СоответствиеРемонтовИОснований[Строка.ID_Ремонта];
		Если МассивОснований = Неопределено И МассивДокументовБезОснований.Найти(Строка.Документ) = Неопределено Тогда
			МассивДокументовБезОснований.Добавить(Строка.Документ);                                
		КонецЕсли;
	КонецЦикла; 

	Если МассивДокументовБезОснований.Количество() > 0 Тогда
		Если МассивДанныхСтрок.Количество() = 1 Тогда
			#Удаление
			ШаблонСообщения = НСтр("ru = 'Настроки ввода на основании запрещают ввести %1 на основании выбранного документа.
			|Настройка и администрирование -> Настройка параметров подсистемы ТОиР -> Интрерфейс и ввод документов -> Настройка ввода на основании.'");
			#КонецУдаления
			#Вставка
			ШаблонСообщения = НСтр("es='Настроки de la introducción a la razón prohíben introducir %1 en razon del "
			+"documento escogido. 
			|El ajuste y la administración-> el Ajuste de los parámetros del subsistema ТОиР-> Intrerfeys y la introducción de "
			+"los documentos-> el Ajuste de la introducción a la razón.';ru='Настроки ввода на основании запрещают ввести %1 на "
			+"основании выбранного документа.
			|Настройка и администрирование -> Настройка параметров подсистемы ТОиР -> Интрерфейс и ввод документов -> Настройка "
			+"ввода на основании.';en='Based on input settings prohibit entering%1 based on the selected document.
			|Setting up and administration -> Setting the parameters of the MRO subsystem -> Interface and document input -> "
			+"Setting input based on.'");
			#КонецВставки
		ИначеЕсли МассивДанныхСтрок.Количество() > 1 Тогда
			#Удаление
			ШаблонСообщения = НСтр("ru = 'Настроки ввода на основании запрещают ввести %1 на основании некоторых выбранных документов.
			|Настройка и администрирование -> Настройка параметров подсистемы ТОиР -> Интрерфейс и ввод документов -> Настройка ввода на основании.'");
			#КонецУдаления
			#Вставка
			ШаблонСообщения = НСтр("es='Настроки de la introducción a la razón prohíben introducir %1 en razon de "
			+"algunos documentos escogidos. 
			|El ajuste y la administración-> el Ajuste de los parámetros del subsistema ТОиР-> Intrerfeys y la introducción de "
			+"los documentos-> el Ajuste de la introducción a la razón.';ru='Настроки ввода на основании запрещают ввести %1 на "
			+"основании некоторых выбранных документов.
			|Настройка и администрирование -> Настройка параметров подсистемы ТОиР -> Интрерфейс и ввод документов -> Настройка "
			+"ввода на основании.';en='Based on input settings prohibit entering%1 based on some selected documents.
			|Setting up and administration -> Setting the parameters of the MRO subsystem -> Interface and document input -> "
			+"Setting input based on.'");
			#КонецВставки
		КонецЕсли;
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ПредставлениеДокументаДляПользователя);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;

КонецФункции

