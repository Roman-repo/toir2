&НаСервере
Процедура гкс_ОбновитьТекущийАктПриемки(ИД)
	Элементы["гкс_СоздатьАктПриемкиКнопка"].Видимость = Истина;
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ДокТЧ.Ссылка КАК Ссылка,
			|	ДокТЧ.Ссылка.Проведен КАК Проведен
			|ИЗ
			|	Документ.торо_АктПриемкиОборудования.РемонтыОборудования КАК ДокТЧ
			|ГДЕ
			|	ДокТЧ.ID = &ИД
			|	И ДокТЧ.Ссылка.ПометкаУдаления = ЛОЖЬ
			|
			|УПОРЯДОЧИТЬ ПО
			|	Проведен УБЫВ";
		
		Запрос.УстановитьПараметр("ИД", ИД);
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() = Ложь Тогда 
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			ЭтотОбъект["гкс_ТекущийАктПриемки"] = Выборка.Ссылка;
			Элементы["гкс_ТекущийАктКнопка"].Заголовок = Строка(Выборка.Ссылка);
			Элементы["гкс_СоздатьАктПриемкиКнопка"].Видимость = Ложь;
		КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура гкс_СоздатьАктПриемки(Команда)
	Если ЗначениеЗаполнено(ЭтотОбъект["гкс_ТекущийАктПриемки"]) Тогда 
		ПоказатьЗначение(, ЭтотОбъект["гкс_ТекущийАктПриемки"]);
		Возврат;
	КонецЕсли;
	//
	ВыполнитьВводДокументаНаОсновании("торо_АктПриемкиОборудования", НСтр("ru='акт приемки';
							|en='equipment acceptance certificate';
							|es='el acta de la recepción de la maquinaria'"));
КонецПроцедуры

&НаКлиенте
Процедура гкс_ТекущийАкт(Команда)
