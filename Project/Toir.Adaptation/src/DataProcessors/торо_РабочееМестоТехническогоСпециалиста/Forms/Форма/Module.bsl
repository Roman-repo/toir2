	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеРемонты.СрезПоследних КАК торо_ОтмененныеРемонтыСрезПоследних
	|		ПО ВТОтборДеффектов.ID = торо_ОтмененныеРемонтыСрезПоследних.ID
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОтборНарядовМаксимумСрез КАК торо_НарядыПоРемонтам
	|		ПО ВТОтборДеффектов.ID = торо_НарядыПоРемонтам.IDРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам.СрезПоследних(, ) КАК торо_Заявка
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_РемонтыЗаявка
	|			ПО торо_Заявка.IDРемонта = торо_РемонтыЗаявка.ID
	|				И торо_Заявка.Регистратор = торо_РемонтыЗаявка.Регистратор
	|		ПО ВТОтборДеффектов.ID = торо_Заявка.IDРемонта
	|			И (НЕ торо_Заявка.Регистратор В
	|					(ВЫБРАТЬ
	|						торо_ОтмененныеЗаявки.Заявка
	|					ИЗ
	|						РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущееСостояниеОР.СрезПоследних(&ТекДата, ) КАК торо_ТекущееСостояниеОРСрезПоследних
	|		ПО ВТОтборДеффектов.ОтказавшийЭлемент = торо_ТекущееСостояниеОРСрезПоследних.ОбъектРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗавершенныеРемонтныеРаботы КАК ЗакрытыеЗаявки
	|		ПО ВТОтборДеффектов.ОтказавшийЭлемент = ЗакрытыеЗаявки.ОбъектРемонта
	|			И ВТОтборДеффектов.ID = ЗакрытыеЗаявки.ID
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_Ремонты
	|		ПО ВТОтборДеффектов.ID = торо_Ремонты.ID
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
	|		ПО ВТОтборДеффектов.ОтказавшийЭлемент = торо_ОбъектыРемонта.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОстановочныеРемонты.СрезПоследних КАК торо_ОстановочныеРемонтыСрезПоследних
	|		ПО ВТОтборДеффектов.ID = торо_ОстановочныеРемонтыСрезПоследних.IDЗависимого
	|			И (НЕ торо_ОстановочныеРемонтыСрезПоследних.Отвязан)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтборИД КАК ВТОтборИД
