#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
&ИзменениеИКонтроль("ВыполнитьОбработкуНаСервере")
Функция Расш_гкс_ВыполнитьОбработкуНаСервере()

	ОбрабатываемыеСтроки.Загрузить(Объект.ЗакрываемыеРемонты.Выгрузить(Новый Структура("Обрабатывать", Истина)));

	НовыеДатыЗаполнены = Истина;
	Для Каждого Строка Из ОбрабатываемыеСтроки Цикл
		Если Строка.Перенесен И Не ЗначениеЗаполнено(Строка.НоваяДатаНачала) и Не ЗначениеЗаполнено(Строка.НоваяДатаОкончания) Тогда
			НовыеДатыЗаполнены = Ложь;
			НомерСтроки = ОбрабатываемыеСтроки.Индекс(Строка) + 1;
			ШаблонСообщения = НСтр("es='¡En la línea № %1 no es rellenado el nuevo período de la reparación!';ru='В строке № %1 не заполнен новый период ремонта!';en='In line No.%1 a new repair period is not filled!'");
			ТекстСообщения = СтрШаблон(ШаблонСообщения, НомерСтроки);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		ИначеЕсли Строка.Перенесен И (Строка.НоваяДатаНачала > Строка.НоваяДатаОкончания 
			ИЛИ (Не ЗначениеЗаполнено(Строка.НоваяДатаНачала) И ЗначениеЗаполнено(Строка.НоваяДатаОкончания))) Тогда
			НовыеДатыЗаполнены = Ложь;
			НомерСтроки = ОбрабатываемыеСтроки.Индекс(Строка) + 1;
			ШаблонСообщения = НСтр("es='¡En la línea № %1 es incorrectamente rellenado el nuevo período de la reparación!';ru='В строке № %1 неверно заполнен новый период ремонта!';en='In line No.%1, the new repair period is incorrectly filled!'");
			ТекстСообщения = СтрШаблон(ШаблонСообщения, НомерСтроки);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЦикла;

	Если не НовыеДатыЗаполнены Тогда
		Возврат Истина;
	КонецЕсли;

	ОбрабатываемыеАварийныеРемонты = Объект.АварийныеРемонты.Выгрузить(Новый Структура("Обрабатывать", Истина));
	Для Каждого Строка Из ОбрабатываемыеАварийныеРемонты Цикл
		#Вставка
		Если Строка.гкс_Перенесен = Истина И ЗначениеЗаполнено(Строка.Заявка) Тогда
			Продолжить;
		КонецЕсли;
		#КонецВставки
		НовСтрока = ОбрабатываемыеСтроки.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, Строка);
		НовСтрока.Перенесен = Ложь;
	КонецЦикла;

	Возврат Ложь;

КонецФункции

&НаКлиенте
Процедура гкс_ДатаПриИзменении(Элемент)
	ТекДанные = Элементы.АварийныеРемонты.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если ЗначениеЗаполнено(ТекДанные.Заявка) Тогда 
			ТекДанные.гкс_Перенесен = Истина;
		Иначе
			ТекДанные.гкс_Перенесен = Ложь;
			ТекДанные.гкс_ДатаНачала = Дата(1,1,1);
			ТекДанные.гкс_ДатаОкончания = Дата(1,1,1);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура гкс_ПеренесенПриИзменении(Элемент)
	ТекДанные = Элементы.АварийныеРемонты.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если ЗначениеЗаполнено(ТекДанные.Заявка) = Ложь Тогда 
			ТекДанные.гкс_Перенесен = Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("СоздатьДокументЗакрытияЗаявокНаСервере")
Функция гкс_СоздатьДокументЗакрытияЗаявокНаСервере()

	ТаблицаЗакрываемыхРемонтов = ОбрабатываемыеСтроки.Выгрузить(Новый Структура("Отменен", Истина));
	ТаблицаПеренесенныхРемонтов = ОбрабатываемыеСтроки.Выгрузить(Новый Структура("Перенесен", Истина));
	Для Каждого СтрокаПеренесенных Из ТаблицаПеренесенныхРемонтов Цикл
		СтрокаЗакрываемых = ТаблицаЗакрываемыхРемонтов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаЗакрываемых,СтрокаПеренесенных);
	КонецЦикла;
	ТаблицаЗакрываемыхЗаявок = ОбрабатываемыеСтроки.Выгрузить(Новый Структура("ЗакрытьЗаявку", Истина), "Заявка, ID, ПричинаЗакрытияЗаявки");
	ТаблицаЗакрываемыхЗаявок.Колонки.ПричинаЗакрытияЗаявки.Имя = "ПричинаЗакрытия";
	ТаблицаЗакрываемыхЗаявок.Колонки.ID.Имя = "ИДРемонта";

	ДокументЗакрытиеЗаявокИРемонтов = Документы.торо_ЗакрытиеЗаявокИРемонтов.СоздатьДокумент();

	Если ЗначениеЗаполнено(Владелец) Тогда
		ДокументЗакрытиеЗаявокИРемонтов.ППРИнициатор = Владелец;
	КонецЕсли;

	ДокументЗакрытиеЗаявокИРемонтов.ЗакрываемыеЗаявки.Загрузить(ТаблицаЗакрываемыхЗаявок);
	ДокументЗакрытиеЗаявокИРемонтов.ЗакрываемыеРемонты.Загрузить(ТаблицаЗакрываемыхРемонтов);
	ДокументЗакрытиеЗаявокИРемонтов.ДатаАктуальности = Объект.ДатаАктуальности;
	ДокументЗакрытиеЗаявокИРемонтов.Дата = ТекущаяДата();
	#Вставка
	Если Не ЭтотОбъект["гкс_СдвигЧП"] = 0 Тогда 
		ДобавитьСекунд = (ЭтотОбъект["гкс_СдвигЧП"] * -3600);
		Для Каждого СтрокаТаблицы Из ДокументЗакрытиеЗаявокИРемонтов.ЗакрываемыеРемонты Цикл
			Если ЗначениеЗаполнено(СтрокаТаблицы.НоваяДатаНачала) Тогда 
				СтрокаТаблицы.НоваяДатаНачала = СтрокаТаблицы.НоваяДатаНачала + ДобавитьСекунд;
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаТаблицы.НоваяДатаОкончания) Тогда 
				СтрокаТаблицы.НоваяДатаОкончания = СтрокаТаблицы.НоваяДатаОкончания + ДобавитьСекунд;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	// гкс+ [02.23] Деснол 06.02.2023
	ДокументЗакрытиеЗаявокИРемонтов.гкс_Комментарий = ЭтотОбъект["гкс_Комментарий"];
	// гкс- [02.23] Деснол 06.02.2023
	#КонецВставки

	ДокументЗакрытиеЗаявокИРемонтов.Организация = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("НастройкиТОиР", "ОсновнаяОрганизация", Истина);
	ДокументЗакрытиеЗаявокИРемонтов.Ответственный = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("НастройкиТОиР", "ОсновнойОтветственный", Справочники.Пользователи.ПустаяСсылка());	

	ДокументЗакрытиеЗаявокИРемонтов.ДополнительныеСвойства.Вставить("ИзОбработки", Истина);
	Попытка

		ДокументЗакрытиеЗаявокИРемонтов.Записать(РежимЗаписиДокумента.Проведение);

		мУдаления = Новый Массив;
		Для каждого текСтрока из Объект.ЗакрываемыеРемонты Цикл
			Если текСтрока.Обрабатывать и (текСтрока.Отменен или текСтрока.Перенесен или текСтрока.ЗакрытьЗаявку) тогда
				мУдаления.Добавить(текСтрока);
			КонецЕсли;
		КонецЦикла;
		Для каждого текСтрока из мУдаления Цикл
			Объект.ЗакрываемыеРемонты.Удалить(текСтрока);
		КонецЦикла;

		мУдаления.Очистить();
		#Вставка
		ДвиженияПоРегиструАктуальныхДат();
		Для Каждого Строка Из Объект.АварийныеРемонты Цикл
			Если Строка.Обрабатывать = Истина И Строка.гкс_Перенесен = Истина И ЗначениеЗаполнено(Строка.Заявка) Тогда
				мУдаления.Добавить(Строка);
			КонецЕсли;
		КонецЦикла;
		#КонецВставки
		Для каждого текСтрока из Объект.АварийныеРемонты Цикл
			Если текСтрока.Обрабатывать и (текСтрока.Отменен или текСтрока.ЗакрытьЗаявку) тогда
				мУдаления.Добавить(текСтрока);
			КонецЕсли;
		КонецЦикла;
		Для каждого текСтрока из мУдаления Цикл
			Объект.АварийныеРемонты.Удалить(текСтрока);
		КонецЦикла;
		ЗаполнитьПлановыеРемонтыНаСервере();
		ЗаполнитьАварийныеРемонтыНаСервере();
		#Вставка
		// гкс+ [02.23] Деснол 06.02.2023
		ЭтотОбъект["гкс_Комментарий"] = "";
		// гкс- [02.23] Деснол 06.02.2023
		#КонецВставки
		Возврат Истина;

	Исключение
		ТекстСообщения = НСтр("es='¡No consiguió anotar el documento ""el Cierre de las demandas y las reparaciones""! ';ru='Не удалось записать документ ""Закрытие заявок и ремонтов""! ';en='Failed to write the document ""Closing applications and repairs""! '") + ОписаниеОшибки();
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат Ложь;
	КонецПопытки;

КонецФункции

&НаСервере
Процедура ДвиженияПоРегиструАктуальныхДат()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.ID КАК ID,
		// гкс+ [02.23] Деснол 06.02.2023
		|	ТЧ.Заявка КАК Заявка,
		// гкс- [02.23] Деснол 06.02.2023
		|	ТЧ.гкс_Перенесен КАК Перенесен,
		|	ТЧ.Отменен КАК Отменен,
		|	ТЧ.гкс_ДатаНачала КАК ДатаНачала,
		|	ТЧ.гкс_ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ Исходные
		|ИЗ
		|	&ТЧ КАК ТЧ
		|ГДЕ
		|	ТЧ.Обрабатывать = ИСТИНА
		|	И ТЧ.гкс_Перенесен = ИСТИНА
		|	И ТЧ.Отменен = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Исходные.ID КАК IDРемонта,
		// гкс+ [02.23] Деснол 06.02.2023
		|	Исходные.Заявка КАК Заявка,
		// гкс- [02.23] Деснол 06.02.2023
		|	Исходные.ДатаНачала КАК ДатаНачала,
		|	Исходные.ДатаОкончания КАК ДатаОкончания,
		|	торо_АктуальныеПлановыеДатыРемонтов.КрайняяДатаЗавершения КАК КрайняяДатаЗавершения,
		|	торо_АктуальныеПлановыеДатыРемонтов.ДокументНачалаЦепочки КАК ДокументНачалаЦепочки,
		|	ЕстьNULL(торо_АктуальныеПлановыеДатыРемонтов.ДокументОснование, торо_ПлановыеРемонтныеРаботыСрезПоследних.Регистратор) КАК ДокументОснование,
		|	торо_АктуальныеПлановыеДатыРемонтов.ОбъектРемонта КАК ОбъектРемонта
		|ИЗ
		|	Исходные КАК Исходные
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних(
		|				,
		|				ID В
		|					(ВЫБРАТЬ
		|						ТЧ.ID
		|					ИЗ
		|						Исходные КАК ТЧ)) КАК торо_ПлановыеРемонтныеРаботыСрезПоследних
		|		ПО Исходные.ID = торо_ПлановыеРемонтныеРаботыСрезПоследних.ID
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК торо_АктуальныеПлановыеДатыРемонтов
		|		ПО (торо_АктуальныеПлановыеДатыРемонтов.IDРемонта = Исходные.ID)
		|ГДЕ
		|	торо_ПлановыеРемонтныеРаботыСрезПоследних.Регистратор ЕСТЬ NULL";
	Запрос.УстановитьПараметр("ТЧ",Объект.АварийныеРемонты.Выгрузить(,"ID,Обрабатывать,гкс_Перенесен,Отменен,гкс_ДатаНачала,гкс_ДатаОкончания,Заявка"));
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	ДобавитьСекунд = (ЭтотОбъект["гкс_СдвигЧП"] * -3600);
	МассивПеренесенных = Новый Массив();
	Пока Выборка.Следующий() Цикл
		НЗ = РегистрыСведений.торо_АктуальныеПлановыеДатыРемонтов.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(НЗ, Выборка);
		Если ЗначениеЗаполнено(НЗ.ДатаНачала) Тогда 
			НЗ.ДатаНачала = НЗ.ДатаНачала + ДобавитьСекунд;
		КонецЕсли;
		Если ЗначениеЗаполнено(НЗ.ДатаОкончания) Тогда 
			НЗ.ДатаОкончания = НЗ.ДатаОкончания + ДобавитьСекунд;
		КонецЕсли;
		Если Выборка.КрайняяДатаЗавершения < Выборка.ДатаОкончания Тогда 
			НЗ.КрайняяДатаЗавершения = Выборка.ДатаОкончания;
		КонецЕсли;
		// гкс+ [02.23] Деснол 06.02.2023
		Если ЗначениеЗаполнено(Выборка.Заявка) Тогда 
			НЗ.ДокументОснование = Выборка.Заявка;
			МассивПеренесенных.Добавить(Выборка.Заявка);
		КонецЕсли;
		// гкс- [02.23] Деснол 06.02.2023
		// гкс+ [] Деснол 16.08.2022
		НЗ.гкс_ЭтоПереносРемонта = Истина;
		// гкс- [] Деснол 16.08.2022
		НЗ.Записать();
	КонецЦикла;
	//
	Если МассивПеренесенных.Количество() Тогда
		СобытиеСсылка = Константы.гкс_СобытиеПереносРемонтаЗаявки.Получить();
		Если ЗначениеЗаполнено(СобытиеСсылка) Тогда 
		// найти заявки по ремонтам и сформировать уведомления
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	РегистрСведенийторо_ЗаявкиПоРемонтам.IDРемонта КАК ИД,
		               |	МАКСИМУМ(РегистрСведенийторо_ЗаявкиПоРемонтам.Регистратор) КАК Ссылка
		               |ИЗ
		               |	РегистрСведений.торо_ЗаявкиПоРемонтам КАК РегистрСведенийторо_ЗаявкиПоРемонтам
		               |ГДЕ
		               |	РегистрСведенийторо_ЗаявкиПоРемонтам.IDРемонта В(&ИД)
		               |	И РегистрСведенийторо_ЗаявкиПоРемонтам.Регистратор ССЫЛКА Документ.торо_ЗаявкаНаРемонт
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	РегистрСведенийторо_ЗаявкиПоРемонтам.IDРемонта";
		Запрос.УстановитьПараметр("ИД", МассивПеренесенных);
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда 
			
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				МассивСвойств = Новый Массив();
				НайдСтр = Объект.АварийныеРемонты.НайтиСтроки(Новый Структура("ID", Выборка.ИД));
				Если НайдСтр.Количество() > 0 Тогда 
					МассивСвойств.Добавить(Новый Структура("Ключ,Значение", "НоваяДатаНачала", НайдСтр[0].НоваяДатаНачала + ДобавитьСекунд));
					МассивСвойств.Добавить(Новый Структура("Ключ,Значение", "НоваяДатаОкончания", НайдСтр[0].НоваяДатаОкончания + ДобавитьСекунд));
				КонецЕсли;
				торо_РаботаСУведомлениями.гкс_ЗаписатьУведомленияСрокаСогласования(Выборка.Ссылка, СобытиеСсылка, Новый Массив(), , МассивСвойств);
			КонецЦикла;
		КонецЕсли;
		//
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ВыполнитьОбработкуФрагмент")
Процедура Расш_гкс_ВыполнитьОбработкуФрагмент(Знач МассивНезаполненныхСтрок)
    
    Перем ДокументСоздан, Строка;
    
    Для Каждого Строка Из МассивНезаполненныхСтрок Цикл
        ОбрабатываемыеСтроки.Удалить(Строка);
    КонецЦикла;

	Если ОбрабатываемыеСтроки.Количество()=0 Тогда
		#Вставка
		Для Каждого Строка Из Объект.АварийныеРемонты Цикл
			Если Строка.Обрабатывать = Истина И Строка.гкс_Перенесен = Истина И ЗначениеЗаполнено(Строка.Заявка) Тогда
				ДвиженияПоРегиструАктуальныхДат();
				мУдаления = Новый Массив();
				Для Каждого Строка Из Объект.АварийныеРемонты Цикл
					Если Строка.Обрабатывать = Истина И Строка.гкс_Перенесен = Истина И ЗначениеЗаполнено(Строка.Заявка) Тогда
						мУдаления.Добавить(Строка);
					КонецЕсли;
				КонецЦикла;
				Для каждого текСтрока из мУдаления Цикл
					Объект.АварийныеРемонты.Удалить(текСтрока);
				КонецЦикла;
				Возврат;
			КонецЕсли;
		КонецЦикла;
		#КонецВставки
		ТекстСообщения = НСтр("es='Ni para una de las líneas escogidas no es indicado el tipo del tratamiento: ¡la anulación/traslado de la reparación o el cierre de la demanda! ¡El tratamiento no es cumplido!';ru='Ни для одной из выбранных строк не указан вид обработки: отмена/перенос ремонта или закрытие заявки! Обработка не выполнена!';en='No type of processing is indicated for any of the selected lines: cancellation / transfer of repairs or closing of an application! Processing failed!'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;

	ДокументСоздан = СоздатьДокументЗакрытияЗаявокНаСервере();

	Если ДокументСоздан Тогда

		Если НЕ ЗначениеЗаполнено(Владелец) Тогда
			Оповестить("ВыполненПереносРемонтов", ЭтаФорма.КлючУникальности, ЭтаФорма);
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры


&НаКлиенте
&ИзменениеИКонтроль("ВыполнитьОбработку")
Процедура гкс_ВыполнитьОбработку(Команда)
	#Вставка
	// гкс+ [02.23] Деснол 06.02.2023
	ОчиститьСообщения();
	Если Не ЗначениеЗаполнено(ЭтотОбъект["гкс_Комментарий"]) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Комментарий не заполнен";
		Сообщение.Поле = "гкс_Комментарий";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	// гкс- [02.23] Деснол 06.02.2023
	#КонецВставки

	отказ = ВыполнитьОбработкуНаСервере();

	ПричиныНеЗаполнены = Ложь;
	Для Каждого Строка Из ОбрабатываемыеСтроки Цикл
		Если ((Строка.Отменен ИЛИ Строка.Перенесен) И НЕ ЗначениеЗаполнено(Строка.ПричинаЗакрытия))
			ИЛИ (Строка.ЗакрытьЗаявку И НЕ ЗначениеЗаполнено(Строка.ПричинаЗакрытияЗаявки)) Тогда
			Если ЗначениеЗаполнено(Владелец) Тогда
				ПоказатьПредупреждение(Неопределено,НСтр("es='No para todas las reparaciones cerradas (los Presupuestos de la reparación (¡las Demandas por la reparación) es indicada la Causa del cierre! ¡El tratamiento no es cumplido!';ru='Не для всех закрываемых ремонтов (Смет ремонта(Заявок на ремонт) указана Причина закрытия! Обработка не выполнена!';en='Not for all repairs to be closed (Repair estimates (Repair requests), the reason for closing is indicated! Processing failed!'"));
			Иначе
				ТекстСообщения = НСтр("es='No para todas las reparaciones cerradas (los Presupuestos de la reparación (¡las Demandas por la reparación) es indicada la Causa del cierre! ¡El tratamiento no es cumplido!';ru='Не для всех закрываемых ремонтов (Смет ремонта(Заявок на ремонт) указана Причина закрытия! Обработка не выполнена!';en='Not for all repairs to be closed (Repair estimates (Repair requests), the reason for closing is indicated! Processing failed!'");
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;

			ПричиныНеЗаполнены = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если отказ или ПричиныНеЗаполнены Тогда
		Возврат;
	КонецЕсли;

	МассивНезаполненныхСтрок = ОбрабатываемыеСтроки.НайтиСтроки(Новый Структура("Обрабатывать, Отменен, Перенесен, ЗакрытьЗаявку", Истина, Ложь, Ложь, Ложь));
	Если МассивНезаполненныхСтрок.Количество()>0 Тогда
		Ответ = Неопределено;

		ПоказатьВопрос(Новый ОписаниеОповещения("ВыполнитьОбработкуЗавершение", ЭтотОбъект, Новый Структура("МассивНезаполненныхСтрок", МассивНезаполненныхСтрок)), НСтр("es='No para todas las líneas tratadas es indicado el tipo del tratamiento de la reparación (es anulado o llevado) o la demanda. ¿Da lo mismo cumplir el tratamiento?';ru='Не для всех обрабатываемых строк указан вид обработки ремонта (отменен или перенесен) или заявки. Все равно выполнить обработку?';en='Not all processed lines indicate the type of repair processing (canceled or rescheduled) or application. Do the processing anyway?'"), РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;

	// Выполняем создание нового документа торо_ЗакрытиеЗаявокИРемонтов.
	ВыполнитьОбработкуФрагмент(МассивНезаполненныхСтрок);

	Оповестить("ЗакрытиеЗаявокИРемонтов", Неопределено);
КонецПроцедуры


&НаСервере
&ИзменениеИКонтроль("ЗаполнитьПлановыеРемонтыНаСервере")
Процедура гкс_ЗаполнитьПлановыеРемонтыНаСервере(ОтборРемонтов)
	#Вставка
	// Гкс+[TOIR20-607] Оселедько В.С. от 17.07.2025. Добавлено:{
	ВремяНачалаЗамераЗаполненияТЧ = ОценкаПроизводительности.НачатьЗамерВремени();
	// } Гкс-[TOIR20-607] Оселедько В.С. от 17.07.2025.
	#КонецВставки
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РемонтыЗаявок.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ РемонтыСАктамиНарядами
	|ИЗ
	|	РегистрСведений.торо_ЗаявкиПоРемонтам КАК РемонтыЗаявок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НарядыПоРемонтам КАК торо_НарядыПоРемонтам
	|		ПО РемонтыЗаявок.IDРемонта = торо_НарядыПоРемонтам.IDРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктыПоРемонтам КАК торо_АктыПоРемонтам
	|		ПО РемонтыЗаявок.IDРемонта = торо_АктыПоРемонтам.IDРемонта
	|ГДЕ
	|	НЕ(торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
	|				И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	торо_ЗаявкиПоРемонтам.IDРемонта КАК ID,
	|	РемонтыСАктамиНарядами.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ РемонтыЗаявокСАктамиНарядами
	|ИЗ
	|	РемонтыСАктамиНарядами КАК РемонтыСАктамиНарядами
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК торо_ЗаявкиПоРемонтам
	|		ПО РемонтыСАктамиНарядами.Регистратор = торо_ЗаявкиПоРемонтам.Регистратор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ПлановыеРемонтныеРаботыСрезПоследних.ID КАК ID,
	|	торо_ПлановыеРемонтныеРаботыСрезПоследних.Регистратор КАК Регистратор,
	|	торо_ПлановыеРемонтныеРаботыСрезПоследних.ДатаНачалаРемонтныхРабот КАК ДатаНачалаРемонтныхРабот,
	|	торо_ПлановыеРемонтныеРаботыСрезПоследних.ДатаОкончанияРемонтныхРабот КАК ДатаОкончанияРемонтныхРабот,
	|	торо_ПлановыеРемонтныеРаботыСрезПоследних.ОбъектРемонтныхРабот КАК ОбъектРемонта,
	|	торо_ПлановыеРемонтныеРаботыСрезПоследних.ВидРемонтныхРабот КАК ВидРемонта
	|ПОМЕСТИТЬ РемонтыПлановыеИДефекты
	|ИЗ
	|	РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних КАК торо_ПлановыеРемонтныеРаботыСрезПоследних
	|ГДЕ
	|	торо_ПлановыеРемонтныеРаботыСрезПоследних.ДатаНачалаРемонтныхРабот <= &ДатаАктуальности
	|	И НЕ торо_ПлановыеРемонтныеРаботыСрезПоследних.Замещен
	|	И НЕ торо_ПлановыеРемонтныеРаботыСрезПоследних.Отменен
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РемонтыПлановыеИДефекты.ID КАК ID,
	|	РемонтыПлановыеИДефекты.Регистратор КАК Регистратор,
	|	РемонтыПлановыеИДефекты.ДатаНачалаРемонтныхРабот КАК ДатаНачалаРемонтныхРабот,
	|	РемонтыПлановыеИДефекты.ДатаОкончанияРемонтныхРабот КАК ДатаОкончанияРемонтныхРабот,
	|	РемонтыПлановыеИДефекты.ОбъектРемонта КАК ОбъектРемонта,
	|	РемонтыПлановыеИДефекты.ВидРемонта КАК ВидРемонта
	|ПОМЕСТИТЬ РемонтыПлановыеСПодчиненными
	|ИЗ
	|	РемонтыПлановыеИДефекты КАК РемонтыПлановыеИДефекты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_НарядыПоРемонтам КАК торо_НарядыПоРемонтам
	|		ПО РемонтыПлановыеИДефекты.ID = торо_НарядыПоРемонтам.IDРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктыПоРемонтам КАК торо_АктыПоРемонтам
	|		ПО РемонтыПлановыеИДефекты.ID = торо_АктыПоРемонтам.IDРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РемонтыЗаявокСАктамиНарядами КАК РемонтыЗаявокСАктамиНарядами
	|		ПО РемонтыПлановыеИДефекты.ID = РемонтыЗаявокСАктамиНарядами.ID
	|ГДЕ
	|	торо_НарядыПоРемонтам.IDРемонта ЕСТЬ NULL
	|	И торо_АктыПоРемонтам.IDРемонта ЕСТЬ NULL
	|	И РемонтыЗаявокСАктамиНарядами.ID ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	РемонтыПлановыеСПодчиненными.ID КАК ID,
	|	РемонтыПлановыеСПодчиненными.ОбъектРемонта КАК ОбъектРемонта,
	|	РемонтыПлановыеСПодчиненными.ВидРемонта КАК ВидРемонта,
	|	РемонтыПлановыеСПодчиненными.ДатаНачалаРемонтныхРабот КАК ДатаНачалаРемонтныхРабот,
	|	РемонтыПлановыеСПодчиненными.ДатаОкончанияРемонтныхРабот КАК ДатаОкончанияРемонтныхРабот,
	|	ВЫБОР
	|		КОГДА НЕ Заявки.Регистратор ЕСТЬ NULL
	|				И торо_ОтмененныеЗаявки.Заявка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЕстьЗаявка,
	|	Заявки.Регистратор КАК Смета,
	|	РемонтыПлановыеСПодчиненными.Регистратор КАК Регистратор,
	|	Константы.торо_ПричинаЗакрытияРемонтов КАК ПричинаЗакрытия,
	|	Константы.торо_ПричинаЗакрытияЗаявок КАК ПричинаЗакрытияЗаявки,
	|	Константы.торо_ОтменятьЗакрытиеЗаявок КАК Отменен,
	|	РемонтыПлановыеСПодчиненными.Регистратор КАК ДокументОснование,
	|	Заявки.МоментВремени КАК ДатаЗаявки,
	|	РемонтыПлановыеСПодчиненными.Регистратор.МоментВремени КАК ДатаДокументаОснования
	|ПОМЕСТИТЬ ТабСДублями
	|ИЗ
	|	РемонтыПлановыеСПодчиненными КАК РемонтыПлановыеСПодчиненными
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ЗаявкиПоРемонтам КАК Заявки
	|		ПО РемонтыПлановыеСПодчиненными.ID = Заявки.IDРемонта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки
	|		ПО (Заявки.Регистратор = торо_ОтмененныеЗаявки.Заявка)
	|			И РемонтыПлановыеСПодчиненными.ID = торо_ОтмененныеЗаявки.ИДРемонта,
	|	Константы КАК Константы
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID,
	|	Смета
	|;
