#Область ОбработчикиСобытийФормы

&НаСервере
Процедура гкс_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ВремяНачалаОткрытияФормы") Тогда
		ВремяНачалаЗамера = Параметры.ВремяНачалаОткрытияФормы;		
	КонецЕсли;	
	
КонецПроцедуры


&НаСервере
Процедура Расш_гкс_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	// гкс+ [Часовые пояса] Куст 09.04.2020
	гкс_ЧасовыеПоясаВызовСервера.ДобавитьНовыеЭлементы(ЭтаФорма, Элементы.Группа2,);
	//гкс_СдвигЧП
	// гкс- [Часовые пояса] Куст 09.04.2020
	//
	НовыеРеквизиты = Новый Массив();
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_ПустаяЗаявка",
		Новый ОписаниеТипов("ДокументСсылка.торо_ЗаявкаНаРемонт")));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_Перенесен",
		Новый ОписаниеТипов("Булево"),"Объект.АварийныеРемонты"));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_ДатаНачала",
		Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)),"Объект.АварийныеРемонты"));
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_ДатаОкончания",
		Новый ОписаниеТипов("Дата",,,,,Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)),"Объект.АварийныеРемонты"));
	// гкс+ [02.23] Деснол 06.02.2023
	НовыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_Комментарий",
		Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(500)),, "Комментарий"));
	// гкс- [02.23] Деснол 06.02.2023
	ИзменитьРеквизиты(НовыеРеквизиты);
	//
	НЭлем = Элементы.Добавить("гкс_Перенесен",Тип("ПолеФормы"),Элементы.АварийныеРемонты);
	НЭлем.Вид = ВидПоляФормы.ПолеФлажка;
	НЭлем.ПутьКДанным = "Объект.АварийныеРемонты.гкс_Перенесен";
	НЭлем.Заголовок = НСтр("ru='Перенесен';en='Moved';es='Es llevado'");
	НЭлем.УстановитьДействие("ПриИзменении","гкс_ПеренесенПриИзменении"); 
	//
	НЭлем = Элементы.Добавить("гкс_ДатаНачала",Тип("ПолеФормы"),Элементы.АварийныеРемонты);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Объект.АварийныеРемонты.гкс_ДатаНачала";
	НЭлем.Заголовок = НСтр("ru='Новая дата начала';en='New start date';es='Una nueva fecha ha comenzado'");
	НЭлем.УстановитьДействие("ПриИзменении","гкс_ДатаПриИзменении");
	//
	НЭлем = Элементы.Добавить("гкс_ДатаОкончания",Тип("ПолеФормы"),Элементы.АварийныеРемонты);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "Объект.АварийныеРемонты.гкс_ДатаОкончания";
	НЭлем.Заголовок = НСтр("ru='Новая дата окончания';en='New end date';es='Una nueva fecha de la terminación'");
	НЭлем.УстановитьДействие("ПриИзменении","гкс_ДатаПриИзменении"); 
	//
	Элементы.Переместить(Элементы["гкс_Перенесен"],Элементы.АварийныеРемонты,Элементы.АварийныеРемонтыРемонтВключенВОбщийПлан);
	Элементы.Переместить(Элементы["гкс_ДатаНачала"],Элементы.АварийныеРемонты,Элементы.АварийныеРемонтыРемонтВключенВОбщийПлан);
	Элементы.Переместить(Элементы["гкс_ДатаОкончания"],Элементы.АварийныеРемонты,Элементы.АварийныеРемонтыРемонтВключенВОбщийПлан);
	// гкс+ [Релиз16] Деснол
	Если Параметры.Свойство("ТекущаяСтраница") Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы[Параметры.ТекущаяСтраница];
	КонецЕсли;
	// гкс- [Релиз16]
	// гкс+ [02.23] Деснол 06.02.2023
	НЭлем = Элементы.Вставить("гкс_Комментарий", Тип("ПолеФормы"), Элементы.Группа2, Элементы.ФормаВыполнитьОбработку);
	НЭлем.Вид = ВидПоляФормы.ПолеВвода;
	НЭлем.ПутьКДанным = "гкс_Комментарий";
	НЭлем.МногострочныйРежим = Истина;
	НЭлем.АвтоМаксимальнаяШирина = Ложь;
	//
	Элементы.Декорация1.Видимость = Ложь;
	// гкс- [02.23] Деснол 06.02.2023
КонецПроцедуры

