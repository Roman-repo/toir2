    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПодчиненныеТК.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПодчиненныеТК.ТехКарта</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	торо_ИдентификаторыТехКарт.Ссылка КАК Ссылка
ПОМЕСТИТЬ ГруппаВладельца
ИЗ
	Справочник.торо_ИдентификаторыТехКарт КАК торо_ИдентификаторыТехКарт
ГДЕ
	торо_ИдентификаторыТехКарт.гкс_Владелец = &amp;Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	торо_ИдентификаторыТехКарт.гкс_Обслуживание КАК Обслуживание,
	торо_ИдентификаторыТехКарт.Статус КАК Статус,
	торо_ИдентификаторыТехКарт.Ссылка КАК Ссылка
ПОМЕСТИТЬ НужныеИТК
ИЗ
	ГруппаВладельца КАК ГруппаВладельца
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК торо_ИдентификаторыТехКарт
		ПО ГруппаВладельца.Ссылка = торо_ИдентификаторыТехКарт.Родитель
			И (торо_ИдентификаторыТехКарт.ЭтоГруппа = ЛОЖЬ)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	НужныеИТК.Обслуживание КАК Обслуживание,
	НужныеИТК.Статус КАК Статус,
	НужныеИТК.Ссылка КАК Ссылка,
	торо_ВерсииТехКартСрезПоследних.ТехКарта.НормаВремениТекст КАК Продолжительность,
	торо_ВерсииТехКартСрезПоследних.ТехКарта.ДатаПринятия КАК ДатаПринятия,
	торо_ВерсииТехКартСрезПоследних.ТехКарта.Ссылка КАК ТехКарта,
	торо_ВерсииТехКартСрезПоследних.ТехКарта.гкс_ПериодДействия КАК гкс_ПериодДействия,	
	торо_ВерсииТехКартСрезПоследних.ТехКарта.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия
ИЗ
	НужныеИТК КАК НужныеИТК
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт.СрезПоследних КАК торо_ВерсииТехКартСрезПоследних
		ПО НужныеИТК.Ссылка = торо_ВерсииТехКартСрезПоследних.ИдентификаторТехКарты</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
