&НаКлиенте
Процедура ПредшествующиеРемонтыПредшествующийВидРемонтаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	текДанные = Элементы.дс_ПредшествующиеРемонты.ТекущиеДанные;
	
	Если текДанные.ПредшествующийВидРемонта = ВыбранноеЗначение Тогда
		Возврат;
	КонецЕсли;
	
	стрПоиска = Новый Структура("ВидРемонта, ПредшествующийВидРемонта", текДанные.ВидРемонта, ВыбранноеЗначение);
	НайС = дс_ПредшествующиеРемонты.НайтиСтроки(стрПоиска);
	
	Если НайС.Количество() > 0 Тогда
		СтандартнаяОбработка = Ложь;
		
		ТекстСообщения = НСтр("es='El tipo de la reparación es añadido ya en otra línea de la tabla.';
		|ru='Вид ремонта уже добавлен в другой строке таблицы.';
		|en='A repair type has already been added to another row in the table.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "дс_ПредшествующиеРемонты");
	КонецЕсли;
	
	СписокОтбора = Новый СписокЗначений(); 	
	
	Для каждого Строка Из дс_НормативныеРемонты Цикл		
		СписокОтбора.Добавить(Строка.ВидРемонта);		
	КонецЦикла; 
	
	НайденВНормативах = СписокОтбора.НайтиПоЗначению(ВыбранноеЗначение);
	Если НайденВНормативах = Неопределено тогда
		СтандартнаяОбработка = Ложь;
		ПоказатьПредупреждение(Неопределено, СтрЗаменить(
		Нстр("es='¡El tipo de la reparación %ВидРемонта% no es encontrado en la lista de las reparaciones normativas!';
		|ru='Вид ремонта %ВидРемонта% не найден в списке нормативных ремонтов!';
		|en='Type of repair %ВидРемонта% not found in the list of normative repairs!'"),
		"%ВидРемонта%", ВыбранноеЗначение),,НСтр("es='La elección del tipo de la reparación...';
		|ru='Выбор вида ремонта...';en='Selecting the type of repair ...'"));		
	КонецЕсли; 	
	
КонецПроцедуры

