#Область ОписаниеПеременных

&НаКлиенте
Перем СтруктураДанныхДоРедактирования;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	_ХозСпособ = Перечисления.СпособыСтроительства.Хозспособ;
	_СтатусДействует = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.Действует;
	_СтатусВРаботе = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке;
	дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ТиповойОР",Неопределено);
	дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ОтборВключен",Ложь);
	//
	// СтандартныеПодсистемы.Свойства
	Контекст = Новый Структура();
	Контекст.Вставить("Объект",                     Объект);
	Контекст.Вставить("ИмяЭлементаДляРазмещения",   "ГруппаДополнительныеРеквизиты");
	Контекст.Вставить("ПроизвольныйОбъект",         Ложь);
	Контекст.Вставить("ИмяРеквизитаНаборСвойств",   "НаборСвойствОР");
	Контекст.Вставить("УсловноеОформлениеЗаполнятьОбязательно",   Ложь);
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Контекст);
	// Конец СтандартныеПодсистемы.Свойства
	Попытка
		Элементы.Переместить(Элементы.ДополнительныеРеквизитыДобавитьИзНабора,Элементы["ГруппаДополнительныеРеквизиты"].ПодчиненныеЭлементы.Свойства_ЗначенияДополнительныхРеквизитов.КоманднаяПанель);
	Исключение
	КонецПопытки;
	//Локализация
	дс_ПриСозданииНаСервере();
	//Локализация
	дс_ТК_Операции.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
	дс_ТК_МатЗатраты.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
	дс_ТК_Трудозатраты.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
	дс_ТК_Инструменты.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
	// гкс+ [Релиз 1] Куст 20.01.2021
	Если РольДоступна("гкс_ЗапретРедактированиеКлассовТиповыхОР") Тогда 
		Элементы.СписокСоздатьКласс.Видимость = Ложь;
		Элементы.СписокСоздатьПодКласс.Видимость = Ложь;
	КонецЕсли;
	// гкс- [Релиз 1] Куст 20.01.2021
	
	// Гкс+[TOIR20-94] Борисов В.М. от 05.06.2020. Добавлено:{
	гкс_ДобавитьЭлементыФормы();
	// } Гкс-[TOIR20-94] Борисов В.М. от 05.06.2020.
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если ЗавершениеРаботы = Ложь И дс_МожноЗакрывать = Ложь Тогда 
		Если МодифицированностьИзмеряемыхПоказателей ИЛИ дс_Модифицированность ИЛИ МодифицированностьПараметровОповещенияОСостоянииОР
			ИЛИ МодифицированностьНормРемонтов
			ИЛИ МодифицированностьПредшествующихРемонтов
			ИЛИ МодифицированностьМаксЗначНаработки
			ИЛИ МодифицированностьПараметровНаработки
			ИЛИ МодифицированностьЗамещаемыхРемонтов Тогда 
			Отказ = Истина; СтандартнаяОбработка = Ложь;
			ОписаниеОповещенияПослеВопроса = Новый ОписаниеОповещения("СохранитьПередЗакрытиемПослеВопроса",ЭтотОбъект,Новый Структура("ЗакрытьПослеЗаписи",Истина));
			ПоказатьВопрос(ОписаниеОповещенияПослеВопроса,НСтр("ru='Введенные данные не сохранены. Сохранить?'"),РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СписокПриАктивизацииСтроки(Элемент)
	Если дс_НеРеагировать Тогда 
		Возврат;
	КонецЕсли;
	//
	Если МодифицированностьТЧТехКарт Тогда 
		ТекДанные = Элементы.Список.ТекущиеДанные;
		Если Не ТекДанные = Неопределено Тогда 
			Если дс_ДоСсылка = ТекДанные.Ссылка Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;
		ОписаниеОповещенияПослеВопроса = Новый ОписаниеОповещения("СохранитьТКПослеВопроса",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещенияПослеВопроса,НСтр("ru='Шаблоны тех карт не сохранены. Сохранить?';
		|en='Patterns standard maintenance plans is not saved. Save?'"),РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	//
	Если МодифицированностьИзмеряемыхПоказателей ИЛИ дс_Модифицированность ИЛИ МодифицированностьПараметровОповещенияОСостоянииОР
		ИЛИ МодифицированностьНормРемонтов
		ИЛИ МодифицированностьПредшествующихРемонтов
		ИЛИ МодифицированностьМаксЗначНаработки
		ИЛИ МодифицированностьПараметровНаработки
		ИЛИ МодифицированностьЗамещаемыхРемонтов Тогда 
		ТекДанные = Элементы.Список.ТекущиеДанные;
		Если Не ТекДанные = Неопределено Тогда 
			Если дс_ДоСсылка = ТекДанные.Ссылка Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;
		ОписаниеОповещенияПослеВопроса = Новый ОписаниеОповещения("НеСохранитьПослеВопроса",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещенияПослеВопроса,НСтр("ru='Введенные данные не сохранены. Продолжить?';
		|en='The entered data is not saved. Continue?'"),РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	//
	ПодключитьОбработчикОжидания("ЧерезСекунду",0.1,Истина);

КонецПроцедуры

&НаКлиенте
Процедура ЧерезСекунду() Экспорт
	ТекДанные = Элементы.Список.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если дс_ДоСсылка = ТекДанные.Ссылка Тогда 
			Возврат;
		КонецЕсли;
		//
		дс_Редактирование = Ложь;
		Элементы.Редактировать.Пометка = дс_Редактирование;
		//
		дс_Ссылка = ТекДанные.Ссылка;
		дс_ДоСсылка = ТекДанные.Ссылка;
		дс_Родитель = ТекДанные.Родитель;
		дс_Код = ТекДанные.Код;
		дс_НаборСвойствОР = ТекДанные.НаборСвойствОР;
		дс_Наименование = ТекДанные.Наименование;
		Изготовитель = ТекДанные.Изготовитель;
		гкс_Модель = ТекДанные.гкс_Модель;
		дс_Направление = ТекДанные.Направление;
		дс_ТипОбъекта = ТекДанные.ТипОбъекта;
		дс_Комментарий = ТекДанные.Комментарий;
		дс_ЭтоГруппа = ТекДанные.ЭтоГруппа;
		дс_ФайлКартинки = ТекДанные.ФайлКартинки;
		//
		ОбновитьПоСсылке();
	Иначе
		ОбновитьДоступностьРеквизитов();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура МожноРеагировать() Экспорт
	дс_НеРеагировать = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПоСсылке()
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ТиповойОР",дс_Ссылка);
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ОтборВключен",Истина);		
		ПодчиненныеТК.Параметры.УстановитьЗначениеПараметра("Ссылка",дс_Ссылка);
		
		СтраницыПраваяПриСменеСтраницы(Элементы.СтраницыПравая, Элементы.СтраницыПравая.ТекущаяСтраница);
		
		ПолучитьТаблицыНормативов();
		
		Массив = Новый Массив;
		Массив.Добавить("дс_СписокИзмеряемыхПоказателей");
		Массив.Добавить("ПараметрыОповещенияПоСостояниямОР");
		Массив.Добавить("СписокПараметровНаработки");
		Массив.Добавить("ТабМаксимальныхЗначенийНаработки");
		Массив.Добавить("дс_НормативныеРемонты");
		Массив.Добавить("дс_ПредшествующиеРемонты");
		Массив.Добавить("дс_ЗамещаемыеРемонты");
		торо_СобытияФормКлиент.ЗаполнитьСтруктуруДанныхДоРедактирования(СтруктураДанныхДоРедактирования,Массив);
		
		ОбновитьДоступностьРеквизитов();
		ОбновитьВидимостьРеквизитов();
		
КонецПроцедуры

&НаСервере
Процедура ПолучитьТаблицыНормативов(ТемпСсылка = Неопределено)
	Если ТемпСсылка = Неопределено Тогда 
		ТемпСсылка = дс_Ссылка;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТемпСсылка) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	//	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ТиповыеОРНормативныеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРНормативныеРемонты.НормативныйРемонт КАК НормативныйРемонт,
		|	торо_ТиповыеОРНормативныеРемонты.СпособПланирования КАК СпособПланирования,
		|	торо_ТиповыеОРНормативныеРемонты.Статус КАК Статус,
		|	торо_ТиповыеОРНормативныеРемонты.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
		|	торо_ТиповыеОРНормативныеРемонты.СпособВыполнения КАК СпособВыполнения,
		|	торо_ТиповыеОРНормативныеРемонты.НеИспользоватьВПланированииДатуВводаВЭксплуатацию КАК НеИспользоватьВПланированииДатуВводаВЭксплуатацию,
		|	торо_ТиповыеОРНормативныеРемонты.СпособУчетаДатыОтсчета КАК СпособУчетаДатыОтсчета,
		|	торо_ТиповыеОРНормативныеРемонты.НеУчаствуетВПланировании КАК НеУчаствуетВПланировании,
		|	торо_ТиповыеОРНормативныеРемонты.РазрешитьСокращатьМежремонтныйПериодПриПланировании КАК РазрешитьСокращатьМежремонтныйПериодПриПланировании,
		|	торо_ТиповыеОРНормативныеРемонты.НеУчитыватьПриПланированииГрафикРемонтныхРабот КАК НеУчитыватьПриПланированииГрафикРемонтныхРабот,
		|	торо_ТиповыеОРНормативныеРемонты.НеУчитыватьПродолжительность КАК НеУчитыватьПродолжительность,
		|	торо_ТиповыеОРНормативныеРемонты.ИспользоватьКоэффициентыРемонтныхОсобенностей КАК ИспользоватьКоэффициентыРемонтныхОсобенностей,
		|	торо_ТиповыеОРНормативныеРемонты.УчитыватьПростоиОборудования КАК УчитыватьПростоиОборудования
		|ИЗ
		|	Справочник.торо_ТиповыеОР.НормативныеРемонты КАК торо_ТиповыеОРНормативныеРемонты
		|ГДЕ
		|	торо_ТиповыеОРНормативныеРемонты.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРПредшествующиеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРПредшествующиеРемонты.ПредшествующийВидРемонта КАК ПредшествующийВидРемонта
		|ИЗ
		|	Справочник.торо_ТиповыеОР.ПредшествующиеРемонты КАК торо_ТиповыеОРПредшествующиеРемонты
		|ГДЕ
		|	торо_ТиповыеОРПредшествующиеРемонты.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРЗамещаемыеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРЗамещаемыеРемонты.ЗамещаемыйВидРемонта КАК ЗамещаемыйВидРемонта,
		|	торо_ТиповыеОРЗамещаемыеРемонты.СпособЗамещения КАК СпособЗамещения,
		|	торо_ТиповыеОРЗамещаемыеРемонты.НачальнаяГраница КАК НачальнаяГраница,
		|	торо_ТиповыеОРЗамещаемыеРемонты.КонечнаяГраница КАК КонечнаяГраница
		|ИЗ
		|	Справочник.торо_ТиповыеОР.ЗамещаемыеРемонты КАК торо_ТиповыеОРЗамещаемыеРемонты
		|ГДЕ
		|	торо_ТиповыеОРЗамещаемыеРемонты.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРгкс_КонструктивныйСостав.Компонент КАК Компонент
		|ИЗ
		|	Справочник.торо_ТиповыеОР.гкс_КонструктивныйСостав КАК торо_ТиповыеОРгкс_КонструктивныйСостав
		|ГДЕ
		|	торо_ТиповыеОРгкс_КонструктивныйСостав.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ТиповыеОР.Родитель КАК Родитель,
		|	2 КАК Уровень
		|ПОМЕСТИТЬ ВсеРодители
		|ИЗ
		|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
		|ГДЕ
		|	торо_ТиповыеОР.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ТиповыеОР.Родитель.Родитель,
		|	3
		|ИЗ
		|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
		|ГДЕ
		|	торо_ТиповыеОР.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРДополнительныеРеквизиты.Свойство КАК Свойство,
		|	торо_ТиповыеОРДополнительныеРеквизиты.Значение КАК Значение,
		|	торо_ТиповыеОРДополнительныеРеквизиты.ТекстоваяСтрока КАК ТекстоваяСтрока,
		|	3 КАК Уровень
		|ПОМЕСТИТЬ СвоиРеквизиты
		|ИЗ
		|	Справочник.торо_ТиповыеОР.ДополнительныеРеквизиты КАК торо_ТиповыеОРДополнительныеРеквизиты
		|ГДЕ
		|	торо_ТиповыеОРДополнительныеРеквизиты.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_ТиповыеОРДополнительныеРеквизиты.Свойство,
		|	торо_ТиповыеОРДополнительныеРеквизиты.Значение,
		|	торо_ТиповыеОРДополнительныеРеквизиты.ТекстоваяСтрока,
		|	ВсеРодители.Уровень
		|ИЗ
		|	ВсеРодители КАК ВсеРодители
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ДополнительныеРеквизиты КАК торо_ТиповыеОРДополнительныеРеквизиты
		|		ПО ВсеРодители.Родитель = торо_ТиповыеОРДополнительныеРеквизиты.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СвоиРеквизиты.Свойство КАК Свойство,
		|	МАКСИМУМ(СвоиРеквизиты.Уровень) КАК Уровень
		|ПОМЕСТИТЬ ПриоритетыРеквизитов
		|ИЗ
		|	СвоиРеквизиты КАК СвоиРеквизиты
		|
		|СГРУППИРОВАТЬ ПО
		|	СвоиРеквизиты.Свойство
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СвоиРеквизиты.Свойство КАК Свойство,
		|	СвоиРеквизиты.Значение КАК Значение,
		|	СвоиРеквизиты.ТекстоваяСтрока КАК ТекстоваяСтрока,
		|	СвоиРеквизиты.Уровень = 3 КАК Своя
		|ИЗ
		|	ПриоритетыРеквизитов КАК ПриоритетыРеквизитов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СвоиРеквизиты КАК СвоиРеквизиты
		|		ПО ПриоритетыРеквизитов.Свойство = СвоиРеквизиты.Свойство
		|			И ПриоритетыРеквизитов.Уровень = СвоиРеквизиты.Уровень";
	
	Запрос.УстановитьПараметр("Ссылка", ТемпСсылка);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	дс_НормативныеРемонты.Загрузить(РезультатЗапроса[0].Выгрузить());
	дс_ПредшествующиеРемонты.Загрузить(РезультатЗапроса[1].Выгрузить());
	дс_ЗамещаемыеРемонты.Загрузить(РезультатЗапроса[2].Выгрузить());
	гкс_КонструктивныйСостав.Загрузить(РезультатЗапроса[3].Выгрузить());
	ДополнительныеРеквизиты.Загрузить(РезультатЗапроса[7].Выгрузить());
	
	Если Не дс_ФайлКартинки.Пустая() Тогда
		АдресКартинки = НавигационнаяСсылкаКартинки(дс_ФайлКартинки, УникальныйИдентификатор);
	Иначе
		АдресКартинки = "";
	Конецесли;
	Если ЗначениеЗаполнено(дс_Ссылка) Тогда 
		ЗначениеВДанныеФормы(дс_Ссылка.ПолучитьОбъект(),Объект);
	Иначе
		ТекОб = Справочники.торо_ТиповыеОР.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(ТекОб,Объект);
		ЗначениеВДанныеФормы(ТекОб,Объект);
	КонецЕсли;
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтаФорма, Объект, "НаборСвойствОР");
	// Конец СтандартныеПодсистемы.Свойства
	// Локализация
	//СтроковыеРеквизиты = "Наименование,Изготовитель,Комментарий,гкс_Модель";
	СтроковыеРеквизиты = "Наименование,Комментарий,гкс_Модель";
	торо_ЛокализацияСобытияФорм.ОбновитьПереводы(ЭтаФорма, СтроковыеРеквизиты);
	// Локализация
	ЗаполнитьТЧТехКарт(ТемпСсылка);

КонецПроцедуры

