&НаКлиенте
Процедура СоздатьМодель(Команда)
	
	Если дс_Редактирование = Истина Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Для создания, покиньте режим редактирования.';en='To create, leave edit mode.'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;

	ТекДанные = Элементы.Список.ТекущиеДанные;
	Если ТекДанные = Неопределено ИЛИ ЗначениеЗаполнено(ТекДанные.Родитель) = Ложь Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Модель можно создать только на 3-м уровне иерархии.'");
		Сообщение.Сообщить();
		Возврат;
	Иначе
		
		Если ТекДанные.ЭтоГруппа = Истина Тогда 
			дс_Родитель = ТекДанные.Ссылка;
		Иначе
			дс_Родитель = ТекДанные.Родитель;
		КонецЕсли;
		дс_ЕстьПодчиненные = Ложь;
		дс_Ссылка = Неопределено;
		дс_ДоСсылка = Неопределено;
		дс_Редактирование = Истина;
		Элементы.Редактировать.Пометка = дс_Редактирование;
		дс_РодительРодителя = ПолучитьРодителя(дс_Родитель);
		//
		дс_НеРеагировать = Истина;
		ПодключитьОбработчикОжидания("МожноРеагировать", 0.5, Истина);
		//
		дс_Код = Неопределено;
		дс_Наименование = "";
		Изготовитель = Неопределено;
		гкс_Модель = "";
		дс_НаборСвойствОР = Неопределено;
		дс_Направление = Неопределено;
		дс_ТипОбъекта = торо_ОбщегоНазначенияКлиентПовтИсп.ПолучитьПеречисление("торо_ТипыОбъектовRCM", "Объект");
		дс_Комментарий = "";
		дс_ЭтоГруппа = Ложь;
		дс_ФайлКартинки = Неопределено;
		//
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ТиповойОР", Неопределено);
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ОтборВключен", Ложь);
		ПодчиненныеТК.Параметры.УстановитьЗначениеПараметра("Ссылка", Неопределено);
		//
		дс_ЗамещаемыеРемонты.Очистить();
		дс_ПредшествующиеРемонты.Очистить();
		дс_НормативныеРемонты.Очистить();
		гкс_КонструктивныйСостав.Очистить();
		дс_СписокИзмеряемыхПоказателей.Очистить();
		ПараметрыОповещенияПоСостояниямОР.Очистить();
		СписокПараметровНаработки.Очистить();
		СтатусыНормативныхРемонтовДоИзменений.Очистить();
		ТабМаксимальныхЗначенийНаработки.Очистить();
		АдресКартинки = "";
		//
		ОчиститьЛокализацию();
		ОчиститьОбъект(3);
		//
		дс_СписокИзмеряемыхПоказателей.Очистить();
		ОбновитьИзмеряемыеПоказатели(дс_Родитель,дс_РодительРодителя, дс_СписокИзмеряемыхПоказателей);
		Для каждого Строка из дс_СписокИзмеряемыхПоказателей Цикл
			Если Строка.ОбъектРемонта = дс_Родитель Тогда
				Строка.ОбъектРемонта = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
		МассивСтруктурПараметровОповещения = ПолучитьПараметрыОповещенияПоКонтролируемымПоказателям(дс_Родитель,
			дс_РодительРодителя);
		ПараметрыОповещенияПоСостояниямОР.Очистить();
		Для Каждого ЭлементМассива Из МассивСтруктурПараметровОповещения Цикл
			НоваяСтрока = ПараметрыОповещенияПоСостояниямОР.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
			Если НоваяСтрока.ТиповойОР = дс_Родитель Тогда
				НоваяСтрока.ТиповойОР = Неопределено;
			КонецЕсли;
		КонецЦикла;

		СтруктураВозврата = ПолучитьТаблицуПараметровНаработки(дс_Родитель, дс_РодительРодителя);
		СписокПараметровНаработки.Очистить();
		Для каждого Элем Из СтруктураВозврата Цикл
			НоваяСтрока = СписокПараметровНаработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Элем);
			Если НоваяСтрока.ОбъектРемонта = дс_Родитель Тогда
				НоваяСтрока.ОбъектРемонта = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
		СтруктураВозврата = ОбновитьМаксимальныеЗначенияПоказателейНаработки(дс_Родитель);
		ТабМаксимальныхЗначенийНаработки.Очистить();
		Для каждого Элем Из СтруктураВозврата Цикл
			НоваяСтрока = ТабМаксимальныхЗначенийНаработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Элем);
			Если НоваяСтрока.ОбъектРемонта = дс_Родитель Тогда
				НоваяСтрока.ОбъектРемонта = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
		ПолучитьТаблицыНормативов(дс_Родитель);
		
		Массив = Новый Массив;
		Массив.Добавить("дс_СписокИзмеряемыхПоказателей");
		Массив.Добавить("ПараметрыОповещенияПоСостояниямОР");
		Массив.Добавить("СписокПараметровНаработки");
		Массив.Добавить("ТабМаксимальныхЗначенийНаработки");
		Массив.Добавить("дс_НормативныеРемонты");
		Массив.Добавить("дс_ПредшествующиеРемонты");
		Массив.Добавить("дс_ЗамещаемыеРемонты");
		торо_СобытияФормКлиент.ЗаполнитьСтруктуруДанныхДоРедактирования(СтруктураДанныхДоРедактирования,Массив);
		
		ОбновитьДоступностьРеквизитов();
		ОбновитьВидимостьРеквизитов();
		
		дс_Ссылка = Неопределено;
		
		МодифицированностьИзмеряемыхПоказателей = Истина;
		дс_Модифицированность = Истина;
		МодифицированностьПараметровОповещенияОСостоянииОР = Истина;
		МодифицированностьПредшествующихРемонтов = Истина;
		МодифицированностьЗамещаемыхРемонтов = Истина;
		МодифицированностьНормРемонтов = Истина;
		МодифицированностьМаксЗначНаработки = Истина;
		МодифицированностьПараметровНаработки = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьТОР(Команда)
	
	Если дс_Редактирование = Истина Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Для копирования, покиньте режим редактирования.'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	ТекДанные = Элементы.Список.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		// гкс+ [Релиз 1] Куст 20.01.2021
		Если ТекДанные.ЭтоГруппа И РольДоступнаНаСервере("гкс_ЗапретРедактированиеКлассовТиповыхОР") Тогда 
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru='Недостаточно прав';en='Not enough rights';es='No hay suficientes derechos'");
			Сообщение.Сообщить();
			Возврат;
		КонецЕсли;
		// гкс- [Релиз 1] Куст 20.01.2021
		дс_НеРеагировать = Истина;
		ПодключитьОбработчикОжидания("МожноРеагировать", 0.5, Истина);
		
		дс_Редактирование = Истина;
		Элементы.Редактировать.Пометка = дс_Редактирование;
		
		дс_Ссылка = ТекДанные.Ссылка;
		дс_Родитель = ТекДанные.Родитель;
		дс_Код = ТекДанные.Код;
		дс_Наименование = ТекДанные.Наименование;
		Изготовитель = ТекДанные.Изготовитель;
		гкс_Модель = ТекДанные.гкс_Модель;
		дс_НаборСвойствОР = ТекДанные.НаборСвойствОР;
		дс_Направление = ТекДанные.Направление;
		дс_ТипОбъекта = ТекДанные.ТипОбъекта;
		дс_Комментарий = ТекДанные.Комментарий;
		дс_ЭтоГруппа = ТекДанные.ЭтоГруппа;
		дс_ФайлКартинки = ТекДанные.ФайлКартинки;
		
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ТиповойОР",Неопределено);
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ОтборВключен",Ложь);
		дс_СписокИзмеряемыхПоказателей.Очистить();
		ОбновитьИзмеряемыеПоказатели(дс_Ссылка,дс_Родитель, дс_СписокИзмеряемыхПоказателей);
		Для каждого Строка из дс_СписокИзмеряемыхПоказателей Цикл
			Если Строка.ОбъектРемонта = дс_Ссылка Тогда
				Строка.ОбъектРемонта = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
		МассивСтруктурПараметровОповещения = ПолучитьПараметрыОповещенияПоКонтролируемымПоказателям(дс_Ссылка, дс_Родитель);
		ПараметрыОповещенияПоСостояниямОР.Очистить();
		Для Каждого ЭлементМассива Из МассивСтруктурПараметровОповещения Цикл
			НоваяСтрока = ПараметрыОповещенияПоСостояниямОР.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
			Если НоваяСтрока.ТиповойОР = дс_Ссылка Тогда
				НоваяСтрока.ТиповойОР = Неопределено;
			КонецЕсли;
		КонецЦикла;

		СтруктураВозврата = ПолучитьТаблицуПараметровНаработки(дс_Ссылка, дс_Родитель);
		СписокПараметровНаработки.Очистить();
		Для каждого Элем Из СтруктураВозврата Цикл
			НоваяСтрока = СписокПараметровНаработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Элем);
			Если НоваяСтрока.ОбъектРемонта = дс_Ссылка Тогда
				НоваяСтрока.ОбъектРемонта = Неопределено;
			КонецЕсли;
		КонецЦикла;
	
			СтруктураВозврата = ОбновитьМаксимальныеЗначенияПоказателейНаработки(дс_Ссылка);
			ТабМаксимальныхЗначенийНаработки.Очистить();
			Для каждого Элем Из СтруктураВозврата Цикл
				НоваяСтрока = ТабМаксимальныхЗначенийНаработки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Элем);
				Если НоваяСтрока.ОбъектРемонта = дс_Ссылка Тогда
					НоваяСтрока.ОбъектРемонта = Неопределено;
				КонецЕсли;
			КонецЦикла;
		
		ТемпСсылка = дс_Ссылка;
		дс_Ссылка = Неопределено;
		ПолучитьТаблицыНормативов(ТемпСсылка);
		дс_Ссылка = ТемпСсылка;

		Массив = Новый Массив;
		Массив.Добавить("дс_СписокИзмеряемыхПоказателей");
		Массив.Добавить("ПараметрыОповещенияПоСостояниямОР");
		Массив.Добавить("СписокПараметровНаработки");
		Массив.Добавить("ТабМаксимальныхЗначенийНаработки");
		Массив.Добавить("дс_НормативныеРемонты");
		Массив.Добавить("дс_ПредшествующиеРемонты");
		Массив.Добавить("дс_ЗамещаемыеРемонты");
		торо_СобытияФормКлиент.ЗаполнитьСтруктуруДанныхДоРедактирования(СтруктураДанныхДоРедактирования, Массив);
		
		ОбновитьДоступностьРеквизитов();
		ОбновитьВидимостьРеквизитов();
		
		дс_Ссылка = Неопределено;
		
		МодифицированностьИзмеряемыхПоказателей = Истина;
		дс_Модифицированность = Истина;
		МодифицированностьПараметровОповещенияОСостоянииОР = Истина;
		МодифицированностьПредшествующихРемонтов = Истина;
		МодифицированностьЗамещаемыхРемонтов = Истина;
		МодифицированностьНормРемонтов = Истина;
		МодифицированностьМаксЗначНаработки = Истина;
		МодифицированностьПараметровНаработки = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоздатьКласс(Команда)
	
	Если дс_Редактирование = Истина Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Для создания, покиньте режим редактирования.';en='To create, leave edit mode.'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	дс_НеРеагировать = Истина;
	ПодключитьОбработчикОжидания("МожноРеагировать", 0.5, Истина);
	
	дс_ЕстьПодчиненные = Ложь;
	дс_Родитель = Неопределено;
	дс_Ссылка = Неопределено;
	дс_ДоСсылка = Неопределено;
	дс_Редактирование = Истина;
	Элементы.Редактировать.Пометка = дс_Редактирование;
	дс_Код = Неопределено;
	дс_Наименование = "";
	Изготовитель = Неопределено;
	гкс_Модель = "";
	дс_НаборСвойствОР = Неопределено;
	дс_Направление = Неопределено;
	дс_ТипОбъекта = торо_ОбщегоНазначенияКлиентПовтИсп.ПолучитьПеречисление("торо_ТипыОбъектовRCM", "Объект");
	дс_Комментарий = "";
	дс_ЭтоГруппа = Истина;
	дс_ФайлКартинки = Неопределено;
	дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ТиповойОР", Неопределено);
	дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ОтборВключен", Ложь);
	ПодчиненныеТК.Параметры.УстановитьЗначениеПараметра("Ссылка", Неопределено);
	дс_ЗамещаемыеРемонты.Очистить();
	дс_ПредшествующиеРемонты.Очистить();
	дс_НормативныеРемонты.Очистить();
	гкс_КонструктивныйСостав.Очистить();
	дс_СписокИзмеряемыхПоказателей.Очистить();
	ПараметрыОповещенияПоСостояниямОР.Очистить();
	СписокПараметровНаработки.Очистить();
	СтатусыНормативныхРемонтовДоИзменений.Очистить();
	ТабМаксимальныхЗначенийНаработки.Очистить();
	ДополнительныеРеквизиты.Очистить();
	АдресКартинки = "";
	
	ОчиститьЛокализацию();
	ОчиститьОбъект(1);
	
	Массив = Новый Массив;
	Массив.Добавить("дс_СписокИзмеряемыхПоказателей");
	Массив.Добавить("ПараметрыОповещенияПоСостояниямОР");
	Массив.Добавить("СписокПараметровНаработки");
	Массив.Добавить("ТабМаксимальныхЗначенийНаработки");
	Массив.Добавить("дс_НормативныеРемонты");
	Массив.Добавить("дс_ПредшествующиеРемонты");
	Массив.Добавить("дс_ЗамещаемыеРемонты");
	торо_СобытияФормКлиент.ЗаполнитьСтруктуруДанныхДоРедактирования(СтруктураДанныхДоРедактирования, Массив);
	
	ОбновитьДоступностьРеквизитов();
	ОбновитьВидимостьРеквизитов();
	
	МодифицированностьИзмеряемыхПоказателей = Истина;
	дс_Модифицированность = Истина;
	МодифицированностьПараметровОповещенияОСостоянииОР = Истина;
	МодифицированностьПредшествующихРемонтов = Истина;
	МодифицированностьЗамещаемыхРемонтов = Истина;
	МодифицированностьНормРемонтов = Истина;
	МодифицированностьМаксЗначНаработки = Истина;
	МодифицированностьПараметровНаработки = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьЛокализацию()
	// Локализация
	//СтроковыеРеквизиты = "Наименование,Изготовитель,Комментарий,гкс_Модель";
	СтроковыеРеквизиты = "Наименование,Комментарий,гкс_Модель";
		
	торо_ЛокализацияСобытияФорм.ОчиститьПереводы(ЭтаФорма, СтроковыеРеквизиты);
	// Локализация
КонецПроцедуры

&НаСервере
Процедура ОчиститьОбъект(ТекУровень)
	Если ТекУровень = 3 Тогда 
		ТекОб = Справочники.торо_ТиповыеОР.СоздатьЭлемент();
	Иначе
		ТекОб = Справочники.торо_ТиповыеОР.СоздатьГруппу();
	КонецЕсли;
	ЗначениеВДанныеФормы(ТекОб,Объект);
	Объект.ДополнительныеРеквизиты.Очистить();
	УправлениеСвойствами.ЗаполнитьДополнительныеРеквизитыВФорме(ЭтаФорма, Неопределено, , Неопределено, "НаборСвойствОР");
КонецПроцедуры

&НаКлиенте
Процедура СоздатьПодКласс(Команда)
	
	Если дс_Редактирование = Истина Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Для создания, покиньте режим редактирования.';en='To create, leave edit mode.'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	ТекДанные = Элементы.Список.ТекущиеДанные;
	Если ТекДанные = Неопределено Или ТекДанные.ЭтоГруппа = Ложь Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Подкласс можно создать только на 2-м уровне иерархии.'");
		Сообщение.Сообщить();
		Возврат;
	Иначе
		Если ЗначениеЗаполнено(ТекДанные.Родитель) Тогда 
		    дс_Родитель = ТекДанные.Родитель;
		Иначе
			дс_Родитель = ТекДанные.Ссылка;
		КонецЕсли;
		дс_ЕстьПодчиненные = Ложь;
		дс_Ссылка = Неопределено;
		дс_ДоСсылка = Неопределено;
		дс_Редактирование = Истина;
		Элементы.Редактировать.Пометка = дс_Редактирование;
		дс_РодительРодителя = ПолучитьРодителя(дс_Родитель);
		
		дс_НеРеагировать = Истина;
		ПодключитьОбработчикОжидания("МожноРеагировать", 0.5, Истина);
		
		дс_Код = Неопределено;
		дс_Наименование = "";
		Изготовитель = Неопределено;
		гкс_Модель = "";
		дс_НаборСвойствОР = Неопределено;
		дс_Направление = Неопределено;
		дс_ТипОбъекта = торо_ОбщегоНазначенияКлиентПовтИсп.ПолучитьПеречисление("торо_ТипыОбъектовRCM", "Объект");
		дс_Комментарий = "";
		дс_ЭтоГруппа = Истина;
		дс_ФайлКартинки = Неопределено;
		ШаблоныТК.Очистить();
		ШаблоныТО.Очистить();
		
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ТиповойОР", Неопределено);
		дс_СписокОР.Параметры.УстановитьЗначениеПараметра("ОтборВключен", Ложь);
		ПодчиненныеТК.Параметры.УстановитьЗначениеПараметра("Ссылка", Неопределено);
		
		дс_ЗамещаемыеРемонты.Очистить();
		дс_ПредшествующиеРемонты.Очистить();
		дс_НормативныеРемонты.Очистить();
		гкс_КонструктивныйСостав.Очистить();
		дс_СписокИзмеряемыхПоказателей.Очистить();
		ПараметрыОповещенияПоСостояниямОР.Очистить();
		СписокПараметровНаработки.Очистить();
		СтатусыНормативныхРемонтовДоИзменений.Очистить();
		ТабМаксимальныхЗначенийНаработки.Очистить();
		АдресКартинки = "";
		
		ОчиститьЛокализацию();
		ОчиститьОбъект(2);
		
		дс_СписокИзмеряемыхПоказателей.Очистить();
		ОбновитьИзмеряемыеПоказатели(дс_Родитель,дс_РодительРодителя, дс_СписокИзмеряемыхПоказателей);
		Для каждого Строка из дс_СписокИзмеряемыхПоказателей Цикл
			Если Строка.ОбъектРемонта = дс_Родитель Тогда
				Строка.ОбъектРемонта = дс_Ссылка;
			КонецЕсли;
		КонецЦикла;
		
		МассивСтруктурПараметровОповещения = ПолучитьПараметрыОповещенияПоКонтролируемымПоказателям(дс_Родитель, дс_РодительРодителя);
		ПараметрыОповещенияПоСостояниямОР.Очистить();
		Для Каждого ЭлементМассива Из МассивСтруктурПараметровОповещения Цикл
			НоваяСтрока = ПараметрыОповещенияПоСостояниямОР.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
			Если НоваяСтрока.ТиповойОР = дс_Родитель Тогда
				НоваяСтрока.ТиповойОР = дс_Ссылка;
			КонецЕсли;
		КонецЦикла;

		СтруктураВозврата = ПолучитьТаблицуПараметровНаработки(дс_Родитель, дс_РодительРодителя);
		СписокПараметровНаработки.Очистить();
		Для каждого Элем Из СтруктураВозврата Цикл
			НоваяСтрока = СписокПараметровНаработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Элем);
			Если НоваяСтрока.ОбъектРемонта = дс_Родитель Тогда
				НоваяСтрока.ОбъектРемонта = дс_Ссылка;
			КонецЕсли;
		КонецЦикла;
		
		СтруктураВозврата = ОбновитьМаксимальныеЗначенияПоказателейНаработки(дс_Родитель);
		ТабМаксимальныхЗначенийНаработки.Очистить();
		Для каждого Элем Из СтруктураВозврата Цикл
			НоваяСтрока = ТабМаксимальныхЗначенийНаработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Элем);
			Если НоваяСтрока.ОбъектРемонта = дс_Родитель Тогда
				НоваяСтрока.ОбъектРемонта = дс_Ссылка;
			КонецЕсли;
		КонецЦикла;
		//
		Массив = Новый Массив;
		Массив.Добавить("дс_СписокИзмеряемыхПоказателей");
		Массив.Добавить("ПараметрыОповещенияПоСостояниямОР");
		Массив.Добавить("СписокПараметровНаработки");
		Массив.Добавить("ТабМаксимальныхЗначенийНаработки");
		Массив.Добавить("дс_НормативныеРемонты");
		Массив.Добавить("дс_ПредшествующиеРемонты");
		Массив.Добавить("дс_ЗамещаемыеРемонты");
		торо_СобытияФормКлиент.ЗаполнитьСтруктуруДанныхДоРедактирования(СтруктураДанныхДоРедактирования, Массив);
		
		ОбновитьДоступностьРеквизитов();
		ОбновитьВидимостьРеквизитов();
		
		дс_Ссылка = Неопределено;
		
		МодифицированностьИзмеряемыхПоказателей = Истина;
		дс_Модифицированность = Истина;
		МодифицированностьПараметровОповещенияОСостоянииОР = Истина;
		МодифицированностьПредшествующихРемонтов = Истина;
		МодифицированностьЗамещаемыхРемонтов = Истина;
		МодифицированностьНормРемонтов = Истина;
		МодифицированностьМаксЗначНаработки = Истина;
		МодифицированностьПараметровНаработки = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СписокПараметровНаработкиПриИзменении(Элемент)
	ТекДанные = Элементы.СписокПараметровНаработки.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекДанные.Изменен = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура дс_СписокИзмеряемыхПоказателейПриИзменении(Элемент)
	ТекДанные = Элементы.дс_СписокИзмеряемыхПоказателей.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекДанные.Изменен = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыОповещенияПоСостояниямОРПриИзменении(Элемент)
	ТекДанные = Элементы.СписокПараметровНаработки.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекДанные.Изменен = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	// СтандартныеПодсистемы.Свойства
	Если ИмяСобытия = "ИзмененИТК" Тогда 
		
		Элементы.дс_ТК_Операции.Обновить();
		Элементы.дс_ТК_МатЗатраты.Обновить();
		Элементы.дс_ТК_Трудозатраты.Обновить();
		Элементы.дс_ТК_Инструменты.Обновить();
		
		Элементы.дс_ТК_Операции1.Обновить();
		Элементы.дс_ТК_МатЗатраты1.Обновить();
		Элементы.дс_ТК_Трудозатраты1.Обновить();
		Элементы.дс_ТК_Инструменты1.Обновить();
		
		Возврат;
	КонецЕсли;
	дс_НеРеагировать = Истина;
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтаФорма);
		торо_УправлениеСвойствамиКлиентСервер.НастроитьКнопкиКоманднойПанелиТаблицыДопРеквизитов(ЭтаФорма, Истина);
		дс_Модифицированность = Истина;
	КонецЕсли;
	ПодключитьОбработчикОжидания("МожноРеагировать", 0.5, Истина);
	// Конец СтандартныеПодсистемы.Свойства
КонецПроцедуры

&НаКлиенте
Процедура СохранитьПередЗакрытиемПослеВопроса(Результат, ДопПараметры)Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда 
		СохранитьИзмененияПослеВопроса(КодВозвратаДиалога.Да, ДопПараметры);
	Иначе
		дс_МожноЗакрывать = Истина;
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПроверитьНаличиеПодчиненных(ТекСсылка)
	дс_ЕстьПодчиненные = Ложь;
	Если ЗначениеЗаполнено(ТекСсылка) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ТиповыеОР.Наименование КАК Наименование
		|ИЗ
		|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
		|ГДЕ
		|	торо_ТиповыеОР.Родитель = &Родитель";
	
	Запрос.УстановитьПараметр("Родитель", ТекСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	дс_ЕстьПодчиненные = НЕ РезультатЗапроса.Пустой();
КонецПроцедуры

