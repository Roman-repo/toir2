&НаКлиенте
Процедура ШаблоныТКСтатусПриИзменении(Элемент)
	МодифицированностьТЧТехКарт = Истина;
	ТекДанные = Элементы.ШаблоныТК.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекДанные.Изменен = Истина;
		Если ЗначениеЗаполнено(ТекДанные.ТК) = Ложь
			И ЗначениеЗаполнено(ТекДанные.ИД) = Ложь Тогда 
			ТекДанные.ИД = Строка(Новый УникальныйИдентификатор());
			ТекДанные.Изменен = Истина;
		КонецЕсли;
		Если ТекДанные.Статус = _СтатусДействует 
			И ЗначениеЗаполнено(ТекДанные.ДатаПринятия) = Ложь Тогда 
			ТекДанные.Статус = _СтатусВРаботе;
			Возврат;
		КонецЕсли;
		ДоступностьПолей = ТекДанные.Статус = _СтатусВРаботе;
		Если Элементы.ШаблоныТК.ИзменятьПорядокСтрок = Истина Тогда 
			Элементы.ШаблоныТО.ИзменятьСоставСтрок = ДоступностьПолей;
			Элементы.ШаблоныТО.ИзменятьПорядокСтрок = ДоступностьПолей;
			//
			Элементы.ШаблоныТООперация.ТолькоПросмотр = Не ДоступностьПолей;
			Элементы.ШаблоныТОКоличество.ТолькоПросмотр = Не ДоступностьПолей;
			Элементы.ШаблоныТОСпособВыполнения.ТолькоПросмотр = Не ДоступностьПолей;
			Элементы.ШаблоныТОтк_СдвинутьТОВниз.Доступность = ДоступностьПолей;
			Элементы.ШаблоныТОтк_СдвинутьТОВверх.Доступность = ДоступностьПолей;
			Элементы.ШаблоныТОтк_ДобавитьТО.Доступность = ДоступностьПолей;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ШаблоныТКПередУдалением(Элемент, Отказ)
	ТекДанные = Элементы.ШаблоныТК.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		МодифицированностьТЧТехКарт = Истина;
		Если ЗначениеЗаполнено(ТекДанные.ТК) Тогда 
			Отказ = Истина;
			ТекДанные.ПометкаУдаления = НЕ ТекДанные.ПометкаУдаления;
			ТекДанные.Изменен = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ШаблоныТКПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	Если Не ОтменаРедактирования Тогда 
		ТекДанныеТК = Элементы.ШаблоныТК.ТекущиеДанные;
		Если Не ТекДанныеТК = Неопределено Тогда 
			Если ЗначениеЗаполнено(ТекДанныеТК.ТК) = Ложь
				И ЗначениеЗаполнено(ТекДанныеТК.ИД) = Ложь Тогда 
				ТекДанныеТК.ИД = Строка(Новый УникальныйИдентификатор());
				ТекДанныеТК.Изменен = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура СохранитьИзмененияТЧТехКартНаСервере()
	Для Каждого СтрокаТаблицы Из ШаблоныТК Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицы.Статус) = Ложь Тогда 
			СтрокаТаблицы.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке;
		КонецЕсли;
	КонецЦикла;
	МассивУдаления = Новый Массив();
	Для Каждого СтрокаТаблицы Из ШаблоныТО Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицы.Операция) = Ложь Тогда 
			МассивУдаления.Добавить(СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаМассива Из МассивУдаления Цикл
		ШаблоныТО.Удалить(ШаблоныТО.Индекс(СтрокаМассива));
	КонецЦикла;
	//
	Запрос = Новый Запрос;
	Запрос.Текст =  
		"ВЫБРАТЬ
		|	торо_ИдентификаторыТехКарт.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ИдентификаторыТехКарт КАК торо_ИдентификаторыТехКарт
		|ГДЕ
		|	торо_ИдентификаторыТехКарт.гкс_Владелец = &Ссылка";
	 	Запрос.УстановитьПараметр("Ссылка", дс_Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ГруппаРодительИТК = Выборка.Ссылка;
	КонецЕсли;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.ТК КАК ТК,
		|	ТЧ.Статус КАК Статус,
		|	ТЧ.Обслуживание КАК Обслуживание,
		|	ТЧ.ДатаПринятия КАК ДатаПринятия,
		// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
		|	ТЧ.гкс_ПериодДействия КАК гкс_ПериодДействия,
		|	ТЧ.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия,
		// } Гкс-[TOIR20-194] 
		|	ТЧ.ПометкаУдаления КАК ПометкаУдаления,
		|	ТЧ.ИД КАК ИД
		|ПОМЕСТИТЬ ИсходныеТК
		|ИЗ
		|	&ТЧ КАК ТЧ
		|ГДЕ
		|	НЕ(ТЧ.ПометкаУдаления = ИСТИНА
		|				И ТЧ.ТК = ЗНАЧЕНИЕ(Справочник.торо_ИдентификаторыТехКарт.ПустаяСсылка))
		|	И ТЧ.Изменен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧ.ТК КАК ТК,
		|	ВЫРАЗИТЬ(ТЧ.Операция КАК Справочник.торо_ТехнологическиеОперации) КАК Операция,
		|	ТЧ.Количество КАК Количество,
		|	ТЧ.СпособВыполнения КАК СпособВыполнения,
		|	ТЧ.гкс_Примечание КАК гкс_Примечание,
		|	ТЧ.ИД КАК ИД
		|ПОМЕСТИТЬ ИсходныеТО
		|ИЗ
		|	&ТЧ1 КАК ТЧ
		|ГДЕ
		|	НЕ ТЧ.Операция = ЗНАЧЕНИЕ(Справочник.торо_ТехнологическиеОперации.ПустаяСсылка)
		|	И НЕ (ТЧ.ИД = """" И ТЧ.ТК = ЗНАЧЕНИЕ(Справочник.торо_ИдентификаторыТехКарт.ПустаяСсылка))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходныеТК.Статус КАК Статус,
		|	ИсходныеТК.Обслуживание КАК Обслуживание,
		|	ИсходныеТК.ДатаПринятия КАК ДатаПринятия,
		// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
		|	ИсходныеТК.гкс_ПериодДействия КАК гкс_ПериодДействия,
		|	ИсходныеТК.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия,
		// } Гкс-[TOIR20-194] 
		|	ИсходныеТК.ПометкаУдаления КАК ПометкаУдаления,
		|	ИсходныеТК.ИД КАК ИД
		|ПОМЕСТИТЬ НовыеИТК
		|ИЗ
		|	ИсходныеТК КАК ИсходныеТК
		|ГДЕ
		|	ИсходныеТК.ТК = ЗНАЧЕНИЕ(Справочник.торо_ИдентификаторыТехКарт.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НовыеИТК.Статус КАК Статус,
		|	НовыеИТК.Обслуживание КАК Обслуживание,
		|	НовыеИТК.ДатаПринятия КАК ДатаПринятия,
		// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
		|	НовыеИТК.гкс_ПериодДействия КАК гкс_ПериодДействия,
		|	НовыеИТК.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия,
		// } Гкс-[TOIR20-194] 
		|	НовыеИТК.ПометкаУдаления КАК ПометкаУдаления,
		|	НовыеИТК.ИД КАК ИД
		|ИЗ
		|	НовыеИТК КАК НовыеИТК
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходныеТО.Операция КАК Операция,
		|	ИсходныеТО.Количество КАК Количество,
		|	ИсходныеТО.СпособВыполнения КАК СпособВыполнения,
		|	ИсходныеТО.ИД КАК ИД,
		|	ИсходныеТО.Операция.НормаВремени КАК НормаВремени,
		|	ИсходныеТО.гкс_Примечание КАК гкс_Примечание
		|ИЗ
		|	НовыеИТК КАК НовыеИТК
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсходныеТО КАК ИсходныеТО
		|		ПО НовыеИТК.ИД = ИсходныеТО.ИД
		|ИТОГИ ПО
		|	ИД
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходныеТК.Статус КАК Статус,
		|	ИсходныеТК.Обслуживание КАК Обслуживание,
		|	ИсходныеТК.ДатаПринятия КАК ДатаПринятия,
		// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
		|	ИсходныеТК.гкс_ПериодДействия КАК гкс_ПериодДействия,
		|	ИсходныеТК.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия,
		// } Гкс-[TOIR20-194] 
		|	ИсходныеТК.ПометкаУдаления КАК ПометкаУдаления,
		|	ИсходныеТК.ТК КАК ТК
		|ПОМЕСТИТЬ СтарыйИТК
		|ИЗ
		|	ИсходныеТК КАК ИсходныеТК
		|ГДЕ
		|	НЕ ИсходныеТК.ТК = ЗНАЧЕНИЕ(Справочник.торо_ИдентификаторыТехКарт.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СтарыйИТК.Статус КАК Статус,
		|	СтарыйИТК.Обслуживание КАК Обслуживание,
		|	СтарыйИТК.ДатаПринятия КАК ДатаПринятия,
		// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
		|	СтарыйИТК.гкс_ПериодДействия КАК гкс_ПериодДействия,
		|	СтарыйИТК.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия,
		// } Гкс-[TOIR20-194] 
		|	СтарыйИТК.ПометкаУдаления КАК ПометкаУдаления,
		|	СтарыйИТК.ТК КАК ТК,
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта КАК ТехКарта
		|ИЗ
		|	СтарыйИТК КАК СтарыйИТК
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт.СрезПоследних КАК торо_ВерсииТехКартСрезПоследних
		|		ПО СтарыйИТК.ТК = торо_ВерсииТехКартСрезПоследних.ИдентификаторТехКарты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходныеТО.Операция КАК Операция,
		|	ИсходныеТО.Количество КАК Количество,
		|	ИсходныеТО.СпособВыполнения КАК СпособВыполнения,
		|	ИсходныеТО.ТК КАК ТК,
		|	ИсходныеТО.гкс_Примечание КАК гкс_Примечание,
		|	ИсходныеТО.Операция.НормаВремени КАК НормаВремени
		|ИЗ
		|	СтарыйИТК КАК СтарыйИТК
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсходныеТО КАК ИсходныеТО
		|		ПО СтарыйИТК.ТК = ИсходныеТО.ТК
		|ИТОГИ ПО
		|	ТК";
	Запрос.УстановитьПараметр("ТЧ", ШаблоныТК.Выгрузить());
	Запрос.УстановитьПараметр("ТЧ1", ШаблоныТО.Выгрузить());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ИндексПакетаНовых = 3;
	ИндексПакетаСтарых = 6;
	Если РезультатЗапроса[ИндексПакетаНовых].Пустой() = Ложь Тогда 		
		ВыборкаТК = РезультатЗапроса[ИндексПакетаНовых].Выбрать();
		ВыборкаТО = РезультатЗапроса[ИндексПакетаНовых + 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаТК.Следующий() Цикл
			Попытка
				НачатьТранзакцию();
				ОбъектИТК = справочники.торо_ИдентификаторыТехКарт.СоздатьЭлемент();
				ОбъектИТК.Родитель = ГруппаРодительИТК;
				ОбъектИТК.Наименование = ВыборкаТК.Обслуживание + " " + ОбъектИТК.Родитель;
				ОбъектИТК.гкс_Обслуживание = ВыборкаТК.Обслуживание;
				ОбъектИТК.гкс_Ответственный = ПараметрыСеанса.ТекущийПользователь;
				ОбъектИТК.Статус = ВыборкаТК.Статус;
				//
				ОбъектТК = Справочники.торо_ТехКарты.СоздатьЭлемент();
				ОбъектТК.Наименование = ОбъектИТК.Наименование;
				ОбъектТК.ДатаПринятия = ВыборкаТК.ДатаПринятия;
				// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
				ОбъектТК.гкс_ПериодДействия = ВыборкаТК.гкс_ПериодДействия;
				ОбъектТК.гкс_КоличествоПериодовДействия = ВыборкаТК.гкс_КоличествоПериодовДействия;
					торо_ОбщегоНазначенияКлиентСервер.РассчитатьДатуОкончанияПериода(ВыборкаТК.ДатаПринятия, 
																					 ВыборкаТК.гкс_ПериодДействия, 
																					 ВыборкаТК.гкс_КоличествоПериодовДействия);
				// } Гкс-[TOIR20-194] 
				//
				СуммаВремениТК = 0;
				Если ВыборкаТО.НайтиСледующий(Новый Структура("ИД", ВыборкаТК.ИД)) Тогда 
					ВыборкаТОПодробно = ВыборкаТО.Выбрать();
					Пока ВыборкаТОПодробно.Следующий() Цикл
						НоваяСтрока = ОбъектТК.СписокОпераций.Добавить();
						НоваяСтрока.ID = Строка(Новый УникальныйИдентификатор());
						НоваяСтрока.Количество = ВыборкаТОПодробно.Количество;
						НоваяСтрока.Операция = ВыборкаТОПодробно.Операция;
						НоваяСтрока.СпособВыполнения = ВыборкаТОПодробно.СпособВыполнения;
						НоваяСтрока.НормаВремениВСекундах = ВыборкаТОПодробно.НормаВремени;
						НоваяСтрока.гкс_Примечание = ВыборкаТОПодробно.гкс_Примечание;
						СуммаВремениТК = СуммаВремениТК + ВыборкаТОПодробно.НормаВремени;
					КонецЦикла;
				КонецЕсли;
				ВыборкаТО.Сбросить();
				ОбъектТК.НормаВремени = СуммаВремениТК;
				ОбъектТК.СпособРасчетаПродолжительности = 
					Перечисления.торо_СпособыРасчетаПродолжительности.ПоНормамВремениТехОпераций;
				ОбъектТК.НормаВремениТекст = СформироватьПродолжительность(СуммаВремениТК);
				
				ОбъектИТК.Записать();
				ОбъектТК.Записать();
				//
				Для Каждого СтрокаТаблицы Из ШаблоныТК Цикл
					Если СтрокаТаблицы.ИД = ВыборкаТК.ИД Тогда 
						СтрокаТаблицы.ТК = ОбъектИТК.Ссылка;
						Для Каждого СтрокаТО Из ШаблоныТО Цикл
							Если СтрокаТО.ИД = СтрокаТаблицы.ИД Тогда 
								СтрокаТО.ТК = ОбъектИТК.Ссылка;
							КонецЕсли;
						КонецЦикла;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				НаборЗаписей = РегистрыСведений.торо_ВерсииТехКарт.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ИдентификаторТехКарты.Установить(ОбъектИТК.Ссылка);
				НаборЗаписей.Отбор.Период.Установить(ВыборкаТК.ДатаПринятия);
				НоваяСтрока = НаборЗаписей.Добавить();
				НоваяСтрока.ИдентификаторТехКарты = ОбъектИТК.Ссылка;
				НоваяСтрока.ТехКарта = ОбъектТК.Ссылка;
				НоваяСтрока.Период = ВыборкаТК.ДатаПринятия;
				НаборЗаписей.Записать();
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = ОписаниеОшибки();
				Сообщение.Сообщить();
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	
	Если РезультатЗапроса[ИндексПакетаСтарых].Пустой() = Ложь Тогда 
		ВыборкаТК = РезультатЗапроса[ИндексПакетаСтарых].Выбрать();
		ВыборкаТО = РезультатЗапроса[ИндексПакетаСтарых + 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаТК.Следующий() Цикл
			Попытка
				НачатьТранзакцию();
				ОбъектИТК = ВыборкаТК.ТК.ПолучитьОбъект();
				ОбъектИТК.Родитель = ГруппаРодительИТК;
				ОбъектИТК.Наименование = ВыборкаТК.Обслуживание + " " + ОбъектИТК.Родитель;
				ОбъектИТК.гкс_Обслуживание = ВыборкаТК.Обслуживание;
				ОбъектИТК.Статус = ВыборкаТК.Статус;
				
				ОбъектТК = ВыборкаТК.ТехКарта.ПолучитьОбъект();
				ОбъектТК.Наименование = ОбъектИТК.Наименование;
				ОбъектТК.ДатаПринятия = ВыборкаТК.ДатаПринятия;
				// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
				ОбъектТК.гкс_ПериодДействия = ВыборкаТК.гкс_ПериодДействия;
				ОбъектТК.гкс_КоличествоПериодовДействия = ВыборкаТК.гкс_КоличествоПериодовДействия;
				ОбъектТК.гкс_ДатаОкончанияАктуальности = 
					торо_ОбщегоНазначенияКлиентСервер.РассчитатьДатуОкончанияПериода(ВыборкаТК.ДатаПринятия, 
																					 ВыборкаТК.гкс_ПериодДействия,
																					 ВыборкаТК.гкс_КоличествоПериодовДействия);
				// } Гкс-[TOIR20-194] 
				
				СуммаВремениТК = 0;
				Если ВыборкаТО.НайтиСледующий(Новый Структура("ТК", ВыборкаТК.ТК)) Тогда 
					ПройденныеСтроки = Новый Массив();
					ВыборкаТОПодробно = ВыборкаТО.Выбрать();
					Пока ВыборкаТОПодробно.Следующий() Цикл
						СтрокаНеНайдена = Истина;
						Для Каждого СтрокаТаблицы Из ОбъектТК.СписокОпераций Цикл
							Если СтрокаТаблицы.Операция = ВыборкаТОПодробно.Операция Тогда 
								Если ПройденныеСтроки.Найти(СтрокаТаблицы.ID) = Неопределено Тогда 
									СтрокаТаблицы.Количество = ВыборкаТОПодробно.Количество;
									СтрокаТаблицы.Операция = ВыборкаТОПодробно.Операция;
									СтрокаТаблицы.СпособВыполнения = ВыборкаТОПодробно.СпособВыполнения;
									СтрокаТаблицы.гкс_Примечание = ВыборкаТОПодробно.гкс_Примечание;
									СуммаВремениТК = СуммаВремениТК + СтрокаТаблицы.НормаВремениВСекундах;
									ПройденныеСтроки.Добавить(СтрокаТаблицы.ID);
									СтрокаНеНайдена = Ложь;
									Прервать;
								КонецЕсли;
							КонецЕсли;
						КонецЦикла;
						Если СтрокаНеНайдена Тогда 
							НоваяСтрока = ОбъектТК.СписокОпераций.Добавить();
							НоваяСтрока.ID = Строка(Новый УникальныйИдентификатор());
							НоваяСтрока.Количество = ВыборкаТОПодробно.Количество;
							НоваяСтрока.Операция = ВыборкаТОПодробно.Операция;
							НоваяСтрока.СпособВыполнения = ВыборкаТОПодробно.СпособВыполнения;
							НоваяСтрока.НормаВремениВСекундах = ВыборкаТОПодробно.НормаВремени;
							НоваяСтрока.гкс_Примечание = ВыборкаТОПодробно.гкс_Примечание;
							СуммаВремениТК = СуммаВремениТК + ВыборкаТОПодробно.НормаВремени;
							ПройденныеСтроки.Добавить(НоваяСтрока.ID);
						КонецЕсли;
					КонецЦикла;
					СтрокиКУдалению = Новый Массив();
					Для Каждого СтрокаТаблицы Из ОбъектТК.СписокОпераций Цикл
						Если ПройденныеСтроки.Найти(СтрокаТаблицы.ID) = Неопределено Тогда 
							СтрокиКУдалению.Добавить(СтрокаТаблицы);
						КонецЕсли;
					КонецЦикла;
					Для Каждого СтрокаМассива Из СтрокиКУдалению Цикл
						ОбъектТК.СписокОпераций.Удалить(СтрокаМассива);
					КонецЦикла;
					
					НомерСтрокиНовый = 0;
					Для Каждого СтрокаМассива ИЗ ПройденныеСтроки Цикл
						НомерСтрокиСтарый = 0;
						Для Каждого ТехОперацияСтарая ИЗ ОбъектТК.СписокОпераций Цикл
							Если ТехОперацияСтарая.ID = СтрокаМассива Тогда 
								Прервать;
							КонецЕсли;
							НомерСтрокиСтарый = НомерСтрокиСтарый + 1;
						КонецЦикла;
						Если НЕ НомерСтрокиНовый = НомерСтрокиСтарый Тогда 
							ОбъектТК.СписокОпераций.Сдвинуть(НомерСтрокиСтарый, НомерСтрокиНовый - НомерСтрокиСтарый);
						КонецЕсли;
						НомерСтрокиНовый = НомерСтрокиНовый + 1;
					КонецЦикла;
				КонецЕсли;
				ВыборкаТО.Сбросить();
				Если ОбъектТК.СпособРасчетаПродолжительности = 
					Перечисления.торо_СпособыРасчетаПродолжительности.ПоНормамВремениТехОпераций Тогда 
					ОбъектТК.НормаВремениТекст = СформироватьПродолжительность(СуммаВремениТК);
					ОбъектТК.НормаВремени = СуммаВремениТК;
				КонецЕсли;
				
				ОбъектИТК.Записать();
				ОбъектТК.Записать();
				Если Не ОбъектИТК.ПометкаУдаления = ВыборкаТК.ПометкаУдаления Тогда 
					ОбъектИТК.УстановитьПометкуУдаления(ВыборкаТК.ПометкаУдаления);
				КонецЕсли;
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = ОписаниеОшибки();
				Сообщение.Сообщить();
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	ОбновитьПодчиненныеТК();
	
	МодифицированностьТЧТехКарт = Ложь;
	Для Каждого СтрокаТаблицы Из ШаблоныТК Цикл
		СтрокаТаблицы.Изменен = Ложь;
	КонецЦикла;
	
	ЗаполнитьТЧТехКарт(дс_Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИзмененияТЧТехКарт(Команда)
	НомерПП = 0;
	Для Каждого СТрокаТаблицы Из ШаблоныТК Цикл
		Если СТрокаТаблицы.Изменен Тогда 
			Если ЗначениеЗаполнено(СТрокаТаблицы.ДатаПринятия) = Ложь Тогда    
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = НСтр("ru='Укажите дату принятия';
				|en='Indicate the date of adoption';es='';");
				Сообщение.Поле = "ШаблоныТК[" + НомерПП + "].ДатаПринятия";
				Сообщение.Сообщить();
				Возврат;
			КонецЕсли;
			Если ЗначениеЗаполнено(СТрокаТаблицы.Обслуживание) = Ложь Тогда 
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = НСтр("ru='Укажите обслуживание';
				|en='Indicate service';es='';");
				Сообщение.Поле = "ШаблоныТК[" + НомерПП + "].Обслуживание";
				Сообщение.Сообщить();
				Возврат;
			КонецЕсли;
			// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
			Если ЗначениеЗаполнено(СТрокаТаблицы.ДатаПринятия) = Ложь Тогда    
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = НСтр("ru='Укажите период действия';
				|en='Specify the validity period';es='Especifique el período de validez';");
				Сообщение.Поле = "ШаблоныТК[" + НомерПП + "].гкс_ПериодДействия";
				Сообщение.Сообщить();
				Возврат;
			КонецЕсли; // } Гкс-[TOIR20-194] 
		КонецЕсли;
		НомерПП = НомерПП + 1;
	КонецЦикла;
	СохранитьИзмененияТЧТехКартНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОбновитьПодчиненныеТК()
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ТЧ.ТК КАК Справочник.торо_ИдентификаторыТехКарт) КАК ТК,
		|	ТЧ.Изменен КАК Изменен,
		|	ТЧ.Статус КАК Статус
		|ПОМЕСТИТЬ Исходные
		|ИЗ
		|	&ТЧ КАК ТЧ
		|ГДЕ
		|	ТЧ.Изменен = ИСТИНА 
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Исходные.ТК КАК ТК,
		|	Исходные.Статус КАК Статус,
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта КАК ТехКарта
		|ПОМЕСТИТЬ ИсходныеТК
		|ИЗ
		|	Исходные КАК Исходные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт.СрезПоследних КАК торо_ВерсииТехКартСрезПоследних
		|		ПО Исходные.ТК = торо_ВерсииТехКартСрезПоследних.ИдентификаторТехКарты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	гкс_ИерархияТехКарт.Подчиненный КАК Подчиненный,
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта КАК ТехКарта,
		|	Исходные.ТехКарта КАК Ссылка,
		|	Исходные.ТК.гкс_Обслуживание КАК гкс_Обслуживание,
		|	Исходные.ТК.гкс_Ответственный КАК гкс_Ответственный,
		|	Исходные.ТК.ПометкаУдаления КАК ПометкаУдаления
		|ИЗ
		|	ИсходныеТК КАК Исходные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.гкс_ИерархияТехКарт КАК гкс_ИерархияТехКарт
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт.СрезПоследних КАК торо_ВерсииТехКартСрезПоследних
		|			ПО гкс_ИерархияТехКарт.Подчиненный = торо_ВерсииТехКартСрезПоследних.ИдентификаторТехКарты
		|		ПО Исходные.ТК = гкс_ИерархияТехКарт.Родитель
		|			И (Исходные.Статус = ЗНАЧЕНИЕ(Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Действует))
		|ИТОГИ ПО
		|	Ссылка";
	
	Запрос.УстановитьПараметр("ТЧ", ШаблоныТК.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда
		ВыборкаТехКарт = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Событие = Константы.гкс_ПараметрыОповещенияОИзмененииТехКарты.Получить();
		МассивИменТаблиц = Новый Массив();
		МассивИменТаблиц.Добавить("СписокОпераций");
		МассивИменТаблиц.Добавить("МатериальныеЗатраты");
		МассивИменТаблиц.Добавить("ТрудовыеЗатраты");
		МассивИменТаблиц.Добавить("ИнструментыИТехника");
		МассивИменТаблиц.Добавить("ИзмеряемыеПоказатели");
		МассивИменТаблиц.Добавить("ОказываемыеУслуги");
		МассивИменТаблиц.Добавить("МерыБезопасности");
		Пока ВыборкаТехКарт.Следующий() Цикл
			// Гкс+[TOIR20-170] Селимов от 16.11.2020. Добавлено:{
			ОповещаемыеПользователи = Новый Соответствие; // } Гкс-[TOIR20-170] 
			ТехКартаРодитель = ВыборкаТехКарт.Ссылка.ПолучитьОбъект();
			Выборка = ВыборкаТехКарт.Выбрать();
			Пока Выборка.Следующий() Цикл
				НеНайденныеТО = Новый Массив();
				ПодчиненнаяТехКарта = Выборка.ТехКарта.ПолучитьОбъект();
				ПодчиненнаяТехКарта.гкс_ШаблонОригинал = Выборка.ТехКарта;
				Для Каждого ТехОперацияСтарая ИЗ ПодчиненнаяТехКарта.СписокОпераций Цикл
					НеНайденныеТО.Добавить(ТехОперацияСтарая.ID);
				КонецЦикла;
				Для Каждого ТехОперация ИЗ ТехКартаРодитель.СписокОпераций Цикл
					ЭтоНовая = Истина;
					Для Каждого ТехОперацияСтарая ИЗ ПодчиненнаяТехКарта.СписокОпераций Цикл
						Если ТехОперацияСтарая.ID = ТехОперация.ID Тогда 
							НеНайденныеТО.Удалить(НеНайденныеТО.Найти(ТехОперацияСтарая.ID));
							ЗаполнитьЗначенияСвойств(ТехОперацияСтарая, ТехОперация,, "Продолжительность,НормаВремениВСекундах");
							ЭтоНовая = Ложь;
							Прервать;
						КонецЕсли;
					КонецЦикла;
					Если ЭтоНовая Тогда 
						НоваяСтрока = ПодчиненнаяТехКарта.СписокОпераций.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТехОперация);
					КонецЕсли;
				КонецЦикла;
				
				Для Каждого СтрокаМассива Из НеНайденныеТО Цикл
					Для Каждого ИмяТаблицы Из МассивИменТаблиц Цикл
						НайденныеСтроки = ПодчиненнаяТехКарта[ИмяТаблицы].НайтиСтроки(Новый Структура("ID", СтрокаМассива));
						Для Каждого СтрокаТЧ Из НайденныеСтроки Цикл
							ПодчиненнаяТехКарта[ИмяТаблицы].Удалить(СтрокаТЧ);
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
				
				НомерСтрокиНовый = 0;
				Для Каждого ТехОперация ИЗ ТехКартаРодитель.СписокОпераций Цикл
					НомерСтрокиСтарый = 0;
					Для Каждого ТехОперацияСтарая ИЗ ПодчиненнаяТехКарта.СписокОпераций Цикл
						Если ТехОперацияСтарая.ID = ТехОперация.ID Тогда 
							Прервать;
						КонецЕсли;
						НомерСтрокиСтарый = НомерСтрокиСтарый + 1;
					КонецЦикла;
					Если НЕ НомерСтрокиНовый = НомерСтрокиСтарый Тогда 
						ПодчиненнаяТехКарта.СписокОпераций.Сдвинуть(НомерСтрокиСтарый, НомерСтрокиНовый - НомерСтрокиСтарый);
					КонецЕсли;
					НомерСтрокиНовый = НомерСтрокиНовый + 1;
				КонецЦикла;
				
				ЗаполнитьЗначенияСвойств(ПодчиненнаяТехКарта, ТехКартаРодитель,, 
					"Код,ПометкаУдаления,Ссылка,Владелец,НормаВремени,НормаВремениТекст,СпособРасчетаПродолжительности");
				ПодчиненнаяТехКарта.Записать();
				Если НЕ ПодчиненнаяТехКарта.ПометкаУдаления = Выборка.ПометкаУдаления Тогда 
					ПодчиненнаяТехКарта.УстановитьПометкуУдаления(Выборка.ПометкаУдаления);
				КонецЕсли;
				
				ОбъектИТК = Выборка.Подчиненный.ПолучитьОбъект();
				ОбъектИТК.Наименование = Строка(Выборка.гкс_Обслуживание) + " " + ОбъектИТК.Родитель;
				ОбъектИТК.гкс_Обслуживание = Выборка.гкс_Обслуживание;
				// Гкс+[TOIR20-170] Селимов от 16.11.2020. Изменено:{
				// НужноСменитьСтатус = Не ОбъектИТК.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке;
				// }На:{
				НужноСменитьСтатус = ОбъектИТК.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке;
				// } Гкс-[TOIR20-170]
				ОбъектИТК.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке;
				ОбъектИТК.Записать();
				Если НЕ ОбъектИТК.ПометкаУдаления = Выборка.ПометкаУдаления Тогда 
					ОбъектИТК.УстановитьПометкуУдаления(Выборка.ПометкаУдаления);
				КонецЕсли;
				// Гкс+[TOIR20-170] Селимов от 16.11.2020. Добавлено:{
				Если НужноСменитьСтатус И ЗначениеЗаполнено(ОбъектИТК.гкс_Ответственный)
					И ЗначениеЗаполнено(Событие) Тогда 
					Если ОповещаемыеПользователи.Получить(ОбъектИТК.гкс_Ответственный) = Неопределено Тогда
						ОповещаемыеПользователи.Вставить(ОбъектИТК.гкс_Ответственный, "- " + СокрЛП(ОбъектИТК.Наименование));
					Иначе
						ИзмененныеТехКарты = ОповещаемыеПользователи[ОбъектИТК.гкс_Ответственный];
						ОповещаемыеПользователи[ОбъектИТК.гкс_Ответственный] = ОповещаемыеПользователи[ОбъектИТК.гкс_Ответственный] 
																			 + Символы.ПС + "- " + СокрЛП(ОбъектИТК.Наименование);
					КонецЕсли; 
				КонецЕсли; // } Гкс-[TOIR20-170] 
			КонецЦикла;
			// Гкс+[TOIR20-170] Селимов от 16.11.2020. Удалено:{
			Если НужноСменитьСтатус И ЗначениеЗаполнено(ОбъектИТК.гкс_Ответственный)
				И ЗначениеЗаполнено(Событие) Тогда 
				СтруктураДанных = Новый Структура;
				СтруктураДанных.Вставить("Ссылка", ОбъектИТК.Ссылка); 				
				СтруктураДанных.Вставить("Ответственный", ОбъектИТК.гкс_Ответственный); 				
				СтруктураДанных.Вставить("ВидДокумента", ""); 				
				СтруктураДанных.Вставить("Наименование", ОбъектИТК.Наименование); 				
				СтруктураДанных.Вставить("ОповещаемыеПользователи", ОповещаемыеПользователи); 	
				СтруктураДанных.Вставить("АвторИзменений", Пользователи.ТекущийПользователь());
				торо_РаботаСУведомлениями.ЗаписатьУведомленияТК(СтруктураДанных, Событие);
			КонецЕсли; // } Гкс-[TOIR20-170] 
		КонецЦикла;
	КонецЕсли;

	Запрос.Текст = 
		"
		|ВЫБРАТЬ
		|	гкс_ИерархияТехКарт.Подчиненный КАК Подчиненный,
		|	гкс_ИерархияТехКарт.Подчиненный.Родитель КАК Родитель,
		|	Исходные.ТК КАК ТК
		|ПОМЕСТИТЬ Существующие
		|ИЗ
		|	Исходные КАК Исходные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.гкс_ИерархияТехКарт КАК гкс_ИерархияТехКарт
		|		ПО Исходные.ТК = гкс_ИерархияТехКарт.Родитель
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ИдентификаторыТехКарт.Ссылка КАК Ссылка,
		|	Исходные.ТехКарта КАК ТехКарта,
		|	Исходные.ТК КАК ТК
		|ПОМЕСТИТЬ ВсеПОдчиненныеРодители
		|ИЗ
		|	ИсходныеТК КАК Исходные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК торо_ИдентификаторыТехКарт
		|		ПО Исходные.ТК.Родитель = торо_ИдентификаторыТехКарт.Родитель
		|ГДЕ
		|	торо_ИдентификаторыТехКарт.ЭтоГруппа = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВсеПОдчиненныеРодители.Ссылка КАК Ссылка,
		|	ВсеПОдчиненныеРодители.ТК.гкс_Обслуживание КАК гкс_Обслуживание,
		|	ВсеПОдчиненныеРодители.ТК.гкс_Ответственный КАК гкс_Ответственный,
		|	ВсеПОдчиненныеРодители.ТехКарта КАК ТехКарта,
		|	ВсеПОдчиненныеРодители.ТК КАК ТК
		|ИЗ
		|	ВсеПОдчиненныеРодители КАК ВсеПОдчиненныеРодители
		|		ЛЕВОЕ СОЕДИНЕНИЕ Существующие КАК Существующие
		|		ПО ВсеПОдчиненныеРодители.Ссылка = Существующие.Родитель
		|			И ВсеПОдчиненныеРодители.ТК = Существующие.ТК
		|ГДЕ
		|	Существующие.Подчиненный ЕСТЬ NULL
		|	И ВсеПОдчиненныеРодители.ТК.ПометкаУдаления = Ложь
		|	И ВсеПОдчиненныеРодители.ТК.Статус = Значение(Перечисление.торо_СтатусыНормативныхРемонтовИТехКарт.Действует)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			НовыйОбъект = Выборка.ТехКарта.Скопировать();
			НовыйОбъект.гкс_ШаблонОригинал = Выборка.ТехКарта;
			НовыйОбъект.Записать();
			
			НовыйИТК = Справочники.торо_ИдентификаторыТехКарт.СоздатьЭлемент();
			НовыйИТК.Наименование = Строка(Выборка.гкс_Обслуживание) + " " + Выборка.Ссылка;
			НовыйИТК.гкс_Обслуживание = Выборка.гкс_Обслуживание;
			НовыйИТК.Родитель = Выборка.Ссылка;
			НовыйИТК.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке;
			НовыйИТК.гкс_Ответственный = Выборка.гкс_Ответственный;
			НовыйИТК.Записать();
			
			НаборЗаписей = РегистрыСведений.торо_ВерсииТехКарт.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.ИдентификаторТехКарты.Установить(НовыйИТК.Ссылка);
			НаборЗаписей.Отбор.Период.Установить(НовыйОбъект.ДатаПринятия);
			НоваяСтрока = НаборЗаписей.Добавить();
			НоваяСтрока.ИдентификаторТехКарты = НовыйИТК.Ссылка;
			НоваяСтрока.ТехКарта = НовыйОбъект.Ссылка;
			НоваяСтрока.Период = НовыйОбъект.ДатаПринятия;
			НаборЗаписей.Записать();
			
			НаборЗаписей = РегистрыСведений.гкс_ИерархияТехКарт.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Подчиненный.Установить(НовыйИТК.Ссылка);
			НоваяСтрока = НаборЗаписей.Добавить();
			НоваяСтрока.Подчиненный = НовыйИТК.Ссылка;
			НоваяСтрока.Родитель = Выборка.ТК;
			НаборЗаписей.Записать();
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция СформироватьПродолжительность(ПродолжительностьВСекундах)
	
	Если ПродолжительностьВСекундах = 0 Тогда
		
		Возврат "Ввести продолжительность";
		
	Иначе
		
		Часы    = Цел(ПродолжительностьВСекундах / 3600);
		Минуты  = Цел((ПродолжительностьВСекундах - 3600 * Часы) / 60);
		Секунды = ПродолжительностьВСекундах - 3600 * Часы - Минуты * 60;
		
		ПродолжительностьСтрокой = СтрШаблон(НСтр("es='%1 h. %2 min. %3 sec.';
		|ru='%1 ч. %2 мин. %3 с.';en='%1 hr.%2 min. %3 s'"), Часы, Минуты, Секунды);
		Возврат ПродолжительностьСтрокой;
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура СохранитьТКПослеВопроса(Результат, ДопПараметры)Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда 
		СохранитьИзмененияТЧТехКарт(Истина);
	Иначе
		МодифицированностьТЧТехКарт = Ложь;
	КонецЕсли;
	Если МодифицированностьТЧТехКарт = Ложь Тогда 
		СписокПриАктивизацииСтроки(Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПодчиненныеТКПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.ПодчиненныеТК.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		дс_ТК_Операции.Параметры.УстановитьЗначениеПараметра("Ссылка",ТекДанные.Ссылка);
		дс_ТК_МатЗатраты.Параметры.УстановитьЗначениеПараметра("Ссылка",ТекДанные.Ссылка);
		дс_ТК_Трудозатраты.Параметры.УстановитьЗначениеПараметра("Ссылка",ТекДанные.Ссылка);
		дс_ТК_Инструменты.Параметры.УстановитьЗначениеПараметра("Ссылка",ТекДанные.Ссылка);
	Иначе
		дс_ТК_Операции.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
		дс_ТК_МатЗатраты.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
		дс_ТК_Трудозатраты.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
		дс_ТК_Инструменты.Параметры.УстановитьЗначениеПараметра("Ссылка",Неопределено);
	КонецЕсли;
	
	Элементы.дс_ТК_Операции1.Обновить();
	Элементы.дс_ТК_МатЗатраты1.Обновить();
	Элементы.дс_ТК_Трудозатраты1.Обновить();
	Элементы.дс_ТК_Инструменты1.Обновить();
КонецПроцедуры

&НаКлиенте
Процедура тк_СдвинутьТОВниз(Команда)
	ТекДанные = Элементы.ШаблоныТО.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		НомерПП = 1; ИндексПередвигаемого = 0;
		Для Каждого СтрокаСдвига Из ШаблоныТО Цикл
			Если СтрокаСдвига.УИД = ТекДанные.УИД Тогда 
				Если НомерПП >= ШаблоныТО.Количество() Тогда 
					Прервать;
				КонецЕсли;
				ИндексПередвигаемого = НомерПП;
			ИначеЕсли не ИндексПередвигаемого = 0 Тогда 
				Если СтрокаСдвига.ИД = ТекДанные.ИД
					И СтрокаСдвига.ТК = ТекДанные.ТК Тогда 
					ШаблоныТО.Сдвинуть(ШаблоныТО.Индекс(ШаблоныТО[ИндексПередвигаемого-1]), НомерПП - ИндексПередвигаемого);
					ТекДанныеТК = Элементы.ШаблоныТК.ТекущиеДанные;
					Если Не ТекДанныеТК = Неопределено Тогда 
						ТекДанныеТК.Изменен = Истина;
						МодифицированностьТЧТехКарт = Истина;
					КонецЕсли;
					Прервать;
				КонецЕсли;
			КонецЕсли;
			НомерПП = НомерПП + 1;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура тк_СдвинутьТОВверх(Команда)
	ТекДанные = Элементы.ШаблоныТО.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ПоследнийПодходящий = 0;
		НомерПП = 1;
		Для Каждого СтрокаСдвига Из ШаблоныТО Цикл
			Если СтрокаСдвига.УИД = ТекДанные.УИД Тогда 
				Если НомерПП > 1 И Не ПоследнийПодходящий = 0 Тогда 
					ШаблоныТО.Сдвинуть(ШаблоныТО.Индекс(СтрокаСдвига), ПоследнийПодходящий - НомерПП);
					ТекДанныеТК = Элементы.ШаблоныТК.ТекущиеДанные;
					Если Не ТекДанныеТК = Неопределено Тогда 
						ТекДанныеТК.Изменен = Истина;
						МодифицированностьТЧТехКарт = Истина;
					КонецЕсли;
				КонецЕсли;
				Прервать;
			Иначе
				Если СтрокаСдвига.ИД = ТекДанные.ИД
					И СтрокаСдвига.ТК = ТекДанные.ТК Тогда 
					ПоследнийПодходящий = НомерПП;
				КонецЕсли;
			КонецЕсли;
			НомерПП = НомерПП + 1;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
