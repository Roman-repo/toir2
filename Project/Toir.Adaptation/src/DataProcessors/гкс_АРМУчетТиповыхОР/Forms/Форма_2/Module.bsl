			Объект.НаборСвойствОР, Элемент, Отказ);
		дс_Модифицированность=Истина;
	Иначе
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Необходимо записать элемент'");
		Сообщение.Сообщить();
