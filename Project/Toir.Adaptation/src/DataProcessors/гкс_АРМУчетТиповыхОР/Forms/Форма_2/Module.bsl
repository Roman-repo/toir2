#КонецОбласти

#Область Удаление
&НаСервереБезКонтекста
Функция ЕстьПодчиненныеТК(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ИдентификаторыТехКарт.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.торо_ИдентификаторыТехКарт КАК ТК_Родители
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК торо_ИдентификаторыТехКарт
		|		ПО (ТК_Родители.гкс_Владелец = &Ссылка
		|				ИЛИ ТК_Родители.Родитель.гкс_Владелец = &Ссылка
		|				ИЛИ ТК_Родители.Родитель.Родитель.гкс_Владелец = &Ссылка)
		|			И (торо_ИдентификаторыТехКарт.Родитель = ТК_Родители.Ссылка)
		|			И (торо_ИдентификаторыТехКарт.ЭтоГруппа = ЛОЖЬ)";	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);	
	РезультатЗапроса = Запрос.Выполнить();	
	Возврат Не РезультатЗапроса.Пустой();
КонецФункции
&НаСервереБезКонтекста
Процедура ПометитьТиповойОР(Ссылка, Флаг)
	Объект = Ссылка.ПолучитьОбъект();
	Объект.УстановитьПометкуУдаления(Флаг);
КонецПроцедуры

&НаКлиенте
Процедура ПометитьНаУдалениеПослеВопроса(Результат, ДопПараметры)Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда 
		ПометитьТиповойОР(ДопПараметры.ТОР, Истина);
		Элементы.Список.Обновить();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УдалитьТОР(Команда)
	ТекДанные = Элементы.Список.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Отказ = Ложь;
		Если ТекДанные.ПометкаУдаления = Ложь И ЕстьПодчиненныеТК(ТекДанные.Ссылка) Тогда 
			Отказ = истина;
			СтруктураОпОп = Новый Структура("ТОР", ТекДанные.Ссылка);
			ОписаниеОповещенияПослеВопроса = Новый ОписаниеОповещения("ПометитьНаУдалениеПослеВопроса", ЭтотОбъект, СтруктураОпОп);
			ПоказатьВопрос(ОписаниеОповещенияПослеВопроса,
			НСтр("ru='Для удаляемого объекта есть вложенные технологические карты. Пометить их на удаление?'"), РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
		Если Не Отказ Тогда 
			ПометитьТиповойОР(ТекДанные.Ссылка,Не ТекДанные.ПометкаУдаления);
			Элементы.Список.Обновить();
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

