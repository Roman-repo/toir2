		|ГДЕ
		|	(торо_ТиповыеОР.Родитель = &Ссылка
		|			ИЛИ торо_ТиповыеОР.Родитель.Родитель = &Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
