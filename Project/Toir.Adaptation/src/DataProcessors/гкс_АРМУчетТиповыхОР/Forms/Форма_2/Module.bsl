 &НаСервере
Процедура ДобавитьВНаборНаСервере(Параметр)
	
	Блокировка = Новый БлокировкаДанных;	
	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		
		ТекущийНаборОбъект = Объект.НаборСвойствОР.ПолучитьОбъект();
		
		ТабличнаяЧасть = ТекущийНаборОбъект["ДополнительныеРеквизиты"];		
		НайденнаяСтрока = ТабличнаяЧасть.Найти(Параметр, "Свойство");
		
		Если НайденнаяСтрока = Неопределено Тогда
			НоваяСтрока = ТабличнаяЧасть.Добавить();
			НоваяСтрока.Свойство = Параметр;
			ТекущийНаборОбъект.Записать();
			
		ИначеЕсли НайденнаяСтрока.ПометкаУдаления Тогда
			НайденнаяСтрока.ПометкаУдаления = Ложь;
			ТекущийНаборОбъект.Записать();
		КонецЕсли;			
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтаФорма, Объект, "НаборСвойствОР");
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.Свойства

#КонецОбласти

#Область Сохранение
&НаКлиенте
Процедура СохранитьИзменения(Команда)
	СохранитьИзмененияПослеВопроса(КодВозвратаДиалога.Да, Неопределено);
КонецПроцедуры

&НаСервере
Процедура ТранзакцияСохранитьНаСервере(Отказ)
	НачатьТранзакцию();
	СохранитьНаСервере(Отказ);
	Если Отказ Тогда 
		ОтменитьТранзакцию();
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура СохранитьНаСервере(Отказ,ДопПараметры = Неопределено)
	//Локализация
	ПараметрыЗаписи = новый Структура();
	дс_ПередЗаписьюНаСервере(ЭтаФорма, Отказ, Объект, ПараметрыЗаписи);
	//Локализация
	
	Если дс_УровеньОбъекта = 2 Тогда 
		МассивУдаления = Новый Массив();
		Для Каждого СтрокаТаблицы Из гкс_КонструктивныйСостав Цикл
			Если ЗначениеЗаполнено(СтрокаТаблицы.Компонент) = Ложь Тогда 
				МассивУдаления.Добавить(СтрокаТаблицы);
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрокаМассива Из МассивУдаления Цикл
			гкс_КонструктивныйСостав.Удалить(гкс_КонструктивныйСостав.Индекс(СтрокаМассива));
		КонецЦикла;
	КонецЕсли;
	
	Если Не ДопПараметры = Неопределено Тогда 
		Если ДопПараметры.Свойство("ОбновитьНормативы") И ДопПараметры.ОбновитьНормативы И дс_УровеньОбъекта = 2 Тогда 
			ПодчиненныеОчиститьНормативы(дс_Ссылка, дс_НормативныеРемонты);
		КонецЕсли;
	КонецЕсли;
	
	Если дс_Модифицированность 
		ИЛИ МодифицированностьНормРемонтов 
		ИЛИ МодифицированностьПредшествующихРемонтов 
		ИЛИ МодифицированностьЗамещаемыхРемонтов Тогда 
		Если ЗначениеЗаполнено(дс_Ссылка) Тогда 
			ТекОб = дс_Ссылка.ПолучитьОбъект();
		Иначе
			Если дс_ЭтоГруппа Тогда 
				ТекОб = Справочники.торо_ТиповыеОР.СоздатьГруппу();
			Иначе
				ТекОб = Справочники.торо_ТиповыеОР.СоздатьЭлемент();
			КонецЕсли;
		КонецЕсли;
		ТекОб.Наименование = Объект.Наименование;
		Если дс_УровеньОбъекта = 3 Тогда 
			ТекОб.гкс_Модель = Объект.гкс_Модель;
			ТекОб.Направление = дс_Направление;
			ТекОб.Изготовитель = Объект.Изготовитель;
			ТекОб.ФайлКартинки = дс_ФайлКартинки;
		Иначе
			Если дс_УровеньОбъекта = 2 И Не ТекОб.Направление = дс_Направление Тогда 
				ТекОб.Направление = дс_Направление;
				дс_МодифНаправления = Истина;
			КонецЕсли;
			Для Каждого СТ ИЗ дс_НормативныеРемонты Цикл 
				СТ.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке;
			КонецЦикла;
		КонецЕсли;
		ТекОб.Родитель = дс_Родитель;
		ТекОб.Комментарий = Объект.Комментарий;
		Если МодифицированностьНормРемонтов Тогда 
			ТекОб.НормативныеРемонты.Загрузить(дс_НормативныеРемонты.Выгрузить());
			ТекОб.ПредшествующиеРемонты.Загрузить(дс_ПредшествующиеРемонты.Выгрузить());
			ТекОб.ЗамещаемыеРемонты.Загрузить(дс_ЗамещаемыеРемонты.Выгрузить());
		Иначе
			Если МодифицированностьПредшествующихРемонтов Тогда 
				ТекОб.ПредшествующиеРемонты.Загрузить(дс_ПредшествующиеРемонты.Выгрузить());
			КонецЕсли;
			Если МодифицированностьЗамещаемыхРемонтов Тогда 
				ТекОб.ЗамещаемыеРемонты.Загрузить(дс_ЗамещаемыеРемонты.Выгрузить());
			КонецЕсли;
		КонецЕсли;
		Если дс_УровеньОбъекта = 2 Тогда 
			ТекОб.гкс_КонструктивныйСостав.Загрузить(гкс_КонструктивныйСостав.Выгрузить());
		КонецЕсли;
		ТемпСтрукт = Новый Структура("Свойства_ЗначенияДополнительныхРеквизитов", Неопределено);
		ЗаполнитьЗначенияСвойств(ТемпСтрукт, ЭтотОбъект);
		Если Не ТемпСтрукт.Свойства_ЗначенияДополнительныхРеквизитов = Неопределено Тогда 
			Для Каждого СтрокаТаблицы ИЗ ТемпСтрукт.Свойства_ЗначенияДополнительныхРеквизитов Цикл
				НоваяСтрока = ТекОб.ДополнительныеРеквизиты.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			КонецЦикла;
		КонецЕсли;
		// Гкс+[TOIR20-94] Борисов В.М. от 08.06.2020. Добавлено:{
		ТекОб.гкс_Критичность = Объект.гкс_Критичность;
		ТекОб.гкс_ОтветственныйИнженер = Объект.гкс_ОтветственныйИнженер;
		// } Гкс-[TOIR20-94] Борисов В.М. от 08.06.2020.
		ТекОб.Записать();
		дс_Модифицированность = Ложь;
		дс_Ссылка = ТекОб.Ссылка;
		дс_НаборСвойствОР = ТекОб.НаборСвойствОР;
		торо_УправлениеСвойствами.ЗаписатьДопРеквизитыСведенияНабора(ЭтаФорма, Отказ, "ДопРеквизит", дс_НаборСвойствОР);
		
		Если дс_МодифНаправления = Истина Тогда 
			дс_МодифНаправления = Ложь;
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	торо_ТиповыеОР.Ссылка КАК Ссылка
				|ИЗ
				|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
				|ГДЕ
				|	торо_ТиповыеОР.Родитель = &Родитель
				|	И НЕ торо_ТиповыеОР.Направление = &Направление";
			Запрос.УстановитьПараметр("Направление", ТекОб.Направление);
			Запрос.УстановитьПараметр("Родитель", ТекОб.Ссылка);
			РезультатЗапроса = Запрос.Выполнить();
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				ПодчиненныйТОР = Выборка.Ссылка.ПолучитьОбъект();
				ПодчиненныйТОР.Направление = ТекОб.Направление;
				ПодчиненныйТОР.Записать();
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Если МодифицированностьНормРемонтов Тогда
		
		СтруктураВозврата = ПолучитьОРиВРИзТиповогоОР2(дс_Ссылка, "НормативныеРемонты",
		"торо_НормативныеРемонтыОборудования", дс_НормативныеРемонты);
		НаборЗаписей = РегистрыСведений.торо_НормативныеРемонтыОборудования.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТиповойОР.Установить(дс_Ссылка);
		НаборЗаписей.Прочитать();
		
		НаборЗаписей.Очистить();
		НомерСтрокиТЧ = 0;
		Для каждого Стр Из дс_НормативныеРемонты Цикл
			НомерСтрокиТЧ = НомерСтрокиТЧ + 1;
			
			Если ЗначениеЗаполнено(Стр.ВидРемонта) И ЗначениеЗаполнено(Стр.НормативныйРемонт)
				И ЗначениеЗаполнено(Стр.СпособПланирования) 
				И ЗначениеЗаполнено(Стр.ГрафикРемонтныхРабот) И ЗначениеЗаполнено(Стр.СпособВыполнения)
				И Стр.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.Действует Тогда
				Для каждого Элем Из СтруктураВозврата Цикл
					Если Элем.ВидРемонта = Стр.ВидРемонта Тогда
						
						СтрокаНабора = НаборЗаписей.Добавить();	
						
						ЗаполнитьЗначенияСвойств(СтрокаНабора, Элем);
						ЗаполнитьЗначенияСвойств(СтрокаНабора, Стр);
						
						СтрокаНабора.ТиповойОР = дс_Ссылка; 
					КонецЕсли; 
				КонецЦикла;
			ИначеЕсли Стр.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.Действует Тогда  
				Если НЕ ЗначениеЗаполнено(Стр.ВидРемонта) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""el"
					+ " Tipo de la reparación"" en la línea № ';ru='Не удалось записать нормативные ремонты: не заполнено поле"
					+ " ""Вид ремонта"" в строке № ';en='Failed to record standard repairs: the field"
					+ " “Type of repair” in line № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.НормативныйРемонт) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo"
					+ " ""la tarjeta Tecnológica"" en la línea № ';ru='Не удалось записать нормативные ремонты: не заполнено"
					+ " поле ""Технологическая карта"" в строке № ';en='Failed to record normative repairs: the “Route map” "
					+ "field in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.СпособПланирования) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo"
					+ " ""el Modo de la planificación"" en la línea № ';ru='Не удалось записать нормативные ремонты: не "
					+ "заполнено поле ""Способ планирования"" в строке № ';en='Failed to record standard repairs: the"
					+ " ""Planning method"" field in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.ГрафикРемонтныхРабот) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo"
					+ " ""el Gráfico de los trabajos de reparación"" en la línea № ';ru='Не удалось записать нормативные ремонты:"
					+ " не заполнено поле ""График ремонтных работ"" в строке № ';en='Failed to record normative repairs: the"
					+ " ""Repair schedule"" field is not filled in line № '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.СпособВыполнения) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""el"
					+ " Modo de la ejecución"" en la línea № ';ru='Не удалось записать нормативные ремонты: не заполнено поле"
					+ " ""Способ выполнения"" в строке № ';en='Failed to record standard repairs: the ""Execution method"" "
					+ "field in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если Не ЗначениеЗаполнено(Стр.СпособУчетаДатыОтсчета) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""el"
					+ " Modo del recuento de la fecha de la lectura"" en la línea № ';ru='Не удалось записать нормативные "
					+ "ремонты: не заполнено поле ""Способ учета даты отсчета"" в строке № ';en='Failed to record normative"
					+ " repairs: the ""Method for counting the reference date"" field in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
			КонецЕсли;
			Если Отказ Тогда 
				Прервать;
			КонецЕсли;
		КонецЦикла; 
		Если Отказ = Ложь Тогда 
			НаборЗаписей.Записать();
			
			МодифицированностьНормРемонтов = Ложь;
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если МодифицированностьИзмеряемыхПоказателей Тогда 
		НаборЗаписей = РегистрыСведений.торо_ИзмеряемыеПоказателиОбъектовРемонта.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ОбъектРемонта.Установить(дс_Ссылка);		
		НаборЗаписей.Прочитать();
		
		Для каждого СтрокаПоказателя из дс_СписокИзмеряемыхПоказателей Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаПоказателя.ОбъектРемонта) Тогда
				СтрокаПоказателя.ОбъектРемонта = дс_Ссылка;
			КонецЕсли;
		КонецЦикла;
		
		МассивСтрок = дс_СписокИзмеряемыхПоказателей.НайтиСтроки(Новый Структура("ОбъектРемонта", дс_Ссылка));
		НаборЗаписей.Загрузить(дс_СписокИзмеряемыхПоказателей.Выгрузить(МассивСтрок));
		
		НаборЗаписей.Записать();
		
		// Удалим из регистра строки, которые были удалены для конкретных ОР.
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ИзмеряемыеПоказателиОбъектовРемонта.ОбъектРемонта,
		|	ИзмеряемыеПоказателиОбъектовРемонта.Показатель КАК Показатель
		|ИЗ
		|	(ВЫБРАТЬ
		|		торо_ОбъектыРемонта.Ссылка КАК Ссылка
		|	ИЗ
		|		Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
		|	ГДЕ
		|		торо_ОбъектыРемонта.ТиповойОР = &ТиповойОР) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИзмеряемыеПоказателиОбъектовРемонта 
		|	КАК ИзмеряемыеПоказателиОбъектовРемонта
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ИзмеряемыеПоказателиОбъектовРемонта КАК ИзмеряемыеПоказателиТиповыхОР
		|			ПО ИзмеряемыеПоказателиОбъектовРемонта.Показатель = ИзмеряемыеПоказателиТиповыхОР.Показатель
		|				И (ИзмеряемыеПоказателиТиповыхОР.ОбъектРемонта = &ТиповойОР)
		|		ПО (ВложенныйЗапрос.Ссылка = (ВЫРАЗИТЬ(ИзмеряемыеПоказателиОбъектовРемонта.ОбъектРемонта 
		|	КАК Справочник.торо_ОбъектыРемонта)))
		|ГДЕ
		|	ИзмеряемыеПоказателиОбъектовРемонта.Удален
		|	И ИзмеряемыеПоказателиТиповыхОР.Показатель ЕСТЬ NULL 
		|ИТОГИ ПО
		|	Показатель";
		Запрос.УстановитьПараметр("ТиповойОР", дс_Ссылка);
		Результат = Запрос.Выполнить();
		Если НЕ Результат.Пустой() Тогда
			ВыборкаПоказатели = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоказатели.Следующий() Цикл
				НаборЗаписей = РегистрыСведений.торо_ИзмеряемыеПоказателиОбъектовРемонта.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Показатель.Установить(ВыборкаПоказатели.Показатель);
				НаборЗаписей.Прочитать();
				ВыборкаДетЗаписи = ВыборкаПоказатели.Выбрать();
				МассивУдаляемых = Новый Массив;
				Для Каждого Запись Из НаборЗаписей Цикл
					Если ВыборкаДетЗаписи.НайтиСледующий(Новый Структура("ОбъектРемонта,Показатель", Запись.ОбъектРемонта, Запись.Показатель)) Тогда
						МассивУдаляемых.Добавить(Запись);
					КонецЕсли;
					ВыборкаДетЗаписи.Сбросить();
				КонецЦикла;
				Для Каждого ЭлМассива Из МассивУдаляемых Цикл
					НаборЗаписей.Удалить(ЭлМассива);
				КонецЦикла;
				НаборЗаписей.Записать();
			КонецЦикла;
		КонецЕсли;
		МодифицированностьИзмеряемыхПоказателей = Ложь;
	КонецЕсли;
	
	Если МодифицированностьПараметровОповещенияОСостоянииОР Тогда
		
		Для каждого Строка из ПараметрыОповещенияПоСостояниямОР Цикл
			Если НЕ ЗначениеЗаполнено(Строка.ОбъектРемонта) Тогда
				Строка.ОбъектРемонта = дс_Ссылка;
			КонецЕсли;
		КонецЦикла;
		
		Попытка
			НаборПараметровОповещения = РегистрыСведений.торо_ПараметрыОповещенияОСостоянииОборудования.СоздатьНаборЗаписей();
			НаборПараметровОповещения.Отбор.ТиповойОР.Установить(дс_Ссылка);
			НайденныеСтроки = ПараметрыОповещенияПоСостояниямОР.НайтиСтроки(Новый Структура("ТиповойОР",
				Справочники.торо_ТиповыеОР.ПустаяСсылка()));
			Для каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				НайденнаяСтрока.ТиповойОР = дс_Ссылка;
			КонецЦикла;
			МассивСтрок = ПараметрыОповещенияПоСостояниямОР.НайтиСтроки(Новый Структура("ТиповойОР", дс_Ссылка));
			НаборПараметровОповещения.Загрузить(ПараметрыОповещенияПоСостояниямОР.Выгрузить(МассивСтрок));			
			НаборПараметровОповещения.Записать();
			МодифицированностьПараметровОповещенияОСостоянииОР = Ложь;
		Исключение
			ТекстСообщения = НСтр("es='No consiguió anotar los parámetros del aviso sobre el estado de la maquinaria: '
			|;ru='Не удалось записать параметры оповещения о состоянии оборудования: ';
			|en='Failed to record equipment status alert parameters: '") + ОписаниеОшибки();
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
			Отказ = Истина;
			Возврат;
		КонецПопытки;
		
	КонецЕсли;
	
	Если МодифицированностьПредшествующихРемонтов ИЛИ МодифицированностьНормРемонтов Тогда
		
		НаборЗаписей = РегистрыСведений.торо_ПредшествующиеНормативныеРемонтыОборудования.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТиповойОР.Установить(дс_Ссылка);
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить();
		
		СтруктураВозврата = ПолучитьОРиВРИзТиповогоОР2(дс_Ссылка, "ПредшествующиеРемонты",
		"торо_ПредшествующиеНормативныеРемонтыОборудования", дс_ПредшествующиеРемонты); 
		ТЗПредшествующих = ПолучитьПредшествующиеИлиНормативные("ПредшествующийВидРемонта",
		дс_НормативныеРемонты, дс_ПредшествующиеРемонты, Неопределено);
		
		Для каждого Стр Из ТЗПредшествующих Цикл
			Для каждого Элем Из СтруктураВозврата Цикл
				Если Элем.ВидРемонта = Стр.ВидРемонта Тогда
					
					СтрокаНабора = НаборЗаписей.Добавить();	
					ЗаполнитьЗначенияСвойств(СтрокаНабора, Элем);
					ЗаполнитьЗначенияСвойств(СтрокаНабора, Стр);
					СтрокаНабора.Приоритет = Элем.Приоритет;
					СтрокаНабора.ТиповойОР = дс_Ссылка;
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла; 
		
		НаборЗаписей.Записать();
		
		Если Не Отказ Тогда     			
			МодифицированностьПредшествующихРемонтов = Ложь;			
		иначе
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Если МодифицированностьЗамещаемыхРемонтов ИЛИ МодифицированностьНормРемонтов Тогда
		СтруктураВозврата = ПолучитьОРиВРИзТиповогоОР2(дс_Ссылка, "ЗамещаемыеРемонты","торо_ПараметрыЗамещенияПланированияРемонтныхРабот", дс_ЗамещаемыеРемонты); 
		НаборЗаписей = РегистрыСведений.торо_ПараметрыЗамещенияПланированияРемонтныхРабот.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТиповойОР.Установить(дс_Ссылка);
		НаборЗаписей.Прочитать();
		
		НаборЗаписей.Очистить();
		
		ТЗЗамещаемых = ПолучитьПредшествующиеИлиНормативные("ЗамещаемыйВидРемонта", 
			дс_НормативныеРемонты, Неопределено, дс_ЗамещаемыеРемонты);
		
		Для каждого Стр Из ТЗЗамещаемых Цикл
			Для каждого Элем Из СтруктураВозврата Цикл
				Если Элем.ВидРемонта = Стр.ВидРемонта Тогда
					СтрокаНабора = НаборЗаписей.Добавить();	
					ЗаполнитьЗначенияСвойств(СтрокаНабора, Элем);
					ЗаполнитьЗначенияСвойств(СтрокаНабора, Стр);
					СтрокаНабора.Приоритет = Элем.Приоритет;
					СтрокаНабора.ТиповойОР = дс_Ссылка;
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла; 
		
		НаборЗаписей.Записать();
		Если Не Отказ Тогда
			МодифицированностьЗамещаемыхРемонтов = Ложь;		
		Иначе
			Возврат;
		КонецЕсли;

	КонецЕсли;
	
	Если МодифицированностьПараметровНаработки Тогда
		
		Для каждого Строка из СписокПараметровНаработки Цикл
			Если НЕ ЗначениеЗаполнено(Строка.ОбъектРемонта) Тогда
				Строка.ОбъектРемонта = дс_Ссылка;
			КонецЕсли;
		КонецЦикла;
		
		Попытка
			ТаблицаЗначенийПараметровНаработки = СписокПараметровНаработки.Выгрузить();
			МассивСтрокПараметров = ТаблицаЗначенийПараметровНаработки.НайтиСтроки(Новый Структура("ОбъектРемонта", дс_Ссылка));
			ТаблицаБуфер = ТаблицаЗначенийПараметровНаработки.Скопировать(МассивСтрокПараметров);
			
			НаборПараметровНаработки = РегистрыСведений.торо_ПараметрыНаработкиОбъектовРемонта.СоздатьНаборЗаписей();
			НаборПараметровНаработки.Отбор.ОбъектРемонта.Установить(дс_Ссылка);
			НаборПараметровНаработки.Загрузить(ТаблицаБуфер);
			НаборПараметровНаработки.Записать();
			
		Исключение
			
			ТекстСообщения = НСтр("es='No consiguió anotar los parámetros de la elaboración: ';
			|ru='Не удалось записать параметры наработки: ';en='Failed to write running hours: '") + ОписаниеОшибки();
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
			Возврат;
			
		КонецПопытки;
		Если Не Отказ Тогда 
			МодифицированностьПараметровНаработки = Ложь;
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если МодифицированностьМаксЗначНаработки Тогда
		
		ТабМаксЗнач = ТабМаксимальныхЗначенийНаработки.Выгрузить();
		ТабМаксЗнач.ЗаполнитьЗначения(дс_Ссылка, "ОбъектРемонта");
		
		НаборКонтролируемыхПоказателей = РегистрыСведений.торо_МаксимальныеЗначенияНаработкиОР.СоздатьНаборЗаписей();
		НаборКонтролируемыхПоказателей.Отбор.ОбъектРемонта.Установить(дс_Ссылка);
		НаборКонтролируемыхПоказателей.Загрузить(ТабМаксЗнач);
		НаборКонтролируемыхПоказателей.Записать();		
		
		МодифицированностьМаксЗначНаработки = Ложь;
	КонецЕсли;
	//
	Если Не ДопПараметры = Неопределено Тогда 
		Если ДопПараметры.Свойство("ОбновитьНормативы") И ДопПараметры.ОбновитьНормативы И дс_УровеньОбъекта = 2 Тогда 
			ПодчиненныеОбновитьНормативы(дс_Ссылка);
		КонецЕсли;
		Если ДопПараметры.Свойство("ОбновитьПоказатели") И ДопПараметры.ОбновитьПоказатели И Не дс_УровеньОбъекта = 3 Тогда 
			ПодчиненныеОбновитьПоказатели(дс_Ссылка,дс_СписокИзмеряемыхПоказателей,
				дс_СписокИзмеряемыхПоказателейДоИзменения, Отказ);
		КонецЕсли;
		Если ДопПараметры.Свойство("ОбновитьНаработку") И ДопПараметры.ОбновитьНаработку И Не дс_УровеньОбъекта = 3 Тогда 
			ПодчиненныеОбновитьНаработку(дс_Ссылка, СписокПараметровНаработки, СписокПараметровНаработкиДоИзменения, Отказ);
		КонецЕсли;
	КонецЕсли;
	//Локализация
	торо_ЛокализацияСобытияФорм.ПослеЗаписиНаСервере(ЭтаФорма,, ПараметрыЗаписи, дс_Ссылка);
	//Локализация
КонецПроцедуры
// 
&НаСервереБезКонтекста
Процедура ПодчиненныеОчиститьНормативы(Ссылка, ТЧ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.ВидРемонта КАК ВидРемонта,
		|	ТЧ.СпособПланирования КАК СпособПланирования
		|ПОМЕСТИТЬ ТчНовые
		|ИЗ
		|	&ТЧ КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРНормативныеРемонты.ВидРемонта КАК ВидРемонта
		|ПОМЕСТИТЬ Нормативы
		|ИЗ
		|	Справочник.торо_ТиповыеОР.НормативныеРемонты КАК торо_ТиповыеОРНормативныеРемонты
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТчНовые КАК ТчНовые
		|		ПО торо_ТиповыеОРНормативныеРемонты.ВидРемонта = ТчНовые.ВидРемонта
		|ГДЕ
		|	торо_ТиповыеОРНормативныеРемонты.Ссылка = &Ссылка
		|	И (ТчНовые.ВидРемонта ЕСТЬ NULL
		|			ИЛИ НЕ торо_ТиповыеОРНормативныеРемонты.СпособПланирования = ТчНовые.СпособПланирования)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ТиповыеОРНормативныеРемонты.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ИзменяемыеТОР
		|ИЗ
		|	Справочник.торо_ТиповыеОР.НормативныеРемонты КАК торо_ТиповыеОРНормативныеРемонты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Нормативы КАК Нормативы
		|		ПО торо_ТиповыеОРНормативныеРемонты.ВидРемонта = Нормативы.ВидРемонта
		|ГДЕ
		|	торо_ТиповыеОРНормативныеРемонты.Ссылка.Родитель = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРНормативныеРемонты.Ссылка КАК Ссылка,
		|	торо_ТиповыеОРНормативныеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРНормативныеРемонты.НормативныйРемонт КАК НормативныйРемонт,
		|	торо_ТиповыеОРНормативныеРемонты.СпособПланирования КАК СпособПланирования,
		|	торо_ТиповыеОРНормативныеРемонты.Статус КАК Статус,
		|	торо_ТиповыеОРНормативныеРемонты.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
		|	торо_ТиповыеОРНормативныеРемонты.СпособВыполнения КАК СпособВыполнения,
		|	торо_ТиповыеОРНормативныеРемонты.НеИспользоватьВПланированииДатуВводаВЭксплуатацию 
		|	КАК НеИспользоватьВПланированииДатуВводаВЭксплуатацию,
		|	торо_ТиповыеОРНормативныеРемонты.СпособУчетаДатыОтсчета КАК СпособУчетаДатыОтсчета,
		|	торо_ТиповыеОРНормативныеРемонты.НеУчаствуетВПланировании КАК НеУчаствуетВПланировании,
		|	торо_ТиповыеОРНормативныеРемонты.РазрешитьСокращатьМежремонтныйПериодПриПланировании 
		|	КАК РазрешитьСокращатьМежремонтныйПериодПриПланировании,
		|	торо_ТиповыеОРНормативныеРемонты.НеУчитыватьПриПланированииГрафикРаботыОборудования 
		|	КАК НеУчитыватьПриПланированииГрафикРаботыОборудования,
		|	торо_ТиповыеОРНормативныеРемонты.НеУчитыватьПриПланированииГрафикРемонтныхРабот 
		|	КАК НеУчитыватьПриПланированииГрафикРемонтныхРабот,
		|	торо_ТиповыеОРНормативныеРемонты.НеУчитыватьПродолжительность КАК НеУчитыватьПродолжительность,
		|	торо_ТиповыеОРНормативныеРемонты.УчитыватьПростоиОборудования КАК УчитыватьПростоиОборудования,
		|	торо_ТиповыеОРНормативныеРемонты.ИспользоватьКоэффициентыРемонтныхОсобенностей 
		|	КАК ИспользоватьКоэффициентыРемонтныхОсобенностей,
		|	НЕ Нормативы.ВидРемонта ЕСТЬ NULL КАК Лишний
		|ИЗ
		|	ИзменяемыеТОР КАК ИзменяемыеТОР
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.НормативныеРемонты КАК торо_ТиповыеОРНормативныеРемонты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Нормативы КАК Нормативы
		|			ПО торо_ТиповыеОРНормативныеРемонты.ВидРемонта = Нормативы.ВидРемонта
		|		ПО (торо_ТиповыеОРНормативныеРемонты.Ссылка = ИзменяемыеТОР.Ссылка)
		|ИТОГИ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРПредшествующиеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРПредшествующиеРемонты.ПредшествующийВидРемонта КАК ПредшествующийВидРемонта,
		|	торо_ТиповыеОРПредшествующиеРемонты.Ссылка КАК Ссылка,
		|	НЕ Нормативы.ВидРемонта ЕСТЬ NULL КАК Лишний
		|ИЗ
		|	Справочник.торо_ТиповыеОР.ПредшествующиеРемонты КАК торо_ТиповыеОРПредшествующиеРемонты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИзменяемыеТОР КАК ИзменяемыеТОР
		|		ПО торо_ТиповыеОРПредшествующиеРемонты.Ссылка = ИзменяемыеТОР.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Нормативы КАК Нормативы
		|		ПО торо_ТиповыеОРПредшествующиеРемонты.ВидРемонта = Нормативы.ВидРемонта
		|ИТОГИ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	торо_ТиповыеОРЗамещаемыеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРЗамещаемыеРемонты.ЗамещаемыйВидРемонта КАК ЗамещаемыйВидРемонта,
		|	торо_ТиповыеОРЗамещаемыеРемонты.СпособЗамещения КАК СпособЗамещения,
		|	торо_ТиповыеОРЗамещаемыеРемонты.НачальнаяГраница КАК НачальнаяГраница,
		|	торо_ТиповыеОРЗамещаемыеРемонты.КонечнаяГраница КАК КонечнаяГраница,
		|	торо_ТиповыеОРЗамещаемыеРемонты.Ссылка КАК Ссылка,
		|	НЕ Нормативы.ВидРемонта ЕСТЬ NULL КАК Лишний
		|ИЗ
		|	Справочник.торо_ТиповыеОР.ЗамещаемыеРемонты КАК торо_ТиповыеОРЗамещаемыеРемонты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИзменяемыеТОР КАК ИзменяемыеТОР
		|		ПО торо_ТиповыеОРЗамещаемыеРемонты.Ссылка = ИзменяемыеТОР.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Нормативы КАК Нормативы
		|		ПО торо_ТиповыеОРЗамещаемыеРемонты.ВидРемонта = Нормативы.ВидРемонта
		|ИТОГИ ПО
		|	Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ТЧ", ТЧ.Выгрузить(, "ВидРемонта,СпособПланирования"));
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаСсылка = РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ПредНормативы = РезультатЗапроса[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ПостНормативы = РезультатЗапроса[5].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСсылка.Следующий() Цикл
		ТекОб = ВыборкаСсылка.Ссылка.ПолучитьОбъект();
		ТекОб.НормативныеРемонты.Очистить();
		Выборка = ВыборкаСсылка.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Не Выборка.Лишний Тогда 
				НоваяСтрока = ТекОб.НормативныеРемонты.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЕсли;
		КонецЦикла;
		
		ТекОб.ПредшествующиеРемонты.Очистить();
		Если ПредНормативы.НайтиСледующий(Новый Структура("Ссылка", ВыборкаСсылка.Ссылка)) Тогда 
			Выборка = ПредНормативы.Выбрать();
			Пока Выборка.Следующий() Цикл
				Если Не Выборка.Лишний Тогда 
					НоваяСтрока = ТекОб.ПредшествующиеРемонты.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		ПредНормативы.Сбросить();
		
		ТекОб.ЗамещаемыеРемонты.Очистить();
		Если ПостНормативы.НайтиСледующий(Новый Структура("Ссылка", ВыборкаСсылка.Ссылка)) Тогда 
			Выборка = ПостНормативы.Выбрать();
			Пока Выборка.Следующий() Цикл
				Если Не Выборка.Лишний Тогда 
					НоваяСтрока = ТекОб.ЗамещаемыеРемонты.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		ПостНормативы.Сбросить();
		//
		ТекОб.Записать();
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПодчиненныеОбновитьНормативы(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ТиповыеОРНормативныеРемонты.ВидРемонта КАК ВидРемонта,
		|	торо_ТиповыеОРНормативныеРемонты.СпособПланирования КАК СпособПланирования,
		|	торо_ТиповыеОРНормативныеРемонты.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
		|	торо_ТиповыеОРНормативныеРемонты.СпособВыполнения КАК СпособВыполнения,
		|	торо_ТиповыеОРНормативныеРемонты.СпособУчетаДатыОтсчета КАК СпособУчетаДатыОтсчета
		|ПОМЕСТИТЬ Нормативы
		|ИЗ
		|	Справочник.торо_ТиповыеОР.НормативныеРемонты КАК торо_ТиповыеОРНормативныеРемонты
		|ГДЕ
		|	торо_ТиповыеОРНормативныеРемонты.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	торо_ТиповыеОР.Ссылка КАК Ссылка,
		|	Нормативы.ВидРемонта КАК ВидРемонта,
		|	Нормативы.СпособПланирования КАК СпособПланирования,
		|	Нормативы.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
		|	Нормативы.СпособВыполнения КАК СпособВыполнения,
		|	Нормативы.СпособУчетаДатыОтсчета КАК СпособУчетаДатыОтсчета
		|ПОМЕСТИТЬ НужныеТОР
		|ИЗ
		|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР,
		|	Нормативы КАК Нормативы
		|ГДЕ
		|	торо_ТиповыеОР.Родитель = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НужныеТОР.Ссылка КАК Ссылка,
		|	НужныеТОР.ВидРемонта КАК ВидРемонта,
		|	НужныеТОР.СпособПланирования КАК СпособПланирования,
		|	ЕСТЬNULL(торо_ТиповыеОРНормативныеРемонты.НомерСтроки, -1) КАК НомерСтроки,
		|	ЕСТЬNULL(торо_ТиповыеОРНормативныеРемонты.Статус, &Статус) КАК Статус,
		|	торо_ТиповыеОРНормативныеРемонты.СпособПланирования ЕСТЬ NULL
		|		ИЛИ НЕ торо_ТиповыеОРНормативныеРемонты.СпособПланирования = НужныеТОР.СпособПланирования КАК Изменение,
		|	НужныеТОР.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
		|	НужныеТОР.СпособВыполнения КАК СпособВыполнения,
		|	НужныеТОР.СпособУчетаДатыОтсчета КАК СпособУчетаДатыОтсчета
		|ИЗ
		|	НужныеТОР КАК НужныеТОР
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.НормативныеРемонты КАК торо_ТиповыеОРНормативныеРемонты
		|		ПО НужныеТОР.Ссылка = торо_ТиповыеОРНормативныеРемонты.Ссылка
		|			И НужныеТОР.ВидРемонта = торо_ТиповыеОРНормативныеРемонты.ВидРемонта
		|ИТОГИ
		|	МАКСИМУМ(Изменение)
		|ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НужныеТОР.Ссылка КАК Ссылка,
		|	НужныеТОР.ВидРемонта КАК ВидРемонта,
		|	ЕСТЬNULL(торо_ТиповыеОРПредшествующиеРемонты.ПредшествующийВидРемонта, НужныеТОР.ВидРемонта)
		|	КАК ПредшествующийВидРемонта,
		|	ЕСТЬNULL(торо_ТиповыеОРПредшествующиеРемонты.НомерСтроки, -1) КАК НомерСтроки
		|ИЗ
		|	НужныеТОР КАК НужныеТОР
		|		Левое СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ПредшествующиеРемонты КАК торо_ТиповыеОРПредшествующиеРемонты
		|		ПО НужныеТОР.Ссылка = торо_ТиповыеОРПредшествующиеРемонты.Ссылка
		|			И НужныеТОР.ВидРемонта = торо_ТиповыеОРПредшествующиеРемонты.ВидРемонта
		|ИТОГИ ПО
		|	Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Статус", Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.ВРазработке);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ИндексОсновногоПакета = 2;
	ИндексДополнительногоПакета = 3;
	Выборка1 = РезультатЗапроса[ИндексОсновногоПакета].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Выборка2 = РезультатЗапроса[ИндексДополнительногоПакета].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка1.Следующий() Цикл
		Если Выборка1.Изменение = Ложь Тогда 
			Продолжить;
		КонецЕсли;
		
		НачатьТранзакцию();
		Попытка
			ТекОб = Выборка1.Ссылка.ПолучитьОбъект();
			Выборка = Выборка1.Выбрать();
			Пока Выборка.Следующий() Цикл
				Если Выборка.НомерСтроки = -1 Тогда 
					НоваяСтрока = ТекОб.НормативныеРемонты.Добавить();
				Иначе
					НоваяСтрока = ТекОб.НормативныеРемонты[Выборка.НомерСтроки - 1];
				КонецЕсли;
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			Если Выборка2.НайтиСледующий(Новый Структура("Ссылка", Выборка1.Ссылка)) Тогда 
				Выборка = Выборка2.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если Выборка.НомерСтроки = -1 Тогда 
						НоваяСтрока = ТекОб.ПредшествующиеРемонты.Добавить();
					Иначе
						НоваяСтрока = ТекОб.ПредшествующиеРемонты[Выборка.НомерСтроки - 1];
					КонецЕсли;
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				КонецЦикла;
			КонецЕсли;
			Выборка2.Сбросить();
			//
			Отказ = Ложь;
			ЗаписатьНормативы(Выборка1.Ссылка, ТекОб.НормативныеРемонты, Отказ);
			Если Не Отказ Тогда 
				ЗаписатьПредшествующие(Ссылка, ТекОб.НормативныеРемонты, ТекОб.ПредшествующиеРемонты, Отказ);
			КонецЕсли;
			Если Не Отказ Тогда 
				ЗаписатьЗамещаемые(Ссылка, ТекОб.НормативныеРемонты, ТекОб.ЗамещаемыеРемонты, Отказ);
			КонецЕсли;
			Если Отказ Тогда 
				ОтменитьТранзакцию();
				Продолжить;
			КонецЕсли;
			//
			ТекОб.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = ОписаниеОшибки();
			Сообщение.Сообщить();
			ОтменитьТранзакцию();
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьНормативы(Ссылка, ТЧ, Отказ)
	СтруктураВозврата = ПолучитьОРиВРИзТиповогоОР2(Ссылка, "НормативныеРемонты",
		"торо_НормативныеРемонтыОборудования", ТЧ);
		НаборЗаписей = РегистрыСведений.торо_НормативныеРемонтыОборудования.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТиповойОР.Установить(Ссылка);
		НомерСтрокиТЧ = 0;
		Для каждого Стр Из ТЧ Цикл
			НомерСтрокиТЧ = НомерСтрокиТЧ + 1;
			
			Если ЗначениеЗаполнено(Стр.ВидРемонта) И ЗначениеЗаполнено(Стр.НормативныйРемонт)
					И ЗначениеЗаполнено(Стр.СпособПланирования) 
				И ЗначениеЗаполнено(Стр.ГрафикРемонтныхРабот) И ЗначениеЗаполнено(Стр.СпособВыполнения)
				И Стр.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.Действует Тогда
				Для каждого Элем Из СтруктураВозврата Цикл
					Если Элем.ВидРемонта = Стр.ВидРемонта Тогда
						
						СтрокаНабора = НаборЗаписей.Добавить();	
						
						ЗаполнитьЗначенияСвойств(СтрокаНабора, Элем);
						ЗаполнитьЗначенияСвойств(СтрокаНабора, Стр);
						
						СтрокаНабора.ТиповойОР = Ссылка; 
					КонецЕсли; 
				КонецЦикла;
			ИначеЕсли Стр.Статус = Перечисления.торо_СтатусыНормативныхРемонтовИТехКарт.Действует Тогда  
				Если НЕ ЗначениеЗаполнено(Стр.ВидРемонта) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""el Tipo"
					+ " de la reparación"" en la línea № ';ru='Не удалось записать нормативные ремонты: не заполнено поле"
					+ " ""Вид ремонта"" в строке № ';en='Failed to record standard repairs: the field “Type "
					+ "of repair” in line № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.НормативныйРемонт) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""la tarjeta"
					+ " Tecnológica"" en la línea № ';ru='Не удалось записать нормативные ремонты: не заполнено поле"
					+ " ""Технологическая карта"" в строке № ';en='Failed to record normative repairs: "
					+ "the “Route map” field in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.СпособПланирования) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""el Modo"
					+ " de la planificación"" en la línea № ';ru='Не удалось записать нормативные ремонты: не заполнено поле"
					+ " ""Способ планирования"" в строке № ';en='Failed to record standard repairs: the ""Planning method"" field"
					+ " in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.ГрафикРемонтныхРабот) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""el"
					+ " Gráfico de los trabajos de reparación"" en la línea № ';ru='Не удалось записать нормативные ремонты: "
					+ "не заполнено поле ""График ремонтных работ"" в строке № ';en='Failed to record normative repairs: the"
					+ " ""Repair schedule"" field is not filled in line № '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Стр.СпособВыполнения) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo"
					+ " ""el Modo de la ejecución"" en la línea № ';ru='Не удалось записать нормативные ремонты: не заполнено"
					+ " поле ""Способ выполнения"" в строке № ';en='Failed to record standard repairs: the ""Execution method"" "
					+ "field in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
				Если Не ЗначениеЗаполнено(Стр.СпособУчетаДатыОтсчета) Тогда
					ТекстСообщения = НСтр("es='No consiguió anotar las reparaciones normativas: no es rellenado el campo ""el "
					+ "Modo del recuento de la fecha de la lectura"" en la línea № ';ru='Не удалось записать нормативные "
					+ "ремонты: не заполнено поле ""Способ учета даты отсчета"" в строке № ';en='Failed to record normative "
					+ "repairs: the ""Method for counting the reference date"" field in row № is not filled '") + НомерСтрокиТЧ;
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
			КонецЕсли;
			Если Отказ Тогда 
				Прервать;
			КонецЕсли;
		КонецЦикла; 
		Если Отказ = Ложь Тогда 
			НаборЗаписей.Записать();
			
			МодифицированностьНормРемонтов = Ложь;
		Иначе
			Возврат;
		КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьПредшествующие(Ссылка, ТЧ, ТЧ2, Отказ)
	НаборЗаписей = РегистрыСведений.торо_ПредшествующиеНормативныеРемонтыОборудования.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ТиповойОР.Установить(Ссылка);
	СтруктураВозврата = ПолучитьОРиВРИзТиповогоОР2(Ссылка, "ПредшествующиеРемонты",
	"торо_ПредшествующиеНормативныеРемонтыОборудования", ТЧ); 
	ТЗПредшествующих = ПолучитьПредшествующиеИлиНормативные("ПредшествующийВидРемонта", ТЧ, ТЧ2);
	
	Для каждого Стр Из ТЗПредшествующих Цикл
		Для каждого Элем Из СтруктураВозврата Цикл
			Если Элем.ВидРемонта = Стр.ВидРемонта Тогда
				
				СтрокаНабора = НаборЗаписей.Добавить();	
				ЗаполнитьЗначенияСвойств(СтрокаНабора, Элем);
				ЗаполнитьЗначенияСвойств(СтрокаНабора, Стр);
				СтрокаНабора.Приоритет = Элем.Приоритет;
				СтрокаНабора.ТиповойОР = Ссылка;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла; 
	
	НаборЗаписей.Записать();

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьЗамещаемые(Ссылка, ТЧ, ТЧ2, Отказ)
	СтруктураВозврата = ПолучитьОРиВРИзТиповогоОР2(Ссылка, "ЗамещаемыеРемонты",
		"торо_ПараметрыЗамещенияПланированияРемонтныхРабот", ТЧ2); 
	НаборЗаписей = РегистрыСведений.торо_ПараметрыЗамещенияПланированияРемонтныхРабот.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ТиповойОР.Установить(Ссылка);
	ТЗЗамещаемых = ПолучитьПредшествующиеИлиНормативные("ЗамещаемыйВидРемонта",ТЧ,Неопределено,ТЧ2);
	
	Для каждого Стр Из ТЗЗамещаемых Цикл
		Для каждого Элем Из СтруктураВозврата Цикл
			Если Элем.ВидРемонта = Стр.ВидРемонта Тогда
				СтрокаНабора = НаборЗаписей.Добавить();	
				ЗаполнитьЗначенияСвойств(СтрокаНабора, Элем);
				ЗаполнитьЗначенияСвойств(СтрокаНабора, Стр);
				СтрокаНабора.Приоритет = Элем.Приоритет;
				СтрокаНабора.ТиповойОР = Ссылка;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла; 
	
	НаборЗаписей.Записать();

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПодчиненныеОбновитьПоказатели(Ссылка, ТЧ1, ТЧ2, Отказ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ.ОбъектРемонта КАК ОбъектРемонта,
		|	ТЧ.Показатель КАК Показатель,
		|	ТЧ.ДопустимыйМинимум КАК ДопустимыйМинимум,
		|	ТЧ.ДопустимыйМаксимум КАК ДопустимыйМаксимум,
		|	ТЧ.КритическийМинимум КАК КритическийМинимум,
