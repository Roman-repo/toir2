КонецПроцедуры

&НаКлиенте
Процедура тк_ДобавитьТО(Команда)
	ТекДанныеТК = Элементы.ШаблоныТК.ТекущиеДанные;
	Если НЕ ТекДанныеТК = Неопределено Тогда 
		ФормаВыбора = ПолучитьФорму("Справочник.торо_ТехнологическиеОперации.ФормаВыбора",
			Новый Структура("МножественныйВыбор", Истина), Элементы.ШаблоныТО);
		ФормаВыбора.ЗакрыватьПриВыборе = Ложь;
		ФормаВыбора.Открыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ШаблоныТООбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ТекДанныеТК = Элементы.ШаблоныТК.ТекущиеДанные;
	Если НЕ ТекДанныеТК = Неопределено Тогда 
		ТекДанныеТК.Изменен = Истина;
		МодифицированностьТЧТехКарт = Истина;
		
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда 
			Для Каждого ВыбраннаяСтрока Из ВыбранноеЗначение Цикл
				НоваяСтрока = ШаблоныТО.Добавить();
				НоваяСтрока.Операция = ВыбраннаяСтрока;
				НоваяСтрока.Количество = 1;
				НоваяСтрока.СпособВыполнения = _ХозСпособ;
				НоваяСтрока.ИД = ТекДанныеТК.ИД;
				НоваяСтрока.ТК = ТекДанныеТК.ТК;
				НоваяСтрока.УИД = Строка(Новый УникальныйИдентификатор());
			КонецЦикла;
		Иначе 
			НоваяСтрока = ШаблоныТО.Добавить();
			НоваяСтрока.Операция = ВыбранноеЗначение;
			НоваяСтрока.Количество = 1;
			НоваяСтрока.СпособВыполнения = _ХозСпособ;
			НоваяСтрока.ИД = ТекДанныеТК.ИД;
			НоваяСтрока.ТК = ТекДанныеТК.ТК;
			НоваяСтрока.УИД = Строка(Новый УникальныйИдентификатор());
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ШаблоныТОПередУдалением(Элемент, Отказ)
	ТекДанные = Элементы.ШаблоныТК.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		МодифицированностьТЧТехКарт = Истина;
		ТекДанные.Изменен = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ШаблоныТОгкс_ПримечаниеПриИзменении(Элемент)
	МодифицированностьТЧТехКарт = Истина;
	ТекДанные = Элементы.ШаблоныТК.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		ТекДанные.Изменен = Истина;
		Если ЗначениеЗаполнено(ТекДанные.ТК) Тогда 
			Элементы.ШаблоныТО.ОтборСтрок = Новый ФиксированнаяСтруктура("ТК",ТекДанные.ТК);
		Иначе
			Элементы.ШаблоныТО.ОтборСтрок = Новый ФиксированнаяСтруктура("ИД",ТекДанные.ИД);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

