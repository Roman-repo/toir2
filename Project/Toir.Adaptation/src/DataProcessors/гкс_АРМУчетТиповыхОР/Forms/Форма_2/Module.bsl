	Если дс_Редактирование И ЗначениеЗаполнено(дс_Ссылка) Тогда 
		торо_УправлениеСвойствамиКлиент.Свойства_ЗначенияДополнительныхРеквизитовПередНачаломДобавления(ЭтаФорма,
			Объект.НаборСвойствОР, Элемент, Отказ, Копирование, Родитель, Группа);
	Иначе
		СтруктураОпОп = Новый Структура("ПродолжитьРедактирование", Истина);
