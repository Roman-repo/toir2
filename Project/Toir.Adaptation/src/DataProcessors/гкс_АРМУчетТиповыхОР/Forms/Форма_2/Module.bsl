&НаСервере
Процедура ЗаполнитьТЧТехКарт(СсылкаТОР)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТехКарты.Ссылка КАК Ссылка,
		|	ТехКарты.гкс_Обслуживание КАК гкс_Обслуживание,
		|	ТехКарты.Статус КАК Статус,
		|	ТехКарты.ПометкаУдаления КАК ПометкаУдаления
		|ПОМЕСТИТЬ НужныеИТК
		|ИЗ
		|	Справочник.торо_ИдентификаторыТехКарт КАК ИТКГруппа
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ИдентификаторыТехКарт КАК ТехКарты
		|		ПО ИТКГруппа.Ссылка = ТехКарты.Родитель
		|			И (ТехКарты.ЭтоГруппа = ЛОЖЬ)
		|ГДЕ
		|	ИТКГруппа.гкс_Владелец = &СсылкаТОР
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НужныеИТК.Ссылка КАК ТК,
		|	НужныеИТК.гкс_Обслуживание КАК Обслуживание,
		|	НужныеИТК.Статус КАК Статус,
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта КАК ТехКарта,
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта.ДатаПринятия КАК ДатаПринятия,
		// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта.гкс_ПериодДействия КАК гкс_ПериодДействия,
		|	торо_ВерсииТехКартСрезПоследних.ТехКарта.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия,
		// } Гкс-[TOIR20-194] 
		|	НужныеИТК.ПометкаУдаления КАК ПометкаУдаления
		|ПОМЕСТИТЬ СТехКартами
		|ИЗ
		|	НужныеИТК КАК НужныеИТК
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВерсииТехКарт.СрезПоследних(
		|				,
		|				ИдентификаторТехКарты В
		|					(ВЫБРАТЬ
		|						ТЧ.Ссылка
		|					ИЗ
		|						НужныеИТК КАК ТЧ)) КАК торо_ВерсииТехКартСрезПоследних
		|		ПО НужныеИТК.Ссылка = торо_ВерсииТехКартСрезПоследних.ИдентификаторТехКарты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СТехКартами.ТК КАК ТК,
		|	СТехКартами.Обслуживание КАК Обслуживание,
		|	СТехКартами.Статус КАК Статус,
		|	СТехКартами.ТехКарта КАК ТехКарта,
		|	СТехКартами.ДатаПринятия КАК ДатаПринятия,
		// Гкс+[TOIR20-194] Селимов от 17.11.2020. Добавлено:{
		|	СТехКартами.гкс_ПериодДействия КАК гкс_ПериодДействия,
		|	СТехКартами.гкс_КоличествоПериодовДействия КАК гкс_КоличествоПериодовДействия,
		// } Гкс-[TOIR20-194] 
		|	СТехКартами.ПометкаУдаления КАК ПометкаУдаления
		|ИЗ
		|	СТехКартами КАК СТехКартами
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТК
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СТехКартами.ТехКарта КАК ТехКарта,
		|	торо_ТехКартыСписокОпераций.Операция КАК Операция,
		|	торо_ТехКартыСписокОпераций.Количество КАК Количество,
		|	торо_ТехКартыСписокОпераций.СпособВыполнения КАК СпособВыполнения,
		|	торо_ТехКартыСписокОпераций.гкс_Примечание КАК гкс_Примечание,
		|	торо_ТехКартыСписокОпераций.ID КАК УИД
		// Гкс+[TOIR20-98] Борисов В.М. от 21.05.2020. Добавлено:{
		|	,торо_ТехКартыСписокОпераций.НомерСтроки КАК НомерСтроки
		// } Гкс-[TOIR20-98] Борисов В.М. от 21.05.2020.
		|ИЗ
		|	СТехКартами КАК СТехКартами
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТехКарты.СписокОпераций КАК торо_ТехКартыСписокОпераций
		|		ПО СТехКартами.ТехКарта = торо_ТехКартыСписокОпераций.Ссылка
		// Гкс+[TOIR20-98] Борисов В.М. от 21.05.2020. Добавлено:{
		|УПОРЯДОЧИТЬ ПО
		|	торо_ТехКартыСписокОпераций.НомерСтроки
		// } Гкс-[TOIR20-98] Борисов В.М. от 21.05.2020.
		|ИТОГИ ПО
		|	ТехКарта";
	
	Запрос.УстановитьПараметр("СсылкаТОР", СсылкаТОР);	
	РезультатЗапроса = Запрос.ВыполнитьПакет();	
	ШаблоныТК.Очистить();
	ШаблоныТО.Очистить();
	Если РезультатЗапроса[2].Пустой() = Ложь Тогда 
		Выборка = РезультатЗапроса[2].Выбрать();	
		ВыборкаТО = РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
		Пока Выборка.Следующий() Цикл
			СтрокаТК = ШаблоныТК.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТК,Выборка);
			Если ВыборкаТО.НайтиСледующий(Новый Структура("ТехКарта", Выборка.ТехКарта)) Тогда 
				ВыборкаТОПодробно = ВыборкаТО.Выбрать();
				Пока ВыборкаТОПодробно.Следующий() Цикл
					СтрокаТО = ШаблоныТО.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТО, ВыборкаТОПодробно);
					СтрокаТО.ТК = Выборка.ТК;
				КонецЦикла;
			КонецЕсли;
			ВыборкаТО.Сбросить();
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ШаблоныТКПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.ШаблоныТК.ТекущиеДанные;
	Если Не ТекДанные = Неопределено Тогда 
		Если ЗначениеЗаполнено(ТекДанные.ТК) Тогда 
			Элементы.ШаблоныТО.ОтборСтрок = Новый ФиксированнаяСтруктура("ТК",ТекДанные.ТК);
		Иначе
			Элементы.ШаблоныТО.ОтборСтрок = Новый ФиксированнаяСтруктура("ИД",ТекДанные.ИД);
		КонецЕсли;
		ДоступностьПолей = ТекДанные.Статус = _СтатусВРаботе;
	Иначе
		Элементы.ШаблоныТО.ОтборСтрок = Новый ФиксированнаяСтруктура("ТК,ИД",Неопределено,Неопределено);
		ДоступностьПолей = Ложь;
	КонецЕсли;
	Если Элементы.ШаблоныТК.ИзменятьПорядокСтрок = Истина Тогда 
		Элементы.ШаблоныТО.ИзменятьСоставСтрок = ДоступностьПолей;
		Элементы.ШаблоныТО.ИзменятьПорядокСтрок = ДоступностьПолей;
		//
		Элементы.ШаблоныТООперация.ТолькоПросмотр = Не ДоступностьПолей;
		Элементы.ШаблоныТОКоличество.ТолькоПросмотр = Не ДоступностьПолей;
		Элементы.ШаблоныТОСпособВыполнения.ТолькоПросмотр = Не ДоступностьПолей;
		Элементы.ШаблоныТОтк_СдвинутьТОВниз.Доступность = ДоступностьПолей;
		Элементы.ШаблоныТОтк_СдвинутьТОВверх.Доступность = ДоступностьПолей;
		Элементы.ШаблоныТОтк_ДобавитьТО.Доступность = ДоступностьПолей;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьДоступностьТЧТехКарт()
	
	ПравоРедактирования = (РольДоступна("ПолныеПрава")
	// гкс+ [Релиз19] Деснол
	ИЛИ РольДоступна("гкс_РедактированиеЗаявкиНаРемонт")
	// гкс- [Релиз19]
	ИЛИ РольДоступна("гкс_ИзменениеШаблоновТехКарт")) И ЗначениеЗаполнено(дс_Ссылка);
	Элементы.ШаблоныТК.ИзменятьСоставСтрок = ПравоРедактирования;
	Элементы.ШаблоныТК.ИзменятьПорядокСтрок = ПравоРедактирования;
	Элементы.ШаблоныТО.ИзменятьСоставСтрок = ПравоРедактирования;
	Элементы.ШаблоныТО.ИзменятьПорядокСтрок = ПравоРедактирования;
	//
	Элементы.ШаблоныТКОбслуживание.ТолькоПросмотр = Не ПравоРедактирования;
	Элементы.ШаблоныТКДатаПринятия.ТолькоПросмотр = Не ПравоРедактирования;
	Элементы.ШаблоныТКСтатус.ТолькоПросмотр = Не ПравоРедактирования;
	Элементы.ШаблоныТООперация.ТолькоПросмотр = Не ПравоРедактирования;
	Элементы.ШаблоныТОКоличество.ТолькоПросмотр = Не ПравоРедактирования;
	Элементы.ШаблоныТОСпособВыполнения.ТолькоПросмотр = Не ПравоРедактирования;
	Элементы.ШаблоныТКСохранитьИзмененияТЧТехКарт.Доступность = ПравоРедактирования;
	Элементы.ШаблоныТОтк_СдвинутьТОВниз.Доступность = ПравоРедактирования;
	Элементы.ШаблоныТОтк_СдвинутьТОВверх.Доступность = ПравоРедактирования;
	Элементы.ШаблоныТОтк_ДобавитьТО.Доступность = ПравоРедактирования;
КонецПроцедуры

&НаКлиенте
Процедура ШаблоныТОПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	Если Не ОтменаРедактирования Тогда 
		ТекДанныеТК = Элементы.ШаблоныТК.ТекущиеДанные;
		ТекДанные = Элементы.ШаблоныТО.ТекущиеДанные;
		Если Не ТекДанные = Неопределено Тогда 
			Если Не ТекДанныеТК = Неопределено Тогда 
				ТекДанные.ТК = ТекДанныеТК.ТК;
				ТекДанные.ИД = ТекДанныеТК.ИД;
				МодифицированностьТЧТехКарт = Истина;
				ТекДанныеТК.Изменен = Истина;
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекДанные.Количество) = Ложь Тогда 
				ТекДанные.Количество = 1;
				МодифицированностьТЧТехКарт = Истина;
				ТекДанныеТК.Изменен = Истина;
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекДанные.СпособВыполнения) = Ложь Тогда 
				ТекДанные.СпособВыполнения = _ХозСпособ;
				МодифицированностьТЧТехКарт = Истина;
				ТекДанныеТК.Изменен = Истина;
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекДанные.УИД) = Ложь Тогда 
				ТекДанные.УИД = Строка(Новый УникальныйИдентификатор());
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

