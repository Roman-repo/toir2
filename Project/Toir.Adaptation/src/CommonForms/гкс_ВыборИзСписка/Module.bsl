#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Сценарий") Тогда 
		Если Параметры.Сценарий = "ВыборИсполнителяДокумента" Тогда 
			Заголовок = НСтр("es='Select el ejecutors';ru='Выберите исполнителей';en='Select executors'");;
			Элементы.ТабСпискаКлюч.Заголовок = НСтр("es='El ejecutor';ru='Исполнитель';en='Executor'");
		КонецЕсли;
	КонецЕсли;
	Если Параметры.Свойство("Список") Тогда 
		Если ТипЗнч(Параметры.Список) = Тип("СписокЗначений") Тогда 
			Для Каждого КлючЗначение Из Параметры.Список Цикл
				НоваяСтрока = ТабСписка.Добавить();
				НоваяСтрока.Ключ = КлючЗначение.Представление;
				НоваяСтрока.Значение = КлючЗначение.Значение;
			КонецЦикла;
		Иначе
			Для Каждого КлючЗначение Из Параметры.Список Цикл
				НоваяСтрока = ТабСписка.Добавить();
				НоваяСтрока.Ключ = КлючЗначение.Ключ;
				НоваяСтрока.Значение = КлючЗначение.Значение;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Готово(Команда)
	МассивВозврата = Новый Массив();
	Для Каждого СтрокаТаблицы Из ТабСписка Цикл
		Если СтрокаТаблицы.Выбран Тогда 
			МассивВозврата.Добавить(СтрокаТаблицы.Значение);
		КонецЕсли;
	КонецЦикла;
	Закрыть(МассивВозврата);
КонецПроцедуры

#КонецОбласти

