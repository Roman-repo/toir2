
&ИзменениеИКонтроль("ПеревестиДинамическийСписок")
Процедура Расш_гкс_ПеревестиДинамическийСписок(ЭтаФорма, Список, Реквизиты, Метаданные)
	#Вставка
	Язык = торо_ОбщегоНазначенияПовтИсп.ТекущийЯзыкИБ();
	#КонецВставки
	#Удаление
	Язык = торо_Локализация.ТекущийЯзыкИБ();
	#КонецУдаления

	Если Реквизиты <> Неопределено Тогда
		СтроковыеПоля = СтрРазделить(Реквизиты, ",");
		Для каждого Поле Из СтроковыеПоля Цикл
			Элемент = ЭтаФорма.Элементы.Найти(Поле);
			Если Элемент <> Неопределено Тогда
				СтандартныеЗаголовки = Новый Соответствие;
				СтандартныеЗаголовки.Вставить("Наименование", НСтр("en='Name';ru='Наименование'"));
				СтандартныеЗаголовки.Вставить("Код", НСтр("en='Code';ru='Код'"));

				Если СтандартныеЗаголовки[Поле] = Неопределено Тогда
					Элемент.Заголовок = Метаданные.Реквизиты[Поле].Синоним;
				Иначе
					Элемент.Заголовок = СтандартныеЗаголовки[Поле];
				КонецЕсли; 
			КонецЕсли; 
		КонецЦикла; 
	Иначе
		СтроковыеПоля = Реквизиты;
	КонецЕсли; 

	Список.ТекстЗапроса = ПолучитьТекстЗапросаСПереводами(Список.ТекстЗапроса, СтроковыеПоля);
	Список.Параметры.УстановитьЗначениеПараметра("Язык", Язык);
КонецПроцедуры

&ИзменениеИКонтроль("ДобавитьНастройкуЯзыкаВПользовательскихНастройках")
Процедура Расш_гкс_ДобавитьНастройкуЯзыкаВПользовательскихНастройках(ЭтаФорма)
	ДобавляемыеРеквизиты = Новый Массив;

	ЗаголовокЭлемента = НСтр("es='Idioma de edición';ru='Язык редактирования';en='Editing language'");
	ЯзыкРедактирования = Новый РеквизитФормы("дс_ЯзыкРедактирования",
	Новый ОписаниеТипов("СправочникСсылка.торо_Языки"), , ЗаголовокЭлемента, Истина);

	ДобавляемыеРеквизиты.Добавить(ЯзыкРедактирования);
	ЭтаФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	ЭлементЯзыкРедактирования = ЭтаФорма.Элементы.Вставить("дс_ЯзыкРедактирования", Тип("ПолеФормы"),
	ЭтаФорма.Элементы.НастройкиТОиР, ЭтаФорма.Элементы.Декорация5);
	ЭлементЯзыкРедактирования.Вид = ВидПоляФормы.ПолеВвода;
	ЭлементЯзыкРедактирования.ПутьКДанным = "дс_ЯзыкРедактирования";

	#Вставка
	ЭтаФорма.дс_ЯзыкРедактирования = торо_ОбщегоНазначенияПовтИсп.ТекущийЯзыкИБ();
	#КонецВставки
	ЭтаФорма.дс_ЯзыкРедактирования = торо_Локализация.ТекущийЯзыкИБ();
	#Удаление
	#КонецУдаления
КонецПроцедуры
