&ИзменениеИКонтроль("ОбработатьДанные")
Процедура Расш_гкс_ОбработатьДанные()
	#Удаление
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	торо_ДанныеАСУТП.МеткаВремени КАК МеткаВремени,
	               |	торо_ДанныеАСУТП.ИДСеанса КАК ИДСеанса
	               |ИЗ
	               |	РегистрСведений.торо_ДанныеАСУТП КАК торо_ДанныеАСУТП
	               |ГДЕ
	               |	торо_ДанныеАСУТП.Ошибка = ЛОЖЬ
	               |	И торо_ДанныеАСУТП.Обработан = ЛОЖЬ
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	МеткаВремени";
	
	резЗапроса = Запрос.Выполнить();
	Если резЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = резЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ОбработатьПоСеансу(Выборка.ИДСеанса);
		СформироватьПочтовыеУведомление(Выборка.ИДСеанса);
	КонецЦикла;
	#КонецУдаления
	#Вставка
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	торо_ДанныеАСУТП.ИДСеанса КАК ИДСеанса,
	               |	торо_ДанныеАСУТП.Подключение КАК Подключение
	               |ИЗ
	               |	РегистрСведений.торо_ДанныеАСУТП КАК торо_ДанныеАСУТП
	               |ГДЕ
	               |	торо_ДанныеАСУТП.Ошибка = ЛОЖЬ
	               |	И торо_ДанныеАСУТП.Обработан = ЛОЖЬ
	               |ИТОГИ ПО
	               |	Подключение";

	резЗапроса = Запрос.Выполнить();
	Если резЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	Выборка1 = резЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка1.Следующий() Цикл
		ТемпМассив = Новый Массив();
		Выборка = Выборка1.Выбрать();
		Пока Выборка.Следующий() Цикл
			ТемпМассив.Добавить(Выборка.ИДСеанса);
		КонецЦикла;
		
		ОбработатьПоСеансу(ТемпМассив);
		СформироватьПочтовыеУведомление(ТемпМассив);
	КонецЦикла;
	#КонецВставки
	
КонецПроцедуры

&ИзменениеИКонтроль("СформироватьПочтовыеУведомление")
Процедура Расш_гкс_СформироватьПочтовыеУведомление(ИДСеанса)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	торо_СобытияИнтеграцииСАСУТП.Ошибка КАК Ошибка
	|ИЗ
	|	РегистрСведений.торо_СобытияИнтеграцииСАСУТП КАК торо_СобытияИнтеграцииСАСУТП
	|ГДЕ
	#Удаление
	|	торо_СобытияИнтеграцииСАСУТП.ИДСеанса = &ИДСеанса
	#КонецУдаления
	#Вставка
	|	торо_СобытияИнтеграцииСАСУТП.ИДСеанса В (&ИДСеанса)
	#КонецВставки
	|	И торо_СобытияИнтеграцииСАСУТП.ТипСобытия = &ТипСобытия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	торо_СписокОповещаемыхЛиц.ОповещаемоеЛицо КАК ОповещаемоеЛицо
	|ИЗ
	|	РегистрСведений.торо_СписокОповещаемыхЛиц КАК торо_СписокОповещаемыхЛиц";

	Запрос.УстановитьПараметр("ИДСеанса", ИДСеанса);
	Запрос.УстановитьПараметр("ТипСобытия", Перечисления.торо_СобытияИнтеграции.Ошибка);

	резЗапроса = Запрос.ВыполнитьПакет();

	Если резЗапроса[0].Пустой() или резЗапроса[1].Пустой() Тогда
		Возврат;
	КонецЕсли;

	СписокОшибок = резЗапроса[0].Выбрать();
	СписокЛиц = резЗапроса[1].Выбрать();

	ТемаПисьма = "Ошибка при обмене с АСУ ТП (" + ТекущаяДата() + "). Зафиксировано " + СписокОшибок.Количество() + " ошибок.";
	ТелоПисьма = "";
	Пока СписокОшибок.Следующий() Цикл
		Если ТелоПисьма = "" Тогда
			ТелоПисьма = СписокОшибок.Ошибка + ";";
		Иначе 
			ТелоПисьма = ТелоПисьма + Символы.ПС + "===============" + Символы.ПС + СписокОшибок.Ошибка + ";";
		КонецЕсли;
	КонецЦикла;

	Пока СписокЛиц.следующий() Цикл
		мз = РегистрыСведений.торо_ОчередьУведомлений.СоздатьМенеджерЗаписи();
		мз.Пользователь = СписокЛиц.ОповещаемоеЛицо;
		мз.ID_уведомления = Новый УникальныйИдентификатор;
		мз.СпособУведомления = Перечисления.торо_СпособыУведомленияПользователей.УведомлениеПоЭлектроннойПочте;
		мз.ТемаПисьма = ТемаПисьма;
		мз.ТелоПисьма = ТелоПисьма;
		мз.Записать();
	КонецЦикла;

КонецПроцедуры

&ИзменениеИКонтроль("ОбработатьСигналСостояние")
Процедура Расш_гкс_ОбработатьСигналСостояние(Выборка, масСозданныхДокументов, сооДокументыИИсхДанные)
	#Вставка
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации КАК ВидЭксплуатации
		|ИЗ
		|	РегистрСведений.торо_ТекущееСостояниеОР.СрезПоследних(, ОбъектРемонта = &ОР) КАК торо_ТекущееСостояниеОРСрезПоследних
		|ГДЕ
		|	НЕ торо_ТекущееСостояниеОРСрезПоследних.ВидЭксплуатации = &ВидЭксплуатации";
	
	Запрос.УстановитьПараметр("ВидЭксплуатации", Выборка.Состояние);
	Запрос.УстановитьПараметр("ОР", Выборка.ОР);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	#КонецВставки
	докОб = Документы.торо_СостоянияОбъектовРемонта.СоздатьДокумент();
	ЗаполнитьЗначенияСвойств(докОб, Выборка);
	докОб.Дата = ТекущаяДата();
	докОб.Комментарий = НСтр("ru='Документ сформирован автоматически при загрузке данных АСУ ТП.'");
	#Вставка
	докОб.Комментарий = НСтр("es='El documento es formado automáticamente a la carga de los SISTEMAS"
		+ " informatizados de gestión ТП dados.';ru='Документ сформирован автоматически при загрузке данных"
		+ " АСУ ТП.';en='The document is generated automatically when loading the data from the automatic"
		+ " process control system.'");
	#КонецВставки
	докОб.ВидОперации = Перечисления.торо_ВидыОперацийОтклоненияВРаботеОборудования.ВидЭксплуатации;

	нс = докОб.ОбъектыРемонта.Добавить();
	нс.ДатаОкончания = Выборка.Дата;
	нс.ОбъектРемонта = Выборка.ОР;
	нс.ВидЭксплуатации = Выборка.Состояние;
	нс.ПричинаПростоя = Выборка.ПричинаПростоя;

	докОб.Записать(РежимЗаписиДокумента.Запись);
	масСозданныхДокументов.Добавить(докОб.Ссылка);
	Если сооДокументыИИсхДанные[докОб.Ссылка] = Неопределено Тогда
		сооДокументыИИсхДанные.Вставить(докОб.Ссылка, выборка);
	КонецЕсли;
КонецПроцедуры

&ИзменениеИКонтроль("ОбработатьПоСеансу")
Процедура Расш_гкс_ОбработатьПоСеансу(ИДСеанса, НомерПопытки)

	Если НомерПопытки > 100 Тогда
		Возврат;
	КонецЕсли;

	ОсновнаяИерархия = Константы.торо_ИерархияДляВводаНовыхОР.Получить();
	УдалятьОбработанныеЗаписи = Константы.торо_УдалятьОбработанныеЗаписиАСУТП.Получить();
	СоздаватьДефекты = ПолучитьФункциональнуюОпцию("торо_ИспользоватьРемонтыПоСостоянию");
	СоздаватьДокументыКПИ = ПолучитьФункциональнуюОпцию("торо_ПоказыватьПодсистемуKPI");
