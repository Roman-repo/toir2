		//	ИначеЕсли (СтрокаТаблицы.УстанавливаемыйСтатус = Перечисления.торо_СтатусыДокументов.Выполняется
		//		И СтрокаТаблицы.ТипДокумента = Документы.торо_ЗаявкаНаРемонт.ПустаяСсылка() И СтрокаТаблицы.Порядок = 2) Тогда 
		//		СтрокаТаблицы.УстанавливаемыйСтатус = Перечисления.торо_СтатусыДокументов.Выполнен;
		//		СтрокаТаблицы.Порядок = 3;
		//	ИначеЕсли (СтрокаТаблицы.УстанавливаемыйСтатус = Перечисления.торо_СтатусыДокументов.Выполняется
