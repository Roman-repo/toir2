#Область СлужебныеПроцедурыИФункции

Функция ПроверитьВозможностьИзмененияСтатусаДефекта(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	торо_ЗаявкаНаРемонт.Ссылка КАК Заявка,
		|	торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка КАК Акт
		|ПОМЕСТИТЬ ЗаявкаСФлагом
		|ИЗ
		|	Документ.торо_АктОВыполненииЭтапаРабот.ДокументыОснования КАК торо_АктОВыполненииЭтапаРаботДокументыОснования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт КАК торо_ЗаявкаНаРемонт
		|		ПО (торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка = &Ссылка)
		|			И торо_АктОВыполненииЭтапаРаботДокументыОснования.ДокументОснование = торо_ЗаявкаНаРемонт.Ссылка
		|			И (торо_ЗаявкаНаРемонт.гкс_НуженИспытание = ""ДА"")
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	торо_ЗаявкаНаРемонт.Ссылка,
		|	торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка
		|ИЗ
		|	Документ.торо_АктОВыполненииЭтапаРабот.ДокументыОснования КАК торо_АктОВыполненииЭтапаРаботДокументыОснования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_НарядНаВыполнениеРемонтныхРабот.ДокументыОснования КАК торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт КАК торо_ЗаявкаНаРемонт
		|			ПО (торо_ЗаявкаНаРемонт.гкс_НуженИспытание = ""ДА"")
		|				И торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования.ДокументОснование = торо_ЗаявкаНаРемонт.Ссылка
		|		ПО (торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка = &Ссылка)
		|			И торо_АктОВыполненииЭтапаРаботДокументыОснования.ДокументОснование = торо_НарядНаВыполнениеРемонтныхРаботДокументыОснования.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаявкаСФлагом.Заявка КАК Заявка,
		|	ЗаявкаСФлагом.Акт КАК Акт,
		// Гкс+[TOIR20-558] Вялых Д.А. от 06.03.2025. Добавлено:{
		|	торо_ЗаявкаНаРемонтДокументыОснования.ДокументОснование КАК Дефект
		//|	торо_ВыявленныеДефекты.Ссылка КАК Дефект 
		// } Гкс-[TOIR20-558] Вялых Д.А. от 05.03.2025.
		|ПОМЕСТИТЬ ВсяЦепочка
		|ИЗ
		|	ЗаявкаСФлагом КАК ЗаявкаСФлагом
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.ДокументыОснования КАК торо_ЗаявкаНаРемонтДокументыОснования
		// Гкс+[TOIR20-558] Вялых Д.А. от 06.03.2025. Добавлено:{
		//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ВыявленныеДефекты КАК торо_ВыявленныеДефекты
		//|			ПО торо_ЗаявкаНаРемонтДокументыОснования.ДокументОснование = торо_ВыявленныеДефекты.Ссылка
		// } Гкс-[TOIR20-558] Вялых Д.А. от 05.03.2025.
		|		ПО ЗаявкаСФлагом.Заявка = торо_ЗаявкаНаРемонтДокументыОснования.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЕСТЬNULL(торо_АктПриемкиОборудованияДокументыОснования.Ссылка.Проведен, ЛОЖЬ)) КАК АктПроведен
		|ИЗ
		|	ВсяЦепочка КАК ВсяЦепочка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_АктПриемкиОборудования.ДокументыОснования КАК торо_АктПриемкиОборудованияДокументыОснования
		|		ПО (ВсяЦепочка.Заявка = торо_АктПриемкиОборудованияДокументыОснования.ДокументОснование
		|				ИЛИ ВсяЦепочка.Акт = торо_АктПриемкиОборудованияДокументыОснования.ДокументОснование
		|				ИЛИ ВсяЦепочка.Дефект = торо_АктПриемкиОборудованияДокументыОснования.ДокументОснование)";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() = Ложь Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() И Выборка.АктПроведен = Ложь Тогда 
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;
КонецФункции 

&ИзменениеИКонтроль("ПолучитьТаблицуУстанавливаемыхСтатусовПоСсылке")
