		ЧтениеJSON	= Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
		СтруктураВозврата	= СериализаторXDTO.ПрочитатьJSON(ЧтениеJSON); 
		
		НавигационнаяСсылка = СтруктураВозврата.Данные;
		
	Иначе
		
		ЗаписьЖурналаРегистрации("Интеграция ERP2.Получение навигационной ссылки",
		УровеньЖурналаРегистрации.Ошибка, 
		, 
		, 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru='Ошибка запроса к сервису код : %1'"), Ответ.КодСостояния));
					
	КонецЕсли;
	
	Возврат НавигационнаяСсылка;
	
КонецФункции

// Предоставляет данные для сводного отчета ERP2.
// Вызывается из http-сервиса ERP2IntegrationService /SummaryReport
// 
// Параметры:
//  СтруктураПараметров - Структура - 
// 
// Возвращаемое значение:
//  Структура - Получить данные для сводного отчета ERP2:
// * Данные - ТаблицаЗначений - :
// ** ЗаявкаТОиР - Строка 
// ** НомерТОиР - Строка
// ** ОписаниеРаботТОиР - Строка
// ** НуженОстанов - Строка
// ** ДатаСозданияТОиР - Дата
// ** АктуальнаяДатаНачалаРабот - Дата
// ** АктуальнаяДатаОкончанияРабот - Дата
// ** СтатусЗаявкиТОиР - Строка
// ** ЭтапСогласованияТОиР - Строка
// ** ДатаНаправленияВОтделЗУ - Дата
// ** ДатаНачалаОбработкиЗаявки - Дата
// ** ЗаявкаВРаботеДней - Число
// ** ДатаВыбораПоставщика - Дата
Функция ПолучитьДанныеДляСводногоОтчетаERP2(СтруктураПараметров) Экспорт 

	РезультатВозврата	= Новый Структура;		        
	ТаблицаВозврата	= Новый ТаблицаЗначений;
	ТаблицаВозврата.Колонки.Добавить("ЗаявкаТОиР", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ТаблицаВозврата.Колонки.Добавить("НомерТОиР", ОбщегоНазначения.ОписаниеТипаСтрока(11));
	ТаблицаВозврата.Колонки.Добавить("ОписаниеРаботТОиР", ОбщегоНазначения.ОписаниеТипаСтрока(255));
	ТаблицаВозврата.Колонки.Добавить("НуженОстанов", ОбщегоНазначения.ОписаниеТипаСтрока(10));
	ТаблицаВозврата.Колонки.Добавить("ДатаСозданияТОиР", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ТаблицаВозврата.Колонки.Добавить("АктуальнаяДатаНачалаРабот", ОбщегоНазначения.ОписаниеТипаДата(
		ЧастиДаты.ДатаВремя));
	ТаблицаВозврата.Колонки.Добавить("АктуальнаяДатаОкончанияРабот", ОбщегоНазначения.ОписаниеТипаДата(
		ЧастиДаты.ДатаВремя));
	ТаблицаВозврата.Колонки.Добавить("СтатусЗаявкиТОиР", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ТаблицаВозврата.Колонки.Добавить("ЭтапСогласованияТОиР", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ТаблицаВозврата.Колонки.Добавить("ДатаНаправленияВОтделЗУ", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ТаблицаВозврата.Колонки.Добавить("ДатаНачалаОбработкиЗаявки", ОбщегоНазначения.ОписаниеТипаДата(
		ЧастиДаты.ДатаВремя));
	ТаблицаВозврата.Колонки.Добавить("ЗаявкаВРаботеДней", ОбщегоНазначения.ОписаниеТипаЧисло(5));
	ТаблицаВозврата.Колонки.Добавить("ДатаВыбораПоставщика", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));

	НомераЗаявок = "";
	Если СтруктураПараметров.Свойство("НомераЗаявок") Тогда
	   	НомераЗаявок	= СтруктураПараметров.НомераЗаявок;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НомераЗаявок) Тогда

		ВыбранаПодряднаяОрганизация = 
			ПланыВидовХарактеристик.гкс_ПроизвольныеПредопределенныеОбъекты.ПроизвольныйПредопределенныйОбъект(
			"СтатусСогласованияВыбранаПодряднаяОрганизация");
		ДляСМТСОтГлСпециалиста = 
			ПланыВидовХарактеристик.гкс_ПроизвольныеПредопределенныеОбъекты.ПроизвольныйПредопределенныйОбъект(
			"СтатусСогласованияДляСМТСОтГлСпециалиста");
		ПринятоВРаботуСМТС = 
			ПланыВидовХарактеристик.гкс_ПроизвольныеПредопределенныеОбъекты.ПроизвольныйПредопределенныйОбъект(
			"СтатусСогласованияПринятоВРаботуСМТС");

		Настройка = Справочники.гкс_ПроизвольныеНастройкиИнтеграций.СтатусыЗаявокКВыгрузке;
		СоответствиеСтатусовЗаявок = Справочники.гкс_ПроизвольныеНастройкиИнтеграций.ПолучитьСвойства(Настройка,
			"Свойства");
		МассивСтатусовЗаявок = Новый Массив;

		Для Каждого Элемент Из СоответствиеСтатусовЗаявок Цикл
			Если Элемент.Значение = ПринятоВРаботуСМТС Тогда
				Продолжить;
			КонецЕсли;
			МассивСтатусовЗаявок.Добавить(Элемент.Значение);
		КонецЦикла;

		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапросаДанныеПоЗаявкам();
		
		Запрос.УстановитьПараметр("НомераЗаявок", НомераЗаявок);
		Запрос.УстановитьПараметр("ВыбранаПодряднаяОрганизация", ВыбранаПодряднаяОрганизация);
		Запрос.УстановитьПараметр("ДляСМТСОтГлСпециалиста", ДляСМТСОтГлСпециалиста); 
		Запрос.УстановитьПараметр("ПринятоВРаботуСМТС", ПринятоВРаботуСМТС);
		Запрос.УстановитьПараметр("СтатусыЗаявок", МассивСтатусовЗаявок);
		Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = ТаблицаВозврата.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		КонецЦикла;

	КонецЕсли;
		
	РезультатВозврата.Вставить("Данные", ТаблицаВозврата);
	
	Возврат РезультатВозврата;
		
КонецФункции


#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЛогинПарольПользователя(ВебСервис)
	
	ИспользоватьАутентификациюОС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВебСервис,
		"ИспользоватьАутентификациюОС");
	
	Аутентификация = Новый Структура("ИспользоватьАутентификациюОС, Пользователь, Пароль",
		ИспользоватьАутентификациюОС, "", "");
	
	УстановитьПривилегированныйРежим(Истина);
	
	ИмяПароль = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(ВебСервис, "ИмяПарольПользователя");
	
	Если ЗначениеЗаполнено(ИмяПароль) Тогда
		Аутентификация.Пользователь = ИмяПароль.ИмяПользователя;
		Аутентификация.Пароль = ИмяПароль.ПарольПользователя; 		
	КонецЕсли;
	
	Возврат Аутентификация;
	
КонецФункции

Функция РеквизитыВыполненияВебСервиса(ВебСервис)
	
	ИменаРеквизитов = Новый Структура();
	ИменаРеквизитов.Вставить("СтрокаЗапроса", "URL");
	ИменаРеквизитов.Вставить("ИмяМетода", "Метод");
	
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВебСервис, ИменаРеквизитов);
	
КонецФункции

Функция СтрокаАвторизацииЗапроса(ПараметрыПодключения)
	
	ИмяПользователя = ПараметрыПодключения.Пользователь;
	Пароль = ПараметрыПодключения.Пароль;
	
	ШаблонСтроки = "%1:%2";
	СтрокаАвторизации = СтрШаблон(ШаблонСтроки, ИмяПользователя, Пароль);
	ДвоичныеДанныеСтроки = 
		ПолучитьДвоичныеДанныеИзСтроки(СтрокаАвторизации, КодировкаТекста.UTF8, Ложь);
		
	Возврат 
		СтрШаблон("%1%2", "Basic " , ПолучитьBase64СтрокуИзДвоичныхДанных(ДвоичныеДанныеСтроки));
		
КонецФункции
	
Функция ЗаголовокЗапроса(СтрокаАвторизации)
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json"); // "application/json; charset=utf-8"
	Заголовки.Вставить("Authorization", СтрокаАвторизации);
	Заголовки.Вставить("Accept", "application/json"); // "application/json; charset=utf-8"
	
	Возврат Заголовки;

КонецФункции

Функция ТекстЗапросаДанныеПоЗаявкам()
	
Возврат "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	        |	ЗаявкаНаРемонт.Ссылка КАК Заявка,
	        |	ЗаявкаНаРемонт.Номер КАК Номер,
	        |	ЗаявкаНаРемонт.Дата КАК ДатаСоздания,
	        |	ЗаявкаНаРемонт.гкс_НуженОстанов КАК НуженОстанов,
	        |	ЕСТЬNULL(ЗаявкаНаРемонтРемонтыОборудования.ОписаниеРемонта, """") КАК ОписаниеРемонта,
	        |	ЕСТЬNULL(АктуальныеПлановыеДатыРемонтов.ДатаНачала, ДАТАВРЕМЯ(1, 1, 1)) КАК АктуальнаяДатаНачалаРабот,
	        |	ЕСТЬNULL(АктуальныеПлановыеДатыРемонтов.ДатаОкончания, ДАТАВРЕМЯ(1, 1, 1)) КАК АктуальнаяДатаОкончанияРабот,
	        |	ЕСТЬNULL(ТекущиеСтатусыСогласованияДокументов.СтатусДокумента, ЗНАЧЕНИЕ(Справочник.торо_СтатусыСогласованияДокументовРемонтныхРабот.ПустаяСсылка)) КАК ЭтапСогласования
	        |ПОМЕСТИТЬ ВТЗаявки
	        |ИЗ
	        |	Документ.торо_ЗаявкаНаРемонт КАК ЗаявкаНаРемонт
	        |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК ЗаявкаНаРемонтРемонтыОборудования
	        |			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК АктуальныеПлановыеДатыРемонтов
	        |			ПО ЗаявкаНаРемонтРемонтыОборудования.ID = АктуальныеПлановыеДатыРемонтов.IDРемонта
	        |		ПО ЗаявкаНаРемонт.Ссылка = ЗаявкаНаРемонтРемонтыОборудования.Ссылка
	        |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущиеСтатусыСогласованияДокументов КАК ТекущиеСтатусыСогласованияДокументов
	        |		ПО ЗаявкаНаРемонт.Ссылка = ТекущиеСтатусыСогласованияДокументов.СогласуемыйДокумент
	        |ГДЕ
	        |	ЗаявкаНаРемонт.Номер В(&НомераЗаявок)
	        |
	        |ИНДЕКСИРОВАТЬ ПО
	        |	Заявка
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	        |	СтатусыДокументовЗаявокСрезПоследних.ИзменяемыйДокумент КАК ИзменяемыйДокумент,
	        |	СтатусыДокументовЗаявокСрезПоследних.СтатусДокумента КАК СтатусДокумента
	        |ПОМЕСТИТЬ ВТСтатусы
	        |ИЗ
	        |	РегистрСведений.торо_СтатусыДокументовЗаявок.СрезПоследних(
	        |			,
	        |			СтатусУстановлен
	        |				И ИзменяемыйДокумент В
	        |					(ВЫБРАТЬ
	        |						ВТЗаявки.Заявка КАК Заявка
	        |					ИЗ
	        |						ВТЗаявки КАК ВТЗаявки)) КАК СтатусыДокументовЗаявокСрезПоследних
	        |
	        |ИНДЕКСИРОВАТЬ ПО
	        |	ИзменяемыйДокумент
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	        |	ИсторияСтатусовСогласованияДокументов.СогласуемыйДокумент КАК СогласуемыйДокумент,
	        |	МАКСИМУМ(ВЫБОР
	        |			КОГДА ИсторияСтатусовСогласованияДокументов.СтатусДокумента В (&СтатусыЗаявок)
	        |				ТОГДА ИсторияСтатусовСогласованияДокументов.Период
	        |		КОНЕЦ) КАК ДатаНаправленияВОтделЗакупок,
	        |	МАКСИМУМ(ВЫБОР
	        |			КОГДА ИсторияСтатусовСогласованияДокументов.СтатусДокумента = &ПринятоВРаботуСМТС
	        |				ТОГДА ИсторияСтатусовСогласованияДокументов.Период
	        |		КОНЕЦ) КАК ДатаНачалаОбработкиЗаявки,
	        |	МАКСИМУМ(ВЫБОР
	        |			КОГДА ИсторияСтатусовСогласованияДокументов.СтатусДокумента = &ВыбранаПодряднаяОрганизация
	        |				ТОГДА ИсторияСтатусовСогласованияДокументов.Период
	        |		КОНЕЦ) КАК ДатаНазначенияПодряднойОрганизации
	        |ПОМЕСТИТЬ ВТИсторияСогласования
	        |ИЗ
	        |	РегистрСведений.торо_ИсторияСтатусовСогласованияДокументов КАК ИсторияСтатусовСогласованияДокументов
	        |ГДЕ
	        |	ИсторияСтатусовСогласованияДокументов.СогласуемыйДокумент В
	        |			(ВЫБРАТЬ
	        |				ВТЗаявки.Заявка КАК Заявка
	        |			ИЗ
	        |				ВТЗаявки КАК ВТЗаявки)
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	ИсторияСтатусовСогласованияДокументов.СогласуемыйДокумент
	        |
	        |ИНДЕКСИРОВАТЬ ПО
	        |	СогласуемыйДокумент
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ПРЕДСТАВЛЕНИЕ(ВТЗаявки.Заявка) КАК ЗаявкаТОиР,
	        |	ВТЗаявки.Номер КАК НомерТОиР,
	        |	ВТЗаявки.ДатаСоздания КАК ДатаСозданияТОиР,
	        |	ВТЗаявки.ОписаниеРемонта КАК ОписаниеРаботТОиР,
	        |	ВТЗаявки.НуженОстанов КАК НуженОстанов,
	        |	ВТЗаявки.АктуальнаяДатаНачалаРабот КАК АктуальнаяДатаНачалаРабот,
	        |	ВТЗаявки.АктуальнаяДатаОкончанияРабот КАК АктуальнаяДатаОкончанияРабот,
	        |	ПРЕДСТАВЛЕНИЕ(ВТЗаявки.ЭтапСогласования) КАК ЭтапСогласованияТОиР,
	        |	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(ВТСтатусы.СтатусДокумента), """") КАК СтатусЗаявкиТОиР,
	        |	ЕСТЬNULL(ВТИсторияСогласования.ДатаНаправленияВОтделЗакупок, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаНаправленияВОтделЗУ,
	        |	ЕСТЬNULL(ВТИсторияСогласования.ДатаНачалаОбработкиЗаявки, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаНачалаОбработкиЗаявки,
	        |	ВЫБОР
	        |		КОГДА НЕ ВТИсторияСогласования.ДатаНачалаОбработкиЗаявки ЕСТЬ NULL
	        |			ТОГДА ВЫБОР
	        |					КОГДА НЕ ВТИсторияСогласования.ДатаНазначенияПодряднойОрганизации ЕСТЬ NULL
	        |						ТОГДА РАЗНОСТЬДАТ(ВТИсторияСогласования.ДатаНачалаОбработкиЗаявки, ВТИсторияСогласования.ДатаНазначенияПодряднойОрганизации, ДЕНЬ)
	        |					ИНАЧЕ РАЗНОСТЬДАТ(ВТИсторияСогласования.ДатаНачалаОбработкиЗаявки, &ТекущаяДата, ДЕНЬ)
	        |				КОНЕЦ
	        |		ИНАЧЕ 0
	        |	КОНЕЦ КАК ЗаявкаВРаботеДней,
	        |	ЕСТЬNULL(ВТИсторияСогласования.ДатаНазначенияПодряднойОрганизации, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаВыбораПоставщика
	        |ИЗ
	        |	ВТЗаявки КАК ВТЗаявки
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусы КАК ВТСтатусы
	        |		ПО ВТЗаявки.Заявка = ВТСтатусы.ИзменяемыйДокумент
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсторияСогласования КАК ВТИсторияСогласования
	        |		ПО ВТЗаявки.Заявка = ВТИсторияСогласования.СогласуемыйДокумент";
	
	
КонецФункции	

#КонецОбласти


