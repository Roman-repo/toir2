Функция ПолучитьДанныеОтчетОбеспечениеРемонтовТМЦ(ЗаявкаНаРемонт, СписокНоменклатуры) Экспорт  
		
	ТаблицаВозврата	= Новый ТаблицаЗначений; 
	
	ТаблицаВозврата= Новый ТаблицаЗначений;
	ТаблицаВозврата.Колонки.Добавить("ЗаявкаНаРемонт");
	ТаблицаВозврата.Колонки.Добавить("Номенклатура");   //Номенклатуры
	ТаблицаВозврата.Колонки.Добавить("ТоварнаяКатегория", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ТаблицаВозврата.Колонки.Добавить("СвободныеОстатки", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	ТаблицаВозврата.Колонки.Добавить("ВНаличииИтого", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	ТаблицаВозврата.Колонки.Добавить("Склад", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ТаблицаВозврата.Колонки.Добавить("НомерЗаказНаПеремещение", ОбщегоНазначения.ОписаниеТипаСтрока(11));
	ТаблицаВозврата.Колонки.Добавить("гкс_ДатаСогласованияДО", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ТаблицаВозврата.Колонки.Добавить("МенеджерПоЗакупкам", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ТаблицаВозврата.Колонки.Добавить("СрокПоставки", ОбщегоНазначения.ОписаниеТипаЧисло(10));
	ТаблицаВозврата.Колонки.Добавить("НомерЗП", ОбщегоНазначения.ОписаниеТипаСтрока(11));
	ТаблицаВозврата.Колонки.Добавить("Партнер", ОбщегоНазначения.ОписаниеТипаСтрока(200));
	ТаблицаВозврата.Колонки.Добавить("ДатаЗП", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ТаблицаВозврата.Колонки.Добавить("Количество", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3)); 
	ТаблицаВозврата.Колонки.Добавить("ДатаПоступления", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));

	Если ЗаявкаНаРемонт.Количество() = 0 ИЛИ СписокНоменклатуры.Количество() = 0 Тогда
		Возврат ТаблицаВозврата;	
	КонецЕсли;
	
	СтруктураЗапроса	= Новый Структура;
	СтруктураЗапроса.Вставить("GUIDЗаявкиНаРемонт", Новый СписокЗначений);
	СтруктураЗапроса.Вставить("GUIDНоменклатура", Новый СписокЗначений);
	
	Для Каждого ТекСтрока Из СписокНоменклатуры Цикл
		СтруктураЗапроса.GUIDНоменклатура.Добавить(XMLСтрока(ТекСтрока.Значение));
	КонецЦикла;
	Для Каждого ТекСтрока Из ЗаявкаНаРемонт Цикл
		СтруктураЗапроса.GUIDЗаявкиНаРемонт.Добавить(XMLСтрока(ТекСтрока.Значение));
	КонецЦикла;
			                               
	ВебСервис = Справочники.гкс_ПодключениеКВебСервисам.ПодключениеERP2;
		
	ИменаРеквизитовПодключения = "Сервер, Порт, Таймаут, ИспользоватьЗащищенноеСоединение";
	РеквизитыПодключения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВебСервис, ИменаРеквизитовПодключения);
		
	ТаймаутРекомендация = 60;
	Таймаут = ?(РеквизитыПодключения.Таймаут = 0, ТаймаутРекомендация, РеквизитыПодключения.Таймаут);
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);		
	Аутентификация = ЛогинПарольПользователя(ВебСервис);
	
	Соединение = Новый HTTPСоединение(РеквизитыПодключения.Сервер,,Аутентификация.Пользователь, Аутентификация.Пароль,,
		Таймаут, ЗащищенноеСоединение, Аутентификация.ИспользоватьАутентификациюОС);
		
	РесурсВебСервиса = Справочники.гкс_РесурсыВебСервисов.SuppliesInventoryАssets;
	РеквизитыВыполнения = РеквизитыВыполненияВебСервиса(РесурсВебСервиса);			
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	СериализаторXDTO.ЗаписатьJSON(ЗаписьJSON, СтруктураЗапроса);
	ТелоЗапроса = ЗаписьJSON.Закрыть();	
	
	СтрокаАвторизации = СтрокаАвторизацииЗапроса(Соединение);
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json"); 
	Заголовки.Вставить("Authorization", СтрокаАвторизации);
	
	
	Запрос = Новый HTTPЗапрос(РеквизитыВыполнения.СтрокаЗапроса, Заголовки);
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8);				
	
	Попытка
		Ответ = Соединение.ВызватьHTTPМетод(РеквизитыВыполнения.ИмяМетода, Запрос);
	Исключение
		
		ЗаписьЖурналаРегистрации("Интеграция ERP2.Получение остатков номенклатуры",
		УровеньЖурналаРегистрации.Ошибка, 
		, 
		, 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru='Ошибка при выполнении HTTP запроса: %1'"), ОписаниеОшибки()));			
		
	КонецПопытки; 
	
	Если Ответ.КодСостояния = 200 Тогда
		
		ЧтениеJSON	= Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
		СтруктураВозврата	= СериализаторXDTO.ПрочитатьJSON(ЧтениеJSON);
		Если ТипЗнч(СтруктураВозврата) = Тип("Структура")
			И СтруктураВозврата.Свойство("Данные") Тогда
			
			Для Каждого ТекСтрока Из СтруктураВозврата.Данные Цикл
				НоваяСтрока = ТаблицаВозврата.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
				НоваяСтрока.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ТекСтрока.GUID)); 
				НоваяСтрока.ЗаявкаНаРемонт	= Документы.торо_ЗаявкаНаРемонт.ПолучитьСсылку(Новый УникальныйИдентификатор(ТекСтрока.ИДЗаявкаНаРемонт));
			КонецЦикла;
		ИначеЕсли ТипЗнч(СтруктураВозврата) = Тип("Строка") Тогда
			
			ЗаписьЖурналаРегистрации("Интеграция ERP2.Получение остатков номенклатуры",
		УровеньЖурналаРегистрации.Ошибка,
			, 
			, 
			СтруктураВозврата)
			
		КонецЕсли;
		
	Иначе
		
		ЗаписьЖурналаРегистрации("Интеграция ERP2.Получение остатков номенклатуры",
		УровеньЖурналаРегистрации.Ошибка, 
		, 
		, 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru='Ошибка запроса к сервису код : %1'"), Ответ.КодСостояния));
					
	КонецЕсли;
	
	Возврат ТаблицаВозврата;
	
КонецФункции

