// Гкс+[TOIR20-510] Зозуля А.В. от 29.01.2025. Изменено:{
Функция ПолучитьДанныеПоНоменклатуре(ЗаявкаНаРемонт = Неопределено, Организация = Неопределено, СписокНоменклатуры) Экспорт  //Зозуля 510+ Доб. Организация
		
	ТаблицаВозврата	= Новый ТаблицаЗначений;
	
	// Гкс+[TOIR20-517] Льговский Р.Н. от 03.02.2025. Добавлено:{
	Если Организация = Неопределено Тогда 
		ПолучитьТолькоСегмент = Истина
	Иначе
		ПолучитьТолькоСегмент = Ложь
	КонецЕсли;
	
	Если ПолучитьТолькоСегмент Тогда 
		ТаблицаВозврата.Колонки.Добавить("Номенклатура");
		ТаблицаВозврата.Колонки.Добавить("Наименование");   //Номенклатуры
		ТаблицаВозврата.Колонки.Добавить("Сегмент"); 
	// } Гкс-[TOIR20-517] Льговский Р.Н от 03.02.2025.
	Иначе
		ТаблицаВозврата.Колонки.Добавить("Номенклатура");
		ТаблицаВозврата.Колонки.Добавить("Наименование");   //Номенклатуры
		ТаблицаВозврата.Колонки.Добавить("гкс_ВНаличии");
		ТаблицаВозврата.Колонки.Добавить("гкс_ИнформацияОбОстатках");
		ТаблицаВозврата.Колонки.Добавить("гкс_СрокПоставки");
		ТаблицаВозврата.Колонки.Добавить("гкс_ДатаСогласованияДО");
		ТаблицаВозврата.Колонки.Добавить("гкс_ВРаботеУОМТС");
		ТаблицаВозврата.Колонки.Добавить("гкс_ДатаЗаказаПоставщику");
		ТаблицаВозврата.Колонки.Добавить("гкс_КоличествоВЗаказе");
		ТаблицаВозврата.Колонки.Добавить("гкс_ДатаПоставки");
		// Гкс+[TOIR20-510] Зозуля А.В. от 29.01.2025. Добавлено:{
		ТаблицаВозврата.Колонки.Добавить("гкс_ТМЦВПути");
		// } Гкс-[TOIR20-510] Зозуля А.В. от 29.01.2025. 
		// Гкс+[TOIR20-528] Вялых Д.А. от 05.02.2025. Добавлено:{	
        ТаблицаВозврата.Колонки.Добавить("гкс_Отгрузить");
		// } Гкс-[TOIR20-528] Вялых Д.А. от 05.02.2025.
		// Гкс+[TOIR20-532] Вялых Д.А. от 10.02.2025. Добавлено:{
		ТаблицаВозврата.Колонки.Добавить("гкс_ВключенВЗаказ");
		ТаблицаВозврата.Колонки.Добавить("гкс_КоличествоВПеремещении");
		// } Гкс-[TOIR20-532] Вялых Д.А. от 10.02.2025.
	КонецЕсли;
			
	СтруктураЗапроса	= Новый Структура;
	СтруктураЗапроса.Вставить("GUIDЗаявкиНаРемонт", XMLСтрока(ЗаявкаНаРемонт));
	// Гкс+[TOIR20-510] Зозуля А.В. от 29.01.2025. Добавлено:{
	СтруктураЗапроса.Вставить("Организация", XMLСтрока(Организация));
	// } Гкс-[TOIR20-510] Зозуля А.В. от 29.01.2025.
	СтруктураЗапроса.Вставить("Номенклатура", Новый СписокЗначений);
	Для Каждого ТекСтрока Из СписокНоменклатуры Цикл
		СтруктураЗапроса.Номенклатура.Добавить(XMLСтрока(ТекСтрока.Значение));
	КонецЦикла;	
			                               
	ВебСервис = Справочники.гкс_ПодключениеКВебСервисам.ПодключениеERP2;
		
	ИменаРеквизитовПодключения = "Сервер, Порт, Таймаут, ИспользоватьЗащищенноеСоединение";
	РеквизитыПодключения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВебСервис, ИменаРеквизитовПодключения);
		
	ТаймаутРекомендация = 60;
	Таймаут = ?(РеквизитыПодключения.Таймаут = 0, ТаймаутРекомендация, РеквизитыПодключения.Таймаут);
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);		
	Аутентификация = ЛогинПарольПользователя(ВебСервис);
	
	Соединение = Новый HTTPСоединение(РеквизитыПодключения.Сервер,,Аутентификация.Пользователь, Аутентификация.Пароль,,
		Таймаут, ЗащищенноеСоединение, Аутентификация.ИспользоватьАутентификациюОС);
		
	РесурсВебСервиса = Справочники.гкс_РесурсыВебСервисов.AvailabilityOfGoods;
	РеквизитыВыполнения = РеквизитыВыполненияВебСервиса(РесурсВебСервиса);			
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	СериализаторXDTO.ЗаписатьJSON(ЗаписьJSON, СтруктураЗапроса);
	ТелоЗапроса = ЗаписьJSON.Закрыть();	
	
	СтрокаАвторизации = СтрокаАвторизацииЗапроса(Соединение);
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json"); 
	Заголовки.Вставить("Authorization", СтрокаАвторизации);
	
	
	Запрос = Новый HTTPЗапрос(РеквизитыВыполнения.СтрокаЗапроса, Заголовки);
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8);				
	
	Попытка
		Ответ = Соединение.ВызватьHTTPМетод(РеквизитыВыполнения.ИмяМетода, Запрос);
	Исключение
		
		ЗаписьЖурналаРегистрации("Интеграция ERP2.Получение остатков номенклатуры",
		УровеньЖурналаРегистрации.Ошибка, 
		, 
		, 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru='Ошибка при выполнении HTTP запроса: %1'"), ОписаниеОшибки()));			
		
	КонецПопытки; 
	
	Если Ответ.КодСостояния = 200 Тогда
		
		ЧтениеJSON	= Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
		СтруктураВозврата	= СериализаторXDTO.ПрочитатьJSON(ЧтениеJSON);
		Если ТипЗнч(СтруктураВозврата) = Тип("Структура")
			И СтруктураВозврата.Свойство("Данные") Тогда
			
			Для Каждого ТекСтрока Из СтруктураВозврата.Данные Цикл
				НоваяСтрока = ТаблицаВозврата.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
				НоваяСтрока.Номенклатура = Справочники.Номенклатура.
				ПолучитьСсылку(Новый УникальныйИдентификатор(ТекСтрока.GUID));				
			КонецЦикла;
		ИначеЕсли ТипЗнч(СтруктураВозврата) = Тип("Строка") Тогда
			
			ЗаписьЖурналаРегистрации("Интеграция ERP2.Получение остатков номенклатуры",
			УровеньЖурналаРегистрации.Ошибка,
			, 
			, 
			СтруктураВозврата)
			
		КонецЕсли;
		
	Иначе
		
		ЗаписьЖурналаРегистрации("Интеграция ERP2.Получение остатков номенклатуры",
		УровеньЖурналаРегистрации.Ошибка, 
		, 
		, 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru='Ошибка запроса к сервису код : %1'"), Ответ.КодСостояния));
					
	КонецЕсли;
	
	Возврат ТаблицаВозврата;
	
КонецФункции         
