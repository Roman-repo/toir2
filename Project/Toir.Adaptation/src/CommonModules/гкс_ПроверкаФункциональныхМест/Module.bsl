	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ТиповыеОР.ДополнительныеРеквизиты КАК торо_ТиповыеОРДополнительныеРеквизиты
	|		ПО ВсеОР.ТОР = торо_ТиповыеОРДополнительныеРеквизиты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.ВидСравнения КАК ВидСравнения,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Значение КАК Значение,
	|	ОграниченияОР.ОР КАК ОР,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Характеристика КАК Характеристика,
	|	ОграниченияОР.ФМ КАК ФМ
	|ПОМЕСТИТЬ ОграниченияРеквизиты
	|ИЗ
	|	ОграниченияОР КАК ОграниченияОР
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграничений КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений
	|		ПО ОграниченияОР.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграничений.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОграниченияОР.ОР КАК ОР,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Характеристика КАК Характеристика,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.ВидСравнения КАК ВидСравнения,
	|	торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Значение КАК Значение,
	|	ОграниченияОР.ФМ КАК ФМ
	|ПОМЕСТИТЬ ОграниченияПоказатели
	|ИЗ
	|	ОграниченияОР КАК ОграниченияОР
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОграниченияНаХарактеристикиОбрудования.СписокОграниченийПоказатели КАК торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели
	|		ПО ОграниченияОР.Ограничение = торо_ОграниченияНаХарактеристикиОбрудованияСписокОграниченийПоказатели.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОграниченияРеквизиты.ВидСравнения КАК ВидСравнения,
	|	ОграниченияРеквизиты.Значение КАК План,
	|	ОграниченияРеквизиты.ОР КАК ОР,
	|	РеквизитыТОР.Значение КАК Факт,
	|	РеквизитыТОР.Свойство КАК Свойство,
	|	ОграниченияРеквизиты.ФМ КАК ФМ,
	|	ОграниченияРеквизиты.ФМ.Подразделение КАК Подразделение
	|ИЗ
	|	ОграниченияРеквизиты КАК ОграниченияРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РеквизитыТОР КАК РеквизитыТОР
	|		ПО ОграниченияРеквизиты.ОР = РеквизитыТОР.ОР
	|			И ОграниченияРеквизиты.Характеристика = РеквизитыТОР.Свойство
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОграниченияПоказатели.ВидСравнения,
	|	ОграниченияПоказатели.Значение,
	|	ОграниченияПоказатели.ОР,
	|	ПоказателиОР.Значение,
	|	ПоказателиОР.Показатель,
	|	ОграниченияПоказатели.ФМ,
	|	ОграниченияПоказатели.ФМ.Подразделение
	|ИЗ
	|	ОграниченияПоказатели КАК ОграниченияПоказатели
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоказателиОРСрез КАК ПоказателиОР
	|		ПО ОграниченияПоказатели.Характеристика = ПоказателиОР.Показатель
	|			И ОграниченияПоказатели.ОР = ПоказателиОР.ОбъектРемонта
	|ИТОГИ
	|	МАКСИМУМ(ФМ)
	|ПО
	|	ОР";
	МВТ = Новый МенеджерВременныхТаблиц();
	Результат = ПроверитьОграниченияМассиваОР(,, ЗапросТекст, МВТ);

	Если Не Результат = Неопределено Тогда 
		Запрос = Новый Запрос();
		Запрос.МенеджерВременныхТаблиц = МВТ;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЭтиНужноПроверить.Ссылка КАК Ссылка
		|ИЗ
		|	ЭтиНужноПроверить1 КАК ЭтиНужноПроверить
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЭтиНужноПроверить.Док КАК Док
		|ИЗ
		|	ЭтиНужноПроверить2 КАК ЭтиНужноПроверить";
		РезультатЗапроса = Запрос.ВыполнитьПакет();

		Выборка = РезультатЗапроса[0].Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ = 
			РегистрыСведений.торо_ОбъектыДляПроверкиТребованийФМ.СоздатьНаборЗаписей();
			НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Отбор.Объект.Установить(Выборка.Ссылка);
			НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Записать();
		КонецЦикла;

		Выборка = РезультатЗапроса[1].Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборЗаписейРегистраторо_ДокументыДляПроверкиТребованийФМ = 
			РегистрыСведений.торо_ДокументыДляПроверкиТребованийФМ.СоздатьНаборЗаписей();
			НаборЗаписейРегистраторо_ДокументыДляПроверкиТребованийФМ.Отбор.ПроверяемыйДокумент.Установить(Выборка.Док);
			НаборЗаписейРегистраторо_ДокументыДляПроверкиТребованийФМ.Записать();
		КонецЦикла;

		//
		Для Каждого СтрокаМассиваНеподходящихОбъектовРемонта Из Результат.НеПодходят Цикл
			СтруктураДанных = Новый Структура("Ссылка,ОбъектРемонта,ТекстТребований,ФМ,ВидДокумента");
			ЗаполнитьЗначенияСвойств(СтруктураДанных, СтрокаМассиваНеподходящихОбъектовРемонта);
			СтруктураДанных.ОбъектРемонта = СтрокаМассиваНеподходящихОбъектовРемонта.Ссылка;
			#Вставка
			Попытка
				торо_РаботаСУведомлениями.ЗаписатьУведомленияФМ(СтруктураДанных, СобытиеФМ);
			Исключение
				ЗаписьЖурналаРегистрации("РЗ_торо_ПроверкаОборудованияНаФункциональныхМестах", УровеньЖурналаРегистрации.Ошибка,,
				СтрокаМассиваНеподходящихОбъектовРемонта.Ссылка, ОписаниеОшибки());

				НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ = 
				РегистрыСведений.торо_ОбъектыДляПроверкиТребованийФМ.СоздатьНаборЗаписей();
				НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Отбор
				.Объект.Установить(СтрокаМассиваНеподходящихОбъектовРемонта.Ссылка);
				НоваяСтрокаНабораЗаписей = НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Добавить();
				НоваяСтрокаНабораЗаписей.Объект = СтрокаМассиваНеподходящихОбъектовРемонта.Ссылка;
				НоваяСтрокаНабораЗаписей.Период = ТекущаяДата();
				НаборЗаписейРегистраторо_ОбъектыДляПроверкиТребованийФМ.Записать();
			КонецПопытки;
			#КонецВставки
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры
