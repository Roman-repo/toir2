
&ИзменениеИКонтроль("торо_ПроверкаОборудованияНаФункциональныхМестах")
Процедура гкс_торо_ПроверкаОборудованияНаФункциональныхМестах()
	Если Константы.торо_ИспользоватьФункциональныеМеста.Получить() = Ложь Тогда 
		Возврат;
	КонецЕсли;
	СобытиеФМ = Константы.торо_ПараметрыОповещенияОПроверкеОборудованияНаФМ.Получить();
	Если ЗначениеЗаполнено(СобытиеФМ) = Ложь Тогда 
		Возврат;
	КонецЕсли;

	ЗапросТекст = 
	"ВЫБРАТЬ
	|	торо_ОбъектыДляПроверкиТребованийФМ.Объект КАК Ссылка,
	|	торо_ОбъектыДляПроверкиТребованийФМ.Объект.ТипОбъекта 
	|	= ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто) КАК ЭтоФМ,
	|	ТИПЗНАЧЕНИЯ(торо_ОбъектыДляПроверкиТребованийФМ.Объект.Ссылка) = ТИП(Справочник.торо_ОбъектыРемонта) КАК ЭтоОР,
	|	торо_ОбъектыДляПроверкиТребованийФМ.Объект.ТиповойОР КАК ТОР
	|ПОМЕСТИТЬ ЭтиНужноПроверить1
	|ИЗ
	|	РегистрСведений.торо_ОбъектыДляПроверкиТребованийФМ КАК торо_ОбъектыДляПроверкиТребованийФМ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	торо_УчетКонтролируемыхПоказателейПоказатели.ОбъектРемонта КАК ОР,
	|	торо_УчетКонтролируемыхПоказателейПоказатели.ОбъектРемонта.ТиповойОР КАК ТОР,
	|	торо_УчетКонтролируемыхПоказателейПоказатели.ОбъектРемонта.ТипОбъекта 
	|	= ЗНАЧЕНИЕ(Перечисление.торо_ТипыОбъектовRCM.ФункциональноеМесто) КАК ЭтоФМ,
	|	ИСТИНА КАК ЭтоОР,
	|	торо_ДокументыДляПроверкиТребованийФМ.ПроверяемыйДокумент КАК Док
	|ПОМЕСТИТЬ ЭтиНужноПроверить2
	|ИЗ
	|	РегистрСведений.торо_ДокументыДляПроверкиТребованийФМ КАК торо_ДокументыДляПроверкиТребованийФМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_УчетКонтролируемыхПоказателей.Показатели 
	|	КАК торо_УчетКонтролируемыхПоказателейПоказатели
	|		ПО торо_ДокументыДляПроверкиТребованийФМ.ПроверяемыйДокумент = торо_УчетКонтролируемыхПоказателейПоказатели.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭтиНужноПроверить.Ссылка КАК Ссылка,
	|	ЭтиНужноПроверить.ЭтоФМ КАК ЭтоФМ,
	|	ЭтиНужноПроверить.ЭтоОР КАК ЭтоОР,
	|	ЭтиНужноПроверить.ТОР КАК ТОР,
	|	NULL КАК ОР
	|ПОМЕСТИТЬ ЭтиНужноПроверить
	|ИЗ
	|	ЭтиНужноПроверить1 КАК ЭтиНужноПроверить
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	NULL,
	|	ЭтиНужноПроверить2.ЭтоФМ,
	|	ЭтиНужноПроверить2.ЭтоОР,
	|	ЭтиНужноПроверить2.ТОР,
	|	ЭтиНужноПроверить2.ОР
	|ИЗ
	|	ЭтиНужноПроверить2 КАК ЭтиНужноПроверить2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭтиНужноПроверить.Ссылка КАК Ссылка,
	|	NULL КАК ОР
	|ПОМЕСТИТЬ ТолькоОР
	|ИЗ
	|	ЭтиНужноПроверить КАК ЭтиНужноПроверить
	|ГДЕ
	|	ЭтиНужноПроверить.ЭтоФМ = ЛОЖЬ
	|	И ЭтиНужноПроверить.ЭтоОР = ИСТИНА
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	торо_ОбъектыРемонта.Ссылка,
	|	NULL
	|ИЗ
	|	ЭтиНужноПроверить КАК ЭтиНужноПроверить
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК торо_ОбъектыРемонта
	|		ПО ЭтиНужноПроверить.Ссылка = торо_ОбъектыРемонта.ТиповойОР
	|ГДЕ
	|	ЭтиНужноПроверить.ЭтоОР = ЛОЖЬ
	|	И ЭтиНужноПроверить.ЭтоФМ = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭтиНужноПроверить.Ссылка КАК ФМ,
	|	ЭтиНужноПроверить.ТОР КАК ТОР,
	|	ИСТИНА КАК ПроверитьВсе
	|ПОМЕСТИТЬ ВсеФМ
	|ИЗ
	|	ЭтиНужноПроверить КАК ЭтиНужноПроверить
	|ГДЕ
	|	ЭтиНужноПроверить.ЭтоФМ = ИСТИНА
	|	И ЭтиНужноПроверить.ЭтоОР = ИСТИНА
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	торо_ОбъектыРемонта.Ссылка,
	|	торо_ОбъектыРемонта.ТиповойОР,
	|	ИСТИНА
