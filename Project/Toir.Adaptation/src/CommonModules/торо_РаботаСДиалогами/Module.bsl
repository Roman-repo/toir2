 Функция гкс_ЗаголовокФормыДокумента(СтруктураПараметров) Экспорт
    // Гкс+[TOIR20-608] Вялых Д.А. от 21.07.2025. Добавлено:{	
	Если ПустаяСтрока(СтруктураПараметров.СтрокаВидаОперации) Тогда
		Заголовок = СтруктураПараметров.Метаданные + "";
	Иначе
		Заголовок = СтруктураПараметров.Метаданные + " [" + СтруктураПараметров.СтрокаВидаОперации + "]";
	КонецЕсли;

	//Если ДокументОбъект.ЭтоНовый() Тогда  
	Если Не ЗначениеЗаполнено(СтруктураПараметров.Ссылка) Тогда  
		Заголовок = Заголовок + НСтр("es='. Nuevo';ru='. Новый';en='. New'");
	Иначе
		Заголовок = Заголовок + СтрШаблон(НСтр("es=' № %1 de %2. ';ru=' №%1 от %2. ';en=' №%1 from %2. '"),СтруктураПараметров.Номер,СтруктураПараметров.Дата);
		Если СтруктураПараметров.Проведен Тогда
			Заголовок = Заголовок + НСтр("es='Es pasado';ru='Проведен';en='Carried out'");
		ИначеЕсли СтруктураПараметров.Ссылка.Метаданные().Проведение = Метаданные.СвойстваОбъектов.Проведение.Разрешить Тогда
			Заголовок = Заголовок + НСтр("es='No es pasado';ru='Не проведен';en='Not done'");
		Иначе
			Заголовок = Заголовок + НСтр("es='Es anotado';ru='Записан';en='Recorded by'");
		КонецЕсли;
	КонецЕсли;

	// Добавления в заголовок статуса
	ФОИспользоватьСтатусыДокументов = ПолучитьФункциональнуюОпцию("торо_ИспользоватьСтатусыДокументовТОиР");
	Если ФОИспользоватьСтатусыДокументов Тогда
		Заголовок = торо_РаботаСоСтатусамиДокументовСервер.гкс_ДобавитьСтатусВЗаголовокФормы(Заголовок, СтруктураПараметров.Ссылка);
	КонецЕсли;

	Возврат Заголовок;
	// } Гкс-[TOIR20-558] Вялых Д.А. от 21.07.2025.
КонецФункции
