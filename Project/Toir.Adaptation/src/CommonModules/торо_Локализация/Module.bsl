#Область СлужебныеПроцедурыИФункции

&Вместо("ОбработкаПолученияПредставленияОбработкаПолученияПредставления")
Процедура Расш_гкс_ОбработкаПолученияПредставленияОбработкаПолученияПредставления(Источник, Данные, Представление, СтандартнаяОбработка)

	// Аннотация &Вместо в данном случае используется специально, чтобы не зависеть от кода процедуры в основной конфигурации
	// Процедуру нужно удалить из расширения, после успешного тестирования задачи "TOIR20-756" на прод базе
	
	Возврат;
	
	Если Данные.Свойство("Ссылка") = Ложь Тогда
		Возврат;
	КонецЕсли;

	СтандартнаяОбработка = Ложь;
	
	Язык = торо_ОбщегоНазначенияПовтИсп.ТекущийЯзыкИБ();

	Ссылка = Данные.Ссылка;
	ТипСсылки = ТипЗнч(Ссылка);
	
	Если ТипСсылки = Тип("СправочникСсылка.торо_ТиповыеОР") Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(торо_Переводы.Текст, """") КАК Текст,
		|	торо_Переводы.Реквизит КАК Реквизит,
		|	ВЫБОР
		|		КОГДА торо_ТиповыеОР.ЭтоГруппа
		|			ТОГДА торо_ТиповыеОР.Наименование
		|		ИНАЧЕ торо_ТиповыеОР.гкс_Модель
		|	КОНЕЦ КАК Текст2
		|ИЗ
		|	Справочник.торо_ТиповыеОР КАК торо_ТиповыеОР
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_Переводы КАК торо_Переводы
		|		ПО (торо_Переводы.ID = торо_ТиповыеОР.Ссылка)
		|			И (торо_Переводы.Язык = &Язык)
		|			И (торо_Переводы.Реквизит = ""Наименование""
		|					И торо_ТиповыеОР.ЭтоГруппа
		|				ИЛИ торо_Переводы.Реквизит = ""гкс_Модель""
		|					И торо_ТиповыеОР.ЭтоГруппа = ЛОЖЬ)
		|ГДЕ
		|	торо_ТиповыеОР.Ссылка = &ID";	
		Запрос.УстановитьПараметр("ID", Ссылка);
		Запрос.УстановитьПараметр("Язык", Язык);
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() = Ложь Тогда 
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			Представление = ?(ЗначениеЗаполнено(Выборка.Текст),Выборка.Текст,Выборка.Текст2);
		КонецЕсли;
		Возврат;
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.гкс_ТехническиеМеста") Тогда 
		Возврат
		// гкс+ [11.22] Деснол 29.11.2022
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.торо_ОбъектыРемонта") Тогда 
		Если Константы.гкс_ОтключитьМногоязычностьОР.Получить() Тогда 
			СтандартнаяОбработка = Истина;
			Возврат;
		КонецЕсли;
		// гкс- [11.22] Деснол 29.11.2022
	КонецЕсли;

	ФорматнаяСтрока = Неопределено;
	Если ТипСсылки = Тип("СправочникСсылка.торо_ОбъектыРемонта") Тогда 
		ФорматнаяСтрока = торо_РаботаСПользовательскимПредставлениемПовтИсп.ПолучитьФорматнуюСтроку("Справочники.торо_ОбъектыРемонта");
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.гкс_ТехническиеМеста") Тогда 
		ФорматнаяСтрока = СтрРазделить("НаименованиеПолное", "");
	КонецЕсли;

	СписокПолей = ?(ФорматнаяСтрока = Неопределено, 
	СтрРазделить("Наименование", ""), 
	торо_РаботаСПользовательскимПредставлением.ПолучитьСписокПолей(ФорматнаяСтрока));

	Запрос = Новый Запрос;
	#Область ТекстЗапроса
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	торо_Переводы.Текст КАК Текст,
	|	торо_Переводы.Реквизит КАК Реквизит
	|ИЗ
	|	РегистрСведений.торо_Переводы КАК торо_Переводы
	|ГДЕ
	|	торо_Переводы.ID = &ID
	|	И торо_Переводы.Язык = &Язык
	|	И торо_Переводы.Реквизит В (&Реквизит)";
	#КонецОбласти 

	Запрос.УстановитьПараметр("ID", Ссылка);
	Запрос.УстановитьПараметр("Язык", Язык);
	Запрос.УстановитьПараметр("Реквизит", СписокПолей);
	Результаты = Запрос.Выполнить().Выгрузить();

	Переводы = Новый Структура;
	Для каждого Результат Из Результаты Цикл
		Переводы.Вставить(Результат.Реквизит, Результат.Текст);
	КонецЦикла; 

	Для каждого Поле Из СписокПолей Цикл
		Если Не Переводы.Свойство(Поле) Тогда
			Переводы.Вставить(Поле, Ссылка[Поле]);
		КонецЕсли; 
	КонецЦикла; 

	Представление = ?(ФорматнаяСтрока = Неопределено, 
	Переводы["Наименование"],
	торо_РаботаСПользовательскимПредставлением.ПолучитьПредставлениеПоФорматнойСтроке(ФорматнаяСтрока,Переводы));
	
КонецПроцедуры

&ИзменениеИКонтроль("ОбработкаПолученияДанныхВыбораОбработкаПолученияДанныхВыбора")
Процедура Расш_гкс_ОбработкаПолученияДанныхВыбораОбработкаПолученияДанныхВыбора(Источник, ДанныеВыбора, Параметры, СтандартнаяОбработка)
	Возврат;
	#Вставка
	Если Не торо_ОбщегоНазначенияПовтИсп.ЭтоЯзыкПоУмолчанию() Тогда
	#КонецВставки
	#Удаление
	Если Не ЭтоЯзыкПоУмолчанию() Тогда
	#КонецУдаления
		Слова = СтрРазделить(Источник, ".");
		Тип = Слова[0];
		ОбъектИБ = Слова[1];
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = Новый СписокЗначений;

		Если Тип = "СправочникМенеджер" Тогда
			Запрос = Новый Запрос;
			#Область ТекстЗапроса
			Запрос.Текст = СтрШаблон(
			"ВЫБРАТЬ
			|	СправочникИБ.Ссылка КАК Ссылка,
			|	торо_Переводы.Текст КАК Представление
			|ИЗ
			|	РегистрСведений.торо_Переводы КАК торо_Переводы
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.%1 КАК СправочникИБ
			|		ПО торо_Переводы.ID = СправочникИБ.Ссылка
			|			И (торо_Переводы.Реквизит = ""Наименование"")
			|			И (торо_Переводы.Язык.Код = &Язык)
			|ГДЕ
			|	торо_Переводы.Текст ПОДОБНО &Наименование", ОбъектИБ);
			#КонецОбласти 

			Запрос.УстановитьПараметр("Язык", ТекущийЯзык().КодЯзыка);
			Запрос.УстановитьПараметр("Наименование", "%" + Параметры.СтрокаПоиска + "%");
			РезультатЗапроса = Запрос.Выполнить();
			Выборка = РезультатЗапроса.Выбрать();

			Пока Выборка.Следующий() Цикл
				ДанныеВыбора.Добавить(Выборка.Ссылка, Выборка.Представление);
			КонецЦикла;
		КонецЕсли; 
	КонецЕсли; 
КонецПроцедуры

&ИзменениеИКонтроль("ОбработкаПолученияФормыОбработкаПолученияФормы")
Процедура Расш_гкс_ОбработкаПолученияФормыОбработкаПолученияФормы(Источник, ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	Возврат;
	#Вставка
	Если Не торо_ОбщегоНазначенияПовтИсп.ЭтоЯзыкПоУмолчанию() Тогда
	#КонецВставки
	#Удаление
	Если Не ЭтоЯзыкПоУмолчанию() Тогда
	#КонецУдаления
		Если ЭтоПользовательскаяФорма(Источник, ВидФормы) Тогда
			Возврат;
		КонецЕсли;

		Параметры.Вставить("ВидФормы", ВидФормы);

		Если ВидФормы = "ФормаОбъекта" Тогда
			#Область ФормаОбъекта
			СтандартнаяОбработка = Ложь;
			ДополнительнаяИнформация.ПовторноеИспользование = Истина;
			ВыбраннаяФорма = "ОбщаяФорма.торо_Автоформа";

			Ключ = Неопределено;
			Если Параметры.Свойство("Ключ", Ключ) Тогда
				Параметры.Вставить("Ключ", Ключ.ПолучитьОбъект());
			Иначе
				МетаданныеИсточника = ПолучитьМетаданныеИсточника(Источник);
				ТипОбъектаИБ = МетаданныеИсточника.ТипОбъектаИБ;
				ТипМетаданных = МетаданныеИсточника.ТипМетаданных;

				Если ТипМетаданных = "Справочники" Тогда
					НовыйЭлемент = Справочники[ТипОбъектаИБ].СоздатьЭлемент();
				ИначеЕсли ТипМетаданных = "Документы" Тогда
					НовыйЭлемент = Документы[ТипОбъектаИБ].СоздатьДокумент();
				КонецЕсли;

				Параметры.Вставить("Ключ", НовыйЭлемент);
			КонецЕсли; 
			#КонецОбласти 
		ИначеЕсли ВидФормы = "ФормаСписка" ИЛИ ВидФормы = "ФормаВыбора" Тогда
			#Область ФормаСписка
			МетаданныеИсточника = ПолучитьМетаданныеИсточника(Источник);
			ТипОбъектаИБ = МетаданныеИсточника.ТипОбъектаИБ;
			ТипМетаданных = МетаданныеИсточника.ТипМетаданных;
			Если СтрНайти(ТипМетаданных,"Документ") = 0 И СтрНайти(ТипМетаданных,"Справочник") = 0 Тогда 
				Возврат;
			ИначеЕсли СтрНайти(ТипМетаданных,"Регистр") > 0 Тогда 
				Возврат;
			КонецЕсли;
			Параметры.Вставить("ТипОбъектаИБ", ТипОбъектаИБ);
			Параметры.Вставить("ТипМетаданных", ТипМетаданных);

			СтандартнаяОбработка = Ложь;
			ДополнительнаяИнформация.ПовторноеИспользование = Истина;
			ВыбраннаяФорма = "ОбщаяФорма.торо_Автоформа";
			#КонецОбласти 
		ИначеЕсли ВидФормы = "ФормаЗаписи" Тогда
			#Область ФормаЗаписи
			Возврат;
			МетаданныеИсточника = ПолучитьМетаданныеИсточника(Источник);
			ТипОбъектаИБ = МетаданныеИсточника.ТипОбъектаИБ;
			ТипМетаданных = МетаданныеИсточника.ТипМетаданных;
			МассивИзмерений = Новый Массив();
			МассивРесурсов = Новый Массив();
			МассивРеквизитов = Новый Массив();
			Параметры.Вставить("ТипМетаданных", ТипМетаданных);

			Если ТипМетаданных = "РегистрыСведений" Тогда
				НовыйЭлемент = РегистрыСведений[ТипОбъектаИБ].СоздатьМенеджерЗаписи();
			Иначе
				Возврат;
			КонецЕсли;

			СтандартнаяОбработка = Ложь;
			ДополнительнаяИнформация.ПовторноеИспользование = Истина;
			ВыбраннаяФорма = "ОбщаяФорма.торо_Автоформа";

			Для Каждого Измерение Из Метаданные[ТипМетаданных][ТипОбъектаИБ].Измерения Цикл
				МассивИзмерений.Добавить(Измерение.Имя);
			КонецЦикла;
			Для Каждого Измерение Из Метаданные[ТипМетаданных][ТипОбъектаИБ].Ресурсы Цикл
				МассивРесурсов.Добавить(Измерение.Имя);
			КонецЦикла;
			Для Каждого Измерение Из Метаданные[ТипМетаданных][ТипОбъектаИБ].Реквизиты Цикл
				МассивРесурсов.Добавить(Измерение.Имя);
			КонецЦикла;
			Параметры.Вставить("МассивИзмерений", МассивИзмерений);
			Параметры.Вставить("МассивРесурсов", МассивРесурсов);
			Параметры.Вставить("МассивРеквизитов", МассивРеквизитов);
			Параметры.Вставить("ТипОбъектаИБ", ТипОбъектаИБ);

			Ключ = Неопределено;
			Если Параметры.Свойство("Ключ", Ключ) Тогда
				Если Не ТипЗнч(Ключ.Регистратор) = Тип("Неопределено") Тогда 
					НовыйЭлемент.Регистратор = Ключ.Регистратор;
				Иначе
					Для Каждого Измерение Из МассивИзмерений Цикл
						НовыйЭлемент[Измерение] = Ключ[Измерение];
					КонецЦикла;
				КонецЕсли;
				НовыйЭлемент.Прочитать();
				Параметры.Вставить("Ключ", НовыйЭлемент);
			Иначе
				Параметры.Вставить("Ключ", НовыйЭлемент);
			КонецЕсли;
			#КонецОбласти 
		КонецЕсли; 
	КонецЕсли; 
КонецПроцедуры

#КонецОбласти