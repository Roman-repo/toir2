					ТекстДопОтбора = СформироватьСтрокуДополнительныхОтборовИУстановитьПараметры(ДополнительныеОтборы, "торо_ОбъектыРемонта", Запрос);
					Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДополнительныеОтборы",	ТекстДопОтбора);
