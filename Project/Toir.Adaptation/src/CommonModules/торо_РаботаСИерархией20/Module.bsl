				Иначе
					Запрос.УстановитьПараметр("УсловиеПоСтатусамВУчете", Истина);
				КонецЕсли;

			Иначе

				Возврат Новый Массив;

			КонецЕсли;

		КонецЕсли;

		Результат = Запрос.Выполнить();

	Иначе // Не строится автоматически.

		Если СтруктураПараметровИерархии.ИзменяетсяДокументами Тогда

			Запрос = Новый Запрос;

