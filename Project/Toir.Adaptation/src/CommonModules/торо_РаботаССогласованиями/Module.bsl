&ИзменениеИКонтроль("ПолучитьДанныеПоСтатусуДокумента")
Функция Расш_гкс_ПолучитьДанныеПоСтатусуДокумента(СпособСогласования, СтатусДокумента)

	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("Начальный", Ложь);
	СтруктураДанных.Вставить("СогласованиеЗавершено", Ложь);
	СтруктураДанных.Вставить("ПроводитьДокумент", Ложь);
	СтруктураДанных.Вставить("ШаблонСообщенияЭлектроннойПочты", Неопределено);
	СтруктураДанных.Вставить("ЗапретитьРедактирование", Ложь);
	СтруктураДанных.Вставить("РазрешитьПометкуНаУдаление", Ложь);
	СтруктураДанных.Вставить("НеОтображатьВСпискеЗадач", Ложь);
	#Вставка
	СтруктураДанных.Вставить("ПроводитьАвтоматически", Ложь);
	#КонецВставки

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	торо_НастройкиСтатусовСогласованияДокументов.Начальный КАК Начальный,
	|	торо_НастройкиСтатусовСогласованияДокументов.СогласованиеЗавершено КАК СогласованиеЗавершено,
	|	торо_НастройкиСтатусовСогласованияДокументов.ПроводитьДокумент КАК ПроводитьДокумент,
	|	торо_НастройкиСтатусовСогласованияДокументов.ШаблонСообщенияЭлектроннойПочты КАК ШаблонСообщенияЭлектроннойПочты,
	|	торо_НастройкиСтатусовСогласованияДокументов.ЗапретитьРедактирование КАК ЗапретитьРедактирование,
	|	торо_НастройкиСтатусовСогласованияДокументов.РазрешитьПометкуНаУдаление КАК РазрешитьПометкуНаУдаление,
	#Вставка
	|	торо_НастройкиСтатусовСогласованияДокументов.гкс_ПроводитьАвтоматически КАК ПроводитьАвтоматически,
	// гкс+ [Релиз16] Деснол
	|	торо_НастройкиСтатусовСогласованияДокументов.гкс_РазрешеноСоздаватьПодчиненные КАК гкс_РазрешеноСоздаватьПодчиненные,
	// гкс- [Релиз16]
	#КонецВставки
	|	торо_НастройкиСтатусовСогласованияДокументов.НеОтображатьВСпискеЗадач КАК НеОтображатьВСпискеЗадач
	|ИЗ
	|	РегистрСведений.торо_НастройкиСтатусовСогласованияДокументов КАК торо_НастройкиСтатусовСогласованияДокументов
	|ГДЕ
	|	торо_НастройкиСтатусовСогласованияДокументов.Статус = &ТекущийСтатус
	|	И торо_НастройкиСтатусовСогласованияДокументов.СпособСогласования = &СпособСогласования";

	Запрос.УстановитьПараметр("ТекущийСтатус", СтатусДокумента);
	Запрос.УстановитьПараметр("СпособСогласования", СпособСогласования);

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураДанных, Выборка);
	КонецЕсли;

	Возврат СтруктураДанных;

КонецФункции

&ИзменениеИКонтроль("ЗавершитьУтверждениеСтатусаДокумента")
Процедура Расш_гкс_ЗавершитьУтверждениеСтатусаДокумента(Форма, ПараметрыОповещения)

	Объект = Форма.Объект;
	ВыбранныйСтатус = ПараметрыОповещения.ВыбранныйСтатус;
	#Вставка
	// Гкс+[TOIR20-160] Селимов
	ИсходныйСтатус = Форма.СтатусДокументаРегистр;			 
	// гкс+ [06.23] Деснол 16.06.2023
	НужноДобавитьПФвДО = Ложь;
	// гкс- [06.23] Деснол 16.06.2023
	#КонецВставки

	Попытка

		СменитьСтатус = НужноИзменитьСтатусДокумента(Форма, ВыбранныйСтатус);
		#Вставка
		Если СменитьСтатус = Ложь И ПараметрыОповещения.Свойство("УстановитьПринудительно")
			И ПараметрыОповещения.УстановитьПринудительно = Истина Тогда 
			СменитьСтатус = Истина;
		КонецЕсли;
		#КонецВставки

		СтруктураПараметров = Новый Структура;
		Если СменитьСтатус Тогда

			Форма.СтатусДокументаРегистр = ВыбранныйСтатус;
			Если Форма.мХранитьИсториюСогласованияВДокументах Тогда
				Объект.СтатусДокумента = Форма.СтатусДокументаРегистр;
			КонецЕсли;

			ПроводитьДокумент = Ложь;
			СтруктураДанных = ПолучитьДанныеПоСтатусуДокумента(Объект.СпособСогласования, Форма.СтатусДокументаРегистр);
			ПроводитьДокумент = СтруктураДанных.ПроводитьДокумент;

			#Удаление
			Если ПроводитьДокумент И Объект.Проведен Тогда
			#КонецУдаления
			#Вставка
			Если ПроводитьДокумент И (Объект.Проведен
				ИЛИ (СтруктураДанных.ПроводитьАвтоматически = Истина И Объект.Проведен = Ложь)) Тогда
			#КонецВставки
				СтруктураПараметров.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
				СтруктураПараметров.Вставить("РежимПроведения", РежимПроведенияДокумента.Неоперативный);
			Иначе 
				СтруктураПараметров.Вставить("РежимЗаписи", РежимЗаписиДокумента.Запись);
			КонецЕсли;

		Иначе
			СтруктураПараметров.Вставить("РежимЗаписи", РежимЗаписиДокумента.Запись);
			#Вставка
			СтруктураДанных = Новый Структура("ПроводитьАвтоматически",Ложь);
			#КонецВставки
		КонецЕсли;
		#Вставка
		// гкс+ [05.23] Деснол 10.05.2023
		// Читаем чтобы восстановить после Отказа
		НаборДляЗаписи1 = РегистрыСведений.торо_ТекущиеСогласующиеДокументов.СоздатьНаборЗаписей();
		НаборДляЗаписи1.Отбор.СогласуемыйДокумент.Установить(Объект.Ссылка);
	    НаборДляЗаписи1.Прочитать();
		// Запись таблицы ИсторияСтатусов.
		НаборДляЗаписи2 = РегистрыСведений.торо_ИсторияСтатусовСогласованияДокументов.СоздатьНаборЗаписей();
		НаборДляЗаписи2.Отбор.СогласуемыйДокумент.Установить(Объект.Ссылка);
        НаборДляЗаписи2.Прочитать();
		// Запись текущего статуса документа.
		НаборДляЗаписи3 = РегистрыСведений.торо_ТекущиеСтатусыСогласованияДокументов.СоздатьНаборЗаписей();
		НаборДляЗаписи3.Отбор.СогласуемыйДокумент.Установить(Объект.Ссылка);
		НаборДляЗаписи3.Прочитать();
		// Нужно установить статусы до проведения, потомучто есть подписки
		ЗаписатьРегистрыСогласования(Форма);
		// гкс- [05.23] Деснол 10.05.2023
		#КонецВставки

		#Удаление
		ЗаписатьРегистрыСогласования(Форма);
		#КонецУдаления
		#Удаление
		Если Форма.мХранитьИсториюСогласованияВДокументах Тогда
		#КонецУдаления
		#Вставка 
		Если Форма.мХранитьИсториюСогласованияВДокументах 
			ИЛИ СтруктураДанных.ПроводитьАвтоматически = Истина Тогда
		#КонецВставки
			Форма.Записать(СтруктураПараметров);
		КонецЕсли;

		#Вставка
		// гкс+ [06.23] Деснол 16.06.2023
		Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.торо_ЗаявкаНаРемонт") Тогда 
			Настройка = Справочники.гкс_ПроизвольныеНастройкиИнтеграций.СтатусыЗаявокКВыгрузке;
			МассивСвойств = Справочники.гкс_ПроизвольныеНастройкиИнтеграций.ПолучитьСвойства(Настройка, "Свойства");
			Для каждого Свойство Из МассивСвойств Цикл
				Если Свойство.Значение = ВыбранныйСтатус Тогда 
					НужноДобавитьПФвДО = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// гкс- [06.23] Деснол 16.06.2023
		// гкс+ [05.23] Деснол 10.05.2023
		//// Гкс+[TOIR20-160] Селимов
		//ЗаписатьРегистрыСогласования(Форма); 
		// гкс- [05.23] Деснол 10.05.2023
		#КонецВставки
		ДобавитьНапоминанияПоСтатусамСогласования(Объект.Ссылка);
		ОбновитьДеревоСогласующих(Форма);

		торо_РаботаССогласованиямиКлиентСервер.УстановитьВидимостьСогласованиеИУтверждение(Форма.мИспользоватьСогласованиеДокументов, Объект, Форма);

	Исключение
		#Вставка
		// гкс+ [06.23] Деснол 16.06.2023
		НужноДобавитьПФвДО = Ложь;
		// гкс- [06.23] Деснол 16.06.2023
		// гкс+ [05.23] Деснол 10.05.2023
		НаборДляЗаписи1.Записать();
		НаборДляЗаписи2.Записать();
		НаборДляЗаписи3.Записать();
		// гкс- [05.23] Деснол 10.05.2023
		// Гкс+[TOIR20-160]
		Форма.СтатусДокументаРегистр = ИсходныйСтатус;
		Если Форма.мХранитьИсториюСогласованияВДокументах Тогда
			Объект.СтатусДокумента = Форма.СтатусДокументаРегистр;
		КонецЕсли;
		КолВоСтатустов = Форма.ИсторияСтатусовРегистр.Количество();
		Если КолВоСтатустов > 0 
			И Форма.ИсторияСтатусовРегистр[КолВоСтатустов - 1].СтатусДокумента = ВыбранныйСтатус 
			И ВыбранныйСтатус <> ИсходныйСтатус Тогда
			ТекПользователь = Форма.ИсторияСтатусовРегистр[КолВоСтатустов - 1].Пользователь;
			// отмена добавленной записи на форме в ИсторияСтатусов
			Форма.ИсторияСтатусовРегистр.Удалить(КолВоСтатустов - 1);						
			// отмена установленных флагов "согласовано" на форме в ДеревоСогласования
			СнятьГалочкиЗаТекущегоПользователя(ВыбранныйСтатус, Форма, ТекПользователь);
		КонецЕсли; 
		#КонецВставки 
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(НСтр("es='La excepción';ru='Исключение';en='An exception'"), УровеньЖурналаРегистрации.Предупреждение,, ОписаниеОшибки);
	КонецПопытки;
	#Вставка
	// гкс+ [06.23] Деснол 16.06.2023
	Если НужноДобавитьПФвДО Тогда 
		Попытка
			Документы.торо_ЗаявкаНаРемонт.гкс_ДобавитьПФТехЗаданияВДО(Объект.Ссылка, Истина);
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
			ЗаписьЖурналаРегистрации(НСтр("es='La excepción';ru='Исключение';en='An exception'"), УровеньЖурналаРегистрации.Предупреждение,, ОписаниеОшибки);
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = ОписаниеОшибки;
			Сообщение.Сообщить();
		КонецПопытки;
	КонецЕсли;
	// гкс- [06.23] Деснол 16.06.2023
	#КонецВставки

КонецПроцедуры

&ИзменениеИКонтроль("ПриСозданииНаСервере")
Процедура Расш_гкс_ПриСозданииНаСервере(ЭтаФорма, ВидДокумента, Регламентный)

	ЭтаФорма.мХранитьИсториюСогласованияВДокументах = Константы.торо_ХранитьИсториюСогласованияВДокументах.Получить();
	ЭтаФорма.мИспользоватьСогласованиеДокументов = ПроверитьИспользованиеСогласованияДокументов(ВидДокумента, Регламентный);

	ОписаниеРевизита = Новый РеквизитФормы("СогласованиеТолькоПросмотр", Новый ОписаниеТипов("Булево"));
	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(ОписаниеРевизита);
	#Вставка
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("гкс_ПериодЧП", Новый ОписаниеТипов("Дата",,,,,
		Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)), "ИсторияСтатусовРегистр"));
	#КонецВставки
	ЭтаФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	#Вставка
	Для Каждого ЭлементФормы Из ЭтаФорма.Элементы Цикл
		Если ТипЗнч(ЭлементФормы) = Тип("ТаблицаФормы") И ЭлементФормы.ПутьКДанным = "ИсторияСтатусовРегистр" Тогда 
			Для Каждого ПодчиненныйЭлемент Из ЭлементФормы.ПодчиненныеЭлементы Цикл
				Если ПодчиненныйЭлемент.ПутьКДанным = "ИсторияСтатусовРегистр.Период" Тогда 
					НЭлем = ЭтаФорма.Элементы.Добавить("гкс_ПериодЧП", Тип("ПолеФормы"), ЭлементФормы);
					НЭлем.Заголовок = ПодчиненныйЭлемент.Заголовок;
					НЭлем.Вид = ВидПоляФормы.ПолеВвода;
					НЭлем.ТолькоПросмотр = Истина;
					НЭлем.ПутьКДанным = "ИсторияСтатусовРегистр.гкс_ПериодЧП";
					ЭтаФорма.Элементы.Переместить(НЭлем, ЭлементФормы, ПодчиненныйЭлемент);
					ПодчиненныйЭлемент.Видимость = Ложь;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	#КонецВставки

	Если ЭтаФорма.мИспользоватьСогласованиеДокументов Тогда

		Если Не ЗначениеЗаполнено(ЭтаФорма.Объект.Ссылка) Тогда

			Если НЕ ЗначениеЗаполнено(ЭтаФорма.Объект.СпособСогласования) Тогда
				#Вставка
				Если ВидДокумента = 
						Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ВыявленныеДефекты Тогда 
						Если ЭтаФорма.Объект.СписокДефектов.Количество() > 0 Тогда 
							ЭтаФорма.Объект.СпособСогласования = гкс_ПолучитьСпособСогласованияПоУмолчанию(
					ВидДокумента, ЭтаФорма.Объект.Организация, ЭтаФорма.Объект.СписокДефектов[0].ОтказавшийЭлемент.Подразделение, ЭтаФорма.Объект.ПодразделениеИсполнитель);
						Иначе
							ЭтаФорма.Объект.СпособСогласования = гкс_ПолучитьСпособСогласованияПоУмолчанию(
					ВидДокумента, ЭтаФорма.Объект.Организация, ЭтаФорма.Объект.Подразделение, ЭтаФорма.Объект.ПодразделениеИсполнитель);
						КонецЕсли;
				ИначеЕсли (ВидДокумента = 
						Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_ЗаявкаНаРемонт)
						ИЛИ (ВидДокумента = 
						Перечисления.торо_ВидыДокументовСогласованияРемонтов.торо_АктОВыполненииЭтапаРабот) Тогда 
					ПодразделениеИсполнитель = Справочники.СтруктураПредприятия.ПустаяСсылка();
					//
					Если ЭтаФорма.Объект.ИсполнителиПоРемонтам.Количество() И
						ТипЗнч(ЭтаФорма.Объект.ИсполнителиПоРемонтам[0].Исполнитель) = Тип("СправочникСсылка.СтруктураПредприятия") Тогда 
						ПодразделениеИсполнитель = ЭтаФорма.Объект.ИсполнителиПоРемонтам[0].Исполнитель;
					КонецЕсли;
					//
					ЭтаФорма.Объект.СпособСогласования = гкс_ПолучитьСпособСогласованияПоУмолчанию(
						ВидДокумента, ЭтаФорма.Объект.Организация, ЭтаФорма.Объект.Подразделение, ПодразделениеИсполнитель);
				Иначе
				#КонецВставки
				ЭтаФорма.Объект.СпособСогласования = ПолучитьСпособСогласованияПоУмолчанию(ВидДокумента, ЭтаФорма.Объект.Организация, ЭтаФорма.Объект.Подразделение);
				#Вставка
				КонецЕсли;
				#КонецВставки
			КонецЕсли;

			ЭтаФорма.СтатусДокументаРегистр = ПолучитьНачальныйСтатус(ЭтаФорма.Объект.СпособСогласования);
			Если ЭтаФорма.мХранитьИсториюСогласованияВДокументах Тогда
				ЭтаФорма.Объект.СтатусДокумента = ЭтаФорма.СтатусДокументаРегистр;
			КонецЕсли;

			торо_РаботаССогласованиямиКлиентСервер.ДобавитьСтрокуВИсториюСтатусов(ЭтаФорма, ЭтаФорма.СтатусДокументаРегистр);

		Иначе

			ЭтаФорма.СтатусДокументаРегистр = ПолучитьТекущийСтатусСогласованияДокумента(ЭтаФорма.Объект.Ссылка);
			ПрочитатьРегистрыСогласования(ЭтаФорма);

		КонецЕсли;

		ОбновитьДеревоСогласующих(ЭтаФорма);

	КонецЕсли;

	торо_РаботаССогласованиямиКлиентСервер.УстановитьВидимостьСогласованиеИУтверждение(ЭтаФорма.мИспользоватьСогласованиеДокументов, ЭтаФорма.Объект, ЭтаФорма);

КонецПроцедуры

&ИзменениеИКонтроль("ПриЗаписиНаСервере")
Процедура гкс_ПриЗаписиНаСервере(ЭтаФорма, ТекущийОбъект) Экспорт
	#Вставка
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("гкс_НазначитьСтатусДокумента") Тогда   
		СпособСогласования = ТекущийОбъект.СпособСогласования;	
		СтатусДокумента = торо_РаботаССогласованиямиПовтИсп.ПолучитьНачальныйСтатус(СпособСогласования);
		Если Не ЗначениеЗаполнено(СтатусДокумента) Тогда
			Возврат;
		КонецЕсли;
								
		ЭтаФорма.СтатусДокументаРегистр = СтатусДокумента;
	
		Объект = ЭтаФорма.Объект;
	
		НаборЗаписей = ЭтаФорма.РеквизитФормыВЗначение("ИсторияСтатусовРегистр");
		НаборЗаписей.Отбор.СогласуемыйДокумент.Установить(ТекущийОбъект.Ссылка);
		НаборЗаписей.Прочитать();
		ЭтаФорма.ЗначениеВреквизитФормы(НаборЗаписей, "ИсторияСтатусовРегистр");
				
		СогласующиеРегистр = РегистрыСведений.торо_ТекущиеСогласующиеДокументов.СоздатьНаборЗаписей();
		ДеревоСогласования = ПолучитьДеревоСогласования(
			СпособСогласования, СтатусДокумента, СогласующиеРегистр.Выгрузить());
	
		ЭтаФорма.ЗначениеВРеквизитФормы(ДеревоСогласования,"ДеревоСогласования");
		ЭтаФорма.Элементы.ДеревоСогласованияУтвердитьСтатус.Доступность = ЗначениеЗаполнено(СпособСогласования);
			
		Возврат;		
	КонецЕсли;
	#КонецВставки
	
	Если ЭтаФорма.мИспользоватьСогласованиеДокументов Тогда
		торо_РаботаССогласованиямиКлиентСервер.ЗаписатьДеревоСогласования(ЭтаФорма);
		Если ЭтаФорма.СтатусДокументаРегистр = ПолучитьНачальныйСтатус(ТекущийОбъект.СпособСогласования) Тогда
			ЗаписатьРегистрыСогласования(ЭтаФорма, ТекущийОбъект);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

