		Запрос.Текст = Запрос.Текст + ", ВидРемонтныхРабот";

		Запрос.УстановитьПараметр("ТаблицаДанныхППР", ТаблицаДанныхППР);
		Запрос.УстановитьПараметр("СтруктураИерархии", СтруктураИерархии);

