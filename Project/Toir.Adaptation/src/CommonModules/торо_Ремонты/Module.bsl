Функция гкс_ИндексКартинкиДереваРемонтныхРаботПоПараметрам(Работа, ЭтоГруппа = Ложь, ПометкаУдаления = Ложь) Экспорт
	
	ТипРаботы = ТипЗнч(Работа);
	
	Если ТипРаботы = Тип("СправочникСсылка.торо_ИдентификаторыТехКарт") Тогда
		Результат = ?(ПометкаУдаления, 1, 0);
	ИначеЕсли ТипРаботы = Тип("СправочникСсылка.торо_ТехнологическиеОперации") Тогда
		Если ЭтоГруппа Тогда 
			Результат = 4;
		Иначе 
			Результат = ?(ПометкаУдаления, 3, 2);
		КонецЕсли;	
	Иначе
		Результат = 4;
	КонецЕсли;

	Возврат Результат; 
	
КонецФункции
