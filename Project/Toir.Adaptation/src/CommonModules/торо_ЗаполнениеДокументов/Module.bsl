// гкс+ [Релиз16] Деснол
Процедура гкс_ПроверитьВозможностьВводаОтСтатуса(Объект, Отказ) Экспорт
	Если Не ЗначениеЗаполнено(Объект.Ссылка) И Объект.ДокументыОснования.Количество() Тогда 
		МассивДокументов = Новый Массив();
		Для Каждого СтрокаТаблицы Из Объект.ДокументыОснования Цикл
			Если МассивДокументов.Найти(СтрокаТаблицы.ДокументОснование) = Неопределено Тогда 
				МассивДокументов.Добавить(СтрокаТаблицы.ДокументОснование);
			КонецЕсли;
		КонецЦикла;
		Запрос = Новый Запрос();
		Запрос.Текст = 
		"ВЫБРАТЬ
           |	РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов.гкс_РазрешеноСоздаватьПодчиненные КАК Флаг,
		   |	РегистрСведенийторо_ТекущиеСтатусыСогласованияДокументов.СтатусДокумента КАК Статус
           |ИЗ
           |	РегистрСведений.торо_ТекущиеСтатусыСогласованияДокументов 
		   |	КАК РегистрСведенийторо_ТекущиеСтатусыСогласованияДокументов
           |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_НастройкиСтатусовСогласованияДокументов 
		   |	КАК РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов
           |		ПО (РегистрСведенийторо_ТекущиеСтатусыСогласованияДокументов.СогласуемыйДокумент В (&Ссылка))
           |			И (РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов.СпособСогласования = 
		   | РегистрСведенийторо_ТекущиеСтатусыСогласованияДокументов.СогласуемыйДокумент.СпособСогласования)
           |			И РегистрСведенийторо_ТекущиеСтатусыСогласованияДокументов.СтатусДокумента 
		   |	= РегистрСведенийторо_НастройкиСтатусовСогласованияДокументов.Статус";
		Запрос.УстановитьПараметр("Ссылка", МассивДокументов);
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			Если Выборка.Флаг = Ложь Тогда 
					ТекстСообщения = НСтр("es='';
					|ru='В статусе ""%1%"" запрещен ввод на основании';
					|en='Input is prohibited in status ""%1%""'");
					ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1%", Строка(Выборка.Статус));
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
				Отказ = Истина;
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
