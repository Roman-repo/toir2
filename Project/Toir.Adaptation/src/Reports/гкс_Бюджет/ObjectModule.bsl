
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	НастройкиКД = КомпоновщикНастроек.ПолучитьНастройки();
	ДопПараметры = Новый Структура("ПланДатаНачала,ПланДатаОкончания,ПоВД,ПоППР,ПоВО", Дата(1, 1, 1), Дата(3999, 1, 1), Истина, Истина, Истина);
	ДопПараметры.Вставить("АктДатаНачала", Дата(1, 1, 1));
	ДопПараметры.Вставить("АктДатаОкончания", Дата(3999, 1, 1));
	ПараметрПериодАкт = Новый ПараметрКомпоновкиДанных("АктуальныйПериод");
	ПараметрПериодПлан = Новый ПараметрКомпоновкиДанных("ПлановыйПериод");
	ПараметрПодр = Новый ПараметрКомпоновкиДанных("Подразделение");
	ПараметрСтатус = Новый ПараметрКомпоновкиДанных("СтатусСогласования");
	ПараметрПоВД = Новый ПараметрКомпоновкиДанных("ПоВД");
	ПараметрПоППР = Новый ПараметрКомпоновкиДанных("ПоППР");
	ПараметрПоВО = Новый ПараметрКомпоновкиДанных("ПоВО");
	
	Для Каждого СтрокаПараметр Из НастройкиКД.ПараметрыДанных.Элементы Цикл
		Если СтрокаПараметр.Использование Тогда
			Если СтрокаПараметр.Параметр = ПараметрПериодПлан Тогда
				ДопПараметры.ПланДатаНачала = СтрокаПараметр.Значение.ДатаНачала;
				ДопПараметры.ПланДатаОкончания = СтрокаПараметр.Значение.ДатаОкончания;
			ИначеЕсли СтрокаПараметр.Параметр = ПараметрПериодАкт Тогда
				ДопПараметры.АктДатаНачала = СтрокаПараметр.Значение.ДатаНачала;
				ДопПараметры.АктДатаОкончания = СтрокаПараметр.Значение.ДатаОкончания;
			ИначеЕсли СтрокаПараметр.Параметр = ПараметрПодр Тогда
				ДопПараметры.Вставить("Подразделение", СтрокаПараметр.Значение);
			ИначеЕсли СтрокаПараметр.Параметр = ПараметрСтатус Тогда
				ДопПараметры.Вставить("Статус", СтрокаПараметр.Значение);
			КонецЕсли;
		КонецЕсли;
		Если СтрокаПараметр.Параметр = ПараметрПоВД Тогда
			ДопПараметры.Вставить("ПоВД", СтрокаПараметр.Значение);
		ИначеЕсли СтрокаПараметр.Параметр = ПараметрПоППР Тогда
			ДопПараметры.Вставить("ПоППР", СтрокаПараметр.Значение);
		ИначеЕсли СтрокаПараметр.Параметр = ПараметрПоВО Тогда
			ДопПараметры.Вставить("ПоВО", СтрокаПараметр.Значение);
		КонецЕсли;
	КонецЦикла;
	////
	НастройкиОсновнойСхемы = КомпоновщикНастроек.ПолучитьНастройки();
	ВнешниеНаборыДанных = Новый Структура("ТабДанных1", ПолучитьОсновнуюТаблицу(ДопПараметры));
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКД, ДанныеРасшифровки);
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных, ДанныеРасшифровки);
	
	ПроцессорВыводаВТабличныйДокумент = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВыводаВТабличныйДокумент.УстановитьДокумент(ДокументРезультат);	
	ПроцессорВыводаВТабличныйДокумент.Вывести(ПроцессорКомпоновкиДанных);
	// обойти и схлопнуть ячейки
	НомерКолонки = 1;
	ВертикальноеТерпение = 10;
	
	НомерСтроки = 1;
	НомерПервой = 0;
	НомерПоследней = 0;
	Пока ВертикальноеТерпение > 0 Цикл
		ЭтоПустая = Истина;
		ТекстКолонки = ДокументРезультат.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки).Текст;
		ЭтоПустая = Не ЗначениеЗаполнено(ТекстКолонки);
		Если ЭтоПустая Тогда 
			ВертикальноеТерпение = ВертикальноеТерпение - 1;
			Если НомерПоследней > 0 Тогда 
				Сч = 1;
				Пока Сч < 34 Цикл
					ДокументРезультат.Область(НомерПервой, Сч, НомерПоследней, Сч).Объединить();
					Сч = Сч + 1;
					Если Сч = 20 Тогда 
						Сч = 33;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			НомерПоследней = 0;
		Иначе    
			ВертикальноеТерпение = 10;
			Если ТекстКолонки = "&+" Тогда 
				НомерПоследней = НомерСтроки;
			Иначе
				Если НомерПоследней > 0 Тогда 
					Сч = 1;
					Пока Сч < 34 Цикл
						ДокументРезультат.Область(НомерПервой, Сч, НомерПоследней, Сч).Объединить();
						Сч = Сч + 1;
						Если Сч = 20 Тогда 
							Сч = 33;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				НомерПервой = НомерСтроки;
				НомерПоследней = 0;
			КонецЕсли;
		КонецЕсли;
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
		
КонецПроцедуры


Функция ПолучитьОсновнуюТаблицу(ДопПараметры)
	#Область ПостроениеТаблицы
	ОпТипПриоритет = Новый ОписаниеТипов("СправочникСсылка.торо_КатегорииРиска");
	ОпТипОР = Новый ОписаниеТипов("СправочникСсылка.торо_ОбъектыРемонта");
	ОпТипВР = Новый ОписаниеТипов("СправочникСсылка.торо_ВидыРемонтов");
	ОпТипПодр = Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия");
	ОпТипОрг = Новый ОписаниеТипов("СправочникСсылка.Организации");
	ОпТипСогл = Новый ОписаниеТипов("СправочникСсылка.торо_СтатусыСогласованияДокументовРемонтныхРабот");
	ОпТипСмета = Новый ОписаниеТипов("ДокументСсылка.торо_ЗаявкаНаРемонт");
	ОпТипНоменклатура = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ОпТипКвалификация = Новый ОписаниеТипов("СправочникСсылка.торо_КвалификацииРемонтногоПерсонала");
	
	ОпТипСпособСогл = Новый ОписаниеТипов("СправочникСсылка.торо_СпособыСогласованияДокументов");
	
	МассТипов = Новый Массив();
	МассТипов.Добавить(Тип("ДокументСсылка.торо_ВнешнееОснованиеДляРабот"));
	МассТипов.Добавить(Тип("ДокументСсылка.торо_ВыявленныеДефекты"));
	МассТипов.Добавить(Тип("ДокументСсылка.торо_ПланГрафикРемонта"));
	ОпТипОснование = Новый ОписаниеТипов(МассТипов);
	ОпТипСтрока150 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(150));
	ОпТипСтрока36 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(36));
	ОпТипСтрока16 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(16));
	ОпТипСтрока = Новый ОписаниеТипов("Строка");
	ОпТипБулево = Новый ОписаниеТипов("Булево");
	ОпТипДата = Новый ОписаниеТипов("Дата", , , , , Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя));
	ОпТипЧисло15_2 = Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 2));
	//
	Таб = Новый ТаблицаЗначений();
	Таб.Колонки.Добавить("ДокОсн", ОпТипОснование);
	Таб.Колонки.Добавить("КоммОсн", ОпТипСтрока);
	Таб.Колонки.Добавить("НомерСметы", ОпТипСтрока16);
	Таб.Колонки.Добавить("Ссылка", ОпТипСмета);
	Таб.Колонки.Добавить("Организация", ОпТипОрг);
	Таб.Колонки.Добавить("Подразделение", ОпТипПодр);
	Таб.Колонки.Добавить("НуженОстанов", ОпТипБулево);
	Таб.Колонки.Добавить("СпособСогл", ОпТипСпособСогл);
	Таб.Колонки.Добавить("СтатусСогл", ОпТипСогл);
	Таб.Колонки.Добавить("КоммСметы", ОпТипСтрока);
	Таб.Колонки.Добавить("ОР", ОпТипОР);
	Таб.Колонки.Добавить("ВР", ОпТипВР);
	Таб.Колонки.Добавить("Описание", ОпТипСтрока);
	Таб.Колонки.Добавить("ПланДатаНачала", ОпТипДата);
	Таб.Колонки.Добавить("ПланДатаОкончания", ОпТипДата);
	Таб.Колонки.Добавить("АктДатаНачала", ОпТипДата);
	Таб.Колонки.Добавить("АктДатаОкончания", ОпТипДата);
	Таб.Колонки.Добавить("ПланСтоимость", ОпТипСтрока16);
	Таб.Колонки.Добавить("Валюта", ОпТипСтрока16);
	Таб.Колонки.Добавить("Номенклатура", ОпТипНоменклатура);
	Таб.Колонки.Добавить("КодНом", ОпТипСтрока16);
	Таб.Колонки.Добавить("ЕдИзмНом", ОпТипСтрока16);
	Таб.Колонки.Добавить("ЦенаНом", ОпТипСтрока16);
	Таб.Колонки.Добавить("КолвоНом", ОпТипСтрока16);
	Таб.Колонки.Добавить("СуммаНом", ОпТипСтрока16);
	Таб.Колонки.Добавить("ДавальческийНом", ОпТипБулево);
	Таб.Колонки.Добавить("Квал", ОпТипСтрока16);
	Таб.Колонки.Добавить("КодКвал", ОпТипСтрока16);
	Таб.Колонки.Добавить("Трудоемкость", ОпТипСтрока16);
	Таб.Колонки.Добавить("ЦенаКвал", ОпТипСтрока16);
	Таб.Колонки.Добавить("СуммаКвал", ОпТипСтрока16);
	Таб.Колонки.Добавить("Исполнитель", ОпТипСтрока150);
	Таб.Колонки.Добавить("Ответственный", ОпТипСтрока150);
	//
	Таб.Колонки.Добавить("СпособСоглТекст", ОпТипСтрока150);
	Таб.Колонки.Добавить("СтатусСоглТекст", ОпТипСтрока150);
	Таб.Колонки.Добавить("СтатусСметыТекст", ОпТипСтрока150);
	Таб.Колонки.Добавить("НуженОстановТекст", ОпТипСтрока16);
	Таб.Колонки.Добавить("ДокОснТекст", ОпТипСтрока150);
	
	                    	
	#КонецОбласти
	//
	#Область ТекстЗапроса
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сметы.Ссылка КАК Ссылка,
		|	Сметы.ДатаНачала КАК ДатаНачала,
		|	Сметы.ДатаОкончания КАК ДатаОкончания,
		|	Сметы.ОписаниеРемонта КАК ОписаниеРемонта,
		|	Сметы.ОбъектРемонта КАК ОбъектРемонта,
		|	Сметы.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
		|	ЕСТЬNULL(Рег.ДатаНачала, Сметы.ДатаНачала) КАК АктДатаНачала,
		|	ЕСТЬNULL(Рег.ДатаОкончания, Сметы.ДатаОкончания) КАК АктДатаОкончания,
		|	Сметы.Ссылка.Организация.гкс_ВидЦены.ВалютаЦены КАК ОргВалюта,
		|	Сметы.Ссылка.Организация.гкс_ВидЦены КАК ВидЦены,
		|	Сметы.ID КАК ИД_Ремонта
		|ПОМЕСТИТЬ ВсеРемонты
		|ИЗ
		|	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК Сметы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК Рег
		|		ПО Сметы.ID = Рег.IDРемонта
		|ГДЕ
		|	Сметы.Ссылка.Проведен
		|	И Сметы.Ссылка.ПометкаУдаления = ЛОЖЬ
		|	И Сметы.ДатаНачала >= &ПланДатаНачала
		|	И Сметы.ДатаНачала < &ПланДатаОкончания
		|	И ЕСТЬNULL(Рег.ДатаНачала, Сметы.ДатаНачала) >= &АктДатаНачала
		|	И ЕСТЬNULL(Рег.ДатаНачала, Сметы.ДатаНачала) < &АктДатаОкончания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Сметы.Ссылка.Номер КАК НомерСметы,
		|	Сметы.Ссылка КАК Ссылка,
		|	Сметы.Ссылка.Организация КАК Организация,
		|	Сметы.Ссылка.Подразделение КАК Подразделение,
		|	Сметы.Ссылка.Комментарий КАК КоммСметы,
		|	Сметы.Ссылка.Ответственный КАК Ответственный,
		|	Сметы.Ссылка.СпособСогласования КАК СпособСогл,
		|	торо_ТекущиеСтатусыСогласованияДокументов.СтатусДокумента КАК СтатусСогл,
		|	торо_СтатусыДокументов.СтатусДокумента КАК СтатусСметы,
		|	Сметы.Ссылка.гкс_НуженОстанов КАК НуженОстанов,
		|	Сметы.Ссылка.гкс_Валюта КАК Валюта,
		|	Сметы.ДатаНачала КАК ДатаНачала,
		|	Сметы.ДатаОкончания КАК ДатаОкончания,
		|	Сметы.ОписаниеРемонта КАК ОписаниеРемонта,
		|	Сметы.ОбъектРемонта КАК ОбъектРемонта,
		|	Сметы.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
		|	Сметы.АктДатаНачала КАК АктДатаНачала,
		|	Сметы.АктДатаОкончания КАК АктДатаОкончания,
		|	Сметы.ИД_Ремонта КАК ИД_Ремонта,
		|	ЕСТЬNULL(ВнешниеО.Регистратор, ЕСТЬNULL(Дефекты.Регистратор, ППР.Регистратор)) КАК ДокОсн
		|ПОМЕСТИТЬ ВсеРемонты2
		|ИЗ
		|	ВсеРемонты КАК Сметы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВнешниеОснованияДляРабот.СрезПоследних(, Регистратор ССЫЛКА Документ.торо_ВнешнееОснованиеДляРабот) КАК ВнешниеО
		|		ПО Сметы.ИД_Ремонта = ВнешниеО.ID
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ВыявленныеДефекты.СрезПоследних КАК Дефекты
		|		ПО Сметы.ИД_Ремонта = Дефекты.ID
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних КАК ППР
		|		ПО Сметы.ИД_Ремонта = ППР.ID
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущиеСтатусыСогласованияДокументов КАК торо_ТекущиеСтатусыСогласованияДокументов
		|		ПО (торо_ТекущиеСтатусыСогласованияДокументов.СогласуемыйДокумент = Сметы.Ссылка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыДокументовЗаявокУстановленные.СрезПоследних КАК торо_СтатусыДокументов
		|		ПО Сметы.Ссылка = торо_СтатусыДокументов.ИзменяемыйДокумент
		|ГДЕ
		|	ИСТИНА
		|	И &Отбор1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВсеРемонты.Ссылка КАК Ссылка,
		|	ВсеРемонты.ИД_Ремонта КАК ИД_Ремонта,
		|	ВсеРемонты.ОргВалюта КАК ОргВалюта,
		|	ВсеРемонты.ВидЦены КАК ВидЦены
		|ПОМЕСТИТЬ УникальныеРемонты
		|ИЗ
		|	ВсеРемонты КАК ВсеРемонты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВсеРемонты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВсеРемонты.НомерСметы КАК НомерСметы,
		|	ВсеРемонты.Ссылка КАК Ссылка,
		|	ВсеРемонты.Организация КАК Организация,
		|	ВсеРемонты.Организация.гкс_ВидЦены.ВалютаЦены КАК ОргВалюта,
		|	ВсеРемонты.Подразделение КАК Подразделение,
		|	ВсеРемонты.КоммСметы КАК КоммСметы,
		|	ВсеРемонты.Ответственный КАК Ответственный,
		|	ВсеРемонты.СпособСогл КАК СпособСогл,
		|	ВсеРемонты.СтатусСметы КАК СтатусСметы,
		|	ВсеРемонты.НуженОстанов КАК НуженОстанов,
		|	ВсеРемонты.Валюта КАК Валюта,
		|	ВсеРемонты.ДатаНачала КАК ПланДатаНачала,
		|	ВсеРемонты.ДатаОкончания КАК ПланДатаОкончания,
		|	ВсеРемонты.ОписаниеРемонта КАК Описание,
		|	ВсеРемонты.ОбъектРемонта КАК ОР,
		|	ВсеРемонты.ВидРемонтныхРабот КАК ВР,
