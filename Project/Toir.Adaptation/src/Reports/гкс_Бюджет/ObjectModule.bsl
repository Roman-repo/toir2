	Запрос.УстановитьПараметр("ПланДатаНачала", ДопПараметры.ПланДатаНачала);
	Запрос.УстановитьПараметр("ПланДатаОкончания", ДопПараметры.ПланДатаОкончания);
	Запрос.УстановитьПараметр("АктДатаНачала", ДопПараметры.АктДатаНачала);
	Запрос.УстановитьПараметр("АктДатаОкончания", ДопПараметры.АктДатаОкончания);
	МассивОтбора = Новый Массив();
	Если ДопПараметры.ПоВД Тогда 
		МассивОтбора.Добавить("Не Дефекты.ID есть NULL");
	КонецЕсли;
	Если ДопПараметры.ПоВО Тогда 
		МассивОтбора.Добавить("Не ВнешниеО.ID есть NULL");
	КонецЕсли;
	Если ДопПараметры.ПоППР Тогда 
		МассивОтбора.Добавить("Не ППР.ID есть NULL");
	КонецЕсли;
	Если МассивОтбора.Количество() Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &Отбор1", " И (" + СтрСоединить(МассивОтбора, " ИЛИ ") + ") И &Отбор1");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &Отбор1", " И Ложь И &Отбор1");
	КонецЕсли;
	//Если ДопПараметры.Свойство("Подразделение") Тогда 
	//	Запрос.УстановитьПараметр("Подразделение", ДопПараметры.Подразделение);
	//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Отбор1", "РемонтыЗаявки.Ссылка.Подразделение В (&Подразделение)");
	//Иначе
	//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Отбор1", "Истина");
	//КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &Отбор1", " ");
	
	#КонецОбласти
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	НомерРем = 4;
	НомерМЗ = 7;
	НомерТЗ = 8;
	НомерИсп = 9;
	НомерКвал = 10;
	
	ВыборкаРем1 = РезультатЗапроса[НомерРем].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ВыборкаМЗ1 = РезультатЗапроса[НомерМЗ].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаТЗ1 = РезультатЗапроса[НомерТЗ].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИсп1 = РезультатЗапроса[НомерИсп].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаКвал = РезультатЗапроса[НомерКвал].Выбрать(); // стоимость квалификаций
	// Курс валют не смотрим
	Пока ВыборкаРем1.Следующий() Цикл
		ВыборкаМЗ1.Сбросить();
		Если ВыборкаМЗ1.НайтиСледующий(Новый Структура("Ссылка", ВыборкаРем1.Ссылка)) Тогда 
			ВыборкаМЗ2 = ВыборкаМЗ1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Иначе
			ВыборкаМЗ2 = Неопределено;
		КонецЕсли;
		ВыборкаТЗ1.Сбросить();
		Если ВыборкаТЗ1.НайтиСледующий(Новый Структура("Ссылка", ВыборкаРем1.Ссылка)) Тогда 
			ВыборкаТЗ2 = ВыборкаТЗ1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Иначе
			ВыборкаТЗ2 = Неопределено;
		КонецЕсли;
		ВыборкаИсп1.Сбросить();
		Если ВыборкаИсп1.НайтиСледующий(Новый Структура("Ссылка", ВыборкаРем1.Ссылка)) Тогда 
			ВыборкаИсп2 = ВыборкаИсп1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Иначе
			ВыборкаИсп2 = Неопределено;
		КонецЕсли;
		ВыборкаРем2 = ВыборкаРем1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаРем2.Следующий() Цикл
			ВыборкаРем = ВыборкаРем2.Выбрать();
			ВыборкаРем.Следующий(); // для каждого ремонта только одна строка. чтобы небыло дублей
			МассМЗ = Новый Массив(); // Таблица материалов
			МассТЗ = Новый Массив(); // Таблица трудовых
			МассИсп = Новый Массив(); // Таблица исполнителей
			Если Не ВыборкаМЗ2 = Неопределено Тогда 
				ВыборкаМЗ2.Сбросить();
				Если ВыборкаМЗ2.НайтиСледующий(Новый Структура("ИД_Ремонта", ВыборкаРем.ИД_Ремонта)) Тогда 
					ВыборкаМЗ = ВыборкаМЗ2.Выбрать();
					Пока ВыборкаМЗ.Следующий() Цикл
						ЭтоПерваяНоменклатура = Истина;
						СтрокаТаблицы = ПолучитьСтрокуМЗ();
						ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыборкаМЗ);
						СтрокаТаблицы.СуммаНом = ВыборкаМЗ.ЦенаНом * ВыборкаМЗ.КолвоНом;
						Для Каждого СтрокаМассива Из МассМЗ Цикл
							Если СтрокаМассива.Номенклатура = ВыборкаМЗ.Номенклатура Тогда 
								СтрокаМассива.СуммаНом = СтрокаМассива.СуммаНом + СтрокаТаблицы.СуммаНом;
								СтрокаМассива.КолвоНом = СтрокаМассива.КолвоНом + СтрокаТаблицы.КолвоНом;
								ЭтоПерваяНоменклатура = Ложь;
							КонецЕсли;
						КонецЦикла;
						Если ЭтоПерваяНоменклатура Тогда 
							МассМЗ.Добавить(СтрокаТаблицы);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			Если Не ВыборкаТЗ2 = Неопределено Тогда 
				ВыборкаТЗ2.Сбросить();
				Если ВыборкаТЗ2.НайтиСледующий(Новый Структура("ИД_Ремонта", ВыборкаРем.ИД_Ремонта)) Тогда 
					ВыборкаТЗ = ВыборкаТЗ2.Выбрать();
					Пока ВыборкаТЗ.Следующий() Цикл
						СтрокаТаблицы = ПолучитьСтрокуТЗ();
						ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыборкаТЗ);
						СтрокаТаблицы.Трудоемкость = ВыборкаТЗ.КолвоКвал * (ВыборкаТЗ.ВремяРаботы / 3600);
						ВыборкаКвал.Сбросить();
						Если ВыборкаКвал.НайтиСледующий(Новый Структура("Квал,Валюта", ВыборкаТЗ.Квал, ВыборкаРем.ОргВалюта)) Тогда 
							СтрокаТаблицы.СуммаКвал = СтрокаТаблицы.Трудоемкость * ВыборкаКвал.Стоимость;
							СтрокаТаблицы.ЦенаКвал = ВыборкаКвал.Стоимость;
						КонецЕсли;
						ЭтоПерваяКвалификация = Истина;
						Для Каждого СтрокаМассива Из МассТЗ Цикл
							Если СтрокаМассива.Квал = ВыборкаТЗ.Квал Тогда 
								СтрокаМассива.СуммаКвал = СтрокаМассива.СуммаКвал + СтрокаТаблицы.СуммаКвал;
								СтрокаМассива.Трудоемкость = СтрокаМассива.Трудоемкость + СтрокаТаблицы.Трудоемкость;
								ЭтоПерваяКвалификация = Ложь;
							КонецЕсли;
						КонецЦикла;
						Если ЭтоПерваяКвалификация Тогда 
							МассТЗ.Добавить(СтрокаТаблицы);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			Если Не ВыборкаИсп2 = Неопределено Тогда 
				ВыборкаИсп2.Сбросить();
				Если ВыборкаИсп2.НайтиСледующий(Новый Структура("ИД_Ремонта", ВыборкаРем.ИД_Ремонта)) Тогда 
					ВыборкаИсп = ВыборкаИсп2.Выбрать();
					Пока ВыборкаИсп.Следующий() Цикл
						СтрокаТаблицы = ПолучитьСтрокуИсп();
						ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыборкаИсп);
						МассИсп.Добавить(СтрокаТаблицы);
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			СуммаРемонта = 0;
			Для Каждого СтрокаМассива Из МассТЗ Цикл
				СуммаРемонта = СуммаРемонта + СтрокаМассива.СуммаКвал;
			КонецЦикла;
			Для Каждого СтрокаМассива Из МассМЗ Цикл
				СуммаРемонта = СуммаРемонта + СтрокаМассива.СуммаНом;
			КонецЦикла;
			МаксСтрок = Макс(МассМЗ.Количество(), МассТЗ.Количество(), МассИсп.Количество());
			// Заполняем паралельные таблицы в строках
			Пока МаксСтрок > МассТЗ.Количество() Цикл
				МассТЗ.Добавить(ПолучитьСтрокуТЗ());
			КонецЦикла;
			Пока МаксСтрок > МассМЗ.Количество() Цикл
				МассМЗ.Добавить(ПолучитьСтрокуМЗ());
			КонецЦикла;
			Пока МаксСтрок > МассИсп.Количество() Цикл
				МассИсп.Добавить(ПолучитьСтрокуИсп());
			КонецЦикла;
			ПерваяСтрока = Неопределено;
			Если МаксСтрок > 0 Тогда 
				Для Сч = 1 По МаксСтрок Цикл
					СтрТаб = Таб.Добавить();
					// без схлопывания
					ЗаполнитьЗначенияСвойств(СтрТаб, ВыборкаРем);
					СтрТаб.ДокОснТекст = Строка(ВыборкаРем.ДокОсн);
					СтрТаб.СпособСоглТекст = Строка(ВыборкаРем.СпособСогл);
					Если ЗначениеЗаполнено(ВыборкаРем.СтатусСогл) Тогда 
						СтрТаб.СтатусСоглТекст = Строка(ВыборкаРем.СтатусСогл);
					Иначе
						СтрТаб.СтатусСоглТекст = "Черновик";
					КонецЕсли;
					Если ЗначениеЗаполнено(ВыборкаРем.СтатусСметы) Тогда 
						СтрТаб.СтатусСметыТекст = Строка(ВыборкаРем.СтатусСметы);
					Иначе
						СтрТаб.СтатусСметыТекст = "Черновик";
					КонецЕсли;
					СтрТаб.НуженОстановТекст = Строка(ВыборкаРем.НуженОстанов);
					СтрТаб.ПланСтоимость = СуммаРемонта;
					// для схлопывания
					//Если Сч = 1 Тогда 
					//	ПерваяСтрока = СтрТаб;
					//Иначе
					//	СтрТаб.ДокОснТекст = "&+";
					//КонецЕсли;
					
					СтрМЗ = МассМЗ[Сч - 1];
					СтрТЗ = МассТЗ[Сч - 1];
					СтрИсп = МассИсп[Сч - 1];
					ЗаполнитьЗначенияСвойств(СтрТаб, СтрМЗ);
					ЗаполнитьЗначенияСвойств(СтрТаб, СтрТЗ);
					ЗаполнитьЗначенияСвойств(СтрТаб, СтрИсп);
					Если ЗначениеЗаполнено(СтрТЗ.Квал) Тогда 
						СтрТаб.Трудоемкость = Формат(СтрТЗ.Трудоемкость, "ЧДЦ=2");
						СтрТаб.ЦенаКвал = Формат(СтрТЗ.ЦенаКвал, "ЧДЦ=2");
						СтрТаб.СуммаКвал = Формат(СтрТЗ.СуммаКвал, "ЧДЦ=2");
					Иначе
						СтрТаб.Трудоемкость = "";
						СтрТаб.ЦенаКвал = "";
						СтрТаб.СуммаКвал = "";
					КонецЕсли;
				КонецЦикла;
			Иначе
				ПерваяСтрока = Таб.Добавить();
			КонецЕсли;
			// для схлопывания
			//СтрТаб = ПерваяСтрока;
			//ЗаполнитьЗначенияСвойств(СтрТаб, ВыборкаРем);
			//СтрТаб.ДокОснТекст = Строка(ВыборкаРем.ДокОсн);
			//СтрТаб.СпособСоглТекст = Строка(ВыборкаРем.СпособСогл);
			//Если ЗначениеЗаполнено(ВыборкаРем.СтатусСогл) Тогда 
			//	СтрТаб.СтатусСоглТекст = Строка(ВыборкаРем.СтатусСогл);
			//Иначе
