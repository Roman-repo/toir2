	<calculatedField>
		<dataPath>ТекущийСрокПоставкиОтЗаказаКПлановой</dataPath>
		<expression>ВЫБОР КОГДА ДатаПоступления = ДАТАВРЕМЯ(1,1,1) ТОГДА ДАТАВРЕМЯ(1,1,1) ИНАЧЕ РАЗНОСТЬДАТ(ДатаПоступления, &amp;ТекДата, "ДЕНЬ") КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Текущий срок поставки от заказа к плановой</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>ДатаКонтроляПоступлений</dataPath>
		<expression>ДОБАВИТЬКДАТЕ(ДатаНачала, "ДЕНЬ", -30)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата контроля поступлений (30 дней до потребности)</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ДФ=dd.MM.yyyy</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
		</appearance>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>Date</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
	</calculatedField>
	<calculatedField>
		<dataPath>КритичностьОтклоненияПоставкиОтПлановойДатыРемонта</dataPath>
		<expression>ВЫБОР КОГДА РАЗНОСТЬДАТ(ДатаОкончания, ДатаПоступления, "ДЕНЬ")  &gt; 14 И РАЗНОСТЬДАТ(ДатаОкончания, ДатаПоступления, "ДЕНЬ") &lt; 30 ТОГДА "Не критично" КОГДА РАЗНОСТЬДАТ(ДатаОкончания, ДатаПоступления, "ДЕНЬ")  &gt; 30 И РАЗНОСТЬДАТ(ДатаОкончания, ДатаПоступления, "ДЕНЬ") &lt; 45 ТОГДА "Средняя критичность" КОГДА РАЗНОСТЬДАТ(ДатаОкончания, ДатаПоступления, "ДЕНЬ")  &gt; 45 ТОГДА "Крайне критично" КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Критичность отклонения поставки от плановой даты ремонта</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>уд_ДатаКонтроляПоступлений</dataPath>
		<expression>ВЫБОР КОГДА ДатаОкончания = ДАТАВРЕМЯ(1,1,1) ИЛИ ДатаПоступления = ДАТАВРЕМЯ(1,1,1) ТОГДА ДАТАВРЕМЯ(1,1,1) ИНАЧЕ ДОБАВИТЬКДАТЕ(ДатаОкончания, "ДЕНЬ", РАЗНОСТЬДАТ(ДатаОкончания, ДатаПоступления, "ДЕНЬ") + 30) КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата контроля поступлений (старый)</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ДФ=dd.MM.yyyy</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
		</appearance>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>Date</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
	</calculatedField>
	<totalField>
		<dataPath>СвободныеОстатки</dataPath>
		<expression>Сумма(СвободныеОстатки)</expression>
	</totalField>
