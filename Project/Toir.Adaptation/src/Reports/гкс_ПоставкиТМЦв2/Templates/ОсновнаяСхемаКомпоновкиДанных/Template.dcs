		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	торо_ЗаявкаНаРемонт.Ссылка КАК Ссылка,
	торо_ЗаявкаНаРемонт.Номер КАК Номер,
	торо_ЗаявкаНаРемонт.Ответственный КАК Ответственный,
	торо_ЗаявкаНаРемонтРемонтыОборудования.ОписаниеРемонта КАК ОписаниеРемонта,
	торо_ЗаявкаНаРемонтРемонтыОборудования.ДатаНачала КАК ДатаНачала,
	торо_ЗаявкаНаРемонтРемонтыОборудования.ДатаОкончания КАК ДатаОкончания,
	торо_ЗаявкаНаРемонтМатериальныеЗатраты.Номенклатура КАК Номенклатура,
	НоменклатураСсылка.Код КАК НоменклатураКод,
	торо_ЗаявкаНаРемонтМатериальныеЗатраты.Количество КАК КоличествоЗаявка,
	торо_ЗаявкаНаРемонтРемонтыОборудования.КритичностьДефекта КАК КритичностьДефекта,
	торо_ЗаявкаНаРемонт.гкс_НуженОстанов КАК гкс_НуженОстанов,
	ТекущиеСтатусы.СтатусДокумента КАК СтатусДокумента,
	торо_ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	НоменклатураСсылка.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	торо_ЗаявкаНаРемонтМатериальныеЗатраты.гкс_Давальческие КАК гкс_Давальческие,
	торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка КАК СсылкаАоВЭР,
	торо_АктОВыполненииЭтапаРабот.Номер КАК НомерАктаОВыполненииРабот,
	ТекущиеСтатусыАоВР.СтатусДокумента КАК СтатусАктаОВыполненииРабот,
	торо_ЗаявкаНаРемонт.гкс_СрочностьВоздействия КАК гкс_СрочностьВоздействия,
	торо_ЗаявкаНаРемонтРемонтыОборудования.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	СпрОбъектыРемонта.гкс_КатегорияРиска КАК ОбъектРемонтагкс_КатегорияРиска,
	торо_ЗаявкаНаРемонт.Подразделение КАК Подразделение
ИЗ
	Документ.торо_ЗаявкаНаРемонт КАК торо_ЗаявкаНаРемонт
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.МатериальныеЗатраты КАК торо_ЗаявкаНаРемонтМатериальныеЗатраты
		ПО торо_ЗаявкаНаРемонт.Ссылка = торо_ЗаявкаНаРемонтМатериальныеЗатраты.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК торо_ЗаявкаНаРемонтРемонтыОборудования
		ПО торо_ЗаявкаНаРемонт.Ссылка = торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК СпрОбъектыРемонта
		ПО (торо_ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта = СпрОбъектыРемонта.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСсылка
		ПО (торо_ЗаявкаНаРемонтМатериальныеЗатраты.Номенклатура = НоменклатураСсылка.Ссылка)		
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот.ДокументыОснования КАК торо_АктОВыполненииЭтапаРаботДокументыОснования
		ПО торо_ЗаявкаНаРемонт.Ссылка = торо_АктОВыполненииЭтапаРаботДокументыОснования.ДокументОснование
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.торо_АктОВыполненииЭтапаРабот КАК торо_АктОВыполненииЭтапаРабот
		ПО (торо_АктОВыполненииЭтапаРаботДокументыОснования.Ссылка = торо_АктОВыполненииЭтапаРабот.Ссылка)
		
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущиеСтатусыСогласованияДокументов КАК ТекущиеСтатусы
		ПО торо_ЗаявкаНаРемонт.Ссылка = ТекущиеСтатусы.СогласуемыйДокумент
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущиеСтатусыСогласованияДокументов КАК ТекущиеСтатусыАоВР
		ПО (торо_АктОВыполненииЭтапаРабот.Ссылка = ТекущиеСтатусыАоВР.СогласуемыйДокумент)
ГДЕ
	//торо_ЗаявкаНаРемонт.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания 
	торо_ЗаявкаНаРемонтРемонтыОборудования.ДатаНачала МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
{ГДЕ
	(торо_ЗаявкаНаРемонт.Ссылка В (&amp;Документ)),
	(торо_ЗаявкаНаРемонт.Организация В (&amp;Организация)),
	(торо_ЗаявкаНаРемонт.Подразделение В (&amp;Подразделение))}</query>
	</dataSet>
