		<field xsi:type="DataSetFieldField">
			<dataPath>КатегорияКритичности</dataPath>
			<field>КатегорияКритичности</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Категория критичности</v8:content>
