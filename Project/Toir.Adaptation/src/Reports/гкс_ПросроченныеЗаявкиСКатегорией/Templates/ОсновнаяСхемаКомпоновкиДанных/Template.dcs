		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Организация</dataPath>
			<field>Организация</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗаявкаНаРемонт.Ссылка КАК Ссылка,
	ЗаявкаНаРемонтРемонтыОборудования.ДатаНачала КАК ДатаНачалаРемонта,
	ЗаявкаНаРемонтРемонтыОборудования.ДатаОкончания КАК ДатаОкончанияРемонта,
	ЗаявкаНаРемонт.Номер КАК Номер,
	ЗаявкаНаРемонт.Дата КАК ДатаЗаявки,
	ЗаявкаНаРемонт.Организация КАК Организация,
	ЗаявкаНаРемонт.Подразделение КАК Подразделение,
	ЗаявкаНаРемонтРемонтыОборудования.ОбъектРемонта КАК ОбъектРемонта,
	ЗаявкаНаРемонтРемонтыОборудования.ОписаниеРемонта КАК ОписаниеРемонта,
	ЗаявкаНаРемонт.Ответственный КАК ОтветственноеЛицо,
	ЗаявкаНаРемонтРемонтыОборудования.КритичностьДефекта КАК КатегорияКритичности
ПОМЕСТИТЬ ВТЗаявки
ИЗ
	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК ЗаявкаНаРемонтРемонтыОборудования
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт КАК ЗаявкаНаРемонт
		ПО (ЗаявкаНаРемонтРемонтыОборудования.Ссылка = ЗаявкаНаРемонт.Ссылка)
ГДЕ
	НЕ ЗаявкаНаРемонт.ПометкаУдаления
	И ЗаявкаНаРемонт.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СтатусыЗаявок.ИзменяемыйДокумент КАК ИзменяемыйДокумент,
	СтатусыЗаявок.СтатусДокумента КАК СтатусДокумента
ПОМЕСТИТЬ ВТСтатусыЗаявок
ИЗ
	РегистрСведений.торо_СтатусыДокументовЗаявокУстановленные.СрезПоследних(
			,
			ИзменяемыйДокумент В
				(ВЫБРАТЬ
					ВТЗаявки.Ссылка КАК Ссылка
				ИЗ
					ВТЗаявки КАК ВТЗаявки)) КАК СтатусыЗаявок
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТЗаявки.Ссылка КАК Ссылка,
	ВТЗаявки.ДатаНачалаРемонта КАК ДатаНачалаРемонта,
	ВТЗаявки.ДатаОкончанияРемонта КАК ДатаОкончанияРемонта,
	ВТЗаявки.Номер КАК Номер,
	ВТЗаявки.ДатаЗаявки КАК ДатаЗаявки,
	ВТЗаявки.Организация КАК Организация,
	ВТЗаявки.Подразделение КАК Подразделение,
	ВТЗаявки.ОбъектРемонта КАК ОбъектРемонта,
	ВТЗаявки.ОписаниеРемонта КАК ОписаниеРемонта,
	ВТЗаявки.ОтветственноеЛицо КАК ОтветственноеЛицо,
	ВТЗаявки.КатегорияКритичности КАК КатегорияКритичности,
	ЕСТЬNULL(ВТСтатусыЗаявок.СтатусДокумента, "Черновик") КАК СтатусДокумента
ИЗ
	ВТЗаявки КАК ВТЗаявки
		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыЗаявок КАК ВТСтатусыЗаявок
		ПО (ВТЗаявки.Ссылка = ВТСтатусыЗаявок.ИзменяемыйДокумент)
</query>
	</dataSet>
