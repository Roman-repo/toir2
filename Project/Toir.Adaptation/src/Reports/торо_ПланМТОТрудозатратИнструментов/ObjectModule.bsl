
&ИзменениеИКонтроль("ПолучитьСодержательнуюЧастьЗапроса")
Функция Расш_гкс_ПолучитьСодержательнуюЧастьЗапроса()

	ЗапросТекст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_Ремонты.Регистратор КАК Смета,
	|	торо_Ремонты.ID КАК ID,
	|	торо_Ремонты.ОбъектРемонта КАК ОбъектРемонта,
	|	торо_Ремонты.ВидРемонта КАК ВидРемонта,
	#Удаление
	|	торо_Ремонты.ДатаНачалаПлан КАК ДатаНачалаПлан,
	|	торо_Ремонты.ДатаОкончанияПлан КАК ДатаОкончанияПлан
	#КонецУдаления
	#Вставка
	|	ЕстьNull(ТЧДат.ДатаНачала, торо_Ремонты.ДатаНачалаПлан) КАК ДатаНачалаПлан,
	|	ЕстьNull(ТЧДат.ДатаОкончания, торо_Ремонты.ДатаОкончанияПлан) КАК ДатаОкончанияПлан
	#КонецВставки
	|ПОМЕСТИТЬ ВТ_ВсеРемонтыПоЗаявкам
	|ИЗ
	|	РегистрСведений.торо_Ремонты КАК торо_Ремонты
	#Вставка
	|	Левое соединение РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК ТЧДат
	|	По ТЧДат.IDРемонта = торо_Ремонты.ID
	#КонецВставки
	|ГДЕ
	|	торо_Ремонты.Регистратор ССЫЛКА Документ.торо_ЗаявкаНаРемонт
	|	И торо_Ремонты.Активность = ИСТИНА
	#Удаление
	|{ГДЕ
	|	(торо_Ремонты.ДатаНачалаПлан <= &ОкончаниеПериода),
	|	(торо_Ремонты.ДатаОкончанияПлан >= &НачалоПериода)}
	#КонецУдаления
	#Вставка
	|{ГДЕ
	|	(ЕстьNull(ТЧДат.ДатаНачала, торо_Ремонты.ДатаНачалаПлан) <= &ОкончаниеПериода),
	|	(ЕстьNull(ТЧДат.ДатаОкончания, торо_Ремонты.ДатаОкончанияПлан) >= &НачалоПериода)}
	#КонецВставки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Смета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_ВсеРемонтыПоЗаявкам.Смета КАК Смета,
	|	ВТ_ВсеРемонтыПоЗаявкам.ID КАК ID,
	|	ВТ_ВсеРемонтыПоЗаявкам.ОбъектРемонта КАК ОбъектРемонта,
	|	ВТ_ВсеРемонтыПоЗаявкам.ВидРемонта КАК ВидРемонта,
	|	ВТ_ВсеРемонтыПоЗаявкам.ДатаНачалаПлан КАК ДатаНачалаПлан,
	|	ВТ_ВсеРемонтыПоЗаявкам.ДатаОкончанияПлан КАК ДатаОкончанияПлан,
	|	торо_ОтмененныеЗаявки.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ_РемонтыПоЗаявкам
	|ИЗ
	|	ВТ_ВсеРемонтыПоЗаявкам КАК ВТ_ВсеРемонтыПоЗаявкам
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ОтмененныеЗаявки КАК торо_ОтмененныеЗаявки
	|		ПО (торо_ОтмененныеЗаявки.Заявка = ВТ_ВсеРемонтыПоЗаявкам.Смета)
	|			И (торо_ОтмененныеЗаявки.ИДРемонта = ВТ_ВсеРемонтыПоЗаявкам.ID)
	|ГДЕ
	|	торо_ОтмененныеЗаявки.НомерСтроки ЕСТЬ NULL
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ПланГрафикРемонта.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	|	торо_ПланГрафикРемонта.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_ПланГрафикРемонта.Регистратор КАК ДокППР,
	|	торо_ПланГрафикРемонта.ID КАК ID,
	#Удаление
	|	торо_ПланГрафикРемонта.ДатаНачалаРемонтныхРабот КАК ДатаНачалаРемонтныхРабот,
	|	торо_ПланГрафикРемонта.ДатаОкончанияРемонтныхРабот КАК ДатаОкончанияРемонтныхРабот
	#КонецУдаления
	#Вставка
	|	ЕстьNull(ТЧДат.ДатаНачала, торо_ПланГрафикРемонта.ДатаНачалаРемонтныхРабот) КАК ДатаНачалаРемонтныхРабот,
	|	ЕстьNull(ТЧДат.ДатаОкончания, торо_ПланГрафикРемонта.ДатаОкончанияРемонтныхРабот) КАК ДатаОкончанияРемонтныхРабот
	#КонецВставки
	|ПОМЕСТИТЬ ВТ_РемонтыПоППР
	|ИЗ
	|	РегистрСведений.торо_ПлановыеРемонтныеРаботы.СрезПоследних(, &РассчетППР = ИСТИНА {(Подразделение = &Подразделение)}) КАК торо_ПланГрафикРемонта
	#Вставка
	|	Левое соединение РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК ТЧДат
	|	По ТЧДат.IDРемонта = торо_ПланГрафикРемонта.ID
	#КонецВставки
	|ГДЕ
	|	НЕ торо_ПланГрафикРемонта.Отменен
	|	И НЕ торо_ПланГрафикРемонта.Замещен
	|{ГДЕ
	|	(торо_ПланГрафикРемонта.Исполнитель = &Исполнитель)}
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	торо_ПлановыеМероприятияСрезПоследних.СписокОбъектов КАК СписокОбъектов,
	|	торо_ПлановыеМероприятияСрезПоследних.ВидМероприятия КАК ВидМероприятия,
	#Удаление
	|	торо_ПлановыеМероприятияСрезПоследних.ДатаНачала КАК ДатаНачала,
	|	торо_ПлановыеМероприятияСрезПоследних.ДатаОкончания КАК ДатаОкончания,
	#КонецУдаления
	#Вставка
	|	ЕстьNull(ТЧДат.ДатаНачала, торо_ПлановыеМероприятияСрезПоследних.ДатаНачала) КАК ДатаНачала,
	|	ЕстьNull(ТЧДат.ДатаОкончания, торо_ПлановыеМероприятияСрезПоследних.ДатаОкончания) КАК ДатаОкончания,
	#КонецВставки
	|	торо_ПлановыеМероприятияСрезПоследних.Регистратор КАК Регистратор,
	|	торо_ПлановыеМероприятияСрезПоследних.ID КАК ID
	|ПОМЕСТИТЬ ВТ_ПлановыеМероприятия
	|ИЗ
	|	РегистрСведений.торо_ПлановыеМероприятия.СрезПоследних(, &РассчетРеглМероприятий = ИСТИНА {(Подразделение = &Подразделение) }) КАК торо_ПлановыеМероприятияСрезПоследних
	#Вставка
	|	Левое соединение РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК ТЧДат
	|	По ТЧДат.IDРемонта = торо_ПлановыеМероприятияСрезПоследних.ID
	#КонецВставки
	|ГДЕ
	|	НЕ торо_ПлановыеМероприятияСрезПоследних.Отменен
	|{ГДЕ
	#Удаление
	|	(торо_ПлановыеМероприятияСрезПоследних.ДатаНачала <= &ОкончаниеПериода
	|			И торо_ПлановыеМероприятияСрезПоследних.ДатаНачала >= &НачалоПериода),
	#КонецУдаления
	#Вставка
	|	(ЕстьNull(ТЧДат.ДатаНачала, торо_ПлановыеМероприятияСрезПоследних.ДатаНачала) <= &ОкончаниеПериода
	|			И ЕстьNull(ТЧДат.ДатаНачала, торо_ПлановыеМероприятияСрезПоследних.ДатаНачала) >= &НачалоПериода),
	#КонецВставки
	|	(торо_ПлановыеМероприятияСрезПоследних.Исполнитель = &Исполнитель)}
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СписокОбъектов,
	|	ВидМероприятия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаНачалаПлан, ВТ_РемонтыПоППР.ДатаНачалаРемонтныхРабот) КАК ДатаРемонта,
	|	ВТ_РемонтыПоППР.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	|	ВТ_РемонтыПоППР.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаОкончанияПлан, ВТ_РемонтыПоППР.ДатаОкончанияРемонтныхРабот) КАК ДатаОкончания,
	|	ВТ_РемонтыПоППР.ДокППР КАК ДокППР,
	|	ВТ_РемонтыПоЗаявкам.Смета КАК Смета,
	|	ВТ_РемонтыПоППР.ID КАК ID
	|ПОМЕСТИТЬ ВТ_ППРБезСмет
	|ИЗ
	|	ВТ_РемонтыПоППР КАК ВТ_РемонтыПоППР
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РемонтыПоЗаявкам КАК ВТ_РемонтыПоЗаявкам
	|		ПО ВТ_РемонтыПоППР.ID = ВТ_РемонтыПоЗаявкам.ID
	|			И (&РассчетСметПоППР = ИСТИНА)
	|ГДЕ
	|	ВТ_РемонтыПоЗаявкам.Смета ЕСТЬ NULL
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ОбъектРемонтныхРабот,
	|	ВидРемонтныхРабот
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаНачалаПлан, ВТ_РемонтыПоППР.ДатаНачалаРемонтныхРабот) КАК ДатаРемонта,
	|	ВТ_РемонтыПоППР.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	|	ВТ_РемонтыПоППР.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	ЕСТЬNULL(ВТ_РемонтыПоЗаявкам.ДатаОкончанияПлан, ВТ_РемонтыПоППР.ДатаОкончанияРемонтныхРабот) КАК ДатаОкончания,
	|	ВТ_РемонтыПоППР.ДокППР КАК ДокППР,
	|	ВТ_РемонтыПоЗаявкам.Смета КАК Смета,
	|	ВТ_РемонтыПоППР.ID КАК ID
	|ПОМЕСТИТЬ ВТ_ППРСоСметами
	|ИЗ
	|	ВТ_РемонтыПоППР КАК ВТ_РемонтыПоППР
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РемонтыПоЗаявкам КАК ВТ_РемонтыПоЗаявкам
	|		ПО (ВТ_РемонтыПоЗаявкам.ID = ВТ_РемонтыПоППР.ID)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID,
	|	Смета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	#Удаление
	|	торо_Ремонты.ДатаНачалаПлан КАК ДатаРемонта,
	#КонецУдаления
	|	торо_Ремонты.ОбъектРемонта КАК Объект,
	|	торо_Ремонты.ВидРемонта КАК ВидРемонтныхРабот,
	#Удаление
	|	торо_Ремонты.ДатаОкончанияПлан КАК ДатаОкончания,
	#КонецУдаления
	#Вставка
	|	ЕстьNull(ТЧДат.ДатаНачала, торо_Ремонты.ДатаНачалаПлан) КАК ДатаРемонта,
	|	ЕстьNull(ТЧДат.ДатаОкончания, торо_Ремонты.ДатаОкончанияПлан) КАК ДатаОкончания,
	#КонецВставки
	|	NULL КАК ДокППР,
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка КАК Смета,
	|	торо_Ремонты.ID КАК ID
	|ПОМЕСТИТЬ СписокЗаявокНаОснованииДефектовИВнешнихОснований
	|ИЗ
	|	Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК торо_ЗаявкаНаРемонтРемонтыОборудования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_Ремонты КАК торо_Ремонты
	#Вставка
	|	Левое соединение РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК ТЧДат
	|	По ТЧДат.IDРемонта = торо_Ремонты.ID
	#КонецВставки
	|		ПО торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка = торо_Ремонты.Регистратор
	|			И торо_ЗаявкаНаРемонтРемонтыОборудования.ID = торо_Ремонты.ID
	|			И (&РассчетСметПоДефектам = ИСТИНА
	|					И ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонтРемонтыОборудования.ДокументИсточник) = ТИП(Документ.торо_ВыявленныеДефекты)
	|				ИЛИ &РассчетСметПоВнешнимОснованиям = ИСТИНА
	|					И ТИПЗНАЧЕНИЯ(торо_ЗаявкаНаРемонтРемонтыОборудования.ДокументИсточник) = ТИП(Документ.торо_ВнешнееОснованиеДляРабот))
	|{ГДЕ
	#Вставка
	|	(ЕстьNull(ТЧДат.ДатаНачала, торо_Ремонты.ДатаНачалаПлан) <= &ОкончаниеПериода
	|			И ЕстьNull(ТЧДат.ДатаОкончания, торо_Ремонты.ДатаОкончанияПлан) >= &НачалоПериода),
	#КонецВставки
	#Удаление
	|	(торо_Ремонты.ДатаНачалаПлан <= &ОкончаниеПериода
	|			И торо_Ремонты.ДатаОкончанияПлан >= &НачалоПериода),
	#КонецУдаления
	|	(торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка.Подразделение = &Подразделение)}
	|
	|СГРУППИРОВАТЬ ПО
	#Удаление
	|	торо_Ремонты.ДатаНачалаПлан,
	#КонецУдаления
	|	торо_Ремонты.ОбъектРемонта,
	|	торо_Ремонты.ВидРемонта,
	#Удаление
	|	торо_Ремонты.ДатаОкончанияПлан,
	#КонецУдаления
	#Вставка
	|	ЕстьNull(ТЧДат.ДатаНачала, торо_Ремонты.ДатаНачалаПлан),
	|	ЕстьNull(ТЧДат.ДатаОкончания, торо_Ремонты.ДатаОкончанияПлан),
	#КонецВставки
	|	торо_ЗаявкаНаРемонтРемонтыОборудования.Ссылка,
	|	торо_Ремонты.ID
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID,
	|	Смета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_ППРБезСмет.ДатаРемонта КАК ДатаРемонта,
	|	ВТ_ППРБезСмет.ОбъектРемонтныхРабот КАК ОбъектРемонтныхРабот,
	|	ВТ_ППРБезСмет.ВидРемонтныхРабот КАК ВидРемонтныхРабот,
	|	торо_НормативныеРемонтыОборудования.НормативныйРемонт КАК НормРемДляПольз,
	|	ВТ_ППРБезСмет.ДатаОкончания КАК ДатаОкончания,
	|	торо_НормативныеРемонтыОборудования.ГрафикРемонтныхРабот КАК ГрафикРемонтныхРабот,
	|	ВТ_ППРБезСмет.ДокППР КАК ДокППР,
	|	ВТ_ППРБезСмет.Смета КАК Смета,
	|	РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(ВТ_ППРБезСмет.ДатаРемонта, ДЕНЬ), КОНЕЦПЕРИОДА(ВТ_ППРБезСмет.ДатаОкончания, ДЕНЬ), ДЕНЬ) + 1 КАК КоличествоДней,
	|	ВТ_ППРБезСмет.ID КАК ID
	|ПОМЕСТИТЬ БазаОтчета_Ремонты_БезТехКарт
	|ИЗ
	|	ВТ_ППРБезСмет КАК ВТ_ППРБезСмет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.торо_НормативныеРемонтыОборудования КАК торо_НормативныеРемонтыОборудования
	|		ПО ВТ_ППРБезСмет.ОбъектРемонтныхРабот = торо_НормативныеРемонтыОборудования.ОбъектРемонта
	|			И ВТ_ППРБезСмет.ВидРемонтныхРабот = торо_НормативныеРемонтыОборудования.ВидРемонта
	|ГДЕ
	|	торо_НормативныеРемонтыОборудования.Приоритет
	|{ГДЕ
	|	(ВТ_ППРБезСмет.ДатаРемонта <= &ОкончаниеПериода
	|			И ВТ_ППРБезСмет.ДатаРемонта >= &НачалоПериода)}
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ППРБезСмет.ДатаРемонта,
	|	ВТ_ППРБезСмет.ОбъектРемонтныхРабот,
	|	ВТ_ППРБезСмет.ВидРемонтныхРабот,
	|	торо_НормативныеРемонтыОборудования.НормативныйРемонт,
	|	ВТ_ППРБезСмет.ДатаОкончания,
	|	торо_НормативныеРемонтыОборудования.ГрафикРемонтныхРабот,
	|	ВТ_ППРБезСмет.ДокППР,
	|	ВТ_ППРБезСмет.Смета,
	|	ВТ_ППРБезСмет.ID
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	торо_ПлановыеМероприятия.ДатаНачала,
	|	торо_МаршрутыРегламентныхМероприятий.ОбъектРемонта,
	|	торо_ПлановыеМероприятия.ВидМероприятия,
	|	торо_РегламентныеМероприятияИСпискиОбъектов.НормативныйРемонт,
	|	торо_ПлановыеМероприятия.ДатаОкончания,
	|	торо_РегламентныеМероприятияИСпискиОбъектов.ГрафикРемонтныхРабот,
	|	торо_ПлановыеМероприятия.Регистратор,
	|	NULL,
