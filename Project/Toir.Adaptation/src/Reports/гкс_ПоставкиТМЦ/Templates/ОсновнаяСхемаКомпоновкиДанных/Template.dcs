		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ДатыРемонтов.IDРемонта КАК ИД_Ремонта,
	ДатыРемонтов.ДатаНачала КАК ДатаНачала,
	ДатыРемонтов.ДатаОкончания КАК ДатаОкончания
ПОМЕСТИТЬ ВТ_ВсеРемонты
ИЗ
	РегистрСведений.торо_АктуальныеПлановыеДатыРемонтов КАК ДатыРемонтов
ГДЕ
	ДатыРемонтов.ДатаНачала &gt;= &amp;ДатаНачала
	И ДатыРемонтов.ДатаНачала &lt; &amp;ДатаОкончания
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ВсеРемонты.ИД_Ремонта КАК ИД_Ремонта,
	ВТ_ВсеРемонты.ДатаНачала КАК ДатаНачала,
	ВТ_ВсеРемонты.ДатаОкончания КАК ДатаОкончания,
	РемонтыЗаявки.Ссылка КАК Смета,
	РемонтыЗаявки.ОбъектРемонта КАК ОР,
	РемонтыЗаявки.ВидРемонтныхРабот КАК ВР,
	РемонтыЗаявки.ОписаниеРемонта КАК ОписаниеРемонта,
	СпрОбъектыРемонта.ТехНомер КАК ТехНомер,
	СпрОбъектыРемонта.гкс_КатегорияРиска КАК Приоритет,
	РемонтыЗаявки.КритичностьДефекта КАК Критичность,
	ДокЗаявкаНаРемонт.гкс_СрочностьВоздействия КАК Срочность
ПОМЕСТИТЬ ВТ_Заявки
ИЗ
	ВТ_ВсеРемонты КАК ВТ_ВсеРемонты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт.РемонтыОборудования КАК РемонтыЗаявки
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.торо_ОбъектыРемонта КАК СпрОбъектыРемонта
			ПО РемонтыЗаявки.ОбъектРемонта = СпрОбъектыРемонта.Ссылка
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт КАК ДокЗаявкаНаРемонт
			ПО РемонтыЗаявки.Ссылка = ДокЗаявкаНаРемонт.Ссылка
		ПО ВТ_ВсеРемонты.ИД_Ремонта = РемонтыЗаявки.ID
			И (ДокЗаявкаНаРемонт.Проведен)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	1 КАК Порядок,
	ЗНАЧЕНИЕ(Перечисление.гкс_СрочностьВоздействия.Немедленно) КАК Срочность
ПОМЕСТИТЬ ВТ_Порядок

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	2,
	ЗНАЧЕНИЕ(Перечисление.гкс_СрочностьВоздействия.Сегодня)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	3,
	ЗНАЧЕНИЕ(Перечисление.гкс_СрочностьВоздействия.ВТечениеНедели)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	4,
	ЗНАЧЕНИЕ(Перечисление.гкс_СрочностьВоздействия.ВТечениеМесяца)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	5,
	ЗНАЧЕНИЕ(Перечисление.гкс_СрочностьВоздействия.ПриСледующейОстановке)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	6,
	ЗНАЧЕНИЕ(Перечисление.гкс_СрочностьВоздействия.БуфернаяРабота)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	РегСтатусы.ИзменяемыйДокумент КАК Смета,
	РегСтатусы.СтатусДокумента КАК СтатусДокумента
ПОМЕСТИТЬ ВТ_СтатусыСмет
ИЗ
	РегистрСведений.торо_СтатусыДокументовЗаявокУстановленные.СрезПоследних(, ) КАК РегСтатусы
ГДЕ
	РегСтатусы.ИзменяемыйДокумент В
			(ВЫБРАТЬ
				ВТ_Заявки.Смета
			ИЗ
				ВТ_Заявки)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Заявки.ИД_Ремонта КАК ИД_Ремонта,
	ВТ_Заявки.ДатаНачала КАК ДатаНачала,
	ВТ_Заявки.ДатаОкончания КАК ДатаОкончания,
	ВТ_Заявки.Смета КАК Смета,
	ДокСмета.Номер КАК НомерСметы,
	ВТ_Заявки.ОР КАК ОР,
	ВТ_Заявки.ВР КАК ВР,
	ДокСмета.Организация КАК Организация,
	ДокСмета.СпособСогласования КАК СпособСоглСметы,
	ДокСмета.Подразделение КАК Подразделение,
	ДокСмета.гкс_НуженОстанов КАК НуженОстанов,
	ВТ_Заявки.ОписаниеРемонта КАК ОписаниеРемонта,
	ВТ_Заявки.ТехНомер КАК ТехНомер,
	ВТ_Заявки.Приоритет КАК Приоритет,
	ВТ_Заявки.Критичность КАК Критичность,
	ДокСмета.Комментарий КАК Комментарий,
	ДокСмета.Ответственный КАК Ответственный,
	ВТ_Заявки.Срочность КАК Срочность,
	ТекущиеСтатусы.СтатусДокумента КАК СтатусДокумента,
	РегСтатусы.СтатусДокумента КАК СтатусСметы,
	ДокСмета.гкс_ПлановаяСтоимостьРемонта КАК СтоимостьПлан,
	ВТ_Порядок.Порядок КАК Порядок 
	// Гкс+[TOIR20-525] Вялых Д.А. от 06.02.2025. Добавлено:{
	,ЕСТЬNULL(СтатусыДокументов.СтатусДокумента, "Черновик") КАК СтатусСметыРемонта
	// } Гкс-[TOIR20-525] Вялых Д.А. от 06.02.2025.
ИЗ
	ВТ_Заявки КАК ВТ_Заявки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_ТекущиеСтатусыСогласованияДокументов КАК ТекущиеСтатусы
		ПО ВТ_Заявки.Смета = ТекущиеСтатусы.СогласуемыйДокумент
		// Гкс+[TOIR20-525] Вялых Д.А. от 06.02.2025. Добавлено:{ 
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.торо_СтатусыДокументовЗаявокУстановленные.СрезПоследних КАК СтатусыДокументов
		ПО ВТ_Заявки.Смета = СтатусыДокументов.ИзменяемыйДокумент
		// } Гкс-[TOIR20-525] Вялых Д.А. от 06.02.2025.	
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтатусыСмет КАК РегСтатусы
		ПО ВТ_Заявки.Смета = РегСтатусы.Смета
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Порядок КАК ВТ_Порядок
		ПО (ВТ_Порядок.Срочность = ВТ_Заявки.Срочность)
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.торо_ЗаявкаНаРемонт КАК ДокСмета
		ПО ВТ_Заявки.Смета = ДокСмета.Ссылка</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных2</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>НоменклатураКод</dataPath>
