		<field xsi:type="DataSetFieldField">
			<dataPath>СтатусСметыРемонта</dataPath>
			<field>СтатусСметыРемонта</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
